From 7b59c326fe1ce9edc6d3137e9ace944bdb6c7842 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:04:38 +0200
Subject: [PATCH 112/149] mediatek: add 999-eth-46 netdev open fail handling
 for XDP

Restore the kernel patch that resets the eBPF program pointer to
old_prog and skips decreasing its ref-count when mtk_open() inside
mtk_xdp_setup() fails. MediaTek added this patch in 25.12 feeds
commit 2ccfc4d5 (2026-03-27) and then removed it in 5ba063f6
(2026-04-07) before the TIP import base, citing a conflict; the
fix is still desirable, so re-import as captured at MTK feeds
commit 5ee86b8.

Signed-off-by: John Crispin <john@phrozen.org>
---
 ...dd-netdev-open-fail-handling-for-xdp.patch | 52 +++++++++++++++++++
 1 file changed, 52 insertions(+)
 create mode 100644 target/linux/mediatek/patches-6.12/999-eth-46-mtk_eth_soc-add-netdev-open-fail-handling-for-xdp.patch

diff --git a/target/linux/mediatek/patches-6.12/999-eth-46-mtk_eth_soc-add-netdev-open-fail-handling-for-xdp.patch b/target/linux/mediatek/patches-6.12/999-eth-46-mtk_eth_soc-add-netdev-open-fail-handling-for-xdp.patch
new file mode 100644
index 0000000000..bd31a60513
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-46-mtk_eth_soc-add-netdev-open-fail-handling-for-xdp.patch
@@ -0,0 +1,52 @@
+---
+[v1] net: ethernet: mtk_eth_soc: add netdev open fail handling for xdp
+
+Reset eBPF program pointer to old_prog and do not decrease its ref-count
+if mtk_open routine in mtk_xdp_setup() fails.
+---
+v1: Add netdev open fail handling for XDP.
+---
+
+From a8a7fc664b0527414f7a29e313f13d947a861f92 Mon Sep 17 00:00:00 2001
+Date: Fri, 27 Mar 2026 15:00:24 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add netdev open fail handling
+ for xdp
+
+Reset eBPF program pointer to old_prog and do not decrease its ref-count
+if mtk_open routine in mtk_xdp_setup() fails.
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 15 ++++++++++++---
+ 1 file changed, 12 insertions(+), 3 deletions(-)
+
+diff --git a/drivers/net/ethernet/mediatek/mtk_eth_soc.c b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+index 833756d..9f01c11 100644
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -4732,12 +4732,21 @@ static int mtk_xdp_setup(struct net_device *dev, struct bpf_prog *prog,
+ 		mtk_stop(dev);
+ 
+ 	old_prog = rcu_replace_pointer(eth->prog, prog, lockdep_rtnl_is_held());
++
++	if (netif_running(dev) && need_update) {
++		int err;
++
++		err = mtk_open(dev);
++		if (err) {
++			rcu_assign_pointer(eth->prog, old_prog);
++
++			return err;
++		}
++	}
++
+ 	if (old_prog)
+ 		bpf_prog_put(old_prog);
+ 
+-	if (netif_running(dev) && need_update)
+-		return mtk_open(dev);
+-
+ 	return 0;
+ }
+ 
+-- 
+2.45.2
+
