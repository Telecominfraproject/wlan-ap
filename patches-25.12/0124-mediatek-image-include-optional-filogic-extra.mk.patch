From 105c1ab5c317fc2a6b7fb9303f58457b8924b522 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:43:21 +0200
Subject: [PATCH 124/149] mediatek: image: include optional filogic-extra.mk

Add an -include hook for $(SUBTARGET)-extra.mk so out-of-tree
device recipes can drop an additional makefile alongside
filogic.mk without modifying the in-tree image makefile.

Import of patches-base/0900 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/Makefile | 1 +
 1 file changed, 1 insertion(+)

diff --git a/target/linux/mediatek/image/Makefile b/target/linux/mediatek/image/Makefile
index 711ec84cca..a28fa5cfa3 100644
--- a/target/linux/mediatek/image/Makefile
+++ b/target/linux/mediatek/image/Makefile
@@ -39,6 +39,7 @@ define Build/asus-trx
 endef
 
 include $(SUBTARGET).mk
+-include $(SUBTARGET)-extra.mk
 
 define Image/Build
 	$(call Image/Build/$(1),$(1))
-- 
2.34.1

