From 0b1d931d2cfec46ad83017fa7d5ef326b9d550c3 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 08:02:38 +0200
Subject: [PATCH 149/149] mediatek: filogic: enable kmod-mt798x-2p5g-phy on
 MT798x targets

Add kmod-mt798x-2p5g-phy to DEVICE_PACKAGES for Bananapi BPI-R4-Lite,
MT7987A-RFB and MT7988A-RFB so the modular 2.5G PHY driver from
feeds/mtk-app is auto-loaded on those targets. Pairs with the move
to mt798x-2p5g-phy-firmware-internal in patches-base/1140-01.

Import of patches-base/1146 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index b571dcb3f9..cd581fa3fc 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -739,7 +739,8 @@ define Device/bananapi_bpi-r4-lite
   DEVICE_DTS_LOADADDR := 0x4ff00000
   DEVICE_PACKAGES := kmod-eeprom-at24 kmod-gpio-pca953x kmod-i2c-mux-pca954x \
 		     kmod-rtc-pcf8563 kmod-sfp kmod-usb3 e2fsprogs mkf2fs \
-		     mt798x-2p5g-phy-firmware-internal blkid kmod-hwmon-pwmfan
+		     mt798x-2p5g-phy-firmware-internal kmod-mt798x-2p5g-phy \
+		     blkid kmod-hwmon-pwmfan
   BLOCKSIZE := 128k
   PAGESIZE := 2048
   KERNEL_IN_UBI := 1
@@ -2077,7 +2078,7 @@ define Device/mediatek_mt7987a-rfb
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x4ff00000
-  DEVICE_PACKAGES := mt798x-2p5g-phy-firmware-internal kmod-sfp mkf2fs
+  DEVICE_PACKAGES := mt798x-2p5g-phy-firmware-internal kmod-mt798x-2p5g-phy kmod-sfp mkf2fs
   KERNEL_LOADADDR := 0x40000000
   KERNEL := kernel-bin | gzip
   KERNEL_INITRAMFS := kernel-bin | lzma | \
@@ -2125,7 +2126,7 @@ define Device/mediatek_mt7988a-rfb
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x45f00000
-  DEVICE_PACKAGES := mt798x-2p5g-phy-firmware-internal kmod-sfp kmod-phy-aquantia blkid mkf2fs
+  DEVICE_PACKAGES := mt798x-2p5g-phy-firmware-internal kmod-mt798x-2p5g-phy kmod-sfp kmod-phy-aquantia blkid mkf2fs
   KERNEL_LOADADDR := 0x46000000
   KERNEL := kernel-bin | gzip
   KERNEL_INITRAMFS := kernel-bin | lzma | \
-- 
