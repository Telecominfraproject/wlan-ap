From 4ea04634077a74c1ce535b3b4113bc08d93ec681 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:52:35 +0200
Subject: [PATCH 140/149] mediatek: filogic: add MT7986 full-UBI SPI-NAND DT
 overlay

Add mt7986-spim-nand.dtso providing a full-UBI partition layout
for SPI-NAND on MT7986, and reference it via DEVICE_DTS_OVERLAY
on MT7986A-RFB and MT7986B-RFB image definitions.

Import of patches-base/1143-02 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../boot/dts/mediatek/mt7986-spim-nand.dtso   | 82 +++++++++++++++++++
 target/linux/mediatek/image/filogic.mk        |  2 +
 2 files changed, 84 insertions(+)
 create mode 100644 target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7986-spim-nand.dtso

diff --git a/target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7986-spim-nand.dtso b/target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7986-spim-nand.dtso
new file mode 100644
index 0000000000..8fdf93d613
--- /dev/null
+++ b/target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7986-spim-nand.dtso
@@ -0,0 +1,82 @@
+/* SPDX-License-Identifier: (GPL-2.0-only OR MIT) */
+/*
+ * Copyright (C) 2025 MediaTek Inc.
+ * Author: Sky Huang <SkyLake.Huang@mediatek.com>
+ */
+
+/dts-v1/;
+/plugin/;
+
+&{/chosen} {
+	rootdisk-spim-nand = <&ubi_root>;
+	bootargs-append = " ubi.block=0,firmware root=/dev/fit0 rootwait";
+};
+
+&{/soc/spi@1100a000} {
+	status = "okay";
+
+	flash@0 {
+		compatible = "spi-nand";
+		reg = <0>;
+		spi-max-frequency = <52000000>;
+		spi-tx-bus-width = <4>;
+		spi-rx-bus-width = <4>;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "BL2";
+				reg = <0x00000 0x0200000>;
+				read-only;
+			};
+
+			partition@200000 {
+				label = "ubi";
+				reg = <0x0200000 0x7e00000>;
+				compatible = "linux,ubi";
+
+				volumes {
+					ubi-volume-ubootenv {
+						volname = "ubootenv";
+						nvmem-layout {
+							compatible = "u-boot,env-redundant-bool";
+						};
+					};
+
+					ubi-volume-ubootenv2 {
+						volname = "ubootenv2";
+						nvmem-layout {
+							compatible = "u-boot,env-redundant-bool";
+						};
+					};
+
+					ubi_factory: ubi-volume-factory {
+						volname = "factory";
+						nvmem-layout {
+							compatible = "fixed-layout";
+							#address-cells = <1>;
+							#size-cells = <1>;
+
+							eeprom_wmac: eeprom@0 {
+								reg = <0x0 0x1000>;
+							};
+						};
+					};
+
+					ubi_root: ubi-volume-fit {
+						volname = "fit";
+					};
+				};
+			};
+		};
+	};
+};
+
+&{/soc/wifi@18000000} {
+	nvmem-cell-names = "eeprom";
+	nvmem-cells = <&eeprom_wmac>;
+	status = "okay";
+};
diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index a3f5617c52..4ae2f5dbfa 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2001,6 +2001,7 @@ define Device/mediatek_mt7986a-rfb
   DEVICE_MODEL := MT7986A rfb (DT-overlay)
   DEVICE_DTS := mt7986a-rfb
   DEVICE_DTS_OVERLAY:= \
+	mt7986-spim-nand \
 	mt7986-spim-nand-nmbm
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
@@ -2024,6 +2025,7 @@ define Device/mediatek_mt7986b-rfb
   DEVICE_MODEL := MT7986B rfb (DT-overlay)
   DEVICE_DTS := mt7986b-rfb
   DEVICE_DTS_OVERLAY:= \
+	mt7986-spim-nand \
 	mt7986-spim-nand-nmbm
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
-- 
2.34.1

