From 7f61a82875104bee142003b06506e6ffeb222222 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:41:20 +0200
Subject: [PATCH 120/149] mediatek: filogic: rework MT7981 spi-nand dtso for
 full UBI

Rework mt7981-rfb-spim-nand.dtso to bind the SPI-NAND flash via
fixed-partitions / nvmem-layout with a proper ubi_root volume,
factory volume with eeprom_wmac nvmem cell, and bootargs that
mount the FIT volume as root. Re-add mt7981-rfb-spim-nand to
DEVICE_DTS_OVERLAY so the reworked overlay is selectable
alongside the spim-nor and NMBM variants.

Import of patches-base/1144-04 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../dts/mediatek/mt7981-rfb-spim-nand.dtso    | 63 ++++++++++++-------
 target/linux/mediatek/image/filogic.mk        |  1 +
 2 files changed, 40 insertions(+), 24 deletions(-)

diff --git a/target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7981-rfb-spim-nand.dtso b/target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7981-rfb-spim-nand.dtso
index 7e731cd433..9bc72988e7 100644
--- a/target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7981-rfb-spim-nand.dtso
+++ b/target/linux/mediatek/files-6.12/arch/arm64/boot/dts/mediatek/mt7981-rfb-spim-nand.dtso
@@ -7,7 +7,8 @@
 
 	fragment@0 {
 		target = <&chosen>;
-		rootdisk-spim-nand = <&ubi_rootdisk>;
+		rootdisk-spim-nand = <&ubi_root>;
+		bootargs-append = " ubi.block=0,firmware root=/dev/fit0 rootwait";
 	};
 
 	fragment@1 {
@@ -17,10 +18,10 @@
 			#address-cells = <1>;
 			#size-cells = <0>;
 
-			spi_nand: spi_nand@1 {
+			flash@0 {
 				compatible = "spi-nand";
-				reg = <1>;
-				spi-max-frequency = <10000000>;
+				reg = <0>;
+				spi-max-frequency = <52000000>;
 				spi-tx-bus-width = <4>;
 				spi-rx-bus-width = <4>;
 
@@ -31,32 +32,45 @@
 
 					partition@0 {
 						label = "BL2";
-						reg = <0x00000 0x0100000>;
+						reg = <0x00000 0x0200000>;
 						read-only;
 					};
 
-					partition@100000 {
-						label = "u-boot-env";
-						reg = <0x0100000 0x0080000>;
-					};
-
-					factory: partition@180000 {
-						label = "Factory";
-						reg = <0x180000 0x0200000>;
-					};
-
-					partition@380000 {
-						label = "FIP";
-						reg = <0x380000 0x0200000>;
-					};
-
-					partition@580000 {
+					partition@200000 {
 						label = "ubi";
-						reg = <0x580000 0x4000000>;
+						reg = <0x0200000 0x7e00000>;
 						compatible = "linux,ubi";
 
 						volumes {
-							ubi_rootdisk: ubi-volume-fit {
+							ubi-volume-ubootenv {
+								volname = "ubootenv";
+								nvmem-layout {
+									compatible = "u-boot,env-redundant-bool";
+								};
+							};
+
+							ubi-volume-ubootenv2 {
+								volname = "ubootenv2";
+								nvmem-layout {
+									compatible = "u-boot,env-redundant-bool";
+								};
+							};
+
+							ubi_factory: ubi-volume-factory {
+								volname = "factory";
+
+								nvmem-layout {
+									compatible = "fixed-layout";
+									#address-cells = <1>;
+									#size-cells = <1>;
+
+									eeprom_wmac: eeprom@0 {
+										reg = <0x0 0x1000>;
+									};
+								};
+							};
+
+							ubi_root: ubi-volume-fit {
 								volname = "fit";
 							};
 						};
@@ -69,7 +83,8 @@
 	fragment@2 {
 		target = <&wifi>;
 		__overlay__ {
-			mediatek,mtd-eeprom = <&factory 0x0>;
+			nvmem-cell-names = "eeprom";
+			nvmem-cells = <&eeprom_wmac>;
 			status = "okay";
 		};
 	};
diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index cf953a94c2..4f09cac7a3 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -1965,6 +1965,7 @@ define Device/mediatek_mt7981-rfb
   DEVICE_DTS := mt7981-rfb
   DEVICE_DTS_OVERLAY:= \
 	mt7981-rfb-spim-nor \
+	mt7981-rfb-spim-nand \
 	mt7981-rfb-spim-nand-nmbm \
 	mt7981-rfb-mxl-2p5g-phy-eth1 \
 	mt7981-rfb-mxl-2p5g-phy-swp5 \
-- 
