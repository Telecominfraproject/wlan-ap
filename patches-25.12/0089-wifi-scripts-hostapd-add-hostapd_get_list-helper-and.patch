From 121bc1bea08da1bc33406ac4766212c80e24ca1f Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 2 Feb 2026 09:19:49 +0100
Subject: [PATCH 89/93] wifi-scripts: hostapd: add hostapd_get_list() helper
 and AFC declarations

Add hostapd_get_list() helper function for building comma-separated
lists from JSON array values, needed by the AFC configuration.

Add config_add declarations for AFC (Automatic Frequency Coordination)
parameters in hostapd_common_add_device_config() to prepare for 6 GHz
AFC support.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../wifi-scripts/files/lib/netifd/hostapd.sh  | 20 +++++++++++++++++++
 1 file changed, 20 insertions(+)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
index affff2a459..08a8d2494a 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
@@ -142,9 +142,29 @@ hostapd_common_add_device_config() {
 	config_add_int airtime_mode
 	config_add_int mbssid
 
+	config_add_boolean afc
+	config_add_string \
+		afc_request_version afc_request_id afc_serial_number \
+		afc_location_type afc_location afc_height afc_height_type
+	config_add_array afc_cert_ids afc_freq_range afc_op_class
+	config_add_int \
+		afc_min_power afc_major_axis afc_minor_axis afc_orientation \
+		afc_vertical_tolerance
+
 	hostapd_add_log_config
 }
 
+hostapd_get_list() {
+	local var="$1"
+	local field="$2"
+
+	local cur __val_list
+	json_get_values __val_list "$field"
+	for cur in $__val_list; do
+		append "$var" "$cur" ","
+	done
+}
+
 hostapd_prepare_device_config() {
 	local config="$1"
 	local driver="$2"
-- 
