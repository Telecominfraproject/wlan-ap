From 7ab8a657d22c0163d86533f31764584e34979265 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 08:01:26 +0200
Subject: [PATCH 147/149] mediatek: filogic: switch MT7988A-RFB to internal
 2.5G PHY firmware

Replace the upstream mt7988-2p5g-phy-firmware package reference in
MT7988A-RFB DEVICE_PACKAGES with mt798x-2p5g-phy-firmware-internal,
which is the MediaTek-internal firmware variant shipped via the
feeds/mtk-app feed (mirrored from mtk-openwrt-feeds/feed/app).

Import of patches-base/1140-01 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index f10d751216..a29653c5ec 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2125,7 +2125,7 @@ define Device/mediatek_mt7988a-rfb
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x45f00000
-  DEVICE_PACKAGES := mt7988-2p5g-phy-firmware kmod-sfp kmod-phy-aquantia blkid
+  DEVICE_PACKAGES := mt798x-2p5g-phy-firmware-internal kmod-sfp kmod-phy-aquantia blkid
   KERNEL_LOADADDR := 0x46000000
   KERNEL := kernel-bin | gzip
   KERNEL_INITRAMFS := kernel-bin | lzma | \
-- 
2.34.1

