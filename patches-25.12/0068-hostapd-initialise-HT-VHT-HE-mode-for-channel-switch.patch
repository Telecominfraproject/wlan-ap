From dddbe95c813f6619e3b0ff4144f1f88b55bed602 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 18:06:00 +0100
Subject: [PATCH 68/93] hostapd: initialise HT/VHT/HE mode for channel switch

Port TIP zzzz-002-initialize-mode-for-hostapd-cli-chan-switch.patch:
initialises HT/VHT/HE freq_params when processing hostapd_cli
chan_switch command so channel switch includes correct mode information.

Signed-off-by: John Crispin <john@phrozen.org>
---
 ...-0008-initialize-mode-for-chan-switch.patch | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)
 create mode 100644 package/network/services/hostapd/patches/zzz-0008-initialize-mode-for-chan-switch.patch

diff --git a/package/network/services/hostapd/patches/zzz-0008-initialize-mode-for-chan-switch.patch b/package/network/services/hostapd/patches/zzz-0008-initialize-mode-for-chan-switch.patch
new file mode 100644
index 0000000000..a808b33f63
--- /dev/null
+++ b/package/network/services/hostapd/patches/zzz-0008-initialize-mode-for-chan-switch.patch
@@ -0,0 +1,18 @@
+#
+# TIP patch: zzzz-002-initialize-mode-for-hostapd-cli-chan-switch.patch
+# Initialises HT/VHT/HE parameters when processing hostapd_cli chan_switch
+# command, so channel switch includes correct mode information.
+#
+--- a/hostapd/ctrl_iface.c
++++ b/hostapd/ctrl_iface.c
+@@ -2740,6 +2740,10 @@ static int hostapd_ctrl_iface_chan_switc
+ 		break;
+ 	}
+ 
++	settings.freq_params.ht_enabled = iface->conf->ieee80211n;
++	settings.freq_params.vht_enabled = iface->conf->ieee80211ac;
++	settings.freq_params.he_enabled = iface->conf->ieee80211ax;
++
+ 	if (settings.freq_params.center_freq1)
+ 		dfs_range += hostapd_is_dfs_overlap(
+ 			iface, bandwidth, settings.freq_params.center_freq1);
-- 
2.34.1

