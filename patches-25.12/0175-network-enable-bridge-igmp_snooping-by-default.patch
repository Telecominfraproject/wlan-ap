From 5ef402e72bd8fa15bd544e3659d0e02f1a4b46cf Thu May 21 15:09:17 2026
From: Benjamin Lin <benjamin-jw.lin@mediatek.com> 
Date: Thu, 21 May 2026 15:09:17 +0800
Subject: [PATCH v1] Change default setting of IGMP snooping

Change default setting of IGMP snooping.
Specifically, enable bridge's IGMP snooping by default.
This also enables multicast_querier, which is essential for snooping and M2U.

--- a/package/base-files/files/bin/config_generate
+++ b/package/base-files/files/bin/config_generate
@@ -115,6 +115,7 @@ generate_network() {
 			add network device
 			set network.@device[-1].name='br-$1'
 			set network.@device[-1].type='bridge'
+			set network.@device[-1].igmp_snooping='1'
 		EOF
 		for port in $ports; do uci add_list network.@device[-1].ports="$port"; done
 		[ -n "$macaddr" ] && {
