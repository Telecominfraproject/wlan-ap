From 1d1b128b092044c7ace85b76e0c3899f76bab9bf Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 18:29:36 +0100
Subject: [PATCH 69/93] hostapd: add overridable max station association check

Port TIP 780-maxassoc.patch: uses hostapd_check_max_sta() helper
instead of inline max_num_sta comparison in ap_sta_add(), allowing
ubus/ucode to override the max STA check.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../hostapd/patches/zzz-0009-maxassoc.patch      | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)
 create mode 100644 package/network/services/hostapd/patches/zzz-0009-maxassoc.patch

diff --git a/package/network/services/hostapd/patches/zzz-0009-maxassoc.patch b/package/network/services/hostapd/patches/zzz-0009-maxassoc.patch
new file mode 100644
index 0000000000..79b4beef04
--- /dev/null
+++ b/package/network/services/hostapd/patches/zzz-0009-maxassoc.patch
@@ -0,0 +1,16 @@
+#
+# TIP patch: 780-maxassoc.patch
+# Uses hostapd_check_max_sta() helper instead of inline max_num_sta
+# comparison, allowing ubus/ucode to override the max STA check.
+#
+--- a/src/ap/sta_info.c
++++ b/src/ap/sta_info.c
+@@ -717,7 +717,7 @@ struct sta_info * ap_sta_add(struct host
+ 		return sta;
+ 
+ 	wpa_printf(MSG_DEBUG, "  New STA");
+-	if (hapd->num_sta >= hapd->conf->max_num_sta) {
++	if (hostapd_check_max_sta(hapd)) {
+ 		/* FIX: might try to remove some old STAs first? */
+ 		wpa_printf(MSG_DEBUG, "no more room for new STAs (%d/%d)",
+ 			   hapd->num_sta, hapd->conf->max_num_sta);
-- 
