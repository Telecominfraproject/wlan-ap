From df741d920d2196eb6d937ee9215aa4b088818da4 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 9 Mar 2026 14:09:28 +0100
Subject: [PATCH] wifi-scripts: add psk2-radius and osen encryption support

Port psk2-radius auth type and osen encryption detection from the
QCA wifi-6 netifd-wireless.sh to the standard wifi-scripts version,
allowing the QCA wifi-6 package to use wifi-scripts directly.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../wifi-scripts/files/lib/netifd/netifd-wireless.sh     | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh b/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh
index ac11905fac..03748a16bb 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh
@@ -283,6 +283,9 @@ wireless_vif_parse_encryption() {
 		wpa3*)
 			auth_type=eap2
 		;;
+		psk2-radius*)
+			auth_type=psk2-radius
+		;;
 		psk3-mixed*|sae-mixed*)
 			auth_type=psk-sae
 		;;
@@ -308,6 +311,12 @@ wireless_vif_parse_encryption() {
 			esac
 		;;
 	esac
+
+	case "$encryption" in
+		*osen*)
+			auth_osen=1
+		;;
+	esac
 }
 
 _wireless_set_brsnoop_isolation() {
