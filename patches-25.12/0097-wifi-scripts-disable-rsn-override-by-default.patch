From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Thu, 13 Mar 2026 09:00:00 +0100
Subject: [PATCH] wifi-scripts: disable rsn_override by default

Vendor hostapd builds (e.g. qca-wifi-6) do not support the
rsn_override_key_mgmt, rsn_override_pairwise and rsn_override_mfp
configuration items. When rsn_override defaults to 1, these items
are emitted for wpa3 and wpa3-mixed encryption types, causing
hostapd to reject the configuration and fail to start.

Change the default to 0 so RSN Override is opt-in, and gate the
emission of rsn_override_* config lines on rsn_override being
explicitly enabled.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../config/wifi-scripts/files/lib/netifd/hostapd.sh        | 6 +++---
 .../config/wifi-scripts/files/lib/netifd/netifd-wireless.sh | 2 +-
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
index dc5b27f546..5ab6088599 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
@@ -631,7 +631,7 @@ hostapd_set_bss_options() {
 		vendor_elements fils ocv beacon_prot spp_amsdu apup rsn_override \
 		rssi_reject_assoc_rssi rssi_ignore_probe_request

-	set_default rsn_override 1
+	set_default rsn_override 0
 	set_default fils 0
 	set_default isolate 0
 	set_default maxassoc 0
@@ -1017,7 +1017,7 @@ hostapd_set_bss_options() {

 		hostapd_append_wpa_key_mgmt
 		[ -n "$wpa_key_mgmt" ] && append bss_conf "wpa_key_mgmt=$wpa_key_mgmt" "$N"
-		[ -n "$rsn_override_key_mgmt" -o -n "$rsn_override_pairwise" ] && {
+		[ "$rsn_override" -gt 0 ] && [ -n "$rsn_override_key_mgmt" -o -n "$rsn_override_pairwise" ] && {
 			append bss_conf "rsn_override_key_mgmt=${rsn_override_key_mgmt:-$wpa_key_mgmt}" "$N"
 			append bss_conf "rsn_override_pairwise=${rsn_override_pairwise:-$wpa_pairwise}" "$N"
 			append bss_conf "rsn_override_mfp=$ieee80211w" "$N"
@@ -1446,7 +1446,7 @@ wpa_supplicant_add_network() {

 	json_get_values basic_rate_list basic_rate

-	set_default rsn_override 1
+	set_default rsn_override 0

 	case "$auth_type" in
 		sae|owe|eap2|eap192)
diff --git a/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh b/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh
index 03748a16bb..190457df69 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/netifd-wireless.sh
@@ -212,7 +212,7 @@ wireless_vif_parse_encryption() {
 	json_get_vars encryption rsn_override
 	set_default encryption none

-	set_default rsn_override 1
+	set_default rsn_override 0
 	auth_mode_open=1
 	auth_mode_shared=0
 	auth_type=none
