From 04b531a92624a757574a0c776db1315ec0ee972a Mon Sep 17 00:00:00 2001
From: developer <developer@mediatek.com>
Date: Tue, 28 Apr 2026 10:29:12 +0800
Subject: [PATCH] [][kernel-6.12][mt7986][dts][Enable watchdog]

[Description]
Enable watchdog for MT7986A and MT7986C kernel 6.12 codebase.
Otherwise, Wi-Fi device node cannot be successfully enabled.

[Release-log]
N/A
---
 ...fb-15-arm64-dts-mediatek-enable-watchdog.patch | 15 +++++++++++++++
 1 file changed, 15 insertions(+)
 create mode 100644 target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-15-arm64-dts-mediatek-enable-watchdog.patch

diff --git a/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-15-arm64-dts-mediatek-enable-watchdog.patch b/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-15-arm64-dts-mediatek-enable-watchdog.patch
new file mode 100644
index 0000000..cbbbae5
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-15-arm64-dts-mediatek-enable-watchdog.patch
@@ -0,0 +1,15 @@
+Index: linux-6.12.79/arch/arm64/boot/dts/mediatek/mt7986a-rfb.dts
+===================================================================
+--- linux-6.12.79.orig/arch/arm64/boot/dts/mediatek/mt7986a-rfb.dts
++++ linux-6.12.79/arch/arm64/boot/dts/mediatek/mt7986a-rfb.dts
+@@ -290,6 +290,10 @@
+ 	status = "okay";
+ };
+ 
++&watchdog {
++	status = "okay";
++};
++
+ &wifi {
+ 	status = "okay";
+ 	pinctrl-names = "default", "dbdc";
