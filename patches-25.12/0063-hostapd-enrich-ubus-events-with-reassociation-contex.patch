From 6aa3b4ff657e8c3ee53a1c530598104d999d8c21 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 17:03:04 +0100
Subject: [PATCH 63/93] hostapd: enrich ubus events with reassociation context

Add origin AP, target AP, and reassoc flag to ubus association and
authorisation events to support roaming-aware consumers. Emit
ft-finish notification on successful FT authentication.

Upstream changes applied via zzz-0003-re-assoc-event.patch, overlay
changes (ubus.c, ubus.h) applied directly.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../patches/zzz-0003-re-assoc-event.patch     | 161 ++++++++++++++++++
 .../services/hostapd/src/src/ap/ubus.c        |   8 +-
 .../services/hostapd/src/src/ap/ubus.h        |   5 +-
 3 files changed, 171 insertions(+), 3 deletions(-)
 create mode 100644 package/network/services/hostapd/patches/zzz-0003-re-assoc-event.patch

diff --git a/package/network/services/hostapd/patches/zzz-0003-re-assoc-event.patch b/package/network/services/hostapd/patches/zzz-0003-re-assoc-event.patch
new file mode 100644
index 0000000000..60f3f4d915
--- /dev/null
+++ b/package/network/services/hostapd/patches/zzz-0003-re-assoc-event.patch
@@ -0,0 +1,161 @@
+zzz-0003-re-assoc-event.patch
+
+Enriches ubus events with roaming/reassociation context:
+- Adds origin_ap field to sta_info to track the previous AP on reassociation
+- Copies current_ap from reassoc request into sta->origin_ap
+- Passes reassoc flag through to ubus assoc-req and sta-authorized events
+- Adds origin MAC (previous AP) to assoc-req and sta-authorized ubus events
+  when the station is reassociating
+- Adds target MAC (current AP BSSID) to notify and sta-authorized events
+- Emits ft-finish ubus notification after successful FT authentication
+- Introduces _ap_sta_set_authorized() variant that threads the reassoc flag
+  through to ap_sta_set_authorized_event and into the ubus notification
+
+Companion changes in overlay files (ubus.c, ubus.h) are applied directly,
+not via this patch.
+
+--- a/src/ap/ieee802_11.c
++++ b/src/ap/ieee802_11.c
+@@ -468,6 +468,7 @@ static void handle_auth_ft_finish(void *
+ 
+ 	hostapd_logger(hapd, dst, HOSTAPD_MODULE_IEEE80211,
+ 		       HOSTAPD_LEVEL_DEBUG, "authentication OK (FT)");
++	hostapd_ubus_notify(hapd, "ft-finish", sta->addr);
+ 	sta->flags |= WLAN_STA_AUTH;
+ 	mlme_authenticate_indication(hapd, sta);
+ }
+@@ -5833,6 +5834,8 @@ static void handle_assoc(struct hostapd_
+ 	}
+ 
+ 	sta = ap_get_sta(hapd, mgmt->sa);
++	if (reassoc && sta)
++		os_memcpy(sta->origin_ap, mgmt->u.reassoc_req.current_ap, 6);
+ 
+ #ifdef CONFIG_IEEE80211BE
+ 	/*
+@@ -6013,6 +6016,7 @@ static void handle_assoc(struct hostapd_
+ 		.type = HOSTAPD_UBUS_ASSOC_REQ,
+ 		.mgmt_frame = mgmt,
+ 		.ssi_signal = rssi,
++		.reassoc = reassoc,
+ 	};
+ 
+ 	/* followed by SSID and Supported rates; and HT capabilities if 802.11n
+@@ -6979,7 +6983,7 @@ static void ieee80211_ml_link_sta_assoc_
+ 
+ 	hostapd_set_sta_flags(hapd, sta);
+ 	if (updated)
+-		ap_sta_set_authorized_event(hapd, sta, 1);
++		ap_sta_set_authorized_event(hapd, sta, 1, 0);
+ 
+ 	/*
+ 	 * TODOs:
+@@ -7106,7 +7110,7 @@ static void handle_assoc_cb(struct hosta
+ 		 * Open, static WEP, FT protocol, or FILS; no separate
+ 		 * authorization step.
+ 		 */
+-		ap_sta_set_authorized(hapd, sta, 1);
++		_ap_sta_set_authorized(hapd, sta, 1, reassoc);
+ 	}
+ 
+ 	if (reassoc)
+--- a/src/ap/sta_info.c
++++ b/src/ap/sta_info.c
+@@ -1571,7 +1571,8 @@ bool ap_sta_set_authorized_flag(struct h
+ 
+ 
+ void ap_sta_set_authorized_event(struct hostapd_data *hapd,
+-				 struct sta_info *sta, int authorized)
++				 struct sta_info *sta, int authorized,
++				 int reassoc)
+ {
+ 	const u8 *dev_addr = NULL;
+ 	char buf[100];
+@@ -1665,7 +1666,7 @@ void ap_sta_set_authorized_event(struct
+ 				    " vlanid=%u", sta->vlan_id);
+ #endif /* CONFIG_NO_VLAN */
+ 
+-		hostapd_ubus_notify_authorized(hapd, sta, auth_alg);
++		hostapd_ubus_notify_authorized(hapd, sta, auth_alg, reassoc);
+ 		wpa_msg(hapd->msg_ctx, MSG_INFO, AP_STA_CONNECTED "%s%s%s%s%s%s",
+ 			buf, ip_addr, keyid_buf, dpp_pkhash_buf, vlanid_buf, alg_buf);
+ 
+@@ -1707,7 +1708,17 @@ bool ap_sta_set_authorized(struct hostap
+ {
+ 	if (!ap_sta_set_authorized_flag(hapd, sta, authorized))
+ 		return false;
+-	ap_sta_set_authorized_event(hapd, sta, authorized);
++	ap_sta_set_authorized_event(hapd, sta, authorized, 0);
++	return true;
++}
++
++
++bool _ap_sta_set_authorized(struct hostapd_data *hapd, struct sta_info *sta,
++			    int authorized, int reassoc)
++{
++	if (!ap_sta_set_authorized_flag(hapd, sta, authorized))
++		return false;
++	ap_sta_set_authorized_event(hapd, sta, authorized, reassoc);
+ 	return true;
+ }
+ 
+--- a/src/ap/sta_info.h
++++ b/src/ap/sta_info.h
+@@ -85,6 +85,7 @@ struct sta_info {
+ 	struct sta_info *next; /* next entry in sta list */
+ 	struct sta_info *hnext; /* next entry in hash table list */
+ 	u8 addr[6];
++	u8 origin_ap[6];
+ 	be32 ipaddr;
+ 	struct dl_list ip6addr; /* list head for struct ip6addr */
+ 	u16 aid; /* STA's unique AID (1 .. 2007) or 0 if not yet assigned */
+@@ -387,13 +388,17 @@ void ap_sta_disconnect(struct hostapd_da
+ bool ap_sta_set_authorized_flag(struct hostapd_data *hapd, struct sta_info *sta,
+ 				int authorized);
+ void ap_sta_set_authorized_event(struct hostapd_data *hapd,
+-				 struct sta_info *sta, int authorized);
++				 struct sta_info *sta, int authorized,
++				 int reassoc);
+ bool ap_sta_set_authorized(struct hostapd_data *hapd,
+ 			   struct sta_info *sta, int authorized);
+ static inline int ap_sta_is_authorized(struct sta_info *sta)
+ {
+ 	return sta->flags & WLAN_STA_AUTHORIZED;
+ }
++bool _ap_sta_set_authorized(struct hostapd_data *hapd,
++			   struct sta_info *sta, int authorized,
++			   int reassoc);
+ 
+ void ap_sta_deauth_cb(struct hostapd_data *hapd, struct sta_info *sta);
+ void ap_sta_disassoc_cb(struct hostapd_data *hapd, struct sta_info *sta);
+--- a/src/ap/drv_callbacks.c
++++ b/src/ap/drv_callbacks.c
+@@ -87,7 +87,7 @@ void hostapd_notify_assoc_fils_finish(st
+ 	sta->flags &= ~WLAN_STA_WNM_SLEEP_MODE;
+ 	hostapd_set_sta_flags(hapd, sta);
+ 	if (updated)
+-		ap_sta_set_authorized_event(hapd, sta, 1);
++		ap_sta_set_authorized_event(hapd, sta, 1, 0);
+ 	wpa_auth_sm_event(sta->wpa_sm, WPA_ASSOC_FILS);
+ 	ieee802_1x_notify_port_enabled(sta->eapol_sm, 1);
+ 	hostapd_new_assoc_sta(hapd, sta, !new_assoc);
+@@ -979,7 +979,7 @@ skip_wpa_check:
+ #endif /* CONFIG_IEEE80211BE */
+ 
+ 	if (updated)
+-		ap_sta_set_authorized_event(hapd, sta, 1);
++		ap_sta_set_authorized_event(hapd, sta, 1, reassoc);
+ 
+ 	if (reassoc && (sta->auth_alg == WLAN_AUTH_FT))
+ 		wpa_auth_sm_event(sta->wpa_sm, WPA_ASSOC_FT);
+--- a/src/ap/ieee802_1x.c
++++ b/src/ap/ieee802_1x.c
+@@ -122,7 +122,7 @@ static void ieee802_1x_set_authorized(st
+ 	update = ap_sta_set_authorized_flag(hapd, sta, authorized);
+ 	res = hostapd_set_authorized(hapd, sta, authorized);
+ 	if (update)
+-		ap_sta_set_authorized_event(hapd, sta, authorized);
++		ap_sta_set_authorized_event(hapd, sta, authorized, 0);
+ 	hostapd_logger(hapd, sta->addr, HOSTAPD_MODULE_IEEE8021X,
+ 		       HOSTAPD_LEVEL_DEBUG, "%sauthorizing port",
+ 		       authorized ? "" : "un");
diff --git a/package/network/services/hostapd/src/src/ap/ubus.c b/package/network/services/hostapd/src/src/ap/ubus.c
index c1d68c34ff..9779b12890 100644
--- a/package/network/services/hostapd/src/src/ap/ubus.c
+++ b/package/network/services/hostapd/src/src/ap/ubus.c
@@ -1886,6 +1886,8 @@ int hostapd_ubus_handle_event(struct hostapd_data *hapd, struct hostapd_ubus_req
 	if (req->ssi_signal)
 		blobmsg_add_u32(&b, "signal", req->ssi_signal);
 	blobmsg_add_u32(&b, "freq", hapd->iface->freq);
+	if (req->reassoc && req->mgmt_frame)
+		blobmsg_add_macaddr(&b, "origin", req->mgmt_frame->u.reassoc_req.current_ap);
 
 	if (req->elems) {
 		if(req->elems->ht_capabilities)
@@ -1956,12 +1958,13 @@ void hostapd_ubus_notify(struct hostapd_data *hapd, const char *type, const u8 *
 	blob_buf_init(&b, 0);
 	blobmsg_add_macaddr(&b, "address", addr);
 	blobmsg_add_string(&b, "ifname", hapd->conf->iface);
+	blobmsg_printf(&b, "target", MACSTR, MAC2STR(hapd->conf->bssid));
 
 	ubus_notify(ctx, &hapd->ubus.obj, type, b.head, -1);
 }
 
 void hostapd_ubus_notify_authorized(struct hostapd_data *hapd, struct sta_info *sta,
-				    const char *auth_alg)
+				    const char *auth_alg, int reassoc)
 {
 	if (!hapd->ubus.obj.has_subscribers)
 		return;
@@ -1980,6 +1983,9 @@ void hostapd_ubus_notify_authorized(struct hostapd_data *hapd, struct sta_info *
 		blobmsg_add_u32(&b, "", sta->bandwidth[1]);
 		blobmsg_close_array(&b, r);
 	}
+	if (reassoc)
+		blobmsg_add_macaddr(&b, "origin", sta->origin_ap);
+	blobmsg_printf(&b, "target", MACSTR, MAC2STR(hapd->conf->bssid));
 
 	ubus_notify(ctx, &hapd->ubus.obj, "sta-authorized", b.head, -1);
 }
