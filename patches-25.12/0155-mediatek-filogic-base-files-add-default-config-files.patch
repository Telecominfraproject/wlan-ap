From dc728f424f34a230a42e5d73e22cb9b64af26342 Mon Sep 17 00:00:00 2001
From: Sam Shih <sam.shih@mediatek.com>
Date: Tue, 19 May 2026 09:29:29 +0800
Subject: [PATCH 155/169] mediatek: filogic: base-files: add default config
 files

Add default UCI configuration files for MediaTek filogic
boards. These provide base configuration for fstab and
other system settings needed for MT7987/MT7988 platforms.

Signed-off-by: Sam Shih <sam.shih@mediatek.com>
---
 target/linux/mediatek/filogic/base-files/etc/config/fstab | 7 +++++++
 1 file changed, 7 insertions(+)
 create mode 100644 target/linux/mediatek/filogic/base-files/etc/config/fstab

diff --git a/target/linux/mediatek/filogic/base-files/etc/config/fstab b/target/linux/mediatek/filogic/base-files/etc/config/fstab
new file mode 100644
index 0000000000..c07ea3003f
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/etc/config/fstab
@@ -0,0 +1,7 @@
+config global
+        option anon_swap '1'
+        option anon_mount '1'
+        option auto_swap '1'
+        option auto_mount '1'
+        option delay_root '5'
+        option check_fs '1'
-- 
2.34.1

