From b6ca1b4509d625eb1a79e3217eb1ed954613f801 Mon Sep 17 00:00:00 2001
From: Richard <Richard.Zhang@cybertan.com.tw>
Date: Wed, 29 Apr 2026 11:37:09 +0800
Subject: [PATCH] mediatek: add support for Sonicfi Rap630w-211g

---
 include/image-commands.mk                     |   4 +-
 .../uboot-envtools/files/mediatek_filogic     |  27 +
 scripts/mkits.sh                              |  52 +-
 .../dts/mt7981b-sonicfi-rap630w-211g.dts      | 551 ++++++++++++++++++
 .../filogic/base-files/etc/board.d/02_network |  36 ++
 .../base-files/lib/upgrade/platform.sh        |  30 +
 target/linux/mediatek/image/filogic.mk        |  28 +
 7 files changed, 719 insertions(+), 9 deletions(-)
 create mode 100644 target/linux/mediatek/dts/mt7981b-sonicfi-rap630w-211g.dts

diff --git a/include/image-commands.mk b/include/image-commands.mk
index ee1ddc9789..8998453ad8 100644
--- a/include/image-commands.mk
+++ b/include/image-commands.mk
@@ -452,7 +452,9 @@ define Build/fit-its
 		$(if $(DEVICE_DTS_LOADADDR),-s $(DEVICE_DTS_LOADADDR)) \
 		$(if $(DEVICE_DTS_OVERLAY),$(foreach dtso,$(DEVICE_DTS_OVERLAY), -O $(dtso):$(KERNEL_BUILD_DIR)/image-$(dtso).dtbo)) \
 		-c $(if $(DEVICE_DTS_CONFIG),$(DEVICE_DTS_CONFIG),"config-1") \
-		-A $(LINUX_KARCH) -v $(LINUX_VERSION)
+		-A $(LINUX_KARCH) -v $(LINUX_VERSION) \
+		$(if $(CONFIG_TARGET_mediatek_filogic_DEVICE_sonicfi_rap630w_211g),-R) \
+		$(if $(and $(CONFIG_TARGET_ROOTFS_SQUASHFS),$(CONFIG_TARGET_mediatek_filogic_DEVICE_sonicfi_rap630w_211g)),-r $(ROOTFS/squashfs/$(DEVICE_NAME)))
 endef
 
 define Build/fit-image
diff --git a/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic b/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
index fd89a211d8..4d255f04a9 100644
--- a/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
+++ b/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
@@ -8,6 +8,9 @@ touch /etc/config/ubootenv
 
 . /lib/uboot-envtools.sh
 . /lib/functions.sh
+. /lib/functions/uci-defaults.sh
+. /lib/functions/system.sh
+. /lib/upgrade/nand.sh
 
 board=$(board_name)
 
@@ -160,6 +163,30 @@ zyxel,ex5601-t0)
 zyxel,ex5700-telenor)
 	ubootenv_add_uci_config "/dev/ubootenv" "0x0" "0x4000" "0x4000" "1"
 	;;
+sonicfi,rap630w-211g)
+        #env_dev=$(cat /sys/module/boot_param/parameters/env_part 2>/dev/null)
+        env_dev=$(cmdline_get_var "boot_param.env_part")
+        CI_UBIPART="ubi"
+        if [ -n "$env_dev" ]; then
+                mtdnum="$( find_mtd_index "$CI_UBIPART" )"
+                if [ ! "$mtdnum" ]; then
+                        echo "cannot find ubi mtd partition $CI_UBIPART"
+                        return 1
+                fi
+
+                ubidev="$( nand_find_ubi "$CI_UBIPART" )"
+                if [ ! "$ubidev" ]; then
+                        ubiattach -m "$mtdnum"
+                        sync
+                        ubidev="$( nand_find_ubi "$CI_UBIPART" )"
+                fi
+
+                env_ubivol="$( nand_find_volume "${ubidev}" ${env_dev} )"
+                if [ -n "${env_ubivol}" ]; then
+                        ubootenv_add_uci_config "/dev/$env_ubivol" "0" "0x80000" "0x80000" 1
+                fi
+        fi
+        ;;
 esac
 
 config_load ubootenv
diff --git a/scripts/mkits.sh b/scripts/mkits.sh
index fc2b580ee2..4e1f34c8ae 100755
--- a/scripts/mkits.sh
+++ b/scripts/mkits.sh
@@ -48,8 +48,9 @@ HASH=sha1
 LOADABLES=
 DTOVERLAY=
 DTADDR=
+ROOTFS_HASH=0
 
-while getopts ":A:a:c:C:D:d:e:f:i:k:l:n:o:O:v:r:s:H:" OPTION
+while getopts ":A:a:c:C:D:d:e:f:i:k:l:n:o:O:v:r:s:H:R" OPTION
 do
 	case $OPTION in
 		A ) ARCH=$OPTARG;;
@@ -70,6 +71,7 @@ do
 		s ) FDTADDR=$OPTARG;;
 		H ) HASH=$OPTARG;;
 		v ) VERSION=$OPTARG;;
+		R ) ROOTFS_HASH=1;;
 		* ) echo "Invalid option passed to '$0' (options:$*)"
 		usage;;
 	esac
@@ -82,7 +84,8 @@ if [ -z "${ARCH}" ] || [ -z "${COMPRESS}" ] || [ -z "${LOAD_ADDR}" ] || \
 	usage
 fi
 
-if [ -n "${ROOTFS}" ] && [ ! -f "${ROOTFS}".pagesync ]; then
+#when ROOTFS_HASH=1, the .pagesync verification is skipped, matching the firmware generation requirements for the rap630w-211g process
+if [ -n "${ROOTFS}" ] && [ $ROOTFS_HASH -eq 0 ] && [ ! -f "${ROOTFS}".pagesync ]; then
 	echo "Missing .pagesync blob for RootFS blob '${ROOTFS}'"
 	exit 1
 fi
@@ -139,9 +142,27 @@ if [ -n "${INITRD}" ]; then
 	INITRD_PROP="ramdisk=\"initrd${REFERENCE_CHAR}${INITRDNUM}\";"
 fi
 
-
+#When ROOTFS_HASH=1, the script automatically calculates the size, CRC32, and SHA1 check values of the rootfs file, and generates a dedicated DTS format rootfs node (with built-in check information) to meet the rap630w-211g Bootloader startup check requirements.
 if [ -n "${ROOTFS}" ]; then
-	ROOTFS_NODE="
+	if [ $ROOTFS_HASH -eq 1 ]; then
+		ROOTFS_SIZE=$(stat -c %s ${ROOTFS})
+        	ROOTFS_SHA1=$(sha1sum ${ROOTFS} | awk '{print "<0x"substr($0,1,8) " 0x"substr($0,9,8) " 0x"substr($0,17,8) " 0x"substr($0,25,8) " 0x"substr($0,33,8) ">"}')
+        	ROOTFS_CRC32=$(crc32sum ${ROOTFS})
+        	ROOTFS_NODE="
+                rootfs {
+                                size = <${ROOTFS_SIZE}>;
+                                hash-1 {
+                                        value = <0x${ROOTFS_CRC32}>;
+                                        algo = \"crc32\";
+                                        };
+                                hash-2 {
+                                        value = ${ROOTFS_SHA1};
+                                        algo = \"sha1\";
+                                        };
+                        };
+"
+	else
+		ROOTFS_NODE="
 		rootfs${REFERENCE_CHAR}$ROOTFSNUM {
 			description = \"${ARCH_UPPER} OpenWrt ${DEVICE} rootfs\";
 			${COMPATIBLE_PROP}
@@ -158,6 +179,8 @@ if [ -n "${ROOTFS}" ]; then
 		};
 "
 	LOADABLES="${LOADABLES:+$LOADABLES, }\"rootfs${REFERENCE_CHAR}${ROOTFSNUM}\""
+
+	fi
 fi
 
 # add DT overlay blobs
@@ -196,6 +219,20 @@ OVCONFIGS=""
 	"
 done
 
+#ROOTFS_HASH=1: The rootfs node containing verification information is independently placed externally, while only the core nodes are retained in the main image to accommodate rap630w-211g;
+if [ $ROOTFS_HASH -eq 1 ]; then
+    IMAGES_CONTENT="                ${INITRD_NODE}
+${FDT_NODE}
+${FDTOVERLAY_NODE}"
+    ROOTFS_OUTSIDE="${ROOTFS_NODE}"
+else
+    IMAGES_CONTENT="                ${INITRD_NODE}
+${FDT_NODE}
+${FDTOVERLAY_NODE}
+${ROOTFS_NODE}"
+    ROOTFS_OUTSIDE=""
+fi
+
 # Create a default, fully populated DTS file
 DATA="/dts-v1/;
 
@@ -220,12 +257,11 @@ DATA="/dts-v1/;
 				algo = \"$HASH\";
 			};
 		};
-${INITRD_NODE}
-${FDT_NODE}
-${FDTOVERLAY_NODE}
-${ROOTFS_NODE}
+${IMAGES_CONTENT}
 	};
 
+${ROOTFS_OUTSIDE}
+
 	configurations {
 		default = \"${CONFIG}\";
 		${CONFIG} {
