From b8d87eeef1886f7d431412e693ad1d069f29aa51 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 6 Apr 2026 16:08:23 +0200
Subject: [PATCH] bpf-headers: fix GENERIC_PLATFORM_DIR for feed targets

When the target lives in a feed (e.g. ipq53xx from qca-wifi-7), the
generic platform directory is under target/linux/feeds/<board>/generic
rather than target/linux/generic. Use firstword/wildcard to try the
feed path first.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/kernel/bpf-headers/Makefile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/package/kernel/bpf-headers/Makefile b/package/kernel/bpf-headers/Makefile
index ceafcc0763..b66a39519e 100644
--- a/package/kernel/bpf-headers/Makefile
+++ b/package/kernel/bpf-headers/Makefile
@@ -16,7 +16,7 @@ PKG_NAME:=linux
 PKG_PATCHVER:=6.12
 
 # Manually include kernel version and hash from kernel details file
-GENERIC_PLATFORM_DIR := $(CURDIR)/../../../target/linux/generic
+GENERIC_PLATFORM_DIR := $(firstword $(wildcard $(CURDIR)/../../../target/linux/feeds/$(BOARD)/generic $(CURDIR)/../../../target/linux/generic))
 include $(GENERIC_PLATFORM_DIR)/kernel-$(PKG_PATCHVER)
 
 PKG_VERSION:=$(PKG_PATCHVER)$(strip $(LINUX_VERSION-$(PKG_PATCHVER)))
-- 
2.34.1

