From 199aecc834a85e9524dc7b301641505785cdc882 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 16:50:38 +0100
Subject: [PATCH 62/93] hostapd: add ANonce timestamp field for FT staleness
 checking

Record when the ANonce was generated to enable a validity window for
retransmitted FT auth requests, preventing key derivation mismatches.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../hostapd/patches/zzz-0002-ft-anonce.patch    | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)
 create mode 100644 package/network/services/hostapd/patches/zzz-0002-ft-anonce.patch

diff --git a/package/network/services/hostapd/patches/zzz-0002-ft-anonce.patch b/package/network/services/hostapd/patches/zzz-0002-ft-anonce.patch
new file mode 100644
index 0000000000..53d020f5f0
--- /dev/null
+++ b/package/network/services/hostapd/patches/zzz-0002-ft-anonce.patch
@@ -0,0 +1,17 @@
+ANonce timestamp field for FT staleness checking
+
+Adds an ANonce_time field (struct os_reltime) to wpa_state_machine,
+recording when the ANonce was generated. Used by the FT association
+reject fix (zzz-0009) to implement a 1-second ANonce validity window
+for retransmitted FT auth requests.
+
+--- a/src/ap/wpa_auth_i.h
++++ b/src/ap/wpa_auth_i.h
+@@ -54,6 +54,7 @@ struct wpa_state_machine {
+ 	bool MICVerified;
+ 	bool GUpdateStationKeys;
+ 	u8 ANonce[WPA_NONCE_LEN];
++	struct os_reltime ANonce_time;
+ 	u8 SNonce[WPA_NONCE_LEN];
+ 	u8 alt_SNonce[WPA_NONCE_LEN];
+ 	u8 alt_replay_counter[WPA_REPLAY_COUNTER_LEN];
-- 
