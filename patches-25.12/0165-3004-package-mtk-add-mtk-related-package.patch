+	$(TOPDIR)/scripts/ta-offline-sign.sh \
+		build_dir=$(PKG_BUILD_DIR)/out \
+		public_key=$(TA_PUBLIC_KEY) \
+		private_key=$(TA_PRIVATE_KEY)
