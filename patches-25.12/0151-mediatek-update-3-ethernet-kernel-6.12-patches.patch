From 8703b84970933e5c494407284f86c5910133b157 Mon Sep 17 00:00:00 2001
From: Sam Shih <sam.shih@mediatek.com>
Date: Tue, 19 May 2026 17:38:18 +0800
Subject: [PATCH 151/169] mediatek: update 3 ethernet kernel 6.12 patches
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

This patch ports part of the modifications from:
c0ef0ca705bc7dad741fdfc65c60052725c3d7c1 of the MediaTek SDK

It integrates the XGMAC force mode v2–related fixes from the following patches:
999-eth-03-mtk_eth_soc-revise-xgmac-force-mode.patch
999-eth-14-mtk_eth_soc-add-XGMACv2-support-for-MT7987.patch
999-eth-47-mtk_eth_soc-add-extended-MIB-counters-for-NETSYSv3.patch

Signed-off-by: Sam Shih <sam.shih@mediatek.com>
---
 ...k_eth_soc-revise-xgmac-force-mode-v2.patch | 92 +++++++++++++++++++
 1 file changed, 92 insertions(+)
 create mode 100644 target/linux/mediatek/patches-6.12/999-eth-48-mtk_eth_soc-revise-xgmac-force-mode-v2.patch

diff --git a/target/linux/mediatek/patches-6.12/999-eth-48-mtk_eth_soc-revise-xgmac-force-mode-v2.patch b/target/linux/mediatek/patches-6.12/999-eth-48-mtk_eth_soc-revise-xgmac-force-mode-v2.patch
new file mode 100644
index 0000000000..3bc28dd4aa
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-48-mtk_eth_soc-revise-xgmac-force-mode-v2.patch
@@ -0,0 +1,92 @@
+---
+[v1] net: ethernet: mtk_eth_soc: revise XGMAC force mode v2
+ 
+This patch ports part of the modifications from:
+https://git01.mediatek.com/plugins/gitiles/openwrt/feeds/mtk-openwrt-feeds/+/c0ef0ca705bc7dad741fdfc65c60052725c3d7c1
+ 
+It integrates the XGMAC force mode v2–related fixes from the following patches:
+25.12/files/target/linux/mediatek/patches-6.12/999-eth-03-mtk_eth_soc-revise-xgmac-force-mode.patch  
+25.12/files/target/linux/mediatek/patches-6.12/999-eth-14-mtk_eth_soc-add-XGMACv2-support-for-MT7987.patch  
+25.12/files/target/linux/mediatek/patches-6.12/999-eth-47-mtk_eth_soc-add-extended-MIB-counters-for-NETSYSv3.patch 
+
+---
+v1: initial commit
+---
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -860,33 +860,6 @@ init_err:
+ 		mac->id, phy_modes(state->interface), err);
+ }
+ 
+-static int mtk_mac_prepare(struct phylink_config *config, unsigned int mode,
+-			   phy_interface_t iface)
+-{
+-	struct mtk_mac *mac = container_of(config, struct mtk_mac,
+-					   phylink_config);
+-	struct mtk_eth *eth = mac->hw;
+-
+-	if (mtk_is_netsys_v3_or_greater(mac->hw) && mtk_interface_mode_is_xgmii(iface) &&
+-	    mac->id != MTK_GMAC1_ID) {
+-		mtk_m32(mac->hw, XMAC_MCR_TRX_DISABLE,
+-			XMAC_MCR_TRX_DISABLE, MTK_XMAC_MCR(mac->id));
+-
+-		if (MTK_HAS_CAPS(eth->soc->caps, MTK_XGMAC_V2))
+-			mtk_m32(mac->hw, XMAC_FORCE_RX_FC_MODE | XMAC_FORCE_TX_FC_MODE |
+-					 XMAC_FORCE_LINK_MODE | XMAC_FORCE_LINK,
+-					 XMAC_FORCE_RX_FC_MODE | XMAC_FORCE_TX_FC_MODE |
+-					 XMAC_FORCE_LINK_MODE, MTK_XMAC_STS_FRC(mac->id));
+-		else
+-			mtk_m32(mac->hw, MTK_XGMAC_FORCE_MODE(mac->id) | MTK_XGMAC_FORCE_LINK(mac->id),
+-				MTK_XGMAC_FORCE_MODE(mac->id), MTK_XGMAC_STS(mac->id));
+-
+-		mtk_w32(mac->hw, 0x4, MTK_XMAC_CNT_CTRL(mac->id));
+-	}
+-
+-	return 0;
+-}
+-
+ static int mtk_mac_finish(struct phylink_config *config, unsigned int mode,
+ 			  phy_interface_t interface)
+ {
+@@ -1243,7 +1216,6 @@ static void mtk_mac_link_up(struct phyli
+ static const struct phylink_mac_ops mtk_phylink_ops = {
+ 	.mac_select_pcs = mtk_mac_select_pcs,
+ 	.mac_config = mtk_mac_config,
+-	.mac_prepare = mtk_mac_prepare,
+ 	.mac_finish = mtk_mac_finish,
+ 	.mac_link_down = mtk_mac_link_down,
+ 	.mac_link_up = mtk_mac_link_up,
+@@ -5516,12 +5488,28 @@ static int mtk_hw_init(struct mtk_eth *e
+ 	 * invoked.
+ 	 */
+ 	for (i = 0; i < MTK_MAX_DEVS; i++) {
+-		struct net_device *dev = eth->netdev[i];
++		if (!mtk_is_netsys_v3_or_greater(eth) && i == MTK_GMAC3_ID)
++ 			continue;
++ 
++ 		mtk_w32(eth, MAC_MCR_FORCE_LINK_DOWN, MTK_MAC_MCR(i));
++
++		if (mtk_is_netsys_v3_or_greater(eth) && eth->soc->caps == MT7988_CAPS)
++			mtk_m32(eth, MTK_XGMAC_FORCE_MODE(i) | MTK_XGMAC_FORCE_LINK(i),
++				     MTK_XGMAC_FORCE_MODE(i), MTK_XGMAC_STS(i));
+ 
+-		if (!dev)
+-			continue;
++		if (mtk_is_netsys_v3_or_greater(eth) && i >= MTK_GMAC2_ID) {
++			if (eth->soc->caps == MT7987_CAPS && i == MTK_GMAC3_ID)
++				continue;
+ 
+-		mtk_w32(eth, MAC_MCR_FORCE_LINK_DOWN, MTK_MAC_MCR(i));
++			if (MTK_HAS_CAPS(eth->soc->caps, MTK_XGMAC_V2))
++				mtk_m32(eth, XMAC_FORCE_RX_FC_MODE | XMAC_FORCE_TX_FC_MODE |
++					     XMAC_FORCE_LINK_MODE | XMAC_FORCE_LINK,
++					     XMAC_FORCE_RX_FC_MODE | XMAC_FORCE_TX_FC_MODE |
++					     XMAC_FORCE_LINK_MODE, MTK_XMAC_STS_FRC(i));
++
++			mtk_m32(eth, XMAC_MCR_TRX_DISABLE, XMAC_MCR_TRX_DISABLE, MTK_XMAC_MCR(i));
++			mtk_w32(eth, 0x4, MTK_XMAC_CNT_CTRL(i));
++		}
+ 	}
+ 
+ 	/* Indicates CDM to parse the MTK special tag from CPU
-- 
2.34.1

