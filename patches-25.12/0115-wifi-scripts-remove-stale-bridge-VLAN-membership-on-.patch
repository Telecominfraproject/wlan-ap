From 9e3bebbe4c2c82010c84c7d0a41004c9000b835d Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 8 Jun 2026 10:01:47 +0200
Subject: [PATCH] wifi-scripts: remove stale bridge/VLAN membership on wireless
 reconfig

When a wifi-iface's network changes, the wdev stays "up" and re-runs
setup without a teardown, so handle_link(..., false) is never issued for
the networks the vif left behind. The BSS netdev keeps its old bridge and
VLAN membership and only accumulates the new one, leaving clients on the
previous segment (e.g. the upstream bridge after a bridge to NAT switch)
until the next reboot. Static bridge ports are diffed correctly; only the
wireless hotplug ports leak.

Unlink the memberships that are absent from the new config in
wdev_config_init() before the previous handler_data is discarded, matched
by section key. Only the removed networks are torn down, so BSSes whose
network is unchanged are left untouched.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../files/lib/netifd/wireless-device.uc       | 41 ++++++++++++++++++-
 1 file changed, 39 insertions(+), 2 deletions(-)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/wireless-device.uc b/package/network/config/wifi-scripts/files/lib/netifd/wireless-device.uc
index 768a421480..339ad9ea0b 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/wireless-device.uc
+++ b/package/network/config/wifi-scripts/files/lib/netifd/wireless-device.uc
@@ -81,6 +81,40 @@ function handle_link(dev, data, up)
 		});
 }
 
+function build_network_map(handler_config)
+{
+	let map = {};
+	for (let vif_name, vif in handler_config.interfaces) {
+		map[vif.name] = vif.config.network ?? [];
+		for (let vlan_name, vlan in vif.vlans)
+			map[vif.name + "/" + vlan.name] = vlan.config.network ?? [];
+	}
+	return map;
+}
+
+// A reconfig keeps the wdev "up" and re-runs setup without a teardown, so
+// handle_link(..., false) is never issued for networks the vif left behind.
+// Unlink only the memberships that are gone from the new config, matched by
+// section key (the new ifnames are not known until setup re-registers them).
+function remove_stale_links(prev, handler_config)
+{
+	let keep = build_network_map(handler_config);
+
+	for (let key, data in prev) {
+		if (!data.ifname)
+			continue;
+		if (data.type != "vif" && data.type != "vlan")
+			continue;
+
+		let cur = keep[key] ?? [];
+		let removed = filter(data.config.network ?? [], net => index(cur, net) < 0);
+		if (!length(removed))
+			continue;
+
+		handle_link(data.ifname, { ...data, config: { ...data.config, network: removed } }, false);
+	}
+}
+
 function wdev_config_init(wdev)
 {
 	let data = wdev.data;
@@ -136,8 +170,11 @@ function wdev_config_init(wdev)
 	let prev = wdev.handler_data;
 	wdev.handler_data = {};
 
-	if (prev && prev[wdev.name])
-		wdev.handler_data[wdev.name] = prev[wdev.name];
+	if (prev) {
+		remove_stale_links(prev, wdev.handler_config);
+		if (prev[wdev.name])
+			wdev.handler_data[wdev.name] = prev[wdev.name];
+	}
 }
 
 function wdev_setup_cb(wdev)
-- 
2.34.1

