From 9dfcbc914a647b89d85b555d0a2fb2e65ec76c63 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Thu, 11 Jun 2026 12:05:57 +0200
Subject: [PATCH] busybox: udhcpc: respect retries on network error

Avoids infinite loop if the interface is down

Signed-off-by: John Crispin <john@phrozen.org>
---
 ...02-udhcpc_respect_retries_on_read_error.patch | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)
 create mode 100644 package/utils/busybox/patches/202-udhcpc_respect_retries_on_read_error.patch

diff --git a/package/utils/busybox/patches/202-udhcpc_respect_retries_on_read_error.patch b/package/utils/busybox/patches/202-udhcpc_respect_retries_on_read_error.patch
new file mode 100644
index 0000000000..63fef83b18
--- /dev/null
+++ b/package/utils/busybox/patches/202-udhcpc_respect_retries_on_read_error.patch
@@ -0,0 +1,16 @@
+--- a/networking/udhcp/dhcpc.c
++++ b/networking/udhcp/dhcpc.c
+@@ -1628,6 +1628,13 @@ int udhcpc_main(int argc UNUSED_PARAM, c
+ 				bb_error_msg("read error: "STRERROR_FMT", reopening socket" STRERROR_ERRNO);
+ 				sleep(discover_timeout); /* 3 seconds by default */
+ 				change_listen_mode(client_data.listen_mode); /* just close and reopen */
++				/* Expire the timeout so the retry/timeout state machine
++				 * runs next iteration. Without this, a persistently
++				 * erroring socket (e.g. interface down) keeps waking
++				 * poll() and we never reach the retry-exhaustion logic,
++				 * ignoring the discover retry limit (-t).
++				 */
++				timeout = 0;
+ 			}
+ 			if (len < 0)
+ 				continue;
-- 
