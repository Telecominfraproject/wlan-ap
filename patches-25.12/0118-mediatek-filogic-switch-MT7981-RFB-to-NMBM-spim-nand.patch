From b853ba69d0c3d8555a779bf595666293fa577ae5 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:40:49 +0200
Subject: [PATCH 118/149] mediatek: filogic: switch MT7981-RFB to NMBM
 spim-nand overlay

Switch the spim-nand DEVICE_DTS_OVERLAY entry to its NMBM-enabled
variant (mt7981-rfb-spim-nand-nmbm) and add the mt7981-rfb-spim-nor
overlay so the MT7981-RFB image picks up the dtso files added by
the MediaTek kernel-6.12 patch import in patches-25.12/0108. Tag
the device model with the (DT-overlay) suffix to mirror upstream
MTK naming.

Import of patches-base/1144-01 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 1fe0ddb147..6de08f0b0e 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -1961,10 +1961,11 @@ TARGET_DEVICES += konka_komi-a31
 
 define Device/mediatek_mt7981-rfb
   DEVICE_VENDOR := MediaTek
-  DEVICE_MODEL := MT7981 rfb
+  DEVICE_MODEL := MT7981 rfb (DT-overlay)
   DEVICE_DTS := mt7981-rfb
   DEVICE_DTS_OVERLAY:= \
-	mt7981-rfb-spim-nand \
+	mt7981-rfb-spim-nor \
+	mt7981-rfb-spim-nand-nmbm \
 	mt7981-rfb-mxl-2p5g-phy-eth1 \
 	mt7981-rfb-mxl-2p5g-phy-swp5
   DEVICE_DTS_DIR := $(DTS_DIR)/
-- 
