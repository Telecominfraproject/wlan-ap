From d4ef7a7c422981c624793450657b6b187947e0aa Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:43:21 +0200
Subject: [PATCH 122/149] netifd: drop packet_steering init.d service

Delete the packet_steering init.d script and its triggers. The
script reloads the userspace packet-steering helper on every
network/firewall reload, which produces noisy reloads and is
unnecessary on filogic where steering is set up at boot via
the platform helper directly.

Import of patches-base/0013 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../netifd/files/etc/init.d/packet_steering   | 25 -------------------
 1 file changed, 25 deletions(-)
 delete mode 100755 package/network/config/netifd/files/etc/init.d/packet_steering

diff --git a/package/network/config/netifd/files/etc/init.d/packet_steering b/package/network/config/netifd/files/etc/init.d/packet_steering
deleted file mode 100755
index 5266a931ae..0000000000
--- a/package/network/config/netifd/files/etc/init.d/packet_steering
+++ /dev/null
@@ -1,25 +0,0 @@
-#!/bin/sh /etc/rc.common
-
-START=25
-USE_PROCD=1
-
-start_service() {
-	reload_service
-}
-
-service_triggers() {
-	procd_add_reload_trigger "network"
-	procd_add_reload_trigger "firewall"
-	procd_add_raw_trigger "interface.*" 1000 /etc/init.d/packet_steering reload
-}
-
-reload_service() {
-	packet_steering="$(uci -q get "network.@globals[0].packet_steering")"
-	steering_flows="$(uci -q get "network.@globals[0].steering_flows")"
-	[ "${steering_flows:-0}" -gt 0 ] && opts="-l $steering_flows"
-	if [ -e "/usr/libexec/platform/packet-steering.sh" ]; then
-		/usr/libexec/platform/packet-steering.sh "$packet_steering"
-	else
-		/usr/libexec/network/packet-steering.uc $opts "$packet_steering"
-	fi
-}
