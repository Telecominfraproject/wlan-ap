From 4349f88bb65649547cbb7e8bffa401d72ffa1c17 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:43:21 +0200
Subject: [PATCH 127/149] dtc: add host build

Add a HostBuild stanza so dtc is installable as a host tool.
Image build steps that need to compile or assemble device-tree
overlays invoke dtc on the host before any target packages are
staged; paired with patches-base/0940 which wires the dependency
into the package/compile target.

Import of patches-base/3701 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/utils/dtc/Makefile | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/package/utils/dtc/Makefile b/package/utils/dtc/Makefile
index 9a03662afa..699cf4d8ac 100644
--- a/package/utils/dtc/Makefile
+++ b/package/utils/dtc/Makefile
@@ -20,6 +20,7 @@ PKG_CPE_ID:=cpe:/a:dtc_project:dtc
 PKG_INSTALL:=1
 
 include $(INCLUDE_DIR)/package.mk
+include $(INCLUDE_DIR)/host-build.mk
 include $(INCLUDE_DIR)/meson.mk
 
 define Package/dtc
@@ -95,6 +96,10 @@ MESON_ARGS += \
 	-Dpython=disabled \
 	-Dstatic-build=$(if $(CONFIG_DTC_STATIC_BUILD),true,false)
 
+MESON_HOST_ARGS += $(MESON_ARGS)
+
+HOST_LDFLAGS += -Wl,-rpath=$(STAGING_DIR_HOSTPKG)/lib
+
 define Build/InstallDev
 	$(INSTALL_DIR) $(1)/usr/lib
 	$(INSTALL_DIR) $(1)/usr/include
@@ -105,3 +110,4 @@ endef
 $(eval $(call BuildPackage,dtc))
 $(eval $(call BuildPackage,fdt-utils))
 $(eval $(call BuildPackage,libfdt))
+$(eval $(call HostBuild))
-- 
