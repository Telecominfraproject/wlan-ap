From e5f0835d782d6cec95c90f44ea96bddf125cf3f3 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Fri, 1 Aug 2025 14:23:01 +0200
Subject: [PATCH] gpio-button-hotplug: fix compile on older kernel

Adds kernel version compatibility for GPIO API changes between 5.4/6.1 and 6.6 kernels, ensuring button driver compiles across all supported versions.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../src/gpio-button-hotplug.c                 | 54 +++++++++++++++++--
 1 file changed, 51 insertions(+), 3 deletions(-)

diff --git a/package/kernel/gpio-button-hotplug/src/gpio-button-hotplug.c b/package/kernel/gpio-button-hotplug/src/gpio-button-hotplug.c
index d0e3723311..1e8199c984 100644
--- a/package/kernel/gpio-button-hotplug/src/gpio-button-hotplug.c
+++ b/package/kernel/gpio-button-hotplug/src/gpio-button-hotplug.c
@@ -365,6 +365,9 @@ gpio_keys_get_devtree_pdata(struct device *dev)
 {
 	struct device_node *node = dev->of_node;
 	struct gpio_keys_platform_data *pdata;
+#if (LINUX_VERSION_CODE < KERNEL_VERSION(6,8,0))
+	struct device_node *pp;
+#endif
 	int nbuttons;
 	int i = 0;
 
@@ -382,15 +385,26 @@ gpio_keys_get_devtree_pdata(struct device *dev)
 
 	pdata->nbuttons = nbuttons;
 
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,3,0))
 	pdata->rep = of_property_present(node, "autorepeat");
+#else
+	pdata->rep = !!of_get_property(node, "autorepeat", NULL);
+#endif
 	of_property_read_u32(node, "poll-interval", &pdata->poll_interval);
 
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,8,0))
 	for_each_available_child_of_node_scoped(node, pp) {
+#else
+	for_each_child_of_node(node, pp) {
+#endif
 		struct gpio_keys_button *button = (struct gpio_keys_button *)&pdata->buttons[i++];
 
 		if (of_property_read_u32(pp, "linux,code", &button->code)) {
 			dev_err(dev, "Button node '%s' without keycode\n",
 				pp->full_name);
+#if (LINUX_VERSION_CODE < KERNEL_VERSION(6,8,0))
+			of_node_put(pp);
+#endif
 			return ERR_PTR(-EINVAL);
 		}
 
@@ -399,7 +413,11 @@ gpio_keys_get_devtree_pdata(struct device *dev)
 		if (of_property_read_u32(pp, "linux,input-type", &button->type))
 			button->type = EV_KEY;
 
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,3,0))
 		button->wakeup = of_property_present(pp, "gpio-key,wakeup");
+#else
+		button->wakeup = !!of_get_property(pp, "gpio-key,wakeup", NULL);
+#endif
 
 		if (of_property_read_u32(pp, "debounce-interval",
 					&button->debounce_interval))
@@ -459,12 +477,20 @@ static int gpio_keys_button_probe(struct platform_device *pdev,
 		return -EINVAL;
 	}
 
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,8,0))
 	buttons = devm_kmemdup_array(dev, pdata->buttons, pdata->nbuttons, sizeof(struct gpio_keys_button),
 		       GFP_KERNEL);
+#else
+	buttons = devm_kzalloc(dev, pdata->nbuttons * sizeof(struct gpio_keys_button),
+		       GFP_KERNEL);
+#endif
 	if (!buttons) {
 		dev_err(dev, "no memory for button data\n");
 		return -ENOMEM;
 	}
+#if (LINUX_VERSION_CODE < KERNEL_VERSION(6,8,0))
+	memcpy(buttons, pdata->buttons, pdata->nbuttons * sizeof(struct gpio_keys_button));
+#endif
 
 	bdev = devm_kzalloc(dev, struct_size(bdev, data, pdata->nbuttons), GFP_KERNEL);
 	if (!bdev) {
@@ -518,9 +544,10 @@ static int gpio_keys_button_probe(struct platform_device *pdev,
 					button->active_low ? GPIOF_ACTIVE_LOW :
 					0), desc);
 				if (error) {
-					dev_err_probe(dev, error,
-						      "unable to claim gpio %d",
-						      button->gpio);
+					if (error != -EPROBE_DEFER) {
+						dev_err(dev, "unable to claim gpio %d, err=%d\n",
+							button->gpio, error);
+					}
 					goto out;
 				}
 
@@ -531,9 +558,14 @@ static int gpio_keys_button_probe(struct platform_device *pdev,
 			struct device_node *child =
 				of_get_next_child(dev->of_node, prev);
 
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,6,1))
 			bdata->gpiod = devm_fwnode_gpiod_get(dev,
 				of_fwnode_handle(child), NULL, GPIOD_IN,
 				desc);
+#else
+			bdata->gpiod = devm_gpiod_get_from_of_node(dev,
+				child, "gpios", 0, GPIOD_IN, desc);
+#endif
 
 			prev = child;
 		}
@@ -667,7 +699,11 @@ static void gpio_keys_irq_close(struct gpio_keys_button_dev *bdev)
 	}
 }
 
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,1,0))
 static void gpio_keys_remove(struct platform_device *pdev)
+#else
+static int gpio_keys_remove(struct platform_device *pdev)
+#endif
 {
 	struct gpio_keys_button_dev *bdev = platform_get_drvdata(pdev);
 
@@ -677,11 +713,19 @@ static void gpio_keys_remove(struct platform_device *pdev)
 		gpio_keys_polled_close(bdev);
 	else
 		gpio_keys_irq_close(bdev);
+
+#if (LINUX_VERSION_CODE < KERNEL_VERSION(6,1,0))
+	return 0;
+#endif
 }
 
 static struct platform_driver gpio_keys_driver = {
 	.probe	= gpio_keys_probe,
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,1,0))
 	.remove_new = gpio_keys_remove,
+#else
+	.remove	= gpio_keys_remove,
+#endif
 	.driver	= {
 		.name	= "gpio-keys",
 		.of_match_table = of_match_ptr(gpio_keys_of_match),
@@ -690,7 +734,11 @@ static struct platform_driver gpio_keys_driver = {
 
 static struct platform_driver gpio_keys_polled_driver = {
 	.probe	= gpio_keys_polled_probe,
+#if (LINUX_VERSION_CODE >= KERNEL_VERSION(6,1,0))
 	.remove_new = gpio_keys_remove,
+#else
+	.remove	= gpio_keys_remove,
+#endif
 	.driver	= {
 		.name	= "gpio-keys-polled",
 		.of_match_table = of_match_ptr(gpio_keys_polled_of_match),
-- 
2.34.1

