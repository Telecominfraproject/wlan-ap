From a5bcb1d677af6a3e732c82d11ad06a7986230ffb Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:52:35 +0200
Subject: [PATCH 144/149] mediatek: filogic: add SFP overlay to MT7986A/B-RFB

Add mt7986-sfp-eth1 DT overlay to MT7986A-RFB and MT7986B-RFB
image definitions so they support configurations with an SFP
module on eth1.

Import of patches-base/1148 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index b61cefba8e..f77dad7a22 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2002,6 +2002,7 @@ define Device/mediatek_mt7986a-rfb
   DEVICE_MODEL := MT7986A rfb (DT-overlay)
   DEVICE_DTS := mt7986a-rfb
   DEVICE_DTS_OVERLAY:= \
+	mt7986-sfp-eth1 \
 	mt7986-spim-nand \
 	mt7986-spim-nand-nmbm \
 	mt7986-spim-nor \
@@ -2028,6 +2029,7 @@ define Device/mediatek_mt7986b-rfb
   DEVICE_MODEL := MT7986B rfb (DT-overlay)
   DEVICE_DTS := mt7986b-rfb
   DEVICE_DTS_OVERLAY:= \
+	mt7986-sfp-eth1 \
 	mt7986-spim-nand \
 	mt7986-spim-nand-nmbm \
 	mt7986-spim-nor \
-- 
