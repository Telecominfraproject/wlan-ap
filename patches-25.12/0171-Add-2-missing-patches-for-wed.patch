From ba169b4289b2f4cc14090b9e18a4456285dfd273 Mon Sep 17 00:00:00 2001
From: Sam Shih <sam.shih@mediatek.com>
Date: Thu, 21 May 2026 15:21:03 +0800
Subject: [PATCH v1] Add 2 missing patches for wed

---
 ...wed-06-dts-88d-option-type-2-support.patch | 29 +++++++++++++
 .../999-wed-12-dts-mt7987-wed-changes.patch   | 41 +++++++++++++++++++
 2 files changed, 70 insertions(+)
 create mode 100644 target/linux/mediatek/patches-6.12/999-wed-06-dts-88d-option-type-2-support.patch
 create mode 100644 target/linux/mediatek/patches-6.12/999-wed-12-dts-mt7987-wed-changes.patch

--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-wed-06-dts-88d-option-type-2-support.patch
@@ -0,0 +1,29 @@
+From 1b5db1016559bcccc38bf7942f9ed04b676c0570 Mon Sep 17 00:00:00 2001
+From: Rex Lu <rex.lu@mediatek.com>
+Date: Wed, 18 Dec 2024 19:39:18 +0800
+Subject: [PATCH 06/15] dts 88d option type 2 support
+
+Signed-off-by: Rex Lu <rex.lu@mediatek.com>
+---
+ arch/arm64/boot/dts/mediatek/mt7988d-rfb.dts | 10 ++++++++++
+ 1 file changed, 10 insertions(+)
+
+--- a/arch/arm64/boot/dts/mediatek/mt7988d-rfb.dts
++++ b/arch/arm64/boot/dts/mediatek/mt7988d-rfb.dts
+@@ -64,6 +64,16 @@
+  * -ssusb1: usb@11200000 (u2 port and u3 port)
+  */
+ 
++&pcie0 {
++	slot0: pcie@0,0 {
++		reg = <0x0000 0 0 0 0>;
++
++		mt7996@0,0 {
++			option_type = <2>;
++		};
++	};
++};
++
+ &pcie1 {
+ 	status = "disabled";
+ };
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-wed-12-dts-mt7987-wed-changes.patch
@@ -0,0 +1,41 @@
+From 36f858bd508cedc27ea5d5d6c3ecadfc85a015bb Mon Sep 17 00:00:00 2001
+From: Rex Lu <rex.lu@mediatek.com>
+Date: Tue, 8 Apr 2025 13:03:51 +0800
+Subject: [PATCH 12/15] dts mt7987 wed changes
+
+---
+ arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi |  1 +
+ arch/arm64/boot/dts/mediatek/mt7987.dtsi        | 12 +++---------
+ 2 files changed, 4 insertions(+), 9 deletions(-)
+
+--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
++++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
+@@ -52,6 +52,7 @@
+ 					 <&apmixedsys CLK_APMIXED_SGMPLL>,
+ 					 <&apmixedsys CLK_APMIXED_SGMPLL>;
+ 		mediatek,ethsys = <&ethsys>;
++		mediatek,wed = <&wed0>;
+ 		mediatek,infracfg = <&topmisc>;
+ 		pinctrl-names = "default";
+ 		pinctrl-0 = <&mdio0_pins>;
+--- a/arch/arm64/boot/dts/mediatek/mt7987.dtsi
++++ b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
+@@ -642,15 +642,9 @@
+ 			status = "disabled";
+ 		};
+ 
+-		wed: wed {
+-			compatible = "mediatek,wed";
+-			wed_num = <1>;
+-		};
+-
+-		wed0: wed0@15010000 {
+-			compatible = "mediatek,wed0";
+-			/* add this property for wed get the pci slot number */
+-			pci_slot_map = <0>;
++		wed0: wed@15010000 {
++			compatible = "mediatek,mt7987-wed",
++				     "syscon";
+ 			reg = <0 0x15010000 0 0x2000>;
+ 			interrupt-parent = <&gic>;
+ 			interrupts = <GIC_SPI 205 IRQ_TYPE_LEVEL_HIGH>;
