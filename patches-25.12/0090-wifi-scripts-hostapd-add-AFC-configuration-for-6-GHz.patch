From eae882768d37a472f66bb1e3196490f56a5b4ae7 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 2 Feb 2026 09:20:24 +0100
Subject: [PATCH 90/93] wifi-scripts: hostapd: add AFC configuration for 6 GHz

Add Automatic Frequency Coordination (AFC) support for 6 GHz band
operation. When AFC is enabled, the full set of AFC parameters
(request metadata, location, frequency ranges, operating classes) is
emitted into the hostapd device configuration. AFC activation also
forces reg_power_type to SP (1).

Supports ellipse, linear polygon, and radial polygon location types.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../wifi-scripts/files/lib/netifd/hostapd.sh  | 38 +++++++++++++++++++
 1 file changed, 38 insertions(+)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
index 08a8d2494a..23b26fc40d 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
@@ -278,6 +278,44 @@ hostapd_prepare_device_config() {
 	[ -n "$maxassoc" ] && append base_cfg "iface_max_num_sta=$maxassoc" "$N"
 	[ "$mbssid" -gt 0 ] && [ "$mbssid" -le 2 ] && append base_cfg "mbssid=$mbssid" "$N"
 
+	if [ "$band" = "6g" ]; then
+		json_get_vars afc
+	else
+		afc=0
+	fi
+	set_default afc 0
+	[ "$afc" -gt 0 ] && {
+		for v in afc_request_version afc_request_id afc_serial_number afc_min_power afc_height afc_height_type afc_vertical_tolerance \
+				 afc_major_axis afc_minor_axis afc_orientation; do
+			json_get_var val $v
+			append base_cfg "$v=$val" "$N"
+		done
+
+		for v in afc_cert_ids afc_op_class afc_freq_range; do
+			val=
+			hostapd_get_list val $v
+			append base_cfg "$v=$val" "$N"
+		done
+
+		json_get_vars afc_location_type afc_location
+		case "$afc_location_type" in
+			ellipse)
+				append base_cfg "afc_location_type=0" "$N"
+				append base_cfg "afc_linear_polygon=$afc_location" "$N"
+			;;
+			linear_polygon)
+				append base_cfg "afc_location_type=1" "$N"
+				append base_cfg "afc_linear_polygon=$afc_location" "$N"
+			;;
+			radial_polygon)
+				append base_cfg "afc_location_type=2" "$N"
+				append base_cfg "afc_radial_polygon=$afc_location" "$N"
+			;;
+		esac
+
+		reg_power_type=1
+	}
+
 	[ "$band" = "6g" ] && {
 		set_default reg_power_type 0
 		append base_cfg "he_6ghz_reg_pwr_type=$reg_power_type" "$N"
-- 
