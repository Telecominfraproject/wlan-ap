From 627d1cf70fd615aac761f8299fb16d99e765f7a4 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:33:38 +0200
Subject: [PATCH 113/149] mediatek: filogic: remove 2.5GE phy from built-in
 kernel config

CONFIG_MEDIATEK_2P5GE_PHY=y is dropped from the filogic config so the
driver can be built as a module via KernelPackage instead of being
forced into vmlinux. Import of patches-base/0010 from MediaTek 25.12
feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/filogic/config-6.12 | 1 -
 1 file changed, 1 deletion(-)

diff --git a/target/linux/mediatek/filogic/config-6.12 b/target/linux/mediatek/filogic/config-6.12
index 5379146644..a2277e45ef 100644
--- a/target/linux/mediatek/filogic/config-6.12
+++ b/target/linux/mediatek/filogic/config-6.12
@@ -257,7 +257,6 @@ CONFIG_MDIO_AN8855=y
 CONFIG_MDIO_BUS=y
 CONFIG_MDIO_DEVICE=y
 CONFIG_MDIO_DEVRES=y
-CONFIG_MEDIATEK_2P5GE_PHY=y
 CONFIG_MEDIATEK_GE_PHY=y
 CONFIG_MEDIATEK_GE_SOC_PHY=y
 CONFIG_MEDIATEK_WATCHDOG=y
-- 
2.34.1

