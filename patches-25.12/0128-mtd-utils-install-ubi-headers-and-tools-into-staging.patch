From 421079f2ed36ed8c3289cc0bf3755245fede2828 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:43:21 +0200
Subject: [PATCH 128/149] mtd-utils: install ubi headers and tools into staging

Add a Build/InstallDev stanza so mtd-utils ships its UBI public
headers and host tools (ubinize, mkfs.ubifs) into staging, where
image build steps and other packages expect to find them.

Import of patches-base/3703 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/utils/mtd-utils/Makefile | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/package/utils/mtd-utils/Makefile b/package/utils/mtd-utils/Makefile
index 482785f2ad..ef9a266507 100644
--- a/package/utils/mtd-utils/Makefile
+++ b/package/utils/mtd-utils/Makefile
@@ -72,6 +72,14 @@ define Package/ubi-utils/conffiles
 /etc/config/ubihealthd
 endef
 
+define Build/InstallDev
+	$(INSTALL_DIR) $(1)/usr/include
+	$(CP) $(PKG_BUILD_DIR)/include/libmtd.h $(1)/usr/include
+	$(INSTALL_DIR) $(1)/usr/lib
+	$(CP) $(PKG_BUILD_DIR)/libmtd.a $(1)/usr/lib
+	$(CP) $(PKG_BUILD_DIR)/libubi.a $(1)/usr/lib
+endef
+
 define Package/ubi-utils/install
 	$(INSTALL_DIR) $(1)/usr/sbin
 	$(INSTALL_BIN) \
-- 
2.34.1

