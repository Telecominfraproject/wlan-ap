From e0fb75363448ac7ea16221ebf2cfe92abcf9d7f7 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 2 Mar 2026 12:44:19 +0100
Subject: [PATCH] mediatek: add support for Edgecore EAP115/EAP115a

MT7987A-based access points with MT7992 WiFi (PCIe), RTL8211FS 1G
Ethernet (SGMII, LAN) and internal 2.5G PHY (WAN). SPI-NAND flash
with dual rootfs A/B partition scheme.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../uboot-envtools/files/mediatek_filogic     |   2 +
 .../mediatek/dts/mt7987a-edgecore-eap115.dts  |   9 +
 .../mediatek/dts/mt7987a-edgecore-eap115.dtsi | 230 ++++++++++++++++++
 .../mediatek/dts/mt7987a-edgecore-eap115a.dts |   9 +
 .../filogic/base-files/etc/board.d/01_leds    |   4 +
 .../filogic/base-files/etc/board.d/02_network |   9 +
 .../filogic/base-files/etc/init.d/bootcount   |   4 +-
 .../lib/preinit/05_set_edgecore_netdev        |  13 +
 .../base-files/lib/upgrade/platform.sh        |   4 +-
 target/linux/mediatek/image/filogic.mk        |  40 +++
 10 files changed, 322 insertions(+), 2 deletions(-)
 create mode 100644 target/linux/mediatek/dts/mt7987a-edgecore-eap115.dts
 create mode 100644 target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi
 create mode 100644 target/linux/mediatek/dts/mt7987a-edgecore-eap115a.dts
 create mode 100644 target/linux/mediatek/filogic/base-files/lib/preinit/05_set_edgecore_netdev

diff --git a/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic b/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
index 6e8c2c1a97..a0d54d2c76 100644
--- a/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
+++ b/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
@@ -71,6 +71,8 @@ asiarf,ap7986-003|\
 cetron,ct3003|\
 comfast,cf-wr632ax|\
 edgecore,eap111|\
+edgecore,eap115|\
+edgecore,eap115a|\
 netgear,wax220|\
 zbtlink,zbt-z8102ax|\
 zbtlink,zbt-z8103ax)
diff --git a/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dts b/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dts
new file mode 100644
index 0000000000..6fa9d3655c
--- /dev/null
+++ b/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dts
@@ -0,0 +1,9 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+
+/dts-v1/;
+#include "mt7987a-edgecore-eap115.dtsi"
+
+/ {
+	model = "Edgecore EAP115";
+	compatible = "edgecore,eap115", "mediatek,mt7987a", "mediatek,mt7987";
+};
diff --git a/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi b/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi
new file mode 100644
index 0000000000..9d344c7ce5
--- /dev/null
+++ b/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi
@@ -0,0 +1,230 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+
+#include "mt7987a.dtsi"
+#include <dt-bindings/input/input.h>
+#include <dt-bindings/leds/common.h>
+
+/ {
+	aliases {
+		serial0 = &uart0;
+		led-boot = &led_green;
+		led-failsafe = &led_green;
+		led-running = &led_green;
+		led-upgrade = &led_green;
+		label-mac-device = &gmac1;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+
+	gpio-keys {
+		compatible = "gpio-keys";
+
+		button-reset {
+			label = "reset";
+			linux,code = <KEY_RESTART>;
+			gpios = <&pio 1 GPIO_ACTIVE_LOW>;
+			debounce-interval = <10>;
+		};
+	};
+
+	gpio-leds {
+		compatible = "gpio-leds";
+
+		led_green: led-green {
+			gpios = <&pio 9 GPIO_ACTIVE_HIGH>;
+			color = <LED_COLOR_ID_GREEN>;
+			function = LED_FUNCTION_INDICATOR;
+		};
+
+		led_orange: led-orange {
+			gpios = <&pio 12 GPIO_ACTIVE_HIGH>;
+			color = <LED_COLOR_ID_ORANGE>;
+			function = LED_FUNCTION_INDICATOR;
+		};
+
+		led_blue: led-blue {
+			gpios = <&pio 8 GPIO_ACTIVE_HIGH>;
+			color = <LED_COLOR_ID_BLUE>;
+			function = LED_FUNCTION_INDICATOR;
+		};
+	};
+
+	gpio-watchdog {
+		compatible = "linux,wdt-gpio";
+		gpios = <&pio 22 GPIO_ACTIVE_LOW>;
+		hw_algo = "level";
+		hw_margin_ms = <1000>;
+		always-running;
+	};
+
+};
+
+&eth {
+	/delete-node/ mac@2;
+};
+
+&gmac0 {
+	phy-mode = "sgmii";
+	phy-handle = <&phy2>;
+	nvmem-cells = <&macaddr_lan>;
+	nvmem-cell-names = "mac-address";
+	status = "okay";
+};
+
+&gmac1 {
+	phy-mode = "internal";
+	phy-handle = <&phy15>;
+	nvmem-cells = <&macaddr_wan>;
+	nvmem-cell-names = "mac-address";
+	status = "okay";
+};
+
+&mdio {
+	phy2: phy@2 {
+		compatible = "ethernet-phy-id001c.c916";
+		reg = <2>;
+		reset-gpios = <&pio 42 GPIO_ACTIVE_LOW>;
+		reset-assert-us = <10000>;
+		reset-deassert-us = <50000>;
+		realtek,clkout-disable;
+		realtek,aldps-enable;
+	};
+
+	phy15: phy@15 {
+		compatible = "ethernet-phy-ieee802.3-c45";
+		reg = <15>;
+
+		pinctrl-0 = <&i2p5gbe_led0_pins>;
+		pinctrl-names = "i2p5gbe-led";
+	};
+};
+
+&pcie0 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&pcie0_pins>;
+	status = "okay";
+
+	pcie@0,0 {
+		reg = <0x0000 0 0 0 0>;
+		#address-cells = <3>;
+		#size-cells = <2>;
+
+		mt7992@0,0 {
+			compatible = "mediatek,mt76";
+			reg = <0x0000 0 0 0 0>;
+
+			nvmem-cells = <&eeprom_factory>;
+			nvmem-cell-names = "eeprom";
+		};
+	};
+};
+
+&pcie1 {
+	status = "disabled";
+};
+
+&spi0 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&spi0_flash_pins>;
+	status = "okay";
+
+	flash@0 {
+		compatible = "spi-nand";
+		reg = <0>;
+
+		spi-cal-enable;
+		spi-cal-mode = "read-data";
+		spi-cal-datalen = <7>;
+		spi-cal-data = /bits/ 8 <0x53 0x50 0x49 0x4e 0x41 0x4e 0x44>;
+		spi-cal-addrlen = <5>;
+		spi-cal-addr = /bits/ 32 <0x0 0x0 0x0 0x0 0x0>;
+
+		spi-max-frequency = <52000000>;
+		spi-tx-bus-width = <4>;
+		spi-rx-bus-width = <4>;
+
+		mediatek,nmbm;
+		mediatek,bmt-max-ratio = <1>;
+		mediatek,bmt-max-reserved-blocks = <64>;
+
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "BL2";
+				reg = <0x0 0x100000>;
+				read-only;
+			};
+
+			partition@100000 {
+				label = "u-boot-env";
+				reg = <0x100000 0x40000>;
+			};
+
+			partition@140000 {
+				label = "priv_data1";
+				reg = <0x140000 0x20000>;
+			};
+
+			partition@160000 {
+				label = "priv_data2";
+				reg = <0x160000 0x20000>;
+			};
+
+			partition@180000 {
+				label = "Factory";
+				reg = <0x180000 0x400000>;
+				read-only;
+
+				nvmem-layout {
+					compatible = "fixed-layout";
+					#address-cells = <1>;
+					#size-cells = <1>;
+
+					eeprom_factory: eeprom@0 {
+						reg = <0x0 0x1e00>;
+					};
+
+					macaddr_wan: macaddr@ffffa {
+						reg = <0xffffa 0x6>;
+					};
+
+					macaddr_lan: macaddr@ffff4 {
+						reg = <0xffff4 0x6>;
+					};
+				};
+			};
+
+			partition@580000 {
+				label = "FIP";
+				reg = <0x580000 0x200000>;
+				read-only;
+			};
+
+			partition@780000 {
+				label = "rootfs1";
+				reg = <0x780000 0x3840000>;
+			};
+
+			partition@3fc0000 {
+				label = "rootfs2";
+				reg = <0x3fc0000 0x3840000>;
+			};
+		};
+	};
+};
+
+&ssusb {
+	status = "disabled";
+};
+
+&uart0 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&uart0_pins>;
+
+	status = "okay";
+};
diff --git a/target/linux/mediatek/dts/mt7987a-edgecore-eap115a.dts b/target/linux/mediatek/dts/mt7987a-edgecore-eap115a.dts
new file mode 100644
index 0000000000..f801e27943
--- /dev/null
+++ b/target/linux/mediatek/dts/mt7987a-edgecore-eap115a.dts
@@ -0,0 +1,9 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+
+/dts-v1/;
+#include "mt7987a-edgecore-eap115.dtsi"
+
+/ {
+	model = "Edgecore EAP115a";
+	compatible = "edgecore,eap115a", "mediatek,mt7987a", "mediatek,mt7987";
+};
diff --git a/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds b/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
index 0787a12913..cbbaa9dfd7 100644
--- a/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
+++ b/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
@@ -99,6 +99,10 @@ edgecore,eap112)
 	ucidef_set_led_netdev "wan" "wan" "orange:indicator" "eth1"
 	ucidef_set_led_netdev "wlan5g" "WLAN5G" "blue:indicator" "phy1-ap0"
 	;;
+edgecore,eap115|\
+edgecore,eap115a)
+	ucidef_set_led_netdev "wan" "wan" "orange:indicator" "eth0"
+	;;
 elecom,wrc-x3000gs3)
 	ucidef_set_led_netdev "wan" "wan" "green:wan" "wan"
 	;;
diff --git a/target/linux/mediatek/filogic/base-files/etc/board.d/02_network b/target/linux/mediatek/filogic/base-files/etc/board.d/02_network
index d820b66236..800c40f93d 100644
--- a/target/linux/mediatek/filogic/base-files/etc/board.d/02_network
+++ b/target/linux/mediatek/filogic/base-files/etc/board.d/02_network
@@ -125,6 +125,10 @@ mediatek_setup_interfaces()
 	huasifei,wh3000-pro)
 		ucidef_set_interfaces_lan_wan eth0 eth1
 		;;
+	edgecore,eap115|\
+	edgecore,eap115a)
+		ucidef_set_interfaces_lan_wan eth1 eth0
+		;;
 	bazis,ax3000wm|\
 	cudy,m3000-v1|\
 	cudy,tr3000-256mb-v1|\
@@ -214,6 +218,11 @@ mediatek_setup_macs()
 	local label_mac=""
 
 	case $board in
+	edgecore,eap115|\
+	edgecore,eap115a)
+		lan_mac=$(mtd_get_mac_binary "Factory" 0xffff4)
+		wan_mac=$(mtd_get_mac_binary "Factory" 0xffffa)
+		;;
 	airpi,ap3000m)
 		base_mac=$(macaddr_generate_from_mmc_cid mmcblk0)
 		lan_mac="$base_mac"
diff --git a/target/linux/mediatek/filogic/base-files/etc/init.d/bootcount b/target/linux/mediatek/filogic/base-files/etc/init.d/bootcount
index 947e31c649..3164a5731d 100755
--- a/target/linux/mediatek/filogic/base-files/etc/init.d/bootcount
+++ b/target/linux/mediatek/filogic/base-files/etc/init.d/bootcount
@@ -6,7 +6,9 @@ START=99
 boot() {
 	case $(board_name) in
 	edgecore,eap111|\
-	edgecore,eap112)
+	edgecore,eap112|\
+	edgecore,eap115|\
+	edgecore,eap115a)
 		bootcount=$(fw_printenv -n bootcount)
 		[ "$bootcount" != 0 ] && fw_setenv bootcount 0
 		# enable dualboot
diff --git a/target/linux/mediatek/filogic/base-files/lib/preinit/05_set_edgecore_netdev b/target/linux/mediatek/filogic/base-files/lib/preinit/05_set_edgecore_netdev
new file mode 100644
index 0000000000..a3b7403f84
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/lib/preinit/05_set_edgecore_netdev
@@ -0,0 +1,13 @@
+edgecore_swap_ethdev() {
+	case "$(cat /tmp/sysinfo/board_name)" in
+	edgecore,eap111|\
+	edgecore,eap115|\
+	edgecore,eap115a)
+		ip link set eth0 name lan
+		ip link set eth1 name eth0
+		ip link set lan name eth1
+		;;
+	esac
+}
+
+boot_hook_add preinit_main edgecore_swap_ethdev
diff --git a/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh b/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
index 8ef70fd7f8..5603bb6249 100644
--- a/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
+++ b/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
@@ -259,7 +259,9 @@ platform_do_upgrade() {
 		nand_do_upgrade "$1"
 		;;
 	edgecore,eap111|\
-	edgecore,eap112)
+	edgecore,eap112|\
+	edgecore,eap115|\
+	edgecore,eap115a)
 		if [ -e /tmp/downgrade ]; then
 			CI_UBIPART="rootfs1"
 			{ echo 'active 1'; echo 'upgrade_available 0'; } > /tmp/fw_setenv.txt || exit 1
diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 48f35a6424..7807433e22 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -1386,6 +1386,46 @@ define Device/edgecore_eap111
 endef
 TARGET_DEVICES += edgecore_eap111
 
+define Device/edgecore_eap115
+  DEVICE_VENDOR := Edgecore
+  DEVICE_MODEL := EAP115
+  DEVICE_DTS := mt7987a-edgecore-eap115
+  DEVICE_DTS_DIR := ../dts
+  DEVICE_DTS_LOADADDR := 0x4ff00000
+  KERNEL_LOADADDR := 0x40000000
+  BLOCKSIZE := 128k
+  PAGESIZE := 2048
+  UBINIZE_OPTS := -E 5
+  KERNEL_IN_UBI := 1
+  IMAGE_SIZE := 65536k
+  IMAGES := sysupgrade.bin factory.bin
+  IMAGE/factory.bin := append-ubi | check-size $$$$(IMAGE_SIZE)
+  IMAGE/sysupgrade.bin := sysupgrade-tar | append-metadata
+  DEVICE_PACKAGES := mt7987-2p5g-phy-firmware kmod-mt7992-firmware \
+	kmod-phy-realtek
+endef
+TARGET_DEVICES += edgecore_eap115
+
+define Device/edgecore_eap115a
+  DEVICE_VENDOR := Edgecore
+  DEVICE_MODEL := EAP115a
+  DEVICE_DTS := mt7987a-edgecore-eap115a
+  DEVICE_DTS_DIR := ../dts
+  DEVICE_DTS_LOADADDR := 0x4ff00000
+  KERNEL_LOADADDR := 0x40000000
+  BLOCKSIZE := 128k
+  PAGESIZE := 2048
+  UBINIZE_OPTS := -E 5
+  KERNEL_IN_UBI := 1
+  IMAGE_SIZE := 65536k
+  IMAGES := sysupgrade.bin factory.bin
+  IMAGE/factory.bin := append-ubi | check-size $$$$(IMAGE_SIZE)
+  IMAGE/sysupgrade.bin := sysupgrade-tar | append-metadata
+  DEVICE_PACKAGES := mt7987-2p5g-phy-firmware kmod-mt7992-firmware \
+	kmod-phy-realtek
+endef
+TARGET_DEVICES += edgecore_eap115a
+
 define Device/elecom_wrc-x3000gs3
   DEVICE_VENDOR := ELECOM
   DEVICE_MODEL := WRC-X3000GS3
-- 
2.34.1

