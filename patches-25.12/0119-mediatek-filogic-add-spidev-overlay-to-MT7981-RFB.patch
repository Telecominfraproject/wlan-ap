From 5b40c0515dacc834e4a9d6435c6598cbf0da8dd6 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:40:59 +0200
Subject: [PATCH 119/149] mediatek: filogic: add spidev overlay to MT7981-RFB

Add the mt7981-spidev DT overlay to DEVICE_DTS_OVERLAY so the
MT7981-RFB image gains a spidev interface for board bring-up
debugging. The overlay's dtso is provided by patches-25.12/0108.
Import of patches-base/1144-03 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 6de08f0b0e..cf953a94c2 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -1967,7 +1967,8 @@ define Device/mediatek_mt7981-rfb
 	mt7981-rfb-spim-nor \
 	mt7981-rfb-spim-nand-nmbm \
 	mt7981-rfb-mxl-2p5g-phy-eth1 \
-	mt7981-rfb-mxl-2p5g-phy-swp5
+	mt7981-rfb-mxl-2p5g-phy-swp5 \
+	mt7981-spidev
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x43f00000
-- 
2.34.1

