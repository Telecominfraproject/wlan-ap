From e210c3a97fa053ccf6081888c8b30af31cf4d3b3 Mon Sep 17 00:00:00 2001
From: Sam Shih <sam.shih@mediatek.com>
Date: Tue, 19 May 2026 09:29:19 +0800
Subject: [PATCH 154/169] mediatek: filogic: base-files: add MT7987/MT7988
 upgrade support

Add sysupgrade platform support for MT7987 and MT7988 boards:
- MediaTek MT7987A/MT7988A/MT7988D RFB reference boards
- BananaPi R4 Mini and Pro variants
- Support for various storage backends (eMMC, SD, NAND, NOR)
- Device-mapper verification cleanup on upgrade

Enable safe firmware upgrade for these platforms with proper
partition detection and verification handling.

Signed-off-by: Sky Huang <skylake.huang@mediatek.com>
Signed-off-by: Sam Shih <sam.shih@mediatek.com>
---
 .../base-files/lib/upgrade/platform.sh        | 66 ++++++++++++++++++-
 1 file changed, 64 insertions(+), 2 deletions(-)

diff --git a/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh b/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
index ce2d06b9df..b770299522 100644
--- a/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
+++ b/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
@@ -1,5 +1,5 @@
 REQUIRE_IMAGE_METADATA=1
-RAMFS_COPY_BIN='fitblk fit_check_sign fw_setenv'
+RAMFS_COPY_BIN='fitblk blkid fit_check_sign fw_setenv'
 
 asus_initial_setup()
 {
@@ -78,6 +78,38 @@ platform_do_upgrade() {
 	local board=$(board_name)
 
 	case "$board" in
+	mediatek,mt7981-rfb|\
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
+	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw)
+		[ -e /dev/dm-0 ] && dmsetup remove_all
+		[ -e /dev/fit0 ] && fitblk /dev/fit0
+		[ -e /dev/fitrw ] && fitblk /dev/fitrw
+		export_fitblk_bootdev
+		case "$CI_METHOD" in
+		emmc)
+			mmc_do_upgrade "$1"
+			;;
+		default)
+			default_do_upgrade "$1"
+			;;
+		ubi)
+			CI_KERNPART="firmware"
+			ubi_do_upgrade "$1"
+			;;
+		*)
+			if grep \"rootfs_data\" /proc/mtd; then
+				default_do_upgrade "$1"
+			fi
+			;;
+		esac
+		;;
 	abt,asr3000|\
 	acer,predator-w6x-ubootmod|\
 	asus,zenwifi-bt8-ubootmod|\
@@ -100,7 +132,15 @@ platform_do_upgrade() {
 	jdcloud,re-cp-03|\
 	konka,komi-a31|\
 	mediatek,mt7981-rfb|\
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
 	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw|\
 	mercusys,mr90x-v1-ubi|\
 	netis,nx30v2|\
 	netis,nx31|\
@@ -314,6 +354,10 @@ platform_do_upgrade() {
 	esac
 }
 
+fit_verify_image() {
+	return 0
+}
+
 PART_NAME=firmware
 
 platform_check_image() {
@@ -343,7 +387,15 @@ platform_check_image() {
 	jdcloud,re-cp-03|\
 	konka,komi-a31|\
 	mediatek,mt7981-rfb|\
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
 	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw|\
 	mercusys,mr90x-v1-ubi|\
 	nokia,ea0326gmp|\
 	netis,nx32u|\
@@ -359,6 +411,7 @@ platform_check_image() {
 	xiaomi,redmi-router-ax6000-ubootmod|\
 	xiaomi,mi-router-wr30u-ubootmod|\
 	zyxel,ex5601-t0-ubootmod)
+		fit_verify_image "$1" || return 74
 		fit_check_image "$1"
 		return $?
 		;;
@@ -394,7 +447,16 @@ platform_copy_config() {
 	bananapi,bpi-r4-lite|\
 	cmcc,rax3000m|\
 	gatonetworks,gdsp|\
-	mediatek,mt7988a-rfb)
+	mediatek,mt7981-rfb|\
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
+	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw)
 		if [ "$CI_METHOD" = "emmc" ]; then
 			emmc_copy_config
 		fi
-- 
