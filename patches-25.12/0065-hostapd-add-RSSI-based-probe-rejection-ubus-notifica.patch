From b5b660ea1c83db21ea210ae7a402e890a2f4f652 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 17:43:01 +0100
Subject: [PATCH 65/93] hostapd: add RSSI-based probe rejection ubus
 notification

Emit ubus "rssi-ignore-probe" event when probe requests are dropped
due to low signal strength. Add hostapd_ubus_notify_rssi() to overlay
files for RSSI event reporting.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../patches/zzz-0005-ignore-probe-event.patch | 23 +++++++++++++++++++
 .../services/hostapd/src/src/ap/ubus.c        | 16 +++++++++++++
 .../services/hostapd/src/src/ap/ubus.h        |  8 +++++++
 3 files changed, 47 insertions(+)
 create mode 100644 package/network/services/hostapd/patches/zzz-0005-ignore-probe-event.patch

diff --git a/package/network/services/hostapd/patches/zzz-0005-ignore-probe-event.patch b/package/network/services/hostapd/patches/zzz-0005-ignore-probe-event.patch
new file mode 100644
index 0000000000..db5b113c60
--- /dev/null
+++ b/package/network/services/hostapd/patches/zzz-0005-ignore-probe-event.patch
@@ -0,0 +1,23 @@
+zzz-0005-ignore-probe-event.patch
+
+Emits a ubus "rssi-ignore-probe" notification when a probe request is
+rejected due to low RSSI (below rssi_ignore_probe_request threshold).
+Reports the station address and signal strength.
+
+Companion: hostapd_ubus_notify_rssi() added directly to overlay
+files (ubus.c, ubus.h).
+
+--- a/src/ap/beacon.c
++++ b/src/ap/beacon.c
+@@ -934,8 +934,10 @@ void handle_probe_req(struct hostapd_dat
+ 	int ubus_response;
+ 
+ 	if (hapd->iconf->rssi_ignore_probe_request && ssi_signal &&
+-	    ssi_signal < hapd->iconf->rssi_ignore_probe_request)
++	    ssi_signal < hapd->iconf->rssi_ignore_probe_request) {
++		hostapd_ubus_notify_rssi(hapd, "rssi-ignore-probe", mgmt->sa, ssi_signal);
+ 		return;
++	}
+ 
+ 	if (len < IEEE80211_HDRLEN)
+ 		return;
diff --git a/package/network/services/hostapd/src/src/ap/ubus.c b/package/network/services/hostapd/src/src/ap/ubus.c
index 9779b12890..4818319497 100644
--- a/package/network/services/hostapd/src/src/ap/ubus.c
+++ b/package/network/services/hostapd/src/src/ap/ubus.c
@@ -1963,6 +1963,22 @@ void hostapd_ubus_notify(struct hostapd_data *hapd, const char *type, const u8 *
 	ubus_notify(ctx, &hapd->ubus.obj, type, b.head, -1);
 }
 
+void hostapd_ubus_notify_rssi(struct hostapd_data *hapd, const char *type,
+			      const u8 *addr, int rssi)
+{
+	if (!hapd->ubus.obj.has_subscribers)
+		return;
+
+	if (!addr)
+		return;
+
+	blob_buf_init(&b, 0);
+	blobmsg_add_macaddr(&b, "address", addr);
+	blobmsg_add_u32(&b, "rssi", rssi);
+
+	ubus_notify(ctx, &hapd->ubus.obj, type, b.head, -1);
+}
+
 void hostapd_ubus_notify_authorized(struct hostapd_data *hapd, struct sta_info *sta,
 				    const char *auth_alg, int reassoc)
 {
diff --git a/package/network/services/hostapd/src/src/ap/ubus.h b/package/network/services/hostapd/src/src/ap/ubus.h
index 9bbdf051bf..0353714c09 100644
--- a/package/network/services/hostapd/src/src/ap/ubus.h
+++ b/package/network/services/hostapd/src/src/ap/ubus.h
@@ -69,6 +69,8 @@ int hostapd_ubus_notify_bss_transition_query(
 	const u8 *candidate_list, u16 candidate_list_len);
 void hostapd_ubus_notify_authorized(struct hostapd_data *hapd, struct sta_info *sta,
 				    const char *auth_alg, int reassoc);
+void hostapd_ubus_notify_rssi(struct hostapd_data *hapd, const char *type,
+			      const u8 *addr, int rssi);
 void hostapd_ubus_notify_csa(struct hostapd_data *hapd, int freq);
 
 #ifdef CONFIG_APUP
@@ -157,6 +159,12 @@ hostapd_ubus_notify_authorized(struct hostapd_data *hapd, struct sta_info *sta,
 {
 }
 
+static inline void
+hostapd_ubus_notify_rssi(struct hostapd_data *hapd, const char *type,
+			 const u8 *addr, int rssi)
+{
+}
+
 static inline void
 hostapd_ubus_notify_csa(struct hostapd_data *hapd, int freq)
 {
