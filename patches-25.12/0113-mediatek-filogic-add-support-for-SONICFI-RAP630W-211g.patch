 .../gen_sonicfi_rap630w_211g_rootfs_node.sh   |  38 ++
 .../dts/mt7981b-sonicfi-rap630w-211g.dts      | 550 ++++++++++++++++++
 .../filogic/base-files/etc/board.d/02_network |  14 +
 .../base-files/lib/upgrade/platform.sh        |  29 +
 target/linux/mediatek/image/filogic.mk        |  34 ++
 6 files changed, 690 insertions(+)
 create mode 100755 scripts/gen_sonicfi_rap630w_211g_rootfs_node.sh
 create mode 100644 target/linux/mediatek/dts/mt7981b-sonicfi-rap630w-211g.dts

diff --git a/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic b/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
index fd89a211d8..b237246d50 100644
--- a/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
+++ b/package/boot/uboot-tools/uboot-envtools/files/mediatek_filogic
@@ -160,6 +160,31 @@ zyxel,ex5601-t0)
 zyxel,ex5700-telenor)
 	ubootenv_add_uci_config "/dev/ubootenv" "0x0" "0x4000" "0x4000" "1"
 	;;
+sonicfi,rap630w-211g)
+	. /lib/upgrade/nand.sh
+
+	env_dev=$(cmdline_get_var "boot_param.env_part")
+	CI_UBIPART="ubi"
+	if [ -n "$env_dev" ]; then
+		mtdnum="$(find_mtd_index "$CI_UBIPART")"
+		if [ -z "$mtdnum" ]; then
+			echo "cannot find ubi mtd partition $CI_UBIPART"
+			return 1
+		fi
+
+		ubidev="$(nand_find_ubi "$CI_UBIPART")"
+		if [ -z "$ubidev" ]; then
+			ubiattach -m "$mtdnum"
+			sync
+			ubidev="$(nand_find_ubi "$CI_UBIPART")"
+		fi
+
+		env_ubivol="$(nand_find_volume "${ubidev}" "${env_dev}")"
+		if [ -n "${env_ubivol}" ]; then
+			ubootenv_add_uci_config "/dev/$env_ubivol" "0" "0x80000" "0x80000" 1
+		fi
+	fi
+	;;
 esac
 
 config_load ubootenv
diff --git a/scripts/gen_sonicfi_rap630w_211g_rootfs_node.sh b/scripts/gen_sonicfi_rap630w_211g_rootfs_node.sh
new file mode 100755
index 0000000000..e13b7d4a64
--- /dev/null
+++ b/scripts/gen_sonicfi_rap630w_211g_rootfs_node.sh
@@ -0,0 +1,38 @@
+#!/bin/sh
+#
+# SPDX-License-Identifier: GPL-2.0-or-later
+#
+# Author: Jascha Sundaresan <flizarthanon@gmail.com>
+#
+# This helper script generates a top-level 'rootfs' node for inclusion
+# in a Flattened Image Tree (FIT) source (.its) file.  The node includes
+# the size and SHA1 hash of a given root filesystem image and is used by
+# certain Sonicfi rap630w_211g devices which expect this metadata at the top level of
+# the FIT structure.
+#
+# The resulting block is written to standard output and can be appended
+# or inserted into an existing .its file by the OpenWrt build system.
+# Example:
+#     scripts/gen_sonicfi_rap630w_211g_rootfs_node.sh build_dir/.../root.squashfs > node.txt
+#
+# See also: scripts/mkits.sh, which generates the main FIT .its source.
+
+ROOTFS="$1"
+ROOTFS_SIZE=$(stat -c %s "${ROOTFS}")
+ROOTFS_SHA1=$(
+    sha1sum "${ROOTFS}" | awk '{ print "<0x" substr($0, 1, 8) \
+                                          " 0x" substr($0, 9, 8) \
+                                          " 0x" substr($0, 17, 8) \
+                                          " 0x" substr($0, 25, 8) \
+                                          " 0x" substr($0, 33, 8) ">" }'
+)
+cat <<EOF | sed 's/^/\t/'
+rootfs {
+	size = <${ROOTFS_SIZE}>;
+	hash-1 {
+		value = ${ROOTFS_SHA1};
+		algo = "sha1";
+	};
+};
+
+EOF
