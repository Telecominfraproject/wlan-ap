From 7f32b9fb198b2b0842a93383594bbc9adfce902c Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:43:21 +0200
Subject: [PATCH 125/149] package: build host dtc before compiling packages

Add a make-time dependency on dtc/host/compile so the host
device-tree compiler is built before any package compile step.
This is required by image build steps that invoke dtc on the
host (FIT image assembly, dtso overlay compilation) before the
target-side dtc package is staged.

Import of patches-base/0940 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/Makefile | 1 +
 1 file changed, 1 insertion(+)

diff --git a/package/Makefile b/package/Makefile
index 73c8968daf..bc7d0035d6 100644
--- a/package/Makefile
+++ b/package/Makefile
@@ -91,6 +91,7 @@ ifneq ($(CONFIG_USE_APK),)
   $(curdir)//compile += $(BUILD_KEY_APK_SEC) $(BUILD_KEY_APK_PUB)
 endif
 endif
+$(curdir)/compile: $(curdir)/dtc/host/compile
 
 $(curdir)/install: $(TMP_DIR)/.build $(curdir)/merge $(curdir)/merge-index
 	- find $(STAGING_DIR_ROOT) -type d | $(XARGS) chmod 0755
