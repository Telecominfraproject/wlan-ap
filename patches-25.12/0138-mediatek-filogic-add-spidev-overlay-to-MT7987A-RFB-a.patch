From 5657c37f47b4036b7f5624d5a4a544dc347d5582 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:51:35 +0200
Subject: [PATCH 138/149] mediatek: filogic: add spidev overlay to MT7987A-RFB
 and BPI-R4-Lite

Add the mt7987-spidev DT overlay to DEVICE_DTS_OVERLAY for the
MT7987A-RFB and Bananapi BPI-R4-Lite image targets so they gain
a spidev interface for board bring-up debugging.

Import of patches-base/1142-03 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 4cab9dd957..c5202cdb67 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -731,7 +731,8 @@ define Device/bananapi_bpi-r4-lite
 	mt7987a-bananapi-bpi-r4-lite-emmc \
 	mt7987a-bananapi-bpi-r4-lite-sd \
 	mt7987a-bananapi-bpi-r4-lite-1pcie-2L \
-	mt7987a-bananapi-bpi-r4-lite-2pcie-1L
+	mt7987a-bananapi-bpi-r4-lite-2pcie-1L \
+	mt7987-spidev
   DEVICE_DTS_CONFIG := config-mt7987a-bananapi-bpi-r4-lite
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_DIR := $(DTS_DIR)/
@@ -2053,7 +2054,8 @@ define Device/mediatek_mt7987a-rfb
 	mt7987-netsys-eth2-an8801sb \
 	mt7987-netsys-eth2-e2p5g \
 	mt7987-netsys-eth2-sfp \
-	mt7987-netsys-eth2-usb
+	mt7987-netsys-eth2-usb \
+	mt7987-spidev
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x4ff00000
-- 
2.34.1

