--- a/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
+++ b/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
@@ -1,3 +1,5 @@
+. /lib/functions/boot_param.sh
+
 REQUIRE_IMAGE_METADATA=1
 RAMFS_COPY_BIN='fitblk fit_check_sign fw_setenv'
 
@@ -308,6 +310,26 @@ platform_do_upgrade() {
 		CI_FWSETENV="-s /tmp/fw_setenv.txt"
 		nand_do_upgrade "$1"
 		;;
+	sonicfi,rap630w-211g)
+		local upgrade_kernel_part=$(get_boot_param "boot_param.upgrade_kernel_part")
+		local upgrade_rootfs_part=$(get_boot_param "boot_param.upgrade_rootfs_part")
+		local upgrade_image_slot=$(get_boot_param "boot_param.upgrade_image_slot")
+
+		CI_UBIPART="ubi"
+		CI_KERNPART="${upgrade_kernel_part}"
+		CI_ROOTPART="${upgrade_rootfs_part}"
+
+		{
+		echo -e "dual_boot.current_slot\t${upgrade_image_slot}"
+		echo -e "dual_boot.slot_${upgrade_image_slot}_invalid\t0"
+		} > /tmp/fw_setenv.txt
+
+		CI_FWSETENV="-s /tmp/fw_setenv.txt"
+
+		echo "Start upgrade: kernel=${CI_KERNPART}, rootfs=${CI_ROOTPART}, slot=${upgrade_image_slot}"
+
+		nand_do_upgrade "$1"
+                ;;
 	*)
 		nand_do_upgrade "$1"
 		;;
@@ -375,6 +397,14 @@ platform_check_image() {
 
 		return 0
 		;;
+	sonicfi,rap630w-211g)
+                local magic="$(get_magic_long "$1")"
+                [ "$magic" != "73797375" ] && {
+                        echo "Invalid image type."
+                        return 1
+                }
+                return 0
+                ;;
 	*)
 		nand_do_platform_check "$board" "$1"
 		return $?
