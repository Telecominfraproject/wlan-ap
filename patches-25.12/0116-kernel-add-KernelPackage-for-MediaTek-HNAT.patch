From ad6b1b33f5f2064dd42e3f20870739b00dae1c6e Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:33:39 +0200
Subject: [PATCH 116/149] kernel: add KernelPackage for MediaTek HNAT

Package the MediaTek HW NAT offload driver (CONFIG_NET_MEDIATEK_HNAT)
as kmod-mediatek_hnat, with the required bridge netfilter Kconfigs
forced on. Import of patches-base/0014 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/kernel/linux/modules/netdevices.mk | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/package/kernel/linux/modules/netdevices.mk b/package/kernel/linux/modules/netdevices.mk
index fcf00e117e..999107c684 100644
--- a/package/kernel/linux/modules/netdevices.mk
+++ b/package/kernel/linux/modules/netdevices.mk
@@ -2315,6 +2315,25 @@ endef
 $(eval $(call KernelPackage,mtk-t7xx))
 
 
+define KernelPackage/mediatek_hnat
+  SUBMENU:=$(NETWORK_DEVICES_MENU)
+  TITLE:=Mediatek HNAT module
+  DEPENDS:=@TARGET_mediatek +kmod-nf-conntrack
+  KCONFIG:= \
+	CONFIG_BRIDGE_NETFILTER=y \
+	CONFIG_NETFILTER_FAMILY_BRIDGE=y \
+	CONFIG_NET_MEDIATEK_HNAT
+  FILES:= \
+        $(LINUX_DIR)/drivers/net/ethernet/mediatek/mtk_hnat/mtkhnat.ko
+endef
+
+define KernelPackage/mediatek_hnat/description
+  Kernel modules for MediaTek HW NAT offloading
+endef
+
+$(eval $(call KernelPackage,mediatek_hnat))
+
+
 define KernelPackage/atlantic
   SUBMENU:=$(NETWORK_DEVICES_MENU)
   TITLE:=Aquantia AQtion 10Gbps Ethernet NIC
