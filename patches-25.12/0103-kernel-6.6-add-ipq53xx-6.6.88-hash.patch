From 77357023576c58a4fd3b85e50ee8451cd4c81e44 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 6 Apr 2026 16:03:46 +0200
Subject: [PATCH] kernel-6.6: add ipq53xx kernel 6.6.88 hash

The ipq53xx target in the ath13.1 SDK requires kernel 6.6.88. Override
the default 6.6 kernel version for this target.

Signed-off-by: John Crispin <john@phrozen.org>
---
 include/kernel-6.6 | 4 ++++
 1 file changed, 4 insertions(+)
 create mode 100644 include/kernel-6.6

diff --git a/include/kernel-6.6 b/include/kernel-6.6
new file mode 100644
index 0000000000..2047c182f0
--- /dev/null
+++ b/include/kernel-6.6
@@ -0,0 +1,4 @@
+ifeq ($(CONFIG_TARGET_ipq53xx),y)
+LINUX_VERSION-6.6 = .88
+LINUX_KERNEL_HASH-6.6.88 = 19df89b63ef7e950de7297dabfac0569183bf87636f4c300a25336c7da490650
+endif
-- 
2.34.1

