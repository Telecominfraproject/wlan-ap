From db72374b99b4b41140c3b6084375eb0e7ebc943a Mon Sep 17 00:00:00 2001
From: developer <developer@mediatek.com>
Date: Wed, 6 May 2026 08:25:47 +0800
Subject: [PATCH] [][kernel-6.12][mt7986b][dts][Enable watchdog]

[Description]
Enable watchdog for MT7986B kernel 6.12 codebase.
Otherwise, Wi-Fi device node cannot be successfully enabled.

[Release-log]
N/A
---
 ...fb-04-arm64-dts-mediatek-enable-watchdog.patch | 15 +++++++++++++++
 1 file changed, 15 insertions(+)
 create mode 100644 target/linux/mediatek/patches-6.12/999-dts-mt7986b-rfb-04-arm64-dts-mediatek-enable-watchdog.patch

diff --git a/target/linux/mediatek/patches-6.12/999-dts-mt7986b-rfb-04-arm64-dts-mediatek-enable-watchdog.patch b/target/linux/mediatek/patches-6.12/999-dts-mt7986b-rfb-04-arm64-dts-mediatek-enable-watchdog.patch
new file mode 100644
index 0000000..b3acf2a
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-dts-mt7986b-rfb-04-arm64-dts-mediatek-enable-watchdog.patch
@@ -0,0 +1,15 @@
+Index: linux-6.12.79/arch/arm64/boot/dts/mediatek/mt7986b-rfb.dts
+===================================================================
+--- linux-6.12.79.orig/arch/arm64/boot/dts/mediatek/mt7986b-rfb.dts
++++ linux-6.12.79/arch/arm64/boot/dts/mediatek/mt7986b-rfb.dts
+@@ -182,6 +182,10 @@
+ 	status = "okay";
+ };
+ 
++&watchdog {
++	status = "okay";
++};
++
+ &wifi {
+ 	status = "okay";
+ 	pinctrl-names = "default", "dbdc";
