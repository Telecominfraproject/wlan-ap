From 75fa43c5d27bfa53b449513cc89ddb243fe87065 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 27 Apr 2026 09:11:11 +0200
Subject: [PATCH 109/109] mt76: adapt mmio wed init to wpdma_tx array

The WED driver imported from the MediaTek SDK (commit
5c8ca54b0d2ed2d577d1047a986c4791053875a4) changes wpdma_tx from a scalar
to an array. Adjust the mt7996 and mt7915 mmio wed init paths to assign
wpdma_tx[0] so mt76 builds against the updated kernel headers.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../100-mt76-mmio-wpdma-tx-array.patch        | 48 +++++++++++++++++++
 1 file changed, 48 insertions(+)
 create mode 100644 package/kernel/mt76/patches/100-mt76-mmio-wpdma-tx-array.patch

diff --git a/package/kernel/mt76/patches/100-mt76-mmio-wpdma-tx-array.patch b/package/kernel/mt76/patches/100-mt76-mmio-wpdma-tx-array.patch
new file mode 100644
index 0000000000..f8982e3221
--- /dev/null
+++ b/package/kernel/mt76/patches/100-mt76-mmio-wpdma-tx-array.patch
@@ -0,0 +1,48 @@
+--- a/mt7996/mmio.c
++++ b/mt7996/mmio.c
+@@ -488,9 +488,9 @@ int mt7996_mmio_wed_init(struct mt7996_d
+ 				      MT_INT_PCIE1_SOURCE_CSR_EXT;
+ 		wed->wlan.wpdma_mask = wed->wlan.phy_base +
+ 				       MT_INT_PCIE1_MASK_CSR;
+-		wed->wlan.wpdma_tx = wed->wlan.phy_base + hif1_ofs +
+-					     MT_TXQ_RING_BASE(0) +
+-					     MT7996_TXQ_BAND2 * MT_RING_SIZE;
++		wed->wlan.wpdma_tx[0] = wed->wlan.phy_base + hif1_ofs +
++						MT_TXQ_RING_BASE(0) +
++						MT7996_TXQ_BAND2 * MT_RING_SIZE;
+ 		if (mt7996_has_hwrro(dev)) {
+ 			if (is_mt7996(&dev->mt76)) {
+ 				wed->wlan.txfree_tbit = ffs(MT_INT_RX_TXFREE_EXT) - 1;
+@@ -521,8 +521,8 @@ int mt7996_mmio_wed_init(struct mt7996_d
+ 		wed->wlan.hw_rro = mt7996_has_hwrro(dev);
+ 		wed->wlan.wpdma_int = wed->wlan.phy_base + MT_INT_SOURCE_CSR;
+ 		wed->wlan.wpdma_mask = wed->wlan.phy_base + MT_INT_MASK_CSR;
+-		wed->wlan.wpdma_tx = wed->wlan.phy_base + MT_TXQ_RING_BASE(0) +
+-				     MT7996_TXQ_BAND0 * MT_RING_SIZE;
++		wed->wlan.wpdma_tx[0] = wed->wlan.phy_base + MT_TXQ_RING_BASE(0) +
++					MT7996_TXQ_BAND0 * MT_RING_SIZE;
+ 
+ 		wed->wlan.wpdma_rx_glo = wed->wlan.phy_base + MT_WFDMA0_GLO_CFG;
+ 
+--- a/mt7915/mmio.c
++++ b/mt7915/mmio.c
+@@ -658,8 +658,8 @@ int mt7915_mmio_wed_init(struct mt7915_d
+ 				       MT_INT_WED_MASK_CSR;
+ 		wed->wlan.wpdma_phys = pci_resource_start(pci_dev, 0) +
+ 				       MT_WFDMA_EXT_CSR_BASE;
+-		wed->wlan.wpdma_tx = pci_resource_start(pci_dev, 0) +
+-				     MT_TXQ_WED_RING_BASE;
++		wed->wlan.wpdma_tx[0] = pci_resource_start(pci_dev, 0) +
++					MT_TXQ_WED_RING_BASE;
+ 		wed->wlan.wpdma_txfree = pci_resource_start(pci_dev, 0) +
+ 					 MT_RXQ_WED_RING_BASE;
+ 		wed->wlan.wpdma_rx_glo = pci_resource_start(pci_dev, 0) +
+@@ -684,7 +684,7 @@ int mt7915_mmio_wed_init(struct mt7915_d
+ 		wed->wlan.phy_base = res->start;
+ 		wed->wlan.wpdma_int = res->start + MT_INT_SOURCE_CSR;
+ 		wed->wlan.wpdma_mask = res->start + MT_INT_MASK_CSR;
+-		wed->wlan.wpdma_tx = res->start + MT_TXQ_WED_RING_BASE;
++		wed->wlan.wpdma_tx[0] = res->start + MT_TXQ_WED_RING_BASE;
+ 		wed->wlan.wpdma_txfree = res->start + MT_RXQ_WED_RING_BASE;
+ 		wed->wlan.wpdma_rx_glo = res->start + MT_WPDMA_GLO_CFG;
+ 		wed->wlan.wpdma_rx[0] = res->start + MT_RXQ_WED_DATA_RING_BASE;
-- 
