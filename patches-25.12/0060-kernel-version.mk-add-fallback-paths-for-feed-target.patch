From 6f1f38ca0d9ad2b9c3c9fd93a49eea9d442d1ec6 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 12:55:21 +0100
Subject: [PATCH 60/93] kernel-version.mk: add fallback paths for feed target
 kernel details

Feed-based out-of-tree targets fail because GENERIC_PLATFORM_DIR resolves
to an empty feeds directory. Fall back to target/linux/generic/ and then
include/ when the kernel details file is not found.

Signed-off-by: John Crispin <john@phrozen.org>
---
 include/kernel-version.mk | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/include/kernel-version.mk b/include/kernel-version.mk
index 5e2bff4542..97dc17ffb4 100644
--- a/include/kernel-version.mk
+++ b/include/kernel-version.mk
@@ -7,6 +7,12 @@ ifdef CONFIG_TESTING_KERNEL
 endif
 
 KERNEL_DETAILS_FILE=$(GENERIC_PLATFORM_DIR)/kernel-$(KERNEL_PATCHVER)
+ifeq ($(wildcard $(KERNEL_DETAILS_FILE)),)
+  KERNEL_DETAILS_FILE=$(TOPDIR)/target/linux/generic/kernel-$(KERNEL_PATCHVER)
+endif
+ifeq ($(wildcard $(KERNEL_DETAILS_FILE)),)
+  KERNEL_DETAILS_FILE=$(INCLUDE_DIR)/kernel-$(KERNEL_PATCHVER)
+endif
 ifeq ($(wildcard $(KERNEL_DETAILS_FILE)),)
   $(error Missing kernel version/hash file for $(KERNEL_PATCHVER). Please create $(KERNEL_DETAILS_FILE))
 endif
@@ -15,6 +21,12 @@ include $(KERNEL_DETAILS_FILE)
 
 ifdef KERNEL_TESTING_PATCHVER
   KERNEL_TESTING_DETAILS_FILE=$(GENERIC_PLATFORM_DIR)/kernel-$(KERNEL_TESTING_PATCHVER)
+  ifeq ($(wildcard $(KERNEL_TESTING_DETAILS_FILE)),)
+    KERNEL_TESTING_DETAILS_FILE=$(TOPDIR)/target/linux/generic/kernel-$(KERNEL_TESTING_PATCHVER)
+  endif
+  ifeq ($(wildcard $(KERNEL_TESTING_DETAILS_FILE)),)
+    KERNEL_TESTING_DETAILS_FILE=$(INCLUDE_DIR)/kernel-$(KERNEL_TESTING_PATCHVER)
+  endif
   ifeq ($(wildcard $(KERNEL_TESTING_DETAILS_FILE)),)
     $(error Missing kernel version/hash file for $(KERNEL_TESTING_PATCHVER). Please create $(KERNEL_TESTING_DETAILS_FILE))
   endif
-- 
