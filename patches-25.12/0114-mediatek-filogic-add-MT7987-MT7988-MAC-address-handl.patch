From 1713f3922925f256812cad070689276c3e5b568c Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:33:38 +0200
Subject: [PATCH 114/149] mediatek: filogic: add MT7987/MT7988 MAC address
 handling

Read lan/wan MAC addresses from the Factory partition at offsets
0xFFFF4 and 0xFFFFA for all mediatek,mt7987* and mediatek,mt7988*
board compatibles. Import of patches-base/0011 from MediaTek 25.12
feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../linux/mediatek/filogic/base-files/etc/board.d/02_network | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/target/linux/mediatek/filogic/base-files/etc/board.d/02_network b/target/linux/mediatek/filogic/base-files/etc/board.d/02_network
index 12b5e5c2e3..cac9bd853d 100644
--- a/target/linux/mediatek/filogic/base-files/etc/board.d/02_network
+++ b/target/linux/mediatek/filogic/base-files/etc/board.d/02_network
@@ -261,6 +261,11 @@ mediatek_setup_macs()
 		lan_mac=$label_mac
 		wan_mac=$(macaddr_add "$lan_mac" 1)
 		;;
+	mediatek,mt7987*|\
+	mediatek,mt7988*)
+		lan_mac=$(mtd_get_mac_binary "Factory" "0xFFFF4")
+		wan_mac=$(mtd_get_mac_binary "Factory" "0xFFFFA")
+		;;
 	mercusys,mr90x-v1|\
 	tplink,archer-ax80-v1|\
 	tplink,archer-ax80-v1-eu|\
-- 
2.34.1

