++static int an8811hb_suspend(struct phy_device *phydev)
++{
++	int ret = 0;
++
++	phydev_info(phydev, "%s: start!\n", __func__);
++
++	ret = phy_read(phydev, MII_BMCR);
++	if (ret < 0)
++		return ret;
++	ret |= BMCR_ANRESTART;
++	ret = phy_write(phydev, MII_BMCR, ret);
++	if (ret < 0)
++		return ret;
