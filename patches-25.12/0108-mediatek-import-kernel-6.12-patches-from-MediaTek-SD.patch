diff --git a/target/linux/mediatek/patches-6.12/999-eth-32-mtk_eth_soc-add-SER-fast-mode.patch b/target/linux/mediatek/patches-6.12/999-eth-32-mtk_eth_soc-add-SER-fast-mode.patch
