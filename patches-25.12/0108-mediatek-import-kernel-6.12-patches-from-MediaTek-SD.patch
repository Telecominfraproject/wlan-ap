++	/* Reset page to 0 */
++	ret = phy_write(phydev, 0x1f, 0);
++	if (ret < 0)
++		return ret;
++
++	/* Set special page for TX counters */
++	ret = phy_write(phydev, 0x1f, 0x52B5);
++	if (ret < 0)
++		return ret;
++
++	ret = phy_write(phydev, 0x10, 0xBF92);
++	if (ret < 0)
++		return ret;
