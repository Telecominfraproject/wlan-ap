index 0000000000..34cb32b68c
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-02-arm64-dts-mediatek-add-mt7986-dt-overlay-support.patch
@@ -0,0 +1,175 @@
+---
+[v4] arm64: dts: mediatek: convert mt7986 to dts-overlay architecture
+
+Convert MT7986 device tree to overlay based architecture. This refactoring
+separates the base DTS keeping common hardware nodes from board specific
+configurations which are now in DTSO overlay files. The base mt7986a-rfb.dts
+keeps essential nodes while disabling storage nodes. This patch includes
+mt7986-spim-nand-nmbm.dtso as an overlay example.
+
+---
+v4: Remove spi0 node from basic dts for adding spim nor ovelray support.
+v3: Add and unify pinctrl nodes into mt7986-pinctrl.dtsi file for centralized
+    pin configuration management.
+v2: Move openwrt-master files to openwrt-25.12 branch after OpenWrt official
+    25.12 branch release.
+v1: Initial mt7986a-rfb basic boot support to boot OpenWrt to shell.
+---
+
+--- a/arch/arm64/boot/dts/mediatek/mt7986a-rfb.dts
++++ b/arch/arm64/boot/dts/mediatek/mt7986a-rfb.dts
+@@ -8,7 +8,7 @@
+ #include <dt-bindings/pinctrl/mt65xx.h>
+ 
+ #include "mt7986a.dtsi"
+-
++#include "mt7986-pinctrl.dtsi"
+ / {
+ 	model = "MediaTek MT7986a RFB";
+ 	chassis-type = "embedded";
+@@ -18,8 +18,9 @@
+ 		serial0 = &uart0;
+ 	};
+ 
+-	chosen {
++	chosen: chosen {
+ 		stdout-path = "serial0:115200n8";
++		bootargs-append = " root=/dev/fit0 rootwait";
+ 	};
+ 
+ 	memory@40000000 {
+@@ -44,6 +45,24 @@
+ 		regulator-boot-on;
+ 		regulator-always-on;
+ 	};
++
++	sound_wm8960 {
++		compatible = "mediatek,mt7986-wm8960-sound";
++		audio-routing = "Headphone", "HP_L",
++				"Headphone", "HP_R",
++				"LINPUT1", "AMIC",
++				"RINPUT1", "AMIC";
++
++		status = "okay";
++
++		platform {
++			sound-dai = <&afe>;
++		};
++
++		codec {
++			sound-dai = <&wm8960>;
++		};
++	};
+ };
+ 
+ &crypto {
+@@ -83,6 +102,18 @@
+ 	};
+ };
+ 
++&i2c0 {
++	pinctrl-names = "default";
++	pinctrl-0 = <&i2c_pins>;
++	status = "okay";
++
++	wm8960: wm8960@1a {
++		compatible = "wlf,wm8960";
++		#sound-dai-cells = <0>;
++		reg = <0x1a>;
++	};
++};
++
+ &mdio {
+ 	switch: switch@0 {
+ 		compatible = "mediatek,mt7531";
+@@ -122,15 +153,7 @@
+ 	pinctrl-names = "default";
+ 	pinctrl-0 = <&spi_flash_pins>;
+ 	cs-gpios = <0>, <0>;
+-	status = "okay";
+-
+-	spi_nand: flash@0 {
+-		compatible = "spi-nand";
+-		reg = <0>;
+-		spi-max-frequency = <10000000>;
+-		spi-tx-bus-width = <4>;
+-		spi-rx-bus-width = <4>;
+-	};
++	status = "disabled";
+ };
+ 
+ &spi1 {
+--- /dev/null
++++ b/arch/arm64/boot/dts/mediatek/mt7986-spim-nand-nmbm.dtso
+@@ -0,0 +1,71 @@
++/* SPDX-License-Identifier: (GPL-2.0-only OR MIT) */
++/*
++ * Copyright (C) 2025 MediaTek Inc.
++ * Author: Sam.Shih <sam.shih@mediatek.com>
++ */
++
++/dts-v1/;
++/plugin/;
++
++&{/chosen} {
++	rootdisk-spim-nand = <&ubi_rootfs>;
++	bootargs-append = " ubi.block=0,firmware root=/dev/fit0 rootwait";
++};
++
++&{/soc/spi@1100a000} {
++	status = "okay";
++
++	flash@0 {
++		compatible = "spi-nand";
++		reg = <0>;
++		spi-max-frequency = <52000000>;
++		spi-tx-bus-width = <4>;
++		spi-rx-bus-width = <4>;
++		mediatek,nmbm;
++		mediatek,bmt-max-ratio = <1>;
++		mediatek,bmt-max-reserved-blocks = <64>;
++
++		partitions {
++			compatible = "fixed-partitions";
++			#address-cells = <1>;
++			#size-cells = <1>;
++
++			partition@0 {
++				label = "BL2";
++				reg = <0x00000 0x0100000>;
++				read-only;
++			};
++
++			partition@100000 {
++				label = "u-boot-env";
++				reg = <0x0100000 0x0080000>;
++			};
++
++			factory: partition@180000 {
++				label = "Factory";
++				reg = <0x180000 0x0200000>;
++			};
++
++			partition@580000 {
++				label = "FIP";
++				reg = <0x380000 0x0200000>;
++			};
++
++			partition@780000 {
++				label = "ubi";
++				reg = <0x580000 0x4000000>;
++				compatible = "linux,ubi";
++
++				volumes {
++					ubi_rootfs: ubi-volume-fit {
++						volname = "firmware";
++					};
++				};
++			};
++		};
++	};
++};
++
++&{/soc/wifi@18000000} {
++	mediatek,mtd-eeprom = <&factory 0>;
++};
diff --git a/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-03-arm64-dts-mediatek-fix-default-ethernet-interfaces-config.patch b/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-03-arm64-dts-mediatek-fix-default-ethernet-interfaces-config.patch
