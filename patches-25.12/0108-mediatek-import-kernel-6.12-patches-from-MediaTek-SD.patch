diff --git a/target/linux/mediatek/patches-6.12/999-ppe-37-nft_flow_offload-fix-missing-thoff-for-header-pointer-lookup.patch b/target/linux/mediatek/patches-6.12/999-ppe-37-nft_flow_offload-fix-missing-thoff-for-header-pointer-lookup.patch
new file mode 100644
index 0000000000..d3073f579a
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-ppe-37-nft_flow_offload-fix-missing-thoff-for-header-pointer-lookup.patch
@@ -0,0 +1,52 @@
+---
+[v1] netfilter: nft_flow_offload: fix missing thoff for header pointer lookup
+
+When nft_thoff(pkt) returns zero, the subsequent call to
+skb_header_pointer() for the TCP header uses offset 0, which points
+to the network header rather than the transport header. This causes
+incorrect TCP flag inspection (fin/rst) and may lead to flows being
+incorrectly offloaded or rejected.
+---
+v1: Fix TCP header offset when nft_thoff returns zero in nft_flow_offload.
+---
+
+From 91e2474506b069f1cf6eed3cd64a7442b82993f5 Mon Sep 17 00:00:00 2001
+From: "chak-kei.lam" <chak-kei.lam@mediatek.com>
+Date: Thu, 12 Mar 2026 10:11:50 +0800
+Subject: [PATCH] netfilter: nft_flow_offload: fix missing thoff for header
+ pointer lookup
+
+When nft_thoff(pkt) returns zero, the subsequent call to
+skb_header_pointer() for the TCP header uses offset 0, which points
+to the network header rather than the transport header. This causes
+incorrect TCP flag inspection (fin/rst) and may lead to flows being
+incorrectly offloaded or rejected.
+---
+ net/netfilter/nft_flow_offload.c | 9 ++++++++-
+ 1 file changed, 8 insertions(+), 1 deletion(-)
+
+--- a/net/netfilter/nft_flow_offload.c
++++ b/net/netfilter/nft_flow_offload.c
+@@ -547,6 +547,7 @@ static void nft_flow_offload_eval(const
+ 	struct ipv6hdr *ip6h;
+ 	struct iphdr *iph;
+ 	u32 offset = 0;
++	u32 thoff = nft_thoff(pkt);
+ 	u8 tos = 0;
+ 	int ret;
+ 
+@@ -562,7 +563,13 @@ static void nft_flow_offload_eval(const
+ 		if (ct->proto.tcp.state != TCP_CONNTRACK_ESTABLISHED)
+ 			goto out;
+ 
+-		tcph = skb_header_pointer(pkt->skb, nft_thoff(pkt),
++		if (!thoff) {
++			if (pkt->skb->protocol == htons(ETH_P_IP))
++				thoff = ip_hdrlen(pkt->skb);
++			else if (pkt->skb->protocol == htons(ETH_P_IPV6))
++				thoff = sizeof(struct ipv6hdr);
++		}
++		tcph = skb_header_pointer(pkt->skb, thoff,
+ 					  sizeof(_tcph), &_tcph);
+ 		if (unlikely(!tcph || tcph->fin || tcph->rst))
+ 			goto out;
