+--- /dev/null
++++ b/drivers/net/phy/airoha/an8855/an8855.c
+@@ -0,0 +1,1434 @@
++// SPDX-License-Identifier: GPL-2.0
++/*
++ * Copyright (c) 2023 Airoha Inc.
++ * Author: Min Yao <min.yao@airoha.com>
