diff --git a/target/linux/mediatek/patches-6.12/999-wed-11-net-ethernet-mtk_wed-add-ppe-drop.patch b/target/linux/mediatek/patches-6.12/999-wed-11-net-ethernet-mtk_wed-add-ppe-drop.patch
