diff --git a/target/linux/mediatek/patches-6.12/999-eth-10-mtk_eth_soc-add-hw-lro-support.patch b/target/linux/mediatek/patches-6.12/999-eth-10-mtk_eth_soc-add-hw-lro-support.patch
new file mode 100644
index 0000000000..eb52630bd8
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-10-mtk_eth_soc-add-hw-lro-support.patch
@@ -0,0 +1,566 @@
+---
+[v4] net: ethernet: mtk_eth_soc: add hardware LRO support
+
+Implement Hardware Large Receive Offload (LRO) support for improved receive throughput.
+This patch adds LRO ring management, aggregation configuration, and interrupt handling
+to aggregate TCP segments at hardware level before delivery to software.
+---
+v4: Add HW LRO max 4-depth VLAN support including switch special tag.
+v3: Change LRO initialization with L4 PSH check enabled.
+v2: Add Ethernet LRO support for MT7981/7986.
+v1: Add Ethernet LRO support for MT7988.
+---
+
+From 93f1b172525d9d0de39f731c1b6b3d1b806a8cfe Mon Sep 17 00:00:00 2001
+From: Mason Chang <mason-cw.chang@mediatek.com>
+Date: Tue, 21 Oct 2025 20:53:04 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add hw lro support
+
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 213 ++++++++++++++++++--
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h |  54 ++---
+ 2 files changed, 222 insertions(+), 45 deletions(-)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -3013,7 +3013,7 @@ static int mtk_rx_alloc(struct mtk_eth *
+ 	if (!ring->data)
+ 		return -ENOMEM;
