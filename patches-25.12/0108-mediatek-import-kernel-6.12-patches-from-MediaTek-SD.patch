diff --git a/target/linux/mediatek/patches-6.12/999-ppe-17-nft_flow_offload-DSCP-learning-flow.patch b/target/linux/mediatek/patches-6.12/999-ppe-17-nft_flow_offload-DSCP-learning-flow.patch
new file mode 100644
index 0000000000..351b228580
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-ppe-17-nft_flow_offload-DSCP-learning-flow.patch
@@ -0,0 +1,118 @@
+---
+[v1] netfilter: add DSCP learning flow to nft_flow_offload
+
+We have implemented a mechanism to learn the DSCP until count of the
+bi-directional TCP packets reached threshold.
+
+User can use the command below to enable DSCP learning flow.
+ - echo [0, 200] > /proc/sys/net/netfilter/nf_conntrack_qos
+
+Without this patch, the PPEs are unable to learn the DSCP from SKB.
+---
+v1: Add DSCP learning flow to nft_flow_offload.
+---
+
+From bdbdcfa2efdc414324351e595128462aaba14e1c Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Wed, 24 Sep 2025 12:58:10 +0800
+Subject: [PATCH] netfilter: add DSCP learning flow to nft_flow_offload
+
+We have implemented a mechanism to learn the DSCP until count of the
+bi-directional TCP packets reached threshold.
+
+User can use the command below to enable DSCP learning flow.
+ - echo [0, 200] > /proc/sys/net/netfilter/nf_conntrack_qos
+
+Without this patch, the PPEs are unable to learn the DSCP from SKB.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ net/netfilter/nft_flow_offload.c | 46 +++++++++++++++++++++++++++++++-
+ 1 file changed, 45 insertions(+), 1 deletion(-)
+
+--- a/net/netfilter/nft_flow_offload.c
++++ b/net/netfilter/nft_flow_offload.c
+@@ -12,6 +12,7 @@
+ #include <net/inet_dscp.h>
+ #include <net/netfilter/nf_tables.h>
+ #include <net/netfilter/nf_tables_core.h>
++#include <net/netfilter/nf_conntrack_qos.h>
+ #include <net/netfilter/nf_conntrack_core.h>
+ #include <net/netfilter/nf_conntrack_extend.h>
+ #include <net/netfilter/nf_flow_table.h>
+@@ -21,6 +22,19 @@ struct nft_flow_offload {
+ 	struct nft_flowtable	*flowtable;
+ };
+ 
++static void
++nft_flow_offload_dscp_init(struct flow_offload *flow, const struct nf_conn *ct,
++			   enum ip_conntrack_dir dir)
++{
++	struct nf_conn_qos *qos;
++
++	qos = nf_conn_qos_find(ct);
++	if (qos) {
++		flow->tuplehash[dir].tuple.tos = qos->tos[dir].value;
++		flow->tuplehash[!dir].tuple.tos = qos->tos[!dir].value;
++	}
++}
++
+ static enum flow_offload_xmit_type nft_xmit_type(struct dst_entry *dst)
+ {
+ 	if (dst_xfrm(dst))
+@@ -486,6 +500,11 @@ static void nft_flow_offload_eval(const
+ 	struct flow_offload *flow;
+ 	enum ip_conntrack_dir dir;
+ 	struct nf_conn *ct;
++	struct nf_conn_qos *qos;
++	struct ipv6hdr *ip6h;
++	struct iphdr *iph;
++	u32 offset = 0;
++	u8 tos = 0;
+ 	int ret;
+ 
+ 	if (nft_flow_offload_skip(pkt->skb, nft_pf(pkt)))
+@@ -531,10 +550,33 @@ static void nft_flow_offload_eval(const
+ 	if (!nf_ct_is_confirmed(ct))
+ 		goto out;
+ 
++	dir = CTINFO2DIR(ctinfo);
++
++	qos = nf_conn_qos_find(ct);
++	if (qos) {
++		struct net *net = nf_ct_net(ct);
++
++		switch (nft_pf(pkt)) {
++		case NFPROTO_IPV4:
++			iph = (struct iphdr *)(skb_network_header(pkt->skb) + offset);
++			tos = iph->tos;
++			break;
++		case NFPROTO_IPV6:
++			ip6h = (struct ipv6hdr *)(skb_network_header(pkt->skb) + offset);
++			tos = ipv6_get_dsfield(ip6h);
++			break;
++		}
++
++		qos->tos[dir].value = tos;
++		atomic64_add(1, &qos->tos[dir].counter);
++
++		if (atomic64_read(&qos->tos[dir].counter) < net->ct.sysctl_qos)
++			goto out;
++	}
++
+ 	if (test_and_set_bit(IPS_OFFLOAD_BIT, &ct->status))
+ 		goto out;
+ 
+-	dir = CTINFO2DIR(ctinfo);
+ 	if (nft_flow_offload_is_bridging(pkt->skb)) {
+ 		if (nft_flow_route_bridging(pkt, ct, &route, dir, priv->flowtable) < 0)
+ 			goto err_flow_route;
+@@ -551,6 +593,8 @@ static void nft_flow_offload_eval(const
+ 	if (tcph)
+ 		flow_offload_ct_tcp(ct);
+ 
++	nft_flow_offload_dscp_init(flow, ct, dir);
++
+ 	__set_bit(NF_FLOW_HW_BIDIRECTIONAL, &flow->flags);
+ 	ret = flow_offload_add(flowtable, flow);
+ 	if (ret < 0)
diff --git a/target/linux/mediatek/patches-6.12/999-ppe-18-xt_FLOWOFFLOAD-netfilter-fix-memory-leak-issue.patch b/target/linux/mediatek/patches-6.12/999-ppe-18-xt_FLOWOFFLOAD-netfilter-fix-memory-leak-issue.patch
