+-static int
+-mtk_flow_get_ct_dir(struct mtk_eth *eth, struct mtk_foe_entry *foe,
+-		    struct nf_conn *ct)
++static void
++mtk_foe_to_ct_tuple(struct mtk_eth *eth, struct mtk_foe_entry *foe,
++		    struct nf_conntrack_tuple *tuple)
+ {
+-	const struct nf_conntrack_tuple *tuple;
+-	struct mtk_flow_entry ct_entry;
+-	struct mtk_foe_entry *ct_foe;
+-	int i, j, len;
++	int i, pkt_type;
+ 
+-	if (!eth || !foe || !ct)
+-		return -EINVAL;
++	pkt_type = mtk_get_ib1_pkt_type(eth, foe->ib1);
+ 
+-	len = mtk_flow_entry_match_len(eth, foe);
+-	ct_foe = &ct_entry.data;
+-	ct_foe->ib1 = foe->ib1;
++	memset(tuple, 0, sizeof(*tuple));
++	tuple->dst.protonum = FIELD_GET(MTK_FOE_IB1_UDP, foe->ib1)
++			      ? IPPROTO_UDP : IPPROTO_TCP;
++
++	switch (pkt_type) {
++	case MTK_PPE_PKT_TYPE_IPV4_HNAPT:
++	case MTK_PPE_PKT_TYPE_IPV4_DSLITE:
++		tuple->src.l3num = AF_INET;
++		tuple->src.u3.ip = htonl(foe->ipv4.orig.src_ip);
++		tuple->dst.u3.ip = htonl(foe->ipv4.orig.dest_ip);
++		tuple->src.u.all = htons(foe->ipv4.orig.src_port);
++		tuple->dst.u.all = htons(foe->ipv4.orig.dest_port);
++		break;
++	case MTK_PPE_PKT_TYPE_IPV6_ROUTE_5T:
++	case MTK_PPE_PKT_TYPE_IPV6_6RD:
++		tuple->src.l3num = AF_INET6;
++		for (i = 0; i < 4; i++) {
++			tuple->src.u3.in6.s6_addr32[i] = htonl(foe->ipv6.src_ip[i]);
++			tuple->dst.u3.in6.s6_addr32[i] = htonl(foe->ipv6.dest_ip[i]);
