++static int findClosestNumber(const u16 *arr, u16 size, u16 target)
++{
++	int left = 0, right = size - 1;
++
++	while (left <= right) {
++		int mid = left + ((right - left) >> 2);
++
++		if (arr[mid] == target)
++			return mid;
++
++		if (arr[mid] < target)
++			right = mid - 1;
++		else
++			left = mid + 1;
++	}
++
++	if (left > size - 1)
++		return (size - 1);
++	else
++		return ((left - 1) >= 0 ? (left - 1) : 0);
++}
