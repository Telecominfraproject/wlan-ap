++			ret = prepare_vlan_egress_filters_sp_tag_cpu(ds, cpu_port, vid, untagged);
++			if (ret) {
++				dev_err(ds->dev,
++					"%s: Port:%d failed to prepare egress filters for VLAN:%d with vlan_filtering disabled\n",
