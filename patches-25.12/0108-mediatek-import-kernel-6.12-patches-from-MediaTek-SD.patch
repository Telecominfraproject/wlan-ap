++static void mt753x_disconnect_internal_phys(struct gsw_mt753x *gsw)
++{
++	int i;
++
++	for (i = 0; i < ARRAY_SIZE(gsw->phys); i++) {
++		if (gsw->phys[i].phydev) {
++			phy_stop(gsw->phys[i].phydev);
++			phy_disconnect(gsw->phys[i].phydev);
++			gsw->phys[i].phydev = NULL;
++		}
++	}
++}
