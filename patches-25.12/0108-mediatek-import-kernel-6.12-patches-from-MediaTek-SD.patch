+ struct mtk_ppe {
+ 	struct mtk_eth *eth;
+ 	struct device *dev;
+@@ -436,5 +453,6 @@ int mtk_flow_entry_match_len(struct mtk_
+ bool mtk_flow_entry_match(struct mtk_eth *eth, struct mtk_flow_entry *entry,
