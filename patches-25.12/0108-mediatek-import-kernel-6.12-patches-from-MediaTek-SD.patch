+-				 <&infracfg CLK_INFRA_133M_PCIE_CK_P2>;
++				 <&infracfg CLK_INFRA_133M_PCIE_CK_P2>,
++				 <&topckgen CLK_TOP_PEXTP_P2_SEL>;
+ 			clock-names = "pl_250m", "tl_26m", "peri_26m",
+-				      "top_133m";
++				      "top_133m", "pextp_clk";
+ 			pinctrl-names = "default";
