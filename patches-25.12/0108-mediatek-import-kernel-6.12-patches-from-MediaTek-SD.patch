+ 	reg_writew(priv, MTK_2P5GPHY_MCU_CSR + MD32_EN_CFG, reg & ~MD32_EN);
+ 	reg_writew(priv, MTK_2P5GPHY_MCU_CSR + MD32_EN_CFG, reg | MD32_EN);
+-	phy_set_bits(phydev, MII_BMCR, BMCR_RESET);
++	__phy_set_bits(phydev, MII_BMCR, BMCR_RESET);
+ 	/* We need a delay here to stabilize initialization of MCU */
