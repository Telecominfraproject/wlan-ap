+---
+[v1] netfilter: fix memory leak issue for the xt_FLOWOFFLOAD
+
+Without this patch, the kernel may encounter an OOM issue with the
+ip_dst during a high number of WiFi STA connections.
+---
+v1: Fix ip_dst memory leak in xt_FLOWOFFLOAD due to missing dst_release.
+---
+
+From ee392375fccb82bd64cd23bcf325a46d6d83d7a3 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Wed, 24 Sep 2025 12:58:26 +0800
+Date: Fri, 6 Jun 2025 20:13:10 +0800
+Subject: [PATCH] netfilter: fix memory leak issue for the xt_FLOWOFFLOAD
+
+Without this patch, the kernel may encounter an OOM issue with the
+ip_dst during a high number of WiFi STA connections.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ net/netfilter/xt_FLOWOFFLOAD.c | 11 ++++++++---
+ 1 file changed, 8 insertions(+), 3 deletions(-)
+
+--- a/net/netfilter/xt_FLOWOFFLOAD.c
++++ b/net/netfilter/xt_FLOWOFFLOAD.c
+@@ -563,10 +563,12 @@ xt_flowoffload_route_routing(struct sk_b
+ 
+ 	if (route->tuple[dir].xmit_type == FLOW_OFFLOAD_XMIT_NEIGH &&
+ 	    route->tuple[!dir].xmit_type == FLOW_OFFLOAD_XMIT_NEIGH) {
+-		if (nf_dev_forward_path(skb, route, ct, dir, devs))
+-			return -ENOENT;
+-		if (nf_dev_forward_path(skb, route, ct, !dir, devs))
++		if (nf_dev_forward_path(skb, route, ct, dir, devs) ||
++		    nf_dev_forward_path(skb, route, ct, !dir, devs)) {
++			dst_release(route->tuple[dir].dst);
++			dst_release(route->tuple[!dir].dst);
+ 			return -ENOENT;
++		}
+ 	}
+ 
+ 	return 0;
+@@ -757,6 +759,9 @@ flowoffload_tg(struct sk_buff *skb, cons
+ 	xt_flowoffload_check_device(table, devs[0]);
+ 	xt_flowoffload_check_device(table, devs[1]);
+ 
++	dst_release(route.tuple[dir].dst);
++	dst_release(route.tuple[!dir].dst);
++
+ 	return XT_CONTINUE;
+ 
+ err_flow_add:
