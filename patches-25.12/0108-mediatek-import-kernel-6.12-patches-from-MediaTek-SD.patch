++static int air_get_autonego(struct phy_device *phydev, int *an)
++{
++	int reg;
++
++	reg = phy_read(phydev, MII_BMCR);
++	if (reg < 0)
++		return -EINVAL;
++	if (reg & BMCR_ANENABLE)
++		*an = AUTONEG_ENABLE;
++	else
++		*an = AUTONEG_DISABLE;
++
++	return 0;
++}
++
++static int air_ref_clk_speed(struct phy_device *phydev, int para)
++{
++	int ret, lpa, bmcr, adv;
++	struct an8811hb_priv *priv = phydev->priv;
++	int saved_page;
++	struct device *dev = phydev_dev(phydev);
++
++	saved_page = phy_select_page(phydev, AIR_PHY_PAGE_STANDARD);
++
++	ret = __phy_read(phydev, MII_BMCR);
++	if (ret < 0)
++		return -EINVAL;
++
++	if (ret & BMCR_ANENABLE)
++		priv->an = AUTONEG_ENABLE;
++	else
++		priv->an = AUTONEG_DISABLE;
++
++	ret = __phy_write(phydev, 0x1f, 0x0);
++
++	/* Get real speed from vendor register */
++	ret = __phy_read(phydev, AIR_AUX_CTRL_STATUS);
++	if (ret < 0)
++		return ret;
++
++	switch (ret & AIR_AUX_CTRL_STATUS_SPEED_MASK) {
++	case AIR_AUX_CTRL_STATUS_SPEED_2500:
++		priv->speed = SPEED_2500;
++		break;
++	case AIR_AUX_CTRL_STATUS_SPEED_1000:
++		priv->speed = SPEED_1000;
++		break;
++	case AIR_AUX_CTRL_STATUS_SPEED_100:
++		priv->speed = SPEED_100;
++		break;
++	case AIR_AUX_CTRL_STATUS_SPEED_10:
++		priv->speed = SPEED_10;
++		break;
++	default:
++		priv->speed = SPEED_2500;
++		priv->duplex = DUPLEX_FULL;
++		dev_err(dev, "%s: Default Speed: 0x%x\n", __func__, ret);
++		break;
++	}
++
++	if (priv->an == AUTONEG_ENABLE) {
++		adv = __phy_read(phydev, MII_ADVERTISE);
++		if (adv < 0)
++			return adv;
++
++		lpa = __phy_read(phydev, MII_LPA);
++		if (lpa < 0)
++			return lpa;
++
++		switch (priv->speed) {
++		case SPEED_2500:
++		case SPEED_1000:
++			priv->duplex = DUPLEX_FULL;
++			break;
++		case SPEED_100:
++			priv->duplex = (adv & lpa & LPA_100FULL) ?
++					DUPLEX_FULL : DUPLEX_HALF;
++			break;
++		case SPEED_10:
++			priv->duplex = (adv & lpa & LPA_10FULL) ?
++					DUPLEX_FULL : DUPLEX_HALF;
++			break;
++		}
++	} else if (priv->an == AUTONEG_DISABLE) {
++		bmcr = __phy_read(phydev, MII_BMCR);
++		if (bmcr < 0)
++			return bmcr;
++
++		if (priv->speed == SPEED_2500)
++			priv->duplex = DUPLEX_FULL;
++		else
++			priv->duplex = (bmcr & BMCR_FULLDPLX) ?
++					DUPLEX_FULL : DUPLEX_HALF;
++	}
++
++	return phy_restore_page(phydev, saved_page, ret);
++}
++
++static int air_read_status(struct phy_device *phydev)
++{
++	int ret = 0, reg = 0;
++	struct an8811hb_priv *priv = phydev->priv;
++
++	priv->speed = SPEED_UNKNOWN;
++	priv->duplex = DUPLEX_UNKNOWN;
++	priv->pause = 0;
++	priv->asym_pause = 0;
++
++	reg = phy_read(phydev, MII_BMSR);
++	if (reg < 0) {
++		phydev_err(phydev, "MII_BMSR reg %d!\n", reg);
++		return reg;
++	}
++	reg = phy_read(phydev, MII_BMSR);
++	if (reg < 0) {
++		phydev_err(phydev, "MII_BMSR reg %d!\n", reg);
++		return reg;
++	}
++	if (reg & BMSR_LSTATUS) {
++		priv->link = 1;
++
++		ret = air_ref_clk_speed(phydev, AIR_PARA_PRIV);
++		if (ret < 0)
++			return ret;
++
++		reg = phy_read(phydev, MII_ADVERTISE);
++		if (reg < 0)
++			return reg;
++		priv->pause = GET_BIT(reg, 10);
++		priv->asym_pause = GET_BIT(reg, 11);
++	} else
++		priv->link = 0;
++
++	return 0;
++}
