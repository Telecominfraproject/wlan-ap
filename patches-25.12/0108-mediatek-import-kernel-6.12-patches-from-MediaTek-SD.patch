diff --git a/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-02-arm64-dts-mediatek-add-mt7986-dt-overlay-support.patch b/target/linux/mediatek/patches-6.12/999-dts-mt7986a-rfb-02-arm64-dts-mediatek-add-mt7986-dt-overlay-support.patch
