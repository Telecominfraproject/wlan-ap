+ 
+ 	*ib2 &= ~MTK_FOE_IB2_DSCP;
+ 	*ib2 |= FIELD_PREP(MTK_FOE_IB2_DSCP, dscp);
+ 
++	if (pkt_type == MTK_PPE_PKT_TYPE_IPV4_DSLITE) {
++		entry->dslite.flow_info &= ~MTK_FOE_DSLITE_IPV6_TRAF_CLS;
++		entry->dslite.flow_info |= FIELD_PREP(MTK_FOE_DSLITE_IPV6_TRAF_CLS, dscp);
++	} else if (pkt_type == MTK_PPE_PKT_TYPE_IPV6_6RD) {
++		entry->ipv6_6rd.dscp = (u8)dscp;
++	}
++
+ 	if (mtk_is_netsys_v3_or_greater(eth) && eth->dscp_toggle == 1) {
+ 		u32 *udf = mtk_foe_entry_udf(eth, entry);
+ 		*udf |= FIELD_PREP(MTK_FOE_UDF_KEEP_ECN, 1) |
+@@ -1096,6 +1146,11 @@ void __mtk_ppe_check_skb(struct mtk_ppe
+ 			continue;
+ 		}
