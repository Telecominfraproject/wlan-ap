+ 	return 0;
+ }
+ 
++static void mtk_stats_update_gmac_ext(struct mtk_mac *mac)
++{
++	struct mtk_hw_stats *hw_stats = mac->hw_stats;
++
++	hw_stats->rx_unicast_packets +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x00);
++	hw_stats->rx_unicast_bytes +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x08);
++	hw_stats->rx_multicast_packets +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x10);
++	hw_stats->rx_multicast_bytes +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x18);
++	hw_stats->rx_broadcast_packets +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x20);
++	hw_stats->rx_broadcast_bytes +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x28);
++
++	hw_stats->tx_unicast_packets +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x30);
++	hw_stats->tx_unicast_bytes +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x38);
++	hw_stats->tx_multicast_packets +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x40);
++	hw_stats->tx_multicast_bytes +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x48);
++	hw_stats->tx_broadcast_packets +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x50);
++	hw_stats->tx_broadcast_bytes +=
++		mtk_r64(mac->hw, MTK_MAC_MIB(mac->id) + 0x58);
++}
++
++static void mtk_stats_update_xgmac(struct mtk_mac *mac)
++{
++	struct mtk_hw_stats *hw_stats = mac->hw_stats;
++	u64 rx_crcerr_cnt, rx_eof_cnt;
