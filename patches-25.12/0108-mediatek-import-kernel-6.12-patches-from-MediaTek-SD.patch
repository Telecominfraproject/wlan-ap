++
++static int mtk_hwlro_cfg_mem_done(struct mtk_eth *eth)
++{
++	u32 val;
++	int ret;
++
++	if (!MTK_HAS_CAPS(eth->soc->caps, MTK_GLO_MEM_ACCESS))
