diff --git a/target/linux/mediatek/patches-6.12/999-dts-mt7986b-rfb-03-arm64-dts-mediatek-fix-spim-nand-dts-setting.patch b/target/linux/mediatek/patches-6.12/999-dts-mt7986b-rfb-03-arm64-dts-mediatek-fix-spim-nand-dts-setting.patch
