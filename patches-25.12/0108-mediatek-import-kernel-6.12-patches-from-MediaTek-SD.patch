+ 	status = "okay";
+ 
+ 	spi_nand: spi_nand@1 {
+ 		compatible = "spi-nand";
+ 		reg = <1>;
+-		spi-max-frequency = <10000000>;
++		spi-max-frequency = <52000000>;
+ 		spi-tx-bus-width = <4>;
+ 		spi-rx-bus-width = <4>;
