++static int an8855_sw_detect(struct gsw_an8855 *gsw, struct chip_rev *crev)
++{
++	u32 id, rev;
++
++	id = an8855_reg_read(gsw, CHIP_ID);
++	rev = an8855_reg_read(gsw, CHIP_REV);
++	if (id == AN8855) {
++		if (crev) {
++			crev->rev = rev;
++			crev->name = "AN8855";
++		}
++
++		return 0;
++	}
++
++	return -ENODEV;
++}
