++				return ret;
++			}
++		}
++		/* vlan_filtering enabled */
++		else {
++			ret = prepare_vlan_ingress_filters(ds, port, vid);
++			if (ret) {
++				dev_err(ds->dev,
++					"%s: Port:%d failed to prepare ingress filters for VLAN:%d\n",
++					__func__, port, vid);
++				NL_SET_ERR_MSG_MOD(extack, "Failed to prepare ingress filters for VLAN");
++				return ret;
