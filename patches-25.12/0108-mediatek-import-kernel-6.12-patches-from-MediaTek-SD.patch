++	MTK_ETHTOOL_STAT(tx_multicast_bytes),
++	MTK_ETHTOOL_STAT(tx_multicast_packets),
++	MTK_ETHTOOL_STAT(tx_broadcast_bytes),
++	MTK_ETHTOOL_STAT(tx_broadcast_packets),
++	MTK_ETHTOOL_STAT(rx_unicast_bytes),
++	MTK_ETHTOOL_STAT(rx_unicast_packets),
++	MTK_ETHTOOL_STAT(rx_multicast_bytes),
++	MTK_ETHTOOL_STAT(rx_multicast_packets),
++	MTK_ETHTOOL_STAT(rx_broadcast_bytes),
++	MTK_ETHTOOL_STAT(rx_broadcast_packets),
++};
++
+ static const char * const mtk_clks_source_name[] = {
+ 	"ethif",
+ 	"sgmiitop",
+@@ -344,6 +362,11 @@ u32 mtk_m32(struct mtk_eth *eth, u32 mask, u32 set, unsigned int reg)
+ 	return reg;
+ }
+ 
++u64 mtk_r64(struct mtk_eth *eth, unsigned reg)
++{
++	return mtk_r32(eth, reg) + ((u64)mtk_r32(eth, reg + 0x4) << 32);
++}
++
+ static int mtk_mdio_busy_wait(struct mtk_eth *eth)
+ {
+ 	unsigned long t_start = jiffies;
+@@ -835,6 +858,8 @@ static int mtk_mac_prepare(struct phylink_config *config, unsigned int mode,
+ 		else
+ 			mtk_m32(mac->hw, MTK_XGMAC_FORCE_MODE(mac->id) | MTK_XGMAC_FORCE_LINK(mac->id),
+ 				MTK_XGMAC_FORCE_MODE(mac->id), MTK_XGMAC_STS(mac->id));
