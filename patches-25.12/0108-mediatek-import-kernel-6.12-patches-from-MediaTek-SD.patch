++
++		ret = air_buckpbus_reg_write(phydev, reg, val);
++		if (ret < 0)
++			return ret;
++
++		pr_notice("\nphy=%d, reg=0x%x, val=0x%x confirm..\n",
++			  addr, reg,
++			  air_buckpbus_reg_read(phydev, reg));
++	} else if (buf[0] == 'r') {
++		if (sscanf(buf, "r %x", &reg) == -1)
++			return -EFAULT;
