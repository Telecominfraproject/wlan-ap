++	if (ret < 0)
++		goto err;
++
++	ret = nla_put_string(rep_skb, AN8855_ATTR_TYPE_MESG, dev_info);
++	if (ret < 0)
++		goto err;
++
++	return an8855_nl_send_reply(rep_skb, info);
