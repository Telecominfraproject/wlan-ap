+ 	/* Configure speed */
+-	mac->speed = speed;
+ 	switch (speed) {
+ 	case SPEED_2500:
+ 	case SPEED_1000:
+@@ -1091,6 +1090,7 @@ static void mtk_mac_link_up(struct phyli
+ 	struct mtk_mac *mac = container_of(config, struct mtk_mac,
+ 					   phylink_config);
+ 
