++
++	ret = mxl862xx_update_bridge_conf_port(ds, port, bridge.dev, 1);
++	if (ret) {
++		dev_err(ds->dev,
++			"%s: bridge port adding failed for port %d, ret %d\n",
++			__func__, port, ret);
