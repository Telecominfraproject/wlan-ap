@@ -0,0 +1,60 @@
+---
+[v1] net: ethernet: mtk_eth_soc: add TX ring full event counter
+
+Add atomic counter to track TX ring full events. This diagnostic feature helps
+monitor ring congestion and provides visibility into transmit queue overflow
+conditions for performance tuning and troubleshooting.
+---
+v1: Add debugfs support for reading TX ring full event count.
+---
+
+From 0c039f8714c37bff440cb6fac6b14d7fa96f3b13 Mon Sep 17 00:00:00 2001
+From: Mason Chang <mason-cw.chang@mediatek.com>
+Date: Tue, 7 Oct 2025 10:52:08 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add tx ring full event counter
+
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 6 +++++-
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h | 1 +
+ 2 files changed, 6 insertions(+), 1 deletion(-)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -2168,6 +2168,7 @@ static netdev_tx_t mtk_start_xmit(struct
+ 		netif_tx_stop_all_queues(dev);
+ 		netif_err(eth, tx_queued, dev,
+ 			  "Tx Ring full when queue awake!\n");
++		atomic_inc(&ring->full_count);
+ 		spin_unlock(&eth->page_lock);
+ 		return NETDEV_TX_BUSY;
+ 	}
+@@ -2213,8 +2214,10 @@ send:
+ 		}
+ 	}
+ 
+-	if (unlikely(atomic_read(&ring->free_count) <= ring->thresh))
++	if (unlikely(atomic_read(&ring->free_count) <= ring->thresh)) {
+ 		netif_tx_stop_all_queues(dev);
++		atomic_inc(&ring->full_count);
++	}
+ 
+ 	spin_unlock(&eth->page_lock);
+ 
+@@ -3065,6 +3068,7 @@ static int mtk_tx_alloc(struct mtk_eth *
+ 
+ 	ring->dma_size = ring_size;
+ 	atomic_set(&ring->free_count, ring_size - 2);
++	atomic_set(&ring->full_count, 0);
+ 	ring->next_free = ring->dma;
+ 	ring->last_free = (void *)txd;
+ 	ring->last_free_ptr = (u32)(ring->phys + TX_DESC_OFS(eth, ring_size - 1));
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -1068,6 +1068,7 @@ struct mtk_tx_ring {
+ 	u32 last_free_ptr;
+ 	u16 thresh;
+ 	atomic_t free_count;
++	atomic_t full_count;
+ 	int dma_size;
+ 	struct mtk_tx_dma *dma_pdma;	/* For MT7628/88 PDMA handling */
+ 	dma_addr_t phys_pdma;
