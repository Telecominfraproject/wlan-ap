++	u32 val = 0, reg = 0;
++	u8 pair, cnt;
++
++	dev_info(dev, "Cable Diag Dump\n");
++	for (pair = 0; pair < 4; pair++) {
++		for (cnt = 0; cnt < 64; cnt++) {
