++static int an8801r_read_status(struct phy_device *phydev)
++{
++	int ret, prespeed = phydev->speed;
++	u32 data;
++
++	ret = genphy_read_status(phydev);
++	if (phydev->link == LINK_DOWN) {
++		prespeed = 0;
