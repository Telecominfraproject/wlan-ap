++void aeon_ipc_sds_txfir(unsigned char sds_id, unsigned char pre, unsigned char main,
++			unsigned char post, struct phy_device *phydev)
++{
++	unsigned char data[8], data_size;
++
++	data[0] = sds_id;
++	data[1] = pre;
++	data[2] = main;
