++static u8 shift_check(u8 base)
++{
++	u8 i;
++	u32 sz = sizeof(r50ohm_table)/sizeof(u8);
++
++	for (i = 0; i < sz; ++i)
++		if (r50ohm_table[i] == base)
++			break;
++
++	if (i < 8 || i >= sz)
++		return 25; /* index of 94 */
++
++	return (i - 8);
++}
++
++static u8 get_shift_val(u8 idx)
++{
++	return r50ohm_table[idx];
++}
