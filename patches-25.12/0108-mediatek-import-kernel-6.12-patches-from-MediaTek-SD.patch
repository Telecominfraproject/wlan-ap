++static int air_phy_reg_modify(struct phy_device *phydev,
++			     u16 reg, u16 mask, u16 set)
++{
++	int val, newval;
++
++	val = phy_read(phydev, reg);
++	if (val < 0)
++		return val;
++
++	newval = (val & ~mask) | set;
++	if (newval == val)
++		return 0;
++
++	return phy_write(phydev, reg, newval);
++}
