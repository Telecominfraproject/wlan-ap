++		ct_mark = ct->mark;
++	}
++
++	if (eth->qos_toggle == 2 && mtk_ppe_check_pppq_path(mac, idev, dsa_port))
++		mtk_foe_entry_set_queue(eth, foe, queue);
++	else if (eth->qos_toggle == 1 || (ct_mark & MTK_QDMA_QUEUE_MASK) >= 9) {
