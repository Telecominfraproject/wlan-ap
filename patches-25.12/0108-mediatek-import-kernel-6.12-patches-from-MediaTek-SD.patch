++static u16 __mtk_foe_entry_get_chkbase(struct iphdr *iph)
++{
++	__wsum csum = csum_unfold(iph->check);
++
++	/* Remove the variable per-packet fields from the checksum */
++	csum = csum_sub(csum, csum_unfold(iph->tot_len));
++	csum = csum_sub(csum, csum_unfold(iph->id));
++
++	return ntohs(csum_fold(csum));
++}
++
++static int mtk_foe_entry_set_csum_base(struct mtk_eth *eth,
++				       struct mtk_foe_entry *entry,
++				       __be32 src_addr, __be32 dest_addr)
++{
++	int type = mtk_get_ib1_pkt_type(eth, entry->ib1);
++	struct iphdr iph = {0};
++
++	if (WARN_ON_ONCE(type != MTK_PPE_PKT_TYPE_IPV6_6RD))
++		return -EINVAL;
++
++	iph.ihl = 5;
++	iph.version = 4;
++	iph.tos = entry->ipv6_6rd.dscp;
++	iph.frag_off = htons(IP_DF); /* Do not fragment */
++	iph.ttl = entry->ipv6_6rd.ttl;
++	iph.protocol = FIELD_GET(MTK_FOE_IB1_UDP, entry->ib1) ? IPPROTO_UDP : IPPROTO_TCP;
++	iph.saddr = src_addr;
++	iph.daddr = dest_addr;
++	iph.check = ip_fast_csum(&iph, iph.ihl);
++
++	entry->ipv6_6rd.hdr_csum = __mtk_foe_entry_get_chkbase(&iph);
++	entry->ipv6_6rd.flag = IP_DF >> 13; /* Do not fragment, without offset */
++
++	return 0;
++}
++
+ int mtk_foe_entry_set_ipv4_tuple(struct mtk_eth *eth,
+ 				 struct mtk_foe_entry *entry, bool egress,
+ 				 __be32 src_addr, __be16 src_port,
+@@ -486,6 +527,7 @@ int mtk_foe_entry_set_ipv4_tuple(struct
+ 	case MTK_PPE_PKT_TYPE_IPV6_6RD:
+ 		entry->ipv6_6rd.tunnel_src_ip = be32_to_cpu(src_addr);
+ 		entry->ipv6_6rd.tunnel_dest_ip = be32_to_cpu(dest_addr);
