+@@ -1202,6 +1212,7 @@ static const struct net_device_ops macvl
+ 	.ndo_features_check	= passthru_features_check,
+ 	.ndo_hwtstamp_get	= macvlan_hwtstamp_get,
+ 	.ndo_hwtstamp_set	= macvlan_hwtstamp_set,
