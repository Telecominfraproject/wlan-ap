+---
+[v1] arm64: dts: mediatek: add mt7981 SPI NAND with NMBM overlay
+
+Add DTS overlay for MT7981 SPI NAND flash with NMBM bad block management
+configuration. This overlay is part of the MT7981 DTS overlay architecture
+enabling runtime device tree composition for different storage types.
+Combining base MT7981 DTS with this overlay enables NAND boot with the
+NMBM bad block management.
+---
+v1: Initial release for the openwrt-25.12 branch.
+---
+
+--- /dev/null
++++ b/arch/arm64/boot/dts/mediatek/mt7981-rfb-spim-nand-nmbm.dtso
+@@ -0,0 +1,71 @@
++/* SPDX-License-Identifier: (GPL-2.0-only OR MIT) */
++/*
++ * Copyright (C) 2025 MediaTek Inc.
++ * Author: Sam.Shih <sam.shih@mediatek.com>
++ */
++
++/dts-v1/;
++/plugin/;
++
++&{/chosen} {
++	rootdisk-spim-nand = <&ubi_rootfs>;
++	bootargs-append = " ubi.block=0,firmware root=/dev/fit0 rootwait";
++};
++
++&{/soc/spi@1100a000} {
++	status = "okay";
++
++	flash@0 {
++		compatible = "spi-nand";
++		reg = <0>;
++		spi-max-frequency = <52000000>;
++		spi-tx-bus-width = <4>;
++		spi-rx-bus-width = <4>;
++		mediatek,nmbm;
++		mediatek,bmt-max-ratio = <1>;
++		mediatek,bmt-max-reserved-blocks = <64>;
++
++		partitions {
++			compatible = "fixed-partitions";
++			#address-cells = <1>;
++			#size-cells = <1>;
++
++			partition@0 {
++				label = "BL2";
++				reg = <0x00000 0x0100000>;
++				read-only;
++			};
++
++			partition@100000 {
++				label = "u-boot-env";
++				reg = <0x0100000 0x0080000>;
++			};
++
++			factory: partition@180000 {
++				label = "Factory";
++				reg = <0x180000 0x0200000>;
++			};
++
++			partition@580000 {
++				label = "FIP";
++				reg = <0x380000 0x0200000>;
++			};
++
++			partition@780000 {
++				label = "ubi";
++				reg = <0x580000 0x4000000>;
++				compatible = "linux,ubi";
++
++				volumes {
++					ubi_rootfs: ubi-volume-fit {
++						volname = "firmware";
++					};
++				};
++			};
++		};
++	};
++};
++
++&{/soc/wifi@18000000} {
++	mediatek,mtd-eeprom = <&factory 0>;
++};
