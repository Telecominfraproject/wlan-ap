@@ -0,0 +1,48 @@
+---
+[v1] arm64: dts: mt7988: fix typo in LAN and WAN MAC address offset for
+ Full UBI
+
+This patch is used to correct the LAN and WAN MAC address offset for
+ Full UBI in the OpenWrt upstream patch [1].
+
+[1] 188-arm64-dts-MediaTek-add-MT7988A-reference-board-devic.patch
+---
+v1: Fix typo in the LAN and WAN MAC address offset for Full UBI
+---
+
+From f923856d43ac2c7ea180e5fd912cecb0faacbef8 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Tue, 24 Mar 2026 10:34:18 +0800
+Subject: [PATCH] arm64: dts: mt7988: fix typo in LAN and WAN MAC address
+ offset for Full UBI
+
+Without this patch, the MAC addresses of the LAN and WAN will be
+swapped when using Full UBI.
+---
+ .../boot/dts/mediatek/mt7988a-rfb-spim-nand-factory.dtso  | 8 ++++----
+ 1 file changed, 4 insertions(+), 4 deletions(-)
+
+diff --git a/arch/arm64/boot/dts/mediatek/mt7988a-rfb-spim-nand-factory.dtso b/arch/arm64/boot/dts/mediatek/mt7988a-rfb-spim-nand-factory.dtso
+index 4b554a1..3130ba4 100644
+--- a/arch/arm64/boot/dts/mediatek/mt7988a-rfb-spim-nand-factory.dtso
++++ b/arch/arm64/boot/dts/mediatek/mt7988a-rfb-spim-nand-factory.dtso
+@@ -27,12 +27,12 @@ gmac2_mac: eeprom@fffee {
+ 							reg = <0xfffee 0x6>;
+ 						};
+ 
+-						gmac1_mac: eeprom@ffff4 {
+-							reg = <0xffff4 0x6>;
++						gmac1_mac: eeprom@ffffa {
++							reg = <0xffffa 0x6>;
+ 						};
+ 
+-						gmac0_mac: eeprom@ffffa {
+-							reg = <0xffffa 0x6>;
++						gmac0_mac: eeprom@ffff4 {
++							reg = <0xffff4 0x6>;
+ 						};
+ 					};
+ 				};
+-- 
+2.45.2
+
