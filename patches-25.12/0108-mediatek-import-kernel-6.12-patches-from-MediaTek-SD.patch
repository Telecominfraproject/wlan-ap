++// SPDX-License-Identifier: (GPL-2.0 OR MIT)
++/*
++ * Copyright (C) 2026 MediaTek Inc.
++ * Author: Sam.Shih <sam.shih@mediatek.com>
++ */
++
++/dts-v1/;
++
++#include <dt-bindings/input/input.h>
++#include "mt7987a.dtsi"
++
++/* MT7987A RFB DTS for DT overlay-based device tree */
++/ {
++	model = "MediaTek MT7987A RFB";
++	compatible = "mediatek,mt7987a", "bananapi,bpi-r4-mini";
++
++	chosen {
++		bootargs = "console=ttyS0,115200n1 loglevel=6  \
++			    earlycon=uart8250,mmio32,0x11000000 \
++			    pci=pcie_bus_perf ubi.block=0,firmware \
++			    root=/dev/fit0 rootwait";
++		/* Every rootdisk node used by FIT is defined in the dtso
++		 * - NAND, FULL-UBI: rootdisk-spim-nand = <&ubi_root>;
++		 * - NAND, NMBM: rootdisk-spim-nand = <&ubi_rootfs>;
++		 * - EMMC: rootdisk-emmc = <&emmc_rootfs>;
++		 * - SD:   rootdisk-sd = <&sd_rootfs>;
++		 */
++	};
++
++	gpio-keys {
++		compatible = "gpio-keys";
++
++		reset {
++			label = "reset";
++			linux,code = <KEY_RESTART>;
++			gpios = <&pio 1 GPIO_ACTIVE_LOW>;
++			debounce-interval = <10>;
++		};
++
++		wps {
++			label = "wps";
++			linux,code = <KEY_WPS_BUTTON>;
++			gpios = <&pio 0 GPIO_ACTIVE_LOW>;
++			debounce-interval = <10>;
++		};
++	};
++
++	reg_3p3v: regulator-3p3v {
++		compatible = "regulator-fixed";
++		regulator-name = "fixed-3.3V";
++		regulator-min-microvolt = <3300000>;
++		regulator-max-microvolt = <3300000>;
++		regulator-boot-on;
++		regulator-always-on;
++	};
++};
++
++&spi0 {
++	status = "disabled";
++};
++
++&mmc0 {
++	/*
++	 * card@0 is defined in the dtso files:
++	 * - MMC: mt7987a-bananapi-bpi-r4-mini-emmc.dtso
++	 * - SD: mt7987a-bananapi-bpi-r4-mini-sd.dtso
++	 * U-boot would apply specified DTSO to this DTS
++	 */
++
++	status = "okay";
++};
++
++&spi2 {
++	/*
++	 * flash@0 is defined in the dtso files:
++	 * - NAND, FULL-UBI: mt7987a-bananapi-bpi-r4-mini-nand.dtso
++	 * - NAND: NMBM: mt7987a-bananapi-bpi-r4-mini-nand-nmbm.dtso
++	 * U-boot would apply specified DTSO to this DTS
++	 */
++
++	status = "okay";
++};
++
++/* Integrate mt7987-netsys-eth0-an8811hb.dtso fragment@1 */
++/*
++ * BPIR4-mini board-specific adjustments:
++ * 1. PHY ID is 14 (not 12 as in reference board)
++ * 2. reset-gpios uses pin 42 (not 48)
++ * 3. SGMII RX signal swap: add 'airoha,pnswap-rx' property for driver handling
++ */
++&mdio {
++	phy14: phy@14 {
++		compatible = "ethernet-phy-idc0ff.04a0";
++		reg = <14>;
++		airoha,pnswap-rx;
++		reset-gpios = <&pio 42 1>;
++		reset-assert-us = <10000>;
++		reset-deassert-us = <10000>;
++		phy-mode = "2500base-x";
++		full-duplex;
++		pause;
++		airoha,phy-handle;
++		eee-broken-100tx;
++		eee-broken-1000t;
++	};
++};
++
++/* Integrate mt7987-netsys-eth1-i2p5g.dtso fragment@1 */
++&mdio {
++	phy15: phy@15 {
++		pinctrl-names = "i2p5gbe-led";
++		pinctrl-0 = <&i2p5gbe_led0_pins>;
++		compatible = "ethernet-phy-ieee802.3-c45";
++		interrupts = <GIC_SPI 286 IRQ_TYPE_LEVEL_HIGH>;
++		interrupt-parent = <&gic>;
++		reg = <15>;
++		phy-mode = "internal";
++	};
++};
++
++/* Integrate mt7987-netsys-eth0-an8811hb.dtso fragment@0 */
++&gmac0 {
++	phy-mode = "2500base-x";
++	phy-handle = <&phy14>;
++	status = "okay";
++};
++
++/* Integrate mt7987-netsys-eth1-i2p5g.dtso fragment@0 */
++&gmac1 {
++	phy-mode = "internal";
++	phy-handle = <&phy15>;
++	status = "okay";
++};
++
++&pcie0 {
++	slot0: pcie@0,0 {
++		reg = <0x0000 0 0 0 0>;
++		wifi: wifi@0,0 {
++			compatible = "mediatek,mt76";
++			reg = <0x0000 0 0 0 0>;
++			device_type = "pci";
++
++			/* Factory node is defined in the dtso
++			 * - NAND, FULL-UBI: nvmem-cell-names = "eeprom";
++			 *                   nvmem-cells = <&eeprom_wmac>;
++			 * - NAND, NMBM: mediatek,mtd-eeprom = <&factory 0x0>;
++			 * - EMMC: nvmem-cells = <&eeprom_factory_0>;
++			 *         nvmem-cell-names = "eeprom";
++			 */
++		};
++	};
++};
++
++/* Integrate mt7987-netsys-eth2-usb.dtso fragment@1 */
++&ssusb {
++	phys = <&tphyu2port0 PHY_TYPE_USB2>,
++	       <&tphyu3port0 PHY_TYPE_USB3>;
++	mediatek,u3p-dis-msk=<0>;
++};
++
++/* Integrate mt7987-netsys-eth2-usb.dtso fragment@0 */
++&tphyu3port0 {
++	status = "okay";
++};
