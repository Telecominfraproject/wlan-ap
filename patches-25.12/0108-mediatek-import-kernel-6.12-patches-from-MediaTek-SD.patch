index 0000000000..54d225092e
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-17-mtk_eth_soc-change-napi-poll-weight-to-256.patch
@@ -0,0 +1,60 @@
+---
+[v1] net: ethernet: mtk_eth_soc: change NAPI poll weight to 256
+
+Change NAPI poll weight from default to 256 for improved throughput. This tuning
+parameter significantly affects peak performance of the software receive path,
+optimizing packet processing per NAPI poll cycle.
+---
+v1: Change TX/RX NAPI poll weight to 256.
+---
+
+From 9be90bb153b9a7cdd1fa0ef0b47414b5ddb36d63 Mon Sep 17 00:00:00 2001
+From: Mason Chang <mason-cw.chang@mediatek.com>
+Date: Mon, 22 Sep 2025 11:12:08 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: change napi poll weight to 256
+
+This parameter will strongly affect the peak throughput of the SW path.
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 13 +++++++------
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h |  1 +
+ 2 files changed, 8 insertions(+), 6 deletions(-)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -6700,19 +6700,20 @@ static int mtk_probe(struct platform_dev
+ 		goto err_deinit_ppe;
+ 	}
+ 	strcpy(eth->dummy_dev->name, "mtk_eth");
+-	netif_napi_add(eth->dummy_dev, &eth->tx_napi, mtk_napi_tx);
+-	netif_napi_add(eth->dummy_dev, &eth->rx_napi[0].napi, mtk_napi_rx);
++	netif_napi_add_weight(eth->dummy_dev, &eth->tx_napi, mtk_napi_tx, MTK_NAPI_WEIGHT);
++	netif_napi_add_weight(eth->dummy_dev, &eth->rx_napi[0].napi, mtk_napi_rx,
++			      MTK_NAPI_WEIGHT);
+ 
+ 	if (MTK_HAS_CAPS(eth->soc->caps, MTK_RSS)) {
+ 		for (i = 1; i < MTK_RX_RSS_NUM; i++)
+-			netif_napi_add(eth->dummy_dev, &eth->rx_napi[MTK_RSS_RING(i)].napi,
+-				       mtk_napi_rx);
++			netif_napi_add_weight(eth->dummy_dev, &eth->rx_napi[MTK_RSS_RING(i)].napi,
++					      mtk_napi_rx, MTK_NAPI_WEIGHT);
+ 	}
+ 
+ 	if (eth->hwlro) {
+ 		for (i = 0; i < MTK_HW_LRO_RING_NUM; i++) {
+-			netif_napi_add(eth->dummy_dev, &eth->rx_napi[MTK_HW_LRO_RING(i)].napi,
+-				       mtk_napi_rx);
++			netif_napi_add_weight(eth->dummy_dev, &eth->rx_napi[MTK_HW_LRO_RING(i)].napi,
++					      mtk_napi_rx, MTK_NAPI_WEIGHT);
+ 		}
+ 	}
+ 
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -36,6 +36,7 @@
+ #define MTK_DMA_SIZE(x)		(SZ_##x)
+ #define MTK_FQ_DMA_HEAD		32
+ #define MTK_FQ_DMA_LENGTH	2048
++#define MTK_NAPI_WEIGHT		256
+ #define MTK_RX_ETH_HLEN		(VLAN_ETH_HLEN + VLAN_HLEN + ETH_FCS_LEN)
+ #define MTK_RX_HLEN		(NET_SKB_PAD + MTK_RX_ETH_HLEN + NET_IP_ALIGN)
+ #define MTK_DMA_DUMMY_DESC	0xffffffff
diff --git a/target/linux/mediatek/patches-6.12/999-eth-18-mtk_eth_soc-refactor-PSE-PPE-port-link-down.patch b/target/linux/mediatek/patches-6.12/999-eth-18-mtk_eth_soc-refactor-PSE-PPE-port-link-down.patch
new file mode 100644
index 0000000000..8d89f24f13
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-18-mtk_eth_soc-refactor-PSE-PPE-port-link-down.patch
@@ -0,0 +1,97 @@
+---
+[v2] net: ethernet: mtk_eth_soc: refactor PSE PPE port link down for NETSYS SER
+
+Refactor PPE port link down handling for System Error Recovery (SER).
+This simplifies the flow by removing manual re-enable code since
+hardware automatically re-enables PSE PPE ports after NETSYS SER.
+---
+v2: Add the missing equal sign to the MTK_FE_GLO_CFG definition.
+v1: Refactor PSE PPE port link down flow for NETSYS SER.
+---
+
+From b49580f4b78abc1e6f49b8677ad1a8dd5faa05f7 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Mon, 22 Sep 2025 11:12:09 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: refactor PSE PPE port link down
+ flow for SER
+
+The PSE PPE port will be re-enabled automatically after NETSYS SER,
+so we do not need to enable it manually.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 27 +++------------------
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h |  5 +++-
+ 2 files changed, 8 insertions(+), 24 deletions(-)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -5285,15 +5285,10 @@ static void mtk_prepare_for_reset(struct
+ 	int i;
+ 
+ 	/* set FE PPE ports link down */
+-	for (i = MTK_GMAC1_ID;
+-	     i <= (mtk_is_netsys_v3_or_greater(eth) ? MTK_GMAC3_ID : MTK_GMAC2_ID);
+-	     i += 2) {
+-		val = mtk_r32(eth, MTK_FE_GLO_CFG(i)) | MTK_FE_LINK_DOWN_P(PSE_PPE0_PORT);
+-		if (MTK_HAS_CAPS(eth->soc->caps, MTK_RSTCTRL_PPE1))
+-			val |= MTK_FE_LINK_DOWN_P(PSE_PPE1_PORT);
+-		if (MTK_HAS_CAPS(eth->soc->caps, MTK_RSTCTRL_PPE2))
+-			val |= MTK_FE_LINK_DOWN_P(PSE_PPE2_PORT);
+-		mtk_w32(eth, val, MTK_FE_GLO_CFG(i));
++	for (i = 0; i < ARRAY_SIZE(eth->ppe); i++) {
++		val = mtk_r32(eth, MTK_FE_GLO_CFG(PSE_PPE_PORT(i)));
++		val |= MTK_FE_LINK_DOWN_P(PSE_PPE_PORT(i));
++		mtk_w32(eth, val, MTK_FE_GLO_CFG(PSE_PPE_PORT(i)));
+ 	}
+ 
+ 	/* adjust PPE configurations to prepare for reset */
+@@ -5314,7 +5309,6 @@ static void mtk_pending_work(struct work
+ {
+ 	struct mtk_eth *eth = container_of(work, struct mtk_eth, pending_work);
+ 	unsigned long restart = 0;
+-	u32 val;
+ 	int i;
+ 
+ 	rtnl_lock();
+@@ -5357,19 +5351,6 @@ static void mtk_pending_work(struct work
+ 		}
+ 	}
+ 
+-	/* set FE PPE ports link up */
+-	for (i = MTK_GMAC1_ID;
+-	     i <= (mtk_is_netsys_v3_or_greater(eth) ? MTK_GMAC3_ID : MTK_GMAC2_ID);
+-	     i += 2) {
+-		val = mtk_r32(eth, MTK_FE_GLO_CFG(i)) & ~MTK_FE_LINK_DOWN_P(PSE_PPE0_PORT);
+-		if (MTK_HAS_CAPS(eth->soc->caps, MTK_RSTCTRL_PPE1))
+-			val &= ~MTK_FE_LINK_DOWN_P(PSE_PPE1_PORT);
+-		if (MTK_HAS_CAPS(eth->soc->caps, MTK_RSTCTRL_PPE2))
+-			val &= ~MTK_FE_LINK_DOWN_P(PSE_PPE2_PORT);
+-
+-		mtk_w32(eth, val, MTK_FE_GLO_CFG(i));
+-	}
+-
+ 	clear_bit(MTK_RESETTING, &eth->state);
+ 
+ 	mtk_wed_fe_reset_complete();
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -87,7 +87,7 @@
+ #define MTK_RSS_MAX_INDIRECTION_TABLE	128
+ 
+ /* Frame Engine Global Configuration */
+-#define MTK_FE_GLO_CFG(x)	(((x) == MTK_GMAC3_ID) ? 0x24 : 0x00)
++#define MTK_FE_GLO_CFG(x)	(((x) >= 8) ? 0x24 : 0x00)
+ #define MTK_FE_LINK_DOWN_P(x)	BIT(((x) + 8) % 16)
+ 
+ /* Frame Engine Global Reset Register */
+@@ -1001,6 +1001,9 @@ enum mtk_pse_port {
+ #define PSE_GDM_PORT(x)		(((x) == 0) ? PSE_GDM1_PORT : \
+ 				 ((x) == 1) ? PSE_GDM2_PORT : PSE_GDM3_PORT)
+ 
++#define PSE_PPE_PORT(x)		(((x) == 0) ? PSE_PPE0_PORT : \
++				 ((x) == 1) ? PSE_PPE1_PORT : PSE_PPE2_PORT)
++
+ #define PSE_WDMA_PORT(x)	(((x) == 0) ? PSE_WDMA0_PORT : \
+ 				 ((x) == 1) ? PSE_WDMA1_PORT : PSE_WDMA2_PORT)
+ 
diff --git a/target/linux/mediatek/patches-6.12/999-eth-19-mtk_eth_soc-add-ETH-ports-link-down-flow.patch b/target/linux/mediatek/patches-6.12/999-eth-19-mtk_eth_soc-add-ETH-ports-link-down-flow.patch
new file mode 100644
index 0000000000..6a4e441d78
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-19-mtk_eth_soc-add-ETH-ports-link-down-flow.patch
@@ -0,0 +1,161 @@
+---
+[v1] net: ethernet: mtk_eth_soc: add ETH ports link down for NETSYSv3 SER
+
+Add Ethernet port link down flow for NETSYSv3 SER. This patch handles
+XGMAC and built-in MT7531 switch link down procedures, extending SER
+support for new NETSYSv3 hardware components.
+---
+v1: Add ETH ports link down flow for NETSYSv3 SER.
+---
+
+From b487917477958c0bab6d144cd19c0f3509383b54 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Mon, 22 Sep 2025 11:12:10 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add ETH ports link down flow for
+ NETSYSv3 SER
+
+The NETSYSv3 introduces new hardware, XGMAC, which is used for
+connecting to the external 10G PHY or internal 2.5G PHY.
+Additionally, there is a new hardware component, built-in MT7531,
+which connects to an internal BUS and is not a real MAC. Therefore,
+we need to add both link down flows to the existing NETSYS SER flow.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 73 ++++++++++++++++++++-
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h |  5 ++
+ 2 files changed, 75 insertions(+), 3 deletions(-)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -5279,8 +5279,48 @@ static int mtk_do_ioctl(struct net_devic
+ 	return -EOPNOTSUPP;
+ }
+ 
++static void mt7988_esw_iomap(struct mtk_eth *eth)
++{
++	struct device_node *np;
++	void __iomem *base;
++
++	np = of_find_compatible_node(NULL, NULL, "mediatek,mt7988-switch");
++	if (!np) {
++		/* check the GSW node if the DSA node does not exist */
++		of_find_compatible_node(NULL, NULL, "mediatek,mt7988-gsw-switch");
++	}
++
++	if (np) {
++		base = of_iomap(np, 0);
++		if (IS_ERR(base)) {
++			dev_err(eth->dev, "failed to map esw base address\n");
++			goto out;
++		}
++	}
++
++	eth->esw_base = base;
++out:
++	of_node_put(np);
++}
++
++static void mt7988_esw_force_link(struct mtk_eth *eth, bool link_up)
++{
++	u32 val;
++
++	if (!eth->esw_base)
++		return;
++
++	val = __raw_readl(eth->esw_base + MT753X_PMCR_P(6));
++	if (link_up)
++		val |= PMCR_FORCE_LNK;
++	else
++		val &= ~PMCR_FORCE_LNK;
++	__raw_writel(val, eth->esw_base + MT753X_PMCR_P(6));
++}
++
+ static void mtk_prepare_for_reset(struct mtk_eth *eth)
+ {
++	struct mtk_mac *mac;
+ 	u32 val;
+ 	int i;
+ 
+@@ -5299,9 +5339,23 @@ static void mtk_prepare_for_reset(struct
+ 	mtk_w32(eth, 0, MTK_FE_INT_ENABLE);
+ 
+ 	/* force link down GMAC */
+-	for (i = 0; i < 2; i++) {
+-		val = mtk_r32(eth, MTK_MAC_MCR(i)) & ~MAC_MCR_FORCE_LINK;
+-		mtk_w32(eth, val, MTK_MAC_MCR(i));
++	for (i = 0; i < MTK_MAX_DEVS; i++) {
++		mac = eth->mac[i];
++		if (!mac)
++			continue;
++
++		if (mtk_is_netsys_v3_or_greater(eth) &&
++		    mtk_interface_mode_is_xgmii(mac->interface)) {
++			if (mac->id == MTK_GMAC1_ID)
++				mt7988_esw_force_link(eth, false);
++			else {
++				mtk_m32(eth, XMAC_MCR_TRX_DISABLE, XMAC_MCR_TRX_DISABLE,
++					MTK_XMAC_MCR(mac->id));
++				mtk_m32(eth, MTK_XGMAC_FORCE_LINK(mac->id), 0,
++					MTK_XGMAC_STS(mac->id));
++			}
++		} else
++			mtk_m32(eth, MAC_MCR_FORCE_LINK, 0, MTK_MAC_MCR(i));
+ 	}
+ }
+ 
+@@ -5349,6 +5403,11 @@ static void mtk_pending_work(struct work
+ 				    "Driver up/down cycle failed\n");
+ 			dev_close(eth->netdev[i]);
+ 		}
++
++		if (mtk_is_netsys_v3_or_greater(eth) &&
++		    mtk_interface_mode_is_xgmii(eth->mac[i]->interface) &&
++		    eth->mac[i]->id == MTK_GMAC1_ID)
++			mt7988_esw_force_link(eth, true);
+ 	}
+ 
+ 	clear_bit(MTK_RESETTING, &eth->state);
+@@ -6112,6 +6171,11 @@ static int mtk_add_mac(struct mtk_eth *e
+ 		}
+ 	}
+ 
++	if (mtk_is_netsys_v3_or_greater(mac->hw) &&
++	    MTK_HAS_CAPS(mac->hw->soc->caps, MTK_ESW) &&
++	    id == MTK_GMAC1_ID)
++		mt7988_esw_iomap(eth);
++
+ 	memset(mac->hwlro_ip, 0, sizeof(mac->hwlro_ip));
+ 	mac->hwlro_ip_cnt = 0;
+ 
+@@ -6744,6 +6808,9 @@ static void mtk_remove(struct platform_d
+ 	struct mtk_mac *mac;
+ 	int i;
+ 
++	if (eth->esw_base)
++		iounmap(eth->esw_base);
++
+ 	/* stop all devices to make sure that dma is properly shut down */
+ 	for (i = 0; i < MTK_MAX_DEVS; i++) {
+ 		if (!eth->netdev[i])
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -728,6 +728,10 @@
+ #define MT7628_SDM_MAC_ADRL	(MT7628_SDM_OFFSET + 0x0c)
+ #define MT7628_SDM_MAC_ADRH	(MT7628_SDM_OFFSET + 0x10)
+ 
++/* MT7988 internal switch register */
++#define MT753X_PMCR_P(x)	(0x3000 + ((x) * 0x100))
++#define  PMCR_FORCE_LNK		BIT(0)
++
+ /* Counter / stat register */
+ #define MT7628_SDM_TPCNT	(MT7628_SDM_OFFSET + 0x100)
+ #define MT7628_SDM_TBCNT	(MT7628_SDM_OFFSET + 0x104)
+@@ -1503,6 +1507,7 @@ struct mtk_eth {
+ 	struct device			*dev;
+ 	struct device			*dma_dev;
+ 	void __iomem			*base;
++	void __iomem			*esw_base;
+ 	void				*sram_base;
+ 	spinlock_t			page_lock;
+ 	spinlock_t			tx_irq_lock;
diff --git a/target/linux/mediatek/patches-6.12/999-eth-20-mtk_eth_soc-add-HQoS-configuration-restore.patch b/target/linux/mediatek/patches-6.12/999-eth-20-mtk_eth_soc-add-HQoS-configuration-restore.patch
new file mode 100644
index 0000000000..368f5898dd
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-20-mtk_eth_soc-add-HQoS-configuration-restore.patch
@@ -0,0 +1,144 @@
+---
+[v1] net: ethernet: mtk_eth_soc: add HQoS configuration restore for NETSYS SER
+
+Add HQoS configuration save and restore to NETSYS SER. This patch
+preserves HQoS settings across QDMA resets during NETSYS SER, ensuring
+QoS policies remain effective after recovery.
+---
+v1: Add HQoS configuration restore flow to NETSYS SER
+---
+
+From 7b43b86f22dc7a0cae398faa50c8f724f7c0d6e4 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Mon, 22 Sep 2025 11:12:10 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add HQoS configuration restore
+ flow to SER
+
+Since SER will reset QDMA, it means that the HQoS configurations will
+be cleared. The driver needs to save the HQoS configuration before the
+SER and then restore the HQoS configuration afterward.
+
+Without this patch, the HQoS is not functioning properly following the
+SER.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 50 +++++++++++++++++++++
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h | 19 ++++++++
+ 2 files changed, 69 insertions(+)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -5318,6 +5318,54 @@ static void mt7988_esw_force_link(struct
+ 	__raw_writel(val, eth->esw_base + MT753X_PMCR_P(6));
+ }
+ 
++static void mtk_save_qdma_cfg(struct mtk_eth *eth)
++{
++	const struct mtk_reg_map *reg_map = eth->soc->reg_map;
++	struct mtk_qdma_params *params = &eth->qdma_params;
++	int i;
++
++	for (i = 0; i < MTK_QDMA_NUM_QUEUES; i++) {
++		mtk_w32(eth, (i / MTK_QTX_PER_PAGE), reg_map->qdma.page);
++
++		params->qtx_cfg[i] =
++			mtk_r32(eth, reg_map->qdma.qtx_cfg +
++				(i % MTK_QTX_PER_PAGE) * MTK_QTX_OFFSET);
++		params->qtx_sch[i] =
++			mtk_r32(eth, reg_map->qdma.qtx_sch +
++				(i % MTK_QTX_PER_PAGE) * MTK_QTX_OFFSET);
++	}
++	mtk_w32(eth, 0, reg_map->qdma.page);
++
++	params->tx_sch[0] = mtk_r32(eth, reg_map->qdma.tx_sch_rate);
++	if (mtk_is_netsys_v2_or_greater(eth))
++		params->tx_sch[1] =
++			mtk_r32(eth, reg_map->qdma.tx_sch_rate + 0x4);
++}
++
++static void mtk_restore_qdma_cfg(struct mtk_eth *eth)
++{
++	const struct mtk_reg_map *reg_map = eth->soc->reg_map;
++	struct mtk_qdma_params *params = &eth->qdma_params;
++	int i;
++
++	for (i = 0; i < MTK_QDMA_NUM_QUEUES; i++) {
++		mtk_w32(eth, (i / MTK_QTX_PER_PAGE), reg_map->qdma.page);
++
++		mtk_w32(eth, params->qtx_cfg[i],
++			reg_map->qdma.qtx_cfg +
++			(i % MTK_QTX_PER_PAGE) * MTK_QTX_OFFSET);
++		mtk_w32(eth, params->qtx_sch[i],
++			reg_map->qdma.qtx_sch +
++			(i % MTK_QTX_PER_PAGE) * MTK_QTX_OFFSET);
++	}
++	mtk_w32(eth, 0, reg_map->qdma.page);
++
++	mtk_w32(eth, params->tx_sch[0], reg_map->qdma.tx_sch_rate);
++	if (mtk_is_netsys_v2_or_greater(eth))
++		mtk_w32(eth, params->tx_sch[1],
++			reg_map->qdma.tx_sch_rate + 0x4);
++}
++
+ static void mtk_prepare_for_reset(struct mtk_eth *eth)
+ {
+ 	struct mtk_mac *mac;
+@@ -5370,6 +5418,7 @@ static void mtk_pending_work(struct work
+ 
+ 	mtk_hw_dump_all(eth);
+ 
++	mtk_save_qdma_cfg(eth);
+ 	mtk_prepare_for_reset(eth);
+ 	mtk_wed_fe_reset();
+ 	/* Run again reset preliminary configuration in order to avoid any
+@@ -5413,6 +5462,7 @@ static void mtk_pending_work(struct work
+ 	clear_bit(MTK_RESETTING, &eth->state);
+ 
+ 	mtk_wed_fe_reset_complete();
++	mtk_restore_qdma_cfg(eth);
+ 
+ 	rtnl_unlock();
+ }
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -337,6 +337,9 @@
+ #define MTK_QTX_SCH_MAX_RATE_MAN_V3	GENMASK(9, 3)
+ #define MTK_QTX_SCH_MAX_RATE_EXP_V3	GENMASK(2, 0)
+ 
++/* QDMA Page Configuration Register */
++#define MTK_QTX_PER_PAGE	(16)
++
+ /* QDMA TX Scheduler Rate Control Register */
+ #define MTK_QDMA_TX_SCH_MAX_WFQ		BIT(15)
+ 
+@@ -1126,6 +1129,21 @@ struct mtk_napi {
+ 	struct mtk_rx_ring	*rx_ring;
+ };
+ 
++/* struct mtk_qdma_params -	This is the structure holding parameters
++				for the HQoS
++ * @qtx_cfg:			The elements are used to record the
++				reserved buffer for the Tx Queue
++ * @qtx_sch:			The elements are used to record the
++				rate control for the Tx Queue
++ * @tx_sch:			The elements are used to record the
++				rate control for the Tx Scheduler
++ */
++struct mtk_qdma_params {
++	u32	qtx_cfg[MTK_QDMA_NUM_QUEUES];
++	u32	qtx_sch[MTK_QDMA_NUM_QUEUES];
++	u32	tx_sch[2];
++};
++
+ enum mkt_eth_capabilities {
+ 	MTK_RGMII_BIT = 0,
+ 	MTK_TRGMII_BIT,
+@@ -1533,6 +1551,7 @@ struct mtk_eth {
+ 	struct napi_struct		tx_napi;
+ 	struct mtk_napi			rx_napi[MTK_RX_NAPI_NUM];
+ 	struct mtk_rss_params		rss_params;
++	struct mtk_qdma_params		qdma_params;
+ 	void				*scratch_ring;
+ 	dma_addr_t			phy_scratch_ring;
+ 	void				*scratch_head[MTK_FQ_DMA_HEAD];
diff --git a/target/linux/mediatek/patches-6.12/999-eth-22-mtk_eth_soc-add-mtk_validate_sram_range.patch b/target/linux/mediatek/patches-6.12/999-eth-22-mtk_eth_soc-add-mtk_validate_sram_range.patch
new file mode 100644
index 0000000000..14d8eae543
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-22-mtk_eth_soc-add-mtk_validate_sram_range.patch
@@ -0,0 +1,308 @@
+---
+[v2] net: ethernet: mtk_eth_soc: add mtk_validate_sram_range to MTK_SRAM feature
+
+Add SRAM range validation to prevent allocating non-existent SRAM regions to
+TX/RX/FQ rings. This enables MTK_SRAM feature on platforms with insufficient
+SRAM, improving compatibility across different SoCs.
+---
+v2: Fix the ADMA RX hang issue that occurs during the reboot test.
+v1: Add mtk_validate_sram_range() to the MTK_SRAM feature.
+---
+
+From 7fb965b100f4b5f70ea1ac7e0d05dfb8b0a78931 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Mon, 19 Jan 2026 16:41:44 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add mtk_validate_sram_range to
+ MTK_SRAM feature
+
+To prevent the ETH Driver from allocating a non-existent SRAM region to
+the TX/RX/FQ rings, we have introduced a new function, mtk_validate_sram
+_range(), which verifies whether the SRAM region is available for these
+rings. Consequently, even if certain platforms lack sufficient SRAM to
+allocate for all TX/RX/FQ rings, they can still enable MTK_SRAM feature.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 93 +++++++++++++--------
+ drivers/net/ethernet/mediatek/mtk_eth_soc.h | 24 +++--
+ 2 files changed, 77 insertions(+), 40 deletions(-)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -1412,6 +1412,18 @@ static void *mtk_max_lro_buf_alloc(gfp_t
+ 	return (void *)data;
+ }
+ 
++static bool mtk_validate_sram_range(struct mtk_eth *eth, u64 offset, u64 size)
++{
++	u64 start, end;
++
++	start = (u64)eth->phy_sram_base;
++	end = (u64)eth->phy_sram_base + eth->sram_size - 1;
++	if ((offset >= start) && (offset + size - 1 <= end))
++		return true;
++
++	return false;
++}
++
+ /* the qdma core needs scratch memory to be setup */
+ static int mtk_init_fq_dma(struct mtk_eth *eth)
+ {
+@@ -1421,28 +1433,32 @@ static int mtk_init_fq_dma(struct mtk_et
+ 	dma_addr_t dma_addr;
+ 	int i, j, len;
+ 
+-	if (MTK_HAS_CAPS(eth->soc->caps, MTK_SRAM))
+-		eth->scratch_ring = eth->sram_base;
+-	else
+-		eth->scratch_ring = dma_alloc_coherent(eth->dma_dev,
+-						       TX_DESC_OFS(eth, cnt),
+-						       &eth->phy_scratch_ring,
+-						       GFP_KERNEL);
++	if (MTK_HAS_CAPS(eth->soc->caps, MTK_SRAM) &&
++	    mtk_validate_sram_range(eth, (u64)eth->phy_sram_base,
++				    TX_DESC_OFS(eth, cnt))) {
++		eth->fq_ring.phy_scratch_ring = eth->phy_sram_base;
++		eth->fq_ring.scratch_ring = eth->sram_base;
++		eth->fq_ring.in_sram = true;
++	} else
++		eth->fq_ring.scratch_ring = dma_alloc_coherent(eth->dma_dev,
++							       TX_DESC_OFS(eth, cnt),
++							       &eth->fq_ring.phy_scratch_ring,
++							       GFP_KERNEL);
+ 
+-	if (unlikely(!eth->scratch_ring))
++	if (unlikely(!eth->fq_ring.scratch_ring))
+ 		return -ENOMEM;
+ 
+-	phy_ring_tail = eth->phy_scratch_ring + TX_DESC_OFS(eth, cnt - 1);
++	phy_ring_tail = eth->fq_ring.phy_scratch_ring + TX_DESC_OFS(eth, cnt - 1);
+ 
+ 	for (j = 0; j < DIV_ROUND_UP(soc->tx.fq_dma_size, MTK_FQ_DMA_LENGTH); j++) {
+ 		len = min_t(int, cnt - j * MTK_FQ_DMA_LENGTH, MTK_FQ_DMA_LENGTH);
+-		eth->scratch_head[j] = kcalloc(len, MTK_QDMA_PAGE_SIZE, GFP_KERNEL);
++		eth->fq_ring.scratch_head[j] = kcalloc(len, MTK_QDMA_PAGE_SIZE, GFP_KERNEL);
+ 
+-		if (unlikely(!eth->scratch_head[j]))
++		if (unlikely(!eth->fq_ring.scratch_head[j]))
+ 			return -ENOMEM;
+ 
+ 		dma_addr = dma_map_single(eth->dma_dev,
+-					  eth->scratch_head[j], len * MTK_QDMA_PAGE_SIZE,
++					  eth->fq_ring.scratch_head[j], len * MTK_QDMA_PAGE_SIZE,
+ 					  DMA_FROM_DEVICE);
+ 
+ 		if (unlikely(dma_mapping_error(eth->dma_dev, dma_addr)))
+@@ -1451,10 +1467,10 @@ static int mtk_init_fq_dma(struct mtk_et
+ 		for (i = 0; i < len; i++) {
+ 			struct mtk_tx_dma_v2 *txd;
+ 
+-			txd = eth->scratch_ring + TX_DESC_OFS(eth, j * MTK_FQ_DMA_LENGTH + i);
++			txd = eth->fq_ring.scratch_ring + TX_DESC_OFS(eth, j * MTK_FQ_DMA_LENGTH + i);
+ 			txd->txd1 = dma_addr + i * MTK_QDMA_PAGE_SIZE;
+ 			if (j * MTK_FQ_DMA_LENGTH + i < cnt)
+-				txd->txd2 = eth->phy_scratch_ring +
++				txd->txd2 = eth->fq_ring.phy_scratch_ring +
+ 					    TX_DESC_OFS(eth, j * MTK_FQ_DMA_LENGTH + i + 1);
+ 
+ 			txd->txd3 = TX_DMA_PLEN0(MTK_QDMA_PAGE_SIZE);
+@@ -1471,7 +1487,7 @@ static int mtk_init_fq_dma(struct mtk_et
+ 		}
+ 	}
+ 
+-	mtk_w32(eth, eth->phy_scratch_ring, soc->reg_map->qdma.fq_head);
++	mtk_w32(eth, eth->fq_ring.phy_scratch_ring, soc->reg_map->qdma.fq_head);
+ 	mtk_w32(eth, phy_ring_tail, soc->reg_map->qdma.fq_tail);
+ 	mtk_w32(eth, (cnt << 16) | cnt, soc->reg_map->qdma.fq_count);
+ 	mtk_w32(eth, MTK_QDMA_PAGE_SIZE << 16, soc->reg_map->qdma.fq_blen);
+@@ -2910,9 +2926,12 @@ static int mtk_tx_alloc(struct mtk_eth *
+ 	if (!ring->buf)
+ 		goto no_tx_mem;
+ 
+-	if (MTK_HAS_CAPS(soc->caps, MTK_SRAM)) {
++	if (MTK_HAS_CAPS(soc->caps, MTK_SRAM) &&
++	    mtk_validate_sram_range(eth, (u64)eth->phy_sram_base + soc->tx.fq_dma_size * sz,
++				    ring_size * sz)) {
+ 		ring->dma = eth->sram_base + soc->tx.fq_dma_size * sz;
+-		ring->phys = eth->phy_scratch_ring + soc->tx.fq_dma_size * (dma_addr_t)sz;
++		ring->phys = eth->phy_sram_base + soc->tx.fq_dma_size * sz;
++		ring->in_sram = true;
+ 	} else {
+ 		ring->dma = dma_alloc_coherent(eth->dma_dev, ring_size * sz,
+ 					       &ring->phys, GFP_KERNEL);
+@@ -3012,7 +3031,6 @@ no_tx_mem:
+ 
+ static void mtk_tx_clean(struct mtk_eth *eth)
+ {
+-	const struct mtk_soc_data *soc = eth->soc;
+ 	struct mtk_tx_ring *ring = &eth->tx_ring;
+ 	int i;
+ 
+@@ -3022,7 +3040,7 @@ static void mtk_tx_clean(struct mtk_eth
+ 		kfree(ring->buf);
+ 		ring->buf = NULL;
+ 	}
+-	if (!MTK_HAS_CAPS(soc->caps, MTK_SRAM) && ring->dma) {
++	if (!ring->in_sram && ring->dma) {
+ 		dma_free_coherent(eth->dma_dev,
+ 				  TX_DESC_OFS(eth, ring->dma_size),
+ 				  ring->dma, ring->phys);
+@@ -3041,6 +3059,7 @@ static int mtk_rx_alloc(struct mtk_eth *
+ {
+ 	const struct mtk_reg_map *reg_map = eth->soc->reg_map;
+ 	const struct mtk_soc_data *soc = eth->soc;
++	struct mtk_tx_ring *tx_ring = &eth->tx_ring;
+ 	struct mtk_rx_ring *ring;
+ 	dma_addr_t offset;
+ 	int rx_data_len, rx_dma_size, tx_ring_size;
+@@ -3082,16 +3101,17 @@ static int mtk_rx_alloc(struct mtk_eth *
+ 		ring->page_pool = pp;
+ 	}
+ 
++	offset = TX_DESC_OFS(eth, tx_ring_size) +
++		 RX_DESC_OFS(eth, eth->soc->rx.dma_size * ring_no);
++
+ 	if (!MTK_HAS_CAPS(eth->soc->caps, MTK_SRAM) ||
+-	    rx_flag != MTK_RX_FLAGS_NORMAL) {
++	    rx_flag != MTK_RX_FLAGS_NORMAL ||
++	    !mtk_validate_sram_range(eth, (u64)tx_ring->phys + offset,
++				     RX_DESC_OFS(eth, rx_dma_size))) {
+ 		ring->dma = dma_alloc_coherent(eth->dma_dev,
+ 				RX_DESC_OFS(eth, rx_dma_size),
+ 				&ring->phys, GFP_KERNEL);
+ 	} else {
+-		struct mtk_tx_ring *tx_ring = &eth->tx_ring;
+-
+-		offset = TX_DESC_OFS(eth, tx_ring_size) +
+-			 RX_DESC_OFS(eth, eth->soc->rx.dma_size * ring_no);
+ 		ring->dma = tx_ring->dma + offset;
+ 		ring->phys = tx_ring->phys + offset;
+ 		ring->in_sram = true;
+@@ -3937,15 +3957,15 @@ static void mtk_dma_free(struct mtk_eth
+ 			netdev_tx_reset_subqueue(eth->netdev[i], j);
+ 	}
+ 
+-	if (!MTK_HAS_CAPS(soc->caps, MTK_SRAM) && eth->scratch_ring) {
++	if (!eth->fq_ring.in_sram && eth->fq_ring.scratch_ring) {
+ 		dma_free_coherent(eth->dma_dev,
+ 				  TX_DESC_OFS(eth, soc->tx.fq_dma_size),
+-				  eth->scratch_ring, eth->phy_scratch_ring);
+-		eth->scratch_ring = NULL;
+-		eth->phy_scratch_ring = 0;
++				  eth->fq_ring.scratch_ring, eth->fq_ring.phy_scratch_ring);
++		eth->fq_ring.scratch_ring = NULL;
++		eth->fq_ring.phy_scratch_ring = 0;
+ 	}
+ 	mtk_tx_clean(eth);
+-	mtk_rx_clean(eth, &eth->rx_ring[0], MTK_HAS_CAPS(soc->caps, MTK_SRAM));
++	mtk_rx_clean(eth, &eth->rx_ring[0], eth->rx_ring[0].in_sram);
+ 	mtk_rx_clean(eth, &eth->rx_ring_qdma, false);
+ 
+ 	if (eth->hwlro) {
+@@ -3962,8 +3982,8 @@ static void mtk_dma_free(struct mtk_eth
+ 	}
+ 
+ 	for (i = 0; i < DIV_ROUND_UP(soc->tx.fq_dma_size, MTK_FQ_DMA_LENGTH); i++) {
+-		kfree(eth->scratch_head[i]);
+-		eth->scratch_head[i] = NULL;
++		kfree(eth->fq_ring.scratch_head[i]);
++		eth->fq_ring.scratch_head[i] = NULL;
+ 	}
+ }
+ 
+@@ -6485,11 +6505,18 @@ static int mtk_probe(struct platform_dev
+ 		 * functions to read from or write to SRAM.
+ 		 */
+ 		if (mtk_is_netsys_v3_or_greater(eth)) {
++			const struct resource *res;
++
+ 			eth->sram_base = (void __force *)devm_platform_ioremap_resource(pdev, 1);
+ 			if (IS_ERR(eth->sram_base))
+ 				return PTR_ERR(eth->sram_base);
++
++			res = platform_get_resource(pdev, IORESOURCE_MEM, 1);
++			if (res)
++				eth->sram_size = resource_size(res);
+ 		} else {
+ 			eth->sram_base = (void __force *)eth->base + MTK_ETH_SRAM_OFFSET;
++			eth->sram_size = SZ_256K;
+ 		}
+ 	}
+ 
+@@ -6576,9 +6603,9 @@ static int mtk_probe(struct platform_dev
+ 					err = -EINVAL;
+ 					goto err_destroy_sgmii;
+ 				}
+-				eth->phy_scratch_ring = res_sram->start;
++				eth->phy_sram_base = res_sram->start;
+ 			} else {
+-				eth->phy_scratch_ring = res->start + MTK_ETH_SRAM_OFFSET;
++				eth->phy_sram_base = res->start + MTK_ETH_SRAM_OFFSET;
+ 			}
+ 		}
+ 	}
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+@@ -1106,6 +1106,19 @@ struct mtk_rx_ring {
+ 	struct xdp_rxq_info xdp_q;
+ };
+ 
++/* struct mtk_fq_ring -	This struct holds info describing a FQ ring
++ * @scratch_ring:	Newer SoCs need memory for a second HW managed TX ring
++ * @phy_scratch_ring:	physical address of scratch_ring
++ * @scratch_head:	The scratch memory that scratch_ring points to.
++ * @in_sram:		The scratch ring in the SRAM
++ */
++struct mtk_fq_ring {
++	dma_addr_t	phy_scratch_ring;
++	void		*scratch_ring;
++	void		*scratch_head[MTK_FQ_DMA_HEAD];
++	bool		in_sram;
++};
++
+ /* struct mtk_rss_params -	This is the structure holding parameters
+ 				for the RSS ring
+  * @hash_key			The element is used to record the
+@@ -1333,7 +1346,7 @@ enum mkt_eth_capabilities {
+ #define MT7987_CAPS  (MTK_36BIT_DMA | MTK_GMAC1_SGMII | \
+ 		      MTK_GMAC2_2P5GPHY_V2 | MTK_GMAC2_SGMII | MTK_GMAC3_SGMII | \
+ 		      MTK_MUX_GMAC123_TO_GEPHY_SGMII | MTK_MUX_GMAC2_TO_2P5GPHY | \
+-		      MTK_MUX_U3_GMAC23_TO_QPHY | MTK_U3_COPHY_V2 | \
++		      MTK_MUX_U3_GMAC23_TO_QPHY | MTK_U3_COPHY_V2 | MTK_SRAM | \
+ 		      MTK_QDMA | MTK_PDMA_INT | MTK_RSS | MTK_HWLRO | \
+ 		      MTK_GLO_MEM_ACCESS | MTK_RSTCTRL_PPE1)
+ 
+@@ -1511,9 +1524,6 @@ struct mtk_soc_data {
+  * @tx_packets:		Net DIM TX packet counter
+  * @tx_bytes:		Net DIM TX byte counter
+  * @tx_dim:		Net DIM TX context
+- * @scratch_ring:	Newer SoCs need memory for a second HW managed TX ring
+- * @phy_scratch_ring:	physical address of scratch_ring
+- * @scratch_head:	The scratch memory that scratch_ring points to.
+  * @clks:		clock array for all clocks required
+  * @mii_bus:		If there is a bus we need to create an instance for it
+  * @pending_work:	The workqueue used to reset the dma ring
+@@ -1527,6 +1537,8 @@ struct mtk_eth {
+ 	void __iomem			*base;
+ 	void __iomem			*esw_base;
+ 	void				*sram_base;
++	u64				sram_size;
++	dma_addr_t			phy_sram_base;
+ 	spinlock_t			page_lock;
+ 	spinlock_t			tx_irq_lock;
+ 	spinlock_t			rx_irq_lock;
+@@ -1548,13 +1560,11 @@ struct mtk_eth {
+ 	struct mtk_tx_ring		tx_ring;
+ 	struct mtk_rx_ring		rx_ring[MTK_MAX_RX_RING_NUM];
+ 	struct mtk_rx_ring		rx_ring_qdma;
++	struct mtk_fq_ring		fq_ring;
+ 	struct napi_struct		tx_napi;
+ 	struct mtk_napi			rx_napi[MTK_RX_NAPI_NUM];
+ 	struct mtk_rss_params		rss_params;
+ 	struct mtk_qdma_params		qdma_params;
+-	void				*scratch_ring;
+-	dma_addr_t			phy_scratch_ring;
+-	void				*scratch_head[MTK_FQ_DMA_HEAD];
+ 	struct clk			*clks[MTK_CLK_MAX];
+ 
+ 	struct mii_bus			*mii_bus;
diff --git a/target/linux/mediatek/patches-6.12/999-eth-23-mtk_eth_soc-add-non-DSA-devices-handling.patch b/target/linux/mediatek/patches-6.12/999-eth-23-mtk_eth_soc-add-non-DSA-devices-handling.patch
new file mode 100644
index 0000000000..3c9bf66cc5
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-23-mtk_eth_soc-add-non-DSA-devices-handling.patch
@@ -0,0 +1,77 @@
+---
+[v1] net: ethernet: mtk_eth_soc: add non-DSA devices handling to mtk_device_event
+
+Add support for handling non-DSA devices in NETDEV_CHANGE events. This enables
+QDMA maximum rate limit configuration for non-DSA devices, extending QoS
+functionality beyond DSA switch environments.
+---
+v1: Add non-DSA devices handling to mtk_device_event.
+---
+
+From a0858742cbdb6b1774ebd67a2a7713d9d39001d0 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Mon, 22 Sep 2025 11:12:12 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add non-DSA devices handling to
+ mtk_device_event
+
+Without this patch, ETH is unable to set the QDMA maximum rate limit
+for non-DSA devices.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 25 ++++++++++++---------
+ 1 file changed, 15 insertions(+), 10 deletions(-)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -4170,35 +4170,40 @@ static int mtk_device_event(struct notif
+ 	struct net_device *ldev;
+ 	struct list_head *iter;
+ 	struct dsa_port *dp;
++	unsigned int queue;
+ 
+-	if (event != NETDEV_CHANGE)
++	if (event != NETDEV_CHANGE || dev->priv_flags & IFF_EBRIDGE)
+ 		return NOTIFY_DONE;
+ 
++	/* handle DSA switch devices event */
+ 	netdev_for_each_lower_dev(dev, ldev, iter) {
+ 		if (netdev_priv(ldev) == mac)
+ 			goto found;
+ 	}
+ 
++	/* handle non-DSA switch devices event */
++	if (netdev_priv(dev) == mac)
++		goto found;
++
+ 	return NOTIFY_DONE;
+ 
+ found:
+-	if (!dsa_user_dev_check(dev))
+-		return NOTIFY_DONE;
+-
+ 	if (__ethtool_get_link_ksettings(dev, &s))
+ 		return NOTIFY_DONE;
+ 
+ 	if (s.base.speed == 0 || s.base.speed == ((__u32)-1))
+ 		return NOTIFY_DONE;
+ 
+-	dp = dsa_port_from_netdev(dev);
+-	if (dp->index >= MTK_QDMA_NUM_QUEUES)
+-		return NOTIFY_DONE;
++	if (dsa_user_dev_check(dev)) {
++		dp = dsa_port_from_netdev(dev);
++		queue = dp->index + 3;
++	} else
++		queue = mac->id;
+ 
+-	if (mac->speed > 0 && mac->speed <= s.base.speed)
+-		s.base.speed = 0;
++	if (queue >= MTK_QDMA_NUM_QUEUES)
++		return NOTIFY_DONE;
+ 
+-	mtk_set_queue_speed(eth, dp->index + 3, s.base.speed);
++	mtk_set_queue_speed(eth, queue, s.base.speed);
+ 
+ 	return NOTIFY_DONE;
+ }
diff --git a/target/linux/mediatek/patches-6.12/999-eth-24-mtk_eth_soc-add-2500Mbps-maximum-rate-limit-for-NETSYSv3.patch b/target/linux/mediatek/patches-6.12/999-eth-24-mtk_eth_soc-add-2500Mbps-maximum-rate-limit-for-NETSYSv3.patch
new file mode 100644
index 0000000000..66fea02316
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-eth-24-mtk_eth_soc-add-2500Mbps-maximum-rate-limit-for-NETSYSv3.patch
@@ -0,0 +1,62 @@
+---
+[v1] net: ethernet: mtk_eth_soc: add 2500Mbps maximum rate limit for NETSYSv3
+
+Add 2.5Gbps rate limiting support for QDMA TX queues on NETSYSv3. This extends
+QoS capabilities to handle 2.5G Ethernet speeds, providing finer-grained traffic
+shaping for modern high-speed network interfaces.
+---
+v1: Add 2500Mbps maximum rate limit for NETSYSv3.
+---
+
+From d0ad66aacb633664a767aa6d5e45e9e3f6278920 Mon Sep 17 00:00:00 2001
+From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+Date: Mon, 22 Sep 2025 11:12:13 +0800
+Subject: [PATCH] net: ethernet: mtk_eth_soc: add 2500Mbps maximum rate limt
+ for NETSYSv3
+
+Without this patch, the ETH driver is unable to set QDMA maximum rate
+limit to 2500 Mbps for the specific TX queue.
+
+Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
+---
+ drivers/net/ethernet/mediatek/mtk_eth_soc.c | 15 +++++++++++++++
+ 1 file changed, 15 insertions(+)
+
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -866,6 +866,9 @@ static void mtk_set_queue_speed(struct m
+ 	if (mtk_is_netsys_v1(eth))
+ 		val |= MTK_QTX_SCH_LEAKY_BUCKET_EN;
+ 
++	if (!mtk_is_netsys_v3_or_greater(eth) && speed > SPEED_1000)
++		goto out;
++
+ 	if (IS_ENABLED(CONFIG_SOC_MT7621)) {
+ 		switch (speed) {
+ 		case SPEED_10:
+@@ -910,6 +913,12 @@ static void mtk_set_queue_speed(struct m
+ 			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_EXP_V3, 6) |
+ 			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_WEIGHT_V3, 10);
+ 			break;
++		case SPEED_2500:
++			val |= MTK_QTX_SCH_MAX_RATE_EN_V3 |
++			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_MAN_V3, 25) |
++			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_EXP_V3, 5) |
++			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_WEIGHT_V3, 25);
++			break;
+ 		default:
+ 			break;
+ 		}
+@@ -933,6 +942,12 @@ static void mtk_set_queue_speed(struct m
+ 			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_EXP, 6) |
+ 			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_WEIGHT, 10);
+ 			break;
++		case SPEED_2500:
++			val |= MTK_QTX_SCH_MAX_RATE_EN |
++			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_MAN, 25) |
++			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_EXP, 5) |
++			       FIELD_PREP(MTK_QTX_SCH_MAX_RATE_WEIGHT, 10);
++			break;
+ 		default:
+ 			break;
+ 		}
diff --git a/target/linux/mediatek/patches-6.12/999-eth-25-mtk_eth_soc-record-both-GMAC-and-XGMAC.patch b/target/linux/mediatek/patches-6.12/999-eth-25-mtk_eth_soc-record-both-GMAC-and-XGMAC.patch
