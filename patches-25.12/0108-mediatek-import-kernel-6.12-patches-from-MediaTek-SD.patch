++int mt753x_nl_init(void)
++{
++	int ret;
++
++	ret = genl_register_family(&mt753x_nl_family);
++	if (ret) {
++		pr_info("mt753x-nl: genl_register_family_with_ops failed\n");
++		return ret;
++	}
++
++	return 0;
++}
++
++void mt753x_nl_exit(void)
++{
++	genl_unregister_family(&mt753x_nl_family);
++}
