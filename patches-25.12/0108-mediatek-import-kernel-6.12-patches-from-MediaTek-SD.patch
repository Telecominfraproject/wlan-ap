++
++/dts-v1/;
++/plugin/;
++
++/ {
++	fragment@0 {
++		target = <&gmac0>;
++		__overlay__ {
++			phy-mode = "2500base-x";
++			phy-handle = <&phy12>;
++			status = "okay";
++		};
++	};
++
++	fragment@1 {
++		target-path = "/soc_netsys/ethernet@15100000/mdio-bus";
++		__overlay__ {
++			phy12: phy@12 {
++				compatible = "ethernet-phy-idc0ff.04a0";
++				reg = <12>;
++				reset-gpios = <&pio 48 1>;
++				reset-assert-us = <10000>;
++				reset-deassert-us = <10000>;
++				phy-mode = "2500base-x";
