diff --git a/target/linux/mediatek/patches-6.12/999-pcs-05-mtk-lynxi-correct-power-down-setting.patch b/target/linux/mediatek/patches-6.12/999-pcs-05-mtk-lynxi-correct-power-down-setting.patch
