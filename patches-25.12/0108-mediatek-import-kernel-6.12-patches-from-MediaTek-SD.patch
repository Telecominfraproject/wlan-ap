++ * Author: Min Yao <min.yao@airoha.com>
++ */
++
++#ifndef _AN8855_NL_H_
++#define _AN8855_NL_H_
++
++#define AN8855_DSA_GENL_NAME "an8855_dsa"
++#define AN8855_GENL_VERSION		0x1
++
++enum an8855_cmd {
++	AN8855_CMD_UNSPEC = 0,
++	AN8855_CMD_REQUEST,
++	AN8855_CMD_REPLY,
++	AN8855_CMD_READ,
++	AN8855_CMD_WRITE,
++
++	__AN8855_CMD_MAX,
++};
++
++enum an8855_attr {
