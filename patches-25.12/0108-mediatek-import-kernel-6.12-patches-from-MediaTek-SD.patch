++#endif
++
++	an8855_proc_device_exit();
++
++	an8855_gsw_nl_exit();
++
++	an8855_remove_gsw(gsw);
++
++	platform_set_drvdata(pdev, NULL);
++
++#if (KERNEL_VERSION(6, 11, 0) > LINUX_VERSION_CODE)
++	return 0;
++#endif
++}
