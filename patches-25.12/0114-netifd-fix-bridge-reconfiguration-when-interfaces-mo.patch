From 40c12ed709fa842c97c63fade9da707a56cc4ad0 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Wed, 10 Jun 2026 07:29:56 +0200
Subject: [PATCH 114/115] netifd: fix bridge reconfiguration when interfaces
 move between bridges

Bridges were not properly reconfigured when interfaces, in particular
wifi interfaces, migrated from one bridge to another. Three issues
contributed:

- bridge_remove_member() tested bst->dev.active instead of the
  bridge_state's own bst->active flag, so members were not detached
  during teardown.
- bridge_free() freed the bridge_state without deleting the kernel
  bridge, leaving a stale br-* device behind.
- system_bridge_addif() only handled the case where an interface was
  already enslaved in the target bridge; if it was still enslaved in a
  different, stale bridge the SIOCBRADDIF failed with EBUSY. Detach
  from the old bridge first.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../netifd/patches/300-bridge-cleanup.patch   | 39 +++++++++++++++++++
 1 file changed, 39 insertions(+)
 create mode 100644 package/network/config/netifd/patches/300-bridge-cleanup.patch

diff --git a/package/network/config/netifd/patches/300-bridge-cleanup.patch b/package/network/config/netifd/patches/300-bridge-cleanup.patch
new file mode 100644
index 0000000000..5ca533021d
--- /dev/null
+++ b/package/network/config/netifd/patches/300-bridge-cleanup.patch
@@ -0,0 +1,39 @@
+--- a/bridge.c
++++ b/bridge.c
+@@ -662,7 +662,7 @@ bridge_remove_member(struct bridge_membe
+ 	if (!bm->present)
+ 		return;
+ 
+-	if (bst->dev.active)
++	if (bst->active)
+ 		bridge_disable_member(bm, false);
+ 
+ 	bm->present = false;
+@@ -1042,6 +1042,9 @@ bridge_free(struct device *dev)
+ 	bst = container_of(dev, struct bridge_state, dev);
+ 	vlist_flush_all(&bst->members);
+ 	vlist_flush_all(&dev->vlans);
++
++	system_bridge_delbr(dev);
++
+ 	kvlist_free(&dev->vlan_aliases);
+ 	free(bst->config_data);
+ 	free(bst);
+--- a/system-linux.c
++++ b/system-linux.c
+@@ -968,8 +968,13 @@ int system_bridge_addif(struct device *b
+ 	for (tries = 0; tries < 3; tries++) {
+ 		ret = 0;
+ 		oldbr = system_get_bridge(dev->ifname, dev_buf, sizeof(dev_buf));
+-		if (oldbr && !strcmp(oldbr, bridge->ifname))
+-			break;
++		if (oldbr) {
++			if (!strcmp(oldbr, bridge->ifname))
++				break;
++
++			/* still enslaved in a stale bridge; detach first to avoid EBUSY */
++			system_bridge_if(oldbr, dev, SIOCBRDELIF, NULL);
++		}
+ 
+ 		ret = system_bridge_if(bridge->ifname, dev, SIOCBRADDIF, NULL);
+ 		if (!ret)
-- 
