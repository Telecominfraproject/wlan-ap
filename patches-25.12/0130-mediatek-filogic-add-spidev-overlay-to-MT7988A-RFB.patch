From 90d5184c72cd52bbb4533618307bafe5e637c5cb Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:47:34 +0200
Subject: [PATCH 130/149] mediatek: filogic: add spidev overlay to MT7988A-RFB

Add the mt7988a-rfb-spidev DT overlay to DEVICE_DTS_OVERLAY so the
MT7988A-RFB image gains a spidev interface for board bring-up
debugging.

Import of patches-base/1120-01 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 49a3d41485..56dfdf06ed 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2126,7 +2126,8 @@ define Device/mediatek_mt7988a-rfb
 	mt7988a-rfb-eth1-sfp \
 	mt7988a-rfb-eth2-aqr \
 	mt7988a-rfb-eth2-mxl \
-	mt7988a-rfb-eth2-sfp
+	mt7988a-rfb-eth2-sfp \
+	mt7988a-rfb-spidev
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x45f00000
-- 
2.34.1

