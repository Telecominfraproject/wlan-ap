From df1952c01170468e39839a2db4a652045e2d3747 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 2 Feb 2026 09:25:48 +0100
Subject: [PATCH 93/93] wifi-scripts: default to shell-based scripts

Set WIFI_SCRIPTS_UCODE default to n, selecting the shell-based
hostapd/wpa_supplicant scripts instead of the ucode variant.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/network/config/wifi-scripts/Config.in | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/package/network/config/wifi-scripts/Config.in b/package/network/config/wifi-scripts/Config.in
index e77d790a0a..92e6612464 100644
--- a/package/network/config/wifi-scripts/Config.in
+++ b/package/network/config/wifi-scripts/Config.in
@@ -1,3 +1,3 @@
 config WIFI_SCRIPTS_UCODE
 	bool "Use new ucode based scripts"
-	default y
+	default n
-- 
2.34.1

