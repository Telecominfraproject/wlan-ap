From 4bf35e3b86e8bbcddc55ff8390d5305376b1c68c Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 2 Feb 2026 09:20:48 +0100
Subject: [PATCH 91/93] wifi-scripts: hostapd: ensure PSK file exists after
 cleanup

Touch the PSK file immediately after removing it to guarantee the file
exists even when no stations match the auth type filter. Prevents
hostapd from failing on a missing wpa_psk_file reference.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh | 1 +
 1 file changed, 1 insertion(+)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
index 23b26fc40d..0b55767f2d 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
@@ -502,6 +502,7 @@ hostapd_set_psk() {
 	local ifname="$1"
 
 	rm -f /var/run/hostapd-${ifname}.psk
+	touch /var/run/hostapd-${ifname}.psk
 	case "$auth_type" in
 		psk|psk-sae) ;;
 		*) return ;;
-- 
