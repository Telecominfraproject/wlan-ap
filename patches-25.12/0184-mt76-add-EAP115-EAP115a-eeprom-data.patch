Subject: [PATCH] mt76: use eeprom data for Edgecore EAP115/EAP115a

---
 .../mediatek/dts/mt7987a-edgecore-eap115.dtsi    |   3 +--
 1 files changed, 1 insertions(+), 2 deletions(-)

diff --git a/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi b/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi
index ff62b695a5..d0a4a5b5bb 100644
--- a/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi
+++ b/target/linux/mediatek/dts/mt7987a-edgecore-eap115.dtsi
@@ -120,8 +120,7 @@
 			compatible = "mediatek,mt76";
 			reg = <0x0000 0 0 0 0>;
 
-			nvmem-cells = <&eeprom_factory>;
-			nvmem-cell-names = "eeprom";
+			bin_file_name = "mediatek/mt7996/edgecore_eap115_eeprom.bin";
 		};
 	};
 };
