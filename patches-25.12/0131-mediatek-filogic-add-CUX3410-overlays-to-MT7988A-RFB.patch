From 1f6a14179d6609436128c6d3dce440331bb19b44 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:47:34 +0200
Subject: [PATCH 131/149] mediatek: filogic: add CUX3410 overlays to
 MT7988A-RFB

Add the mt7988a-rfb-eth1-cux3410 and mt7988a-rfb-eth2-cux3410 DT
overlays to DEVICE_DTS_OVERLAY so the MT7988A-RFB image supports
configurations with the CUX3410 switch on eth1 and eth2.

Import of patches-base/1120-02 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 56dfdf06ed..4ea4a5e167 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2121,10 +2121,12 @@ define Device/mediatek_mt7988a-rfb
 	mt7988a-rfb-spim-nand-nmbm \
 	mt7988a-rfb-spim-nor \
 	mt7988a-rfb-eth1-aqr \
+	mt7988a-rfb-eth1-cux3410 \
 	mt7988a-rfb-eth1-i2p5g-phy \
 	mt7988a-rfb-eth1-mxl \
 	mt7988a-rfb-eth1-sfp \
 	mt7988a-rfb-eth2-aqr \
+	mt7988a-rfb-eth2-cux3410 \
 	mt7988a-rfb-eth2-mxl \
 	mt7988a-rfb-eth2-sfp \
 	mt7988a-rfb-spidev
-- 
2.34.1

