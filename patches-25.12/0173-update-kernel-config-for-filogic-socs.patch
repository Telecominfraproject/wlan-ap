Subject: [PATCH v1] 0173-update-kernel-config-for-filogic-socs

---
 target/linux/mediatek/filogic/config-6.12 | 11 ++++++++---
 1 file changed, 8 insertions(+), 3 deletions(-)

diff --git a/target/linux/mediatek/filogic/config-6.12 b/target/linux/mediatek/filogic/config-6.12
index 36407a31e0..a27625b045 100644
--- a/target/linux/mediatek/filogic/config-6.12
+++ b/target/linux/mediatek/filogic/config-6.12
@@ -224,7 +224,6 @@ CONFIG_HAS_IOPORT=y
 CONFIG_HAS_IOPORT_MAP=y
 CONFIG_HWMON=y
 CONFIG_HW_RANDOM=y
-CONFIG_HW_RANDOM_MTK=y
 CONFIG_HW_RANDOM_MTK_V2=y
 CONFIG_I2C=y
 CONFIG_I2C_BOARDINFO=y
@@ -316,6 +315,9 @@ CONFIG_MTK_TIMER=y
 CONFIG_MUTEX_SPIN_ON_OWNER=y
 CONFIG_NEED_DMA_MAP_STATE=y
 CONFIG_NEED_SG_DMA_LENGTH=y
+CONFIG_NETFILTER=y
+CONFIG_NETFILTER_BPF_LINK=y
+CONFIG_NETFILTER_INGRESS=y
 # CONFIG_NET_AIROHA is not set
 CONFIG_NET_DEVLINK=y
 CONFIG_NET_DSA=y
@@ -336,7 +338,10 @@ CONFIG_NET_SELFTESTS=y
 CONFIG_NET_VENDOR_MEDIATEK=y
 CONFIG_NET_XGRESS=y
 CONFIG_NF_CONNTRACK=y
