From 4909ef562d3fbdc59da72a57cd60ff0d39807dca Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:51:35 +0200
Subject: [PATCH 136/149] mediatek: filogic: add AN8831X overlays to
 MT7988A-RFB

Add mt7988a-rfb-eth1-an8831x and mt7988a-rfb-eth2-an8831x DT
overlays so the MT7988A-RFB image supports the Airoha AN8831X
phy on eth1 and eth2.

Import of patches-base/1140-02 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index a6908fdf36..60e5ee1677 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2085,11 +2085,13 @@ define Device/mediatek_mt7988a-rfb
 	mt7988a-rfb-spim-nor \
 	mt7988a-rfb-eth0-gsw \
 	mt7988a-rfb-eth1-aqr \
+	mt7988a-rfb-eth1-an8831x \
 	mt7988a-rfb-eth1-cux3410 \
 	mt7988a-rfb-eth1-i2p5g-phy \
 	mt7988a-rfb-eth1-mxl \
 	mt7988a-rfb-eth1-sfp \
 	mt7988a-rfb-eth2-aqr \
+	mt7988a-rfb-eth2-an8831x \
 	mt7988a-rfb-eth2-cux3410 \
 	mt7988a-rfb-eth2-mxl \
 	mt7988a-rfb-eth2-sfp \
-- 
2.34.1

