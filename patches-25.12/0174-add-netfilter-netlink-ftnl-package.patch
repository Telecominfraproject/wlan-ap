From c556472386cb76dcb98f7a5e93a65042a646d10b Thu May 21 15:09:16 2026
From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
Date: Thu, 21 May 2026 15:09:16 +0800
Subject: [PATCH v1] Add Netfilter Netlink Ftnl package

Add Netfilter Netlink Ftnl package.
  - Delete specific PPE entry:
    ftnl -D --sip=192.168.1.3 --dip=10.10.10.3 --proto=tcp --sport=1234
    --dport=5678
  - Flush all PPE entries:
    ftnl -F

Without this patch, users are unable to delete or flush flow rule and
PPE entries via the FTNL application.

--- a/package/kernel/linux/modules/netfilter.mk
+++ b/package/kernel/linux/modules/netfilter.mk
@@ -158,6 +158,18 @@ endef
 
 $(eval $(call KernelPackage,nf-log))
 
+define KernelPackage/nf-flow-netlink
+  SUBMENU:=$(NF_MENU)
+  TITLE:=Netfilter flowtable netlink support
+  KCONFIG:= \
+	CONFIG_NF_FLOW_TABLE_NETLINK
+  DEPENDS:=+kmod-nf-flow +kmod-nfnetlink
+  FILES:= \
+	$(LINUX_DIR)/net/netfilter/nf_flow_table_netlink.ko
+  AUTOLOAD:=$(call AutoProbe,nf_flow_table_netlink)
+endef
+
+$(eval $(call KernelPackage,nf-flow-netlink))
 
 define KernelPackage/nf-log6
   SUBMENU:=$(NF_MENU)
