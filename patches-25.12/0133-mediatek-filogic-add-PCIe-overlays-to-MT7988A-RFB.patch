From 001712305ca4f19b164d5d5d1d2c729b38410b8e Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:47:47 +0200
Subject: [PATCH 133/149] mediatek: filogic: add PCIe overlays to MT7988A-RFB

Add the mt7988a-rfb PCIe-related DT overlays to DEVICE_DTS_OVERLAY
so the MT7988A-RFB image supports the PCIe board variants.

Import of patches-base/1120-05 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index ecc3bef63e..358a58722f 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2130,7 +2130,10 @@ define Device/mediatek_mt7988a-rfb
 	mt7988a-rfb-eth2-cux3410 \
 	mt7988a-rfb-eth2-mxl \
 	mt7988a-rfb-eth2-sfp \
-	mt7988a-rfb-spidev
+	mt7988a-rfb-spidev \
+	mt7988a-rfb-4pcie \
+	mt7988a-rfb-2pcie \
+	mt7988d-rfb-2pcie
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x45f00000
-- 
2.34.1

