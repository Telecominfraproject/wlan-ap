From 0ed4145f0dfdb136b863dc013557a18d85671795 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 18:42:01 +0100
Subject: [PATCH 76/93] hostapd: add EWMA smoothed management frame signal tracking

Port TIP 999-ssi_signal.patch: adds EWMA-smoothed management frame
signal tracking per BSS and per STA, tracking ssi_signal on action
frames and all management frames.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../hostapd/patches/zzz-0016-ssi-signal.patch | 80 +++++++++++++++++++
 1 file changed, 80 insertions(+)
 create mode 100644 package/network/services/hostapd/patches/zzz-0016-ssi-signal.patch

diff --git a/package/network/services/hostapd/patches/zzz-0016-ssi-signal.patch b/package/network/services/hostapd/patches/zzz-0016-ssi-signal.patch
new file mode 100644
index 0000000000..455eb83fdb
--- /dev/null
+++ b/package/network/services/hostapd/patches/zzz-0016-ssi-signal.patch
@@ -0,0 +1,80 @@
+#
+# TIP patch: 999-ssi_signal.patch
+# Adds EWMA-smoothed management frame signal tracking per BSS and per STA.
+# Tracks ssi_signal on action frames and all management frames.
+#
+--- a/src/ap/ieee802_11.c
++++ b/src/ap/ieee802_11.c
+@@ -64,6 +64,17 @@
+ #	include "apup.h"
+ #endif // def CONFIG_APUP
+ 
++static int
++ewma(int new, int old)
++{
++	#define ALPHA	10
++	if (!old)
++		return new;
++	if (new >= 0)
++		return old;
++	return ((ALPHA * new) + ((100 - ALPHA) * old)) / 100;
++}
++
+ #ifdef CONFIG_FILS
+ static struct wpabuf *
+ prepare_auth_resp_fils(struct hostapd_data *hapd,
+@@ -6487,7 +6498,7 @@ static int robust_action_frame(u8 catego
+ 
+ static int handle_action(struct hostapd_data *hapd,
+ 			 const struct ieee80211_mgmt *mgmt, size_t len,
+-			 unsigned int freq)
++			 unsigned int freq, int ssi_signal)
+ {
+ 	struct sta_info *sta;
+ 	u8 *action __maybe_unused;
+@@ -6544,6 +6555,7 @@ static int handle_action(struct hostapd_
+ 
+ 		sta->last_seq_ctrl = seq_ctrl;
+ 		sta->last_subtype = WLAN_FC_STYPE_ACTION;
++		sta->signal_mgmt = ewma(ssi_signal, sta->signal_mgmt);;
+ 	}
+ 
+ 	switch (mgmt->u.action.category) {
+@@ -6734,6 +6746,8 @@ int ieee802_11_mgmt(struct hostapd_data
+ 		{ 0x51, 0x6f, 0x9a, 0x02, 0x00, 0x00 };
+ #endif /* CONFIG_NAN_USD */
+ 
++	hapd->signal_mgmt = ewma(ssi_signal, hapd->signal_mgmt);;
++
+ 	if (len < 24)
+ 		return 0;
+ 
+@@ -6849,7 +6863,7 @@ int ieee802_11_mgmt(struct hostapd_data
+ 		break;
+ 	case WLAN_FC_STYPE_ACTION:
+ 		wpa_printf(MSG_DEBUG, "mgmt::action");
+-		ret = handle_action(hapd, mgmt, len, freq);
++		ret = handle_action(hapd, mgmt, len, freq, ssi_signal);
+ 		break;
+ 	default:
+ 		hostapd_logger(hapd, mgmt->sa, HOSTAPD_MODULE_IEEE80211,
+--- a/src/ap/sta_info.h
++++ b/src/ap/sta_info.h
+@@ -314,6 +314,7 @@ struct sta_info {
+ #ifdef CONFIG_PASN
+ 	struct pasn_data *pasn;
+ #endif /* CONFIG_PASN */
++	int signal_mgmt;
+ 
+ #ifdef CONFIG_IEEE80211BE
+ 	struct mld_info mld_info;
+--- a/src/ap/hostapd.h
++++ b/src/ap/hostapd.h
+@@ -513,6 +513,7 @@ struct hostapd_data {
+ #ifdef CONFIG_CTRL_IFACE_UDP
+        unsigned char ctrl_iface_cookie[CTRL_IFACE_COOKIE_LEN];
+ #endif /* CONFIG_CTRL_IFACE_UDP */
++       int signal_mgmt;
+ 
+ #ifdef CONFIG_IEEE80211BE
+ 	u8 eht_mld_bss_param_change;
-- 
2.34.1

