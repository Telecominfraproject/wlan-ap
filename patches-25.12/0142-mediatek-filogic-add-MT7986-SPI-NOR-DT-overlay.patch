From 832f05c982a5c733f2952be94f654707e3ead7d7 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:52:35 +0200
Subject: [PATCH 142/149] mediatek: filogic: add MT7986 SPI-NOR DT overlay

Add mt7986-spim-nor.dtso providing the SPI-NOR partition layout
for MT7986, and reference it via DEVICE_DTS_OVERLAY on MT7986A-RFB
and MT7986B-RFB image definitions so they can boot from NOR flash.

Import of patches-base/1143-05 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 0690ffea1b..44351ed630 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2003,6 +2003,7 @@ define Device/mediatek_mt7986a-rfb
   DEVICE_DTS_OVERLAY:= \
 	mt7986-spim-nand \
 	mt7986-spim-nand-nmbm \
+	mt7986-spim-nor \
 	mt7986-spidev
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
@@ -2028,6 +2029,7 @@ define Device/mediatek_mt7986b-rfb
   DEVICE_DTS_OVERLAY:= \
 	mt7986-spim-nand \
 	mt7986-spim-nand-nmbm \
+	mt7986-spim-nor \
 	mt7986-spidev
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
-- 
