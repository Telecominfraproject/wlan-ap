From 0fdde1a725265461da8e6e6b331f2c94b7f495cb Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:53:02 +0200
Subject: [PATCH 145/149] mediatek: filogic: add WiFi gen DT overlays to
 MT7987A-RFB

Add filogic-wifi7, filogic-wifi8 and filogic-binfile DT overlays
to the MT7987A-RFB image so it can switch between WiFi-7 / WiFi-8
EEPROM binfile selection at boot via the overlay mechanism.

Import of patches-base/1142-06 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index f77dad7a22..20b9c34999 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2070,7 +2070,10 @@ define Device/mediatek_mt7987a-rfb
 	mt7987-netsys-eth2-e2p5g \
 	mt7987-netsys-eth2-sfp \
 	mt7987-netsys-eth2-usb \
-	mt7987-spidev
+	mt7987-spidev \
+	filogic-wifi7 \
+	filogic-wifi8 \
+	filogic-binfile
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x4ff00000
-- 
2.34.1

