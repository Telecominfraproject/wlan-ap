From be1d46a77fe6acf3108922450ebac27a4a74b72d Mon Sep 17 00:00:00 2001
From: "javen.hu" <javen.hu@cybertan.com.tw>
Date: Mon, 11 May 2026 03:35:48 +0000
Subject: [PATCH] netifd: defer bridge present until wireless device link up

When the first bridge member is a wireless device that has not yet
linked up, defer calling device_set_present() until DEV_EVENT_LINK_UP
is received. This fixes bridge bring-up failure with wireless-only
members.

Changes:
- DEV_EVENT_ADD: if the first member is wireless and not yet linked
  up, skip device_set_present() and log a notice.
- DEV_EVENT_LINK_UP: if the bridge has not been set present yet,
  call device_set_present() now.

Fixes: WIFI-15442
Signed-off-by: Javen Hu <Javen.Hu@cybertan.com.tw>
---
 ...esent_for_wlan_members_until_link_up.patch | 46 +++++++++++++++++++
 1 file changed, 46 insertions(+)
 create mode 100644 package/network/config/netifd/patches/201_defer_bridge_present_for_wlan_members_until_link_up.patch

diff --git a/package/network/config/netifd/patches/201_defer_bridge_present_for_wlan_members_until_link_up.patch b/package/network/config/netifd/patches/201_defer_bridge_present_for_wlan_members_until_link_up.patch
new file mode 100644
index 0000000000..0b9efa8619
--- /dev/null
+++ b/package/network/config/netifd/patches/201_defer_bridge_present_for_wlan_members_until_link_up.patch
@@ -0,0 +1,46 @@
+--- a/bridge.c	2026-02-26 20:08:34.000000000 +0800
++++ b/bridge.c	2026-05-09 16:45:58.276631730 +0800
+@@ -768,8 +768,22 @@
+ 		bm->present = true;
+ 		bst->n_present++;
+ 
+-		if (bst->n_present == 1)
+-			device_set_present(&bst->dev, true);
++		if (bst->n_present == 1) {
++			if (dev->wireless && !dev->link_active) {
++				/*
++				* Wireless device has not linked up yet.
++				* Defer bridge present，bringing up an empty bridge
++				* will fail. Wait for DEV_EVENT_LINK_UP instead.
++				*/
++				netifd_log_message(L_NOTICE,
++					"bridge '%s': wireless member '%s' not yet linked up, "
++					"defer bridge present\n",
++					bst->dev.ifname, dev->ifname);
++			} else {
++				device_set_present(&bst->dev, true);
++			}
++		}
++
+ 		fallthrough;
+ 	case DEV_EVENT_AUTH_UP:
+ 		if (!bst->dev.active)
+@@ -787,6 +801,18 @@
+ 					 DEV_OPT_MTU | DEV_OPT_MTU6);
+ 		break;
+ 	case DEV_EVENT_LINK_UP:
++		/*
++		* A bridge member has linked up but the bridge has not
++		* been set present yet, bring it up now.
++		*/
++		if (!bst->dev.present) {
++			netifd_log_message(L_NOTICE,
++			"bridge '%s': member '%s' linked up, "
++				"set bridge present now\n",
++				bst->dev.ifname, dev->ifname);
++			device_set_present(&bst->dev, true);
++		}
++
+ 		if (!bst->has_vlans)
+ 			break;
+ 
-- 
