From 0e1f82446e6886c493447e059604a66a4a7b0a31 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:53:02 +0200
Subject: [PATCH 146/149] mediatek: filogic: drop WIFI packages from
 MT7986A/B-RFB default

Remove kmod-mt7915e and kmod-mt7986-firmware from the MT7986A-RFB
and MT7986B-RFB DEVICE_PACKAGES so the images build without WIFI
by default. Mirrors the equivalent treatment already applied to
MT7981-RFB via patches-base/1144-05.

Import of patches-base/1143-04 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 20b9c34999..f10d751216 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2010,7 +2010,7 @@ define Device/mediatek_mt7986a-rfb
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x43f00000
-  DEVICE_PACKAGES := kmod-mt7915e kmod-mt7986-firmware mt7986-wo-firmware blkid
+  DEVICE_PACKAGES := mt7986-wo-firmware blkid
   KERNEL_LOADADDR := 0x46000000
   KERNEL := kernel-bin | gzip
   KERNEL_INITRAMFS := kernel-bin | lzma | secure-boot-initramfs | \
@@ -2037,7 +2037,7 @@ define Device/mediatek_mt7986b-rfb
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x43f00000
-  DEVICE_PACKAGES := kmod-mt7915e kmod-mt7986-firmware mt7986-wo-firmware blkid
+  DEVICE_PACKAGES := mt7986-wo-firmware blkid
   KERNEL_LOADADDR := 0x46000000
   KERNEL := kernel-bin | gzip
   KERNEL_INITRAMFS := kernel-bin | lzma | secure-boot-initramfs | \
-- 
2.34.1

