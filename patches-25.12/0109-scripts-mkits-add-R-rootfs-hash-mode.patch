From 7a222d45f12dcddb6cf846c7d0cfada2898e57c6 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 11 May 2026 07:58:00 +0200
Subject: [PATCH 2/5] scripts: mkits: add -R rootfs-hash mode

Some vendor bootloaders carry a rootfs descriptor in the FIT image
*outside* the 'images' container: a top-level 'rootfs' node with
'size', 'crc32' and 'sha1' properties used to verify the on-flash
rootfs partition before the kernel mounts it.

mkimage does not auto-fill hash values for nodes outside the 'images'
container, so the values have to be precomputed at build time and
inlined into the .its source.

Add an opt-in '-R' flag that:

  * skips the '.pagesync' requirement on the rootfs argument
  * emits a top-level 'rootfs' node (after the images block) carrying
    size, crc32 and sha1 of the rootfs blob passed via -r
  * leaves the rootfs out of the LOADABLES list and out of the
    'images' container so mkimage does not try to embed it

The new flag is purely additive: when '-R' is not passed, mkits.sh
output is bit-identical to before.

Signed-off-by: John Crispin <john@phrozen.org>
---
 scripts/mkits.sh | 28 ++++++++++++++++++++++++----
 1 file changed, 24 insertions(+), 4 deletions(-)

diff --git a/scripts/mkits.sh b/scripts/mkits.sh
index fc2b580ee2..96d010f007 100755
--- a/scripts/mkits.sh
+++ b/scripts/mkits.sh
@@ -31,6 +31,7 @@ usage() {
 	printf "\n\t-n ==> fdt unit-address 'address'"
 	printf "\n\t-d ==> include Device Tree Blob 'dtb'"
 	printf "\n\t-r ==> include RootFS blob 'rootfs'"
+	printf "\n\t-R ==> emit rootfs descriptor outside images with size + crc32 + sha1"
 	printf "\n\t-H ==> specify hash algo instead of SHA1"
 	printf "\n\t-l ==> legacy mode character (@ etc otherwise -)"
 	printf "\n\t-o ==> create output file 'its_file'"
@@ -48,8 +49,9 @@ HASH=sha1
 LOADABLES=
 DTOVERLAY=
 DTADDR=
+ROOTFS_HASH_NODE=
 
-while getopts ":A:a:c:C:D:d:e:f:i:k:l:n:o:O:v:r:s:H:" OPTION
+while getopts ":A:a:c:C:D:d:e:f:i:k:l:n:o:O:v:r:s:H:R" OPTION
 do
 	case $OPTION in
 		A ) ARCH=$OPTARG;;
@@ -70,6 +72,7 @@ do
 		s ) FDTADDR=$OPTARG;;
 		H ) HASH=$OPTARG;;
 		v ) VERSION=$OPTARG;;
+		R ) ROOTFS_HASH=1;;
 		* ) echo "Invalid option passed to '$0' (options:$*)"
 		usage;;
 	esac
@@ -82,7 +85,7 @@ if [ -z "${ARCH}" ] || [ -z "${COMPRESS}" ] || [ -z "${LOAD_ADDR}" ] || \
 	usage
 fi
 
-if [ -n "${ROOTFS}" ] && [ ! -f "${ROOTFS}".pagesync ]; then
+if [ -n "${ROOTFS}" ] && [ -z "${ROOTFS_HASH}" ] && [ ! -f "${ROOTFS}".pagesync ]; then
 	echo "Missing .pagesync blob for RootFS blob '${ROOTFS}'"
 	exit 1
 fi
@@ -140,7 +143,24 @@ if [ -n "${INITRD}" ]; then
 fi
 
 
-if [ -n "${ROOTFS}" ]; then
+if [ -n "${ROOTFS}" ] && [ -n "${ROOTFS_HASH}" ]; then
+	ROOTFS_SIZE=$(stat -c %s "${ROOTFS}")
+	ROOTFS_SHA1=$(sha1sum "${ROOTFS}" | awk '{print "<0x"substr($0,1,8)" 0x"substr($0,9,8)" 0x"substr($0,17,8)" 0x"substr($0,25,8)" 0x"substr($0,33,8)">"}')
+	ROOTFS_CRC32=$(crc32sum "${ROOTFS}")
+	ROOTFS_HASH_NODE="
+	rootfs {
+		size = <${ROOTFS_SIZE}>;
+		hash${REFERENCE_CHAR}1 {
+			value = <0x${ROOTFS_CRC32}>;
+			algo = \"crc32\";
+		};
+		hash${REFERENCE_CHAR}2 {
+			value = ${ROOTFS_SHA1};
+			algo = \"sha1\";
+		};
+	};
+"
+elif [ -n "${ROOTFS}" ]; then
 	ROOTFS_NODE="
 		rootfs${REFERENCE_CHAR}$ROOTFSNUM {
 			description = \"${ARCH_UPPER} OpenWrt ${DEVICE} rootfs\";
@@ -225,7 +245,7 @@ ${FDT_NODE}
 ${FDTOVERLAY_NODE}
 ${ROOTFS_NODE}
 	};
-
+${ROOTFS_HASH_NODE}
 	configurations {
 		default = \"${CONFIG}\";
 		${CONFIG} {
-- 
2.34.1

