From 058beacbf90af99cdf14e39fc7e71d23eb91d3e9 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 2 Feb 2026 09:01:01 +0100
Subject: [PATCH 078/115] hostapd: ubus: add uci_section and signal_mgmt to
 get_status

Expose the UCI section name and EWMA management frame signal strength
in the BSS status response. The dead ieee80211_frequency_to_channel()
helper from the feeds was dropped as nothing references it.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/network/services/hostapd/src/src/ap/ubus.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/package/network/services/hostapd/src/src/ap/ubus.c b/package/network/services/hostapd/src/src/ap/ubus.c
index ab14f6a62d..60b84de509 100644
--- a/package/network/services/hostapd/src/src/ap/ubus.c
+++ b/package/network/services/hostapd/src/src/ap/ubus.c
@@ -454,6 +454,12 @@ hostapd_bss_get_status(struct ubus_context *ctx, struct ubus_object *obj,
 			hapd->iface->cac_started ? hapd->iface->dfs_cac_ms / 1000 - now.sec : 0);
 	blobmsg_close_table(&b, dfs_table);
 
+	if (hapd->conf->uci_section)
+		blobmsg_add_string(&b, "uci_section", hapd->conf->uci_section);
+
+	if (hapd->signal_mgmt)
+		blobmsg_add_u32(&b, "signal_mgmt", hapd->signal_mgmt);
+
 	ubus_send_reply(ctx, req, b.head);
 
 	return 0;
-- 
