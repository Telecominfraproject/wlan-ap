From ed0d755978b33a4c51070e85101d2b06777aa586 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:51:35 +0200
Subject: [PATCH 137/149] mediatek: filogic: add WiFi gen DT overlays to
 MT7988A-RFB

Add filogic-wifi7, filogic-wifi8 and filogic-binfile DT overlays
so the MT7988A-RFB image can switch between WiFi-7 / WiFi-8 EEPROM
binfile selection at boot via the DT overlay mechanism.

Import of patches-base/1140-05 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 60e5ee1677..4cab9dd957 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2098,7 +2098,10 @@ define Device/mediatek_mt7988a-rfb
 	mt7988a-rfb-spidev \
 	mt7988a-rfb-4pcie \
 	mt7988a-rfb-2pcie \
-	mt7988d-rfb-2pcie
+	mt7988d-rfb-2pcie \
+	filogic-wifi7 \
+	filogic-wifi8 \
+	filogic-binfile
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x45f00000
-- 
2.34.1

