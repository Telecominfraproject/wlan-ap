From 23af813ef86ea7425f0efa7108112c57851d5b65 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 18 May 2026 07:52:35 +0200
Subject: [PATCH 141/149] mediatek: filogic: add spidev overlay to
 MT7986A/B-RFB

Reference the mt7986-spidev DT overlay from MT7986A-RFB and
MT7986B-RFB image definitions so they expose a spidev interface
for board bring-up.

Import of patches-base/1143-03 from MediaTek 25.12 feeds.

Signed-off-by: John Crispin <john@phrozen.org>
---
 target/linux/mediatek/image/filogic.mk | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/target/linux/mediatek/image/filogic.mk b/target/linux/mediatek/image/filogic.mk
index 4ae2f5dbfa..0690ffea1b 100644
--- a/target/linux/mediatek/image/filogic.mk
+++ b/target/linux/mediatek/image/filogic.mk
@@ -2002,7 +2002,8 @@ define Device/mediatek_mt7986a-rfb
   DEVICE_DTS := mt7986a-rfb
   DEVICE_DTS_OVERLAY:= \
 	mt7986-spim-nand \
-	mt7986-spim-nand-nmbm
+	mt7986-spim-nand-nmbm \
+	mt7986-spidev
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x43f00000
@@ -2026,7 +2027,8 @@ define Device/mediatek_mt7986b-rfb
   DEVICE_DTS := mt7986b-rfb
   DEVICE_DTS_OVERLAY:= \
 	mt7986-spim-nand \
-	mt7986-spim-nand-nmbm
+	mt7986-spim-nand-nmbm \
+	mt7986-spidev
   DEVICE_DTS_DIR := $(DTS_DIR)/
   DEVICE_DTC_FLAGS := --pad 4096
   DEVICE_DTS_LOADADDR := 0x43f00000
-- 
2.34.1

