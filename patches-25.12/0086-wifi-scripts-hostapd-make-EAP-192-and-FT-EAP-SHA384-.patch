From 207d658d681a19a8a4ed9c6e42bcabc89e1421f6 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Mon, 2 Feb 2026 09:16:48 +0100
Subject: [PATCH 86/93] wifi-scripts: hostapd: make EAP-192 and FT-EAP-SHA384
 mutually exclusive

With FT enabled, only advertise FT-EAP-SHA384 for eap192 auth type.
WPA-EAP-SUITE-B-192 and FT-EAP-SHA384 should not be advertised
simultaneously as the FT variant supersedes the base key management.

Signed-off-by: John Crispin <john@phrozen.org>
---
 package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
index 00510041bf..0a13d2789d 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
@@ -47,7 +47,7 @@ hostapd_append_wpa_key_mgmt() {
 			[ "${ieee80211w:-0}" -gt 0 ] && append wpa_key_mgmt "WPA-${auth_type_l}-SHA256"
 		;;
 		eap192)
-			append wpa_key_mgmt "WPA-EAP-SUITE-B-192"
+			[ "${ieee80211r:-0}" -gt 0 ] || append wpa_key_mgmt "WPA-EAP-SUITE-B-192"
 			[ "${ieee80211r:-0}" -gt 0 ] && append wpa_key_mgmt "FT-EAP-SHA384"
 		;;
 		eap-eap2)
-- 
2.34.1

