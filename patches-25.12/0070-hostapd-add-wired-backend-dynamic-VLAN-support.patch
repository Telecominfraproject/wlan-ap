From 20511b1023bd58f6e021fbd1e97f8a8edfb8f217 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Sat, 31 Jan 2026 18:31:08 +0100
Subject: [PATCH 70/93] hostapd: add wired backend dynamic VLAN support

Port TIP 790-wired-dynamic-vlan.patch: guards VLAN interface add with
driver capability check, allowing wired dynamic VLAN to work when no
driver if_add callback exists.

Signed-off-by: John Crispin <john@phrozen.org>
---
 .../patches/zzz-0010-wired-dynamic-vlan.patch | 38 +++++++++++++++++++
 1 file changed, 38 insertions(+)
 create mode 100644 package/network/services/hostapd/patches/zzz-0010-wired-dynamic-vlan.patch

diff --git a/package/network/services/hostapd/patches/zzz-0010-wired-dynamic-vlan.patch b/package/network/services/hostapd/patches/zzz-0010-wired-dynamic-vlan.patch
new file mode 100644
index 0000000000..e988c2e8d9
--- /dev/null
+++ b/package/network/services/hostapd/patches/zzz-0010-wired-dynamic-vlan.patch
@@ -0,0 +1,38 @@
+#
+# TIP patch: 790-wired-dynamic-vlan.patch
+# Guards VLAN interface add/remove with driver capability check, allowing
+# wired dynamic VLAN to work when no driver if_add callback exists.
+#
+Index: hostapd-2021-02-20-59e9794c/src/ap/vlan_init.c
+===================================================================
+--- hostapd-2021-02-20-59e9794c.orig/src/ap/vlan_init.c
++++ hostapd-2021-02-20-59e9794c/src/ap/vlan_init.c
+@@ -37,7 +37,14 @@ static int vlan_if_add(struct hostapd_da
+ 	}
+ #endif /* CONFIG_WEP */
+ 
+-	if (!vlan_exists)
++	if (!hapd->driver || !hapd->driver->if_add) {
++		char *dot = strstr(vlan->ifname, ".");
++		if (dot)
++			*dot = '\0';
++		ret = 0;
++	}
++	
++	else if (!vlan_exists)
+ 		ret = hostapd_vlan_if_add(hapd, vlan->ifname);
+ 	else if (!existsok)
+ 		return -1;
+Index: hostapd-2021-02-20-59e9794c/src/ap/vlan_init.c
+===================================================================
+--- hostapd-2021-02-20-59e9794c.orig/src/ap/vlan_init.c
++++ hostapd-2021-02-20-59e9794c/src/ap/vlan_init.c
+@@ -59,7 +59,7 @@ static int vlan_if_add(struct hostapd_da
+ 	if (hapd->wpa_auth)
+ 		ret = wpa_auth_ensure_group(hapd->wpa_auth, vlan->vlan_id);
+ 
+-	if (!ret && !vlan_exists)
++	if (!ret && !vlan_exists && hapd->driver->if_add)
+ 		hostapd_ubus_add_vlan(hapd, vlan);
+ 
+ 	if (ret == 0)
-- 
2.34.1

