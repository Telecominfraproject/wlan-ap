diff --git a/target/linux/mediatek/patches-6.12/999--net-phy-support-an8801-and-mdio-second-phy.patch b/target/linux/mediatek/patches-6.12/999--net-phy-support-an8801-and-mdio-second-phy.patch
new file mode 100644
index 0000000000..ab39a108f9
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999--net-phy-support-an8801-and-mdio-second-phy.patch
@@ -0,0 +1,68 @@
+diff --git a/drivers/net/mdio/of_mdio.c b/drivers/net/mdio/of_mdio.c
+--- a/drivers/net/mdio/of_mdio.c
++++ b/drivers/net/mdio/of_mdio.c
+@@ -142,7 +142,10 @@ static int __of_mdiobus_parse_phys(struc
+ 	int addr, rc = 0;
+
+ 	/* Loop over the child nodes and register a phy_device for each phy */
++	int an8801=0;
+ 	for_each_available_child_of_node(np, child) {
++		if(an8801==1)break;
++
+ 		if (of_node_name_eq(child, "ethernet-phy-package")) {
+ 			/* Ignore invalid ethernet-phy-package node */
+ 			if (!of_property_present(child, "reg"))
+@@ -168,8 +171,25 @@ static int __of_mdiobus_parse_phys(struc
+ 			continue;
+ 		}
+
+-		if (of_mdiobus_child_is_phy(child))
++		if (of_mdiobus_child_is_phy(child)) {
++			if(addr==30)
++			{
++				int phy_id ;
++
++				phy_id = mdiobus_read(mdio, addr, MII_PHYSID1) << 16 ;
++				phy_id = phy_id + mdiobus_read(mdio, addr, MII_PHYSID2);
++				dev_info(&mdio->dev, "[of_mdio] %s %d  addr:%d phy_id:0x%x  \n",__func__, __LINE__, addr, phy_id);
++
++				if (phy_id==0 || phy_id==0x1a750000)
++				{
++					dev_info(&mdio->dev, "[of_mdio] %s %d  continue  \n",__func__, __LINE__);
++					continue;
++				}
++				else
++					an8801=1;
++			}
+ 			rc = of_mdiobus_register_phy(mdio, child, addr);
++		}
+ 		else
+ 			rc = of_mdiobus_register_device(mdio, child, addr);
+
+diff --git a/drivers/net/phy/phylink.c b/drivers/net/phy/phylink.c
+--- a/drivers/net/phy/phylink.c
++++ b/drivers/net/phy/phylink.c
+@@ -2291,8 +2291,21 @@ int phylink_fwnode_phy_connect(struct ph
+ 	phy_dev = fwnode_phy_find_device(phy_fwnode);
+ 	/* We're done with the phy_node handle */
+ 	fwnode_handle_put(phy_fwnode);
+-	if (!phy_dev)
+-		return -ENODEV;
++	if (!phy_dev)
++	{
++		phylink_info(pl, "[phylink] reload phy-handle2. %s %d\n",__func__, __LINE__);
++		phy_fwnode = fwnode_find_reference(fwnode, "phy-handle2", 0);
++		if (IS_ERR(phy_fwnode)) {
++			if (pl->cfg_link_an_mode == MLO_AN_PHY)
++				return -ENODEV;
++			return 0;
++		}
++		phy_dev = fwnode_phy_find_device(phy_fwnode);
++		fwnode_handle_put(phy_fwnode);
++
++		if (!phy_dev)
++			return -ENODEV;
++ 	}
+
+ 	/* Use PHY device/driver interface */
+ 	if (pl->link_interface == PHY_INTERFACE_MODE_NA) {
diff --git a/target/linux/mediatek/patches-6.12/999-2700-net-ethernet-mtk_eth_soc-add-mdio-reset-delay.patch b/target/linux/mediatek/patches-6.12/999-2700-net-ethernet-mtk_eth_soc-add-mdio-reset-delay.patch
new file mode 100644
index 0000000000..6e8b95ea84
--- /dev/null
+++ b/target/linux/mediatek/patches-6.12/999-2700-net-ethernet-mtk_eth_soc-add-mdio-reset-delay.patch
@@ -0,0 +1,26 @@
+--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
++++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+@@ -485,6 +485,16 @@ static int mtk_mdio_read_c45(struct mii_
+ 	return _mtk_mdio_read_c45(eth, phy_addr, devad, phy_reg);
+ }
+
++static int mtk_mdio_reset(struct mii_bus *bus)
++{
++	/* The mdiobus_register will trigger a reset pulse when enabling Bus reset,
++	 * we just need to wait until device ready.
++	 */
++	mdelay(150);
++
++	return 0;
++}
++
+ static int mt7621_gmac0_rgmii_adjust(struct mtk_eth *eth,
+ 				     phy_interface_t interface)
+ {
+@@ -1063,6 +1073,7 @@ static int mtk_mdio_init(struct mtk_eth
+ 	eth->mii_bus->read_c45 = mtk_mdio_read_c45;
+ 	eth->mii_bus->write_c45 = mtk_mdio_write_c45;
++	eth->mii_bus->reset = mtk_mdio_reset;
+ 	eth->mii_bus->priv = eth;
+ 	eth->mii_bus->parent = eth->dev;
+
