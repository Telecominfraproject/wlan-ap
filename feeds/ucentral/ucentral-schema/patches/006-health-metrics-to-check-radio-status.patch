+	 * The +N suffix indicates radio offset within a multi-radio device node */
+	let dev_path = section.path;
+	let phy_offset = 0;
+	let ofs_match = match(dev_path, /^(.+)\+([0-9]+)$/);
+	if (ofs_match) {
