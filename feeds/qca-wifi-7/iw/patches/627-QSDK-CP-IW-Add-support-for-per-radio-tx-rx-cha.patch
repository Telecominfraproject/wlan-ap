From 87c9de6998c098041bd165a3f576842aff6dca83 Mon Sep 17 00:00:00 2001
From: Uraj Sasan <usasan@qti.qualcomm.com>
Date: Fri, 6 Jun 2025 15:04:28 +0530
Subject: [PATCH] QSDK: CP: IW: Add support for per radio tx/rx chainmask

Currently the tx/rx chaimask is provided for the wiphy but there
can be cases where user wants to configure the tx/rx chainmask
per radio. This changes adds that support.

Command Usage:
iw [options] phy <phyname> set antenna [radio <radio idx>] <bitmap> | all | <tx bitmap> <rx bitmap>

iw phy phyXX info

Supported wiphy radios:
        * Idx 0:
    Available Antennas: TX 0xf      RX 0xf
    Configured Antennas: TX 0xa     RX 0xa
            Frequency Range: 2402 MHz - 2472 MHz
        * Idx 1:
    Available Antennas: TX 0xf      RX 0xf
    Configured Antennas: TX 0xb     RX 0xb
            Frequency Range: 5170 MHz - 5835 MHz

        * Idx 2:
    Available Antennas: TX 0xf      RX 0xf
    Configured Antennas: TX 0xc     RX 0xc
            Frequency Range: 5945 MHz - 7125 MHz

Signed-off-by: Uraj Sasan <usasan@qti.qualcomm.com>

diff --git a/info.c b/info.c
index c947ab8..ab1caf9 100644
--- a/info.c
+++ b/info.c
@@ -1110,7 +1110,21 @@ broken_combination:
 					if (!have_combinations)
 						printf("\t\t\tRadio level interface combinations are not supported\n");
 					break;
+				case NL80211_WIPHY_RADIO_ATTR_ANTENNA_AVAIL_TX:
+					printf("\t\t\tAvailable Antennas: TX %#x ", nla_get_u32(radio_prop));
+					break;
+
+				case NL80211_WIPHY_RADIO_ATTR_ANTENNA_AVAIL_RX:
+					printf("\tRX %#x \n", nla_get_u32(radio_prop));
+					break;
+				case NL80211_WIPHY_RADIO_ATTR_ANTENNA_TX:
+					printf("\t\t\tConfigured Antennas: TX %#x ", nla_get_u32(radio_prop));
+					break;
+				case NL80211_WIPHY_RADIO_ATTR_ANTENNA_RX:
+					printf("\tRX %#x \n ", nla_get_u32(radio_prop));
+					break;
 				default:
+					printf("\tdefault %#x ", nla_get_u32(radio_prop));
 					printf("\t\t\t* <failed to parse>\n");
 				}
 			}
diff --git a/nl80211.h b/nl80211.h
index 2ebbdcf..db86d5b 100644
--- a/nl80211.h
+++ b/nl80211.h
@@ -8369,6 +8369,30 @@ enum nl80211_ap_settings_flags {
  * @NL80211_WIPHY_RADIO_ATTR_INTERFACE_COMBINATION: Supported interface
  *	combination for this radio. Attribute may be present multiple times
  *	and contains attributes defined in &enum nl80211_if_combination_attrs.
+ * @NL80211_WIPHY_RADIO_ATTR_ANTENNA_TX: Bitmap of allowed antennas for transmitting.
+ *	This can be used to mask out antennas which are not attached or should
+ *	not be used for transmitting. If an antenna is not selected in this
+ *	bitmap the hardware is not allowed to transmit on this antenna.
+ *
+ *	Each bit represents one antenna, starting with antenna 1 at the first
+ *	bit. Depending on which antennas are selected in the bitmap, 802.11n
+ *	drivers can derive which chainmasks to use (if all antennas belonging to
+ *	a particular chain are disabled this chain should be disabled) and if
+ *	a chain has diversity antennas whether diversity should be used or not.
+ *	HT capabilities (STBC, TX Beamforming, Antenna selection) can be
+ *	derived from the available chains after applying the antenna mask.
+ *	Non-802.11n drivers can derive whether to use diversity or not.
+ *	Drivers may reject configurations or RX/TX mask combinations they cannot
+ *	support by returning -EINVAL.
+ * @NL80211_WIPHY_RADIO_ATTR_ANTENNA_RX: Bitmap of allowed antennas for receiving.
+ *	This can be used to mask out antennas which are not attached or should
+ *	not be used for receiving. If an antenna is not selected in this bitmap
+ *	the hardware should not be configured to receive on this antenna.
+ *	For a more detailed description see @NL80211_ATTR_WIPHY_ANTENNA_TX.
+ * @NL80211_WIPHY_RADIO_ATTR_ANTENNA_AVAIL_TX: Bitmap of antennas which are available
+ *	for configuration as TX antennas via the above parameters.
+ * @NL80211_WIPHY_RADIO_ATTR_ANTENNA_AVAIL_RX: Bitmap of antennas which are available
+ *	for configuration as RX antennas via the above parameters.
  *
  * @__NL80211_WIPHY_RADIO_ATTR_LAST: Internal
  * @NL80211_WIPHY_RADIO_ATTR_MAX: Highest attribute
@@ -8381,6 +8405,10 @@ enum nl80211_wiphy_radio_attrs {
 	NL80211_WIPHY_RADIO_ATTR_INTERFACE_COMBINATION,
 	NL80211_WIPHY_RADIO_ATTR_ANTENNA_MASK,
 	NL80211_WIPHY_RADIO_ATTR_RTS_THRESHOLD,
+	NL80211_WIPHY_RADIO_ATTR_ANTENNA_TX,
+	NL80211_WIPHY_RADIO_ATTR_ANTENNA_RX,
+	NL80211_WIPHY_RADIO_ATTR_ANTENNA_AVAIL_TX,
+	NL80211_WIPHY_RADIO_ATTR_ANTENNA_AVAIL_RX,
 
 	/* keep last */
 	__NL80211_WIPHY_RADIO_ATTR_LAST,
diff --git a/phy.c b/phy.c
index 6df0d97..7852d34 100644
--- a/phy.c
+++ b/phy.c
@@ -966,22 +966,40 @@ static int handle_antenna(struct nl80211_state *state,
 {
 	char *end;
 	uint32_t tx_ant = 0, rx_ant = 0;
+	int i = 0;
 
-	if (argc == 1 && strcmp(argv[0], "all") == 0) {
+	/* check if radio idx is provided */
+	if (argc >= 2 && !strcmp(argv[0], "radio")) {
+		unsigned int radio_id;
+
+		radio_id = strtoul(argv[1], &end, 10);
+		if (*end)
+			return 1;
+
+		NLA_PUT_U8(msg, NL80211_ATTR_WIPHY_RADIO_INDEX, radio_id);
+		i = 2;
+	}
+
+	/* check the required args without radio id */
+	if ((argc - i) != 1 && (argc - i) != 2)
+		return 1;
+
+	if ((argc - i) == 1 && strcmp(argv[i], "all") == 0) {
 		tx_ant = 0xffffffff;
 		rx_ant = 0xffffffff;
-	} else if (argc == 1) {
-		tx_ant = rx_ant = strtoul(argv[0], &end, 0);
+	} else if ((argc - i) == 1) {
+		tx_ant = rx_ant = strtoul(argv[i], &end, 0);
 		if (*end)
 			return 1;
 	}
-	else if (argc == 2) {
-		tx_ant = strtoul(argv[0], &end, 0);
+	else if ((argc - i) == 2) {
+		tx_ant = strtoul(argv[i], &end, 0);
 		if (*end)
 			return 1;
-		rx_ant = strtoul(argv[1], &end, 0);
+		rx_ant = strtoul(argv[i+1], &end, 0);
 		if (*end)
 			return 1;
+
 	} else
 		return 1;
 
@@ -993,7 +1011,7 @@ static int handle_antenna(struct nl80211_state *state,
  nla_put_failure:
 	return -ENOBUFS;
 }
-COMMAND(set, antenna, "<bitmap> | all | <tx bitmap> <rx bitmap>",
+COMMAND(set, antenna, "[radio <radio idx>] <bitmap> | all | <tx bitmap> <rx bitmap>",
 	NL80211_CMD_SET_WIPHY, 0, CIB_PHY, handle_antenna,
 	"Set a bitmap of allowed antennas to use for TX and RX.\n"
 	"The driver may reject antenna configurations it cannot support.");
-- 
2.34.1

