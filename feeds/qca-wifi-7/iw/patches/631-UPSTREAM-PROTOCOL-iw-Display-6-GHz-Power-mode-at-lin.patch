From e247c9812e88ba87a9a9797539fa7442e519c1e1 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Thu, 3 Jul 2025 13:47:56 +0530
Subject: [PATCH] UPSTREAM: PROTOCOL: iw: Display 6 GHz Power mode at link level

Currently, the 6 GHz power mode is displayed at the netdev interface
level. Since the 6 GHz power mode is shown per interface, only one
power mode can be displayed — that of the first 6 GHz link within
the interface.

To fix this, extract the 6 GHz power mode from the link information
and display it at the link level.

For legacy interfaces, display the 6 GHz power mode at the interface
level.

Sample output:

Interface wlan0
        ifindex 15
        wdev 0x2
        addr 00:03:7f:12:56:56
        ssid OpenWrt_tsksk_afc_6gl
        type AP
        link 0:
          addr 00:03:7f:12:56:56
          channel 36 (5180 MHz), width: 80 MHz, center1: 5210 MHz
          txpower 25.00 dBm
        link 1:
          addr 02:03:7f:12:56:56
          channel 89 (6395 MHz), width: 80 MHz, center1: 6385 MHz
          txpower 25.00 dBm
          Power mode: 1 (SP)
        link 2:
          addr 00:03:7f:12:ae:ae
          channel 149 (6695 MHz), width: 80 MHz, center1: 6705 MHz
          txpower 20.00 dBm
          Power mode: 0 (LPI)

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Patch-dependency:
subsys/0048-cfg80211-mac80211-regulatory-awgn-and-6g-channel-cha.patch
subsys/0340-UPSTREAM-PROTOCOL-cfg80211-mac80211-Store-6-GHz-powe.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 interface.c | 18 ++++++++++++++----
 iw.h        |  3 +++
 reg.c       |  3 ++-
 3 files changed, 19 insertions(+), 5 deletions(-)

diff --git a/interface.c b/interface.c
index 03f9b0c23bc3..4e38bc2d4b68 100644
--- a/interface.c
+++ b/interface.c
@@ -460,10 +460,6 @@ static int print_iface_handler(struct nl_msg *msg, void *arg)
 			printf("%s\t4addr: on\n", indent);
 	}
 
-	if (tb_msg[NL80211_ATTR_6G_REG_POWER_MODE])
-		printf("%s\tPower mode: %d\n", indent,
-		       nla_get_u8(tb_msg[NL80211_ATTR_6G_REG_POWER_MODE]));
-
 	if (tb_msg[NL80211_ATTR_MLO_LINKS]) {
 		int ret = 0;
 		nla_for_each_nested(attrs, tb_msg[NL80211_ATTR_MLO_LINKS], ret) {
@@ -477,10 +473,24 @@ static int print_iface_handler(struct nl_msg *msg, void *arg)
 					printf("%s\t  addr %s\n", indent, link_addr);
 				}
 				print_channel_txpower(link, "  ");
+
+				if (link[NL80211_ATTR_6G_REG_POWER_MODE]) {
+					__u8 mode = nla_get_u8(link[NL80211_ATTR_6G_REG_POWER_MODE]);
+
+					printf("%s\t  Power mode: %d (%s)\n", indent,
+					       mode, reg_6ghz_mode_to_str(mode));
+				}
 			}
 		}
 	} else {
 		print_channel_txpower(tb_msg, "");
+
+		if (tb_msg[NL80211_ATTR_6G_REG_POWER_MODE]) {
+			__u8 mode = nla_get_u8(tb_msg[NL80211_ATTR_6G_REG_POWER_MODE]);
+
+			printf("%s\tPower mode: %d (%s)\n", indent,
+			       mode, reg_6ghz_mode_to_str(mode));
+		}
 	}
 
 	return NL_SKIP;
diff --git a/iw.h b/iw.h
index e67da2e95b74..d77e5816c144 100644
--- a/iw.h
+++ b/iw.h
@@ -461,6 +461,9 @@ int nl_get_multicast_id(struct nl_sock *sock, const char *family, const char *gr
 
 char *reg_initiator_to_string(__u8 initiator);
 
+const char *
+reg_6ghz_mode_to_str(enum nl80211_regulatory_power_modes reg_6ghz_power_mode);
+
 const char *get_reason_str(uint16_t reason);
 const char *get_status_str(uint16_t status);
 
diff --git a/reg.c b/reg.c
index 71969bc31e3a..67eee9af430f 100644
--- a/reg.c
+++ b/reg.c
@@ -104,7 +104,8 @@ COMMAND(reg, set, "<ISO/IEC 3166-1 alpha2>",
 	NL80211_CMD_REQ_SET_REG, 0, CIB_NONE, handle_reg_set,
 	"Notify the kernel about the current regulatory domain.");
 
-static const char *reg_6ghz_mode_to_str(enum nl80211_regulatory_power_modes reg_6ghz_power_mode)
+const char *
+reg_6ghz_mode_to_str(enum nl80211_regulatory_power_modes reg_6ghz_power_mode)
 {
 	switch (reg_6ghz_power_mode) {
 	case NL80211_REG_AP_LPI:
