From afc1519b88c73a00788b0e6e3b4d21b0bdc70733 Mon Sep 17 00:00:00 2001
From: Johannes Berg <johannes.berg@intel.com>
Date: Thu, 29 May 2025 09:04:52 +0530
Subject: [PATCH] QSDK: CP: iw: Deprecate ru-punct-bitmap

In Upstream ru-punct-bitmap is deprecated.
So deprecate ru puncturing bitmap and use puncture bitmap.

Link: https://git.kernel.org/pub/scm/linux/kernel/git/jberg/iw.git/commit/?id=b29da202bdcbdc75cd75db37175261fb22d1e13b

Signed-off-by: Johannes Berg <johannes.berg@intel.com>
Signed-off-by: Rajat Soni <rajson@qti.qualcomm.com>
---
 interface.c | 11 ++++++++---
 iw.h        |  2 +-
 mesh.c      |  2 +-
 nl80211.h   |  7 -------
 phy.c       |  8 ++++----
 util.c      | 10 +++++-----
 6 files changed, 19 insertions(+), 21 deletions(-)

diff --git a/interface.c b/interface.c
index cb188ad..03f9b0c 100644
--- a/interface.c
+++ b/interface.c
@@ -384,6 +384,11 @@ static void print_channel_txpower(struct nlattr *tb_msg[], const char *space)
 			if (tb_msg[NL80211_ATTR_CENTER_FREQ2])
 				printf(", center2: %d MHz",
 					nla_get_u32(tb_msg[NL80211_ATTR_CENTER_FREQ2]));
+			if (tb_msg[NL80211_ATTR_PUNCT_BITMAP]) {
+				uint32_t punct = nla_get_u32(tb_msg[NL80211_ATTR_PUNCT_BITMAP]);
+				if (punct)
+					printf(", punctured: 0x%x", punct);
+			}
 		} else if (tb_msg[NL80211_ATTR_WIPHY_CHANNEL_TYPE]) {
 			enum nl80211_channel_type channel_type;
 			channel_type = nla_get_u32(tb_msg[NL80211_ATTR_WIPHY_CHANNEL_TYPE]);
@@ -769,11 +774,11 @@ static int handle_chan(struct nl80211_state *state, struct nl_msg *msg,
 #ifdef IW_FULL
 SECTION(switch);
 COMMAND(switch, freq,
-	"<freq> [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|320MHz] [ru-puncturing-bitmap <bitmap>] [beacons <count>] [block-tx]\n"
-	"<control freq> [5|10|20|40|80|80+80|160|320] [<center1_freq> [<center2_freq>]] [ru-puncturing-bitmap <bitmap>] [beacons <count>] [block-tx]",
+	"<freq> [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|320MHz] [punct <bitmap>] [beacons <count>] [block-tx]\n"
+	"<control freq> [5|10|20|40|80|80+80|160|320] [<center1_freq> [<center2_freq>]] [punct <bitmap>] [beacons <count>] [block-tx]",
 	NL80211_CMD_CHANNEL_SWITCH, 0, CIB_NETDEV, handle_freq,
 	"Switch the operating channel by sending a channel switch announcement (CSA).");
-COMMAND(switch, channel, "<channel> [6G] [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|320MHz] [ru-puncturing-bitmap <bitmap>] [beacons <count>] [block-tx]",
+COMMAND(switch, channel, "<channel> [6G] [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|320MHz] [punct <bitmap>] [beacons <count>] [block-tx]",
 	NL80211_CMD_CHANNEL_SWITCH, 0, CIB_NETDEV, handle_chan,
 	"Switch the operating channel by sending a channel switch announcement (CSA)."
 	"6GHz channels expects '6G' in argument. Defaults to 5GHz or 2GHz channels");
diff --git a/iw.h b/iw.h
index 0078ae7..e67da2e 100644
--- a/iw.h
+++ b/iw.h
@@ -326,7 +326,7 @@ struct chandef {
 	unsigned int center_freq1;
 	unsigned int center_freq1_offset;
 	unsigned int center_freq2;
-	unsigned int ru_punct_bmap;
+	unsigned int punctured;
 };
 
 #define ARRAY_SIZE(ar) (sizeof(ar)/sizeof(ar[0]))
diff --git a/mesh.c b/mesh.c
index fcfec79..45e695a 100644
--- a/mesh.c
+++ b/mesh.c
@@ -588,7 +588,7 @@ static int join_mesh(struct nl80211_state *state,
  nla_put_failure:
 	return -ENOBUFS;
 }
-COMMAND(mesh, join, "<mesh ID> [[freq <freq in MHz> <NOHT|HT20|HT40+|HT40-|80MHz> [ru-puncturing-bitmap <bitmap>]]"
+COMMAND(mesh, join, "<mesh ID> [[freq <freq in MHz> <NOHT|HT20|HT40+|HT40-|80MHz> [punct <bitmap>]]"
 	" [basic-rates <rate in Mbps,rate2,...>]], [mcast-rate <rate in Mbps>]"
 	" [beacon-interval <time in TUs>] [dtim-period <value>]"
 	" [vendor_sync on|off] [<param>=<value>]*",
diff --git a/nl80211.h b/nl80211.h
index 958a9c9..f4eca5a 100644
--- a/nl80211.h
+++ b/nl80211.h
@@ -2943,11 +2943,6 @@ enum nl80211_commands {
  *	staggered mode = 1 or burst mode = 2 in %NL80211_CMD_START_AP or
  *	%NL80211_CMD_JOIN_MESH from user-space.
  *
- * @NL80211_ATTR_RU_PUNCT_BITMAP: (u16) RU puncturing bitmap where the lowest
- *	bit corresponds to the lowest 20 MHz channel. Each bit set to 1
- *	indicates that the sub-channel is punctured, set 0 indicates that the
- *	channel is active.
- *
  * @NL80211_ATTR_MULTI_HW_MACS: nested attribute to send the hardware mac
  *     specific channel capabilities to user space. Drivers registering
  *     multiple physical hardware under a wiphy can use this attribute,
@@ -3570,8 +3565,6 @@ enum nl80211_attrs {
 
 	NL80211_ATTR_6G_REG_POWER_MODE,
 
-	NL80211_ATTR_RU_PUNCT_BITMAP,
-
 	NL80211_ATTR_AP_PS,
 
 	NL80211_ATTR_MULTI_HW_MACS,
diff --git a/phy.c b/phy.c
index 5dd7979..66e2fc7 100644
--- a/phy.c
+++ b/phy.c
@@ -202,13 +202,13 @@ static int handle_freq(struct nl80211_state *state, struct nl_msg *msg,
 
 COMMAND(set, freq,
 	"<freq> [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|160MHz|320MHz]\n"
-	"<control freq> [5|10|20|40|80|80+80|160|320] [<center1_freq> [<center2_freq>]] [ru-puncturing-bitmap <bitmap>]",
+	"<control freq> [5|10|20|40|80|80+80|160|320] [<center1_freq> [<center2_freq>]] [punct <bitmap>]",
 	NL80211_CMD_SET_WIPHY, 0, CIB_PHY, handle_freq,
 	"Set frequency/channel the hardware is using, including HT\n"
 	"configuration.");
 COMMAND(set, freq,
 	"<freq> [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|160MHz|320MHz]\n"
-	"<control freq> [5|10|20|40|80|80+80|160|320] [<center1_freq> [<center2_freq>]] [ru-puncturing-bitmap <bitmap>]",
+	"<control freq> [5|10|20|40|80|80+80|160|320] [<center1_freq> [<center2_freq>]] [punct <bitmap>]",
 	NL80211_CMD_SET_WIPHY, 0, CIB_NETDEV, handle_freq, NULL);
 
 static int handle_freq_khz(struct nl80211_state *state, struct nl_msg *msg,
@@ -302,9 +302,9 @@ static int handle_chan(struct nl80211_state *state, struct nl_msg *msg,
 
 	return put_chandef(msg, &chandef);
 }
-COMMAND(set, channel, "<channel> [6G] [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|160MHz|320MHz] [ru-puncturing-bitmap <bitmap>]",
+COMMAND(set, channel, "<channel> [6G] [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|160MHz|320MHz] [punct <bitmap>]",
 	NL80211_CMD_SET_WIPHY, 0, CIB_PHY, handle_chan, NULL);
-COMMAND(set, channel, "<channel> [6G] [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|160MHz|320MHz] [6G] [ru-puncturing-bitmap <bitmap>]",
+COMMAND(set, channel, "<channel> [6G] [NOHT|HT20|HT40+|HT40-|5MHz|10MHz|80MHz|160MHz|320MHz] [6G] [punct <bitmap>]",
 	NL80211_CMD_SET_WIPHY, 0, CIB_NETDEV, handle_chan, NULL);
 
 static int handle_add_chan(struct nl80211_state *state, struct nl_msg *msg,
diff --git a/util.c b/util.c
index 89beb2c..15f986f 100644
--- a/util.c
+++ b/util.c
@@ -753,8 +753,8 @@ int parse_freqchan(struct chandef *chandef, bool chan, int argc, char **argv,
 	res = parse_freqs(chandef, argc - 1, argv + 1, &_parsed, freq_in_khz);
 
  out:
-	if (!res && (argc - _parsed) > 1 && strcmp(argv[_parsed], "ru-puncturing-bitmap") == 0) {
-		chandef->ru_punct_bmap = strtoul(argv[_parsed+1], &end, 0);
+	if (!res && (argc - _parsed) > 1 && strcmp(argv[_parsed], "punct") == 0) {
+		chandef->punctured = strtoul(argv[_parsed+1], &end, 0);
 		_parsed += 2;
 	}
 
@@ -816,9 +816,9 @@ int put_chandef(struct nl_msg *msg, struct chandef *chandef)
 			    NL80211_ATTR_CENTER_FREQ2,
 			    chandef->center_freq2);
 
-	if (chandef->ru_punct_bmap)
-		NLA_PUT_U16(msg, NL80211_ATTR_RU_PUNCT_BITMAP,
-			    chandef->ru_punct_bmap);
+	if (chandef->punctured)
+		NLA_PUT_U16(msg, NL80211_ATTR_PUNCT_BITMAP,
+			    chandef->punctured);
 
 	return 0;
 
-- 
2.34.1

