From 72fba7dfeac3347e9e30cfa228e9e4c5ea85feed Mon Sep 17 00:00:00 2001
From: Amith A <amitajit@qti.qualcomm.com>
Date: Wed, 18 Jun 2025 16:12:30 +0530
Subject: [PATCH] UPSTREAM: PROTOCOL: IW: Print 6 GHz device deployment type as part of info
 command

Add support to display 6 GHz device deployment type as part of 'info'
command.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Path-dependency:
ath12k/0375-UPSTREAM-PROTOCOL-wifi-ath12k-Add-module-params-for-.patch
subsys/0332-03-UPSTREAM-PROTOCOL-wifi-cfg80211-Extend-NL80211_CMD_GET_W.patch
subsys/0332-04-UPSTREAM-PROTOCOL-wifi-mac80211-Add-a-mac80211_config_op.patch
ath12k/0436-0004-UPSTREAM-PROTOCOL-wifi-ath12k-Add-an-ath12k_ops-to-get-t.patch

Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 info.c    |  5 +++++
 iw.h      |  2 ++
 nl80211.h |  9 +++++++++
 util.c    | 17 +++++++++++++++++
 4 files changed, 33 insertions(+)

--- a/info.c
+++ b/info.c
@@ -379,6 +379,23 @@ static void print_interface_combination(
 	printf("\n");
 }
 
+static void print_6ghz_dev_deployment_type(uint8_t dev_deployment_type)
+{
+	printf("\t6 GHz Device deployment type: ");
+	switch (dev_deployment_type) {
+	case NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_INDOOR:
+		printf("Indoor\n");
+		break;
+	case NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_OUTDOOR:
+		printf("Outdoor\n");
+		break;
+	case NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_UNKNOWN:
+	default:
+		printf("Unknown\n");
+		break;
+	}
+}
+
 static int print_phy_handler(struct nl_msg *msg, void *arg)
 {
 	struct nlattr *tb_msg[NL80211_ATTR_MAX + 1];
@@ -1169,6 +1186,12 @@ broken_combination:
 		}
 	}
 
+	if (tb_msg[NL80211_ATTR_6GHZ_DEVICE_DEPLOYMENT_TYPE]) {
+		__u8 dev_deployment_type = nla_get_u8(tb_msg[NL80211_ATTR_6GHZ_DEVICE_DEPLOYMENT_TYPE]);
+
+		print_6ghz_dev_deployment_type(dev_deployment_type);
+	}
+
 	return NL_SKIP;
 }
 
--- a/nl80211.h
+++ b/nl80211.h
@@ -2989,7 +2989,10 @@ enum nl80211_commands {
  *	params to update ML reconfigure element on corresponding response frame. This
  *	attribute is needed only on ML reconfigure offload case and it is not needed on
  *	ML reconfigure non-offload case since user space itself has these data.
-
+ *
+ * @NL80211_ATTR_6GHZ_DEVICE_DEPLOYMENT_TYPE: Attribute that denotes the 6 GHz
+ *	device deployment type.
+ *
  * @NUM_NL80211_ATTR: total number of nl80211_attrs available
  * @NL80211_ATTR_MAX: highest attribute number currently defined
  * @__NL80211_ATTR_AFTER_LAST: internal use
@@ -3577,7 +3580,18 @@ enum nl80211_attrs {
 	NL80211_ATTR_TSF,
 	NL80211_ATTR_RXMGMT_LINK_REMOVAL_UPDATE,
 	NL80211_ATTR_DYNAMIC_CHAIN_MASK,
+	NL80211_ATTR_ML_MAX_REC_LINKS,
+
+	NL80211_ATTR_ERP,
+
+	NL80211_ATTR_ADVERTISED_TTLM,
+	NL80211_ATTR_ADVERTISED_TTLM_EXPEC_DUR_UPDATE,
+
+	NL80211_ATTR_QOS_MGMT,
+
+	NL80211_ATTR_ASSOC_MLD_EXT_CAPA_OPS,
 
+	NL80211_ATTR_6GHZ_DEVICE_DEPLOYMENT_TYPE,
 	/* add attributes here, update the policy in nl80211.c */
 
 	__NL80211_ATTR_AFTER_LAST,
@@ -4360,6 +4374,8 @@ enum nl80211_band_attr {
 	NL80211_BAND_ATTR_S1G_MCS_NSS_SET,
 	NL80211_BAND_ATTR_S1G_CAPA,
 
+	NL80211_BAND_ATTR_6GHZ_POWER_MODE_FREQS,
+
 	/* keep last */
 	__NL80211_BAND_ATTR_AFTER_LAST,
 	NL80211_BAND_ATTR_MAX = __NL80211_BAND_ATTR_AFTER_LAST - 1
@@ -4390,6 +4406,19 @@ enum nl80211_regulatory_power_modes {
 };
 
 /**
+ * enum nl80211_6ghz_dev_deployment_type - 6 GHz device deployment type
+ * @NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_UNKNOWN: Deployment type unknown
+ * @NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_INDOOR: Indoor deployment
+ * @NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_OUTDOOR: Outdoor deployment
+ */
+
+enum nl80211_6ghz_dev_deployment_type {
+	NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_UNKNOWN,
+	NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_INDOOR,
+	NL80211_6GHZ_DEV_DEPLOYMENT_TYPE_OUTDOOR,
+};
+
+/**
  * enum nl80211_wmm_rule - regulatory wmm rule
  *
  * @__NL80211_WMMR_INVALID: attribute number 0 is reserved
