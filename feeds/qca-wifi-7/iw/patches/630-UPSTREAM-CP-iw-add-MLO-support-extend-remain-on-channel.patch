From 34fda3ebc7885cb5dfbb77e778401a8c4a56ecd8 Mon Sep 17 00:00:00 2001
From: Sathishkumar Muruganandam <murugana@qti.qualcomm.com>
Date: Mon, 2 Jun 2025 16:57:13 +0530
Subject: [PATCH] UPSTREAM:CP:iw: add MLO support & extend remain-on-channel
 upto 320MHz

Existing ROC (remain-on-channel) command, "iw roc start" is extended
to accept bandwidth input upto 320MHz.

NL80211_CMD_REMAIN_ON_CHANNEL is now updated with chandef params and
NL80211_ATTR_MLO_LINK_ID is updated from user input "-l <link_id>"
in case of MLO.

Command:

"iw roc start [-l] <link id> <freq> [HT40+|HT40-|80MHz|160MHz|320MHz] <time in ms>"
"Start off-channel scan for configurable dwell time"

Signed-off-by: Sathishkumar Muruganandam <murugana@qti.qualcomm.com>
---
 roc.c | 41 +++++++++++++++++++++++++++++++----------
 1 file changed, 31 insertions(+), 10 deletions(-)

diff --git a/roc.c b/roc.c
index c6eda103c12a..8d56748e67f5 100644
--- a/roc.c
+++ b/roc.c
@@ -17,24 +17,45 @@ static int handle_roc_start(struct nl80211_state *state,
 			    enum id_input id)
 {
 	char *end;
-	int freq, time;
+	int err, parsed, time;
+	struct chandef chandef;
+	unsigned int link_id;
 
-	if (argc != 2)
+	if (argc < 2)
 		return 1;
 
-	freq = strtol(argv[0], &end, 0);
-	if (!end || *end)
+	if (!strcmp(argv[0], "-l")) {
+		link_id = strtol(argv[1], &end, 10);
+
+		if (link_id <= MAX_MLD_LINK) {
+			NLA_PUT_U8(msg, NL80211_ATTR_MLO_LINK_ID,
+				   link_id);
+			argc -= 2;
+			argv += 2;
+		}
+	}
+
+	err = parse_freqchan(&chandef, false, argc, argv, &parsed, false);
+	if (err)
+		return err;
+
+	argc -= parsed;
+	argv += parsed;
+	err = put_chandef(msg, &chandef);
+	if (err)
+		return err;
+
+	time = strtoul(argv[0], &end, 10);
+	if (*end)
 		return 1;
 
-	time = strtol(argv[1], &end, 0);
-	if (!end || *end)
-		return 1;
-
-	NLA_PUT_U32(msg, NL80211_ATTR_WIPHY_FREQ, freq);
 	NLA_PUT_U32(msg, NL80211_ATTR_DURATION, time);
 	return 0;
+
  nla_put_failure:
 	return -ENOBUFS;
 }
 
-COMMAND(roc, start, "<freq> <time in ms>", NL80211_CMD_REMAIN_ON_CHANNEL, 0, CIB_NETDEV, handle_roc_start, "");
+COMMAND(roc, start, "[-l] <link id> <freq> [HT40+|HT40-|80MHz|160MHz|320MHz] <time in ms>",
+	NL80211_CMD_REMAIN_ON_CHANNEL, 0, CIB_NETDEV, handle_roc_start,
+	"Start off-channel scan for configurable dwell time");
-- 
