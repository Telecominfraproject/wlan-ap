From a2c38d13c4e34e7c978bc7c39d5cac35fba540f6 Mon Sep 17 00:00:00 2001
From: Logapriya P <logapriy@qti.qualcomm.com>
Date: Mon, 16 Jun 2025 22:34:01 +0530
Subject: [PATCH] iw : Add primary link migration vendor support

Usage : iw wlan<X> vendor_qcom link_migrate <link ID> [MAC address]

Providing the link ID is mandatory, while the MAC address is optional.

If a MAC address is provided, only the single ML station matching the given
MAC address as the MLD address will be migrated to the specified link ID.
If only the link ID is given, all ML stations in the system connected to
the specified wlanX and having the primary link on the given link ID will
be migrated to the host-chosen next primary link ID.

Signed-off-by: Logapriya P <logapriy@qti.qualcomm.com>
---
 vendor_qcom.c | 79 +++++++++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 79 insertions(+)
 create mode 100644 vendor_qcom.c

--- /dev/null
+++ b/vendor_qcom.c
@@ -0,0 +1,78 @@
+/*
+ * Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
+ * SPDX-License-Identifier: ISC
+ */
+
+#include <errno.h>
+#include <string.h>
+
+#include <netlink/genl/genl.h>
+#include <netlink/genl/family.h>
+#include <netlink/genl/ctrl.h>
+#include <netlink/msg.h>
+#include <netlink/attr.h>
+
+#include "nl80211.h"
+#include "iw.h"
+
+SECTION(vendor_qcom);
+
+static int qca_vendor_handle_pri_link_migrate(struct nl80211_state *state, struct nl_msg *msg,
+					      int argc, char *argv[], enum id_input id)
+{
+	unsigned char mac_addr[ETH_ALEN];
+	unsigned int link_id;
+	int ret = 0;
+	struct nlattr *attr;
+
+	if (argc > 2) {
+		ret = -EINVAL;
+		goto exit;
+	}
+
+	nla_put_u32(msg, NL80211_ATTR_VENDOR_ID, OUI_QCA);
+	nla_put_u32(msg, NL80211_ATTR_VENDOR_SUBCMD,
+		    QCA_NL80211_VENDOR_SUBCMD_PRI_LINK_MIGRATE);
+
+	ret = sscanf(argv[0], "0x%x", &link_id);
+	if (ret != 1) {
+		printf("Link ID must start with 0x\n");
+		goto exit;
+	}
+
+	attr = nla_nest_start(msg, NL80211_ATTR_VENDOR_DATA);
+	if (!attr)
+		return -ENOBUFS;
+
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_NEW_PRI_LINK_ID, link_id);
+
+	argc--;
+	argv++;
+
+	if (argc) {
+		if (mac_addr_a2n(mac_addr, argv[0])) {
+			printf("Invalid MAC address\n");
+			ret = 2;
+			goto exit;
+		}
+
+		NLA_PUT(msg, QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_MLD_MAC_ADDR, ETH_ALEN,
+			mac_addr);
+	}
+
+	nla_nest_end(msg, attr);
+	ret = 0;
+
+exit:
+	if (ret)
+		printf("Usage: error\n");
+
+	return ret;
+
+nla_put_failure:
+	printf("MAC nla put error\n");
+	return -ENOBUFS;
+}
+
+COMMAND(vendor_qcom, link_migrate, "[link_migrate <Link_id> <MAC ADdress>]", NL80211_CMD_VENDOR,
+	0, CIB_NETDEV, qca_vendor_handle_pri_link_migrate, ".");
--- a/iw.h
+++ b/iw.h
@@ -56,6 +56,8 @@ enum nlmsgerr_attrs {
 #define DBM_TO_MBM(gain) ((gain) * 100)
 #define MBM_TO_DBM(gain) ((gain) / 100)
 
+#define OUI_QCA 0x001374
+
 struct nl80211_state {
 	struct nl_sock *nl_sock;
 	int nl80211_id;
@@ -80,6 +82,7 @@ enum qca_nl80211_vendor_subcmds {
 	QCA_NL80211_VENDOR_SUBCMD_SDWF_PHY_OPS = 235,
 	QCA_NL80211_VENDOR_SUBCMD_SDWF_DEV_OPS = 236,
 	QCA_NL80211_VENDOR_SUBCMD_DCS_WLAN_INTERFERENCE_COMPUTE = 243,
+	QCA_NL80211_VENDOR_SUBCMD_PRI_LINK_MIGRATE = 256,
 	QCA_NL80211_VENDOR_SUBCMD_TELEMETRY_GETSTATS = 334,
 };
 /* Attributes for data used by
@@ -287,6 +290,18 @@ enum qca_wlan_vendor_attr_dcs {
 		QCA_WLAN_VENDOR_ATTR_DS_AFTER_LAST - 1
 };
 
+enum qca_wlan_vendor_attr_pri_link_migrate {
+	QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_INVALID = 0,
+	QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_MLD_MAC_ADDR,
+	QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_CURRENT_PRI_LINK_ID,
+	QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_NEW_PRI_LINK_ID,
+
+	/* keep this last */
+	QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_AFTER_LAST,
+	QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_MAX =
+	QCA_WLAN_VENDOR_ATTR_PRI_LINK_MIGR_AFTER_LAST - 1,
+};
+
 #define HANDLER_RET_USAGE 1
 #define HANDLER_RET_DONE 3
 
