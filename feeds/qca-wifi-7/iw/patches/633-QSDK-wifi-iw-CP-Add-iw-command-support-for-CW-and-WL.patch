From 9751d6481f6c52226a5e7df82c469d46c714d772 Mon Sep 17 00:00:00 2001
From: Nagarajan Maran <nmaran@qti.qualcomm.com>
Date: Wed, 30 Jul 2025 11:28:20 +0530
Subject: [PATCH] QSDK: wifi: iw: CP: Add iw command support for CW and WLAN
 interference

Porting changes from mainline requires updating the vendor subcommand
number in the driver. Update vendor subcommand number in iw to match
driver changes.

Patch-dependency:
	621-QSDK-iw-wifi-Add-command-support-for-CW-WLAN-interfe.patch

Signed-off-by: Nagarajan Maran <nmaran@qti.qualcomm.com>
---
 iw.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/iw.h b/iw.h
index f00baaa7e7dc..4d31bee93706 100644
--- a/iw.h
+++ b/iw.h
@@ -81,9 +81,9 @@ enum id_input {
 enum qca_nl80211_vendor_subcmds {
 	QCA_NL80211_VENDOR_SUBCMD_SDWF_PHY_OPS = 235,
 	QCA_NL80211_VENDOR_SUBCMD_SDWF_DEV_OPS = 236,
-	QCA_NL80211_VENDOR_SUBCMD_DCS_WLAN_INTERFERENCE_COMPUTE = 243,
 	QCA_NL80211_VENDOR_SUBCMD_PRI_LINK_MIGRATE = 256,
 	QCA_NL80211_VENDOR_SUBCMD_TELEMETRY_GETSTATS = 334,
+	QCA_NL80211_VENDOR_SUBCMD_DCS_WLAN_INTERFERENCE_COMPUTE = 350,
 };
 /* Attributes for data used by
  * QCA_NL80211_VENDOR_SUBCMD_SET_WIFI_CONFIGURATION and
-- 
2.34.1

