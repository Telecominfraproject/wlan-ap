From 5b5bddabcdf88ba01ddd006a900a30c28433ed3b Mon Sep 17 00:00:00 2001
From: Nagarajan Maran <nmaran@qti.qualcomm.com>
Date: Fri, 25 Jul 2025 15:47:50 +0530
Subject: [PATCH] QSDK: wifi: iw: Handle additional SLA parameters

Add additional SLA parameters: Packet Error Rate, MCS minimum
threshold, MCS maximum threshold, and Retries threshold for SLA DETECT
per second and SLA THRESHOLD configurations.

Signed-off-by: Nagarajan Maran <nmaran@qti.qualcomm.com>
---
 iw.h        |  8 ++++++++
 telemetry.c | 58 +++++++++++++++++++++++++++++++++++++++++++++--------
 2 files changed, 58 insertions(+), 8 deletions(-)

--- a/iw.h
+++ b/iw.h
@@ -170,6 +170,10 @@ enum qca_wlan_vendor_attr_sdwf_sla_detec
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_DELAY_BOUND = 6,
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_MSDU_TTL = 7,
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_MSDU_RATE_LOSS = 8,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_PKT_ERROR_RATE = 9,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_MCS_MIN_THRESHOLD = 10,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_MCS_MAX_THRESHOLD = 11,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_RETRIES_THRESHOLD = 12,
 
 	/* keep last */
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_AFTER_LAST,
@@ -195,6 +199,10 @@ enum qca_wlan_vendor_attr_sdwf_sla_thres
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_DELAY_BOUND = 6,
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_MSDU_TTL = 7,
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_MSDU_RATE_LOSS = 8,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_PKT_ERROR_RATE = 9,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_MCS_MIN_THRESHOLD = 10,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_MCS_MAX_THRESHOLD = 11,
+	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_RETRIES_THRESHOLD = 12,
 
 	/* keep last */
 	QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_AFTER_LAST,
--- a/telemetry.c
+++ b/telemetry.c
@@ -43,8 +43,8 @@
 #define streq(a, b) (strcmp((a), (b)) == 0)
 
 #define TELEMETRY_SLA_SAMPLES_CONFIG_NUM_OF_PARAMS       4
-#define TELEMETRY_SLA_THERSHOLD_CONFIG_NUM_OF_PARAMS     8
-#define TELEMETRY_SLA_DETECTION_CONFIG_NUM_OF_PARAMS     8
+#define TELEMETRY_SLA_THERSHOLD_CONFIG_NUM_OF_PARAMS     12
+#define TELEMETRY_SLA_DETECTION_CONFIG_NUM_OF_PARAMS     12
 
 #define HTT_STATS          0x10000000
 #define MGMT_STATS         0x20000000
@@ -73,6 +73,10 @@ struct telemetry_sdwf_sla_thershold {
 	uint32_t delay_bound;
 	uint32_t msdu_ttl;
 	uint32_t msdu_rate_loss;
+	uint8_t per;
+	uint8_t mcs_min_thres;
+	uint8_t mcs_max_thres;
+	uint8_t retries_thres;
 };
 
 enum telemetry_sdwf_sla_detect {
@@ -92,6 +96,10 @@ struct telemetry_sdwf_sla_detect_param {
 	uint32_t delay_bound;
 	uint32_t msdu_ttl;
 	uint32_t msdu_rate_loss;
+	uint8_t per;
+	uint8_t mcs_min_thres;
+	uint8_t mcs_max_thres;
+	uint8_t retries_thres;
 };
 
 
@@ -177,6 +185,10 @@ static int handle_telemetry_sdwf_sla_the
 	sla_thershold_cfg.delay_bound = strtoul(argv[5], &end, 10);
 	sla_thershold_cfg.msdu_ttl = strtoul(argv[6], &end, 10);
 	sla_thershold_cfg.msdu_rate_loss = strtoul(argv[7], &end, 10);
+	sla_thershold_cfg.per = strtoul(argv[8], &end, 10);
+	sla_thershold_cfg.mcs_min_thres = strtoul(argv[9], &end, 10);
+	sla_thershold_cfg.mcs_max_thres = strtoul(argv[10], &end, 10);
+	sla_thershold_cfg.retries_thres = strtoul(argv[11], &end, 10);
 
 	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_PHY_OPERATION, QCA_WLAN_VENDOR_SDWF_PHY_OPER_SLA_THRESHOLD_SET);
 	sla_params = nla_nest_start(msg, QCA_WLAN_VENDOR_ATTR_SDWF_PHY_SLA_THRESHOLD_PARAMS);
@@ -199,6 +211,14 @@ static int handle_telemetry_sdwf_sla_the
 		    sla_thershold_cfg.msdu_ttl);
 	nla_put_u32(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_MSDU_RATE_LOSS,
 		    sla_thershold_cfg.msdu_rate_loss);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_PKT_ERROR_RATE,
+		   sla_thershold_cfg.per);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_MCS_MIN_THRESHOLD,
+		   sla_thershold_cfg.mcs_min_thres);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_MCS_MAX_THRESHOLD,
+		   sla_thershold_cfg.mcs_max_thres);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_THRESHOLD_RETRIES_THRESHOLD,
+		   sla_thershold_cfg.retries_thres);
 
 	nla_nest_end(msg, sla_params);
 	nla_nest_end(msg, telemetry_cfg);
@@ -208,12 +228,15 @@ err:
 	printf("invalid telemetry sla thershold configuration command format: Usage\n");
 	printf("\t iw phy <phyname> telemetry sla_thershold <service_id> ");
 	printf(" <min_throughput_rate> <max_throughput_rate> <burst_size> <service_interval> ");
-	printf(" <delay_bound> <msdu_ttl> <msdu_rate_loss> \n");
+	printf(" <delay_bound> <msdu_ttl> <msdu_rate_loss> <packet_error_rate>"
+	       " <mcs_min_threshold> <mcs_max_threshold> <retries_threshold> \n");
 	return -EINVAL;
 }
 
-COMMAND(telemetry, sla_thershold, "<service_id> <min_throughput_rate> <max_throughput_rate>"
-"<burst_size> <service_interval> <delay_bound> <msdu_ttl> <msdu_rate_loss>", NL80211_CMD_VENDOR, 0,
+COMMAND(telemetry, sla_thershold, "<service_id> <min_throughput_rate> <max_throughput_rate> "
+"<burst_size> <service_interval> <delay_bound> <msdu_ttl> <msdu_rate_loss> "
+"<packet_error_rate> <mcs_min_threshold> <mcs_max_threshold> "
+"<retries_threshold>", NL80211_CMD_VENDOR, 0,
 CIB_PHY, handle_telemetry_sdwf_sla_thershold_cfg, ".");
 
 
@@ -248,6 +271,10 @@ static int handle_telemetry_sdwf_sla_det
 	telemetry_param.delay_bound = strtoul(argv[5], &end, 10);
 	telemetry_param.msdu_ttl = strtoul(argv[6], &end, 10);
 	telemetry_param.msdu_rate_loss = strtoul(argv[7], &end, 10);
+	telemetry_param.per = strtoul(argv[8], &end, 10);
+	telemetry_param.mcs_min_thres = strtoul(argv[9], &end, 10);
+	telemetry_param.mcs_max_thres = strtoul(argv[10], &end, 10);
+	telemetry_param.retries_thres = strtoul(argv[11], &end, 10);
 
 
 	nla_put_u32(msg, NL80211_ATTR_VENDOR_ID, OUI_QCA);
@@ -279,20 +306,35 @@ static int handle_telemetry_sdwf_sla_det
 		    telemetry_param.msdu_ttl);
 	nla_put_u32(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_MSDU_RATE_LOSS,
 		    telemetry_param.msdu_rate_loss);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_PKT_ERROR_RATE,
+		   telemetry_param.per);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_MCS_MIN_THRESHOLD,
+		   telemetry_param.mcs_min_thres);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_MCS_MAX_THRESHOLD,
+		   telemetry_param.mcs_max_thres);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SLA_DETECT_RETRIES_THRESHOLD,
+		   telemetry_param.retries_thres);
 	nla_nest_end(msg, sla_params);
 	nla_nest_end(msg, telemetry_cfg);
 
 	return NL_OK;
 
 err:
-	printf("invalid telemetry sla breach detection configuration command format: Usage\n");
-	printf("\t iw phy <phyname> telemetry sla_detection_cfg <detection_option> <min_throughput_rate> <max_throughput_rate> <burst_size> <service_interval> <delay_bound> <msdu_ttl> <msdu_rate_loss>\n");
+	printf("invalid telemetry sla breach detection configuration "
+	       "command format: Usage\n");
+	printf("\t iw phy <phyname> telemetry sla_detection_cfg "
+	       "<detection_option> <min_throughput_rate> "
+	       "<max_throughput_rate> <burst_size> <service_interval> "
+	       "<delay_bound> <msdu_ttl> <msdu_rate_loss> "
+	       "<packet_error_rate> <mcs_min_threshold> "
+	       "<mcs_max_threshold> <retries_threshold>\n");
 	return -EINVAL;
 }
 
 COMMAND(telemetry, sla_detection_cfg, "<detection_option> <min_throughput_rate>"
 "<max_throughput_rate> <burst_size> <service_interval> <delay_bound> <msdu_ttl>"
-"<msdu_rate_loss>", NL80211_CMD_VENDOR, 0, CIB_PHY,
+"<msdu_rate_loss> <packet_error_rate> <mcs_min_threshold>"
+"<mcs_max_threshold> <retries_threshold>", NL80211_CMD_VENDOR, 0, CIB_PHY,
 handle_telemetry_sdwf_sla_detection_cfg, ".");
 
 #define TELEMETRY_SLA_CLEAR_STATS_MAX_ARG 1
