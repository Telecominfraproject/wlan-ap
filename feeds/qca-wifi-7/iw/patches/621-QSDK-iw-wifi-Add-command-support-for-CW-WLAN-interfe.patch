From 17b3828d972c17641bc4b6dba95d03ff0e7b5ec4 Mon Sep 17 00:00:00 2001
From: Amit Pandit <quic_pamit@quicinc.com>
Date: Wed, 22 May 2024 21:09:53 +0530
Subject: [PATCH] QSDK: iw: wifi: Add command support for CW & WLAN
 interference.

CW and WLAN interference support is added as part of the driver,
this can be enabled/disabled at runtime by the userspace,
adding iw command support to enable/disable the intereference.

CW interference would be supported using NL80211_CMD_UPDATE_AP
command with atrribute NL80211_ATTR_INTERFERENCE_TYPE.

WLAN interference would be supported using vendor nl command,
QCA_NL80211_VENDOR_SUBCMD_DCS_WLAN_INTERFERENCE_COMPUTE with
atrribute QCA_WLAN_VENDOR_ATTR_DCS_WLAN_INTERFERENCE_CONFIGURE.

Signed-off-by: Amit Pandit <quic_pamit@quicinc.com>
---
 dcs.c       | 81 +++++++++++++++++++++++++++++++++++++++++++++++++++++
 interface.c | 47 +++++++++++++++++++++++++++++++
 iw.h        | 11 ++++++++
 3 files changed, 139 insertions(+)
 create mode 100644 dcs.c

--- /dev/null
+++ b/dcs.c
@@ -0,0 +1,75 @@
+#include <errno.h>
+#include <stdlib.h>
+#include <string.h>
+#include <netlink/genl/genl.h>
+#include <netlink/genl/family.h>
+#include <netlink/genl/ctrl.h>
+#include <netlink/msg.h>
+#include <netlink/attr.h>
+
+#include "nl80211.h"
+#include "iw.h"
+
+#define OUI_QCA 0x001374
+
+SECTION(dcs);
+
+static int handle_dcs_disable(struct nl80211_state *state,
+			      struct nl_msg *msg, int argc, char **argv,
+			      enum id_input id)
+{
+	struct nlattr *stats;
+	uint8_t link_id = 0xF;
+	/* Put data to disable DCS */
+	if (argc == 2 && (strcmp(argv[0], "-l") == 0))
+		link_id = atoi(argv[1]);
+
+	nla_put_u32(msg, NL80211_ATTR_VENDOR_ID, OUI_QCA);
+	nla_put_u32(msg, NL80211_ATTR_VENDOR_SUBCMD,
+		    QCA_NL80211_VENDOR_SUBCMD_DCS_WLAN_INTERFERENCE_COMPUTE);
+
+	stats = nla_nest_start(msg, NL80211_ATTR_VENDOR_DATA);
+	if (!stats)
+		return -ENOBUFS;
+
+	if (link_id != 0xF)
+		nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_MLO_LINK_ID, link_id);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_DCS_WLAN_INTERFERENCE_CONFIGURE, 0);
+	nla_nest_end(msg, stats);
+
+	return NL_OK;
+}
+COMMAND(dcs, disable, "",
+	NL80211_CMD_VENDOR, 0, CIB_PHY,	handle_dcs_disable, ".");
+COMMAND(dcs, disable, "-l <link_id[0/1/2/3]>",
+	NL80211_CMD_VENDOR, 0, CIB_NETDEV, handle_dcs_disable, ".");
+
+static int handle_dcs_enable(struct nl80211_state *state,
+			     struct nl_msg *msg, int argc, char **argv,
+			     enum id_input id)
+{
+	struct nlattr *stats;
+	uint8_t link_id = 0xF;
+	/* Put data to enable DCS */
+	if (argc == 2 && (strcmp(argv[0], "-l") == 0))
+		link_id = atoi(argv[1]);
+
+	nla_put_u32(msg, NL80211_ATTR_VENDOR_ID, OUI_QCA);
+	nla_put_u32(msg, NL80211_ATTR_VENDOR_SUBCMD,
+		    QCA_NL80211_VENDOR_SUBCMD_DCS_WLAN_INTERFERENCE_COMPUTE);
+
+	stats = nla_nest_start(msg, NL80211_ATTR_VENDOR_DATA);
+	if (!stats)
+		return -ENOBUFS;
+
+	if (link_id != 0xF)
+		nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_MLO_LINK_ID, link_id);
+	nla_put_u8(msg, QCA_WLAN_VENDOR_ATTR_DCS_WLAN_INTERFERENCE_CONFIGURE, 1);
+	nla_nest_end(msg, stats);
+
+	return NL_OK;
+}
+COMMAND(dcs, enable, "",
+	NL80211_CMD_VENDOR, 0, CIB_PHY, handle_dcs_enable, ".");
+COMMAND(dcs, enable, "-l <link_id[0/1/2/3]>",
+	NL80211_CMD_VENDOR, 0, CIB_NETDEV, handle_dcs_enable, ".");
--- a/interface.c
+++ b/interface.c
@@ -1274,4 +1274,54 @@ static int handle_interface_ap_ps (struc
 	COMMAND(set, ap_ps, "[-l] <link id> <Enable[1]/Disable[0]>",
 		NL80211_CMD_UPDATE_AP, 0, CIB_NETDEV, handle_interface_ap_ps, NULL);
 
+static int handle_set_intf_detect(struct nl80211_state *state,
+				  struct nl_msg *msg,
+				  int argc, char **argv,
+				  enum id_input id)
+{
+	char *end;
+	uint8_t intf_bitmap = 0;
+	int i = 0;
 
+	if (argc == 3) {
+		if (!strcmp(argv[0], "-l")) {
+			unsigned int link_id;
+
+			link_id = strtol(argv[1], &end, 10);
+			if (*end)
+				return 1;
+			if (link_id < MAX_MLD_LINK) {
+				NLA_PUT_U8(msg, NL80211_ATTR_MLO_LINK_ID, link_id);
+				i = 2;
+			} else {
+				printf("Invalid parameter link_id: %s\n", argv[1]);
+				return 1;
+			}
+		} else {
+			printf("Invalid parameter: %s\n", argv[0]);
+			return 1;
+		}
+	} else {
+		if (argc != 1)
+			return 1;
+	}
+
+	intf_bitmap = strtol(argv[i], &end, 10);
+	if (intf_bitmap > 1) {
+		printf("Invalid parameter: %s\n", argv[i]);
+		return 1;
+	}
+
+	if (*end)
+		return 2;
+
+	NLA_PUT_U8(msg, NL80211_ATTR_INTERFERENCE_TYPE, intf_bitmap);
+	return 0;
+
+nla_put_failure:
+	return -ENOBUFS;
+}
+COMMAND(set, intf_detect, "<Disable[0]/Enable CW[1]>",
+	NL80211_CMD_UPDATE_AP, 0, CIB_PHY, handle_set_intf_detect, NULL);
+COMMAND(set, intf_detect, "[-l] <link id> <Disable[0]/Enable CW[1]>",
+	NL80211_CMD_UPDATE_AP, 0, CIB_NETDEV, handle_set_intf_detect, NULL);
--- a/iw.h
+++ b/iw.h
@@ -72,6 +72,7 @@ enum id_input {
 enum qca_nl80211_vendor_subcmds {
 	QCA_NL80211_VENDOR_SUBCMD_SDWF_PHY_OPS = 235,
 	QCA_NL80211_VENDOR_SUBCMD_SDWF_DEV_OPS = 236,
+	QCA_NL80211_VENDOR_SUBCMD_DCS_WLAN_INTERFERENCE_COMPUTE = 243,
 	QCA_NL80211_VENDOR_SUBCMD_TELEMETRY_GETSTATS = 334,
 };
 /* Attributes for data used by
@@ -268,6 +269,16 @@ enum qca_wlan_vendor_sdwf_sla_breach_typ
 	QCA_WLAN_VENDOR_SDWF_SLA_BREACH_PARAM_TYPE_MAX,
 };
 
+enum qca_wlan_vendor_attr_dcs {
+	QCA_WLAN_VENDOR_ATTR_DCS_INVALID = 0,
+	QCA_WLAN_VENDOR_ATTR_MLO_LINK_ID,
+	QCA_WLAN_VENDOR_ATTR_DCS_WLAN_INTERFERENCE_CONFIGURE,
+	/* Keep last */
+	QCA_WLAN_VENDOR_ATTR_DS_AFTER_LAST,
+	QCA_WLAN_VENDOR_ATTR_DS_MAX =
+		QCA_WLAN_VENDOR_ATTR_DS_AFTER_LAST - 1
+};
+
 #define HANDLER_RET_USAGE 1
 #define HANDLER_RET_DONE 3
 
