From a764c39553728aa932d2914bcb2898e61c10b2c7 Mon Sep 17 00:00:00 2001
From: Amith A <amitajit@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 12:02:20 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:IW: Display supported power mode and tx power in
 channels command

Extend the "channels" command to display supported power modes and tx
powers in each power mode for every 6 GHz channel.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Path-dependency:
subsys/0332-01-UPSTREAM-PROTOCOL-wifi-cfg80211-Add-supported-power-mode.patch
subsys/0332-02-UPSTREAM-PROTOCOL-wifi-mac80211-Add-a-mac80211_config_op.patch
ath12k/0436-0001-UPSTREAM-PROTOCOL-wifi-ath12k-Add-an-ath12k_ops-to-fetch.patch

Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 nl80211.h | 30 ++++++++++++++++++++++++++++++
 phy.c     | 39 +++++++++++++++++++++++++++++++++++++++
 2 files changed, 69 insertions(+)

--- a/nl80211.h
+++ b/nl80211.h
@@ -4496,6 +4496,13 @@ enum nl80211_wmm_rule {
  *	otherwise completely disabled.
  * @NL80211_FREQUENCY_ATTR_ALLOW_6GHZ_VLP_AP: This channel can be used for a
  *	very low power (VLP) AP, despite being NO_IR.
+ * @NL80211_FREQUENCY_ATTR_ALLOW_20MHZ_ACTIVITY: This channel can be acitve in
+ *     20 MHz bandwidth, despite being NO_IR.
+ * @NL80211_FREQUENCY_ATTR_6GHZ_SUPP_PWR_MODES: Denotes the power modes
+ *	supported by the channel. If 0th bit is set, it indicates that LPI power
+ *	mode is supported. If 1st bit is set, SP power mode is supported and if
+ *	2nd bit is set, VLP power mode is supported.
+ * @NL80211_FREQUENCY_ATTR_6GHZ_TXPOWERS: Tx powers in each supported power mode
  * @NL80211_FREQUENCY_ATTR_MAX: highest frequency attribute number
  *	currently defined
  * @__NL80211_FREQUENCY_ATTR_AFTER_LAST: internal use
@@ -4540,12 +4547,16 @@ enum nl80211_frequency_attr {
 	NL80211_FREQUENCY_ATTR_NO_6GHZ_AFC_CLIENT,
 	NL80211_FREQUENCY_ATTR_CAN_MONITOR,
 	NL80211_FREQUENCY_ATTR_ALLOW_6GHZ_VLP_AP,
+	NL80211_FREQUENCY_ATTR_ALLOW_20MHZ_ACTIVITY,
+	NL80211_FREQUENCY_ATTR_6GHZ_SUPP_PWR_MODES,
+	NL80211_FREQUENCY_ATTR_6GHZ_TXPOWERS,
 
 	/* keep last */
 	__NL80211_FREQUENCY_ATTR_AFTER_LAST,
 	NL80211_FREQUENCY_ATTR_MAX = __NL80211_FREQUENCY_ATTR_AFTER_LAST - 1
 };
 
+
 #define NL80211_FREQUENCY_ATTR_MAX_TX_POWER NL80211_FREQUENCY_ATTR_MAX_TX_POWER
 #define NL80211_FREQUENCY_ATTR_PASSIVE_SCAN	NL80211_FREQUENCY_ATTR_NO_IR
 #define NL80211_FREQUENCY_ATTR_NO_IBSS		NL80211_FREQUENCY_ATTR_NO_IR
@@ -8587,4 +8598,26 @@ enum nl80211_interference_type {
 	NL80211_INTERFERENCE_TYPE_LAST,
 	NL80211_INTERFERENCE_TYPE_MAX = NL80211_INTERFERENCE_TYPE_LAST - 1,
 };
+
+/**
+ * enum nl80211_6g_txpower_attr - Tx powers in each power mode
+ * @__NL80211_6GHZ_TXPOWER_ATTR_INVALID: attribute number 0 is reserved
+ * @NL80211_6GHZ_TXPOWER_ATTR_LPI: Tx power in LPI power mode
+ * @NL80211_6GHZ_TXPOWER_ATTR_SP: Tx power in SP power mode
+ * @NL80211_6GHZ_TXPOWER_ATTR_VLP: Tx power in VLP power mode
+ * @NL80211_6GHZ_TXPOWER_ATTR_MAX: Maximum power mode attribute number
+ *     currently defined
+ */
+enum nl80211_6ghz_txpower_attr {
+	__NL80211_6GHZ_TXPOWER_ATTR_INVALID,
+	NL80211_6GHZ_TXPOWER_ATTR_LPI,
+	NL80211_6GHZ_TXPOWER_ATTR_SP,
+	NL80211_6GHZ_TXPOWER_ATTR_VLP,
+
+	/* keep last */
+	__NL80211_6GHZ_TXPOWER_ATTR_AFTER_LAST,
+	NL80211_6GHZ_TXPOWER_ATTR_MAX =
+		__NL80211_6GHZ_TXPOWER_ATTR_AFTER_LAST - 1
+};
+
 #endif /* __LINUX_NL80211_H */
--- a/phy.c
+++ b/phy.c
@@ -38,6 +38,29 @@ static char *dfs_state_name(enum nl80211
 	}
 }
 
+static void print_supported_power_modes(uint8_t supp_pwr_mode) {
+	printf("\t  Supported power modes:");
+	if (supp_pwr_mode & BIT(NL80211_REG_AP_LPI))
+		printf(" LPI");
+	if (supp_pwr_mode & BIT(NL80211_REG_AP_SP))
+		printf(" SP");
+	if (supp_pwr_mode & BIT(NL80211_REG_AP_VLP))
+		printf(" VLP");
+	printf("\n");
+}
+
+static void print_tx_power(struct nlattr **tb_txpwr) {
+	if (tb_txpwr[NL80211_6GHZ_TXPOWER_ATTR_LPI])
+		printf("\t  LPI Tx power: %.1f dBm\n",
+		       1.0 * nla_get_u32(tb_txpwr[NL80211_6GHZ_TXPOWER_ATTR_LPI]));
+	if (tb_txpwr[NL80211_6GHZ_TXPOWER_ATTR_SP])
+		printf("\t  SP Tx power: %.1f dBm\n",
+		       1.0 * nla_get_u32(tb_txpwr[NL80211_6GHZ_TXPOWER_ATTR_SP]));
+	if (tb_txpwr[NL80211_6GHZ_TXPOWER_ATTR_VLP])
+		printf("\t  VLP Tx power: %.1f dBm\n",
+		       1.0 * nla_get_u32(tb_txpwr[NL80211_6GHZ_TXPOWER_ATTR_VLP]));
+}
+
 static int print_channels_handler(struct nl_msg *msg, void *arg)
 {
 	struct genlmsghdr *gnlh = nlmsg_data(nlmsg_hdr(msg));
@@ -144,7 +167,30 @@ static int print_channels_handler(struct
 						if (tb_freq[NL80211_FREQUENCY_ATTR_DFS_CAC_TIME])
 							printf("\t  DFS CAC time: %u ms\n",
 							       nla_get_u32(tb_freq[NL80211_FREQUENCY_ATTR_DFS_CAC_TIME]));
+						printf("\n");
+					}
+
+					if (tb_freq[NL80211_FREQUENCY_ATTR_6GHZ_SUPP_PWR_MODES]) {
+						uint8_t supp_pwr_mode;
+
+						supp_pwr_mode = nla_get_u8(tb_freq[NL80211_FREQUENCY_ATTR_6GHZ_SUPP_PWR_MODES]);
+						print_supported_power_modes(supp_pwr_mode);
+					}
+
+					if (tb_freq[NL80211_FREQUENCY_ATTR_6GHZ_TXPOWERS]) {
+						struct nlattr *tb_txpwr[NL80211_6GHZ_TXPOWER_ATTR_MAX + 1];
+						struct nlattr *nl_txpwr;
+						int rem_txpwr;
+
+						nla_for_each_nested(nl_txpwr,
+								    tb_freq[NL80211_FREQUENCY_ATTR_6GHZ_TXPOWERS],
+								    rem_txpwr) {
+							nla_parse(tb_txpwr, NL80211_6GHZ_TXPOWER_ATTR_MAX,
+								  nla_data(nl_txpwr), nla_len(nl_txpwr), NULL);
+							print_tx_power(tb_txpwr);
+						}
 					}
+
 				}
 			}
 		}
