From c4bec2b89c29c53f8f539fc4fb9c0d91ca1bf79d Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Fri, 18 Jul 2025 17:51:19 +0530
Subject: [PATCH] mac80211-extn: Add support to compile mac80211 extensions code

Add support to compile the mac80211 extension files using the
mac80211/Makefile. The qcn_extns/Makefile is linked to
mac80211/Makefile and the qcn_extns/Kconfigis linked to the
mac80211/Kconfig.

Signed-off-by: Venkateswara Swamy Bandaru <vbandaru@qti.qualcomm.com>
Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 local-symbols         | 1 +
 net/mac80211/Kconfig  | 6 ++++++
 net/mac80211/Makefile | 5 +++++
 3 files changed, 12 insertions(+)

diff --git a/local-symbols b/local-symbols
index 6a25460..14c1e30 100644
--- a/local-symbols
+++ b/local-symbols
@@ -99,3 +99,4 @@ ATH12K_CFR=
 ATH12K_POWER_OPTIMIZATION=
 MAC80211_HWSIM=
 VIRT_WIFI=
+QCN_EXTN=
diff --git a/net/mac80211/Kconfig b/net/mac80211/Kconfig
index 6d75cad..dab8409 100644
--- a/net/mac80211/Kconfig
+++ b/net/mac80211/Kconfig
@@ -1,4 +1,8 @@
 # SPDX-License-Identifier: GPL-2.0-only
+config BACKPORT_DIR
+	string
+	option env="BACKPORT_DIR"
+
 config MAC80211
 	tristate "Generic IEEE 802.11 Networking Stack (mac80211)"
 	depends on m
@@ -369,3 +373,11 @@ config MAC80211_STA_HASH_MAX_SIZE
 	  connect more stations than the number selected here.)
 
 	  If unsure, leave the default of 0.
+
+config QCN_EXTN
+	bool "Enable QCN extensions support"
+	depends on MAC80211
+	default y
+	help
+		Select this option to enable QCN 802.11 extensions in mac80211
+		drivers that support it..
diff --git a/net/mac80211/Makefile b/net/mac80211/Makefile
index 77c02a0..e9904a1 100644
--- a/net/mac80211/Makefile
+++ b/net/mac80211/Makefile
@@ -65,6 +67,10 @@ rc80211_minstrel-$(CPTCFG_MAC80211_DEBUGFS) += \
 
 mac80211-$(CPTCFG_MAC80211_RC_MINSTREL) += $(rc80211_minstrel-y)
 
+mac80211-$(CPTCFG_QCN_EXTN) += \
+	qcn_extns/bw240MHz.o \
+	qcn_extns/driver-ops_extn.o
+
 obj-y += tests/
 
 mac80211-y += wbrf.o
-- 
2.34.1

