From 91f30e91116dd8d27f3841034a30a4a31627dc03 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Fri, 18 Jul 2025 17:56:07 +0530
Subject: [PATCH] mac80211-extn: Add 240MHz minimal patch to integrate 240MHz extensions with mac80211

240MHz is a QCN feature to support higher bandwidth in a 5GHz band.
Add 240MHz feature in the qca-driver-extns/subsys/src folder. Use this
minimal patch to link the 240MHz extension code with the mac80211
component in the backports.

This minimal patch integrates the following code with the main mac80211
component:

1. Since, 240MHz is Q-Q feature, add support to advertise this capability
through vendor IE in beacon, probe and association frames for the STA.
2. Parse QCN 240 MHz vendor element and store in struct ieee802_11_elems.
This data will be used for Q-Q 240 MHz association in 5 GHz.
3. Get the associated STA 240MHz capabilities from NL Vendor Data
and then override the STA phy capabilities with copied one during STA
association at the AP side.
4. Store Q-Q 240 MHz vendor IE in the bss data structure for STA mode
and add it in the Association Request frame sent to AP.
5. Use same data to upgrade from 160 MHz to 320 MHz (with punturing
bitmap) while generating channel data for the link.
6. Peer association parameters sent to firmware via WMI will reflect
these bandwidth changes as well.
7. EHT connections on the 5GHz band currently do not set a bandwidth limit,
which may prevent the use of 240MHz operation when puncturing is enabled.
The default behavior does not explicitly allow 240MHz, as the bw_limit
remains unset for 5GHz EHT.
8. Set the bw_limit to IEEE80211_CONN_BW_LIMIT_320 for 5GHz EHT connections
to enable 240MHz operation. This ensures that the connection logic
correctly reflects the capabilities of EHT in the 5GHz band.

Signed-off-by: Venkateswara Swamy Bandaru <vbandaru@qti.qualcomm.com>
Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 net/mac80211/eht.c         |  3 +++
 net/mac80211/ieee80211_i.h | 12 ++++++++++++
 net/mac80211/mlme.c        | 17 +++++++++++++++++
 net/mac80211/parse.c       | 12 ++++++++++++
 net/mac80211/scan.c        |  6 ++++++
 5 files changed, 50 insertions(+)

diff --git a/net/mac80211/eht.c b/net/mac80211/eht.c
index a14a16b..7d30f18 100644
--- a/net/mac80211/eht.c
+++ b/net/mac80211/eht.c
@@ -74,6 +74,8 @@ ieee80211_eht_cap_ie_to_sta_eht_cap(struct ieee80211_sub_if_data *sdata,
 		       &eht_cap_ie_elem->optional[mcs_nss_size],
 		       eht_ppe_size);
 
+	ieee80211_update_eht_cap_from_240mhz_nl(sdata, link_sta, sband);
+
 	eht_cap->has_eht = true;
 
 	link_sta->cur_max_bandwidth = ieee80211_sta_cap_rx_bw(link_sta);
diff --git a/net/mac80211/ieee80211_i.h b/net/mac80211/ieee80211_i.h
index 9c4a10b..242e995 100644
--- a/net/mac80211/ieee80211_i.h
+++ b/net/mac80211/ieee80211_i.h
@@ -35,6 +35,8 @@
 #include "sta_info.h"
 #include "debug.h"
 #include "drop.h"
+#include "qcn_extns/cmn_extn.h"
+
 #ifdef CPTCFG_MAC80211_NSS_SUPPORT
 #include <nss_api_if.h>
 #endif
@@ -127,6 +130,8 @@ struct ieee80211_bss {
 	bool wmm_used;
 	bool uapsd_supported;
 
+	struct ieee80211_bss_extn bss_extn;
+
 #define IEEE80211_MAX_SUPP_RATES 32
 	u8 supp_rates[IEEE80211_MAX_SUPP_RATES];
 	size_t supp_rates_len;
@@ -1450,6 +1456,8 @@ struct ieee80211_local {
 	atomic_t aql_ac_pending_airtime[IEEE80211_NUM_ACS];
 
 	const struct ieee80211_ops *ops;
+
+	const struct ieee80211_ops_extn *ops_extn;
 
 	/*
 	 * private workqueue to mac80211. mac80211 makes this accessible
@@ -1816,6 +1825,8 @@ struct ieee802_11_elems {
 	size_t total_len;
 	u32 crc;
 
+	struct ieee802_11_elems_extn elems_extn;
+
 	/* pointers to IEs */
 	const struct ieee80211_tdls_lnkie *lnk_id;
 	const struct ieee80211_ch_switch_timing *ch_sw_timing;
diff --git a/net/mac80211/mlme.c b/net/mac80211/mlme.c
index 02b96e0..51d0e0f 100644
--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -29,6 +29,7 @@
 #include "driver-ops.h"
 #include "rate.h"
 #include "led.h"
+#include "qcn_extns/cmn_extn.h"
 #include "fils_aead.h"
 
 #include <kunit/static_stub.h>
@@ -378,6 +381,9 @@ ieee80211_determine_ap_chan(struct ieee80211_sub_if_data *sdata,
 		*chandef = eht_chandef;
 	}
 
+	if (ieee802_11_determine_ap_chan_extn(elems, chandef, sdata))
+		return IEEE80211_CONN_MODE_HE;
+
 	return IEEE80211_CONN_MODE_EHT;
 }
 
@@ -1774,6 +1780,11 @@ ieee80211_add_link_elems(struct ieee80211_sub_if_data *sdata,
 		ieee80211_add_s1g_capab_ie(sdata, &sband->s1g_cap, skb);
 	}
 
+	struct ieee80211_bss *bss = (void *)cbss->priv;
+
+	ieee80211_add_qcn_vendor_ie_extn(skb, &bss->bss_extn,
+					 assoc_data->link[link_id].conn.mode);
+
 	if (iftd && iftd->vendor_elems.data && iftd->vendor_elems.len)
 		skb_put_data(skb, iftd->vendor_elems.data, iftd->vendor_elems.len);
 
@@ -5341,6 +5352,10 @@ static bool ieee80211_assoc_config_link(struct ieee80211_link_data *link,
 							    elems->eht_cap_len,
 							    link_sta);
 
+			ieee80211_bss_240mhz_to_sta_eht_cap_extn(sdata, link_sta,
+								 sband,
+								 cbss);
+
 			bss_conf->eht_support = link_sta->pub->eht_cap.has_eht;
 			bss_conf->epcs_support = bss_conf->eht_support &&
 				!!(elems->eht_cap->fixed.mac_cap_info[0] &
@@ -5827,6 +5827,8 @@ ieee80211_determine_our_sta_mode(struct ieee80211_sub_if_data *sdata,
 
 	conn->mode = IEEE80211_CONN_MODE_EHT;
 
+	ieee80211_modify_bw_limit_for_240mhz(is_5ghz, conn);
+
 	/* check bandwidth */
 	if (is_6ghz &&
 	    eht_cap->eht_cap_elem.phy_cap_info[0] & IEEE80211_EHT_PHY_CAP0_320MHZ_IN_6GHZ)
diff --git a/net/mac80211/parse.c b/net/mac80211/parse.c
index 4664b53..150fff3 100644
--- a/net/mac80211/parse.c
+++ b/net/mac80211/parse.c
@@ -33,6 +33,7 @@
 #include "wme.h"
 #include "led.h"
 #include "wep.h"
+#include "qcn_extns/cmn_extn.h"
 
 struct ieee80211_elems_parse {
 	/* must be first for kfree to work */
@@ -431,6 +434,14 @@ _ieee802_11_parse_elems_full(struct ieee80211_elems_parse_params *params,
 					}
 				}
 			}
+
+			else {
+				if (calc_crc)
+					crc = crc32_be(crc, pos - 2, elen + 2);
+				ieee802_11_parse_elems_vendor_qcn_extn(pos,
+								       elen, elems);
+			}
+
 			break;
 		case WLAN_EID_RSN:
 			elems->rsn = pos;
diff --git a/net/mac80211/scan.c b/net/mac80211/scan.c
index be461a6..83fd64f 100644
--- a/net/mac80211/scan.c
+++ b/net/mac80211/scan.c
@@ -23,6 +23,7 @@
 
 #include "ieee80211_i.h"
 #include "driver-ops.h"
+#include "qcn_extns/cmn_extn.h"
 #include "mesh.h"
 
 #define IEEE80211_PROBE_DELAY (HZ / 33)
@@ -157,6 +160,8 @@ void ieee80211_inform_bss(struct wiphy *wiphy,
 	else
 		bss->vht_cap_info = 0;
 
+	ieee80211_inform_bss_extn(cbss, elems);
+
 	kfree(elems);
 }
 
