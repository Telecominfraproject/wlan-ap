From 423edf6ef46d8308cf8858b49a697a97af9c4d4b Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Fri, 18 Jul 2025 18:15:48 +0530
Subject: [PATCH] ath12k-extn: Add support to compile ath12k extension code for ath12k

Add support to compile the ath12k extension files using the
ath12k/Makefile. The qcn_extns/Makefile is linked to ath12k/Makefile and
the qcn_extns/Kconfig is linked to the ath12k/Kconfig.

Add this patch in the qca-driver-extns/patches folder. Copy and apply
this patch into the backports for building the extension code.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Signed-off-by: Venkateswara Swamy Bandaru <vbandaru@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/Kconfig  | 6 ++++++
 drivers/net/wireless/ath/ath12k/Makefile | 2 ++
 2 files changed, 8 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/Kconfig b/drivers/net/wireless/ath/ath12k/Kconfig
index b39ad4c..f2bc492 100644
--- a/drivers/net/wireless/ath/ath12k/Kconfig
+++ b/drivers/net/wireless/ath/ath12k/Kconfig
@@ -1,4 +1,8 @@
 # SPDX-License-Identifier: BSD-3-Clause-Clear
+config BACKPORT_DIR
+	string
+	option env="BACKPORT_DIR"
+
 config ATH12K
 	tristate "Qualcomm Technologies Wi-Fi 7 support (ath12k)"
 	depends on m
@@ -133,6 +137,8 @@ config ATH12K_PPE_DS_SUPPORT
 
		Say Y to enable PPE DS Support. If unsure, say N.
 
+source "$BACKPORT_DIR/drivers/net/wireless/ath/ath12k/qcn_extns/Kconfig"
+
 config ATHDEBUG
	bool "ath12k debugging module"
	depends on ATH12K
diff --git a/drivers/net/wireless/ath/ath12k/Makefile b/drivers/net/wireless/ath/ath12k/Makefile
index 3082658..86933cc 100644
--- a/drivers/net/wireless/ath/ath12k/Makefile
+++ b/drivers/net/wireless/ath/ath12k/Makefile
@@ -44,6 +44,10 @@ ath12k-$(CPTCFG_ATH12K_PPE_DS_SUPPORT) += ppe.o
 
 obj-$(CPTCFG_ATH12K) += wifi7/
 
+ath12k-$(CPTCFG_QCN_EXTN) += \
+	qcn_extns/core_extn.o \
+	qcn_extns/vendor_extn.o
+
 ath12k-$(CPTCFG_ATH12K_DEBUGFS) += debugfs.o debugfs_htt_stats.o debugfs_sta.o
 ath12k-$(CONFIG_ACPI) += acpi.o
 ath12k-$(CPTCFG_ATH12K_TRACING) += trace.o
-- 
