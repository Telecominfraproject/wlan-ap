From da6478386466b90717abca30b1cb790d043d5ad4 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Wed, 2 Apr 2025 12:47:48 +0530
Subject: [PATCH 01/25] config: ath: Add depends on wext_core

Add depends on wext_core and removed unwanted configs

Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
Signed-off-by: Kaviarasu Sanjeevi <quic_kaviaras@quicinc.com>
---
 net/wireless/Kconfig | 17 +----------------
 1 file changed, 1 insertion(+), 16 deletions(-)

diff --git a/net/wireless/Kconfig b/net/wireless/Kconfig
index 9e2ce3b..428862d 100644
--- a/net/wireless/Kconfig
+++ b/net/wireless/Kconfig
@@ -1,19 +1,4 @@
 # SPDX-License-Identifier: GPL-2.0-only
-config WIRELESS_EXT
-	bool
-
-config WEXT_CORE
-	def_bool y
-	depends on CFG80211_WEXT || WIRELESS_EXT
-
-config WEXT_PROC
-	def_bool y
-	depends on PROC_FS
-	depends on WEXT_CORE
-
-config WEXT_PRIV
-	bool
-
 config CFG80211
 	tristate "cfg80211 - wireless configuration API"
 	depends on m
@@ -188,7 +173,7 @@ config CFG80211_CRDA_SUPPORT
 
 config CFG80211_WEXT
 	bool "cfg80211 wireless extensions compatibility"
-	select WEXT_CORE
+	depends on WEXT_CORE
 	help
 	  Enable this option if you need old userspace for wireless
 	  extensions with cfg80211-based drivers.
-- 
