From 785e13d6099e76a7d57c863b3519230035732cfc Mon Sep 17 00:00:00 2001
From: Gautham Kumar Senthilkumaran <gauthamk@qti.qualcomm.com>
Date: Tue, 15 Jul 2025 18:05:53 +0530
Subject: [PATCH] UPSTREAM:CP: wifi:ath11K: Fix invalid address access in tx_arvif

During the ath11k_mac_op_bss_info_changed call from mac80211 to driver,
need to check the mbssid config from mac80211 and get that vif config
store it in the local pointer for accessing mbssid.

Currently that arvif pointer does not have NULL assignment during
initialization which leads to get invalid memory address inside that pointer.
This invalid address will pass the sanity check and
assign invalid address to the other paramter.

Fix this invalid address by allocating proper NULL if valid mbssid vif is not
present from mac80211.

Signed-off-by: Gautham Kumar Senthilkumaran <gauthamk@qti.qualcomm.com>

--- a/drivers/net/wireless/ath/ath11k/mac.c
+++ b/drivers/net/wireless/ath/ath11k/mac.c
@@ -1758,9 +1758,9 @@ static int ath11k_mac_set_vif_params(str
 static struct ath11k_vif *ath11k_mac_get_tx_arvif(struct ath11k_vif *arvif)
 {
 	// TODO need to revisit
-	/*if (arvif->vif->mbssid_tx_vif)
-		return ath11k_vif_to_arvif(arvif->vif->mbssid_tx_vif);
-	*/
+	if (arvif->vif->bss_conf.mbssid_tx_vif) {
+		return ath11k_vif_to_arvif(arvif->vif->bss_conf.mbssid_tx_vif);
+	}
 
 	return NULL;
 }
@@ -1773,11 +1773,6 @@ static int ath11k_mac_setup_bcn_tmpl_ema
 	u8 i = 0;
 	bool found_vdev = false;
 
-	if (!arvif->vif->bss_conf.mbssid_tx_vif)
-		return -1;
-
-	tx_arvif = (void *)arvif->vif->bss_conf.mbssid_tx_vif->drv_priv;
-
 	beacons = ieee80211_beacon_get_template_ema_list(tx_arvif->ar->hw,
 							 tx_arvif->vif, 0);
 	if (!beacons || !beacons->cnt) {
@@ -1829,14 +1824,11 @@ static int ath11k_mac_setup_bcn_tmpl_mbs
 	struct sk_buff *bcn;
 	int ret;
 
-	if (arvif->vif->bss_conf.mbssid_tx_vif) {
-		tx_arvif = (void *)arvif->vif->bss_conf.mbssid_tx_vif->drv_priv;
-		if (tx_arvif != arvif) {
-			ar = tx_arvif->ar;
-			ab = ar->ab;
-			hw = ar->hw;
-			vif = tx_arvif->vif;
-		}
+	if (tx_arvif != arvif) {
+		ar = tx_arvif->ar;
+		ab = ar->ab;
+		hw = ar->hw;
+		vif = tx_arvif->vif;
 	}
 
 	bcn = ieee80211_beacon_get_template(hw, vif, &offs, 0);
@@ -1919,9 +1911,6 @@ static void ath11k_control_beaconing(str
 	struct vdev_up_params params = { 0 };
 	int ret = 0;
 
-	if (arvif->vif->bss_conf.mbssid_tx_vif)
-		tx_arvif = (void *)arvif->vif->bss_conf.mbssid_tx_vif->drv_priv;
-
 	lockdep_assert_held(&arvif->ar->conf_mutex);
 
 	if (!info->enable_beacon) {
@@ -1952,8 +1941,7 @@ static void ath11k_control_beaconing(str
 
 	ether_addr_copy(arvif->bssid, info->bssid);
 
-	if (arvif->vif->bss_conf.mbssid_tx_vif)
-		tx_arvif = (void *)arvif->vif->bss_conf.mbssid_tx_vif->drv_priv;
+	tx_arvif = ath11k_mac_get_tx_arvif(arvif);
 
 	params.vdev_id = arvif->vdev_id;
 	params.aid = arvif->aid;
@@ -3503,7 +3491,7 @@ static void ath11k_bss_disassoc(struct i
 				struct ieee80211_vif *vif)
 {
 	struct ath11k *ar = hw->priv;
-	struct ath11k_vif *arvif = (void *)vif->drv_priv, *tx_arvif;
+	struct ath11k_vif *arvif = (void *)vif->drv_priv;
 	int ret;
 
 	lockdep_assert_held(&ar->conf_mutex);
@@ -3521,9 +3509,7 @@ static void ath11k_bss_disassoc(struct i
 			    arvif->vdev_id, ret);
 
 	arvif->is_up = false;
-	if (arvif->vif->bss_conf.mbssid_tx_vif) {
-		tx_arvif = (void *)arvif->vif->bss_conf.mbssid_tx_vif->drv_priv;
-	}
+
 	memset(&arvif->rekey_data, 0, sizeof(arvif->rekey_data));
 
 	cancel_delayed_work_sync(&arvif->connection_loss_work);
@@ -9100,8 +9086,7 @@ ath11k_mac_update_vif_chan(struct ath11k
 		params.vdev_id = arvif->vdev_id;
 		params.aid = arvif->aid;
 		params.bssid = arvif->bssid;
-		if (arvif->vif->bss_conf.mbssid_tx_vif) {
-			tx_arvif = (void *)arvif->vif->bss_conf.mbssid_tx_vif->drv_priv;
+		if (tx_arvif) {
 			params.tx_bssid = tx_arvif->bssid;
 			params.profile_idx = arvif->vif->bss_conf.bssid_index;
 			params.profile_count = BIT(arvif->vif->bss_conf.bssid_indicator);
