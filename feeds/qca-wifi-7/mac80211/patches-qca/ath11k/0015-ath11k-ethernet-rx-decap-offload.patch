From 31ff7602f6a0fa3a4e94773ee79b8951c8153db4 Tue Dec 03 15:13:44 2019 +0530
From: Manikanta Pubbisetty <mpubbise@codeaurora.org>
Date: Tue Dec 03 15:13:44 2019 +0530
Subject: ath11k: add ethernet rx decap support

Adding etherent rx decap support in the driver, with this change
we will be able to receive the packets in ethernet format.
These packets which are already in 802.3 format can be directly
forwarded to the network core without much processing in mac80211
there by releasing some CPU cycles.

Ethernet decap will be enabled by default, but can be disabled using
a modparam.

cmd:
insmod ath11k ethernet_mode=0

Change-Id: I601d4488f622b6111eb4f2fb57e9e3f1730ff059
Signed-off-by: Manikanta Pubbisetty <mpubbise@codeaurora.org>
---
--- a/drivers/net/wireless/ath/ath11k/core.c
+++ b/drivers/net/wireless/ath/ath11k/core.c
@@ -26,10 +26,10 @@ module_param_named(crypto_mode, ath11k_c
 MODULE_PARM_DESC(crypto_mode, "crypto mode: 0-hardware, 1-software");
 
 /* frame mode values are mapped as per enum ath11k_hw_txrx_mode */
-unsigned int ath11k_frame_mode = ATH11K_HW_TXRX_NATIVE_WIFI;
+unsigned int ath11k_frame_mode = ATH11K_HW_TXRX_ETHERNET;
 module_param_named(frame_mode, ath11k_frame_mode, uint, 0644);
 MODULE_PARM_DESC(frame_mode,
-		 "Datapath frame mode (0: raw, 1: native wifi (default), 2: ethernet)");
+		 "Datapath frame mode (0: raw, 1: native wifi, 2: ethernet(default))");
 
 struct ath11k_base *ath11k_soc[MAX_SOCS];
 
