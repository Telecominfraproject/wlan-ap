From a157526be131e72ff5a520045b5e089aa6e3d1c6 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Sun, 13 Jul 2025 21:31:46 +0530
Subject: [PATCH] UPSTREAM: PROTOCOL: wifi: ath11k: Use power mode from bss
 config

Currently, for filling the set TPC WMI command, ath11k uses the
power mode from the wdev. But, this field is removed and
moved to a links field of the wdev in the latest cfg80211.

To fix this, use the power mode from the bss configuration instead
of directly from the wdev.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
subsys/0048-cfg80211-mac80211-regulatory-awgn-and-6g-channel-cha.patch
subsys/0340-UPSTREAM-PROTOCOL-cfg80211-mac80211-Store-6-GHz-powe.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath11k/mac.c | 21 +++------------------
 1 file changed, 3 insertions(+), 18 deletions(-)

diff --git a/drivers/net/wireless/ath/ath11k/mac.c b/drivers/net/wireless/ath/ath11k/mac.c
index 6f7414dfb49d..783beeedb61d 100644
--- a/drivers/net/wireless/ath/ath11k/mac.c
+++ b/drivers/net/wireless/ath/ath11k/mac.c
@@ -9484,24 +9484,9 @@ void ath11k_mac_fill_reg_tpc_info(struct ath11k *ar,
 	u16 start_freq, center_freq;
 	u8 reg_6g_power_mode;
 
-	/* For STA, 6g power mode will be present in the beacon, but for AP,
-	 * AP cant parse its own beacon. Hence, we get the 6g power mode
-	 * from the wdev corresponding to the struct ieee80211_vif
-	 */
-	if (arvif->vdev_type == WMI_VDEV_TYPE_STA)
-		reg_6g_power_mode = vif->bss_conf.power_type;
-	else if (arvif->vdev_type == WMI_VDEV_TYPE_AP) {
-		struct wireless_dev *wdev = ieee80211_vif_to_wdev(vif);
-		/* With respect to ieee80211, the 6G AP power mode starts from index
-		 * 1 while the power type stored in struct wireless_dev is based on
-		 * nl80211 power type indexing which starts from 0. Hence 1 is appended
-		 */
-		if (wdev)
-			reg_6g_power_mode = wdev->reg_6g_power_mode + 1;
-		else
-			reg_6g_power_mode = 1;
-	} else
-		reg_6g_power_mode = 1;
+	reg_6g_power_mode = vif->bss_conf.power_type;
+	if (reg_6g_power_mode == IEEE80211_REG_UNSET_AP)
+		reg_6g_power_mode = IEEE80211_REG_LPI_AP;
 
 	chan = ctx->def.chan;
 	start_freq = ath11k_mac_get_6g_start_frequency(&ctx->def);
-- 
