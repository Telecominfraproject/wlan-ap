+void ath11k_coredump_download_rddm(struct ath11k_base *ab)
 {
-	struct ath11k_base *ab = container_of(work, struct ath11k_base, dump_work);
+	struct ath11k_pci *ar_pci = (struct ath11k_pci *)ab->drv_priv;
