+	list_for_each_entry_safe(rx_desc, tmp_rx_desc, used_list, list) {
 		rx_desc->in_use = false;
 
+		if (rx_desc->skb) {
+			skb = rx_desc->skb;
+			ath12k_core_dma_unmap_single(dp->dev, rx_desc->paddr,
+						     DP_RX_BUFFER_SIZE,
