+			dev_kfree_skb_any(skb);
+		}
+		dp->device_stats.free_excess_alloc_skb++;
+	}
 	spin_lock_bh(&dp->rx_desc_lock);
 	list_splice_tail(used_list, &dp->rx_desc_free_list);
 	spin_unlock_bh(&dp->rx_desc_lock);
 }
 
