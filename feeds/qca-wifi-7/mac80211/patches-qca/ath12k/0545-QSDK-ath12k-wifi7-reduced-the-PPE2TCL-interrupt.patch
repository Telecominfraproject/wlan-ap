From 9f3bc97f624f278c08df0f1a9b90727fa45286df Mon Sep 17 00:00:00 2001
From: KARTHIK KUMAR T <kartt@qti.qualcomm.com>
Date: Thu, 18 Sep 2025 11:17:52 +0530
Subject: [PATCH] QSDK:ath12k:wifi7: reduced the PPE2TCL interrupt threshold

reduced the PPE2TCL interrupt threshold timer present timer
configured as 30µs that changed to 3µs.

Patch-dependency: none

Signed-off-by: KARTHIK KUMAR T <kartt@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/hal.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/hal.h b/drivers/net/wireless/ath/ath12k/hal.h
index 5603a29..a70daac 100644
--- a/drivers/net/wireless/ath/ath12k/hal.h
+++ b/drivers/net/wireless/ath/ath12k/hal.h
@@ -926,7 +926,7 @@ struct hal_srng {
 /* Interrupt mitigation - timer threshold in us */
 #define HAL_SRNG_INT_TIMER_THRESHOLD_TX 1000
 #define HAL_SRNG_INT_TIMER_THRESHOLD_RX 200
-#define HAL_SRNG_INT_TIMER_THRESHOLD_PPE2TCL 30
+#define HAL_SRNG_INT_TIMER_THRESHOLD_PPE2TCL 3
 #define HAL_SRNG_INT_TIMER_THRESHOLD_OTHER 256
 
 enum hal_srng_mac_type {
-- 
2.34.1

