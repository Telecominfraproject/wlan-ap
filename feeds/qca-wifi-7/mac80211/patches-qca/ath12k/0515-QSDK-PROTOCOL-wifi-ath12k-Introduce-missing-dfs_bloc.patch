From 9840350858a20f22b896dd4d5e6ca58c6acd52de Mon Sep 17 00:00:00 2001
From: Vignesh U <uvignesh@qti.qualcomm.com>
Date: Tue, 19 Aug 2025 11:48:44 +0530
Subject: [PATCH] QSDK:PROTOCOL: wifi: ath12k: Introduce missing
 dfs_block_radar_events debugfs entry

Introduce the debugfs entry `dfs_block_radar_events` to enable user-space
control over radar event blocking for DFS testing. This interface was
available in ath11k but was not propagated to ath12k.

Convert the field `dfs_block_radar_events` from a bit-field to a regular
boolean to allow addressability required by debugfs_create_bool(), and
register it under the per-radio debugfs directory when 5GHz band is present.

This enables test automation and manual scripts to toggle radar blocking
via sysfs, restoring parity with ath11k functionality.

Signed-off-by: Vignesh U <uvignesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h    | 2 +-
 drivers/net/wireless/ath/ath12k/debugfs.c | 3 +++
 2 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index e86ace6..39c019f 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -1313,7 +1313,7 @@ struct ath12k {
 	bool ch_info_can_report_survey:1;
 	bool target_suspend_ack:1;
 	struct ath12k_pdev_ctrl_path_stats stats;
-	bool dfs_block_radar_events:1;
+	bool dfs_block_radar_events;
 	bool monitor_vdev_created:1;
 	bool monitor_started:1;
 	bool nlo_enabled:1;
diff --git a/drivers/net/wireless/ath/ath12k/debugfs.c b/drivers/net/wireless/ath/ath12k/debugfs.c
index be488c1..5719489 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs.c
@@ -5852,6 +5852,9 @@ void ath12k_debugfs_register(struct ath12k *ar)
 		debugfs_create_file("dfs_simulate_radar", 0200,
 				    ar->debug.debugfs_pdev, ar,
 				    &fops_simulate_radar);
+		debugfs_create_bool("dfs_block_radar_events", 0200,
+				    ar->debug.debugfs_pdev,
+				    &ar->dfs_block_radar_events);
 	}
 
 	debugfs_create_file("tpc_stats", 0400, ar->debug.debugfs_pdev, ar,
-- 
2.34.1

