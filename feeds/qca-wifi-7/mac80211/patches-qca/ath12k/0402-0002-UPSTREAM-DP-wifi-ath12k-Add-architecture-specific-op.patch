From 10171dc96dc8a5a1430a3240b3a829b38265444a Mon Sep 17 00:00:00 2001
From: Sushant Butta <sbutta@qti.qualcomm.com>
Date: Mon, 9 Jun 2025 14:22:02 +0530
Subject: [PATCH 2/5] UPSTREAM: DP: wifi: ath12k: Add architecture specific ops
 for monitor

Ath12k currently support's two different models quad ring model(mon1)
and dual ring model(mon2) which use different hardware rings.
Currently mon1 and mon2 code are intermixed, they are now
separated out into different files.

To separate out quad ring(mon1) and dual ring(mon2) model, introduce
an architecture-specific monitor ops table in ath12k_dp_mon.
These functions are invoked depending on the monitor models.

Patch-dependency:
	0402-0001-UPSTREAM-DP-wifi-ath12k-Segregation-of-Monitor-Objec.patch

Signed-off-by: Sushant Butta <sbutta@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_mon.h      | 25 +++++++++++++++++++
 .../net/wireless/ath/ath12k/wifi7/Makefile    |  4 ++-
 drivers/net/wireless/ath/ath12k/wifi7/dp.c    |  3 +++
 .../net/wireless/ath/ath12k/wifi7/dp_mon.h    | 20 +++++++++++++++
 .../net/wireless/ath/ath12k/wifi7/dp_mon1.c   | 13 ++++++++++
 .../net/wireless/ath/ath12k/wifi7/dp_mon2.c   | 12 +++++++++
 6 files changed, 76 insertions(+), 1 deletion(-)
 create mode 100644 drivers/net/wireless/ath/ath12k/wifi7/dp_mon.h
 create mode 100644 drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c
 create mode 100644 drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c

diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.h b/drivers/net/wireless/ath/ath12k/dp_mon.h
index 5aa5693..500b83e 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.h
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.h
@@ -23,10 +23,19 @@ struct dp_rxdma_mon_ring {
 	int bufs_max;
 };
 
+struct ath12k_dp_arch_mon_ops {
+};
+
 struct ath12k_dp_mon {
 	struct dp_rxdma_mon_ring rxdma_mon_buf_ring;
 	struct dp_rxdma_mon_ring tx_mon_buf_ring;
 	struct dp_rxdma_mon_ring rx_mon_status_refill_ring[MAX_RXDMA_PER_PDEV];
+	const struct ath12k_dp_arch_mon_ops *mon_ops;
+};
+
+enum dp_monitor_type {
+	ATH12K_DP_MON_TYPE_QUAD_RING,
+	ATH12K_DP_MON_TYPE_DUAL_RING
 };
 
 enum dp_monitor_mode {
@@ -94,6 +103,22 @@ struct dp_mon_tx_ppdu_info {
 	struct dp_mon_mpdu *tx_mon_mpdu;
 };
 
+static inline enum dp_monitor_type
+ath12k_dp_get_mon_type(struct ath12k_dp *dp)
+{
+	return ((dp->hw_params->rxdma1_enable) ? ATH12K_DP_MON_TYPE_DUAL_RING :
+				ATH12K_DP_MON_TYPE_QUAD_RING);
+}
+
+static inline
+const struct ath12k_dp_arch_mon_ops *ath12k_dp_mon_ops_get(struct ath12k_dp *dp)
+{
+	if (dp && dp->dp_mon)
+		return dp->dp_mon->mon_ops;
+
+	return NULL;
+}
+
 enum hal_rx_mon_status
 ath12k_dp_mon_rx_parse_mon_status(struct ath12k_pdev_dp *dp_pdev,
 				  struct ath12k_mon_data *pmon,
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/Makefile b/drivers/net/wireless/ath/ath12k/wifi7/Makefile
index 56ce8d9..82193ad 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/Makefile
+++ b/drivers/net/wireless/ath/ath12k/wifi7/Makefile
@@ -13,6 +13,8 @@ ath12k_wifi7-y += core.o \
 		  dp.o \
 		  hal.o \
 		  hal_qcn9274.o \
-		  hal_wcn7850.o
+		  hal_wcn7850.o \
+		  dp_mon1.o \
+		  dp_mon2.o
 
 ath12k_wifi7-$(CPTCFG_ATH12K_AHB) += ahb.o
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp.c b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
index a1db258..f9f5559 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
@@ -15,6 +15,7 @@
 #include "dp_tx.h"
 #include "dp_rx.h"
 #include "hal.h"
+#include "dp_mon.h"
 
 static int ath12k_wifi7_dp_service_srng(struct ath12k_dp *dp,
 					struct ath12k_ext_irq_grp *irq_grp,
@@ -204,6 +205,8 @@ struct ath12k_dp *ath12k_wifi7_dp_init(struct ath12k_base *ab)
 		goto dp_err;
 	}
 
+	ath12k_wifi7_dp_mon_ops_register(dp);
+
 	return dp;
 dp_err:
 	ath12k_wifi7_dp_deinit(dp);
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon.h b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon.h
new file mode 100644
index 0000000..4cdecfa
--- /dev/null
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon.h
@@ -0,0 +1,20 @@
+/* SPDX-License-Identifier: BSD-3-Clause-Clear */
+/*
+ * Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
+ */
+
+#include "../dp_mon.h"
+
+extern const struct ath12k_dp_arch_mon_ops ath12k_wifi7_dp_arch_mon_quad_ring_ops;
+extern const struct ath12k_dp_arch_mon_ops ath12k_wifi7_dp_arch_mon_dual_ring_ops;
+
+static inline
+void ath12k_wifi7_dp_mon_ops_register(struct ath12k_dp *dp)
+{
+	struct ath12k_dp_mon *dp_mon = dp->dp_mon;
+
+	if (ath12k_dp_get_mon_type(dp) == ATH12K_DP_MON_TYPE_DUAL_RING)
+		dp_mon->mon_ops = &ath12k_wifi7_dp_arch_mon_dual_ring_ops;
+	else
+		dp_mon->mon_ops = &ath12k_wifi7_dp_arch_mon_quad_ring_ops;
+}
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c
new file mode 100644
index 0000000..f981e07
--- /dev/null
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c
@@ -0,0 +1,13 @@
+// SPDX-License-Identifier: BSD-3-Clause-Clear
+/*
+ * Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
+ */
+
+/* This file contains the definitions related to the monitor quad ring
+ * model
+ */
+
+#include "../dp_mon.h"
+
+struct ath12k_dp_arch_mon_ops ath12k_wifi7_dp_arch_mon_quad_ring_ops = {
+};
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
new file mode 100644
index 0000000..614dc45
--- /dev/null
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -0,0 +1,12 @@
+// SPDX-License-Identifier: BSD-3-Clause-Clear
+/*
+ * Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
+ */
+
+/* This file contains the definitions related to the monitor dual ring
+ * model
+ */
+#include "../dp_mon.h"
+
+const struct ath12k_dp_arch_mon_ops ath12k_wifi7_dp_arch_mon_dual_ring_ops = {
+};
-- 
