+	HTT_WIFI_VER_11N  = 4,
+	HTT_WIFI_VER_11AC = 5,
+	HTT_WIFI_VER_11AX = 6,
+	HTT_WIFI_VER_11BE = 7,
+	HTT_WIFI_VER_11BN = 8,
+};
 #endif
