From 1bd0ffcb5961411abb8730ead1c9c3cf565516ba Mon Sep 17 00:00:00 2001
From: Alok Singh <aloksing@qti.qualcomm.com>
Date: Mon, 9 Jun 2025 13:08:56 +0530
Subject: [PATCH 06/13] UPSTREAM: DP: wifi: ath12k: add monitor mode handler by
 monitor status ring interrupt

Monitor status ring interrupt is configured in previous patch. So add
handler function __ath12k_dp_mon_process_ring() for monitor mode.

Will implement detail processing in patch 7 and 10.

Patch-dependency:
	0401-0005-UPSTREAM-DP-wifi-ath12k-add-interrupt-configuration-.patch

Signed-off-by: Alok Singh <aloksing@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_mon.c   | 13 +++++++++++++
 drivers/net/wireless/ath/ath12k/wifi7/dp.c |  6 +++++-
 2 files changed, 18 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.c b/drivers/net/wireless/ath/ath12k/dp_mon.c
index 420e1fb..918775c 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.c
@@ -3893,6 +3893,14 @@ free_skb:
 	return num_buffs_reaped;
 }
 
+static int
+__ath12k_dp_mon_process_ring(struct ath12k *ar, int mac_id,
+			     struct napi_struct *napi, int *budget)
+{
+	/* TODO:Implement monitor mode for WCN7850 here. */
+	return 0;
+}
+
 int ath12k_dp_mon_process_ring(struct ath12k_dp *dp, int mac_id,
 			       struct napi_struct *napi, int budget,
 			       enum dp_monitor_mode monitor_mode)
@@ -3912,6 +3920,11 @@ int ath12k_dp_mon_process_ring(struct ath12k_dp *dp, int mac_id,
 	if (dp->hw_params->rxdma1_enable) {
 		if (monitor_mode == ATH12K_DP_RX_MONITOR_MODE)
 			num_buffs_reaped = ath12k_dp_mon_srng_process(dp_pdev, &budget, napi);
+	} else {
+		if (dp_pdev->ar->monitor_started)
+			num_buffs_reaped =
+				__ath12k_dp_mon_process_ring(dp_pdev->ar, mac_id, napi,
+							     &budget);
 	}
 
 	rcu_read_unlock();
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp.c b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
index e606590..fe0749b 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
@@ -75,7 +75,11 @@ static int ath12k_wifi7_dp_service_srng(struct ath12k_dp *dp,
 				int id = i * dp->hw_params->num_rxdma_per_pdev + j;
 
 				if (ring_mask & BIT(id)) {
-					/* TODO: add monitor mode function */
+					work_done =
+					ath12k_dp_mon_process_ring(dp, id, napi, budget,
+								   0);
+					budget -= work_done;
+					tot_work_done += work_done;
 					if (budget <= 0)
 						goto done;
 				}
-- 
