From ea2b962ff899c001e78cb746c09e0f72fafc4c5c Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Wed, 2 Apr 2025 21:11:19 +0530
Subject: [PATCH 25/25] ath12k: Add fix to fetch board-id from dts

Add fix to fetch the board-id from dts file
when it is specified in the dts

Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
Signed-off-by: Kaviarasu Sanjeevi <quic_kaviaras@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/mhi.c | 12 +++++++++---
 drivers/net/wireless/ath/ath12k/qmi.c | 10 +++++++---
 2 files changed, 16 insertions(+), 6 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mhi.c b/drivers/net/wireless/ath/ath12k/mhi.c
index 209371d..1ccc6f5 100644
--- a/drivers/net/wireless/ath/ath12k/mhi.c
+++ b/drivers/net/wireless/ath/ath12k/mhi.c
@@ -7,6 +7,7 @@
 #include <linux/msi.h>
 #include <linux/pci.h>
 #include <linux/firmware.h>
+#include <linux/of.h>
 
 #include "core.h"
 #include "debug.h"
@@ -331,9 +332,14 @@ int ath12k_mhi_register(struct ath12k_pci *ab_pci)
 	mhi_ctrl->rddm_size = ab->hw_params->rddm_size;
 
 	if (ab->hw_params->otp_board_id_register) {
-		board_id =
-			ath12k_pci_read32(ab, ab->hw_params->otp_board_id_register);
-		board_id = u32_get_bits(board_id, OTP_BOARD_ID_MASK);
+		if (!of_property_read_u32(ab->dev->of_node, "qcom,board_id", &board_id) &&
+		    board_id != 0xFF) {
+			board_id = u32_get_bits(board_id, OTP_BOARD_ID_MASK);
+		} else {
+			board_id =
+				ath12k_pci_read32(ab, ab->hw_params->otp_board_id_register);
+			board_id = u32_get_bits(board_id, OTP_BOARD_ID_MASK);
+		}
 
 		if (!board_id || (board_id == OTP_INVALID_BOARD_ID)) {
 			ath12k_dbg(ab, ATH12K_DBG_BOOT,
diff --git a/drivers/net/wireless/ath/ath12k/qmi.c b/drivers/net/wireless/ath/ath12k/qmi.c
index 348dbc8..7db6fb7 100644
--- a/drivers/net/wireless/ath/ath12k/qmi.c
+++ b/drivers/net/wireless/ath/ath12k/qmi.c
@@ -2645,7 +2645,8 @@ int ath12k_qmi_request_target_cap(struct ath12k_base *ab)
 	struct qmi_wlanfw_cap_req_msg_v01 req = {};
 	struct qmi_wlanfw_cap_resp_msg_v01 resp = {};
 	struct qmi_txn txn;
-	unsigned int board_id = ATH12K_BOARD_ID_DEFAULT;
+	struct device *dev = ab->dev;
+	unsigned int board_id;
 	int ret = 0;
 	int r;
 	int i;
@@ -2684,10 +2685,13 @@ int ath12k_qmi_request_target_cap(struct ath12k_base *ab)
 		ab->qmi.target.chip_family = resp.chip_info.chip_family;
 	}
 
-	if (resp.board_info_valid)
+	if (!of_property_read_u32(dev->of_node, "qcom,board_id", &board_id) &&
+	    board_id != 0xFF)
+		ab->qmi.target.board_id = board_id;
+	else if (resp.board_info_valid)
 		ab->qmi.target.board_id = resp.board_info.board_id;
 	else
-		ab->qmi.target.board_id = board_id;
+		ab->qmi.target.board_id = ATH12K_BOARD_ID_DEFAULT;
 
 	if (resp.soc_info_valid)
 		ab->qmi.target.soc_id = resp.soc_info.soc_id;
-- 
