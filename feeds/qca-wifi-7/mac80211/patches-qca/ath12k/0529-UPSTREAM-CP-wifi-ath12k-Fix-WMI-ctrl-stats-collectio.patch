From d1e7e40d4d59e0c94b58b1aa5517a485cdb3c8b3 Mon Sep 17 00:00:00 2001
From: Paulson Raja L <lraja@qti.qualcomm.com>
Date: Wed, 10 Sep 2025 06:28:33 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k: Fix WMI ctrl stats collection
 failure.

WMI control path stats are expected to be collected via debugfs.
However, stats were not being populated due to incorrect handling
of PMLO stats list and conditional splicing logic based on tag_id
and 'more' flag.

Fix the issue by ensuring proper list cleanup, safe iteration, and
correct splicing of PMLO and non-PMLO stats based on tag_id.

Fixes:Ieae44c989d2 ( wifi: ath12k: Enhance wmi ctrl stats )

Patch-dependency:
0280-0001-wifi-ath12k-Add-debugfs-support.patch

Signed-off-by: Paulson Raja L <lraja@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.c | 17 ++++++++++++-----
 1 file changed, 12 insertions(+), 5 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -13248,20 +13248,28 @@ static void ath12k_wmi_ctrl_path_stats_e
 	}
 
 	spin_lock_bh(&ar->debug.wmi_ctrl_path_stats_lock);
-	if (tag_id == WMI_CTRL_PATH_PMLO_STATS)
-		list_splice_tail_init(&param.list, &ar->debug.period_wmi_list);
-	else
-		list_splice_tail_init(src, dst);
 	if (!more) {
-		if (!ar->debug.wmi_ctrl_path_stats_more_enabled)
-			ath12k_wmi_crl_path_stats_list_free(ar, &stats->pdev_stats);
-		else
-			ar->debug.wmi_ctrl_path_stats_more_enabled = false;
+		if (tag_id == WMI_CTRL_PATH_PMLO_STATS) {
+			list_splice_tail_init(&param.list, &ar->debug.period_wmi_list);
+		} else {
+			if (!ar->debug.wmi_ctrl_path_stats_more_enabled)
+				ath12k_wmi_crl_path_stats_list_free(ar,
+								    &stats->pdev_stats);
+			else
+				ar->debug.wmi_ctrl_path_stats_more_enabled = false;
+			list_splice_tail_init(src, dst);
+		}
 		complete(&ar->debug.wmi_ctrl_path_stats_rcvd);
 	} else {
-		if (!ar->debug.wmi_ctrl_path_stats_more_enabled) {
-			ath12k_wmi_crl_path_stats_list_free(ar, &stats->pdev_stats);
-			ar->debug.wmi_ctrl_path_stats_more_enabled = true;
+		if (tag_id == WMI_CTRL_PATH_PMLO_STATS) {
+			list_splice_tail_init(&param.list, &ar->debug.period_wmi_list);
+		} else {
+			if (!ar->debug.wmi_ctrl_path_stats_more_enabled) {
+				ath12k_wmi_crl_path_stats_list_free(ar,
+								    &stats->pdev_stats);
+				ar->debug.wmi_ctrl_path_stats_more_enabled = true;
+			}
+			list_splice_tail_init(src, dst);
 		}
 	}
 	spin_unlock_bh(&ar->debug.wmi_ctrl_path_stats_lock);
