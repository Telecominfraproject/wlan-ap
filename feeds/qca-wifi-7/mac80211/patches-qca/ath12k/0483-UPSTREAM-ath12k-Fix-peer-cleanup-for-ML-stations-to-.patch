From ae58cab0c96bf2f9bea85129a899f1f38d4faa1f Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <bramar@qti.qualcomm.com>
Date: Thu, 7 Aug 2025 12:20:32 +0530
Subject: [PATCH] UPSTREAM:CP: wifi:ath12k: Fix peer cleanup for ML stations
to prevent crash

The current implementation of ath12k_mac_station_remove() skips peer
cleanup for Multi-Link (ML) stations. This causes issues when a link
is removed while the station remains associated. In such cases, the
AP sends a vdev delete command without properly cleaning up the peer,
resulting in a firmware crash due to a non-zero peer count.

To address this, we can enhance the logic to allow peer cleanup for
ML stations during link removal or add.

Signed-off-by: Balamurugan Ramar <bramar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 13 +++++++------
 1 file changed, 7 insertions(+), 6 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -11866,13 +11866,12 @@ int ath12k_mac_op_change_sta_links(struc
 
 		arvif = ahvif->link[link_id];
 		arsta = ahsta->link[link_id];
+		ar = arvif->ar;
 
 		if (!arsta || !arvif)
 			return -EINVAL;
 
 		if (vif->type == NL80211_IFTYPE_AP) {
-			ar = arvif->ar;
-
 			if (ahsta->primary_link_id == link_id) {
 				/* if the peer is not undergoing migration and still the
 				 * primary link is on this removal link, disconnect whole
@@ -11902,7 +11901,9 @@ int ath12k_mac_op_change_sta_links(struc
 			if (ret)
 				ath12k_warn(ar->ab, "Failed to disassoc station: %pM for VDEV: %d\n",
 					    arsta->addr, arvif->vdev_id);
+		}
 
+		if (vif->type == NL80211_IFTYPE_AP || vif->type == NL80211_IFTYPE_STATION) {
 			ret = ath12k_mac_station_remove(ar, arvif, arsta);
 			if (ret)
 				ath12k_warn(ar->ab, "Failed to remove station: %pM for VDEV: %d\n",
@@ -11948,10 +11949,9 @@ int ath12k_mac_op_change_sta_links(struc
 								  link_id);
 			}
 
-			ath12k_wsi_load_info_stats_update(ahvif, ahsta, true);
-		} else if (vif->type == NL80211_IFTYPE_STATION)
-			ath12k_mac_free_unassign_link_sta(ahsta->ahvif->ah, arsta->ahsta,
-							  arsta->link_id);
+			if (vif->type == NL80211_IFTYPE_AP)
+				ath12k_wsi_load_info_stats_update(ahvif, ahsta, true);
+		}
 
 		/* If the link that is getting removed is the assoc link id of
 		 * the station, then move the contents of the next link to
