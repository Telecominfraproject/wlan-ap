From 55fd3eb569a025967cead2421304cb7141f5aa9c Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Date: Thu, 29 May 2025 15:52:41 +0530
Subject: [PATCH] UPSTREAM: CP: wifi: Setup MLO after sub-system recovery

mac unregister and free will only done during rmmod. Hence after device
recovers from core reset during SSR, mlo setup, mac allocate and
register are skipped.
Without MLO setup, firmware will not be able to know the partner links
and MLO client association fails. During peer delete, Q6 asserts due to
peer delete timeout.

Also take care of initiating MLO teardown during hardware group stop. This
will align with the hardware group start sequence.

Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.c b/drivers/net/wireless/ath/ath12k/core.c
index bb8b978..f6c0865 100644
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -1186,6 +1186,8 @@ static void ath12k_core_hw_group_stop(struct ath12k_hw_group *ag)
 
 	ath12k_mac_unregister(ag);
 
+	ath12k_mac_mlo_teardown(ag);
+
 	for (i = ag->num_devices - 1; i >= 0; i--) {
 		ab = ag->ab[i];
 		if (!ab)
@@ -1303,9 +1305,12 @@ static int ath12k_core_hw_group_start(struct ath12k_hw_group *ag)
 
 	lockdep_assert_held(&ag->mutex);
 
-	if (test_bit(ATH12K_GROUP_FLAG_REGISTERED, &ag->flags))
+	if (test_bit(ATH12K_GROUP_FLAG_REGISTERED, &ag->flags)) {
+		ret = ath12k_core_mlo_setup(ag);
+		if (WARN_ON(ret))
+			goto err_mac_destroy;
 		goto core_pdev_create;
-
+	}
 
 	switch (ath12k_crypto_mode) {
 	case ATH12K_CRYPT_MODE_SW:
-- 
