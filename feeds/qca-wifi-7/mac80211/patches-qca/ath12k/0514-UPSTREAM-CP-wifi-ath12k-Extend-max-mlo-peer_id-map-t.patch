From 74d82ab1a6c8e10879034bc3a9040acc19423018 Mon Sep 17 00:00:00 2001
From: Thiraviyam Mariyappan <thiraviyam.mariyappan@oss.qualcomm.com>
Date: Fri, 15 Aug 2025 12:57:29 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k: Extend max mlo peer_id map to 1024

Currently, allocate ml_peer_id_map with a fixed size of 256 bits, which
causes out-of-bound access when ml_peer_id exceeds 256, as the maximum
supported value is 1024. Fix this by extending the bitmap allocation to
1024 bits to match the supported range.

Signed-off-by: Thiraviyam Mariyappan <thiraviyam.mariyappan@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index e86ace6..89417a7 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -90,7 +90,7 @@
 #define ATH12K_INVALID_GROUP_ID  0xFF
 #define ATH12K_INVALID_DEVICE_ID 0xFF
 
-#define ATH12K_MAX_MLO_PEERS            256
+#define ATH12K_MAX_MLO_PEERS            1024
 #define ATH12K_MLO_PEER_ID_INVALID      0xFFFF
 
 #define ATH12K_MAX_ADJACENT_CHIPS   2
-- 
2.34.1

