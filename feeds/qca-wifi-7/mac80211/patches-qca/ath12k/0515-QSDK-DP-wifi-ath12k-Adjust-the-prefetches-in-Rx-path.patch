From 0d950b59b287a658896e2f903f1ec94dd8e764ff Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 13 Aug 2025 17:15:22 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Adjust the prefetches in Rx path

Adjust the prefetches in Rx path for performance improvement:
1. Change the position of prefetching for Marina
2. add prefetch for skb shinfo before delivering to stack through fast path

patch-dependency:
0465-0004-UPSTREAM-DP-Use-scratchpad-memory-in-rx-path.patch

Signed-off-by: Sai Rupesh Chevuru <chevuru@qti.qualcomm.com>
Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 29 ++++++++++++-------
 1 file changed, 18 insertions(+), 11 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index 7bb3923..c2dc641 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -991,6 +991,10 @@ static int ath12k_wifi7_dp_rx_h_mpdu(struct ath12k_pdev_dp *dp_pdev,
 					}
 				}
 			}
+
+#ifdef CONFIG_IO_COHERENCY
+			prefetch(skb_shinfo(msdu));
+#endif
 			msdu->protocol = eth_type_trans(msdu, peer->dev);
 			netif_receive_skb(msdu);
 			return ret;
@@ -1437,24 +1441,27 @@ ath12k_wifi7_dp_rx_process_received_packets(struct ath12k_dp *dp,
 
 		msdu = spd_desc_l->msdu;
 
-#ifdef CONFIG_IO_COHERENCY
-		{
-			u8 *vaddr = spd_desc_l->vaddr;
-
-			prefetch(vaddr);
-			prefetch(&vaddr[64]);
-			prefetch(&vaddr[128]);
-		}
-#endif
+#ifndef CONFIG_IO_COHERENCY
 		prefetch(msdu);
 		prefetch(&msdu->_skb_refdst);
 		prefetch(&msdu->__pkt_type_offset);
-
+#endif
 		if (likely(msdu_idx + 1 < num_msdus)) {
 			struct hal_rx_spd_data *spd_desc_next =
 				&rx_status_desc[msdu_idx + 1];
 			struct sk_buff *next_msdu = spd_desc_next->msdu;
-
+#ifdef CONFIG_IO_COHERENCY
+			{
+				u8 *vaddr = spd_desc_next->vaddr;
+
+				prefetch(vaddr);
+				prefetch(&vaddr[64]);
+				prefetch(&vaddr[128]);
+				prefetch(next_msdu);
+				prefetch(&next_msdu->_skb_refdst);
+				prefetch(&next_msdu->__pkt_type_offset);
+			}
+#endif
 			prefetch(&next_msdu->head);
 		}
 
-- 
