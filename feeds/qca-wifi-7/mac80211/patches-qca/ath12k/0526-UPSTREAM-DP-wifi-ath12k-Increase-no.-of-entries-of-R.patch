From 0abd9a62cff218af402c5de86c0d03bc8209babb Mon Sep 17 00:00:00 2001
From: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Date: Thu, 4 Sep 2025 15:15:56 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: Increase no. of entries of Rx
 Release Ring

Currently the no. of Rx descriptors is 12288 for 1G profile and
6144 for 512M profile, while the no. of entries in Rx Release Ring is
1024.

This size difference can lead to backpressure on Rx Release Ring.

In order to fix this, increase no. of entries of Rx Release Ring to
16384 for 1G profile and 8192 for 512M profile.

Patch-dependency: None

Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 178f2dd..96a9fa2 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -236,7 +236,6 @@ enum ath12k_dp_eapol_key_type {
 #define DP_TCL_STATUS_RING_SIZE		32
 #define DP_REO_DST_RING_SIZE		2048
 #define DP_REO_REINJECT_RING_SIZE	32
-#define DP_RX_RELEASE_RING_SIZE		1024
 #define DP_REO_EXCEPTION_RING_SIZE	128
 #define DP_REO_CMD_RING_SIZE		256
 #define DP_REO_STATUS_RING_SIZE		2048
@@ -245,6 +244,12 @@ enum ath12k_dp_eapol_key_type {
 #define DP_RXDMA_REFILL_RING_SIZE	2048
 #define DP_RXDMA_ERR_DST_RING_SIZE	1024
 
+#if defined(CONFIG_ATH12K_MEM_PROFILE_512M) || defined (CPTCFG_ATH12K_MEM_PROFILE_512M)
+#define DP_RX_RELEASE_RING_SIZE		8192
+#else
+#define DP_RX_RELEASE_RING_SIZE		16384
+#endif
+
 #define DP_RX_BUFFER_SIZE_LITE	1024
 #define DP_RX_BUFFER_ALIGN_SIZE	128
 
-- 
2.34.1

