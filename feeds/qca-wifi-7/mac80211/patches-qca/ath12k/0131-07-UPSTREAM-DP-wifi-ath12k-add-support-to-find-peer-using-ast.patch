From 8db236bbeb60b40ab0c29fdce9f716666d760cc9 Mon Sep 17 00:00:00 2001
From: Aniruddha Mishra <quic_anirmish@quicinc.com>
Date: Mon, 14 Apr 2025 14:23:32 +0530
Subject: [PATCH 7/9] wifi: ath12k: add support to find peer using ast

Add support to find a peer in the list of available peers
using ast hash.

For MU case, ppdu_info structure does not contain peer id for
each user. The current logic tries to find peer using same peer_id
for all the users. This logic is incorrect.

Fix it by using ast_index for peer search.

Signed-off-by: Hari Chandrakanthan <quic_haric@quicinc.com>
Signed-off-by: Aniruddha Mishra <quic_anirmish@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/dp_mon.c  |  3 +--
 drivers/net/wireless/ath/ath12k/dp_peer.c | 15 +++++++++++++++
 drivers/net/wireless/ath/ath12k/dp_peer.h |  3 +++
 3 files changed, 19 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.c b/drivers/net/wireless/ath/ath12k/dp_mon.c
index 32d4589..00a07a8 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.c
@@ -3398,8 +3398,7 @@ ath12k_dp_mon_rx_update_user_stats(struct ath12k_pdev_dp *pdev_dp,
 	if (ppdu_info->peer_id == HAL_INVALID_PEERID)
 		return;
 
-	peer = ath12k_dp_link_peer_find_by_id(dp, ppdu_info->peer_id);
-
+	peer = ath12k_dp_link_peer_find_by_ast(dp, user_stats->ast_index);
 	if (!peer) {
 		ath12k_warn(ab, "peer with peer id %d can't be found\n",
 			    ppdu_info->peer_id);
diff --git a/drivers/net/wireless/ath/ath12k/dp_peer.c b/drivers/net/wireless/ath/ath12k/dp_peer.c
index a2e80e4..6627d6e 100644
--- a/drivers/net/wireless/ath/ath12k/dp_peer.c
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.c
@@ -93,6 +93,21 @@ ath12k_dp_link_peer_find_by_id(struct ath12k_dp *dp, int peer_id)
 }
 EXPORT_SYMBOL(ath12k_dp_link_peer_find_by_id);
 
+struct ath12k_dp_link_peer *
+ath12k_dp_link_peer_find_by_ast(struct ath12k_dp *dp,
+				int ast_hash)
+{
+	struct ath12k_dp_link_peer *peer;
+
+	lockdep_assert_held(&dp->dp_lock);
+
+	list_for_each_entry(peer, &dp->peers, list)
+		if (ast_hash == peer->ast_hash)
+			return peer;
+
+	return NULL;
+}
+
 bool ath12k_dp_link_peer_exist_by_vdev_id(struct ath12k_dp *dp, int vdev_id)
 {
 	struct ath12k_dp_link_peer *peer;
diff --git a/drivers/net/wireless/ath/ath12k/dp_peer.h b/drivers/net/wireless/ath/ath12k/dp_peer.h
index 8247a50..befc8b3 100644
--- a/drivers/net/wireless/ath/ath12k/dp_peer.h
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.h
@@ -179,5 +179,8 @@ struct ath12k_dp_peer *ath12k_dp_peer_find_by_peerid_index(struct ath12k_dp *dp,
 struct ath12k_dp_link_peer *
 ath12k_dp_link_peer_find_by_peerid_index(struct ath12k_dp *dp,
 					 struct ath12k_pdev_dp *dp_pdev, u16 peer_id);
+struct ath12k_dp_link_peer *
+ath12k_dp_link_peer_find_by_ast(struct ath12k_dp *dp,
+				int ast_hash);
 
 #endif
-- 
