From 59b05de539eed999d231917c0e1b7ac45dfe9da4 Mon Sep 17 00:00:00 2001
From: Gautham Kumar Senthilkumaran <gauthamk@qti.qualcomm.com>
Date: Wed, 30 Jul 2025 14:54:31 +0530
Subject: [PATCH] UPSTREAM:CP: wifi:ath12k: Use correct lock for ahvif list
 access

Fix the lock used when accessing the RCU-protected ahvif link list.
Instead of relying on the ath12k hardware mutex, which is not suitable
for this purpose, use the wiphy mutex from mac80211, which provides the
appropriate protection for safely checking the ahvif list.

Signed-off-by: Gautham Kumar Senthilkumaran <gauthamk@qti.qualcomm.com>

--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -2048,8 +2048,9 @@ ath12k_get_arvif_from_link_id(struct ath
 	if (link_id >= ATH12K_NUM_MAX_LINKS)
 		return NULL;
 
-	return rcu_dereference_protected(ahvif->link[link_id],
-					 lockdep_is_held(&ahvif->ah->hw_mutex));
+	lockdep_assert_wiphy(ahvif->ah->hw->wiphy);
+
+	return wiphy_dereference(ahvif->ah->hw->wiphy, ahvif->link[link_id]);
 }
 
 static inline struct ath12k_hw *ath12k_hw_to_ah(struct ieee80211_hw  *hw)
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -7569,9 +7569,7 @@ int ath12k_mac_op_link_reconfig_remove(s
 	 * matter here since after link removal if peer is not migrated, it
 	 * will be anyways disconnected
 	 */
-	mutex_lock(&ahvif->ah->hw_mutex);
 	ath12k_mac_process_link_migrate_req(ahvif, &migrate_params);
-	mutex_unlock(&ahvif->ah->hw_mutex);
 
 	ret = ath12k_wmi_mlo_reconfig_link_removal(ar, arvif->vdev_id,
 						   params->reconfigure_elem,
@@ -11481,7 +11479,7 @@ void ath12k_mac_assign_middle_link_id(st
 	bool adjacent_found = false;
 	unsigned long links;
 
-	lockdep_assert_held(&ah->hw_mutex);
+	lockdep_assert_wiphy(ah->hw->wiphy);
 
 	/* 4 device: In case of 3 link STA association, Make sure to select
 	 * the middle device link as primary_link_id of sta which is adjacent
@@ -11546,14 +11544,12 @@ static bool ath12k_is_primary_link_migra
 	struct ath12k_sta *ahsta = ath12k_sta_to_ahsta(sta);
 	unsigned long removed_link = removed_links;
 	struct ath12k_vif *ahvif = ahsta->ahvif;
-	struct ath12k_hw *ah = ahvif->ah;
 	struct ath12k_link_vif *arvif;
 	bool is_primary = false;
 	struct ath12k *ar;
 	u16 link_id;
 	int ret;
 
-	mutex_lock(&ah->hw_mutex);
 
 	for_each_set_bit(link_id, &removed_link, ATH12K_NUM_MAX_LINKS) {
 		if (ahsta->primary_link_id == link_id) {
@@ -11563,17 +11559,13 @@ static bool ath12k_is_primary_link_migra
 	}
 
 	/* if not primary, just return now */
-	if (!is_primary) {
-		mutex_unlock(&ah->hw_mutex);
+	if (!is_primary)
 		return false;
-	}
 
 	/* if it happens to be primary link, trigger UMAC Migration. */
 	arvif = ath12k_get_arvif_from_link_id(ahvif, ahsta->primary_link_id);
-	if (WARN_ON(!arvif || !arvif->is_up || !arvif->ar)) {
-		mutex_unlock(&ah->hw_mutex);
+	if (WARN_ON(!arvif || !arvif->is_up || !arvif->ar))
 		return true;
-	}
 
 	ar = arvif->ar;
 
@@ -11585,7 +11577,6 @@ static bool ath12k_is_primary_link_migra
 	ret = ath12k_mac_process_link_migrate_req(ahvif, &migrate_params);
 	if (ret) {
 		arvif->is_link_removal_in_progress = false;
-		mutex_unlock(&ah->hw_mutex);
 		return true;
 	}
 
@@ -11611,8 +11602,6 @@ static bool ath12k_is_primary_link_migra
 		}
 	}
 
-	mutex_unlock(&ah->hw_mutex);
-
 	return is_primary;
 }
 
@@ -12115,7 +12104,7 @@ static u8 ath12k_mac_ahsta_get_pri_link_
 	u16 pref_valid_links = 0;
 	u8 active_num_devices = 0;
 
-	lockdep_assert_held(&ah->hw_mutex);
+	lockdep_assert_wiphy(ah->hw->wiphy);
 
 	if (WARN_ON(!valid_links))
 		return IEEE80211_MLD_MAX_NUM_LINKS;
@@ -12204,7 +12193,7 @@ static bool ath12k_mac_ahsta_is_migra_li
 	struct ath12k_vif *ahvif = ahsta->ahvif;
 	struct ath12k_hw *ah = ahvif->ah;
 
-	lockdep_assert_held(&ah->hw_mutex);
+	lockdep_assert_wiphy(ah->hw->wiphy);
 
 	if (!(ahsta->links_map & BIT(link_id)))
 		return false;
@@ -12223,7 +12212,7 @@ static bool ath12k_mac_ahsta_can_migrate
 	struct ath12k_link_sta *arsta;
 	u8 link_id;
 
-	lockdep_assert_held(&ah->hw_mutex);
+	lockdep_assert_wiphy(ah->hw->wiphy);
 
 	/* Currently bridge peer is not supprted. */
 	valid_links &= ~ATH12K_IEEE80211_MLD_MAX_LINKS_MASK;
@@ -12253,7 +12242,7 @@ static int ath12k_mac_get_next_pri_link(
 	u16 curr_links = ahsta->links_map;
 	u16 links_map;
 
-	lockdep_assert_held(&ah->hw_mutex);
+	lockdep_assert_wiphy(ah->hw->wiphy);
 
 	sta = container_of((void *)ahsta, struct ieee80211_sta, drv_priv);
 
@@ -12327,7 +12316,7 @@ ath12k_mac_get_link_migr_peer_node(struc
 	struct ath12k_link_vif *arvif;
 	u8 hw_link_id;
 
-	lockdep_assert_held(&ah->hw_mutex);
+	lockdep_assert_wiphy(ah->hw->wiphy);
 
 	if (!arsta)
 		return NULL;
@@ -12403,7 +12392,7 @@ ath12k_mac_process_link_migrate_req(stru
 
 	INIT_LIST_HEAD(&peer_migr_list);
 
-	lockdep_assert_held(&ah->hw_mutex);
+	lockdep_assert_wiphy(ah->hw->wiphy);
 
 	/* Check if firmware supports migration */
 	for_each_set_bit(link_id, &valid_links, IEEE80211_MLD_MAX_NUM_LINKS) {
