+	/* BRINGUP: QDSS should be removed */
+	ret = ath12k_qmi_send_qdss_config(ab);
+	if (ret < 0) {
+		ath12k_warn(ab, "Failed to download QDSS config to FW: %d\n", ret);
+		return ret;
+	}
+
 	return ret;
 }
 
