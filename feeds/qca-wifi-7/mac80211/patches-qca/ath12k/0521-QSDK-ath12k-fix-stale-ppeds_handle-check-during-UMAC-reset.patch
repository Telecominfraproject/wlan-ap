From c7774979a386af11a34ec5318044eefce9f662b6 Mon Sep 17 00:00:00 2001
From: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
Date: Thu, 14 Aug 2025 16:33:11 -0700
Subject: [PATCH] QSDK:DP:wifi:ath12k: fix stale ppeds_handle check 
during UMAC reset

Currently, UMAC reset framework checks for ppeds_handle to notify
PPE about the ongoing UMAC reset. However, ppeds_handle is no longer 
maintained in the driver making this check obsolete and ineffective.

This change replaces the stale ppeds_handle check with 
ATH12K_FLAG_PPE_DS_ENABLED flag from ab->dev_flags.

Fixes: I82f9483
(QSDK:DP:wifi:ath12k:modularize NSS plugin interface for ath12k & PPE modules)

Patch-dependency:
	0348-QSDK-DP-wifi-ath12k-Enable-UMAC-reset-support-for-DS-mode.patch

Signed-off-by: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c         |    2 +-
 drivers/net/wireless/ath/ath12k/ppe.h        |    1 -
 drivers/net/wireless/ath/ath12k/umac_reset.c |    4 ++--
 3 files changed, 3 insertions(+), 4 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -2208,7 +2208,7 @@ void ath12k_umac_reset_handle_post_reset
         ath12k_dp_umac_txrx_desc_cleanup(ab);
 
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
-	if (ab->dp->ppe.ppeds_handle)
+	if (test_bit(ATH12K_FLAG_PPE_DS_ENABLED, &ab->dev_flags))
 		ath12k_dp_ppeds_tx_desc_cleanup(ab);
 #endif
 
--- a/drivers/net/wireless/ath/ath12k/ppe.h
+++ b/drivers/net/wireless/ath/ath12k/ppe.h
@@ -112,7 +112,6 @@ struct ath12k_ppeds_napi {
 
 struct ath12k_ppe {
 	struct ath12k_base *ab;
-	ppe_ds_wlan_handle_t *ppeds_handle;
 	struct dp_srng reo2ppe_ring;
 	struct dp_srng ppe2tcl_ring;
 	struct dp_ppeds_tx_comp_ring ppeds_comp_ring;
--- a/drivers/net/wireless/ath/ath12k/umac_reset.c
+++ b/drivers/net/wireless/ath/ath12k/umac_reset.c
@@ -371,7 +371,7 @@ void ath12k_umac_reset_handle_pre_reset(
 	ath12k_hif_irq_disable(ab);
 	atomic_inc(&mlo_umac_reset->response_chip);
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
-	if (ab->dp->ppe.ppeds_handle) {
+	if (test_bit(ATH12K_FLAG_PPE_DS_ENABLED, &ab->dev_flags)) {
 		ath12k_dp_ppeds_service_enable_disable(ab, true);
 		ab->dp_umac_reset.umac_pre_reset_in_prog = true;
 		ath12k_dp_ppeds_interrupt_stop(ab);
@@ -395,7 +395,7 @@ void ath12k_umac_reset_handle_post_reset
 	atomic_inc(&mlo_umac_reset->response_chip);
 	ath12k_hif_irq_enable(ab);
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
-	if (ab->dp->ppe.ppeds_handle) {
+	if (test_bit(ATH12K_FLAG_PPE_DS_ENABLED, &ab->dev_flags)) {
 		ath12k_dp_ppeds_start(ab);
 		ath12k_dp_ppeds_interrupt_start(ab);
 	}
