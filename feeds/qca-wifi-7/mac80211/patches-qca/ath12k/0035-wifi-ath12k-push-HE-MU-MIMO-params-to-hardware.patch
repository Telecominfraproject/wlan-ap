 					      struct ieee80211_link_sta *link_sta)
 {
@@ -3266,6 +3385,7 @@ static void ath12k_bss_assoc(struct ath12k *ar,
 	struct ath12k_sta *ahsta;
 	struct ath12k_peer *peer;
