From 0a1ee6a1168e55b114ab872ea0f57067e08c8db6 Mon Sep 17 00:00:00 2001
From: Sarika Sharma <sarishar@qti.qualcomm.com>
Date: Thu, 11 Sep 2025 21:51:52 +0530
Subject: [PATCH] UPSTREAM:DP: wifi:ath12k: update ts->peer_id with link_id to fix per-link
 TX stats

Currently, TX rate and other transmission statistics are updated only
for the primary link. This results in inaccurate TX rate reporting
in per-link station dump stats.

Hence to fix, Update ts->peer_id using ath12k_dp_get_link_id() in
the TX completion path to ensure TX stats are correctly attributed
to the corresponding link_id. This improves accuracy of per-link
metrics in multi-link scenarios.

Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 25 +++++++++++++++++--
 1 file changed, 23 insertions(+), 2 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -2035,6 +2035,9 @@ static void ath12k_wifi7_dp_tx_complete_
 	if (peer) {
 		link_id = ath12k_dp_get_link_id(dp_pdev, ts, peer);
 		peer->stats_link_id = link_id;
+		link_peer = rcu_dereference(peer->link_peers[link_id]);
+		if (link_peer)
+			ts->peer_id = link_peer->peer_id;
 		ath12k_dp_tx_update_peer_basic_stats(peer, msdu_len, ts->status,
 						     link_id, ring);
 
