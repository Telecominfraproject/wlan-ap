From c66279b3a074cbe0de53e8222928bb5d54ed2e33 Mon Sep 17 00:00:00 2001
From: Yuvarani V <yuvarani@qti.qualcomm.com>
Date: Thu, 7 Aug 2025 15:23:27 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL wifi: ath12k: Fix get_tx_link

Currently, when obtaining the tx link_id in the case of MLO,
if the STA is not available, the link ID passed or the default vif
link is used.

In the case of ML Reconfiguration Link Removal, if link 0 or
the default link is removed, this leads to a multicast traffic drop.

Fix this issue by taking first available link instead of default vif
link.

Patch-dependency: ML Reconfiguration Link Removal

Patch-work: None

Signed-off-by: Yuvarani V <yuvarani@qti.qualcomm.com>
Signed-off-by: Manish Dharanenthiran <mdharane@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 53e24a7..430c123 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -14036,12 +14036,13 @@ u8 ath12k_mac_get_tx_link(struct ieee80211_sta *sta, struct ieee80211_vif *vif,
 	unsigned long links;
 	struct ath12k_base *ab;
 
-	/* Use the link id passed or the default vif link */
+	/* Use the link id passed or the first available link */
 	if (!sta) {
 		if (link != IEEE80211_LINK_UNSPECIFIED)
 			return link;
 
-		return ahvif->deflink.link_id;
+		link_id = ffs(ahvif->links_map) - 1;
+		return link_id;
 	}
 
 	ahsta = ath12k_sta_to_ahsta(sta);
-- 
2.34.1

