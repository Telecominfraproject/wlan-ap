 		return -EINVAL;
 
+	if (!qdss_enable) {
+		log_val = strchr(input_buf, ' ');
+		if (log_val && kstrtou64(log_val + 1, 0, &val)) {
+			ath12k_err(ab, "Invalid debug mask\n");
+			return -EINVAL;
+		}
+		switch (val) {
