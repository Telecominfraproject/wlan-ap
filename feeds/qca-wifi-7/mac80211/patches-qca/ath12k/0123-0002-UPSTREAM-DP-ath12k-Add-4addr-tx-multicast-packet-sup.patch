 	struct ieee80211_hdr *hdr = (void *)skb->data;
 	struct ath12k_vif *ahvif = arvif->ahvif;
@@ -107,6 +108,7 @@ int ath12k_wifi7_dp_tx(struct ath12k_pde
 	u8 pool_id;
