From c3f615e73fdf2602208a29cf4b8d72e4d4b328c7 Mon Sep 17 00:00:00 2001
From: Nandha Kishore Easwaran <nandhaki@qti.qualcomm.com>
Date: Mon, 28 Jul 2025 15:01:00 +0530
Subject: [PATCH 1/8] UPSTREAM: DP: HW specific dp_hw_group allocation

With unified driver supporting multiple chipsets of different
architectures, there is a requirement to have private members
of each architecture inside dp_hw_group structure. Hence changing
dp_hw_group to a pointer and moving the allocation inside hw
specific arch ops.

Dependencies:
0404-0006-UPSTREAM-DP-wifi-ath12k-Refactor-monitor-Rx-hal-TLV-.patch

Signed-off-by: Nandha Kishore Easwaran <nandhaki@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c        |  8 ++++++++
 drivers/net/wireless/ath/ath12k/core.h        |  3 +--
 drivers/net/wireless/ath/ath12k/dp.c          |  6 +++---
 drivers/net/wireless/ath/ath12k/dp.h          |  8 +++++++-
 drivers/net/wireless/ath/ath12k/dp_cmn.h      |  3 +++
 drivers/net/wireless/ath/ath12k/wifi7/dp.c    | 14 ++++++++++++++
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c |  2 +-
 drivers/net/wireless/ath/ath12k/wmi.c         |  7 ++++---
 8 files changed, 41 insertions(+), 10 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.c b/drivers/net/wireless/ath/ath12k/core.c
index d30acfc..6c4d3bc 100644
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -29,6 +29,7 @@
 #include "pcic.h"
 #include "wow.h"
 #include "dp_cmn.h"
+#include "dp.h"
 #include "fse.h"
 #include "accel_cfg.h"
 #include "peer.h"
@@ -3816,6 +3817,12 @@ static struct ath12k_hw_group *ath12k_core_hw_group_alloc(struct ath12k_base *ab
 	if (!ag)
 		return NULL;
 
+	ag->dp_hw_grp = ath12k_core_dp_hw_group_alloc(ab->dp);
+	if (!ag->dp_hw_grp) {
+		kfree(ag);
+		return NULL;
+	}
+
 	ag->id = count;
 #ifdef CPTCFG_ATH12K_POWER_OPTIMIZATION
 	ag->dbs_power_reduction = ATH12K_DEFAULT_POWER_REDUCTION;
@@ -3841,6 +3848,7 @@ static void ath12k_core_hw_group_free(struct ath12k_hw_group *ag)
 	mutex_lock(&ath12k_hw_group_mutex);
 
 	list_del(&ag->list);
+	kfree(ag->dp_hw_grp);
 	kfree(ag);
 
 	mutex_unlock(&ath12k_hw_group_mutex);
diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index b5a3b05..72096ed 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -1446,8 +1446,7 @@ struct ath12k_mlo_wsi_load_info {
  * wiphy, protected with struct ath12k_hw_group::mutex.
  */
 struct ath12k_hw_group {
-	/* this should be the first member */
-	struct ath12k_dp_hw_group dp_hw_grp;
+	struct ath12k_dp_hw_group *dp_hw_grp;
 	struct list_head list;
 #ifdef CPTCFG_ATH12K_POWER_OPTIMIZATION
 	u8 dbs_power_reduction;
diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index 4c06f72..b40c75d 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -2225,7 +2225,7 @@ int ath12k_dp_cmn_device_init(struct ath12k_dp *dp)
 void ath12k_dp_cmn_hw_group_unassign(struct ath12k_dp *dp,
 				     struct ath12k_hw_group *ag)
 {
-	struct ath12k_dp_hw_group *dp_hw_grp = &ag->dp_hw_grp;
+	struct ath12k_dp_hw_group *dp_hw_grp = ag->dp_hw_grp;
 	int i;
 
 	lockdep_assert_held(&ag->mutex);
@@ -2259,7 +2259,7 @@ void ath12k_dp_cmn_hw_group_assign(struct ath12k_dp *dp,
 				   struct ath12k_hw_group *ag)
 {
 	struct ath12k_base *ab = dp->ab;
-	struct ath12k_dp_hw_group *dp_hw_grp = &ag->dp_hw_grp;
+	struct ath12k_dp_hw_group *dp_hw_grp = ag->dp_hw_grp;
 	int i;
 
 	dp->dp_hw_grp = dp_hw_grp;
@@ -2520,7 +2520,7 @@ void ath12k_dp_cmn_update_hw_links(struct ath12k_dp *dp,
 				   struct ath12k_hw_group *ag,
 				   struct ath12k *ar)
 {
-	struct ath12k_dp_hw_group *dp_hw_grp = &ag->dp_hw_grp;
+	struct ath12k_dp_hw_group *dp_hw_grp = ag->dp_hw_grp;
 
 	lockdep_assert_held(&ag->mutex);
 
diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 67519de..81eedf9 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -464,7 +464,7 @@ struct ath12k_dp_arch_ops {
 	int (*rx_flow_delete_entry)(struct ath12k_dp *dp, struct rx_flow_info *flow_info);
 	int (*rx_flow_delete_all_entries)(struct ath12k_dp *dp);
 	ssize_t (*dump_fst_table)(struct ath12k_dp *dp, char *buf, int size);
-
+	struct ath12k_dp_hw_group*(*dp_hw_group_alloc)(void);
 	int (*peer_migrate_reo_cmd)(struct ath12k_dp *dp,
 				    struct ath12k_dp_link_peer *peer,
 				    u16 peer_id,
@@ -943,6 +943,12 @@ ath12k_dp_arch_dump_fst_table(struct ath12k_dp *dp, char *buf, int size)
 	return dp->arch_ops->dump_fst_table(dp, buf, size);
 }
 
+static inline struct ath12k_dp_hw_group *
+ath12k_core_dp_hw_group_alloc(struct ath12k_dp *dp)
+{
+	return dp->arch_ops->dp_hw_group_alloc();
+}
+
 static inline void ath12k_dp_get_mac_addr(u32 addr_l32, u16 addr_h16, u8 *addr)
 {
 	memcpy(addr, &addr_l32, 4);
diff --git a/drivers/net/wireless/ath/ath12k/dp_cmn.h b/drivers/net/wireless/ath/ath12k/dp_cmn.h
index a1a75d9..1cc0652 100644
--- a/drivers/net/wireless/ath/ath12k/dp_cmn.h
+++ b/drivers/net/wireless/ath/ath12k/dp_cmn.h
@@ -48,6 +48,9 @@ struct ath12k_dp_hw_group {
 	struct dp_rx_fst *fst;
 	u8 *tx_status_buf[ATH12K_HW_MAX_QUEUES];
 	u8 *rx_status_buf[DP_REO_DST_RING_MAX];
+
+	/* Keep Last */
+	u8 arch_data[] __aligned(sizeof(void *));
 };
 
 /* TODO: Move this to a seperate dp_stats file */
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp.c b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
index 605c38f..1cbaf95 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
@@ -162,6 +162,19 @@ static void ath12k_wifi7_dp_op_device_deinit(struct ath12k_dp *dp)
 	ath12k_hif_ext_irq_cleanup(dp->ab);
 }
 
+static struct ath12k_dp_hw_group *ath12k_wifi7_dp_hw_group_alloc(void)
+{
+	struct ath12k_dp_hw_group *dp_hw_grp;
+
+	dp_hw_grp = kzalloc(sizeof(*dp_hw_grp), GFP_KERNEL);
+	if (!dp_hw_grp) {
+		pr_err("failed to allocate dp_hw_group\n");
+		return NULL;
+	}
+
+	return dp_hw_grp;
+}
+
 static struct ath12k_dp_arch_ops ath12k_wifi7_dp_arch_ops = {
 	.dp_op_device_init = ath12k_wifi7_dp_op_device_init,
 	.dp_op_device_deinit = ath12k_wifi7_dp_op_device_deinit,
@@ -181,6 +194,7 @@ static struct ath12k_dp_arch_ops ath12k_wifi7_dp_arch_ops = {
 	.rx_flow_delete_entry = ath12k_wifi7_dp_rx_flow_delete_entry,
 	.rx_flow_delete_all_entries = ath12k_wifi7_dp_rx_flow_delete_all_entries,
 	.dump_fst_table = ath12k_wifi7_dp_dump_fst_table,
+	.dp_hw_group_alloc = ath12k_wifi7_dp_hw_group_alloc,
 	.peer_migrate_reo_cmd = ath12k_wifi7_dp_peer_migrate_reo_cmd,
 	.sdwf_reinject_handler = ath12k_wifi7_sdwf_reinject_handler,
 };
