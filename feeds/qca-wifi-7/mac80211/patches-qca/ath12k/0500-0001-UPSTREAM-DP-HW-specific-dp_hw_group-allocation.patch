+		pdev_idx = ab->ag->dp_hw_grp->hw_links[i].pdev_idx;
 		partner_ab = ath12k_ag_to_ab(ab->ag, device_id);
 		ar = partner_ab->pdevs[pdev_idx].ar;
 		if (!ar) {
