 drivers/net/wireless/ath/ath12k/qos.h    |   3 +
 drivers/net/wireless/ath/ath12k/sdwf.c   | 151 +++++++++++++++++++++++
 drivers/net/wireless/ath/ath12k/sdwf.h   |  23 ++++
 4 files changed, 178 insertions(+)
 create mode 100644 drivers/net/wireless/ath/ath12k/sdwf.c
