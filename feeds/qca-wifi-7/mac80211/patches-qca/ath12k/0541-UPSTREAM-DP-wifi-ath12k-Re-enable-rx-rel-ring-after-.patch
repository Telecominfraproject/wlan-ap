From ccef55ba3d55ef3013afcb94b7a56e3c9df429a6 Mon Sep 17 00:00:00 2001
From: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
Date: Fri, 19 Sep 2025 17:42:34 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Re-enable rx rel ring after umac
 reset

rx_rel_ring is being disabled during umac reset and not enabled
back which is triggerring to firmware crash. Fix it by re enabling
the ring.

Fixes: I293c6d248a57 ("UPSTREAM:DP:wifi:ath12k: Changes for supporting multiple archs")

Signed-off-by: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index e085fd3..d4e9938 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -2221,6 +2221,12 @@ void ath12k_umac_reset_handle_post_reset_start(struct ath12k_base *ab)
 		ath12k_dp_ppeds_tx_desc_cleanup(ab);
 #endif
 
+	ret = ath12k_dp_srng_setup(ab, &dp->rx_rel_ring, HAL_WBM2SW_RELEASE,
+				   HAL_WBM2SW_REL_ERR_RING_NUM, 0,
+				   DP_RX_RELEASE_RING_SIZE);
+	if (ret)
+		ath12k_warn(ab, "failed to set up rx_rel ring :%d\n", ret);
+
         ath12k_dp_rxdma_ring_setup(ab);
 
         for (i = 0; i < DP_REO_DST_RING_MAX; i++) {
-- 
2.34.1

