                         } else {
@@ -8829,8 +8841,8 @@ void ath12k_mac_fill_reg_tpc_info(struct ath12k *ar,
                                                                    &tx_power,
 								   reg_6g_power_mode);
                                         eirp_power = tx_power;
-                                        max_tx_power[pwr_lvl_idx] =
-                                                reg_tpc_info->tpe[pwr_lvl_idx];
+					max_tx_power[pwr_lvl_idx] =
+					    reg_tpc_info->tpe_psd[pwr_lvl_idx];
                                 /* Connecting AP is not psd power */
                                 } else {
