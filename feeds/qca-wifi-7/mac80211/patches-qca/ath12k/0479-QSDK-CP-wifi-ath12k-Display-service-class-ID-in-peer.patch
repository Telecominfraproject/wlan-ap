From 668105e059fd0d52991ff0a2d54d6b1a723c60d9 Mon Sep 17 00:00:00 2001
From: Vivek Chettri <vchettri@qti.qualcomm.com>
Date: Wed, 30 Jul 2025 16:29:57 +0530
Subject: [PATCH] QSDK: CP: wifi: ath12k: Display service class ID in peer
 MSDUQ info.

The peer QoS MSDUQ info dump is used for both upstream SCS feature
and is also for QSDK SDWF feature.
The info displayed is just the MSDUQ information and the QoS profile ID.

For SDWF to enhance debug, if with the QoS profile ID, the associated
service class ID is also dislayed.

Add service class info in the QoS MSDUQ map for SDWF use cases.

Sample Output for SDWF and SCS

root@OpenWrt:~#  cat
/sys/kernel/debug/ieee80211/phy00/netdev:wlan0/stations/00:
03:7f:12:ac:ac/link-0/qos_msduq
**********************
SVC ID: 30
TID: 0
Queue: 0
QoS ID: 30
msduq_id: 16
tgt_opaque_id: 0x1d
**********************
TID: 2
Queue: 0
QoS ID: 31
msduq_id: 18
tgt_opaque_id: 0x1e

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs_sta.c | 15 ++++++++++++++-
 drivers/net/wireless/ath/ath12k/qos.h         |  1 +
 drivers/net/wireless/ath/ath12k/sdwf.c        |  7 +++++++
 3 files changed, 22 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs_sta.c b/drivers/net/wireless/ath/ath12k/debugfs_sta.c
index 71fccff..81813e5 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs_sta.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs_sta.c
@@ -326,11 +326,19 @@ ath12k_dbg_sta_read_qos_msduq(struct file *file, char __user *user_buf,
 	struct ath12k_dp_peer *peer;
 	struct ath12k_dp_peer_qos *qos;
 	struct ath12k_msduq *msduq_map;
+	struct ath12k_qos_ctx *qos_ctx;
 	const int size = 2048;
 	size_t len = 0;
+	u16 svc_id, qos_id;
 	u8 tid, q;
 	int ret  = -EINVAL;

+	qos_ctx = ath12k_get_qos(ar->ab);
+	if (!qos_ctx) {
+		ath12k_err(ar->ab, "QoS Context is NULL");
+		return ret;
+	}
+
 	wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
 	spin_lock_bh(&ah->dp_hw.peer_lock);

@@ -349,8 +357,14 @@ ath12k_dbg_sta_read_qos_msduq(struct file *file, char __user *user_buf,
 		for(q = 0; q < QOS_TID_MDSUQ_MAX; q++) {
 			msduq_map = &qos->msduq_map[tid][q];
 			if (msduq_map->reserved) {
+				qos_id = msduq_map->qos_id;
+				svc_id = qos_ctx->profiles[qos_id].svc_id;
 				len += scnprintf(buf + len, size - len,
 						 "**********************\n");
+				if (svc_id) {
+					len += scnprintf(buf + len, size - len,
+							 "SVC ID:%u\n", svc_id);
+				}
 				len += scnprintf(buf + len, size - len,
 						 "TID: %u\n", tid);
 				len += scnprintf(buf + len, size - len,
@@ -367,7 +381,6 @@ ath12k_dbg_sta_read_qos_msduq(struct file *file, char __user *user_buf,
 			}
 		}
 	}
-
 	ret = 0;
 ret:
 	spin_unlock_bh(&ah->dp_hw.peer_lock);
diff --git a/drivers/net/wireless/ath/ath12k/qos.h b/drivers/net/wireless/ath/ath12k/qos.h
index 4687cc0..e37b148 100644
--- a/drivers/net/wireless/ath/ath12k/qos.h
+++ b/drivers/net/wireless/ath/ath12k/qos.h
@@ -136,6 +136,7 @@ struct ath12k_qos_params {
 struct ath12k_qos {
 	u8 ref_count;
 	struct ath12k_qos_params params;
+	u16 svc_id;
 };

 struct ath12k_qos_ctx {
diff --git a/drivers/net/wireless/ath/ath12k/sdwf.c b/drivers/net/wireless/ath/ath12k/sdwf.c
index 64386ad..2287904 100644
--- a/drivers/net/wireless/ath/ath12k/sdwf.c
+++ b/drivers/net/wireless/ath/ath12k/sdwf.c
@@ -60,6 +60,13 @@ int ath12k_sdwf_map_service_class(struct ath12k_base *ab, u16 svc_id,
 	qos_ctx->svc_class[svc_id].dl_qos_id = dl_qos_id;
 	qos_ctx->svc_class[svc_id].ul_qos_id = ul_qos_id;
 	qos_ctx->svc_class[svc_id].configured = true;
+
+	if (dl_qos_id != QOS_ID_INVALID)
+		qos_ctx->profiles[dl_qos_id].svc_id = svc_id;
+
+	if (ul_qos_id != QOS_ID_INVALID)
+		qos_ctx->profiles[ul_qos_id].svc_id = svc_id;
+
 	ath12k_dbg(ab, ATH12K_DBG_QOS,
 		   "Service Class %d Config | DL QoS ID:%d | UL QoS ID:%d",
 		   svc_id,
--
2.34.1

