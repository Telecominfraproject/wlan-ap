From a977d70ddf3da81da9e025ba6f6a4f45671197af Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Tue, 5 Aug 2025 16:43:58 +0530
Subject: [PATCH] UPSTREAM:CP wifi:ath12k Fix incrementation of active_scan flag
 during scan start failure

Increment the no_of_active_scans flag only after a successful
scan initiation to ensure it does not increase when the scan
start request to the firmware fails say during recovery.

Already Upstreamed:
https://lore.kernel.org/all/20250512065849.2833232-1
-quic_vignc@quicinc.com/

Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 262806d..e657ed0 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -7930,6 +7930,7 @@ static int ath12k_mac_initiate_hw_scan(struct ieee80211_hw *hw,
 		spin_lock_bh(&ar->data_lock);
 		ar->scan.state = ATH12K_SCAN_IDLE;
 		spin_unlock_bh(&ar->data_lock);
+		goto exit;
 	}
 
 	ath12k_dbg_level(ar->ab, ATH12K_DBG_MAC, ATH12K_DBG_L2, "mac scan started");
-- 
2.34.1

