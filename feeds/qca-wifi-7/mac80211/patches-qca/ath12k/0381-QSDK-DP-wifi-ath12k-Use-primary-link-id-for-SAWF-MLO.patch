From e811c514c1dc263e4b4a707185ef61263cee33d2 Mon Sep 17 00:00:00 2001
From: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Date: Sun, 29 Jun 2025 13:33:28 +0530
Subject: [PATCH] QSDK: DP: wifi: ath12k: Use primary link id for SAWF MLO
 mark_metadata

Use primary link id for SAWF MLO mark_metadata

Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/accel_cfg.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/accel_cfg.c b/drivers/net/wireless/ath/ath12k/accel_cfg.c
index 23c0268..7cfa856 100644
--- a/drivers/net/wireless/ath/ath12k/accel_cfg.c
+++ b/drivers/net/wireless/ath/ath12k/accel_cfg.c
@@ -91,7 +91,7 @@ void ath12k_get_ingress_mlo_dev_info(struct net_device *ndev,
 	arvif  = (!sta->mlo) ? rcu_dereference(ahvif->link[ahsta->deflink.link_id]) :
 			       rcu_dereference(ahvif->link[ahsta->primary_link_id]);
 
-	*link_id = (!sta->mlo) ? ahsta->deflink.link_id : ahsta->assoc_link_id;
+	*link_id = (!sta->mlo) ? ahsta->deflink.link_id : ahsta->primary_link_id;
 
 	ab = arvif->ar->ab;
 
-- 
2.34.1

