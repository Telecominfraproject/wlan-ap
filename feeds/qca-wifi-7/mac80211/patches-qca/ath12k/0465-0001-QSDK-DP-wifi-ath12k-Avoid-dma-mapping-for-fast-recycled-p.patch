From 7c8cebbed06be2c851fe151352b06fec62e2b783 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Tue, 15 Jul 2025 18:15:16 +0530
Subject: [PATCH 1/4] QSDK: DP: wifi: ath12k: Avoid dma mapping fast recycled
 packets

Avoid dma mapping fast recycled packets, if they are already mapped
by other module(s). Which can be checked using the fast_recycled
flag present in skb, if this is not set, use invalidate API to
invalidate the skb data memory.

patch-dependency:
0402-01-UPSTREAM-ath12k-DP-simplify-rx-buffer-ring-replenish-log.patch

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_rx.c | 17 +++++++++--------
 1 file changed, 9 insertions(+), 8 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_rx.c b/drivers/net/wireless/ath/ath12k/dp_rx.c
index 4b200ee..db6ee0a 100644
--- a/drivers/net/wireless/ath/ath12k/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/dp_rx.c
@@ -314,6 +314,7 @@ void ath12k_dp_rx_bufs_replenish(struct ath12k_dp *dp,
 	struct ath12k_rx_desc_info *rx_desc, *tmp_rx_desc;
 	enum hal_rx_buf_return_buf_manager mgr = dp->hal->hal_params->rx_buf_rbm;
 	int allocated_entries = 0;
+	bool is_dma_inv_done = false;
 
 	list_for_each_entry_safe(rx_desc, tmp_rx_desc, used_list, list) {
 #ifdef CPTCFG_MAC80211_SFE_SUPPORT
@@ -325,26 +326,26 @@ void ath12k_dp_rx_bufs_replenish(struct ath12k_dp *dp,
 			break;
 
 #ifndef CONFIG_IO_COHERENCY
-		paddr = dma_map_single(dp->dev, skb->data, DP_RX_BUFFER_SIZE,
-				       DMA_FROM_DEVICE);
-		if (unlikely(dma_mapping_error(dp->dev, paddr))) {
-			ath12k_dp_rx_skb_free(skb, dp, 0,
-					      DP_RX_ERR_DROP_REPLENISH);
-			break;
+		if (unlikely(!skb->fast_recycled)) {
+			dmac_inv_range_no_dsb(skb->data, skb->data + DP_RX_BUFFER_SIZE);
+			is_dma_inv_done = true;
 		}
-#else
+#endif
 		paddr = virt_to_phys(skb->data);
 		if(unlikely(!paddr)) {
 			ath12k_dp_rx_skb_free(skb, dp, 0,
 					      DP_RX_ERR_DROP_REPLENISH);
 			break;
 		}
-#endif
+
 		allocated_entries++;
 		rx_desc->skb = skb;
 		rx_desc->paddr = paddr;
 	}
 
+	if (unlikely(is_dma_inv_done))
+		dsb(st);
+
 	srng = &ab->hal.srng_list[rx_ring->refill_buf_ring.ring_id];
 	spin_lock_bh(&srng->lock);
 	ath12k_hal_srng_access_begin(ab, srng);
-- 
