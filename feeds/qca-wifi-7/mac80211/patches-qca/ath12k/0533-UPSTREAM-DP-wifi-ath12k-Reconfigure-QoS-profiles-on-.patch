From b8d75855dda5fac8851ae20dc9e5a346b7f4c2c6 Mon Sep 17 00:00:00 2001
From: Vivek Chettri <vchettri@qti.qualcomm.com>
Date: Thu, 18 Sep 2025 13:45:43 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Reconfigure QoS profiles on Firmware
 recovery

During Firmware recovery, the target that crashes would lose the QoS
parameters that was configured and would need the parameters to
be reconfigured.

Read the QoS profiles and reprogram the QoS parmeters in the target
after Finware recovery.

Patch-dependency:
0415-0002-UPSTREAM-CP-wifi-ath12k-Enable-QoS-support-in-the-Fi.patc

Patch-work: None

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c |  3 ++-
 drivers/net/wireless/ath/ath12k/qos.c | 23 +++++++++++++++++++++++
 drivers/net/wireless/ath/ath12k/qos.h |  1 +
 3 files changed, 26 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index af6bd42..e0225f2 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -20271,6 +20271,7 @@ ath12k_mac_reconfig_complete(struct ieee80211_hw *hw,
 		ath12k_erp_handle_ssr(ar);
 	}
 
+	ath12k_reconfig_qos_profiles(ab);
 	clear_bit(ATH12K_GROUP_FLAG_RECOVERY, &ar->ab->ag->flags);
 
 	/* Send WMI_FW_HANG_CMD to FW after target has started. This is to
@@ -23137,7 +23138,7 @@ static u16 get_lower_bandwidth_puncture_pattern(u16 prifreq, u16 cur_pat,
 {
 	/* Location of the target bandwidth in current bandwidth */
 	u8 target_bw_loc_in_curbw;
-	/* Number of 20 MHz channels in the target bandwidth */ 
+	/* Number of 20 MHz channels in the target bandwidth */
 	u8 n_20chans_in_target_bw;
 	/* Number of bits for the right shift */
 	u8 nbits_to_right_shift;
diff --git a/drivers/net/wireless/ath/ath12k/qos.c b/drivers/net/wireless/ath/ath12k/qos.c
index f19777e..c06d965 100644
--- a/drivers/net/wireless/ath/ath12k/qos.c
+++ b/drivers/net/wireless/ath/ath12k/qos.c
@@ -425,3 +425,26 @@ ret:
 	}
 	return ret;
 }
+
+int ath12k_reconfig_qos_profiles(struct ath12k_base *ab)
+{
+	struct ath12k_qos_ctx *qos_ctx;
+	struct ath12k_qos_params *params;
+	u8 index;
+
+	qos_ctx = ath12k_get_qos(ab);
+	if (!qos_ctx) {
+		ath12k_err(ab, "QoS Context is NULL");
+		return -EINVAL;
+	}
+
+	for (index = QOS_DL_ID_MIN; index <= QOS_DL_ID_MAX; index++) {
+		if (qos_ctx->profiles[index].ref_count == 0)
+			continue;
+
+		params = &qos_ctx->profiles[index].params;
+		ath12k_core_add_dl_qos(ab, params, index);
+	}
+
+	return 0;
+}
diff --git a/drivers/net/wireless/ath/ath12k/qos.h b/drivers/net/wireless/ath/ath12k/qos.h
index de56bb9..be52ad8 100644
--- a/drivers/net/wireless/ath/ath12k/qos.h
+++ b/drivers/net/wireless/ath/ath12k/qos.h
@@ -192,4 +192,5 @@ int ath12k_qos_update(struct ath12k_base *ab, struct ath12k *ar,
 		      struct ath12k_qos_params *params,
 		      enum qos_profile_dir qos_dir,
 		      u16 id, u8 *mac_addr);
+int ath12k_reconfig_qos_profiles(struct ath12k_base *ab);
 #endif /* ATH12K_QOS_H */
-- 
2.34.1

