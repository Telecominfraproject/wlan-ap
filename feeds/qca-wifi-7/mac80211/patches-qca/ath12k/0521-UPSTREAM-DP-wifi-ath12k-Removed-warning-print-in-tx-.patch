From f2910a4bef6fd08248a9d2acd10a9ee54df12fb0 Mon Sep 17 00:00:00 2001
From: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
Date: Tue, 19 Aug 2025 15:27:21 +0530
Subject: [PATCH] UPSTREAM:DP:wifi: ath12k: Removed warning print in tx path

During interface down sequence arvif can become NULL in
ath12k_wifi7_mac_op_tx(). Since the condition is expected
during interface down sequence, printing it with ath12k_warn()
is not needed. So, remove the warning print.

Patch dependency:
0119-0001-wifi-ath12k-ieee80211_ops-Tx-callback-for-wifi7.patch

Signed-off-by: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/hw.c | 2 --
 1 file changed, 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hw.c b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
index 444a5f5..c69d0c1 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -1453,8 +1453,6 @@ static void ath12k_wifi7_mac_op_tx(struct ieee80211_hw *hw,
 
 	arvif = rcu_dereference(ahvif->link[link_id]);
 	if (!arvif || !arvif->ar) {
-		ath12k_warn(ahvif->ah, "failed to find arvif link id %u for frame transmission",
-			    link_id);
 		ath12k_wifi7_ieee80211_free_txskb(hw, skb, dp_vif,
 						  DP_TX_ENQ_DROP_INV_ARVIF,
 						  ring_id, false);
-- 
2.34.1

