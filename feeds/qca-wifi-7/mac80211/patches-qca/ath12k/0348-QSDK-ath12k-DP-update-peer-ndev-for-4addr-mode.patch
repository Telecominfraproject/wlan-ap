From 15c8c954762eec46cfe97988f4a241b2fcac9c07 Mon Sep 17 00:00:00 2001
From: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
Date: Tue, 17 Jun 2025 14:48:40 +0530
Subject: [PATCH] QSDK:ath12k:DP: update peer ndev for 4addr mode

For 4addr mode, vlan netdev has to be use for all the processing.
Currently,peer netdev would be configured with native netdev
rather than its AP/VLAN interface netdev and this cause a drop
in UL KPI. Fix this issue by configuring the AP/VLAN netdev to
peer netdev during 4addr wok queue.

Patch-dependancy: 0337-wifi-ath12k-DP-enable-perf-mode-and-call-netif-direc.patch

Fixes: I01984ba ("wifi: ath12k: DP: enable perf mode and call netif directly")

Signed-off-by: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 3d1132b..5fe2b18 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -8422,6 +8422,8 @@ static void ath12k_sta_set_4addr_wk(struct wiphy *wiphy, struct wiphy_work *wk)
 			peer->dp_peer->use_4addr = true;
 			arsta->tcl_metadata = peer->tcl_metadata;
 			arsta->ast_hash = peer->ast_hash;
+			if (peer->vif->type == NL80211_IFTYPE_AP)
+				peer->dp_peer->dev = peer->dp_peer->sta->dev;
 		}
 
 		spin_unlock_bh(&ar->ab->dp->dp_lock);
-- 
