From 183bf854a7ae99c7ef47c7032894b18d86f38dfe Mon Sep 17 00:00:00 2001
From: Sarika Sharma <sarishar@qti.qualcomm.com>
Date: Sat, 2 Aug 2025 00:08:12 +0530
Subject: UPSTREAM:DP: wifi:ath12k: Remove unnecessary firmware
 stats check

Currently, ath12k_mac_get_fw_stats() is called twice in both
ath12k_mac_op_sta_statistics() and ath12k_mac_op_link_sta_statistics(),
once after timeout comparison and other during if check, which causing
delays in displaying stats output.

Hence, fix by ensuring the ath12k_mac_get_fw_stats() check is performed
only once to optimize performance.

Fixes: 2e64620c948c9 ("pkg upgrade Added subsys, ath11k and ath12k patches for win.wlan_host_opensource.4.0")
Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 7 ++-----
 1 file changed, 2 insertions(+), 5 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 0cef6c3..99faa52 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -19695,9 +19695,7 @@ void ath12k_mac_op_link_sta_statistics(struct ieee80211_hw *hw,
 		ar->last_signal_update = jiffies;
 	}
 
-	if (!signal &&
-	    ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA &&
-	    !(ath12k_mac_get_fw_stats(ar, &params)))
+	if (!signal && ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA)
 		signal = arsta->rssi_beacon;
 
 	if (signal) {
@@ -19795,8 +19793,7 @@ void ath12k_mac_op_sta_statistics(struct ieee80211_hw *hw,
 		ar->last_signal_update = jiffies;
 	}
 
-	if (!signal && ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA &&
-	    (!ath12k_mac_get_fw_stats(ar, &params)))
+	if (!signal && ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA)
 		signal = arsta->rssi_beacon;
 
 	if (!(sinfo->filled & BIT_ULL(NL80211_STA_INFO_CHAIN_SIGNAL)) &&
-- 
2.34.1

