From 3633772a9646ca041d82d80bd0e734267a2cc9e5 Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Date: Fri, 16 May 2025 16:45:03 +0530
Subject: [PATCH] UPSTREAM: CP: wifi: ath12k: Fix possible NULL pointer derefrence in
 debug

ath12k_err() and ath12k_info() expects struct ath12k_base
(ab) to print the message. However there might be functions where ab is
not readily available. Hence add support to print the message without
accessing the ab.

Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
---
 .built                                  |  0
 drivers/net/wireless/ath/ath12k/debug.c | 10 ++++++++--
 2 files changed, 8 insertions(+), 2 deletions(-)
 delete mode 100644 .built

diff --git a/.built b/.built
deleted file mode 100644
index e69de29..0000000
diff --git a/drivers/net/wireless/ath/ath12k/debug.c b/drivers/net/wireless/ath/ath12k/debug.c
index 968480b..3598c1b 100644
--- a/drivers/net/wireless/ath/ath12k/debug.c
+++ b/drivers/net/wireless/ath/ath12k/debug.c
@@ -17,7 +17,10 @@ void ath12k_info(struct ath12k_base *ab, const char *fmt, ...)
 
 	va_start(args, fmt);
 	vaf.va = &args;
-	dev_info(ab->dev, "%pV", &vaf);
+	if (likely(ab))
+		dev_info(ab->dev, "%pV", &vaf);
+	else
+		pr_info("ath12k: %pV", &vaf);
 	/* TODO: Trace the log */
 	va_end(args);
 }
@@ -32,7 +35,10 @@ void ath12k_err(struct ath12k_base *ab, const char *fmt, ...)
 
 	va_start(args, fmt);
 	vaf.va = &args;
-	dev_err(ab->dev, "%pV", &vaf);
+	if (likely(ab))
+		dev_err(ab->dev, "%pV", &vaf);
+	else
+		pr_err("ath12k: %pV", &vaf);
 	/* TODO: Trace the log */
 	va_end(args);
 }
-- 
2.34.1

