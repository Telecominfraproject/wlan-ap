From e6612ab1d18bcc1b215935600bddeae8ce00c5cc Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <quic_hramanat@quicinc.com>
Date: Tue, 15 Apr 2025 18:41:07 +0530
Subject: [PATCH 07/15] UPSTREAM:DP:ath12k:add statistic support for
counting wmm failed sent packets.

if the acknowledgement is not received for the packets sent in the air,
then incrementing the drop packets are counted based on WMM categories.

Original Patch:
718-ath12k-failed-sent-pkts.patch

Signed-off-by: saleemuddin shaik <quic_saleemud@quicinc.com>
Signed-off-by: Hariharan Ramanathan <quic_hramanat@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/debugfs.c     | 12 ++++++++++++
 drivers/net/wireless/ath/ath12k/dp.h          |  1 +
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c |  8 ++++++++
 3 files changed, 21 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs.c b/drivers/net/wireless/ath/ath12k/debugfs.c
index 87b3918..24c3fa3 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs.c
@@ -1423,6 +1423,7 @@ static ssize_t ath12k_read_wmm_stats(struct file *file,
        ssize_t retval;
        u64 total_wmm_sent_pkts = 0;
        u64 total_wmm_received_pkts = 0;
+       u64 total_wmm_fail_sent = 0;
 
        buf = kzalloc(size, GFP_KERNEL);
        if (!buf) {
@@ -1434,12 +1435,15 @@ static ssize_t ath12k_read_wmm_stats(struct file *file,
        for (count = 0; count < WME_NUM_AC; count++) {
                total_wmm_sent_pkts += dp_pdev->wmm_stats.total_wmm_tx_pkts[count];
 	       total_wmm_received_pkts += dp_pdev->wmm_stats.total_wmm_rx_pkts[count];
+	       total_wmm_fail_sent += dp_pdev->wmm_stats.total_wmm_tx_drop[count];
        }
 
        len += scnprintf(buf + len, size - len, "Total number of wmm_sent: %llu\n",
                         total_wmm_sent_pkts);
        len += scnprintf(buf + len, size - len, "total number of wmm_received: %llu\n",
 		        total_wmm_received_pkts);
+       len += scnprintf(buf + len, size - len, "total number of wmm_fail_sent: %llu\n",
+		        total_wmm_fail_sent);
        len += scnprintf(buf + len, size - len, "Num of BE wmm_sent: %llu\n",
                         dp_pdev->wmm_stats.total_wmm_tx_pkts[WME_AC_BE]);
        len += scnprintf(buf + len, size - len, "Num of BK wmm_sent: %llu\n",
@@ -1456,6 +1460,14 @@ static ssize_t ath12k_read_wmm_stats(struct file *file,
 		        dp_pdev->wmm_stats.total_wmm_rx_pkts[WME_AC_VI]);
        len += scnprintf(buf + len, size - len, "num of vo wmm_received: %llu\n",
 		        dp_pdev->wmm_stats.total_wmm_rx_pkts[WME_AC_VO]);
+       len += scnprintf(buf + len, size - len, "num of be wmm_tx_dropped: %llu\n",
+			dp_pdev->wmm_stats.total_wmm_tx_drop[WME_AC_BE]);
+       len += scnprintf(buf + len, size - len, "num of bk wmm_tx_dropped: %llu\n",
+			dp_pdev->wmm_stats.total_wmm_tx_drop[WME_AC_BK]);
+       len += scnprintf(buf + len, size - len, "num of vi wmm_tx_dropped: %llu\n",
+			dp_pdev->wmm_stats.total_wmm_tx_drop[WME_AC_VI]);
+       len += scnprintf(buf + len, size - len, "num of vo wmm_tx_dropped: %llu\n",
+			dp_pdev->wmm_stats.total_wmm_tx_drop[WME_AC_VO]);
 
        wiphy_unlock(dp_pdev->hw->wiphy);
 
diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 72cac57..6aa5a8c 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -121,6 +121,7 @@ struct ath12k_wmm_stats {
        int rx_type;
        u64 total_wmm_tx_pkts[WME_NUM_AC];
        u64 total_wmm_rx_pkts[WME_NUM_AC];
+       u64 total_wmm_tx_drop[WME_NUM_AC];
 };
 
 struct dp_mon_mpdu {
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index 4177d15..44272f0 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -662,6 +662,12 @@ static void ath12k_wifi7_dp_tx_complete_msdu(struct ath12k_pdev_dp *dp_pdev,
 
 	skb_cb = ATH12K_SKB_CB(msdu);
 
+	dp_pdev->wmm_stats.tx_type = ath12k_tid_to_ac(ts->tid > ATH12K_DSCP_PRIORITY ? 0:ts->tid);
+	if (dp_pdev->wmm_stats.tx_type) {
+		if (ts->status != HAL_WBM_TQM_REL_REASON_FRAME_ACKED)
+			dp_pdev->wmm_stats.total_wmm_tx_drop[dp_pdev->wmm_stats.tx_type]++;
+	}
+
 	dma_unmap_single(ab->dev, skb_cb->paddr, msdu->len, DMA_TO_DEVICE);
 	if (skb_cb->paddr_ext_desc) {
 		dma_unmap_single(ab->dev, skb_cb->paddr_ext_desc,
@@ -800,6 +806,8 @@ ath12k_wifi7_dp_tx_status_parse(struct ath12k_base *ab,
 		ts->tones = u32_get_bits(info0, HAL_TX_RATE_STATS_INFO0_TONES_IN_RU);
 		ts->ofdma = u32_get_bits(info0, HAL_TX_RATE_STATS_INFO0_OFDMA_TX);
 	}
+
+	ts->tid = FIELD_GET(HAL_WBM_RELEASE_TX_INFO3_TID, desc->info3);
 }
 
 void ath12k_wifi7_dp_tx_completion_handler(struct ath12k_dp *dp, int ring_id)
-- 
2.34.1

