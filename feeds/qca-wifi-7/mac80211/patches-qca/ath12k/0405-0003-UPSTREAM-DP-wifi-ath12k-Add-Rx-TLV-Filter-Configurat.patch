+		if(mon_ops && mon_ops->rx_monitor_mode_set)
+			mon_ops->rx_monitor_mode_set(dp_pdev);
+	} else {
+		if(mon_ops && mon_ops->rx_monitor_mode_reset)
+			mon_ops->rx_monitor_mode_reset(dp_pdev);
