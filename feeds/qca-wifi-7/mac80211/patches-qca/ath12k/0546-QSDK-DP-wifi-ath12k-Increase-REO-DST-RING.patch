From fa453294674963f149ea9b1a28e914958e3f2664 Mon Sep 17 00:00:00 2001
From: KARTHIK KUMAR T <kartt@qti.qualcomm.com>
Date: Mon, 15 Sep 2025 11:46:04 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Increase size of reo dst ring

currently REO dest ring size is 2048 this increased to 8192
to improve the UL KPI numbers.

Patch-dependency: none

Signed-off-by: KARTHIK KUMAR T <kartt@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 22da771..c4eceee 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -233,7 +233,7 @@ enum ath12k_dp_eapol_key_type {
 #define DP_TX_IDR_SIZE			DP_TX_COMP_RING_SIZE
 #define DP_TCL_CMD_RING_SIZE		32
 #define DP_TCL_STATUS_RING_SIZE		32
-#define DP_REO_DST_RING_SIZE		2048
+#define DP_REO_DST_RING_SIZE		8192
 #define DP_REO_REINJECT_RING_SIZE	32
 #define DP_REO_EXCEPTION_RING_SIZE	128
 #define DP_REO_CMD_RING_SIZE		256
-- 
2.34.1

