From 9179cb668b3186b2ffd336dd9f04ca53d813b852 Mon Sep 17 00:00:00 2001
From: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
Date: Thu, 10 Jul 2025 09:55:48 +0530
Subject: [PATCH 3/3] UPSTREAM:PROTOCOL: wifi: ath12k: add WMI support for
 station link reconfiguration

Add support for handling associated station link reconfiguration by
updating firmware through WMI peer association commands.

Extend the peer association command to encode the following fields:
- ml_reconfig: indicates a reconfiguration event
- mlo_link_add / mlo_link_del: specify per-link additions or removals

Update ath12k_peer_assoc_h_mlo() to set the ml_reconfig, mlo_link_add,
and mlo_link_del flags in the peer_assoc_mlo_params structure based on
the reconf.added_links and reconf.removed_links bitmaps provided by
mac80211.

These flags are applied to both the self and partner links involved in
the reconfiguration. This allows firmware to interpret the context and
distinguish dynamic link updates from initial association.

Firmware uses these flags to block Tx/Rx on newly added links until
peer authorization is complete, ensure correct partner link setup
during transition, and support simultaneous link additions and
deletions while preserving MLD peer integrity.

Signed-off-by: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 10 ++++++++++
 drivers/net/wireless/ath/ath12k/wmi.c | 12 ++++++++++++
 drivers/net/wireless/ath/ath12k/wmi.h | 23 +++++++++++++++++++++++
 3 files changed, 45 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -4204,10 +4204,16 @@ static void ath12k_peer_assoc_h_mlo(stru
 	ml->ieee_link_id = arsta->link_id;
 	ml->bridge_peer = arsta->is_bridge_peer;
 	ml->num_partner_links = 0;
 	links = ahsta->links_map;
 
+	if (sta->reconf.removed_links & BIT(arsta->link_id))
+		ml->ml_reconfig = ml->mlo_link_del = true;
+
+	if (sta->reconf.added_links & BIT(arsta->link_id))
+		ml->ml_reconfig = ml->mlo_link_add = true;
+
 	rcu_read_lock();
 
 	i = 0;
 
 	for_each_set_bit(link_id, &links, ATH12K_NUM_MAX_LINKS) {
@@ -4231,10 +4237,14 @@ static void ath12k_peer_assoc_h_mlo(stru
 			   ml->partner_info[i].primary_umac = true;
 		   else
 			   ml->partner_info[i].primary_umac = false;
 		   ml->partner_info[i].logical_link_idx_valid = true;
 		ml->partner_info[i].logical_link_idx = arsta_p->link_idx;
+		if (sta->reconf.removed_links & BIT(arsta_p->link_id))
+			ml->ml_reconfig = ml->partner_info[i].mlo_link_del = true;
+		if (sta->reconf.added_links & BIT(arsta_p->link_id))
+			ml->ml_reconfig = ml->partner_info[i].mlo_link_add = true;
 		ml->num_partner_links++;
 
 		i++;
 	}
 
@@ -21092,10 +21102,15 @@ static int ath12k_mac_hw_register(struct
 		ath12k_iftypes_ext_capa[2].mld_capa_and_ops = cap->mld_cap;
 		wiphy->flags |= WIPHY_FLAG_SUPPORTS_MLO;
 
 		if(!is_raw_mode)
 			ieee80211_hw_set(hw, MLO_MCAST_MULTI_LINK_TX);
+
+		if (test_bit(WMI_SERVICE_STA_MLO_RCFG_SUPPORT,
+			     ar->ab->wmi_ab.svc_map))
+			ath12k_iftypes_ext_capa[2].mld_capa_and_ops |=
+				IEEE80211_MLD_CAP_OP_LINK_RECONF_SUPPORT;
 	}
 
 	hw->queues = ATH12K_HW_MAX_QUEUES;
 	wiphy->tx_queue_len = ATH12K_QUEUE_LEN;
 	hw->offchannel_tx_hw_queue = ATH12K_HW_MAX_QUEUES - 1;
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -3180,15 +3180,24 @@ int ath12k_wmi_send_peer_assoc_cmd(struc
 		ml_params->flags |= cpu_to_le32(ATH12K_WMI_FLAG_MLO_PEER_ID_VALID);
 
 	if (arg->ml.bridge_peer)
 		ml_params->flags |= cpu_to_le32(ATH12K_WMI_FLAG_MLO_BRIDGE_PEER);
 
+	if (arg->ml.mlo_link_add)
+		ml_params->flags |= cpu_to_le32(ATH12K_WMI_FLAG_MLO_LINK_ADD);
+
+	if (arg->ml.mlo_link_del)
+		ml_params->flags |= cpu_to_le32(ATH12K_WMI_FLAG_MLO_LINK_DEL);
+
 	ether_addr_copy(ml_params->mld_addr.addr, arg->ml.mld_addr);
 	ml_params->logical_link_idx = cpu_to_le32(arg->ml.logical_link_idx);
 	ml_params->ml_peer_id = cpu_to_le32(arg->ml.ml_peer_id);
 	ml_params->ieee_link_id = cpu_to_le32(arg->ml.ieee_link_id);
 
+	if (arg->ml.ml_reconfig)
+		ml_params->ml_reconfig = 1;
+
 	eml_cap = arg->ml.eml_cap;
 	if (u16_get_bits(eml_cap, IEEE80211_EML_CAP_EMLSR_SUPP)) {
 		/* Padding delay */
 		eml_delay = ath12k_wmi_get_emlsr_pad_delay_us(eml_cap);
 		ml_params->emlsr_padding_delay_us = cpu_to_le32(eml_delay);
@@ -3268,10 +3277,16 @@ skip_ml_params:
 
 		if (arg->ml.partner_info[i].bridge_peer)
 			partner_info->flags |=
 				cpu_to_le32(ATH12K_WMI_FLAG_MLO_BRIDGE_PEER);
 
+		if (arg->ml.partner_info[i].mlo_link_add)
+			partner_info->flags |= cpu_to_le32(ATH12K_WMI_FLAG_MLO_LINK_ADD);
+
+		if (arg->ml.partner_info[i].mlo_link_del)
+			partner_info->flags |= cpu_to_le32(ATH12K_WMI_FLAG_MLO_LINK_DEL);
+
 		partner_info->logical_link_idx =
 			cpu_to_le32(arg->ml.partner_info[i].logical_link_idx);
 		ptr += sizeof(*partner_info);
 	}
 
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2512,10 +2512,11 @@ enum wmi_tlv_service {
 	WMI_SERVICE_IS_TARGET_IPA = 425,
 	WMI_SERVICE_THERM_THROT_TX_CHAIN_MASK = 426,
 	WMI_SERVICE_THERM_THROT_5_LEVELS = 429,
 
 	WMI_SERVICE_UMAC_MIGRATION_SUPPORT = 436,
+	WMI_SERVICE_STA_MLO_RCFG_SUPPORT = 448,
 
 	WMI_MAX_EXT2_SERVICE,
 };
 
 enum wmi_unit_test_cmdid {
@@ -3269,10 +3270,11 @@ struct wmi_vdev_create_mlo_params {
 #define ATH12K_WMI_FLAG_MLO_PEER_ID_VALID		BIT(4)
 #define ATH12K_WMI_FLAG_MLO_MCAST_VDEV			BIT(5)
 #define ATH12K_WMI_FLAG_MLO_EMLSR_SUPPORT		BIT(6)
 #define ATH12K_WMI_FLAG_MLO_FORCED_INACTIVE		BIT(7)
 #define ATH12K_WMI_FLAG_MLO_LINK_ADD			BIT(8)
+#define ATH12K_WMI_FLAG_MLO_LINK_DEL			BIT(9)
 #define ATH12K_WMI_FLAG_MLO_BRIDGE_PEER			BIT(10)
 #define ATH12K_WMI_FLAG_MLO_BRIDGE_LINK			BIT(14)
 #define ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID		BIT(18)
 #define ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID_PARTNER	BIT(19)
 
@@ -3468,10 +3470,12 @@ struct wmi_ml_partner_info {
 	bool primary_umac;
 	bool logical_link_idx_valid;
 	bool mlo_bridge_link;
 	bool bridge_peer;
 	u32 logical_link_idx;
+	bool mlo_link_add;
+	bool mlo_link_del;
 };
 
 struct wmi_ml_arg {
 	bool enabled;
 	bool assoc_link;
@@ -4353,10 +4357,13 @@ struct peer_assoc_mlo_params {
 	u32 ml_peer_id;
 	u32 ieee_link_id;
 	u8 num_partner_links;
 	struct wmi_ml_partner_info partner_info[ATH12K_WMI_MLO_PEER_MAX_LINKS];
 	u16 eml_cap;
+	bool ml_reconfig;
+	bool mlo_link_add;
+	bool mlo_link_del;
 };
 
 struct wmi_rate_set_arg {
 	u32 num_rates;
 	u8 rates[WMI_MAX_SUPPORTED_RATES];
@@ -4608,10 +4615,20 @@ struct wmi_peer_assoc_mlo_params {
 	__le32 ml_peer_id;
 	__le32 ieee_link_id;
 	__le32 emlsr_trans_timeout_us;
 	__le32 emlsr_trans_delay_us;
 	__le32 emlsr_padding_delay_us;
+	__le32 msd_dur_subfield;
+	__le32 msd_ofdm_ed_thr;
+	__le32 msd_max_num_txops;
+	__le32 max_num_simultaneous_links;
+	__le32 nstr_indication_bitmap;
+	__le32 recommended_max_num_simultaneous_links;
+	struct {
+		__le32 ml_reconfig: 1,
+		       unused: 31;
+	};
 } __packed;
 
 struct wmi_peer_assoc_complete_cmd {
 	__le32 tlv_header;
 	struct ath12k_wmi_mac_addr_params peer_macaddr;
--- a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
@@ -2363,10 +2363,13 @@ static int ath12k_prep_htt_stats_cfg_par
 		cfg_params->cfg0 = HTT_STAT_DEFAULT_CFG0_CCA_CUMULATIVE;
 		break;
 	case ATH12K_DBG_HTT_EXT_STATS_TX_SOUNDING_INFO:
 		cfg_params->cfg0 = HTT_STAT_DEFAULT_CFG0_ACTIVE_VDEVS;
 		break;
+	case ATH12K_DBG_HTT_DBG_EXT_STATS_ML_PEERS_INFO:
+		cfg_params->cfg0 = HTT_STAT_DEFAULT_CFG0_MASK;
+		break;
 	default:
 		break;
 	}
 
 	return 0;
--- a/drivers/net/wireless/ath/ath12k/dp_htt.h
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.h
@@ -1768,10 +1768,11 @@ struct htt_ext_stats_cfg_cmd {
 #define HTT_STAT_DEFAULT_CFG0_ALL_CMDQS 0xffff
 #define HTT_STAT_DEFAULT_CFG0_ALL_RINGS 0xffff
 #define HTT_STAT_DEFAULT_CFG0_ACTIVE_PEERS 0xff
 #define HTT_STAT_DEFAULT_CFG0_CCA_CUMULATIVE 0x00
 #define HTT_STAT_DEFAULT_CFG0_ACTIVE_VDEVS 0x00
+#define HTT_STAT_DEFAULT_CFG0_MASK 0x07
 
 /* HTT_DBG_EXT_STATS_PEER_INFO
  * PARAMS:
  * @config_param0:
  *  [Bit0] - [0] for sw_peer_id, [1] for mac_addr based request
