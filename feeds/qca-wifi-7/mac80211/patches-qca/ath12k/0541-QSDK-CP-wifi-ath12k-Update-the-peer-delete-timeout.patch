From 9dade0123099ca04390ebe181246ff27fa19c02a Mon Sep 17 00:00:00 2001
From: Kannan Saravanan <kannsara@qti.qualcomm.com>
Date: Wed, 17 Sep 2025 22:38:37 +0530
Subject: [PATCH 1/2] QSDK:CP wifi:ath12l Update the peer delete timeout
for WSI bypass

For MAX client, current timeout of 10 sec is not sufficient.
Hence increase the timeout to 30 sec.

patch-dependency:0461-0003-CP-ADD-basic-support-for-WSI-bypass.patch
Signed-off-by: Kannan Saravanan <kannsara@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index af6bd42..19aaa3c 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -255,7 +255,7 @@ ath12k_phymodes[NUM_NL80211_BANDS][ATH12K_CHAN_WIDTH_NUM] = {
 #define ATH12K_MAX_NUM_BRIDGE_PER_MLD 2
 #define BRIDGE_IN_RANGE(ar) (ar->num_created_bridge_vdevs < TARGET_NUM_BRIDGE_VDEVS)
 #define ATH12K_MAX_AR_LINK_IDX	5
-#define ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS 10000
+#define ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS 30000
 
 static const u32 ath12k_smps_map[] = {
 	[WLAN_HT_CAP_SM_PS_STATIC] = WMI_PEER_SMPS_STATIC,
