From 8a3a3a923c46d47eab0b81f57786bd7588c122a3 Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Tue, 5 Aug 2025 17:24:32 +0530
Subject: [PATCH] QSDK:CP wifi:ath12k: Add debug log for NULL arvif during
 ath12k_get_arvif_iter

Add a debug message to investigate cases where rcu_dereference returns
NULL for arvif despite the presence of a link address. This may be due
to improper RCU read locking or incorrect link_id retrieval via
for_each_set_bit.

The log includes function name, link ID, links map, and direct dereference
pointer to aid debugging.

Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 13 ++++++++++++-
 1 file changed, 12 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index e657ed0..8577352 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -801,8 +801,19 @@ static void ath12k_get_arvif_iter(void *data, u8 *mac,
 	for_each_set_bit(link_id, &links_map, ATH12K_NUM_MAX_LINKS) {
 		arvif = rcu_dereference(ahvif->link[link_id]);
 
-		if (WARN_ON(!arvif))
+		if (!arvif) {
+			/* Adding this debug to find out how rcu-dereference
+			 * is returing NULL when link address is present.
+			 * There could be two reasons. Either read lock is
+			 * not proper or link_id retrieved by for_each_set_bit
+			 * is not right
+			 */
+			ath12k_err(NULL,
+				   "func %s arvif is NULL for link_id %d links_map 0x%lx arvif-direct de-ref %p\n",
+				   __func__, link_id, links_map, ahvif->link[link_id]);
+			WARN_ON(1);
 			continue;
+		}
 
 		if (arvif->vdev_id == arvif_iter->vdev_id &&
 		    arvif->ar == arvif_iter->ar) {
-- 
2.34.1

