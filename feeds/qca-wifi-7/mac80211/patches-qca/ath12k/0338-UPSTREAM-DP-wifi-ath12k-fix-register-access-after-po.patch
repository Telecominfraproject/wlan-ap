From 336bd8655d1a2fb19ed9bb5e5c1f35d3930ff676 Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Fri, 6 Jun 2025 12:53:58 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: fix register access after power
 down the target

During rmmod, REO QUEUE LUT base address is reset to 0 after
target power down which is invalid access.

Fix it by reset the REO QUEUE LUT address before target power
down.

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c | 11 +++++++++++
 drivers/net/wireless/ath/ath12k/dp.c   | 15 +++++++++++++--
 drivers/net/wireless/ath/ath12k/dp.h   |  1 +
 3 files changed, 25 insertions(+), 2 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -1241,6 +1241,12 @@ static void ath12k_core_hw_group_stop(st
 		clear_bit(ATH12K_FLAG_REGISTERED, &ab->dev_flags);
 
 		ath12k_core_device_cleanup(ab);
+		
+		if (ab->hw_params->reoq_lut_support) {
+			mutex_lock(&ab->core_lock);
+			ath12k_dp_reoq_lut_addr_reset(ath12k_ab_to_dp(ab));
+			mutex_unlock(&ab->core_lock);
+		}
 	}
 
 	ath12k_mac_destroy(ag);
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -1269,7 +1269,6 @@ static void ath12k_dp_reoq_lut_cleanup(s
 		return;
 
 	if (dp->reoq_lut.vaddr_unaligned) {
-		ath12k_hal_write_reoq_lut_addr(ab, 0);
 		ath12k_core_dma_free_coherent(ab->dev, dp->reoq_lut.size,
 					      dp->reoq_lut.vaddr_unaligned,
 					      dp->reoq_lut.paddr_unaligned);
@@ -1277,7 +1276,6 @@ static void ath12k_dp_reoq_lut_cleanup(s
 	}
 
 	if (dp->ml_reoq_lut.vaddr_unaligned) {
-		ath12k_hal_write_ml_reoq_lut_addr(ab, 0);
 		ath12k_core_dma_free_coherent(ab->dev, dp->ml_reoq_lut.size,
 					      dp->ml_reoq_lut.vaddr_unaligned,
 					      dp->ml_reoq_lut.paddr_unaligned);
@@ -1959,3 +1957,16 @@ void ath12k_dp_cmn_update_hw_links(struc
 	dp_hw_grp->hw_links[ar->hw_link_id].device_id = dp->device_id;
 	dp_hw_grp->hw_links[ar->hw_link_id].pdev_idx = ar->pdev_idx;
 }
+
+void ath12k_dp_reoq_lut_addr_reset(struct ath12k_dp *dp)
+{
+	struct ath12k_base *ab = dp->ab;
+
+	if (test_bit(ATH12K_FLAG_QMI_FW_READY_COMPLETE, &ab->dev_flags)){
+		if (dp->reoq_lut.vaddr_unaligned)
+			ath12k_hal_write_reoq_lut_addr(ab, 0);
+
+		if (dp->ml_reoq_lut.vaddr_unaligned)
+			ath12k_hal_write_ml_reoq_lut_addr(ab, 0);
+	}
+}
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -897,6 +897,7 @@ struct ath12k_tx_desc_info *ath12k_dp_ge
 						  u32 desc_id);
 bool ath12k_dp_wmask_compaction_rx_tlv_supported(struct ath12k_base *ab);
 void ath12k_dp_tx_update_bank_profile(struct ath12k_link_vif *arvif);
+void ath12k_dp_reoq_lut_addr_reset(struct ath12k_dp *dp);
 
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
 int ath12k_dp_tx_get_bank_profile(struct ath12k_base *ab, struct ath12k_link_vif *arvif,
