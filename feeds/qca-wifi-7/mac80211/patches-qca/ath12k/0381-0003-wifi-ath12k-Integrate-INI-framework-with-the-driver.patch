From bbd3746491c98dfadb1adec781f38654f1f1bf10 Mon Sep 17 00:00:00 2001
From: Uraj Sasan <usasan@qti.qualcomm.com>
Date: Sun, 29 Jun 2025 20:43:07 +0530
Subject: [PATCH 3/3] wifi: ath12k: Integrates INI framework with the driver

Initialises and Deinitialises the top level INI framework routines
which are involved during the driver loading. Once the INI file has
been parse and values being loaded in to the driver it can be used
for enabling various functions in the driver and Firmware.

Like we can fetch the values which is configured for rxdma
buffer ring and allocate the ring accordingly.

u32 ring_size  = cfg_get(ab, CFG_DP_RXDMA_BUF_RING);

int ath12k_dp_rx_alloc(struct ath12k_base *ab)
{
...

    u32 ring_size  = cfg_get(ab, CFG_DP_RXDMA_BUF_RING);

    ret = ath12k_dp_srng_setup(ab,
                   &dp->rx_refill_buf_ring.refill_buf_ring,
                   HAL_RXDMA_BUF, 0, 0,
                   ring_size);
....
}

With this we can control the memory allocation based on a given memory
profile. Similarly other allocations can be done based on the ini values
like number of PDEV,VDEV, PEERS etc.

It also support section based parsing and so user can provide variable
that should be applied to particular section eg 5G, 5GH, 5GL , 6G etc,

Signed-off-by: Uraj Sasan <usasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/Makefile | 4 +++-
 drivers/net/wireless/ath/ath12k/core.c   | 7 +++++++
 drivers/net/wireless/ath/ath12k/core.h   | 1 +
 drivers/net/wireless/ath/ath12k/wmi.c    | 2 ++
 4 files changed, 13 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/Makefile b/drivers/net/wireless/ath/ath12k/Makefile
index 0150773..35710f8 100644
--- a/drivers/net/wireless/ath/ath12k/Makefile
+++ b/drivers/net/wireless/ath/ath12k/Makefile
@@ -26,7 +26,9 @@ ath12k-y += core.o \
 	    ahb.o \
 	    vendor.o \
 	    umac_reset.o \
-	    accel_cfg.o
+	    accel_cfg.o \
+	    ini.o \
+	    ini_parse.o
 
 ath12k-$(CPTCFG_ATH12K_AHB) += ahb.o
 ath12k-$(CPTCFG_ATH12K_PPE_DS_SUPPORT) += ppe.o
diff --git a/drivers/net/wireless/ath/ath12k/core.c b/drivers/net/wireless/ath/ath12k/core.c
index 6a27658..04ae6c0 100644
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -32,6 +32,7 @@
 #include "peer.h"
 #include "ppe.h"
 #include "cfr.h"
+#include "ini.h"
 
 #define ATH12K_NUM_POOL_PPEDS_TX_DESC_DEFAULT 0x8000
 #define ATH12K_PPEDS_HOTLIST_LEN_MAX_DEFAULT 1024
@@ -1065,6 +1066,7 @@ static void ath12k_core_soc_destroy(struct ath12k_base *ab)
 	ath12k_reg_free(ab);
 	ath12k_debugfs_soc_destroy(ab);
 	ath12k_qmi_deinit_service(ab);
+	ath12k_cfg_deinit(ab);
 }
 
 static int ath12k_core_mlo_shmem_per_device_crash_info_addresses(
@@ -1546,6 +1548,11 @@ core_pdev_create:
 		mutex_unlock(&ab->core_lock);
 	}
 
+	if (ath12k_cfg_init(ab))
+		ath12k_err(ab, "failed to initialize INI data in driver\n");
+	else
+		ath12k_err(ab, "initialize INI data in driver\n");
+
 	return 0;
 
 err:
diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index 3c94bf3..0e486d2 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -1488,6 +1488,7 @@ struct ath12k_base {
 #ifdef CPTCFG_ATH12K_DEBUGFS
 	struct dentry *debugfs_soc;
 #endif
+	struct ath12k_cfg_ctx *cfg_ctx;
 	unsigned long dev_flags;
 	struct completion driver_recovery;
 	struct workqueue_struct *workqueue;
diff --git a/drivers/net/wireless/ath/ath12k/wmi.c b/drivers/net/wireless/ath/ath12k/wmi.c
index 613e03c..1286431 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -25,6 +25,7 @@
 #include "dp_mon.h"
 #include "vendor.h"
 #include "cfr.h"
+#include "ini.h"
 
 struct ath12k_wmi_svc_ready_parse {
 	bool wmi_svc_bitmap_done;
@@ -5757,6 +5758,7 @@ int ath12k_wmi_cmd_init(struct ath12k_base *ab)
 
 	arg.num_band_to_mac = ab->num_radios;
 	ath12k_fill_band_to_mac_param(ab, arg.band_to_mac);
+	ath12k_cfg_parse_pdev_section(ab);
 
 	dp->peer_metadata_ver = arg.res_cfg.peer_metadata_ver;
 
