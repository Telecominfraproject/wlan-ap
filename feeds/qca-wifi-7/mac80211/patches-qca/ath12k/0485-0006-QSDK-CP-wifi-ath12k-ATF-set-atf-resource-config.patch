From b1e39362a7dd8fe8c26f337ec4c74c40920c8a6b Mon Sep 17 00:00:00 2001
From: Harshitha Prem <hprem@qti.qualcomm.com>
Date: Fri, 15 Aug 2025 21:05:03 +0530
Subject: [PATCH] QSDK:CP: wifi: ath12k: ATF: set atf resource config

Set ATF resource config flag if the ATF service bit is
advertised by firmware.

Also, add a debug message in ATF group config.

Signed-off-by: Harshitha Prem <hprem@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/wmi.c | 3 +++
 drivers/net/wireless/ath/ath12k/wmi.c       | 4 ++++
 drivers/net/wireless/ath/ath12k/wmi.h       | 1 +
 3 files changed, 8 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/wmi.c b/drivers/net/wireless/ath/ath12k/wifi7/wmi.c
index 2d1f45c..4026316 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/wmi.c
@@ -66,6 +66,9 @@ void ath12k_wifi7_wmi_init_qcn9274(struct ath12k_base *ab,
 	if (test_bit(WMI_TLV_SERVICE_SDWF_LEVEL0, ab->wmi_ab.svc_map))
 		config->qos = true;
 
+	if (test_bit(WMI_TLV_SERVICE_ATF, ab->wmi_ab.svc_map))
+		config->atf_config |= WMI_RSRC_CFG_FLAG1_ATF_OFFLOAD_ENABLE;
+
 	config->max_beacon_size = TARGET_MAX_BEACON_SIZE;
 
 	if (of_machine_is_compatible("qcom,ipq5424"))
diff --git a/drivers/net/wireless/ath/ath12k/wmi.c b/drivers/net/wireless/ath/ath12k/wmi.c
index f22d3db..4ff3b55 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -17896,6 +17896,10 @@ int ath12k_wmi_atf_send_group_config(struct ath12k *ar)
 					 WMI_ATF_GROUP_NUM_EXPLICIT_PEERS);
 		group_info->atf_total_implicit_peer_units =
 			cpu_to_le32(group->unconfigured_peers_airtime);
+		ath12k_dbg(ar->ab, ATH12K_DBG_WMI, "id: %d  airtime %d flags %d num: %d",
+			   group_info->atf_group_id, group_info->atf_group_units,
+			   group_info->atf_group_flags, group_info->atf_total_num_peers);
+
 		group_info++;
 	}
 
diff --git a/drivers/net/wireless/ath/ath12k/wmi.h b/drivers/net/wireless/ath/ath12k/wmi.h
index 7fb5d08..8a9f044 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2924,6 +2924,7 @@ struct wmi_ctrl_path_pmlo_telemetry_stats {
 #define WMI_RSRC_CFG_HOST_SVC_FLAG_FULL_BW_NOL_SUPPORT_BIT	14
 #define WMI_RSRC_CFG_FLAGS2_RX_PEER_METADATA_VERSION		GENMASK(5, 4)
 #define WMI_RSRC_CFG_FLAG1_BSS_CHANNEL_INFO_64	BIT(5)
+#define WMI_RSRC_CFG_FLAG1_ATF_OFFLOAD_ENABLE BIT(6)
 #define WMI_RSRC_CFG_FLAG1_VIDEO_OVER_WIFI_ENABLE        BIT(23)
 #define WMI_RSRC_CFG_FLAGS2_CALC_NEXT_DTIM_COUNT_SET      BIT(9)
 #define WMI_RSRC_CFG_FLAGS2_SAWF_CONFIG_ENABLE_SET             BIT(13)
-- 
2.34.1

