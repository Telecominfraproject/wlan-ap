From fe3f66c6711aa5109f3df53db99fa633ed412023 Mon Sep 17 00:00:00 2001
From: Sriram Sankar Sankarapandian Thangaraj <sriramsa@qti.qualcomm.com>
Date: Fri, 15 Aug 2025 06:05:53 +0530
Subject: [PATCH] KUNIT: Make changes to enable GCOV_PROFILE

Enable GCOV_PROFILE for ath packages on kunit
debug builds

Signed-off-by: Sriram Sankar Sankarapandian Thangaraj <sriramsa@qti.qualcomm.com>
---
 drivers/net/wireless/ath/Makefile              | 4 ++++
 drivers/net/wireless/ath/ath12k/Makefile       | 4 ++++
 drivers/net/wireless/ath/ath12k/wifi7/Makefile | 4 ++++
 3 files changed, 12 insertions(+)

diff --git a/drivers/net/wireless/ath/Makefile b/drivers/net/wireless/ath/Makefile
index 0470f37..b07f28b 100644
--- a/drivers/net/wireless/ath/Makefile
+++ b/drivers/net/wireless/ath/Makefile
@@ -25,3 +25,7 @@ ath-$(CPTCFG_ATH_DEBUG) += debug.o
 ath-$(CPTCFG_ATH_TRACEPOINTS) += trace.o
 
 CFLAGS_trace.o := -I$(src)
+
+ifeq ($(CONFIG_KERNEL_ATH_GCOV_PROFILE),)
+GCOV_PROFILE:=y
+endif
diff --git a/drivers/net/wireless/ath/ath12k/Makefile b/drivers/net/wireless/ath/ath12k/Makefile
index a27e299..201a5e6 100644
--- a/drivers/net/wireless/ath/ath12k/Makefile
+++ b/drivers/net/wireless/ath/ath12k/Makefile
@@ -62,3 +62,7 @@ ath12k-$(CPTCFG_ATH12K_CFR) += cfr.o
 
 # for tracing framework to find trace.h
 CFLAGS_trace.o := -I$(src)
+
+ifeq ($(CONFIG_KERNEL_ATH_GCOV_PROFILE),)
+GCOV_PROFILE:=y
+endif
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/Makefile b/drivers/net/wireless/ath/ath12k/wifi7/Makefile
index 86f7ff1..46a9370 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/Makefile
+++ b/drivers/net/wireless/ath/ath12k/wifi7/Makefile
@@ -24,3 +24,7 @@ ath12k_wifi7-y += core.o \
 ath12k_wifi7-$(CPTCFG_QCN_EXTN) += qcn_extns/wifi7_hw_extn.o
 
 ath12k_wifi7-$(CPTCFG_ATH12K_AHB) += ahb.o
+
+ifeq ($(CONFIG_KERNEL_ATH_GCOV_PROFILE),)
+GCOV_PROFILE:=y
+endif
-- 
2.34.1

