From 48fec01df7568f52fead51f2b1fc2831c4013f40 Mon Sep 17 00:00:00 2001
From: Sai Rupesh Chevuru <chevuru@qti.qualcomm.com>
Date: Thu, 7 Aug 2025 12:21:13 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: stability improvements for IPQ5424

This patch addresses key stability issues observed on IPQ5424:
1. Memory Corruption due to duplicate TX completions
Introduces dmb(oshst) to enforce memory ordering during
TX ring register updates. Previously, use of writel_relaxed()
without barriers led to duplicate completions and memory
corruption under peak KPI conditions.

2. RX Scratch Pad Memory Leak
Fixes a memory leak related to RX scratch pad memory allocation.

Patch-dependency: None
Signed-off-by: Sai Rupesh Chevuru <chevuru@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c          | 3 +++
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 2 --
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index 4c06f72..ecd18c5 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -2280,6 +2280,9 @@ void ath12k_dp_cmn_hw_group_assign(struct ath12k_dp *dp,
 	}
 
 	for (i = 0; i < DP_REO_DST_RING_MAX; i++) {
+		if (dp_hw_grp->rx_status_buf[i])
+			continue;
+
 		/* Each arch rx process handler can use this buffer by typecasting its own
 		 * entry struct (aligned to 32 bytes).
 		 */
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index 6b76699..d03cf88 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -931,9 +931,7 @@ ath12k_wifi7_dp_tx(struct ath12k_pdev_dp *dp_pdev,
 		}
 
 		memcpy(hal_tcl_desc, &tcl_desc, sizeof(tcl_desc));
-#ifndef CONFIG_IO_COHERENCY
 		dmb(oshst);
-#endif
 		ath12k_hal_srng_access_umac_src_ring_end_nolock_fast(tcl_ring);
 
 		dp->device_stats.tx_fast_unicast[ring_id]++;
-- 
2.34.1

