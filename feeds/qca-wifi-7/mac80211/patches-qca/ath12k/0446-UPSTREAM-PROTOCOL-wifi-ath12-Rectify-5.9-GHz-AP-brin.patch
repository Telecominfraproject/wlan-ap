From 4b465f3c0df2951ef39bf5f160ac4f0cd1c02dbe Mon Sep 17 00:00:00 2001
From: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
Date: Wed, 23 Jul 2025 06:28:48 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:wifi:ath12: Rectify 5.9 GHz AP bring up
 issue

An AP that does not have the 5.9 GHz BDF service flag enabled is able
to operate on the 5.9 GHz channels.

Some changes present in the 3.1 component's
625-ath12k-supporting-5.9G-band-with-160Mhz.patch
were missed in the 4.0 component's
0317-ath12k-supporting-5.9G-band-with-160Mhz.patch during the package
upgrade. These changes involve disabling the 5.9 GHz channels in the
sband, depending on whether the 5.9 GHz BDF service flag is set.

To fix this issue, incorporate the missing changes into the 4.0 component.

Tag: REGULATORY
Fixes: I026a851ab13('ath12k: add support to select all 6 GHZ regulatory rules')

Signed-off-by: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 43 +++++++++++++++++++++------
 drivers/net/wireless/ath/ath12k/reg.c |  3 +-
 drivers/net/wireless/ath/ath12k/wmi.h |  1 +
 3 files changed, 37 insertions(+), 10 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -19826,6 +19826,27 @@ static void ath12k_mac_update_ch_list(st
 	}
 }
 
+#define ATH12K_5_9_MIN_FREQ 5845
+#define ATH12K_5_9_MAX_FREQ 5885
+
+static void ath12k_mac_update_5_9_ch_list(struct ath12k *ar,
+					  struct ieee80211_supported_band *band)
+{
+	int i;
+
+	if (test_bit(WMI_TLV_SERVICE_5_9GHZ_SUPPORT, ar->ab->wmi_ab.svc_map))
+		return;
+
+	if (ar->ab->dfs_region != ATH12K_DFS_REG_FCC)
+		return;
+
+	for (i = 0; i < band->n_channels; i++) {
+		if (band->channels[i].center_freq >= ATH12K_5_9_MIN_FREQ &&
+		    band->channels[i].center_freq <= ATH12K_5_9_MAX_FREQ)
+			band->channels[i].flags |= IEEE80211_CHAN_DISABLED;
+	}
+}
+
 static u32 ath12k_get_phy_id(struct ath12k *ar, u32 band)
 {
 	struct ath12k_pdev *pdev = ar->pdev;
@@ -19937,7 +19958,7 @@ static int ath12k_mac_setup_channels_rat
 		      ARRAY_SIZE(ath12k_6ghz_channels)) !=
 		     ATH12K_NUM_CHANS);
 
-	reg_cap = &ar->ab->hal_reg_cap[ar->pdev_idx];
+	reg_cap = &ab->hal_reg_cap[ar->pdev_idx];
 
 	if (supported_bands & WMI_HOST_WLAN_2GHZ_CAP) {
 		channels = kmemdup(ath12k_2ghz_channels,
@@ -19955,7 +19976,7 @@ static int ath12k_mac_setup_channels_rat
 
 		if (ab->hw_params->single_pdev_only) {
 			phy_id = ath12k_get_phy_id(ar, WMI_HOST_WLAN_2GHZ_CAP);
-			reg_cap = &ar->ab->hal_reg_cap[phy_id];
+			reg_cap = &ab->hal_reg_cap[phy_id];
 		}
 
 		freq_low = max(reg_cap->low_2ghz_chan,
@@ -20023,7 +20044,7 @@ static int ath12k_mac_setup_channels_rat
 			ath12k_mac_update_ch_list(ar, band,
 						  freq_low,
 						  freq_high);
-
+			ath12k_mac_update_5_9_ch_list(ar, band);
 			ar->num_channels = ath12k_reg_get_num_chans_in_band(ar, band);
 			if (!bands[NL80211_BAND_5GHZ]) {
 				bands[NL80211_BAND_5GHZ] = band;
--- a/drivers/net/wireless/ath/ath12k/reg.c
+++ b/drivers/net/wireless/ath/ath12k/reg.c
@@ -937,7 +937,8 @@ static void ath12k_copy_reg_rule(struct
 	if (!ath12k_reg_freq->start_freq)
 		ath12k_reg_freq->start_freq = reg_rule->start_freq;
 
-	if (!ath12k_reg_freq->end_freq || ath12k_reg_freq->end_freq < reg_rule->end_freq)
+	if (!ath12k_reg_freq->end_freq ||
+	    ath12k_reg_freq->end_freq < reg_rule->end_freq)
 		ath12k_reg_freq->end_freq = reg_rule->end_freq;
 }
 
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2533,6 +2533,7 @@ enum wmi_tlv_service {
 	WMI_TLV_SERVICE_FREQINFO_IN_METADATA = 219,
 	WMI_TLV_SERVICE_EXT2_MSG = 220,
 	WMI_TLV_SERVICE_MULTIPLE_VDEV_RESTART_RESPONSE_SUPPORT = 235,
+	WMI_TLV_SERVICE_5_9GHZ_SUPPORT = 247,
 	WMI_TLV_SERVICE_SRG_SRP_SPATIAL_REUSE_SUPPORT = 249,
 	WMI_TLV_SERVICE_CTRL_PATH_STATS_REQUEST = 250,
 	WMI_TLV_SERVICE_MBSS_PARAM_IN_VDEV_START_SUPPORT = 253,
