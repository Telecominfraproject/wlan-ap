 	if (ath12k_debugfs_is_extd_rx_stats_enabled(ar)) {
 		debugfs_create_file("rx_stats", 0400, dir, link_sta,
 				    &fops_rx_stats);
@@ -928,5 +1357,6 @@ void ath12k_debugfs_link_sta_op_add(struct ieee80211_hw *hw,
