 drivers/net/wireless/ath/ath12k/dp_rx.c       |  45 +++++++-
 drivers/net/wireless/ath/ath12k/dp_rx.h       |   6 +
 drivers/net/wireless/ath/ath12k/dp_stats.h    |  33 ++++++
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 104 ++++++++++++------
 5 files changed, 159 insertions(+), 34 deletions(-)

