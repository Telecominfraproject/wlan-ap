From 92c985dbb3a11c87dd82ebbe57308c0449cca5d0 Mon Sep 17 00:00:00 2001
From: Kannan Saravanan <kannsara@qti.qualcomm.com>
Date: Thu, 18 Sep 2025 16:32:00 +0530
Subject: [PATCH 1/1] QSDK:CP wifi:ath12k Add debugfs entry to modify WSI peer
 delete timeout

Add debugfs entry to modify WSI peer delete timeout for debugging.

Example config:
echo <1/2> <peer delete timeout> > /sys/kernel/debug/ath12k/<chip info>/wsi_bypass_device

Peer delete timeout is the optional argument, if not passed, default value
30 sec will be used.

patch-dependency: 0461-0003-CP-ADD-basic-support-for-WSI-bypass.patch
Signed-off-by: Kannan Saravanan <kannsara@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c    |  1 +
 drivers/net/wireless/ath/ath12k/core.h    |  4 ++++
 drivers/net/wireless/ath/ath12k/debugfs.c | 18 +++++++++++++++++-
 drivers/net/wireless/ath/ath12k/mac.c     |  7 +++----
 4 files changed, 25 insertions(+), 5 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.c b/drivers/net/wireless/ath/ath12k/core.c
index 230f053..07908a0 100644
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -3911,6 +3911,7 @@ static struct ath12k_hw_group *ath12k_core_hw_group_alloc(struct ath12k_base *ab
 	ag->mlo_capable = false;
 	ag->recovery_mode = ATH12K_MLO_RECOVERY_MODE0;
 	ag->wsi_load_info = NULL;
+	ag->wsi_peer_clean_timeout = ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS;
 
 #ifdef CPTCFG_ATH12K_POWER_OPTIMIZATION
 	ath12k_global_ps_ctx.ag = ag;
diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index 5e90f6f..e8077d8 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -78,6 +78,9 @@
 /* The magic used by QCA spec */
 #define ATH12K_SMBIOS_BDF_EXT_MAGIC "BDF_"
 
+/* Timeout value for the Peer cleanup during WSI bypass */
+#define ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS 30000
+
 #define ATH12K_INVALID_HW_MAC_ID	0xFF
 #define ATH12K_CONNECTION_LOSS_HZ	(3 * HZ)
 #define ATH12K_SMEM_HOST                1
@@ -1681,6 +1684,7 @@ struct ath12k_hw_group {
 	u8 num_bypassed;
 	bool wsi_remap_in_progress;
 	struct completion peer_cleanup_complete;
+	u64 wsi_peer_clean_timeout;
 };
 
 /* Holds WSI info specific to each device, excluding WSI group info */
diff --git a/drivers/net/wireless/ath/ath12k/debugfs.c b/drivers/net/wireless/ath/ath12k/debugfs.c
index 4a2be83..721da5a 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs.c
@@ -153,12 +153,28 @@ ath12k_debug_write_wsi_bypass_device(struct file *file,
 {
 	struct ath12k_base *ab = file->private_data;
 	unsigned int value;
+	u64 peer_timeout;
 	int ret, i;
 	struct ath12k_hw_group *ag = ab->ag;
 	struct ath12k_base *partner_ab;
+	char buf[128] = {0};
 
-	if (kstrtouint_from_user(user_buf, count, 0, &value))
+	ret = simple_write_to_buffer(buf, sizeof(buf) - 1, ppos,
+				     user_buf, count);
+
+	if (ret <= 0)
+		goto exit;
+
+	ret = sscanf(buf, "%u %llu", &value, &peer_timeout);
+
+	if (ret < 1 || ret > 2) {
 		return -EINVAL;
+	} else if (ret == 2) {
+		ath12k_info(ab, "Updating peer delete timeout to %llu", peer_timeout);
+		ag->wsi_peer_clean_timeout = peer_timeout;
+	} else {
+		ag->wsi_peer_clean_timeout = ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS;
+	}
 
 	if (value > ATH12K_WSI_BYPASS_ADD_DEVICE ||
 	    value <= ATH12K_WSI_BYPASS_DEFAULT) {
diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 19aaa3c..b088c1b 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -255,7 +255,6 @@ ath12k_phymodes[NUM_NL80211_BANDS][ATH12K_CHAN_WIDTH_NUM] = {
 #define ATH12K_MAX_NUM_BRIDGE_PER_MLD 2
 #define BRIDGE_IN_RANGE(ar) (ar->num_created_bridge_vdevs < TARGET_NUM_BRIDGE_VDEVS)
 #define ATH12K_MAX_AR_LINK_IDX	5
-#define ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS 30000
 
 static const u32 ath12k_smps_map[] = {
 	[WLAN_HT_CAP_SM_PS_STATIC] = WMI_PEER_SMPS_STATIC,
@@ -24421,13 +24420,13 @@ int ath12k_mac_dynamic_wsi_remap(struct ath12k_base *ab)
 	if (num_ml_peers) {
 		reinit_completion(&ag->peer_cleanup_complete);
 		time_left = wait_for_completion_timeout(&ag->peer_cleanup_complete,
-				msecs_to_jiffies(ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS));
+				msecs_to_jiffies(ag->wsi_peer_clean_timeout));
 
 		ath12k_dbg(ab, ATH12K_DBG_WSI_BYPASS,
 			   "Bypass: Waiting for ML peer cleanup\n");
 		if (!time_left) {
-			ath12k_err(ab, "peer cleanup didn't get completed within %d ms\n",
-				   ATH12K_MAC_PEER_CLEANUP_TIMEOUT_MSECS);
+			ath12k_err(ab, "peer cleanup didn't get completed within %lld ms, pending peers %d\n",
+				   ag->wsi_peer_clean_timeout, ah->num_ml_peers);
 			return -ETIMEDOUT;
 		}
 	}
-- 
