+			if (ret && test_bit(ATH12K_FLAG_CRASH_FLUSH,
+					    &wmi_ab->ab->dev_flags))
+				ret = -ESHUTDOWN;
 
-		(ret != -EAGAIN);
-	}), WMI_SEND_TIMEOUT_HZ);
+			(ret != -ENOBUFS);
+			}), WMI_SEND_TIMEOUT_HZ);
