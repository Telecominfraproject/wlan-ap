+		wait_event_timeout(wmi_ab->tx_credits_wq, ({
+			ret = ath12k_wmi_cmd_send_nowait(wmi, skb, cmd_id);
+
+			if (ret && test_bit(ATH12K_FLAG_CRASH_FLUSH,
+					    &wmi_ab->ab->dev_flags))
+				ret = -ESHUTDOWN;
+			(ret != -EAGAIN);
+			}), WMI_SEND_TIMEOUT_HZ);
+	} else {
+		wait_event_timeout(wmi->tx_ce_desc_wq, ({
