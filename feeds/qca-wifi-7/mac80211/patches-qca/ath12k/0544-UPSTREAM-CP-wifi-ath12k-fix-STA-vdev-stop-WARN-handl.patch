From 336d5790e903e21e8013d05e71ce7795714ba731 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <bramar@qti.qualcomm.com>
Date: Mon, 22 Sep 2025 15:52:36 +0530
Subject: [PATCH] UPSTREAM:CP:wifi: ath12k: fix STA vdev stop/WARN handling in
 teardown and chanctx unassign

The teardown paths had inconsistent handling of `arvif->is_started` for
STA vdevs which could lead to spurious WARN splats and stale state:

ath12k_mac_station_remove() (STA vdev):
  - Add a guard `WARN_ON(!arvif->is_started)` to catch unexpected
    removal when the vdev was never started.
  - After stopping the vdev, explicitly clear `arvif->is_started` to
    avoid leaving the vdev in a “started” state, which could trigger a
    later WARN or attempt a double stop.

ath12k_mac_unassign_vif_chanctx_handle():
  - Only keep `WARN_ON(!arvif->is_started)` for non-STA vdev types.
    For STA vdevs mac80211 may unassign the channel context during
    disconnect/teardown windows where the vdev is not up yet (or has
    just gone down), so warning there is noisy and not actionable.
  - For STA vdevs, if the vdev was started but is not up, stop it to
    keep driver/firmware state consistent.

This prevents false-positive WARN_ON()s in the chanctx unassign path for
STA vdevs and ensures `is_started` is cleared when the vdev is stopped
during station removal, avoiding stale state and potential double-stop
attempts.

No functional change for active vdevs; affects teardown/transition paths
only

Signed-off-by: Balamurugan Ramar <bramar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -10719,12 +10719,14 @@ static int ath12k_mac_station_remove(str
 	wiphy_work_cancel(ar->ah->hw->wiphy, &arsta->update_wk);
 
 	if (ahvif->vdev_type == WMI_VDEV_TYPE_STA) {
+		WARN_ON(!arvif->is_started);
 		ath12k_bss_disassoc(ar, arvif);
 
 		ret = ath12k_mac_vdev_stop(arvif);
 		if (ret)
 			ath12k_warn(ar->ab, "failed to stop vdev %i: %d\n",
 				    arvif->vdev_id, ret);
+		arvif->is_started = false;
 	}
 
 	if (sta->mlo)
@@ -18519,7 +18521,8 @@ ath12k_mac_unassign_vif_chanctx_handle(s
 			   "mac chanctx unassign for vdev_id %i vdev_subtype %0x\n",
 			   arvif->vdev_id, arvif->vdev_subtype);
 
-	WARN_ON(!arvif->is_started);
+	if (ahvif->vdev_type != WMI_VDEV_TYPE_STA)
+		WARN_ON(!arvif->is_started);
 
 	if (ahvif->vdev_type == WMI_VDEV_TYPE_MONITOR) {
 		ret = ath12k_mac_monitor_stop(ar);
@@ -18535,6 +18538,12 @@ ath12k_mac_unassign_vif_chanctx_handle(s
 		ret = ath12k_mac_vdev_stop(arvif);
 		if (ret)
 			ath12k_warn(ab, "failed to stop vdev %i: %d\n",
+				    arvif->vdev_id, ret);
+	} else if (ahvif->vdev_type == WMI_VDEV_TYPE_STA &&
+		   arvif->is_started && !arvif->is_up) {
+		ret = ath12k_mac_vdev_stop(arvif);
+		if (ret)
+			ath12k_warn(ab, "failed to stop vdev %i: %d\n",
 				    arvif->vdev_id, ret);
 	}
 
