From 3fca15ef80332fd19d8fcfb74029a0ccb9c94419 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <bramar@qti.qualcomm.com>
Date: Tue, 13 May 2025 22:21:33 +0530
Subject: [PATCH] ath12k: Fix kernel panic during mac_setup_channels_rates

Fixed Unable to handle kernel read from unreadable memory kernel panic
when parsing band->chan_6g.

Signed-off-by: Aishwarya R <aisr@qti.qualcomm.com>
Signed-off-by: Balamurugan Ramar <bramar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 125 ++++++++++++++++----------
 1 file changed, 76 insertions(+), 49 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -14763,19 +14763,32 @@ static void ath12k_mac_update_ch_list(st
 				      struct ieee80211_supported_band *band,
 				      u32 freq_low, u32 freq_high)
 {
-	int i;
+	struct ieee80211_6ghz_channel *chan_6g;
+	int i, j;
 
 	if (!(freq_low && freq_high))
 		return;
 
+	ar->freq_range.start_freq = MHZ_TO_KHZ(freq_low);
+        ar->freq_range.end_freq = MHZ_TO_KHZ(freq_high);
+
+	if (band->band == NL80211_BAND_6GHZ) {
+		for (i = 0; i < NL80211_REG_NUM_POWER_MODES; i++) {
+			chan_6g = band->chan_6g[i];
+			for (j = 0; j < chan_6g->n_channels; j++) {
+				if (chan_6g->channels[j].center_freq < freq_low ||
+				    chan_6g->channels[j].center_freq > freq_high)
+					chan_6g->channels[j].flags |= IEEE80211_CHAN_DISABLED;
+			}
+		}
+		return;
+	}
+
 	for (i = 0; i < band->n_channels; i++) {
 		if (band->channels[i].center_freq < freq_low ||
 		    band->channels[i].center_freq > freq_high)
 			band->channels[i].flags |= IEEE80211_CHAN_DISABLED;
 	}
-
-	ar->freq_range.start_freq = MHZ_TO_KHZ(freq_low);
-	ar->freq_range.end_freq = MHZ_TO_KHZ(freq_high);
 }
 
 static u32 ath12k_get_phy_id(struct ath12k *ar, u32 band)
@@ -14834,7 +14847,8 @@ static int ath12k_mac_setup_channels_rat
 	struct ath12k_hw *ah = ar->ah;
 	void *channels;
 	u32 phy_id, freq_low, freq_high;
-	int ret;
+	struct ieee80211_6ghz_channel *chan_6g;
+	int ret, i = 0;
 
 	BUILD_BUG_ON((ARRAY_SIZE(ath12k_2ghz_channels) +
 		      ARRAY_SIZE(ath12k_5ghz_channels) +
@@ -14886,82 +14900,106 @@ static int ath12k_mac_setup_channels_rat
 	}
 
 	if (supported_bands & WMI_HOST_WLAN_5GHZ_CAP) {
-		if (reg_cap->high_5ghz_chan >= ATH12K_MIN_6GHZ_FREQ) {
-			channels = kmemdup(ath12k_6ghz_channels,
-					   sizeof(ath12k_6ghz_channels), GFP_KERNEL);
+		/* If 5g end and 6g start overlaps, decide band based on
+		 * the difference between target limit and ATH12K_5G_MAX_CENTER
+		 */
+		if ((reg_cap->low_5ghz_chan >= ATH12K_MIN_5GHZ_FREQ) &&
+		    ((reg_cap->high_5ghz_chan < ATH12K_MAX_5GHZ_FREQ) ||
+		     ((reg_cap->high_5ghz_chan - ATH12K_5GHZ_MAX_CENTER) < (ATH12K_HALF_20MHZ_BW * 2)))) {
+			channels = kmemdup(ath12k_5ghz_channels,
+					   sizeof(ath12k_5ghz_channels), GFP_KERNEL);
 			if (!channels) {
 				kfree(ar->mac.sbands[NL80211_BAND_2GHZ].channels);
+				for (i = 0; i < NL80211_REG_NUM_POWER_MODES; i++)
+					kfree(ar->mac.sbands[NL80211_BAND_6GHZ].chan_6g[i]);
+
 				return -ENOMEM;
 			}
 
-			ar->supports_6ghz = true;
-			band = &ar->mac.sbands[NL80211_BAND_6GHZ];
-			band->band = NL80211_BAND_6GHZ;
-			band->n_channels = ARRAY_SIZE(ath12k_6ghz_channels);
+			band = &ar->mac.sbands[NL80211_BAND_5GHZ];
+			band->band = NL80211_BAND_5GHZ;
+			band->n_channels = ARRAY_SIZE(ath12k_5ghz_channels);
 			band->channels = channels;
 			band->n_bitrates = ath12k_a_rates_size;
 			band->bitrates = ath12k_a_rates;
 
+			if (ar->ab->hw_params->single_pdev_only)
+				phy_id = ath12k_get_phy_id(ar, WMI_HOST_WLAN_5GHZ_CAP);
+
 			freq_low = max(reg_cap->low_5ghz_chan,
-				       ab->reg_freq_6g.start_freq);
+				       ab->reg_freq_5g.start_freq);
 			freq_high = min(reg_cap->high_5ghz_chan,
-					ab->reg_freq_6g.end_freq);
+					ab->reg_freq_5g.end_freq);
 
 			ath12k_mac_update_ch_list(ar, band,
 						  freq_low,
 						  freq_high);
-			ah->use_6ghz_regd = true;
+
 			ar->num_channels = ath12k_reg_get_num_chans_in_band(ar, band);
-			if (!bands[NL80211_BAND_6GHZ]) {
-				bands[NL80211_BAND_6GHZ] = band;
+			if (!bands[NL80211_BAND_5GHZ]) {
+				bands[NL80211_BAND_5GHZ] = band;
 			} else {
 				/* Split mac in same band under same wiphy during MLO */
 				ret = ath12k_mac_update_band(ar,
-							     bands[NL80211_BAND_6GHZ],
+							     bands[NL80211_BAND_5GHZ],
 							     band);
 				if (ret)
 					return ret;
 				ath12k_dbg(ar->ab, ATH12K_DBG_MAC, "mac pdev %u identified as 6 GHz split mac during MLO\n",
 					   ar->pdev->pdev_id);
 			}
-		}
+		} else if (reg_cap->low_5ghz_chan >= ATH12K_MIN_6GHZ_FREQ &&
+			   reg_cap->high_5ghz_chan <= ATH12K_MAX_6GHZ_FREQ) {
+			band = &ar->mac.sbands[NL80211_BAND_6GHZ];
+			band->band = NL80211_BAND_6GHZ;
+			for (i = 0; i < NL80211_REG_NUM_POWER_MODES; i++) {
+				channels = kmemdup(ath12k_6ghz_channels,
+						   sizeof(ath12k_6ghz_channels),
+						   GFP_KERNEL);
+				chan_6g = kzalloc(sizeof(*chan_6g), GFP_ATOMIC);
+				if (!channels || !chan_6g) {
+					kfree(ar->mac.sbands[NL80211_BAND_2GHZ].channels);
+					break;
+				}
+				chan_6g->channels = channels;
+				chan_6g->n_channels = ARRAY_SIZE(ath12k_6ghz_channels);
+				band->chan_6g[i] = chan_6g;
+				channels = NULL;
+				chan_6g = NULL;
+			}
 
-		if (reg_cap->low_5ghz_chan < ATH12K_MIN_6GHZ_FREQ) {
-			channels = kmemdup(ath12k_5ghz_channels,
-					   sizeof(ath12k_5ghz_channels),
-					   GFP_KERNEL);
-			if (!channels) {
-				kfree(ar->mac.sbands[NL80211_BAND_2GHZ].channels);
-				kfree(ar->mac.sbands[NL80211_BAND_6GHZ].channels);
+			if (i < NL80211_REG_NUM_POWER_MODES) {
+				for (i = i - 1; i >= 0; i--) {
+					chan_6g = band->chan_6g[i];
+					kfree(chan_6g->channels);
+					kfree(chan_6g);
+					band->chan_6g[i] = NULL;
+				}
 				return -ENOMEM;
 			}
-
-			band = &ar->mac.sbands[NL80211_BAND_5GHZ];
-			band->band = NL80211_BAND_5GHZ;
-			band->n_channels = ARRAY_SIZE(ath12k_5ghz_channels);
-			band->channels = channels;
+			ar->supports_6ghz = true;
 			band->n_bitrates = ath12k_a_rates_size;
 			band->bitrates = ath12k_a_rates;
-
-			if (ar->ab->hw_params->single_pdev_only) {
-				phy_id = ath12k_get_phy_id(ar, WMI_HOST_WLAN_5GHZ_CAP);
-				reg_cap = &ar->ab->hal_reg_cap[phy_id];
-			}
+			band->n_channels = band->chan_6g[0]->n_channels;
+			band->channels = band->chan_6g[0]->channels;
 
 			freq_low = max(reg_cap->low_5ghz_chan,
-				       ab->reg_freq_5g.start_freq);
+				       ab->reg_freq_6g.start_freq);
 			freq_high = min(reg_cap->high_5ghz_chan,
-					ab->reg_freq_5g.end_freq);
+					ab->reg_freq_6g.end_freq);
+
 			ath12k_mac_update_ch_list(ar, band,
 						  freq_low,
 						  freq_high);
+
+			ah->use_6ghz_regd = true;
 			ar->num_channels = ath12k_reg_get_num_chans_in_band(ar, band);
-			if (!ah->hw->wiphy->bands[NL80211_BAND_5GHZ]) {
-				ah->hw->wiphy->bands[NL80211_BAND_5GHZ] = band;
+			if (!bands[NL80211_BAND_6GHZ]) {
+				bands[NL80211_BAND_6GHZ] = band;
 			} else {
 				/* Split mac in same band under same wiphy during MLO */
 				ret = ath12k_mac_update_band(ar,
-							     bands[NL80211_BAND_5GHZ],
+							     bands[NL80211_BAND_6GHZ],
 							     band);
 				if (ret)
 					return ret;
