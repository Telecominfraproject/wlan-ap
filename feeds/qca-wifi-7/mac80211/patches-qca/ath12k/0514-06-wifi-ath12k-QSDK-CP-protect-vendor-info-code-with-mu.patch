+		resources_created = false;
+		ath12k_dbg(NULL, ATH12K_DBG_RM,
+			   "Destroyed telemetry resources using id: %d\n", id);
+	} else {
+		ath12k_dbg(NULL, ATH12K_DBG_RM,
+			   "Resources not created or already destroyed, skipping for service id : %d\n",
+			   id);
+	}
 }
 
