+		ath12k_telemetry_create_resources(ag);
+		resources_created = true;
+		ath12k_dbg(NULL, ATH12K_DBG_RM,
+			   "Created ta resources using service id : %d\n", id);
+	} else {
+		ath12k_dbg(NULL, ATH12K_DBG_RM,
+			   "Resources already created, skipping for service id : %d\n",
+			   id);
+	}
 }
 
