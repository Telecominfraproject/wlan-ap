From db1902e3c54a86dbcf20e7b66fcd99b5a7478f29 Mon Sep 17 00:00:00 2001
From: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
Date: Tue, 1 Jul 2025 10:03:52 +0530
Subject: [PATCH] UPSTREAM:ath12k:DP: Fix ARP resolution failure in RAW mode

Currently, In RAW mode, ARP resolution failure in AP which
resulting in traffic failure. This is because of
IEEE80211_HW_MLO_MCAST_MULTI_LINK_TX HW flag is set for RAW
mode which sends the multicast traffic without encryption
over the air and client drops the received packet due to
the encrypt failure. Fix this issue by not setting the HW
flag for RAW mode.

Patch-dependency: none

Signed-off-by: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 95fbbcc..d4c05ff 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -19181,7 +19181,8 @@ static int ath12k_mac_hw_register(struct ath12k_hw *ah)
 		ath12k_iftypes_ext_capa[2].mld_capa_and_ops = cap->mld_cap;
 		wiphy->flags |= WIPHY_FLAG_SUPPORTS_MLO;
 
-		ieee80211_hw_set(hw, MLO_MCAST_MULTI_LINK_TX);
+		if(!is_raw_mode)
+			ieee80211_hw_set(hw, MLO_MCAST_MULTI_LINK_TX);
 	}
 
 	hw->queues = ATH12K_HW_MAX_QUEUES;
-- 
