From 1730833c8471f5b3f6bdb70a711c4ff508990807 Mon Sep 17 00:00:00 2001
From: Sushant Butta <sbutta@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 00:34:15 +0530
Subject: [PATCH 10/10] UPSTREAM: DP: wifi: ath12k: Add dynamic configuration
 support for mo packet data filters

Currently, in the ath12k driver, a single configuration is applied for
both status TLVs and packet data TLVs.

However, the hardware provides the capability to configure status TLVs
and packet data TLVs through separate registers. To leverage this,
dynamic configuration support has been added for packet data mo filters.

Patch-dependency:
	0405-0009-UPSTREAM-DP-wifi-ath12k-Add-dynamic-configuration-su.patch

Signed-off-by: Sushant Butta <sbutta@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_htt.c      | 15 +++-----
 drivers/net/wireless/ath/ath12k/dp_htt.h      |  4 ++
 .../net/wireless/ath/ath12k/dp_mon_filter.c   | 37 +++++++++++++++++++
 .../net/wireless/ath/ath12k/dp_mon_filter.h   |  5 +++
 4 files changed, 51 insertions(+), 10 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.c b/drivers/net/wireless/ath/ath12k/dp_htt.c
index 984c5d2..aecdf69 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.c
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.c
@@ -1538,8 +1538,7 @@ void ath12k_dp_tx_htt_rx_mgmt_flag0_fp_filter_set(u32 *ptr, u16 filter)
 				      (filter & FILTER_MGMT_ATIM) ? 1 : 0);
 }
 
-static void
-ath12k_dp_tx_htt_rx_mgmt_flag0_mo_filter_set(u32 *ptr, u16 filter)
+void ath12k_dp_tx_htt_rx_mgmt_flag0_mo_filter_set(u32 *ptr, u16 filter)
 {
 	HTT_RX_PKT_ENABLE_SUBTYPE_SET(*ptr, MO, MGMT, FLAGS0, ASSOC_REQ,
 				      (filter & FILTER_MGMT_ASSOC_REQ) ? 1 : 0);
@@ -1591,8 +1590,7 @@ void ath12k_dp_tx_htt_rx_mgmt_flag1_fp_filter_set(u32 *ptr, u16 filter)
 				      (filter & FILTER_MGMT_RESERVED_15) ? 1 : 0);
 }
 
-static void
-ath12k_dp_tx_htt_rx_mgmt_flag1_mo_filter_set(u32 *ptr, u16 filter)
+void ath12k_dp_tx_htt_rx_mgmt_flag1_mo_filter_set(u32 *ptr, u16 filter)
 {
 	HTT_RX_PKT_ENABLE_SUBTYPE_SET(*ptr, MO, MGMT, FLAGS1, DISASSOC,
 				      (filter & FILTER_MGMT_DISASSOC) ? 1 : 0);
@@ -1644,8 +1642,7 @@ void ath12k_dp_tx_htt_rx_ctrl_flag2_fp_filter_set(u32 *ptr, u16 filter)
 				      (filter & FILTER_CTRL_BA) ? 1 : 0);
 }
 
-static void
-ath12k_dp_tx_htt_rx_ctrl_flag2_mo_filter_set(u32 *ptr, u16 filter)
+void ath12k_dp_tx_htt_rx_ctrl_flag2_mo_filter_set(u32 *ptr, u16 filter)
 {
 	HTT_RX_PKT_ENABLE_SUBTYPE_SET(*ptr, MO, CTRL, FLAGS2, CTRL_RESERVED_1,
 				      (filter & FILTER_CTRL_RESERVED_1) ? 1 : 0);
@@ -1707,8 +1704,7 @@ void ath12k_dp_tx_htt_rx_data_flag3_fp_filter_set(u32 *ptr, u16 filter)
 				      (filter & FILTER_DATA_NULL) ? 1 : 0);
 }
 
-static void
-ath12k_dp_tx_htt_rx_ctrl_flag3_mo_filter_set(u32 *ptr, u16 filter)
+void ath12k_dp_tx_htt_rx_ctrl_flag3_mo_filter_set(u32 *ptr, u16 filter)
 {
 	HTT_RX_PKT_ENABLE_SUBTYPE_SET(*ptr, MO, CTRL, FLAGS3, PSPOLL,
 				      (filter & FILTER_CTRL_PSPOLL) ? 1 : 0);
@@ -1724,8 +1720,7 @@ ath12k_dp_tx_htt_rx_ctrl_flag3_mo_filter_set(u32 *ptr, u16 filter)
 				      (filter & FILTER_CTRL_CFEND_CFACK) ? 1 : 0);
 }
 
-static void
-ath12k_dp_tx_htt_rx_data_flag3_mo_filter_set(u32 *ptr, u16 filter)
+void ath12k_dp_tx_htt_rx_data_flag3_mo_filter_set(u32 *ptr, u16 filter)
 {
 	HTT_RX_PKT_ENABLE_SUBTYPE_SET(*ptr, MO, DATA, FLASG3, MCAST,
 				      (filter & FILTER_DATA_MCAST) ? 1 : 0);
diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.h b/drivers/net/wireless/ath/ath12k/dp_htt.h
index 1dd636d..2f50844 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.h
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.h
@@ -917,6 +917,7 @@ struct htt_rx_ring_tlv_filter {
 	bool enable_fp;
 	bool enable_mo;
 	bool enable_fp_packet;
+	bool enable_mo_packet;
 	u16 fp_mgmt_filter;
 	u16 fp_ctrl_filter;
 	u16 fp_data_filter;
@@ -926,6 +927,9 @@ struct htt_rx_ring_tlv_filter {
 	u16 fp_packet_mgmt_filter;
 	u16 fp_packet_ctrl_filter;
 	u16 fp_packet_data_filter;
+	u16 mo_packet_mgmt_filter;
+	u16 mo_packet_ctrl_filter;
+	u16 mo_packet_data_filter;
 	u16 rx_packet_offset;
 	u16 rx_header_offset;
 	u16 rx_mpdu_end_offset;
diff --git a/drivers/net/wireless/ath/ath12k/dp_mon_filter.c b/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
index 0f805a3..083a261 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
@@ -193,6 +193,14 @@ void ath12k_dp_mon_rx_display_filters(struct ath12k_dp *dp,
 			   tlv_filter->fp_packet_ctrl_filter);
 		ath12k_dbg(ab, ATH12K_DBG_DATA, "fp_packet_data_filter: 0x%x",
 			   tlv_filter->fp_packet_data_filter);
+		ath12k_dbg(ab, ATH12K_DBG_DATA, "enable_mo_packet: %d",
+			   tlv_filter->enable_mo_packet);
+		ath12k_dbg(ab, ATH12K_DBG_DATA, "mo_packet_mgmt_filter: 0x%x",
+			   tlv_filter->mo_packet_mgmt_filter);
+		ath12k_dbg(ab, ATH12K_DBG_DATA, "mo_packet_ctrl_filter: 0x%x",
+			   tlv_filter->mo_packet_ctrl_filter);
+		ath12k_dbg(ab, ATH12K_DBG_DATA, "mo_packet_data_filter: 0x%x",
+			   tlv_filter->mo_packet_data_filter);
 	}
 }
 EXPORT_SYMBOL(ath12k_dp_mon_rx_display_filters);
@@ -311,6 +319,13 @@ void ath12k_dp_mon_rx_prepare_filter(struct ath12k_dp *dp,
 					src_tlv_filter->fp_packet_ctrl_filter;
 		dst_tlv_filter->fp_packet_data_filter |=
 					src_tlv_filter->fp_packet_data_filter;
+		dst_tlv_filter->enable_mo_packet |= src_tlv_filter->enable_mo_packet;
+		dst_tlv_filter->mo_packet_mgmt_filter |=
+					src_tlv_filter->mo_packet_mgmt_filter;
+		dst_tlv_filter->mo_packet_ctrl_filter |=
+					src_tlv_filter->mo_packet_ctrl_filter;
+		dst_tlv_filter->mo_packet_data_filter |=
+					src_tlv_filter->mo_packet_data_filter;
 		ath12k_dbg(ab, ATH12K_DBG_DATA, "Updated Rx filters for mode: %d", mode);
 		ath12k_dp_mon_rx_display_filters(dp, mode, rx_mon_filter);
 	}
@@ -422,6 +437,10 @@ ath12k_dp_mon_rx_setup_mon_mode_filter(struct htt_rx_ring_tlv_filter *tlv_filter
 	tlv_filter->fp_packet_mgmt_filter = FILTER_MGMT_ALL;
 	tlv_filter->fp_packet_ctrl_filter = FILTER_CTRL_ALL;
 	tlv_filter->fp_packet_data_filter = FILTER_DATA_ALL;
+	tlv_filter->enable_mo_packet = 1;
+	tlv_filter->mo_packet_mgmt_filter = FILTER_MGMT_ALL;
+	tlv_filter->mo_packet_ctrl_filter = FILTER_CTRL_ALL;
+	tlv_filter->mo_packet_data_filter = FILTER_DATA_ALL;
 }
 EXPORT_SYMBOL(ath12k_dp_mon_rx_setup_mon_mode_filter);
 
@@ -529,6 +548,9 @@ void ath12k_dp_mon_rx_enable_packet_filters(void *ptr,
 	u32 fp_packet_mgmt_filter = tlv_filter->fp_packet_mgmt_filter;
 	u32 fp_packet_ctrl_filter = tlv_filter->fp_packet_ctrl_filter;
 	u32 fp_packet_data_filter = tlv_filter->fp_packet_data_filter;
+	u32 mo_packet_mgmt_filter = tlv_filter->mo_packet_mgmt_filter;
+	u32 mo_packet_ctrl_filter = tlv_filter->mo_packet_ctrl_filter;
+	u32 mo_packet_data_filter = tlv_filter->mo_packet_data_filter;
 
 	if (tlv_filter->rxmon_disable)
 		return;
@@ -537,18 +559,27 @@ void ath12k_dp_mon_rx_enable_packet_filters(void *ptr,
 	if (tlv_filter->enable_fp_packet)
 		ath12k_dp_tx_htt_rx_mgmt_flag0_fp_filter_set(&word,
 							     fp_packet_mgmt_filter);
+	if (tlv_filter->enable_mo_packet)
+		ath12k_dp_tx_htt_rx_mgmt_flag0_mo_filter_set(&word,
+							     mo_packet_mgmt_filter);
 	cmd->pkt_type_en_data_flag0 = cpu_to_le32(word);
 
 	word = 0;
 	if (tlv_filter->enable_fp_packet)
 		ath12k_dp_tx_htt_rx_mgmt_flag1_fp_filter_set(&word,
 							     fp_packet_mgmt_filter);
+	if (tlv_filter->enable_mo_packet)
+		ath12k_dp_tx_htt_rx_mgmt_flag1_mo_filter_set(&word,
+							     mo_packet_mgmt_filter);
 	cmd->pkt_type_en_data_flag1 = cpu_to_le32(word);
 
 	word = 0;
 	if (tlv_filter->enable_fp_packet)
 		ath12k_dp_tx_htt_rx_ctrl_flag2_fp_filter_set(&word,
 							     fp_packet_ctrl_filter);
+	if (tlv_filter->enable_mo_packet)
+		ath12k_dp_tx_htt_rx_ctrl_flag2_mo_filter_set(&word,
+							     mo_packet_ctrl_filter);
 	cmd->pkt_type_en_data_flag2 = cpu_to_le32(word);
 
 	word = 0;
@@ -558,6 +589,12 @@ void ath12k_dp_mon_rx_enable_packet_filters(void *ptr,
 		ath12k_dp_tx_htt_rx_data_flag3_fp_filter_set(&word,
 							     fp_packet_data_filter);
 	}
+	if (tlv_filter->enable_mo_packet) {
+		ath12k_dp_tx_htt_rx_ctrl_flag3_mo_filter_set(&word,
+							     mo_packet_ctrl_filter);
+		ath12k_dp_tx_htt_rx_data_flag3_mo_filter_set(&word,
+							     mo_packet_data_filter);
+	}
 	cmd->pkt_type_en_data_flag3 = cpu_to_le32(word);
 }
 EXPORT_SYMBOL(ath12k_dp_mon_rx_enable_packet_filters);
diff --git a/drivers/net/wireless/ath/ath12k/dp_mon_filter.h b/drivers/net/wireless/ath/ath12k/dp_mon_filter.h
index 1d78aa3..263dee7 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon_filter.h
+++ b/drivers/net/wireless/ath/ath12k/dp_mon_filter.h
@@ -65,4 +65,9 @@ void ath12k_dp_tx_htt_rx_ctrl_flag3_fp_filter_set(u32 *ptr, u16 filter);
 void ath12k_dp_tx_htt_rx_data_flag3_fp_filter_set(u32 *ptr, u16 filter);
 void ath12k_dp_mon_rx_enable_packet_filters(void *ptr,
 					    struct htt_rx_ring_tlv_filter *tlv_filter);
+void ath12k_dp_tx_htt_rx_mgmt_flag0_mo_filter_set(u32 *ptr, u16 filter);
+void ath12k_dp_tx_htt_rx_mgmt_flag1_mo_filter_set(u32 *ptr, u16 filter);
+void ath12k_dp_tx_htt_rx_ctrl_flag2_mo_filter_set(u32 *ptr, u16 filter);
+void ath12k_dp_tx_htt_rx_ctrl_flag3_mo_filter_set(u32 *ptr, u16 filter);
+void ath12k_dp_tx_htt_rx_data_flag3_mo_filter_set(u32 *ptr, u16 filter);
 #endif
-- 
2.34.1

