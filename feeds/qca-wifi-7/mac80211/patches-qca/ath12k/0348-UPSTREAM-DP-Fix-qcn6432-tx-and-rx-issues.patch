From 6e7c291c7ef652ba0a325bc195b26d3a0951fdc7 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Tue, 17 Jun 2025 15:03:37 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: Fix qcn6432 tx and rx issues

Fix folloing issues:
1. Reo2 Base address being wrong lead to the ring sizes
   to be miscalculated and wrong reg offsets were initialized by mistake
2. Num reo rings being higher than what the HW supports.
   Possibly corruption on other reo registers.
3. Tx descriptors getting leaked as multiple tx completions
   are mapped to the same interrupt group.

Patch-dependency:
	0111-0013-UPSTREAM-PLATFORM-QCN6432-bringup.patch

Signed-off-by: Balamurugan Mahalingam <bmahalin@qti.qualcomm.com>
Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h                | 2 +-
 drivers/net/wireless/ath/ath12k/wifi7/dp.c          | 8 +++++---
 drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c | 3 +--
 3 files changed, 7 insertions(+), 6 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index c79240d..e303467 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -220,7 +220,7 @@ struct ath12k_pdev_dp {
 #define DP_TX_IDR_SIZE			DP_TX_COMP_RING_SIZE
 #define DP_TCL_CMD_RING_SIZE		32
 #define DP_TCL_STATUS_RING_SIZE		32
-#define DP_REO_DST_RING_MAX		8
+#define DP_REO_DST_RING_MAX		4
 #define DP_REO_DST_RING_SIZE		2048
 #define DP_REO_REINJECT_RING_SIZE	32
 #define DP_RX_RELEASE_RING_SIZE		1024
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp.c b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
index 2351efe..7fc1f19 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
@@ -26,12 +26,14 @@ static int ath12k_wifi7_dp_service_srng(struct ath12k_dp *dp,
 	int i = 0, j;
 	int tot_work_done = 0;
 	enum dp_monitor_mode monitor_mode;
-	u8 ring_mask, rx_mask;
+	u8 ring_mask, rx_mask, tx_mask;
 
 	rx_mask = dp->hw_params->ring_mask->rx[grp_id];
+	tx_mask = dp->hw_params->ring_mask->tx[grp_id];
 
-	if (dp->hw_params->ring_mask->tx[grp_id]) {
-		i = fls(dp->hw_params->ring_mask->tx[grp_id]) - 1;
+	while (tx_mask) {
+		i = fls(tx_mask) - 1;
+		tx_mask ^= 1 << i;
 		ath12k_wifi7_dp_tx_completion_handler(dp, i);
 	}
 
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
index 450dfdf..e02bebb 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
@@ -645,7 +645,7 @@ const struct ath12k_hw_regs qcn6432_regs = {
 	.hal_wbm1_release_ring_base_lsb = 0x00000e80,
 
 	/* reo2ppe ring base address */
-	.hal_reo2_ring_base = 0x00000938,
+	.hal_reo2ppe_ring_base = 0x00000938,
 
 	/* PCIe base address */
 	.pcie_qserdes_sysclk_en_sel = 0x01e0c0a8,
@@ -658,7 +658,6 @@ const struct ath12k_hw_regs qcn6432_regs = {
 	.hal_umac_ce1_dest_reg_base =  0x01B83000,
 
 	.hal_ppe_rel_ring_base = 0x0000046c,
-	.hal_reo2ppe_ring_base = 0x00000938,
 	.hal_tcl_ppe2tcl_ring_base_lsb = 0x00000c58
 };
 
-- 
2.34.1

