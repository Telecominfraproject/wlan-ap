From 76cfb6e4194799509f8d6a695a35e12281ffbf8d Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Thu, 31 Jul 2025 09:51:46 +0530
Subject: [PATCH] QSDK: DP: wifi: ath12k: Skip skb with zero length during
 monitor process

Currently, while enabling monitor mode, driver receives an RX_HDR TLV
without any content and without a corresponding BUFFER ADDR TLV. This
results in an skb being created with fragments (nr_frags > 0), but
with skb->len set to zero, as no payload is present.

Previously, the code did not check for this case and would continue
to process the skb even when its length was zero. This could lead
to issues such as passing empty frames to the networking stack or
triggering warnings and bugs in subsequent code paths that assume
skb->len > 0 when fragments are present.

To address this, add a check to skip skbs that have a non-zero
fragment count but a total length of zero. This prevents any
operations on such invalid skbs and avoids potential out-of-bounds
accesses or erroneous behavior.

Fixes : I96784d025c9
(Upstream: DP: Add non linear skb support for monitor mode)

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
index e6dadc0..5088f60 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -535,6 +535,22 @@ ath12k_wifi7_dp_mon_rx_parse_ppdu_status(struct ath12k_pdev_dp *dp_pdev,
 
 	while ((mpdu = skb_dequeue(&ppdu_info->mpdu_q))) {
 		mpdu_meta = (struct ath12k_dp_mon_mpdu_meta *)mpdu->data;
+		/* In some cases, an RX_HDR TLV may get received with no content
+		 * and without an accompanying BUFFER ADDR TLV—meaning there is
+		 * no payload attached. In such cases, the skb may have fragments
+		 * present (nr_frags > 0) but its total length (skb->len) is zero.
+		 * To avoid processing an skb with zero length, add a check to
+		 * skip these cases.
+		 */
+		if (!mpdu->len) {
+			ath12k_dp_mon_cnt_skb_and_frags(mpdu, &num_skb, &pkt_tlv);
+			mon_stats->num_skb_raw += num_skb;
+			mon_stats->num_frag_raw += pkt_tlv;
+			dev_kfree_skb_any(mpdu);
+			mon_stats->num_skb_free++;
+			continue;
+		}
+
 		if (mpdu_meta->decap_type == DP_RX_DECAP_TYPE_RAW) {
 			last_frag_idx = skb_shinfo(mpdu)->nr_frags - 1;
 			if (skb_shinfo(mpdu)->nr_frags >= 2) {
-- 
