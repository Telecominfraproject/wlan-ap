From 45b54d3221a7e1123a2282c8fd42b7819b01828d Mon Sep 17 00:00:00 2001
From: Avula Sri Charan <asrichar@qti.qualcomm.com>
Date: Tue, 22 Apr 2025 15:31:38 +0530
Subject: QSDK:PLATFORM: wifi: ath12k: Enable amss_dualmac.bin loading for QCN9274

Add changes to load amss_dualmac.bin when firmware-2.bin is not
present.

If firmware-2.bin fails to load, fw features will not be populated, so
any checks on fw features should be skipped in fallback scenarios. So
adding a check on fw api version to bypass any fw features related checks.

Signed-off-by: Avula Sri Charan <asrichar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c | 2 +-
 drivers/net/wireless/ath/ath12k/hw.h   | 1 +
 drivers/net/wireless/ath/ath12k/mhi.c  | 7 ++++---
 drivers/net/wireless/ath/ath12k/pci.c  | 4 ++--
 4 files changed, 8 insertions(+), 6 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -2116,7 +2116,7 @@ void ath12k_core_hw_group_set_mlo_capabl
 		  * bypassing this check for the both. Need to make this generic
 		  */
 
-		if (ab->hif.bus == ATH12K_BUS_PCI && !test_bit(ATH12K_FW_FEATURE_MLO, ab->fw.fw_features)) {
+		if (ab->fw.api_version == ATH12K_FW_API_V2 && !test_bit(ATH12K_FW_FEATURE_MLO, ab->fw.fw_features)) {
 			ag->mlo_capable = false;
 			return;
 		}
--- a/drivers/net/wireless/ath/ath12k/hw.h
+++ b/drivers/net/wireless/ath/ath12k/hw.h
@@ -109,6 +109,7 @@
 #define ATH12K_DEFAULT_BOARD_FILE	"board.bin"
 #define ATH12K_DEFAULT_CAL_FILE		"caldata.bin"
 #define ATH12K_AMSS_FILE		"amss.bin"
+#define ATH12K_AMSS_DUALMAC_FILE	"amss_dualmac.bin"
 #define ATH12K_M3_FILE			"m3.bin"
 #define ATH12K_REGDB_FILE_NAME		"regdb.bin"
 #define ATH12K_DEFAULT_ID		255
--- a/drivers/net/wireless/ath/ath12k/mhi.c
+++ b/drivers/net/wireless/ath/ath12k/mhi.c
@@ -229,9 +229,10 @@ int ath12k_mhi_register(struct ath12k_pc
 			mhi_ctrl->fw_data = ab->fw.amss_dualmac_data;
 			mhi_ctrl->fw_sz = ab->fw.amss_dualmac_len;
 		} else {
-			ath12k_warn(ab, "dualmac firmware IE not present in firmware-N.bin\n");
-			ret = -ENOENT;
-			goto free_controller;
+			ath12k_core_create_firmware_path(ab, ATH12K_AMSS_DUALMAC_FILE,
+							 ab_pci->amss_path,
+							 sizeof(ab_pci->amss_path));
+			mhi_ctrl->fw_image = ab_pci->amss_path;
 		}
 	} else {
 		if (ab->fw.amss_data && ab->fw.amss_len > 0) {
--- a/drivers/net/wireless/ath/ath12k/pci.c
+++ b/drivers/net/wireless/ath/ath12k/pci.c
@@ -225,7 +225,7 @@ static void ath12k_pci_init_qmi_ce_confi
 	cfg->svc_to_ce_map_len = ab->hw_params->svc_to_ce_map_len;
 	ab->qmi.service_ins_id = ab->hw_params->qmi_service_ins_id;
 
-	if (test_bit(ATH12K_FW_FEATURE_MULTI_QRTR_ID, ab->fw.fw_features)) {
+	if (ab->fw.api_version == ATH12K_FW_API_V1 ||test_bit(ATH12K_FW_FEATURE_MULTI_QRTR_ID, ab->fw.fw_features)) {
 		ab_pci->qmi_instance =
 			u32_encode_bits(pci_domain_nr(bus), DOMAIN_NUMBER_MASK) |
 			u32_encode_bits(bus->number, BUS_NUMBER_MASK);
@@ -969,7 +969,7 @@ int ath12k_pci_power_up(struct ath12k_ba
 
 	ath12k_pci_msi_enable(ab_pci);
 
-	if (test_bit(ATH12K_FW_FEATURE_MULTI_QRTR_ID, ab->fw.fw_features))
+	if (ab->fw.api_version == ATH12K_FW_API_V1 || test_bit(ATH12K_FW_FEATURE_MULTI_QRTR_ID, ab->fw.fw_features))
 		ath12k_pci_update_qrtr_node_id(ab);
 
 	ret = ath12k_mhi_start(ab_pci);
--- a/drivers/net/wireless/ath/ath12k/fw.c
+++ b/drivers/net/wireless/ath/ath12k/fw.c
@@ -156,9 +156,9 @@ void ath12k_fw_map(struct ath12k_base *a
 
 	ret = ath12k_fw_request_firmware_api_n(ab, ATH12K_FW_API2_FILE);
 	if (ret == 0)
-		ab->fw.api_version = 2;
+		ab->fw.api_version = ATH12K_FW_API_V2;
 	else
-		ab->fw.api_version = 1;
+		ab->fw.api_version = ATH12K_FW_API_V1;
 
 	ath12k_dbg(ab, ATH12K_DBG_BOOT, "using fw api %d\n",
 		   ab->fw.api_version);
--- a/drivers/net/wireless/ath/ath12k/fw.h
+++ b/drivers/net/wireless/ath/ath12k/fw.h
@@ -30,6 +30,11 @@ enum ath12k_fw_features {
 	ATH12K_FW_FEATURE_COUNT,
 };
 
+enum ath12k_fw_api_version {
+	ATH12K_FW_API_V1 = 1,
+	ATH12K_FW_API_V2,
+};
+
 void ath12k_fw_map(struct ath12k_base *ab);
 void ath12k_fw_unmap(struct ath12k_base *ab);
 
