From f4c3f3fac4c34b1205c184045d5875b00b54c0aa Mon Sep 17 00:00:00 2001
From: Govindaraj Saminathan <gsaminat@qti.qualcomm.com>
Date: Fri, 19 Sep 2025 13:56:18 +0530
Subject: [PATCH] UPSTREAM:CP:wifi: ath12k: Fix incorrect channel width during
 peer channal width update

Currently, the host sends chan_width value 4 instead of 9 for 320MHz 
in PEER_CHAN_WIDTH_SWITCH_CMD. This occurs because the channel width 
is directly derived from ieee80211_sta_rx_bw enums, which do not 
align with wmi_host_channel_width values expected by the firmware.

Convert ieee80211_sta_rx_bw to wmi_host_channel_width before updating 
the peer list to update accurate bandwidth to firmware during peer
channel width switch.

Fixes: I4aac4f0b3ae (CP: wifi: ath12k: PKG upgrade changes set 9)
Patch dependency: 0279-002-ath12k-add-peer-channel-width-switch-command-support.patch

Signed-off-by: Govindaraj Saminathan <gsaminat@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.c | 31 ++++++++++++++++++++++++---
 1 file changed, 28 insertions(+), 3 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -17137,6 +17137,7 @@ static void ath12k_wmi_put_peer_list(str
 	struct wmi_chan_width_peer_list *itr;
 	struct wmi_chan_width_peer_arg *arg_itr;
 	int i;
+	u32 host_chan_width;
 
 	ath12k_dbg(ab, ATH12K_DBG_WMI,
 		   "wmi peer channel width switch command peer list\n");
@@ -17148,13 +17149,38 @@ static void ath12k_wmi_put_peer_list(str
 		itr->tlv_header = ath12k_wmi_tlv_cmd_hdr(WMI_TAG_CHAN_WIDTH_PEER_LIST,
 							 sizeof(*itr));
 		ether_addr_copy(itr->mac_addr.addr, arg_itr->mac_addr.addr);
-		itr->chan_width = cpu_to_le32(arg_itr->chan_width);
+
+		/* Convert ieee80211_sta_rx_bw to wmi_host_chan_width */
+		switch (arg_itr->chan_width) {
+		case IEEE80211_STA_RX_BW_20:
+			host_chan_width = WMI_HOST_CHAN_WIDTH_20;
+		break;
+		case IEEE80211_STA_RX_BW_40:
+			host_chan_width = WMI_HOST_CHAN_WIDTH_40;
+			break;
+		case IEEE80211_STA_RX_BW_80:
+			host_chan_width = WMI_HOST_CHAN_WIDTH_80;
+		break;
+		case IEEE80211_STA_RX_BW_160:
+			host_chan_width = WMI_HOST_CHAN_WIDTH_160;
+		break;
+		case IEEE80211_STA_RX_BW_320:
+			host_chan_width = WMI_HOST_CHAN_WIDTH_320;
+		break;
+		default:
+			ath12k_warn(ab, "invalid bw %d switching back to 20 MHz\n",
+				    arg_itr->chan_width);
+			host_chan_width = WMI_HOST_CHAN_WIDTH_20;
+			break;
+		}
+
+		itr->chan_width = cpu_to_le32(host_chan_width);
 		itr->puncture_20mhz_bitmap = cpu_to_le32(arg_itr->puncture_20mhz_bitmap);
 
 		ath12k_dbg(ab, ATH12K_DBG_WMI,
-			   "   (%u) width %u addr %pM punct_bitmap 0x%x\n",
+			   "   (%u) width %u addr %pM punct_bitmap 0x%x host chan_width: %d\n",
 			   i + 1, arg_itr->chan_width, arg_itr->mac_addr.addr,
-			   arg_itr->puncture_20mhz_bitmap);
+			   arg_itr->puncture_20mhz_bitmap, host_chan_width);
 	}
 }
 
