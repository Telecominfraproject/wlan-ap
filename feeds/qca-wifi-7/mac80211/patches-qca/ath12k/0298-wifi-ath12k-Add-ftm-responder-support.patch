From 516f8cd8b58d1cf370513e50e9218213afc3f6c7 Mon Sep 17 00:00:00 2001
From: Balaganapathy Palanisamy <quic_bpalanis@quicinc.com>
Date: Tue, 5 Nov 2024 13:16:21 +0530
Subject: [PATCH] ath12k: Add ftm responder support

Fine Timing Measurement support is used to measure round
trip time between two nodes. Currently ath12k support
ftm responder in ap mode. This is completely fw offloaded.
Ath12k enables and disables ftm responder based on user
configuration, also added support for advertising the same
in ext caps.

Signed-off-by: Balaganapathy Palanisamy <quic_bpalanis@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/core.h |  1 +
 drivers/net/wireless/ath/ath12k/hw.c   |  6 ++++++
 drivers/net/wireless/ath/ath12k/hw.h   |  1 +
 drivers/net/wireless/ath/ath12k/mac.c  | 17 +++++++++++++++++
 drivers/net/wireless/ath/ath12k/wmi.h  |  1 +
 5 files changed, 26 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -399,6 +399,7 @@ struct ath12k_link_vif {
 	bool pending_csa_up;
 	u32 tx_vdev_id;
 	struct ath12k_prb_resp_tmpl_ml_info ml_info;
+	bool ftm_responder;
 };
 
 struct ath12k_dp_link_vif {
--- a/drivers/net/wireless/ath/ath12k/hw.h
+++ b/drivers/net/wireless/ath/ath12k/hw.h
@@ -264,6 +264,7 @@ struct ath12k_hw_params {
 	bool handle_beacon_miss;
 	bool supports_ap_ps;
 	bool support_ce_manual_poll;
+	bool ftm_responder;
 };
 
 struct ath12k_hw_ops {
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -4886,6 +4886,20 @@ static void ath12k_mac_bss_info_changed(
 	if (unlikely(test_bit(ATH12K_FLAG_CRASH_FLUSH, &ar->ab->dev_flags)))
 		return;
 
+	if (changed & BSS_CHANGED_FTM_RESPONDER &&
+	    arvif->ftm_responder != info->ftm_responder &&
+	    (vif->type == NL80211_IFTYPE_AP ||
+	     vif->type == NL80211_IFTYPE_MESH_POINT)) {
+		param_id = WMI_VDEV_PARAM_ENABLE_DISABLE_RTT_RESPONDER_ROLE;
+		ret =  ath12k_wmi_vdev_set_param_cmd(ar, arvif->vdev_id, param_id,
+						     info->ftm_responder);
+		if (ret)
+			ath12k_warn(ar->ab, "Failed to set ftm responder %i: %d\n",
+				    arvif->vdev_id, ret);
+		else
+			arvif->ftm_responder = info->ftm_responder;
+	}
+
 	if (changed & BSS_CHANGED_BEACON_INT) {
 		arvif->beacon_interval = info->beacon_int;
 
@@ -14986,6 +15000,10 @@ static int ath12k_mac_hw_register(struct
 	wiphy_ext_feature_set(wiphy, NL80211_EXT_FEATURE_SET_SCAN_DWELL);
 	wiphy_ext_feature_set(wiphy, NL80211_EXT_FEATURE_BEACON_RATE_LEGACY);
 
+	if (ar->ab->hw_params->ftm_responder)
+		wiphy_ext_feature_set(wiphy,
+				      NL80211_EXT_FEATURE_ENABLE_FTM_RESPONDER);
+
 	ath12k_reg_init(hw);
 
 	if (!is_raw_mode) {
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -1193,6 +1193,7 @@ enum wmi_tlv_vdev_param {
 	WMI_VDEV_PARAM_ENABLE_BCAST_PROBE_RESPONSE,
 	WMI_VDEV_PARAM_FILS_MAX_CHANNEL_GUARD_TIME,
 	WMI_VDEV_PARAM_HE_LTF = 0x74,
+	WMI_VDEV_PARAM_ENABLE_DISABLE_RTT_RESPONDER_ROLE = 0x7d,
 	WMI_VDEV_PARAM_BA_MODE = 0x7e,
 	WMI_VDEV_PARAM_AUTORATE_MISC_CFG = 0x80,
 	WMI_VDEV_PARAM_SET_HE_SOUNDING_MODE = 0x87,
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -410,6 +410,7 @@ static const struct ath12k_hw_params ath
 			.fragment_160mhz = false,
 		},
 		.supports_ap_ps = true,
+		.ftm_responder = true,
 	},
 	{
 		.name = "wcn7850 hw2.0",
@@ -498,6 +499,7 @@ static const struct ath12k_hw_params ath
 		.handle_beacon_miss = false,
 		.supports_ap_ps = true,
 		.support_ce_manual_poll=true,
+		.ftm_responder = false,
 	},
 	{
 		.name = "qcn9274 hw2.0",
@@ -592,6 +594,7 @@ static const struct ath12k_hw_params ath
 		},
 		.supports_ap_ps = true,
 		.support_ce_manual_poll=true,
+		.ftm_responder = true,
 	},
 	{
 		.name = "ipq5332 hw1.0",
@@ -675,6 +678,7 @@ static const struct ath12k_hw_params ath
 		},
 		.supports_ap_ps = true,
 		.support_ce_manual_poll=true,
+		.ftm_responder = false,
 	},
 	{
 		.name = "qcn6432 hw1.0",
@@ -738,6 +742,7 @@ static const struct ath12k_hw_params ath
 		},
 		.supports_ap_ps = true,
 		.support_ce_manual_poll=true,
+		.ftm_responder = true,
 	},
 	{
 		.name = "ipq5424 hw1.0",
@@ -821,6 +826,7 @@ static const struct ath12k_hw_params ath
 		},
 		.supports_ap_ps = true,
 		.support_ce_manual_poll=true,
+		.ftm_responder = false,
 	},
 };
 
