From bd09e0f8a2a33b07b81a83e8aa7fb46030ad5e4f Mon Sep 17 00:00:00 2001
From: Aniruddha Mishra <quic_anirmish@quicinc.com>
Date: Mon, 14 Apr 2025 14:05:56 +0530
Subject: [PATCH 5/9] wifi: ath12k: initialize link_id in
 ath12k_dp_mon_rx_deliver_msdu()

Initialize link_id in ath12k_dp_mon_rx_deliver_msdu().
Uninitialized link_id values can lead to undefined behaviour
in mac80211.

Signed-off-by: Hari Chandrakanthan <quic_haric@quicinc.com>
Signed-off-by: Aniruddha Mishra <quic_anirmish@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/dp_mon.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.c b/drivers/net/wireless/ath/ath12k/dp_mon.c
index 38f5c68..8703b68 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.c
@@ -2090,6 +2090,7 @@ static void ath12k_dp_mon_rx_deliver_msdu(struct ath12k_pdev_dp *dp_pdev, struct
 	bool is_eapol_tkip = rxcb->is_eapol;
 
 	status->link_valid = 0;
+	status->link_id = 0;
 
 	if ((status->encoding == RX_ENC_HE) && !(status->flag & RX_FLAG_RADIOTAP_HE) &&
 	    !(status->flag & RX_FLAG_SKIP_MONITOR)) {
-- 
2.34.1

