From 1dfdb77ea16a69978c478cd088a9b775a1614529 Mon Sep 17 00:00:00 2001
From: Alok Singh <aloksing@qti.qualcomm.com>
Date: Mon, 9 Jun 2025 13:11:03 +0530
Subject: [PATCH 08/13] UPSTREAM: DP: wifi: ath12k: fix macro definition
 HAL_RX_MSDU_PKT_LENGTH_GET

Currently, HAL_RX_MSDU_PKT_LENGTH_GET uses u32_get_bits to obtain the
MSDU length from the MSDU description.

This is not right. Because all halphy descriptions are little endian.

So use le32_get_bits for HAL_RX_MSDU_PKT_LENGTH_GET.

Patch-dependency:
	0401-0007-UPSTREAM-DP-wifi-ath12k-add-support-to-reap-and-proc.patch

Signed-off-by: Alok Singh <aloksing@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/hal_desc.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_desc.h b/drivers/net/wireless/ath/ath12k/wifi7/hal_desc.h
index 1ba0ac3..9430f4b 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_desc.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_desc.h
@@ -628,7 +628,7 @@ enum hal_rx_msdu_desc_reo_dest_ind {
 #define RX_MSDU_DESC_INFO0_DECAP_FORMAT		GENMASK(30, 29)
 
 #define HAL_RX_MSDU_PKT_LENGTH_GET(val)		\
-	(u32_get_bits((val), RX_MSDU_DESC_INFO0_MSDU_LENGTH))
+	(le32_get_bits((val), RX_MSDU_DESC_INFO0_MSDU_LENGTH))
 
 struct rx_msdu_desc {
 	__le32 info0;
-- 
2.34.1

