From 295dd37b65625961be96e8fb88768eb8c2ff35cc Mon Sep 17 00:00:00 2001
From: Alok Singh <aloksing@qti.qualcomm.com>
Date: Mon, 9 Jun 2025 13:17:04 +0530
Subject: [PATCH 13/13] UPSTREAM: DP: wifi: ath12k: enable monitor mode for
 WCN7850

Enable monitor mode for WCN7850.

Patch-dependency:
	0401-0012-UPSTREAM-DP-wifi-ath12k-use-different-packet-offset-.patch

Signed-off-by: Alok Singh <aloksing@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/hw.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hw.c b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
index 94008f5..a4c6939 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -725,7 +725,7 @@ static struct ath12k_hw_params ath12k_wifi7_hw_params[] = {
 				   BIT(NL80211_IFTYPE_P2P_DEVICE) |
 				   BIT(NL80211_IFTYPE_P2P_CLIENT) |
 				   BIT(NL80211_IFTYPE_P2P_GO),
-		.supports_monitor = false,
+		.supports_monitor = true,
 
 		.idle_ps = true,
 		.cold_boot_calib = true,
-- 
2.34.1

