From 1588110f6f970b19738a02904e5a23766a4d5bc4 Mon Sep 17 00:00:00 2001
From: Sushant Butta <sbutta@qti.qualcomm.com>
Date: Fri, 27 Jun 2025 11:30:19 +0530
Subject: [PATCH 6/6] UPSTREAM: DP: wifi: ath12k: Refactor monitor Rx hal TLV
 parsing ops

Currently, monitor Rx HAL TLV parsing APIs are invoked through
architecture-specific ops. With the HAL TLV parsing logic now
moved to architecture-specific files, these functions can be called
directly without using ops.
Therefore, the Rx HAL TLV parsing ops are being removed.

Patch-dependency:
	0404-0005-UPSTREAM-DP-wifi-ath12k-Move-QCN9274-ring-processing.patch

Signed-off-by: Sushant Butta <sbutta@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/hal_mon_cmn.h        | 12 ------------
 drivers/net/wireless/ath/ath12k/wifi7/Makefile       |  1 -
 drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c      |  6 +++---
 drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c      |  6 +++---
 drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c      |  3 ---
 .../net/wireless/ath/ath12k/wifi7/hal_mon_qcn9274.c  |  4 ----
 .../net/wireless/ath/ath12k/wifi7/hal_mon_wcn7850.c  | 12 ------------
 7 files changed, 6 insertions(+), 38 deletions(-)
 delete mode 100644 drivers/net/wireless/ath/ath12k/wifi7/hal_mon_wcn7850.c

diff --git a/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h b/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h
index 7835ac7..94b204c 100644
--- a/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h
+++ b/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h
@@ -219,9 +219,6 @@ static inline u64 ath12k_hal_le32hilo_to_u64(__le32 hi, __le32 lo)
 }
 
 struct hal_mon_ops {
-	enum hal_rx_mon_status
-	(*rx_parse_status_tlv)(struct hal_rx_mon_ppdu_info *ppdu_info,
-			       const struct hal_tlv_64_hdr *tlv);
 	enum hal_tx_mon_status
 	(*tx_parse_status_tlv)(struct hal_tx_mon_ppdu_info *ppdu_info,
 			       u16 tlv_tag,
@@ -233,15 +230,6 @@ struct hal_mon_ops {
 				  u8 *num_users);
 };
 
-static inline enum hal_rx_mon_status
-ath12k_hal_mon_rx_parse_status(struct ath12k_hal *hal,
-			       struct hal_rx_mon_ppdu_info *ppdu_info,
-			       const struct hal_tlv_64_hdr *tlv)
-{
-	return hal->hal_mon_ops->rx_parse_status_tlv(ppdu_info,
-						     tlv);
-}
-
 static inline enum hal_tx_mon_status
 ath12k_hal_mon_tx_parse_status(struct ath12k_hal *hal,
 			       struct hal_tx_mon_ppdu_info *ppdu_info,
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/Makefile b/drivers/net/wireless/ath/ath12k/wifi7/Makefile
index 84a190f..44fcecc 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/Makefile
+++ b/drivers/net/wireless/ath/ath12k/wifi7/Makefile
@@ -16,7 +16,6 @@ ath12k_wifi7-y += core.o \
 		  hal_wcn7850.o \
 		  hal_mon.o \
 		  hal_mon_qcn9274.o \
-		  hal_mon_wcn7850.o \
 		  dp_mon1.o \
 		  dp_mon2.o
 
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c
index 58295b0..60e99f8 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon1.c
@@ -476,9 +476,9 @@ ath12k_wifi7_dp_mon_rx_parse_dest(struct ath12k_pdev_dp *dp_pdev,
 		else
 			tlv_len = le64_get_bits(tlv->tl, HAL_TLV_64_HDR_LEN);
 
-		hal_status = ath12k_hal_mon_rx_parse_status(dp_pdev->dp->hal,
-							    &pmon->mon_ppdu_info,
-							    tlv);
+		hal_status =
+			ath12k_wifi7_hal_mon_rx_parse_status_tlv(&pmon->mon_ppdu_info,
+								 tlv);
 		ptr += sizeof(*tlv) + tlv_len;
 		ptr = PTR_ALIGN(ptr, HAL_TLV_64_ALIGN);
 
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
index 501e9e2..d5c50c5 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -178,9 +178,9 @@ ath12k_wifi7_dp_mon_rx_parse_dest(struct ath12k_pdev_dp *dp_pdev,
 		else
 			tlv_len = le64_get_bits(tlv->tl, HAL_TLV_64_HDR_LEN);
 
-		hal_status = ath12k_hal_mon_rx_parse_status(dp_pdev->dp->hal,
-							    &pmon->mon_ppdu_info,
-							    tlv);
+		hal_status =
+			ath12k_wifi7_hal_mon_rx_parse_status_tlv(&pmon->mon_ppdu_info,
+								 tlv);
 
 		if (ar->monitor_started &&
 		    ath12k_wifi7_dp_mon_rx_parse_dest_tlv(dp_pdev, pmon, hal_status,
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c
index 22cbdfd..e458f19 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c
@@ -2074,9 +2074,6 @@ void ath12k_wifi7_hal_mon_ops_init(struct ath12k_hal *hal,
 	case ATH12K_HW_QCN9274_HW20:
 		hal->hal_mon_ops = &hal_qcn9274_mon_ops;
 		break;
-	case ATH12K_HW_WCN7850_HW20:
-		hal->hal_mon_ops = &hal_wcn7850_mon_ops;
-		break;
 	case ATH12K_HW_IPQ5332_HW10:
 		hal->hal_mon_ops = &hal_ipq5332_mon_ops;
 		break;
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_mon_qcn9274.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_mon_qcn9274.c
index b326961..e622499 100644
