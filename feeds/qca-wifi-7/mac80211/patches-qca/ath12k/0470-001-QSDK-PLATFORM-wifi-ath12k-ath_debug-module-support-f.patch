+++ b/drivers/net/wireless/ath/ath12k/Kconfig
@@ -132,3 +132,13 @@ config ATH12K_PPE_DS_SUPPORT
 		Enable ath12k PPE-DS support
 
 		Say Y to enable PPE DS Support. If unsure, say N.
+
+config ATHDEBUG
+	bool "ath12k debugging module"
+	depends on ATH12K
