From 14ba858c98a3b4a44b8b57d64c3014320d0fd256 Mon Sep 17 00:00:00 2001
From: Aniruddha Mishra <anirmish@qti.qualcomm.com>
Date: Tue, 2 Sep 2025 16:32:14 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k: Restart monitor vap post channel
 switch

1. While handling ath12k_wmi_process_csa_switch_count_event,
csa finalize work is queued for all vdevs.
As monitor reservation is done in the context of one of the link,
and reservation use is also done in similar fashion.
Hence, skipping queueing finalize work for monitor vap

2. Multi-vdev restart for monitor doesn't work due to following reasons,
   a. ath12k_wmi_vdev_up is not called during ath12k_vdev_restart_sequence
   b. Filter setting is not done post monitor vdev up
To resolve this,
   ath12k_wmi_vdev_up is called for AP vaps in the context of csa
   finalize work. As this is not scheduled for monitor,
   allowing ath12k_wmi_vdev_up to be called in ath12k_vdev_restart_sequence
   for monitor and calling setting filter for monitor vap.

Signed-off-by: Aniruddha Mishra <anirmish@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 11 ++++++++++-
 drivers/net/wireless/ath/ath12k/wmi.c |  3 +++
 2 files changed, 13 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 834df16..fb4c240 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -17466,7 +17466,7 @@ beacon_tmpl_setup:
 	if (arvif->pending_csa_up)
 		return 0;
 
-	if (!arvif->is_up)
+	if (arvif->ahvif->vdev_type != WMI_VDEV_TYPE_MONITOR && !arvif->is_up)
 		return -EOPNOTSUPP;
 
 	if (!is_bridge_vdev) {
@@ -17507,6 +17507,15 @@ beacon_tmpl_setup:
 		return ret;
 	}
 
+	if (arvif->ahvif->vdev_type == WMI_VDEV_TYPE_MONITOR) {
+		ath12k_dp_mon_rx_config_monitor_mode(ar, false);
+		ret = ath12k_dp_mon_rx_update_filter(ar);
+		if (ret) {
+			ath12k_warn(ar->ab, "fail to set monitor filter: %d\n", ret);
+			return ret;
+		}
+	}
+
 	return ret;
 }
 
diff --git a/drivers/net/wireless/ath/ath12k/wmi.c b/drivers/net/wireless/ath/ath12k/wmi.c
index 4c78b49..a2979e0 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -11770,6 +11770,9 @@ ath12k_wmi_process_csa_switch_count_event(struct ath12k_base *ab,
 		}
 		ahvif = arvif->ahvif;
 
+		if (ahvif->vdev_type == WMI_VDEV_TYPE_MONITOR)
+			continue;
+
 		if (arvif->link_id >= IEEE80211_MLD_MAX_NUM_LINKS) {
 			ath12k_warn(ab, "Invalid CSA switch count even link id: %d\n",
 				    arvif->link_id);
-- 
