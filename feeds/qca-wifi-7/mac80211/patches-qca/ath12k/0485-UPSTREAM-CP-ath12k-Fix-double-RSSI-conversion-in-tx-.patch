From 5a0c702ce6760700667d6fe8f80a38ad88316477 Mon Sep 17 00:00:00 2001
From: Banka Sai Krishna <banksaik@qti.qualcomm.com>
Date: Sun, 21 Sep 2025 23:15:26 +0530
Subject: [PATCH] UPSTREAM:CP: wifi: ath12k: Fix ACK signal misreporting
 in station dump

Do not apply rssi_offset to ts->ack_rssi, as it already 
contains the RSSI value in dBm units from firmware.
Adding the offset caused incorrect ACK signal values to be 
reported in station dump, sometimes as low as -127 dBm.
Remove the offset to avoid double conversion and ensure 
accurate ACK signal reporting.

Signed-off-by: Banka Sai Krishna <banksaik@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 6 ++----
 1 file changed, 2 insertions(+), 4 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index 6b76699..846d759 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -1472,8 +1472,7 @@ ath12k_wifi7_dp_tx_htt_tx_complete_buf(struct ath12k_dp *dp,
 	if (ts->acked) {
 		if (!(info->flags & IEEE80211_TX_CTL_NO_ACK)) {
 			info->flags |= IEEE80211_TX_STAT_ACK;
-			info->status.ack_signal = dp_pdev->ar->rssi_offsets.rssi_offset +
-						  ts->ack_rssi;
+			info->status.ack_signal = ts->ack_rssi;
 
 			if (!test_bit(WMI_TLV_SERVICE_HW_DB2DBM_CONVERSION_SUPPORT,
 				      ab->wmi_ab.svc_map))
@@ -1855,8 +1854,7 @@ static void ath12k_wifi7_dp_tx_complete_msdu(struct ath12k_pdev_dp *dp_pdev,
 	if (ts->status == HAL_WBM_TQM_REL_REASON_FRAME_ACKED &&
 			!(info->flags & IEEE80211_TX_CTL_NO_ACK))	{
 		info->flags |= IEEE80211_TX_STAT_ACK;
-		info->status.ack_signal = dp_pdev->ar->rssi_offsets.rssi_offset +
-					  ts->ack_rssi;
+		info->status.ack_signal = ts->ack_rssi;
 
 		if (!test_bit(WMI_TLV_SERVICE_HW_DB2DBM_CONVERSION_SUPPORT,
 			      ab->wmi_ab.svc_map))
-- 
2.34.1

