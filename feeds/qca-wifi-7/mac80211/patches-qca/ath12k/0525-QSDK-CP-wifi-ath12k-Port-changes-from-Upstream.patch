 		ath12k_mac_update_ch_list(ar, band,
 					  freq_low,
 					  freq_high);
+
+		ath12k_mac_update_freq_range(ar, freq_low, freq_high);
+
 		ar->num_channels = ath12k_reg_get_num_chans_in_band(ar, band);
 		if (!bands[NL80211_BAND_2GHZ]) {
 			bands[NL80211_BAND_2GHZ] = band;
@@ -21329,6 +21352,9 @@ static int ath12k_mac_setup_channels_rates(struct ath12k *ar,
 						  freq_low,
 						  freq_high);
 			ath12k_mac_update_5_9_ch_list(ar, band);
+
+			ath12k_mac_update_freq_range(ar, freq_low, freq_high);
+
 			ar->num_channels = ath12k_reg_get_num_chans_in_band(ar, band);
 			if (!bands[NL80211_BAND_5GHZ]) {
 				bands[NL80211_BAND_5GHZ] = band;
@@ -21410,6 +21436,8 @@ static int ath12k_mac_setup_channels_rates(struct ath12k *ar,
 						  freq_low,
