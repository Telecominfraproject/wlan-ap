From 29cd8ff0b6e6bc73fbd5d0def08abc0502a067f0 Mon Sep 17 00:00:00 2001
From: Shwetha G K <kshwetha@qti.qualcomm.com>
Date: Mon, 25 Aug 2025 10:13:35 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: ath12k: Extend advertised ttlm to
 start at BSS level

Add changes to support sending advertised ttlm on bss level to handle the
dynamic link addition scenario. When a new link is added to an already
existing MLD, firmware expects an explicit TTLM WMI command on newly added
link to know whether the new link needs to be enabled or disabled.
If the new link marked as enabled, the bss beacons with TTLM IE as per the
config shared to firmware. If the link is marked as disabled, firmware does
not send any beacon on this link until the current advertised ttlm on other
links gets over.

Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 26 ++++++++++++++++++++++++++
 1 file changed, 26 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 01c5e55..a3a5963 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -5888,6 +5888,23 @@ ath12k_mac_offload_advertised_ttlm(struct ieee80211_hw *hw,
 	ath12k_wmi_ap_tid_to_link_map_config(ar, &map_params);
 }
 
+static void ath12k_mac_bss_offload_advertised_ttlm(struct ath12k_link_vif *arvif)
+{
+	/* prepare the params needed to send the wmi command */
+	struct ath12k_wmi_tid_to_link_map_ap_params map_params = {};
+	struct ath12k *ar = arvif->ar;
+
+	if (!arvif->is_created)
+		return;
+
+	if (ath12k_mac_populate_ttlm_params(arvif, &map_params)) {
+		ath12k_dbg(ar->ab, ATH12K_DBG_MAC,
+			   "Failed to populate advertised ttlm parameters\n");
+		return;
+	}
+
+	ath12k_wmi_ap_tid_to_link_map_config(ar, &map_params);
+}
 
 void ath12k_mac_op_vif_cfg_changed(struct ieee80211_hw *hw,
 				   struct ieee80211_vif *vif,
@@ -6906,6 +6923,15 @@ void ath12k_mac_bss_info_changed(struct ath12k *ar,
 					arvif->beacon_interval, arvif->vdev_id);
 	}
 
+	/* send ttlm config before vdev up, so that first beacon itself can
+	 * advertise ttlm
+	 */
+	if (vif->type == NL80211_IFTYPE_AP &&
+	    changed & BSS_CHANGED_LINK_ADV_TTLM &&
+	    wiphy_ext_feature_isset(ath12k_ar_to_hw(ar)->wiphy,
+				    NL80211_EXT_FEATURE_BEACON_ADVERTISED_TTLM_OFFLOAD))
+		ath12k_mac_bss_offload_advertised_ttlm(arvif);
+
 	if (changed & BSS_CHANGED_BEACON) {
 		param_id = WMI_PDEV_PARAM_BEACON_TX_MODE;
 		param_value = WMI_BEACON_BURST_MODE;
-- 
