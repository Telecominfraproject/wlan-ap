From edf41d5ff45b8909e609ad4db00056293718cc52 Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <quic_hramanat@quicinc.com>
Date: Tue, 15 Apr 2025 18:32:03 +0530
Subject: [PATCH 01/15] UPSTREAM:DP:ath12k:Fix RU allocation incrementation
in tx_stats

RU allocation counters are not incrementing in tx_stats as the
ppdu_type is not initialized. Initialize ppdu_type value to fix thi
incrementation issue.

Original Patch:
646-ath12k-Fix-RU-allocation-incrementation-in-tx_stats.patch

Signed-off-by: Dinesh Karthikeyan <quic_dinek@quicinc.com>
Signed-off-by: Hariharan Ramanathan <quic_hramanat@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/dp_htt.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.c b/drivers/net/wireless/ath/ath12k/dp_htt.c
index 7b63936..0c4c956 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.c
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.c
@@ -230,7 +230,7 @@ ath12k_update_per_peer_tx_stats(struct ath12k_pdev_dp *dp_pdev,
 	mcs = HTT_USR_RATE_MCS(user_rate->rate_flags);
 	sgi = HTT_USR_RATE_GI(user_rate->rate_flags);
 	dcm = HTT_USR_RATE_DCM(user_rate->rate_flags);
-	ppdu_type = HTT_USR_RATE_PPDU_TYPE(user_rate->rate_flags);
+	ppdu_type = HTT_USR_RATE_PPDU_TYPE(user_rate->info1);
 	is_ofdma = (ppdu_type == HTT_PPDU_STATS_PPDU_TYPE_MU_OFDMA) |
 		(ppdu_type == HTT_PPDU_STATS_PPDU_TYPE_MU_MIMO_OFDMA);
 
@@ -345,6 +345,8 @@ ath12k_update_per_peer_tx_stats(struct ath12k_pdev_dp *dp_pdev,
 			HTT_USR_CMPLTN_SHORT_RETRY(usr_stats->cmpltn_cmn.flags);
 	}
 
+	peer_stats->ppdu_type = ppdu_type;
+
 	spin_unlock_bh(&dp->dp_lock);
 	rcu_read_unlock();
 }
-- 
