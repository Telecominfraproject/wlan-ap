From 3ad354fc15121d2e70d21579c8e890e5ea07f4af Mon Sep 17 00:00:00 2001
From: Kiran Venkatappa <kiranv@qti.qualcomm.com>
Date: Thu, 26 Jun 2025 12:22:29 +0530
Subject: [PATCH 3/5] wifi: ath12k: Add Broadcast TWT support for AP role

Broadcast TWT support is enabled in AP role. Do not remove this
capabality in HE MAC capabilities.

Signed-off-by: Kiran Venkatappa <kiranv@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 2 --
 1 file changed, 2 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -10951,7 +10951,6 @@ static void ath12k_mac_copy_he_cap(struc
 
 	switch (iftype) {
 	case NL80211_IFTYPE_AP:
-		he_cap_elem->mac_cap_info[2] &= ~IEEE80211_HE_MAC_CAP2_BCAST_TWT;
 		he_cap_elem->phy_cap_info[3] &=
 			~IEEE80211_HE_PHY_CAP3_DCM_MAX_CONST_TX_MASK;
 		he_cap_elem->phy_cap_info[9] |=
