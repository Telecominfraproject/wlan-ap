From 71172b7982d677ad60786bca0a0bb699acc5c1b3 Mon Sep 17 00:00:00 2001
From: Roopni Devanathan <rdevanat@qti.qualcomm.com>
Date: Tue, 29 Jul 2025 10:36:45 +0530
Subject: [PATCH] UPSTREAM:CP:wifi: ath12k: Add missing stats

Add missing FW stats to HTT stats type 1, 9, 12, 22, 17, 18, 26,
32 and 49. Add new stats tag - HTT_STATS_TX_PDEV_BE_RATE_STATS_TAG,
HTT_STATS_RX_PDEV_BE_BN_UL_TRIG_TAG, HTT_STATS_TX_PDEV_SAWF_RATE_STATS_TAG,
HTT_STATS_TX_PDEV_MLO_ABORT_TAG and HTT_STATS_TX_PDEV_MLO_TXOP_ABORT_TAG,
for these HTT stats types.

Patch-dependency: None
Patch-work: None

Signed-off-by: Roopni Devanathan <rdevanat@qti.qualcomm.com>
---
 .../wireless/ath/ath12k/debugfs_htt_stats.c   | 531 +++++++++++++++++-
 .../wireless/ath/ath12k/debugfs_htt_stats.h   | 157 +++++-
 2 files changed, 684 insertions(+), 4 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
index d030cb8..91c39d9 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
@@ -92,6 +92,34 @@ print_array_to_buf_s8(u8 *buf, u32 offset, const char *header, u32 stats_index,
 	return index;
 }
 
+static u32
+print_array_to_buf_s32(u8 *buf, u32 offset, const char *header, u32 stats_index,
+		       const s32 *array, u32 array_len, const char *footer)
+{
+	u32 buf_len = ATH12K_HTT_STATS_BUF_SIZE;
+	int index = 0;
+	u8 i;
+
+	if (header)
+		index += scnprintf(buf + offset, buf_len - offset, "%s = ", header);
+
+	for (i = 0; i < array_len; i++) {
+		index += scnprintf(buf + offset + index, (buf_len - offset) - index,
+				   " %u:%d,", stats_index++, array[i]);
+	}
+
+	index--;
+	if ((offset + index) < buf_len)
+		buf[offset + index] = '\0';
+
+	if (footer) {
+		index += scnprintf(buf + offset + index, (buf_len - offset) - index,
+				   "%s", footer);
+	}
+
+	return index;
+}
