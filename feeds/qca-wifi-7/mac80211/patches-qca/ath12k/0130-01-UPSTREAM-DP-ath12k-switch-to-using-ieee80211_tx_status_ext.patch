From 7abd9b2596eb3daafeed6c49b735329bec00b4e1 Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <quic_hramanat@quicinc.com>
Date: Tue, 15 Apr 2025 18:35:50 +0530
Subject: [PATCH 02/15] UPSTREAM:DP:ath12k:switch to using
ieee80211_tx_status_ext()

This allows us to pass HE rates down into the stack

Original Patch:
649-ath12k-switch-to-using-ieee80211_tx_status_ext.patch

NOTE:
Below patch is combined with this patch.
727-ath12k-rate-info-is-not-properly-updated-for-tx-pkts.patch

Signed-off-by: Sachin Kedare <quic_skedare@quicinc.com>
Signed-off-by: Hariharan Ramanathan <quic_hramanat@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 12 +++++++++++-
 1 file changed, 11 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index 4514070..4177d15 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -644,6 +644,8 @@ static void ath12k_wifi7_dp_tx_complete_msdu(struct ath12k_pdev_dp *dp_pdev,
 					     struct sk_buff *skb_ext_desc)
 {
 	struct ieee80211_tx_status status = { 0 };
+	struct ieee80211_rate_status status_rate = { 0 };
+	struct rate_info rate;
 	struct ath12k_dp *dp = dp_pdev->dp;
 	struct ath12k_base *ab = dp->ab;
 	struct ieee80211_tx_info *info;
@@ -747,11 +749,19 @@ static void ath12k_wifi7_dp_tx_complete_msdu(struct ath12k_pdev_dp *dp_pdev,
 		ieee80211_free_txskb(ath12k_dp_pdev_to_hw(dp_pdev), msdu);
 		goto exit;
 	}
-	spin_unlock_bh(&dp->dp_lock);
 
 	status.sta = peer->sta;
 	status.info = info;
 	status.skb = msdu;
+	rate = peer->last_txrate;
+
+	status_rate.rate_idx = rate;
+	status_rate.try_count = 1;
+
+	status.rates = &status_rate;
+	status.n_rates = 1;
+	spin_unlock_bh(&dp->dp_lock);
+
 	ieee80211_tx_status_ext(ath12k_dp_pdev_to_hw(dp_pdev), &status);
 
 exit:
