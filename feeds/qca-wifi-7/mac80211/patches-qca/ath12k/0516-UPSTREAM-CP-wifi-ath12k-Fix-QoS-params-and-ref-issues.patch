From 2a1e5f057b612c895b5b6e657c391fc28b9e64d4 Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Thu, 14 Aug 2025 00:14:17 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k: Fix QoS params programming and
 ref_count issues

Fix the below issues related to QoS programming:

1. Fix the service interval conversion from microseconds to
milliseconds before programming to FW.

2. Copy min_data_rate from SCS qos_attr structure and program FW.

3. Return success instead of failure for SCS delete requests
whenever ref_count of the QoS profile was greater than 1, and
delete is successful.

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c |  5 +++++
 drivers/net/wireless/ath/ath12k/qos.c | 27 +++++++++++++++++++++------
 2 files changed, 26 insertions(+), 6 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index f40786f..eff2af3 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -23169,6 +23169,9 @@ void ath12k_compute_qos_params(struct cfg80211_qm_qos_attributes *qos_attr,
 	service_interval = ((qos_attr->min_service_interval +
 			   qos_attr->max_service_interval) >> 1);
 
+	/* Convert microseconds to milliseconds */
+	service_interval = service_interval / 1000;
+
 	/* Data rate in Kilo Bytes Per Second */
 	data_rate = qos_attr->min_data_rate / 8;
 
@@ -23211,6 +23214,8 @@ void ath12k_copy_qos_params(struct ath12k_qos_params *params,
 	if (qos_attr->min_service_interval)
 		params->min_service_interval = service_interval;
 
+	params->min_data_rate = qos_attr->min_data_rate;
+
 	/* Convert microseconds to miliseconds */
 	if (qos_attr->delay_bound)
 		params->delay_bound = qos_attr->delay_bound / 1000;
diff --git a/drivers/net/wireless/ath/ath12k/qos.c b/drivers/net/wireless/ath/ath12k/qos.c
index ad03e31..900333e 100644
--- a/drivers/net/wireless/ath/ath12k/qos.c
+++ b/drivers/net/wireless/ath/ath12k/qos.c
@@ -117,7 +117,8 @@ u16 ath12k_add_profile(struct ath12k_base *ab,
 			qos_ctx->profiles[index].ref_count++;
 			id = index;
 			ath12k_dbg(ab, ATH12K_DBG_QOS,
-				   "QoS profile %d add", id);
+				   "QoS profile %d add, ref_count:%d", id,
+				   qos_ctx->profiles[id].ref_count);
 			break;
 		}
 	}
@@ -132,7 +133,9 @@ int ath12k_update_profile(struct ath12k_base *ab,
 	memcpy(&qos_ctx->profiles[id].params,
 	       params, sizeof(struct ath12k_qos_params));
 	ath12k_dbg(ab, ATH12K_DBG_QOS,
-		   "QoS profile %d Update", id);
+		   "QoS profile %d Update, ref_count:%d", id,
+		   qos_ctx->profiles[id].ref_count);
+
 	return 0;
 }
 
@@ -150,11 +153,15 @@ int ath12k_del_profile(struct ath12k_base *ab,
 		memset(&qos_ctx->profiles[id].params, 0,
 		       sizeof(struct ath12k_qos_params));
 		ath12k_dbg(ab, ATH12K_DBG_QOS,
-			   "QoS profile %d delete", id);
+			   "QoS profile %d delete, ref_count:%d", id,
+			   qos_ctx->profiles[id].ref_count);
 		return 0;
 	}
-	/*Some reference still exist, profile not deleted*/
-	return -EINVAL;
+
+	ath12k_dbg(ab, ATH12K_DBG_QOS, "QoS profile %d delete, ref_count:%d",
+		   id, qos_ctx->profiles[id].ref_count);
+
+	return 0;
 }
 
 static bool ath12k_qos_id_valid(struct ath12k_base *ab, u16 id,
@@ -279,6 +286,9 @@ u16 ath12k_qos_configure(struct ath12k_base *ab, struct ath12k *ar,
 				      min_id, max_id);
 	if (ath12k_qos_id_valid(ab, id, min_id, max_id)) {
 		qos_ctx->profiles[id].ref_count++;
+		ath12k_dbg(ab, ATH12K_DBG_QOS,
+			   "QoS profile matched - ID:%d, ref_count:%d", id,
+			   qos_ctx->profiles[id].ref_count);
 		spin_unlock_bh(&qos_ctx->profile_lock);
 		return id;
 	}
@@ -335,7 +345,12 @@ int ath12k_qos_disable(struct ath12k_base *ab, struct ath12k *ar,
 	       sizeof(struct ath12k_qos_params));
 	ret = ath12k_del_profile(ab, qos_ctx, id);
 	spin_unlock_bh(&qos_ctx->profile_lock);
-	if (ret != 0)
+
+	/*
+	 * Return if either delete failed or ref_count is decremented and is
+	 * non zero - some reference still exist, profile not deleted.
+	 */
+	if (ret != 0 || qos_ctx->profiles[id].ref_count != 0)
 		return ret;
 
 	if (qos_dir == QOS_PROFILE_DL) {
-- 
2.34.1

