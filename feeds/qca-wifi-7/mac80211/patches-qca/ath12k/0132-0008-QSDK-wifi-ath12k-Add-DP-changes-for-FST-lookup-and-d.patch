@@ -2590,3 +2590,90 @@ void ath12k_wifi7_dp_rx_fst_detach(struct ath12k_dp *dp, struct dp_rx_fst *fst)
 	ath12k_wifi7_hal_rx_fst_detach(ab, fst->hal_rx_fst);
 	kfree(fst->base);
