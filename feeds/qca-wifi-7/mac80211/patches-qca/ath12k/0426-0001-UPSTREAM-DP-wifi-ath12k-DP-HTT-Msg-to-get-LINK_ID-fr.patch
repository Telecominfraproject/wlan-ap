From 72e130df0f3c4c446c2fadb794e75e76f2a2afd3 Mon Sep 17 00:00:00 2001
From: Kenvish Butani <kbutani@qti.qualcomm.com>
Date: Fri, 13 Jun 2025 17:27:31 +0530
Subject: [PATCH 1/6] UPSTREAM: DP: wifi: ath12k: DP HTT Msg to get LINK_ID
 from PPDU_ID

- Add support of new HTT msg to get position (bits and offset)
  of link id within PPDU id.
- This fields (bits and offset) will be used in per packet
  path to obtain link_id value from each PPDU ID received
  in Tx completion.
- The link id value derived will be the HW link id and it
  will be mapped to corresponding SW link id and use to
  update Telemetry at link peer level.

Patch-dependency:
	0425-0002-UPSTREAM-DP-wifi-ath12k-DP-Telemetry-in-Tx-Enqueue.patch

Signed-off-by: Kenvish Butani <kbutani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h     |  4 ++++
 drivers/net/wireless/ath/ath12k/dp_htt.c | 20 ++++++++++++++++++++
 drivers/net/wireless/ath/ath12k/dp_htt.h | 20 ++++++++++++++++++++
 3 files changed, 44 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 9ae6f98..760855f 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -629,6 +629,10 @@ struct ath12k_dp {
 	int num_nrps;
 	unsigned long ppeds_service_running;
 	bool stats_disable;
+
+	/* HW link ID position in PPDU_ID */
+	u8 link_id_offset;
+	u8 link_id_bits;
 };
 /* @brief target -> host extended statistics upload
  *
diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.c b/drivers/net/wireless/ath/ath12k/dp_htt.c
index 067a0ba..d9bbdab 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.c
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.c
@@ -1061,6 +1061,23 @@ exit:
 	rcu_read_unlock();
 }
 
+static void ath12k_htt_t2h_ppdu_id_fmt_handler(struct ath12k_dp *dp,
+					       struct sk_buff *skb)
+{
+	u8 valid, bits, offset;
+	struct ath12k_htt_ppdu_id_fmt_info *msg;
+
+	msg = (struct ath12k_htt_ppdu_id_fmt_info *)skb->data;
+	valid = le32_get_bits(msg->link_id, HTT_PPDU_ID_FMT_VALID_BITS);
+	bits = le32_get_bits(msg->link_id, HTT_PPDU_ID_FMT_GET_BITS);
+	offset = le32_get_bits(msg->link_id, HTT_PPDU_ID_FMT_GET_OFFSET);
+
+	if (valid) {
+		dp->link_id_bits = bits;
+		dp->link_id_offset = offset;
+	}
+}
+
 static void
 ath12k_htt_pri_link_peer_migrate_indication(struct ath12k_base *ab,
 					    struct sk_buff *skb)
@@ -1253,6 +1270,9 @@ void ath12k_dp_htt_htc_t2h_msg_handler(struct ath12k_base *ab,
 	case HTT_T2H_MSG_TYPE_MLO_RX_PEER_UNMAP:
 		ath12k_peer_mlo_unmap_event(ab, skb);
 		break;
+	case HTT_T2H_MSG_TYPE_PPDU_ID_FMT_IND:
+		ath12k_htt_t2h_ppdu_id_fmt_handler(dp, skb);
+		break;
 	case HTT_T2H_MSG_TYPE_PRIMARY_LINK_PEER_MIGRATE_IND:
 		ath12k_htt_pri_link_peer_migrate_indication(ab, skb);
 		break;
diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.h b/drivers/net/wireless/ath/ath12k/dp_htt.h
index 265fa7e..14b868f 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.h
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.h
@@ -1058,6 +1058,7 @@ enum htt_t2h_msg_type {
 	HTT_T2H_MSG_TYPE_PEER_MAP3	= 0x2b,
 	HTT_T2H_MSG_TYPE_VDEV_TXRX_STATS_PERIODIC_IND = 0x2c,
 	HTT_T2H_MSG_TYPE_QOS_MSDUQ_INFO_IND = 0x2e,
+	HTT_T2H_MSG_TYPE_PPDU_ID_FMT_IND = 0x30,
 	HTT_T2H_MSG_TYPE_PRIMARY_LINK_PEER_MIGRATE_IND = 0x37,
 };
 
@@ -2094,6 +2095,25 @@ struct htt_t2h_qos_info_ind {
 	__le32 info2;
 } __packed;
 
+struct ath12k_htt_ppdu_id_fmt_info {
+	__le32 info;
+	__le32 info1;
+
+	/* Bits 15:0   reserved
+	 * Bit  16     link_id valid
+	 * Bits 21:17  link_id bits
+	 * Bits 26:22  link_id offset
+	 * Bits 31:27  reserved
+	 */
+	__le32 link_id;
+	__le32 info2;
+	__le32 info3;
+} __packed;
+
+#define HTT_PPDU_ID_FMT_VALID_BITS	BIT(16)
+#define HTT_PPDU_ID_FMT_GET_BITS	GENMASK(21, 17)
+#define HTT_PPDU_ID_FMT_GET_OFFSET	GENMASK(26, 22)
+
 int ath12k_dp_htt_connect(struct ath12k_dp *dp);
 
 void ath12k_dp_htt_htc_t2h_msg_handler(struct ath12k_base *ab,
-- 
2.34.1

