From c0fd46bc6e40b348c59035dc86fbeeafad01b526 Mon Sep 17 00:00:00 2001
From: Narendhar Reddy <nare@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 10:08:42 +0530
Subject: [PATCH] UPSTREAM:PLATFORM:wifi:ath12k:Change firmware stop sequence during core deinit

1)Change firmware stop sequence during core deinit

	WCSS subsystem CLOCK got disabled in firmware during MODE_OFF this leads
to NOC when host try to access CE register after MODE_OFF during reboot
and rmmod usecases.
	Firmware stop done just before the power down avoid accessing CE register
after MODE_OFF. As firmware stop sequence change there might
be interrupt could process if unlock the mutex. Hence register write and
powerdown bring to the single mutex lock block.

2)cleanup CE pipes after firmware stop

	CE pipe got cleanup before firmware stop. This leads to the corruption
in CE allocated SKB as there is a possibility of firmware could
write to the SKB after the CE pipe cleanup done in host side.

Moved the CE pipe cleanup after the firmware stop.

Signed-off-by: Saravanakumar Duraisamy <quic_saradura@quicinc.com>
Signed-off-by: Narendhar Reddy <nare@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ahb.c  | 4 +++-
 drivers/net/wireless/ath/ath12k/ce.c   | 2 +-
 drivers/net/wireless/ath/ath12k/core.c | 7 ++++---
 drivers/net/wireless/ath/ath12k/pci.c  | 1 -
 drivers/net/wireless/ath/ath12k/pcic.c | 1 -
 5 files changed, 8 insertions(+), 7 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/ahb.c
+++ b/drivers/net/wireless/ath/ath12k/ahb.c
@@ -370,7 +370,6 @@ static void ath12k_ahb_stop(struct ath12
 	ath12k_ahb_kill_tasklets(ab);
 #endif
 	del_timer_sync(&ab->rx_replenish_retry);
-	ath12k_ce_cleanup_pipes(ab);
 }
 
 static int ath12k_ahb_power_up(struct ath12k_base *ab)
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -909,12 +909,7 @@ void ath12k_core_to_group_ref_put(struct
 static void ath12k_core_stop(struct ath12k_base *ab)
 {
 	ath12k_core_to_group_ref_put(ab);
-
-	if (!test_bit(ATH12K_FLAG_CRASH_FLUSH, &ab->dev_flags))
-		ath12k_qmi_firmware_stop(ab);
-
 	ath12k_acpi_stop(ab);
-
 	ath12k_dp_rx_pdev_reo_cleanup(ab);
 	ath12k_hif_stop(ab);
 	ath12k_wmi_detach(ab);
@@ -1047,6 +1042,10 @@ err_qmi_deinit:
 
 static void ath12k_core_soc_destroy(struct ath12k_base *ab)
 {
+	if (!test_bit(ATH12K_FLAG_CRASH_FLUSH, &ab->dev_flags))
+		ath12k_qmi_firmware_stop(ab);
+
+	ath12k_ce_cleanup_pipes(ab);
 	ath12k_hif_power_down(ab, false);
 	ath12k_reg_free(ab);
 	ath12k_debugfs_soc_destroy(ab);
--- a/drivers/net/wireless/ath/ath12k/pci.c
+++ b/drivers/net/wireless/ath/ath12k/pci.c
@@ -606,7 +606,6 @@ void ath12k_pci_stop(struct ath12k_base
 		return;
 
 	ath12k_pcic_ce_irq_disable_sync(ab);
-	ath12k_ce_cleanup_pipes(ab);
 }
 
 int ath12k_pci_start(struct ath12k_base *ab)
--- a/drivers/net/wireless/ath/ath12k/pcic.c
+++ b/drivers/net/wireless/ath/ath12k/pcic.c
@@ -841,7 +841,6 @@ void ath12k_pcic_stop(struct ath12k_base
 {
 	ath12k_pcic_ce_irq_disable_sync(ab);
 	timer_delete_sync(&ab->rx_replenish_retry);
-	ath12k_ce_cleanup_pipes(ab);
 }
 
 int ath12k_pcic_start(struct ath12k_base *ab)
