From a21d71409944a759219b9141cf0232ab35076599 Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Wed, 2 Jul 2025 14:09:01 +0530
Subject: [PATCH] Upstream:DP:wifi:ath12k: Add back-references for monitor
 objects

Currently, struct ath12k_dp_mon and struct ath12k_pdev_mon_dp do not
contain back-references to their respective parent datapath structures.
As a result, accessing parent context during monitor destination ring
processing requires passing multiple pointers through the call chain,
leading to unnecessary overhead and reduced code clarity.

To address this, add the following back-references:
- dp_mon->dp to reference the parent struct ath12k_dp
- dp_mon_pdev->dp_pdev to reference the parent struct ath12k_pdev_dp
- dp_mon_pdev->dp_mon to reference the global monitor datapath context

These additions align with the existing design pattern used in the main
datapath structures and simplify access to shared context during packet
processing in the monitor path. This change will also be helpful for the
upcoming fragment-based monitor processing infrastructure, where
efficient access to parent structures.

Patch-dependency : 0402-0004-UPSTREAM-DP-wifi-ath12k-Segregation-of-Monitor-pdev-.patch

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_mon.c | 3 +++
 drivers/net/wireless/ath/ath12k/dp_mon.h | 3 +++
 2 files changed, 6 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.c b/drivers/net/wireless/ath/ath12k/dp_mon.c
index f9013d9..9d8db56 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.c
@@ -1655,6 +1655,7 @@ int ath12k_dp_mon_init(struct ath12k_dp *dp)
 	if (!dp_mon)
 		return -ENOMEM;
 
+	dp_mon->dp = dp;
 	dp->dp_mon = dp_mon;
 
 	return 0;
@@ -1677,6 +1678,8 @@ int ath12k_dp_mon_pdev_alloc(struct ath12k_pdev_dp *dp_pdev)
 	if (!dp_mon_pdev)
 		return -ENOMEM;
 
+	dp_mon_pdev->dp_pdev = dp_pdev;
+	dp_mon_pdev->dp_mon = dp_pdev->dp->dp_mon;
 	dp_pdev->dp_mon_pdev = dp_mon_pdev;
 
 	return 0;
diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.h b/drivers/net/wireless/ath/ath12k/dp_mon.h
index 3152bfe..fefd2f3 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.h
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.h
@@ -99,6 +99,7 @@ struct ath12k_dp_arch_mon_ops {
 };
 
 struct ath12k_dp_mon {
+	struct ath12k_dp *dp;
 	struct dp_rxdma_mon_ring rxdma_mon_buf_ring;
 	struct dp_rxdma_mon_ring tx_mon_buf_ring;
 	struct dp_rxdma_mon_ring rx_mon_status_refill_ring[MAX_RXDMA_PER_PDEV];
@@ -215,6 +216,8 @@ struct ath12k_mon_data {
 };
 
 struct ath12k_pdev_mon_dp {
+	struct ath12k_dp_mon *dp_mon;
+	struct ath12k_pdev_dp *dp_pdev;
 	struct dp_srng rxdma_mon_dst_ring[MAX_RXDMA_PER_PDEV];
 	struct dp_srng tx_mon_dst_ring[MAX_RXDMA_PER_PDEV];
 
