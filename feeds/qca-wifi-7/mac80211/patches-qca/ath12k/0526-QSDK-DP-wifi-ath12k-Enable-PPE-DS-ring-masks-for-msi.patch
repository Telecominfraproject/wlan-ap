From f24217a9cc73bada0a31dfabb3e71d447f8c0c11 Mon Sep 17 00:00:00 2001
From: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
Date: Fri, 5 Sep 2025 14:26:57 -0700
Subject: [PATCH] QSDK:DP:wifi:ath12k:Enable PPE DS ring masks for msi8
 configuration

Currently, MSI8 configuration lacks interrupt mask enablement for PPE2TCL,
REO2PPE, and WBM2SW6_PPEDS_TX_CMPLN rings, preventing proper interrupt
handling for PPE DS operations.
Additionally, the PPE2TCL IRQ is requested with IRQF_NO_SUSPEND, which may
conflict with shared IRQ scenarios.

Enable the interrupt masks for PPE2TCL, REO2PPE, and WBM2SW6_PPEDS_TX_CMPLN
rings in the MSI8 configuration to support PPE DS functionality. Also,
change the PPE2TCL IRQ flag to IRQF_SHARED to allow shared interrupt 
handling.

Patch-dependency:
	0325-01-wifi-ath12k-Add-support-for-four-slot-PCIe-by-changi.patch

Signed-off-by: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/pcic.c     |    2 +-
 drivers/net/wireless/ath/ath12k/wifi7/hw.c |   14 +++++---------
 2 files changed, 6 insertions(+), 10 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/pcic.c
+++ b/drivers/net/wireless/ath/ath12k/pcic.c
@@ -1273,7 +1273,7 @@ int ath12k_pci_ppeds_register_interrupts
 			 sizeof(ab->dp->ppe.ppeds_irq_name[PPEDS_IRQ_PPE2TCL]),
 			 "pci%d_ppe2tcl_%d", bus_id, ab->dp->ppe.ppeds_soc_idx);
 		ret = devm_request_irq(ab->dev, irq,  ath12k_ds_ppe2tcl_irq_handler,
-				       IRQF_NO_SUSPEND,
+				       IRQF_SHARED,
 					   ab->dp->ppe.ppeds_irq_name[PPEDS_IRQ_PPE2TCL],
 					   (void *)ab);
 		if (ret)
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -238,6 +238,10 @@ static const struct ath12k_hw_ops wcn785
 #define ATH12K_TX_MON_RING_MASK_1 0x2
 #define ATH12K_UMAC_RESET_INTR_MASK_0   0x1
 
+#define ATH12K_PPE2TCL_RING_MASK_0 0x1
+#define ATH12K_REO2PPE_RING_MASK_0 0x1
+#define ATH12K_PPE_WBM2SW_RELEASE_RING_MASK_0 0x1
+
 /* To support 8 MSI DP grouping */
 static struct ath12k_hw_ring_mask ath12k_wifi7_hw_ring_mask_qcn9274_msi8 = {
         .tx  = {
@@ -289,9 +293,7 @@ static struct ath12k_hw_ring_mask ath12k
                 ATH12K_TX_MON_RING_MASK_1,
                 0, 0, 0, 0, 0, 0
         },
-/*This will be rebased only when ppeds patches are rebased
- */
-#if 0
+#ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
         .ppe2tcl = {
                 0, 0, 0, 0, 0, 0,
                 ATH12K_PPE2TCL_RING_MASK_0,
@@ -302,23 +304,17 @@ static struct ath12k_hw_ring_mask ath12k
                 ATH12K_REO2PPE_RING_MASK_0,
 		0, 0
         },
-#ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
         .wbm2sw6_ppeds_tx_cmpln = {
 		ATH12K_PPE_WBM2SW_RELEASE_RING_MASK_0,
 		0, 0, 0, 0, 0, 0, 0
         },
 #endif
-#endif
         .umac_dp_reset = {
                 0, 0, 0, 0, 0, 0, 0,
 		ATH12K_UMAC_RESET_INTR_MASK_0
         },
 };
 
-#define ATH12K_PPE2TCL_RING_MASK_0 0x1
-#define ATH12K_REO2PPE_RING_MASK_0 0x1
-#define ATH12K_PPE_WBM2SW_RELEASE_RING_MASK_0 0x1
-
 #define ATH12K_RX_MON_STATUS_RING_MASK_0 0x1
 #define ATH12K_RX_MON_STATUS_RING_MASK_1 0x2
 #define ATH12K_RX_MON_STATUS_RING_MASK_2 0x4
