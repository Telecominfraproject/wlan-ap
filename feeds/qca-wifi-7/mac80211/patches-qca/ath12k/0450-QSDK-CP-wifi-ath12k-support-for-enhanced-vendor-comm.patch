+		ath12k_err(NULL,
+			   "send failed with err=%d\n", ret);
 		return ret;
 	}
 
 	return 0;
 
 err:
-	pr_err("get offload type failed with err=%d\n", ret);
+	ath12k_err(NULL,
+		   "put failed with err=%d\n", ret);
 	kfree_skb(skb);
 	return ret;
 }
