From b124cf30327e6bf2da6a26b782fd0f11ca909611 Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <hramanat@qti.qualcomm.com>
Date: Thu, 21 Aug 2025 12:38:36 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Reorder the enqueue drop counters to
 align with dp enumeration

Reorder the enqueue drop counters to align with dp enumeration. Moving
below enqueue drop attributes to match with the dp code.

TX ENQUEUE DROP COUNTERS:
1. QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_SW_DESC_NA
2. QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_TCL_DESC_NA
3. QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_ARVIF_FAST
4. QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_PDEV_FAST
5. QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_MAX_TX_LIMIT_FAST
6. QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_ENCAP_FAST

Signed-off-by: Hariharan Ramanathan <hramanat@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/vendor.h | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/vendor.h b/drivers/net/wireless/ath/ath12k/vendor.h
index 3e6cc6c..d24e119 100644
--- a/drivers/net/wireless/ath/ath12k/vendor.h
+++ b/drivers/net/wireless/ath/ath12k/vendor.h
@@ -1643,12 +1643,6 @@ enum qca_vendor_wlan_telemetry_tx_ingress_desc_type {
 
 enum qca_vendor_wlan_telemetry_tx_ingress_enq_error {
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_SUCCESS = 1,
-	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_TCL_DESC_NA,
-	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_SW_DESC_NA,
-	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_MAX_TX_LIMIT_FAST,
-	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_ARVIF_FAST,
-	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_PDEV_FAST,
-	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_ENCAP_FAST,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_MISC,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_VIF_TYPE_MON,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_LINK,
@@ -1659,12 +1653,18 @@ enum qca_vendor_wlan_telemetry_tx_ingress_enq_error {
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_PEER,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_CRASH_FLUSH,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_NON_DATA_FRAME,
+	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_SW_DESC_NA,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_ENCAP_RAW,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_ENCAP_802_3,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_DMA_ERR,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_EXT_DESC_NA,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_HTT_MDATA_ERR,
+	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_TCL_DESC_NA,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_TCL_DESC_RETRY,
+	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_ARVIF_FAST,
+	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_PDEV_FAST,
+	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_MAX_TX_LIMIT_FAST,
+	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_INV_ENCAP_FAST,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_DROP_BRIDGE_VDEV,
 	QCA_VENDOR_ATTR_TX_INGRESS_ENQ_ARSTA_NA,
 
-- 
