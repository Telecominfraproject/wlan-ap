index e7ef482..b9a7770 100644
--- a/drivers/net/wireless/ath/ath12k/ppe.c
+++ b/drivers/net/wireless/ath/ath12k/ppe.c
@@ -170,7 +170,7 @@ int ath12k_dp_rx_bufs_replenish_ppeds(struct ath12k_base *ab, int req_entries,
 {
 	struct dp_rxdma_ring *rx_ring = &ab->dp->rx_refill_buf_ring;
 	struct hal_srng *rxdma_srng;
-	struct ath12k_buffer_address *rxdma_desc;
+	struct ath12k_buffer_addr *rxdma_desc;
 	u32 cookie;
 	dma_addr_t paddr;
 	struct ath12k_rx_desc_info *rx_desc;
@@ -203,7 +203,7 @@ int ath12k_dp_rx_bufs_replenish_ppeds(struct ath12k_base *ab, int req_entries,
 		if (!rxdma_desc)
 			break;
 
-		ath12k_hal_rx_buf_addr_info_set(&ab->hal, rxdma_desc, paddr, cookie, mgr);
+		ath12k_hal_rx_buf_addr_info_set(rxdma_desc, paddr, cookie, mgr);
 		num_remain--;
 	}
 
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index 8aba621..bf3ca4c 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -1739,7 +1739,7 @@ ath12k_wifi7_dp_rx_h_defrag_reo_reinject(struct ath12k_dp *dp,
 	u32 cookie, hal_rx_desc_sz, dest_ring_info0, queue_addr_hi;
 	int ret, len_diff;
 	struct ath12k_rx_desc_info *desc_info;
-	struct ath12k_buffer_address *info;
+	struct ath12k_buffer_addr *info;
 	enum hal_rx_buf_return_buf_manager idle_link_rbm = dp->idle_link_rbm;
 	u8 dst_ind;
 
@@ -1803,10 +1803,10 @@ ath12k_wifi7_dp_rx_h_defrag_reo_reinject(struct ath12k_dp *dp,
 
 	ATH12K_SKB_RXCB(defrag_skb)->paddr = buf_paddr;
 
-	info = (struct ath12k_buffer_address *)&msdu0->buf_addr_info;
-	ath12k_wifi7_hal_rx_buf_addr_info_set(info, buf_paddr,
-					      desc_info->cookie,
-					      HAL_RX_BUF_RBM_SW5_BM);
+	info = (struct ath12k_buffer_addr *)&msdu0->buf_addr_info;
+	ath12k_hal_rx_buf_addr_info_set(info, buf_paddr,
+				       desc_info->cookie,
+				       HAL_RX_BUF_RBM_SW5_BM);
 
 	/* Fill mpdu details into reo entrance ring */
 	srng = &hal->srng_list[dp->reo_reinject_ring.ring_id];
@@ -1823,9 +1823,8 @@ ath12k_wifi7_dp_rx_h_defrag_reo_reinject(struct ath12k_dp *dp,
 	}
 	memset(reo_ent_ring, 0, sizeof(*reo_ent_ring));
 
-	info = (struct ath12k_buffer_address *)&reo_ent_ring->buf_addr_info;
-	ath12k_wifi7_hal_rx_buf_addr_info_set(info,
-					      link_paddr, cookie, idle_link_rbm);
+	info = (struct ath12k_buffer_addr *)&reo_ent_ring->buf_addr_info;
+	ath12k_hal_rx_buf_addr_info_set(info, link_paddr, cookie, idle_link_rbm);
 
 	mpdu_info = u32_encode_bits(1, RX_MPDU_DESC_INFO0_MSDU_COUNT) |
 		    u32_encode_bits(0, RX_MPDU_DESC_INFO0_FRAG_FLAG) |
