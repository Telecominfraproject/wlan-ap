From aaec73f476ec5d2c09f78d763416ce553f524df4 Mon Sep 17 00:00:00 2001
From: Vivek Chettri <vchettri@qti.qualcomm.com>
Date: Fri, 18 Jul 2025 00:05:15 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:CP:wifi:ath12k: Check SCS direction if QoS
 attributes are present

The SCS QoS direction (Downlink or Uplink) could be different only in case
of QoS R3 SCS where the QoS attributes (e.g. service interval, burst size)
are present.

In case of QoS R2 SCS, there are no QoS attributes specified and only
Downlink QoS is supported.

Updating the QoS direction always from QoS structures even
when there is no QoS attributes present would result in errors.

Initialize the QoS direction to Downlink and update only when the QoS
attributes and direction are explicitly specified.

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 17 +++++++----------
 1 file changed, 7 insertions(+), 10 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 254a946..b5807a0 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -22606,15 +22606,14 @@ static int ath12k_process_scs_add(struct ath12k *ar,
 	struct ath12k_dp_link_peer *peer;
 	struct ath12k_dp_peer_qos *qos;
 	int ret = -EINVAL;
-	u8 qm_id, tid;
+	u8 qm_id;
 	u16 qos_id;

 	qos_attr = &qm_req->qos_attr;
-	tid = qos_attr->tid;
 	qm_id = qm_req->qm_id;

 	if (!qm_req->is_qos_present) {
-		qos_id = ath12k_qos_get_legacy_id(ar->ab, tid);
+		qos_id = ath12k_qos_get_legacy_id(ar->ab, qm_req->priority);
 	} else {
 		ath12k_qos_set_default(&params);
 		ath12k_copy_qos_params(&params, qos_attr);
@@ -22703,11 +22702,14 @@ int ath12k_process_scs_desc(struct ath12k *ar, u16 peer_id,
 			    u8 *addr)
 {
 	u8 request_type = qm_req_desc->request_type;
-	u8 dir = qm_req_desc->qos_attr.direction;
+	u8 dir = IEEE80211_QM_DIRECTION_DOWNLINK;
 	int status = IEEE80211_QM_REQ_SUCCESS;
 	enum qos_profile_dir qos_dir;
 	int ret;

+	if (qm_req_desc->is_qos_present)
+		dir = qm_req_desc->qos_attr.direction;
+
 	if (dir == IEEE80211_QM_DIRECTION_UPLINK) {
 		qos_dir = QOS_PROFILE_UL;
 	} else if (dir == IEEE80211_QM_DIRECTION_DOWNLINK) {
@@ -22719,11 +22721,6 @@ int ath12k_process_scs_desc(struct ath12k *ar, u16 peer_id,

 	switch (request_type) {
 	case IEEE80211_QM_ADD_REQ:
-		if (!qm_req_desc->is_qos_present &&
-		    dir == IEEE80211_QM_DIRECTION_UPLINK) {
-			ath12k_err(ar->ab, "Legacy SCS UL not supported");
-			return IEEE80211_QM_REQ_DECLINED;
-		}
 		ret = ath12k_process_scs_add(ar, peer_id, qos_dir,
 					     qm_req_desc, addr);

--
2.34.1

