 void ath12k_dp_mon_rx_stats_enable(struct ath12k_pdev_dp *dp_pdev,
 				   enum dp_mon_stats_mode mode);
 void ath12k_dp_mon_rx_stats_disable(struct ath12k_pdev_dp *dp_pdev,
