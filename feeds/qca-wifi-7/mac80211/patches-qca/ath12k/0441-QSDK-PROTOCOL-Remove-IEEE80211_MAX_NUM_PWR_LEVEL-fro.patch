From 39273e2b93ee37a7197119a1f6f9ae211258127e Mon Sep 17 00:00:00 2001
From: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
Date: Sun, 20 Jul 2025 22:29:35 +0530
Subject: [PATCH] QSDK:PROTOCOL: Remove IEEE80211_MAX_NUM_PWR_LEVEL from QSDK

Remove the macro IEEE80211_MAX_NUM_PWR_LEVEL from QSDK.

Replace the occurences in ath11k and ath12k with ATH11K_NUM_PWR_LEVELS
and ATH12K_NUM_PWR_LEVELS respectively.

Tag: REGULATORY

Signed-off-by: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath11k/core.h |  6 +++---
 drivers/net/wireless/ath/ath12k/core.h |  9 ++++++---
 drivers/net/wireless/ath/ath12k/mac.c  | 18 +++++++++---------
 include/linux/ieee80211.h              |  2 --
 4 files changed, 18 insertions(+), 17 deletions(-)

--- a/drivers/net/wireless/ath/ath11k/core.h
+++ b/drivers/net/wireless/ath/ath11k/core.h
@@ -464,10 +464,10 @@ struct ath11k_reg_tpc_power_info {
 	u8 eirp_power;
 	enum wmi_reg_6ghz_ap_type power_type_6g;
 	u8 num_pwr_levels;
-	u8 reg_max[IEEE80211_MAX_NUM_PWR_LEVEL];
+	u8 reg_max[ATH11K_NUM_PWR_LEVELS];
 	u8 ap_constraint_power;
-	s8 tpe[IEEE80211_MAX_NUM_PWR_LEVEL];
-	struct chan_power_info chan_power_info[IEEE80211_MAX_NUM_PWR_LEVEL];
+	s8 tpe[ATH11K_NUM_PWR_LEVELS];
+	struct chan_power_info chan_power_info[ATH11K_NUM_PWR_LEVELS];
 };
 
 struct ath11k_vif {
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -457,6 +457,9 @@ struct ath12k_prb_resp_tmpl_ml_info {
 	u32 cu_vdev_map_cat2_hi;
 };
 
+/* ath12k only deals with 320 MHz, so 16 subchannels */
+#define ATH12K_NUM_PWR_LEVELS  16
+
 /**
  * struct chan_power_info - TPE containing power info per channel chunk
  * @chan_cfreq: channel center freq (MHz)
@@ -503,14 +506,14 @@ struct ath12k_reg_tpc_power_info {
 	u8 num_pwr_levels;
 	u8 num_psd_pwr_levels;
 	u8 num_eirp_pwr_levels;
-	u8 reg_max[IEEE80211_MAX_NUM_PWR_LEVEL];
+	u8 reg_max[ATH12K_NUM_PWR_LEVELS];
 	u8 ap_constraint_power;
 	s8 tpe_psd[IEEE80211_TPE_PSD_ENTRIES_320MHZ];
 	s8 tpe_eirp[IEEE80211_TPE_EIRP_ENTRIES_320MHZ];
 	u8 num_tpe_psd;
 	u8 num_tpe_eirp;
-	struct chan_power_info chan_power_info[IEEE80211_MAX_NUM_PWR_LEVEL];
-	struct chan_power_info chan_psd_power_info[IEEE80211_MAX_NUM_PWR_LEVEL];
+	struct chan_power_info chan_power_info[ATH12K_NUM_PWR_LEVELS];
+	struct chan_power_info chan_psd_power_info[ATH12K_NUM_PWR_LEVELS];
 	struct chan_power_info chan_eirp_power_info[ATH12K_MAX_EIRP_VALS];
 };
 
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -8937,7 +8937,7 @@ void ath12k_mac_fill_reg_tpc_info(struct
         struct ieee80211_channel *chan, *temp_chan;
         u8 pwr_lvl_idx, num_pwr_levels, pwr_reduction;
         bool is_psd_power = false, is_tpe_present = false;
-        s8 max_tx_power[IEEE80211_MAX_NUM_PWR_LEVEL],
+        s8 max_tx_power[ATH12K_NUM_PWR_LEVELS],
                 psd_power, tx_power = 0, eirp_power = 0;
         u16 oper_freq = 0, start_freq = 0, center_freq = 0;
 	u8 reg_6g_power_mode;
@@ -22162,7 +22162,7 @@ ath12k_mac_map_psd_to_subchans(u32 *cfre
 		}
 
 		for (j = start_idx;
-		     num_20mhz_channels > 0 && j < IEEE80211_MAX_NUM_PWR_LEVEL;
+		     num_20mhz_channels > 0 && j < ATH12K_NUM_PWR_LEVELS;
 		     j++, num_20mhz_channels--)
 			tpc_oobe_psd[j] = oobe_psd[i - 1];
 
@@ -22188,7 +22188,7 @@ ath12k_mac_finalize_psd_table(struct ath
 			      u16 *sub_chans, s8 *tpc_oobe_psd,
 			      struct ieee80211_chanctx_conf *ctx)
 {
-	s16 reg_psd[IEEE80211_MAX_NUM_PWR_LEVEL];
+	s16 reg_psd[ATH12K_NUM_PWR_LEVELS];
 	u16 start_freq = sub_chans[0];
 	s8 txpower;
 	int i;
@@ -22232,10 +22232,10 @@ ath12k_mac_fill_reg_tpc_info_with_psd_fo
 {
 	struct ath12k_reg_tpc_power_info *reg_tpc_info = &arvif->reg_tpc_info;
 	u16 max_bw = ath12k_mac_get_chan_width(ctx->def.width);
-	u16 sub_chans[IEEE80211_MAX_NUM_PWR_LEVEL];
+	u16 sub_chans[ATH12K_NUM_PWR_LEVELS];
 	u16 pri_freq = ctx->def.chan->center_freq;
 	s16 oobe_psd[ATH12K_MAX_EIRP_VALS];
-	s8 tpc_oobe_psd[IEEE80211_MAX_NUM_PWR_LEVEL];
+	s8 tpc_oobe_psd[ATH12K_NUM_PWR_LEVELS];
 	u32 cfreqs[ATH12K_MAX_EIRP_VALS];
 	u8 num_oobe_psd;
 	u32 start_freq;
@@ -22389,7 +22389,7 @@ static void ath12k_mac_init_root_tpe(str
 		*tpe = reg_tpc_info->tpe_psd;
 		if (!reg_tpc_info->num_tpe_psd)
 			memset(*tpe, ATH12K_MAX_TX_POWER,
-			       IEEE80211_MAX_NUM_PWR_LEVEL * sizeof(s8));
+			       ATH12K_NUM_PWR_LEVELS * sizeof(s8));
 	} else {
 		*tpe = reg_tpc_info->tpe_eirp;
 		if (!reg_tpc_info->num_tpe_eirp)
@@ -22415,7 +22415,7 @@ ath12k_mac_fill_reg_tpc_info_with_psd_fo
 {
 	struct ath12k_reg_tpc_power_info *reg_tpc_info = &arvif->reg_tpc_info;
 	u16 max_bw = ath12k_mac_get_chan_width(ctx->def.width);
-	u16 sub_chans[IEEE80211_MAX_NUM_PWR_LEVEL];
+	u16 sub_chans[ATH12K_NUM_PWR_LEVELS];
 	s8 *tpe_psd;
 	u32 start_freq;
 	u8 n_subchans;
@@ -22528,7 +22528,7 @@ ath12k_mac_fill_reg_tpc_info_with_eirp_f
 	u32 cfreqs[ATH12K_MAX_EIRP_VALS];
 	static const u16 bw[] = {ATH12K_CHWIDTH_20, ATH12K_CHWIDTH_40, ATH12K_CHWIDTH_80,
 				 ATH12K_CHWIDTH_160, ATH12K_CHWIDTH_320};
-	u16 sub_chans[IEEE80211_MAX_NUM_PWR_LEVEL];
+	u16 sub_chans[ATH12K_NUM_PWR_LEVELS];
 	u16 max_bw = ath12k_mac_get_chan_width(ctx->def.width);
 	u8 max_n_subchans = max_bw / ATH12K_CHWIDTH_20;
 	s8 *tpe_eirp, *tpe_psd;
--- a/include/linux/ieee80211.h
+++ b/include/linux/ieee80211.h
@@ -2910,8 +2910,6 @@ enum ieee80211_tx_power_category_6ghz {
  */
 #define IEEE80211_TPE_MAX_IE_COUNT      8
 
-#define IEEE80211_MAX_NUM_PWR_LEVEL    16
-
 #define IEEE80211_TPE_MAX_POWER_COUNT   8
 /*
  * For IEEE80211_TPE_LOCAL_EIRP / IEEE80211_TPE_REG_CLIENT_EIRP,
