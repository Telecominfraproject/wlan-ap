From 709646cd259c35e914af41c3d3b42a636a3a1230 Mon Sep 17 00:00:00 2001
From: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
Date: Thu, 10 Apr 2025 12:18:18 -0700
Subject: [PATCH 5/8] UPSTREAM:CP:wifi:ath12k: add support for ErP commands

Add new function ath12k_erp_enter() to start entry into ErP
mode in MLO mode. Set packet trigger for automatic exit if
provided by the userspace along with a valid link.

Set functions for driver ops erp_enter and erp_exit.

Patch-dependency: 0288-02-UPSTREAM-CP-wifi-mac80211-ErP-generic-netlink-support.patch
Patch-dependency: 0425-04-UPSTREAM-CP-wifi-ath12k-limit-current-PCIe-changes-t.patch 

Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/erp.c      | 88 +++++++++++++++++++++-
 drivers/net/wireless/ath/ath12k/erp.h      |  3 +
 drivers/net/wireless/ath/ath12k/mac.c      | 17 +++++
 drivers/net/wireless/ath/ath12k/mac.h      |  2 +
 drivers/net/wireless/ath/ath12k/wifi7/hw.c |  1 +
 5 files changed, 110 insertions(+), 1 deletion(-)

--- a/drivers/net/wireless/ath/ath12k/erp.c
+++ b/drivers/net/wireless/ath/ath12k/erp.c
@@ -555,11 +555,16 @@ static void ath12k_vendor_send_erp_trigg
 	wiphy_unlock(wiphy);
 }
 
-static int ath12k_erp_exit(struct wiphy *wiphy, bool send_event)
+int ath12k_erp_exit(struct wiphy *wiphy, bool send_event)
 {
 	struct ath12k_erp_active_ar *active_ar;
 	int ret;
 
+	if (!erp_sm.initialized) {
+		ath12k_err(NULL, "ErP is not initialized\n");
+		return -EOPNOTSUPP;
+	}
+
 	if (!send_event) {
 		/* When exit is triggered by userspace, no need to send event
 		 * back. Wiphy lock must already be acquired in this case. */
@@ -601,6 +606,9 @@ static int ath12k_erp_exit(struct wiphy
 
 		if (send_event)
 			ath12k_vendor_send_erp_trigger(wiphy);
+	} else {
+		if (send_event)
+			cfg80211_erp_trigger_exit(wiphy);
 	}
 
 	return 0;
@@ -659,6 +667,77 @@ static const struct file_operations ath1
 	.read = ath12k_read_erp_rescan_pcie,
 };
 
+int ath12k_erp_enter(struct ieee80211_hw *hw, struct ieee80211_vif *vif, int link_id,
+		     struct cfg80211_erp_params *params)
+{
+	struct ath12k_vif *ahvif;
+	struct ath12k_link_vif *arvif;
+	struct ath12k *ar = NULL;
+
+	lockdep_assert_wiphy(hw->wiphy);
+
+	if (!ath12k_mlo_capable) {
+		ath12k_err(NULL, "command not supported in non-MLO mode\n");
+		return -EOPNOTSUPP;
+	}
+
+	if (!erp_sm.initialized) {
+		ath12k_err(NULL, "Erp is not initialized\n");
+		return -EOPNOTSUPP;
+	}
+
+	if (vif && params->trigger) {
+		if (link_id < 0) {
+			ath12k_err(NULL, "invalid link id for Erp enter operation\n");
+			return -ENOLINK;
+		}
+
+		ahvif = ath12k_vif_to_ahvif(vif);
+		arvif = ath12k_get_arvif_from_link_id(ahvif, link_id);
+		if (!arvif || !arvif->is_created || !arvif->ar) {
+			ath12k_info(NULL, "cannot set ErP trigger for the specified link\n");
+			return -ENOLINK;
+		}
+
+		ar = arvif->ar;
+	}
+
+	mutex_lock(&erp_sm.lock);
+
+	if (erp_sm.state != ATH12K_ERP_OFF) {
+		ath12k_err(NULL, "driver is already in ErP mode\n");
+		goto out;
+	}
+
+	if (erp_pcie_config.enter_cnt) {
+		ath12k_err(NULL,
+			   "PCIe configuration for previous entry has not completed yet\n");
+		goto out;
+	}
+
+	if (erp_pcie_config.exit_cnt) {
+		ath12k_err(NULL,
+			   "PCIe configuration for previous exit has not completed yet\n");
+		goto out;
+	}
+
+	if (ar && params->trigger) {
+		if (ath12k_erp_set_pkt_filter(ar, params->trigger,
+					      ATH12K_WMI_PKTROUTE_ADD))
+			return -EINVAL;
+
+		erp_sm.active_ar.ar = ar;
+	}
+
+	erp_sm.state = ATH12K_ERP_ENTER_COMPLETE;
+	mutex_unlock(&erp_sm.lock);
+	return 0;
+
+out:
+	mutex_unlock(&erp_sm.lock);
+	return -EINVAL;
+}
+
 int ath12k_vendor_parse_rm_erp(struct wiphy *wiphy, struct wireless_dev *wdev,
 			       struct nlattr *attrs)
 {
--- a/drivers/net/wireless/ath/ath12k/erp.h
+++ b/drivers/net/wireless/ath/ath12k/erp.h
@@ -12,6 +12,8 @@ void ath12k_erp_deinit(void);
 bool ath12k_erp_in_progress(void);
 void ath12k_erp_handle_trigger(struct work_struct *work);
 void ath12k_erp_handle_ssr(struct ath12k *ar);
-
+int ath12k_erp_enter(struct ieee80211_hw *hw, struct ieee80211_vif *vif, int link_id,
+		     struct cfg80211_erp_params *params);
+int ath12k_erp_exit(struct wiphy *wiphy, bool send_event);
 #endif /* ATH12K_ERP_H */
 
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -19743,6 +19743,22 @@ void ath12k_mac_op_set_rekey_data(struct
 }
 EXPORT_SYMBOL(ath12k_mac_op_set_rekey_data);
 
+int ath12k_mac_op_erp(struct ieee80211_hw *hw, struct ieee80211_vif *vif,
+		      int link_id, struct cfg80211_erp_params *params)
+{
+	lockdep_assert_wiphy(hw->wiphy);
+
+	switch (params->cmd) {
+		case CFG80211_ERP_CMD_ENTER:
+			return ath12k_erp_enter(hw, vif, link_id, params);
+		case CFG80211_ERP_CMD_EXIT:
+			return ath12k_erp_exit(hw->wiphy, false);
+		default:
+			return -EINVAL;
+	}
+}
+EXPORT_SYMBOL(ath12k_mac_op_erp);
+
 /**
  * ath12k_disable_chans_outside_limit - disable channels outside the freq limits
  * @ch_lst: list of channels to check
@@ -20955,6 +20971,9 @@ static int ath12k_mac_hw_register(struct
 		goto err_cleanup_if_combs;
 	}
 
+	if (ab->ag->mlo_capable)
+		wiphy_ext_feature_set(hw->wiphy, NL80211_EXT_FEATURE_ERP);
+
 	ath12k_vendor_register(ah);
 
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
--- a/drivers/net/wireless/ath/ath12k/mac.h
+++ b/drivers/net/wireless/ath/ath12k/mac.h
@@ -350,6 +350,8 @@ int ath12k_mac_op_link_reconfig_remove(s
 				       struct ieee80211_vif *vif,
 				       const struct cfg80211_link_reconfig_removal_params *params);
 bool ath12k_mac_op_removed_link_is_primary(struct ieee80211_sta *sta, u16 removed_links);
+int ath12k_mac_op_erp(struct ieee80211_hw *hw, struct ieee80211_vif *vif,
+		      int link_id, struct cfg80211_erp_params *params);
 int ath12k_mac_mgmt_tx(struct ath12k *ar, struct sk_buff *skb,
 		       bool is_prb_rsp);
 void ath12k_mac_add_p2p_noa_ie(struct ath12k *ar,
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -1689,6 +1689,7 @@ static const struct ieee80211_ops ath12k
 	.can_neg_ttlm			= ath12k_mac_op_can_neg_ttlm,
 	.apply_neg_ttlm_per_client	= ath12k_mac_op_apply_neg_ttlm_per_client,
 	.set_radar_background           = ath12k_mac_op_set_radar_background,
+	.erp                            = ath12k_mac_op_erp,
 };
 
 int ath12k_wifi7_hw_init(struct ath12k_base *ab)
