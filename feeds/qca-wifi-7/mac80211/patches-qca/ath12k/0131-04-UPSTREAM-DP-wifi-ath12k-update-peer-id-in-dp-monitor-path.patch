 ath12k_dp_mon_rx_parse_mon_status+0x9c/0xa8 [ath12k]
 ath12k_dp_mon_srng_process+0x180/0x528 [ath12k]
 ath12k_dp_mon_process_ring+0x98/0x16d4 [ath12k]
 ath12k_dp_service_srng+0x1f0/0x2b8 [ath12k]
