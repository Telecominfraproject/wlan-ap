+			return -ENOMEM;
+		}
+		nla_nest_end(vendor_event, nl_per_link_entry);
+	}
+
+	nla_nest_end(vendor_event, nl_mld_link_entry);
+
+	ath12k_dbg(NULL, ATH12K_DBG_RM, "Notify vendor app on disassoc\n");
+	return 0;
+}
