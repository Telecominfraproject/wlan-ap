+	len += print_array_to_buf(buf, len, "dl_ofdma_nbinwb_selected_standalone",
+				  htt_stats_buf->dl_ofdma_nbinwb_selected_standalone,
+				  ATH12K_HTT_NUM_AC_WMM, "\n");
+	len += print_array_to_buf(buf, len, "running_only_dl_scheduler_cnt",
