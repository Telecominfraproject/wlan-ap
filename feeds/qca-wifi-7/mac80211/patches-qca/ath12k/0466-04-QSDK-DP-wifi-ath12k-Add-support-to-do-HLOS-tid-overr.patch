From a227fbbacf004bf7665d9440593e61a050fbdc04 Mon Sep 17 00:00:00 2001
From: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
Date: Thu, 24 Jul 2025 17:51:15 -0700
Subject: [PATCH 2/2] QSDK:DP:wifi:ath12k: Add support to do HLOS tid override
 for MSCS session

Add support to do HLOS tid override for tid from skb->priority for
DL accelerated packets, so that HW does overwrite them with the default
tid using mapping tables.
Set this flag per dp_vif when an active MSCS session is created which
happens only when a STA supporting MSCS sends an MSCS request to create
a session.

Tag: MSCS

Signed-off-by: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h        |  1 +
 drivers/net/wireless/ath/ath12k/mac.c         | 13 +++++++++----
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 12 ++++++++++++
 3 files changed, 22 insertions(+), 4 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -650,6 +650,7 @@ struct ath12k_dp_vif {
 	int ppe_vp_num;
 	int ppe_core_mask;
 	u8 ppe_vp_type;
+	bool mscs_hlos_tid_override;
 };
 
 struct ath12k_vif {
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -19581,13 +19581,14 @@ ath12k_mac_set_mscs(struct ieee80211_hw
 		    struct cfg80211_qm_req_data *qm_req,
 		    struct cfg80211_qm_resp_data *qm_resp)
 {
-	struct ath12k *ar;
-	struct ath12k_dp *dp;
-	struct ath12k_dp_link_peer *link_peer;
-	struct ath12k_dp_peer *peer;
 	struct cfg80211_qm_req_desc_data *qm_req_desc = &qm_req->qm_req_desc[0];
 	struct cfg80211_qm_resp_desc_data *qm_resp_desc = &qm_resp->qm_resp_desc[0];
+	struct ath12k_dp_link_peer *link_peer;
 	u8 req_type = qm_req_desc->request_type;
+	struct ath12k_dp_peer *peer;
+	struct ath12k_dp *dp;
+	struct ath12k_dp_vif *dp_vif;
+	struct ath12k *ar;
 
 	ar = arsta->arvif->ar;
 	dp = ath12k_ab_to_dp(ar->ab);
@@ -19600,11 +19601,18 @@ ath12k_mac_set_mscs(struct ieee80211_hw
 		goto send_fail_resp;
 
 	peer = link_peer->dp_peer;
+
+	if (!peer)
+		goto send_fail_resp;
+
+	dp_vif = &ahsta->ahvif->dp_vif;
+
 	switch (req_type) {
 	case IEEE80211_QM_ADD_REQ:
 		if (peer->mscs_session_exists)
 			goto send_fail_resp;
 		peer->mscs_session_exists = true;
+		dp_vif->mscs_hlos_tid_override = true;
 		fallthrough;
 	case IEEE80211_QM_CHANGE_REQ:
 		peer->mscs_ctxt.user_priority_bitmap =
@@ -19625,6 +19633,7 @@ ath12k_mac_set_mscs(struct ieee80211_hw
 		break;
 	case IEEE80211_QM_REMOVE_REQ:
 		peer->mscs_session_exists = false;
+		dp_vif->mscs_hlos_tid_override = false;
 		ath12k_dbg(ar->ab, ATH12K_DBG_QOS,
 			   "MSCS: REMOVE peer %pM, mscs_session_exists %u",
 			   peer->addr, peer->mscs_session_exists);
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -903,6 +903,18 @@ ath12k_wifi7_dp_tx(struct ath12k_pdev_dp
 			goto fail_remove_tx_buf;
 		}
 
+		/**
+		 * Check if the vif supports mscs hlos tid override, which
+		 * will be true if there is an active MSCS session
+		 * In this case, check for skb->priority which would have
+		 * the correct tid value and program it to the TCL metadata
+		 * For accelerated packets with MSCS, skb->mark will not be
+		 * set
+		 */
+		if (unlikely(skb->priority &&
+			     dp_vif->mscs_hlos_tid_override))
+			ath12k_wifi_qos_hlos_tid(&tcl_desc, skb->priority);
+
 		if (unlikely(skb->mark & SDWF_VALID_MASK)) {
 			ath12k_dp_qos_update(dp, dp_pdev, skb->mark, &tcl_desc,
 					     0, NULL);
