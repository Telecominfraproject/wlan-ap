From 2b05681ae7984649941e83a6d67d4ecbc2c347ba Mon Sep 17 00:00:00 2001
From: Vivek Chettri <vchettri@qti.qualcomm.com>
Date: Thu, 11 Sep 2025 13:16:54 +0530
Subject: [PATCH] QSDK: CP: wifi: ath12k: Update TID for UL service class

For UL only service class, TID value is not updated in the NL
message sent to the user to display the service class.
Also the service class ID provided in the display command is not used
directly to fetch the service class attributes, resulting in printing
the wrong service class.

Update the TID also in the NL message for a UL only service classes.
Use the service class ID provided by the user to fetch the service class
attributes and print them.

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/vendor.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/vendor.c b/drivers/net/wireless/ath/ath12k/vendor.c
index 669267c..50d0793 100644
--- a/drivers/net/wireless/ath/ath12k/vendor.c
+++ b/drivers/net/wireless/ath/ath12k/vendor.c
@@ -1,6 +1,6 @@
 // SPDX-License-Identifier: BSD-3-Clause-Clear
 /*
- * Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries. 
+ * Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
  */
 #include <linux/mutex.h>
 #include <linux/pci.h>
@@ -5249,7 +5249,7 @@ static int ath12k_vendor_view_sdwf_config(struct wiphy *wiphy,
 		return -ENOBUFS;
 
 	tailroom = skb_tailroom(msg);
-	for (i = (svc_id) ? (svc_id - 1) : (*storage);
+	for (i = (svc_id) ? (svc_id) : (*storage);
 	     i < QOS_PROFILES_MAX && tailroom > nested_range;
 	     i += (svc_id) ? (QOS_PROFILES_MAX) : (1)) {
 		u16 id_dl = qos_ctx->svc_class[i].dl_qos_id;
@@ -5312,6 +5312,8 @@ static int ath12k_vendor_view_sdwf_config(struct wiphy *wiphy,
 		    nla_put_u32(msg,
 				QCA_WLAN_VENDOR_ATTR_SDWF_SVC_UL_BURST_SIZE,
 				profile->params.burst_size) ||
+		    nla_put_u32(msg, QCA_WLAN_VENDOR_ATTR_SDWF_SVC_TID,
+				profile->params.tid) ||
 		    nla_put_u8(msg,
 			       QCA_WLAN_VENDOR_ATTR_SDWF_SVC_UL_OFDMA_DISABLE,
 			       profile->params.ul_ofdma_disable) ||
-- 
