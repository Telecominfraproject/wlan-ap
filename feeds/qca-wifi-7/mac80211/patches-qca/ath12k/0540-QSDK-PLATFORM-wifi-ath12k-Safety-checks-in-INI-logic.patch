From 2d982efe8c060f2c272e18e77879f6ceb9529026 Mon Sep 17 00:00:00 2001
From: Uraj Sasan <usasan@qti.qualcomm.com>
Date: Mon, 15 Sep 2025 14:43:01 +0530
Subject: [PATCH] QSDK:PLATFORM:wifi: ath12k: Safety checks in INI logic

Add safety check in INI parsing logic to fix NULL pointer dereference issues

Signed-off-by: Uraj Sasan <usasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ini.c | 31 ++++++++++++++++-----------
 1 file changed, 18 insertions(+), 13 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/ini.c b/drivers/net/wireless/ath/ath12k/ini.c
index 6820998..e6a7c6a 100644
--- a/drivers/net/wireless/ath/ath12k/ini.c
+++ b/drivers/net/wireless/ath/ath12k/ini.c
@@ -222,6 +222,10 @@ ath12k_cfg_bool_item_handler(struct ath12k_cfg_value_store *store,
 	int ret;
 	bool *store_value = ath12k_cfg_value_ptr(store, meta);
 
+	if (!str_value || strlen(str_value) == 0) {
+		ath12k_err(NULL, "Invalid boolean value for %s", meta->name);
+		return;
+	}
 	ret = kstrtobool(str_value, store_value);
 	if (ret) {
 		ath12k_err(NULL,
@@ -476,11 +480,13 @@ ath12k_cfg_store_alloc(const char *path,
  */
 static void ath12k_cfg_store_free(struct ath12k_cfg_value_store *store)
 {
-	spin_lock_bh(&ath12k_cfg_stores_lock);
-	list_del_init(&store->node);
-	spin_unlock_bh(&ath12k_cfg_stores_lock);
-	kfree(store->path);
-	vfree(store);
+	if (store) {
+		spin_lock_bh(&ath12k_cfg_stores_lock);
+		list_del_init(&store->node);
+		spin_unlock_bh(&ath12k_cfg_stores_lock);
+		kfree(store->path);
+		vfree(store);
+	}
 }
 
 /**
@@ -567,7 +573,7 @@ ath12k_cfg_store_get(const char *path, struct ath12k_cfg_value_store **out_store
  */
 static void ath12k_cfg_store_put(struct ath12k_cfg_value_store *store)
 {
-	if (atomic_dec_and_test(&store->users))
+	if (store && atomic_dec_and_test(&store->users))
 		ath12k_cfg_store_free(store);
 }
 
@@ -585,15 +591,14 @@ static void ath12k_cfg_store_set(struct ath12k_cfg_ctx *cfg_ctx)
 /**
  * ath12k_cfg_get_ctx - get the ath12k_cfg context from the base
  * @ab: ath12k_base reference
- * Return: reference to the cfg context on success , null on failure
+ * Return: reference to the cfg context on success
  */
 static struct ath12k_cfg_ctx *ath12k_cfg_get_ctx(struct ath12k_base *ab)
 {
 	struct ath12k_cfg_ctx *cfg_ctx;
 
-	if (!ab->cfg_ctx)
-		return NULL;
 	cfg_ctx = ab->cfg_ctx;
+	WARN_ON(!cfg_ctx);
 	return cfg_ctx;
 }
 
@@ -1003,9 +1008,9 @@ int ath12k_cfg_get_ini_file_name(u32 target_type, struct ath12k_ini_file *ini)
 int ath12k_cfg_init(struct ath12k_base *ab)
 {
 	struct ath12k_ini_file ini;
-	char ini_buf[ATH12K_CFG_FILE_NAME_MAX];
-	char global_file[ATH12K_CFG_FILE_NAME_MAX];
-	char global_file_i[ATH12K_CFG_FILE_NAME_MAX];
+	char ini_buf[ATH12K_CFG_FILE_NAME_MAX] = {0};
+	char global_file[ATH12K_CFG_FILE_NAME_MAX] = {0};
+	char global_file_i[ATH12K_CFG_FILE_NAME_MAX] = {0};
 	int ret;
 
 	ret = ath12k_cfg_dispatcher_init(ab);
@@ -1060,7 +1065,7 @@ void ath12k_cfg_parse_pdev_section(struct ath12k_base *ab)
 {
 	struct ath12k_pdev *pdev;
 	struct ath12k_ini_file ini;
-	char ini_buf[100];
+	char ini_buf[100] = {0};
 	int ret;
 	u32 i;
 
-- 
2.34.1

