From 2f21c27c6be0c461467cdc611c04e40eac2824d0 Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Sat, 12 Jul 2025 16:55:36 +0530
Subject: [PATCH 2/4] Upstream: DP: wifi: ath12k: Add helper to safely retrieve
 skb fragment size by index

Introduce a new helper function ath12k_dp_mon_get_frag_size_by_idx() to
safely retrieve the size of a fragment from an skb by index. This function
validates the index against MAX_SKB_FRAGS and logs a warning if the index
is out of bounds, preventing potential out-of-bounds access.

Update ath12k_wifi7_dp_mon_skb_remove_frag() to use this helper instead of
directly accessing skb_shinfo()->frags[]. This helper will be reused in
upcoming patches to safe fragment size access across the monitor path.

Patch-dependency:
0495-01-Upstream-DP-wifi-ath12k-Force-decap-type-to-RAW-for-.patch

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_mon.c        | 14 +++++++++++++-
 drivers/net/wireless/ath/ath12k/dp_mon.h        |  2 ++
 drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c |  9 +++++----
 3 files changed, 20 insertions(+), 5 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.c b/drivers/net/wireless/ath/ath12k/dp_mon.c
index d939414..0298fcd 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.c
@@ -2203,7 +2203,7 @@ void ath12k_dp_mon_skb_remove_frag(struct ath12k_dp *dp, struct sk_buff *skb,
 	if (unlikely(!page))
 		return;
 
-	frag_len = skb_frag_size(&skb_shinfo(skb)->frags[idx]);
+	frag_len = ath12k_wifi7_dp_mon_get_frag_size_by_idx(dp, skb, idx);
 	put_page(page);
 	skb->len -= frag_len;
 	skb->data_len -= frag_len;
@@ -2288,3 +2288,15 @@ ath12k_dp_mon_cnt_skb_and_frags(struct sk_buff *skb, u32 *skb_count, u32 *frag_c
 	*frag_count += total_frags;
 }
 EXPORT_SYMBOL(ath12k_dp_mon_cnt_skb_and_frags);
+
+u32 ath12k_wifi7_dp_mon_get_frag_size_by_idx(struct ath12k_dp *dp,
+					     struct sk_buff *skb, u8 idx)
+{
+	u32 size = 0;
+
+	if (likely(idx < MAX_SKB_FRAGS))
+		size = skb_frag_size(&skb_shinfo(skb)->frags[idx]);
+
+	return size;
+}
+EXPORT_SYMBOL(ath12k_wifi7_dp_mon_get_frag_size_by_idx);
diff --git a/drivers/net/wireless/ath/ath12k/dp_mon.h b/drivers/net/wireless/ath/ath12k/dp_mon.h
index de0b8bd..00b6a69 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon.h
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.h
@@ -410,6 +410,8 @@ void
 ath12k_dp_mon_cnt_skb_and_frags(struct sk_buff *skb, u32 *skb_count, u32 *frag_count);
 void ath12k_dp_mon_pktlog_config_filter(struct ath12k_pdev_dp *dp_pdev,
 				enum ath12k_pktlog_mode mode, bool enable);
+u32 ath12k_wifi7_dp_mon_get_frag_size_by_idx(struct ath12k_dp *dp, struct sk_buff *skb,
+					     u8 idx);
 static inline
 int ath12k_dp_mon_rx_alloc(struct ath12k_dp *dp)
 {
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
index 654e1ce..25ac3ed 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -516,7 +516,6 @@ ath12k_wifi7_dp_mon_rx_parse_ppdu_status(struct ath12k_pdev_dp *dp_pdev,
 	struct sk_buff *mpdu;
 	struct ath12k_dp_mon_mpdu_meta *mpdu_meta;
 	struct ath12k_pdev_mon_dp_stats *mon_stats = &dp_pdev->dp_mon_pdev->mon_stats;
-	const skb_frag_t *frag;
 	enum hal_rx_mon_status hal_status;
 	u32 buf_size = ATH12K_DP_MON_RX_BUF_SIZE, num_skb = 0, pkt_tlv = 0;
 	u8 fcs_len_left = FCS_LEN, last_frag_idx, last_frag_size;
@@ -546,9 +545,11 @@ ath12k_wifi7_dp_mon_rx_parse_ppdu_status(struct ath12k_pdev_dp *dp_pdev,
 		if (mpdu_meta->decap_type == DP_RX_DECAP_TYPE_RAW) {
 			last_frag_idx = skb_shinfo(mpdu)->nr_frags - 1;
 			if (skb_shinfo(mpdu)->nr_frags >= 2) {
-				frag = &skb_shinfo(mpdu)->frags[last_frag_idx];
-				last_frag_size = skb_frag_size(frag);
-				if (last_frag_size < FCS_LEN) {
+				last_frag_size =
+				ath12k_wifi7_dp_mon_get_frag_size_by_idx(dp_pdev->dp,
+									 mpdu,
+									 last_frag_idx);
+				if (last_frag_size > 0 && last_frag_size < FCS_LEN) {
 					ath12k_dp_mon_skb_remove_frag(dp_pdev->dp, mpdu,
 								      last_frag_idx,
 								      buf_size);
-- 
