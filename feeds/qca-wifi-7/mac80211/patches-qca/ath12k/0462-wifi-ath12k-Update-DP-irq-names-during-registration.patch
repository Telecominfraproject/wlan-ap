From 617aca45f31553a2d4f037f0f134b29fd87ead51 Mon Sep 17 00:00:00 2001
From: Narendhar Reddy <nare@qti.qualcomm.com>
Date: Fri, 15 Dec 2023 12:57:47 +0530
Subject: [PATCH] UPSTREAM:DP wifi: ath12k: Update DP IRQ names for
devices with hybrid bus.

In ath12k driver IRQ names for PCI is in the "pci%u_xxxx_%d" where
%u is based on the bus_id for PCI. For QCN6432 %u is based on 
userpd_id.
In case of devices with both QCN9274 and  QCN6432,there is 
a conflict as both the bus_id and userpd_id
is 1.Changed the IRQ name of QCN6432 from "pci%u_xxx" 
to "pcic%u_xxx".

Earlier IPQ5332 and IPQ5424 was considered to rootPD, with
new implementation these are considered to first userPDs,
hence decreament userpd_id by 1 in certain places to maintain
parity with old implementation.

Patch dependency: 0122-UPSTREAM-DP-wifi-ath12k-Handle-irq-registration-for-hybrid-bus-t.patch
Signed-off-by: Sowmiya Sree Elavalagan <ssreeela@qti.qualcomm.com>
Signed-off-by: Narendhar Reddy <nare@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/pcic.c | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/pcic.c
+++ b/drivers/net/wireless/ath/ath12k/pcic.c
@@ -81,6 +81,7 @@ static const char *irq_name[ATH12K_IRQ_N
 };
 
 char dp_irq_name[ATH12K_MAX_PCI_DOMAINS + 1][ATH12K_EXT_IRQ_DP_NUM_VECTORS][DP_IRQ_NAME_LEN] = {};
+char dp_pcic_irq_name[ATH12K_MAX_PCI_DOMAINS + 1][ATH12K_EXT_IRQ_DP_NUM_VECTORS][DP_IRQ_NAME_LEN] = {};
 char ce_irq_name[ATH12K_MAX_PCI_DOMAINS + 1][ATH12K_IRQ_NUM_MAX][DP_IRQ_NAME_LEN] = {};
 
 void ath12k_pcic_config_static_window(struct ath12k_base *ab)
@@ -395,10 +396,10 @@ int ath12k_pcic_ext_cfg_gic_msi_irq(stru
 	int j, budget, ret = 0, num_vectors = 0;
 	struct net_device *napi_ndev;
 	int ring_num = 0, ring_type = 0;
-	u8 userpd_id;
+	u8 userpd_idx;
 	u32 num_irq = 0;
 
-	userpd_id = ab_ahb->userpd_id;
+	userpd_idx = ab_ahb->userpd_id - 1;
 	base_idx = ATH12K_PCI_IRQ_CE0_OFFSET + CE_COUNT_MAX;
 	ret = ath12k_pcic_get_user_msi_assignment(ab, "DP", &num_vectors,
 						  &user_base_data, &base_vector);
@@ -467,12 +468,12 @@ int ath12k_pcic_ext_cfg_gic_msi_irq(stru
 			}
 			ath12k_hif_ppeds_register_interrupts(ab, ring_type, 0, ring_num);
 		} else {
-			scnprintf(dp_irq_name[userpd_id][i], DP_IRQ_NAME_LEN,
-				  "pci%u_wlan_dp_%u", userpd_id, i);
+			scnprintf(dp_pcic_irq_name[userpd_idx][i], DP_IRQ_NAME_LEN,
+				  "pcic%u_wlan_dp_%u", userpd_idx, i);
 			irq_set_status_flags(msi_desc->irq, IRQ_DISABLE_UNLAZY);
 			ret = devm_request_irq(&pdev->dev, msi_desc->irq,
 					       ath12k_pcic_ext_interrupt_handler, IRQF_SHARED,
-					       dp_irq_name[userpd_id][i], irq_grp);
+					       dp_pcic_irq_name[userpd_idx][i], irq_grp);
 			if (ret) {
 				ath12k_warn(ab, "failed to request irq %d: %d\n", irq_idx, ret);
 				return ret;
@@ -494,7 +495,7 @@ static int ath12k_pcic_config_gic_msi_ir
 	struct ath12k_ce_pipe *ce_pipe = &ab->ce.ce_pipe[i];
 	struct ath12k_ahb *ab_ahb = ath12k_ab_to_ahb(ab);
 	int irq_idx, ret;
-	u8 userpd_id = ab_ahb->userpd_id;
+	u8 userpd_idx = ab_ahb->userpd_id - 1;
 
 #if LINUX_VERSION_IS_GEQ(6,13,0)
 		INIT_WORK(&ce_pipe->intr_wq, ath12k_pcic_ce_workqueue);
@@ -504,12 +505,12 @@ static int ath12k_pcic_config_gic_msi_ir
 
 	irq_idx = ATH12K_PCI_IRQ_CE0_OFFSET + i;
 
-	scnprintf(ce_irq_name[userpd_id][irq_idx], DP_IRQ_NAME_LEN,
-		  "pci%u_wlan_ce_%u", userpd_id, i);
+	scnprintf(ce_irq_name[userpd_idx][irq_idx], DP_IRQ_NAME_LEN,
+		  "pci%u_wlan_ce_%u", userpd_idx, i);
 
 	ret = devm_request_irq(&pdev->dev, msi_desc->irq,
 			       ath12k_pcic_ce_interrupt_handler, IRQF_SHARED,
-			       ce_irq_name[userpd_id][irq_idx], ce_pipe);
+			       ce_irq_name[userpd_idx][irq_idx], ce_pipe);
 	if (ret) {
 		ath12k_warn(ab, "failed to request irq %d: %d\n", irq_idx, ret);
 		return ret;
@@ -670,7 +671,7 @@ int ath12k_pcic_ppeds_register_interrupt
 	u8 bus_id;
 
 	ab_ahb = ath12k_ab_to_ahb(ab);
-	bus_id = ab_ahb->userpd_id;
+	bus_id = ab_ahb->userpd_id - 1;
 	pdev = ab->pdev;
 
 	if (ab->dp->ppe.ppeds_soc_idx == -1) {
