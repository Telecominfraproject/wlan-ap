From 5f4009bf872bcb284ad1725a78af316e1a76f394 Mon Sep 17 00:00:00 2001
From: Vivek Chettri <vchettri@qti.qualcomm.com>
Date: Wed, 13 Aug 2025 21:13:50 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k: Update max supported values for QoS
 params

The granularity of the service interval, delay bound and MDSU TTL
is in 1 msec instead of the 10usec granularity that was defined
earlier.

Update the maximum value that can be configured for the service
interval, delay bound and the MSDU TTL based on the updated
granularity.

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/qos.h | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/qos.h b/drivers/net/wireless/ath/ath12k/qos.h
index e37b148..17d3838 100644
--- a/drivers/net/wireless/ath/ath12k/qos.h
+++ b/drivers/net/wireless/ath/ath12k/qos.h
@@ -21,10 +21,10 @@
 #define QOS_MAX_MAX_THROUGHPUT (10 * 1024 * 1024)
 
 /* Service interval limit 0 - 10 secs.
- * Granularity: 100 µs
+ * Granularity: 1 ms
  */
 #define QOS_MIN_SVC_INTERVAL 0
-#define QOS_MAX_SVC_INTERVAL (10 * 100 * 100)
+#define QOS_MAX_SVC_INTERVAL (10 * 1000)
 
 /* Burst size 0 - 16 MB.
  * Granularity: 1 Byte.
@@ -33,16 +33,16 @@
 #define QOS_MAX_BURST_SIZE (16 * 1024 * 1024)
 
 /* Delay bound limit 0 - 10 secs
- * Granularity: 100 µs
+ * Granularity: 1 ms
  */
 #define QOS_MIN_DELAY_BOUND 0
-#define QOS_MAX_DELAY_BOUND (10 * 100 * 100)
+#define QOS_MAX_DELAY_BOUND (10 * 1000)
 
 /* Msdu TTL limit 0 - 10 secs.
- * Granularity: 100 µs
+ * Granularity: 1 ms
  */
 #define QOS_MIN_MSDU_TTL 0
-#define QOS_MAX_MSDU_TTL (10 * 100 * 100)
+#define QOS_MAX_MSDU_TTL (10 * 1000)
 
 /* Priority limit 0 - 127.
  * Higher the numerical value, higher is the priority.
-- 
2.34.1

