From ca372b9bc34d7d2fcfde00de629b05bd03bfe149 Mon Sep 17 00:00:00 2001
From: Rajat Soni <rajson@qti.qualcomm.com>
Date: Sat, 5 Jul 2025 13:37:58 +0530
Subject: [PATCH] QSDK: CP: wifi: ath12k: Fix vdev stop delete sequence

Currently when station association is not successful then driver
is sending vdev delete wmi command to firmware and Q6 crash is seen.
This is because driver is not following the correct sequence for
vdev delete.

Issue sequence:
VDEV CREATE
VDEV START
VDEV DELETE

The correct sequence is:
VDEV CREATE
VDEV START
VDEV STOP
VDEV DELETE

In issue case vdev stop wmi command is not sent to firmware.

To resolve this issue in function ath12k_mac_op_remove_interface()
send wmi vdev stop command.

Signed-off-by: Rajat Soni <rajson@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 15 +++++++++++++++
 1 file changed, 15 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index cdd10fc..e303381 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -13791,6 +13791,7 @@ void ath12k_mac_op_remove_interface(struct ieee80211_hw *hw,
 	struct ath12k_link_vif *arvif;
 	struct ath12k *ar;
 	u8 link_id;
+	int ret;
 
 	lockdep_assert_wiphy(hw->wiphy);
 
@@ -13819,6 +13820,9 @@ void ath12k_mac_op_remove_interface(struct ieee80211_hw *hw,
 		}
 		ar = arvif->ar;
 
+		if (!ar)
+			continue;
+
 		/* Scan abortion is in progress since before this, cancel_hw_scan()
 		 * is expected to be executed. Since link is anyways going to be removed
 		 * now, just cancel the worker and send the scan aborted to user space
@@ -13842,6 +13846,17 @@ void ath12k_mac_op_remove_interface(struct ieee80211_hw *hw,
 			spin_unlock_bh(&ar->data_lock);
 		}
 
+		if (arvif->is_scan_vif && arvif->is_started) {
+			ret = ath12k_mac_vdev_stop(arvif);
+			if (ret) {
+				ath12k_warn(ar->ab, "failed to stop vdev %d: %d\n",
+					    arvif->vdev_id, ret);
+				return;
+			}
+			arvif->is_started = false;
+			arvif->is_scan_vif = false;
+		}
+
 		ath12k_mac_remove_link_interface(hw, arvif);
 		ath12k_mac_unassign_link_vif(arvif);
 	}
