From 8d7d3011b465c1bc733fc992f91559f687800b8c Mon Sep 17 00:00:00 2001
From: Aaradhana Sahu <aarasahu@qti.qualcomm.com>
Date: Fri, 4 Jul 2025 15:57:46 +0530
Subject: [PATCH] UPSTREAM:CP: wifi: ath12k: Avoid setting HTT_TCL_METADATA_VER_V2 in FTM
 mode

Currently host sends HTT_TCL_METADATA latest version(2) to the
firmware regardless of the operating mode (Mission or FTM).

Firmware expects additional software information
(like peer ID, vdev ID, and link ID) in Tx packets when
HTT_TCL_METADATA version 2 is set.
However, in FTM (Factory Test Mode) mode, no vdev is created
on the host side (this is expected). As a result, the firmware
fails to find the expected vdev during packet processing and
ends up dropping packets.

To fix this, avoid setting HTT_TCL_METADATA_VER_V2 when operating
in FTM mode.

Patch-dependency: None
Patch-work:
[PATCH ath-next] wifi: ath12k: Avoid setting HTT_TCL_METADATA_VER_V2 in FTM mode

Signed-off-by: Aaradhana Sahu <aarasahu@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_htt.c | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.c b/drivers/net/wireless/ath/ath12k/dp_htt.c
index c23e1ee..281ad79 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.c
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.c
@@ -1281,12 +1281,14 @@ int ath12k_dp_tx_htt_h2t_ver_req_msg(struct ath12k_base *ab)
 	cmd->ver_reg_info = le32_encode_bits(HTT_H2T_MSG_TYPE_VERSION_REQ,
 					     HTT_OPTION_TAG);
 
-	cmd->tcl_metadata_version = le32_encode_bits(HTT_TAG_TCL_METADATA_VERSION,
-						     HTT_OPTION_TAG) |
-				    le32_encode_bits(HTT_TCL_METADATA_VER_SZ,
-						     HTT_OPTION_LEN) |
-				    le32_encode_bits(HTT_OPTION_TCL_METADATA_VER_V2,
-						     HTT_OPTION_VALUE);
+	if (!ath12k_ftm_mode) {
+		cmd->tcl_metadata_version = le32_encode_bits(HTT_TAG_TCL_METADATA_VERSION,
+							     HTT_OPTION_TAG) |
+					    le32_encode_bits(HTT_TCL_METADATA_VER_SZ,
+							     HTT_OPTION_LEN) |
+					    le32_encode_bits(HTT_OPTION_TCL_METADATA_VER_V2,
+							     HTT_OPTION_VALUE);
+	}
 
 	ret = ath12k_htc_send(&ab->htc, dp->eid, skb);
 	if (ret) {
-- 
