From 9ae5281f9667c75a710ae311fa617fce8c56ce13 Mon Sep 17 00:00:00 2001
From: Karthikeyan Periyasamy <karthikeyan.periyasamy@oss.qualcomm.com>
Date: Wed, 10 Sep 2025 12:42:37 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: Fix flush timeout

Currently, flush timeout value inherited from the separate wiphy approach.
But in single wiphy approach, this lead to timeout occur with flush fail
warning message. This timeout has to consider all the radio participated
in the wiphy. Also only pending Tx buffer is printed in timeout of Tx
flush request. Its not sufficient root cause the problem, so added the Tx
pending before flush wait and print this information in the timeout
scenario helps to decode number of flushed buffer count for better root
cause the timeout issue.

Patch-dependency: 0443-UPSTREAM-ath12k-DP-optimize-tx_pending-by-batching-atomi.patch

Signed-off-by: Karthikeyan Periyasamy <karthikeyan.periyasamy@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h     |  1 +
 drivers/net/wireless/ath/ath12k/mac.c      | 11 +++++++++--
 drivers/net/wireless/ath/ath12k/wifi7/hw.c |  4 ++++
 3 files changed, 14 insertions(+), 2 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -19384,15 +19384,17 @@ EXPORT_SYMBOL(ath12k_mac_op_set_frag_thr
 
 static int ath12k_mac_flush(struct ath12k *ar)
 {
+	int num_tx_pending = atomic_read(&ar->dp.num_tx_pending);
 	long time_left;
 	int ret = 0;
 
 	time_left = wait_event_timeout(ar->dp.tx_empty_waitq,
 				       (atomic_read(&ar->dp.num_tx_pending) == 0),
-				       ATH12K_FLUSH_TIMEOUT);
+				       ar->ah->num_radio * ATH12K_FLUSH_TIMEOUT);
 	if (time_left == 0) {
 		ath12k_warn(ar->ab,
-			    "failed to flush transmit queue, data pkts pending %d\n",
+			    "failed to flush transmit queue, data pkts req %d pending %d\n",
+			    num_tx_pending,
 			    atomic_read(&ar->dp.num_tx_pending));
 		ret = -ETIMEDOUT;
 	}
