From 874f9cb821165c3dd78242edc0fb097c4ca57a98 Mon Sep 17 00:00:00 2001
From: Adwait Nayak <adwaitn@qti.qualcomm.com>
Date: Thu, 11 Sep 2025 17:34:03 +0530
Subject: [PATCH] QSDK:DP: wifi: ath12k: Fix pktlog header mismatch issue

This change takes care of keeping the pktlog header in
align with the header maintained in the target side parser
code.

Patch-dependency:0522-QSDK-DP-wifi-ath12k-Add-pktlog-full-tx-support.patch
Patch-work: None
Fixes: I585d4c8c2e4 (QSDK:DP: wifi: ath12k: Add pktlog full tx support)

Change-Id: I990707f38846fb6602268be960ee59c51540de30
Signed-off-by: Adwait Nayak <adwaitn@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/pktlog.c | 20 +++++++++++---------
 drivers/net/wireless/ath/ath12k/pktlog.h |  8 ++------
 2 files changed, 13 insertions(+), 15 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/pktlog.c b/drivers/net/wireless/ath/ath12k/pktlog.c
index 701762f..2246f79 100644
--- a/drivers/net/wireless/ath/ath12k/pktlog.c
+++ b/drivers/net/wireless/ath/ath12k/pktlog.c
@@ -578,15 +578,17 @@ static void ath12k_pktlog_pull_hdr(struct ath12k_pktlog_hdr_arg *arg,
 
 	hdr = (struct ath12k_pktlog_hdr *)data;
 
-	arg->flags = __le16_to_cpu(hdr->flags);
-	arg->missed_cnt = __le16_to_cpu(hdr->missed_cnt);
-	arg->log_type = __le16_to_cpu(hdr->log_type);
-	arg->payload_size = __le16_to_cpu(hdr->size);
-	arg->timestamp = __le32_to_cpu(hdr->timestamp);
-	arg->type_specific_data = __le32_to_cpu(hdr->type_specific_data);
-
-	arg->payload = (u8 *)data;
-	arg->pktlog_hdr = (u8 *)hdr;
+	hdr->flags = __le16_to_cpu(hdr->flags);
+	hdr->missed_cnt = __le16_to_cpu(hdr->missed_cnt);
+	hdr->log_type = __le16_to_cpu(hdr->log_type);
+	hdr->size = __le16_to_cpu(hdr->size);
+	hdr->timestamp = __le32_to_cpu(hdr->timestamp);
+	hdr->type_specific_data = __le32_to_cpu(hdr->type_specific_data);
+
+	arg->log_type = hdr->log_type;
+	arg->payload = hdr->payload;
+	arg->payload_size = hdr->size;
+	arg->pktlog_hdr = data;
 }
 
 static void ath12k_pktlog_write_buf(struct ath12k *ar,
diff --git a/drivers/net/wireless/ath/ath12k/pktlog.h b/drivers/net/wireless/ath/ath12k/pktlog.h
index d3d0728..ae55168 100644
--- a/drivers/net/wireless/ath/ath12k/pktlog.h
+++ b/drivers/net/wireless/ath/ath12k/pktlog.h
@@ -86,14 +86,10 @@ enum ath12k_pktlog_enum {
 };
 
 struct ath12k_pktlog_hdr_arg {
-	__le16 log_type;
+	u16 log_type;
 	u8 *payload;
-	__le16 payload_size;
+	u16 payload_size;
 	u8 *pktlog_hdr;
-	__le32 flags;
-	__le16 missed_cnt;
-	__le16 timestamp;
-	__le32 type_specific_data;
 };
 
 struct ath12k_pktlog_bufhdr {
-- 
2.34.1

