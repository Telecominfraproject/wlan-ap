From d06c7035470d2f44c4a6cc6bd1b4c263f3b75382 Mon Sep 17 00:00:00 2001
From: Nidhi Jain <nidhjain@qti.qualcomm.com>
Date: Thu, 18 Sep 2025 12:36:42 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:wifi:ath12k: Fix channel context count
for MLO scenario

During channel update, ath12k_mac_update_rx_channel checks for the
number of channel context for the particular radio(ar). Currently,
the count is returned as 3 for 3-link MLO by ath12k_mac_num_chanctxs_iter.
The iterator is checking for local chanctx instead of radio level chanctx.
Since MLD has 3 links, chanctx count is returned as 3. Due to this,
rx_channel is being set to NULL which leads to AWGN info validation
failure.

In order to fix this, ensure that the iterator is updating the channel
context count only for that particular radio. This will ensure that the
ath12k_mac_num_chanctxs(ar) is for MLO case as well. This helps in updating
of rx_channel properly for that particular radio(ar). When next AWGN event
is triggered, it passes as now, rx_channel is not NULL.

Patch-dependency:
      0230-0001-ath12k-Add-support-to-handle-AWGN-interference-for-6.patch
Feature: AWGN

Signed-off-by: Nidhi Jain <nidhjain@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 15 ++++++++++-----
 drivers/net/wireless/ath/ath12k/mac.h |  5 +++++
 2 files changed, 15 insertions(+), 5 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -17635,20 +17635,25 @@ static void ath12k_mac_num_chanctxs_iter
                                          struct ieee80211_chanctx_conf *conf,
                                          void *data)
 {
-        int *num = data;
+	struct ath12k_mac_num_chanctxs_arg *arg =
+				(struct ath12k_mac_num_chanctxs_arg *)data;
+	struct ath12k *ctx_ar, *ar = arg->ar;
 
-        (*num)++;
+	ctx_ar = ath12k_get_ar_by_ctx(ar->ah->hw, conf);
+
+	if (ctx_ar == ar)
+		arg->num++;
 }
 
 static int ath12k_mac_num_chanctxs(struct ath12k *ar)
 {
-        int num = 0;
+	struct ath12k_mac_num_chanctxs_arg arg = { .ar = ar, .num = 0};
 
         ieee80211_iter_chan_contexts_atomic(ar->ah->hw,
                                             ath12k_mac_num_chanctxs_iter,
-                                            &num);
+					    &arg);
 
-        return num;
+	return arg.num;
 }
 
 static void ath12k_mac_update_rx_channel(struct ath12k *ar,
--- a/drivers/net/wireless/ath/ath12k/mac.h
+++ b/drivers/net/wireless/ath/ath12k/mac.h
@@ -140,6 +140,16 @@ enum ath12k_supported_bw {
 
 #define ATH12K_NUM_20_MHZ_CHAN_IN_320_MHZ_CHAN	16
 
+/**
+ * struct ath12k_mac_num_chanctxs_arg - Structure to hold channel context
+ * @ar: Pointer to ath12k device context
+ * @num: Number of channel context for the applicable ar
+ */
+struct ath12k_mac_num_chanctxs_arg {
+	struct ath12k *ar;
+	u8 num;
+};
+
 struct ath12k_mac_get_any_chanctx_conf_arg {
 	struct ath12k *ar;
 	struct ieee80211_chanctx_conf *chanctx_conf;
