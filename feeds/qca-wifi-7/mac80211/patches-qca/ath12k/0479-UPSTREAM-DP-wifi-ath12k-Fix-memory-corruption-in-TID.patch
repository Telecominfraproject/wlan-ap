 	if (ab->hw_params->reoq_lut_support) {
@@ -912,6 +910,11 @@ int ath12k_dp_rx_peer_pn_replay_config(s
 		return -ENOENT;
 	}
 
+	if (!peer->primary_link) {
+		spin_unlock_bh(&dp->dp_lock);
+		return 0;
+	}
+
 	for (tid = 0; tid <= IEEE80211_NUM_TIDS; tid++) {
 		rx_tid = &peer->dp_peer->rx_tid[tid];
 		if (!rx_tid->active)
