From a7e9b8f5bb83a4466be3110d3b8a20b81b7a63d7 Mon Sep 17 00:00:00 2001
From: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Date: Fri, 26 Sep 2025 12:28:35 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Init ahsta to NULL and add NULL
 check for ahsta

In the API ath12k_dp_primary_peer_migrate_setup(), pointer variable ahsta
is not initialized. This can result in random memory access in failure
case of when peer is not found, and ahsta points to random address.

In access to fix this, initialize ahsta to NULL and also add NULL check
for ahsta in failure case handling.

Patch-dependency:
0339-0008-wifi-ath12k-Handle-dp-tid-setup-and-cleanup-for-UMAC.patch

Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_rx.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_rx.c b/drivers/net/wireless/ath/ath12k/dp_rx.c
index e5c2b77..005ddf9 100644
--- a/drivers/net/wireless/ath/ath12k/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/dp_rx.c
@@ -1589,7 +1589,7 @@ ath12k_dp_primary_peer_migrate_setup(struct ath12k_dp *dp, void *ctx,
 	struct ath12k_dp_link_peer *peer;
 	struct ath12k_link_sta *arsta;
 	struct ath12k_base *mig_ab;
-	struct ath12k_sta *ahsta;
+	struct ath12k_sta *ahsta = NULL;
 	struct ath12k_dp *mig_dp;
 	u16 peer_id = rx_tid->peer_id;
 	u8 chip_id = rx_tid->chip_id;
@@ -1651,7 +1651,9 @@ ath12k_dp_primary_peer_migrate_setup(struct ath12k_dp *dp, void *ctx,
 	return;
 
 migration_fail:
-	complete(&ahsta->dp_migration_event);
+	if (ahsta)
+		complete(&ahsta->dp_migration_event);
+
 	return;
 }
 EXPORT_SYMBOL(ath12k_dp_primary_peer_migrate_setup);
-- 
