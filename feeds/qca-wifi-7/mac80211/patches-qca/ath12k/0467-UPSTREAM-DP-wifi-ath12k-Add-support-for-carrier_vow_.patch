From 0cb39a89733651726658096faba41ddb9c03501c Mon Sep 17 00:00:00 2001
From: Girish Kumar M P <gmp@qti.qualcomm.com>
Date: Wed, 9 Jul 2025 15:25:49 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k Add support for
 carrier_vow_optimization

Add support to enable/disable carrier_vow_optimization
in ath12k driver.

Patch-dependency: none

Signed-off-by: Girish Kumar M P <gmp@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c      | 4 ++++
 drivers/net/wireless/ath/ath12k/core.h      | 1 +
 drivers/net/wireless/ath/ath12k/wifi7/wmi.c | 4 ++++
 drivers/net/wireless/ath/ath12k/wmi.c       | 2 ++
 drivers/net/wireless/ath/ath12k/wmi.h       | 2 ++
 5 files changed, 13 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -142,6 +142,11 @@ module_param_named(wsi_bypass_bmap, ath1
 MODULE_PARM_DESC(wsi_bypass_bmap,
 		 "Bitmap for the chip to be bypassed for WSI interface");
 
+bool ath12k_carrier_vow_optimization;
+module_param_named(carrier_vow_optimization, ath12k_carrier_vow_optimization, bool, 0644);
+MODULE_PARM_DESC(carrier_vow_optimization, "Enable/Disable VoW optimization for carier usecases");
+EXPORT_SYMBOL(ath12k_carrier_vow_optimization);
+
 /* protected with ath12k_hw_group_mutex */
 static struct list_head ath12k_hw_group_list = LIST_HEAD_INIT(ath12k_hw_group_list);
 
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -104,6 +104,7 @@ extern unsigned int ath12k_rfs_core_mask
 extern unsigned int ath12k_frame_mode;
 extern bool ath12k_fse_3_tuple_enabled;
 extern bool ath12k_rx_nwifi_err_dump;
+extern bool ath12k_carrier_vow_optimization;
 #ifndef CONFIG_ATH12K_MEM_PROFILE_512M
 extern unsigned int ath12k_max_clients;
 #endif
--- a/drivers/net/wireless/ath/ath12k/wifi7/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/wmi.c
@@ -56,6 +56,8 @@ void ath12k_wifi7_wmi_init_qcn9274(struc
 	config->twt_ap_sta_count = 1000;
 	config->ema_max_vap_cnt = ab->num_radios * TARGET_MAX_MBSSID_GROUPS;
 	config->ema_max_profile_period = TARGET_EMA_MAX_PROFILE_PERIOD;
+	if (ath12k_carrier_vow_optimization)
+		config->carrier_vow_optimization = ath12k_carrier_vow_optimization;
 	config->beacon_tx_offload_max_vdev += config->ema_max_vap_cnt;
 
 	if (test_bit(WMI_TLV_SERVICE_PEER_METADATA_V1A_V1B_SUPPORT, ab->wmi_ab.svc_map))
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -5972,6 +5972,8 @@ ath12k_wmi_copy_resource_config(struct a
 	wmi_cfg->use_pdev_id = cpu_to_le32(tg_cfg->use_pdev_id);
 	wmi_cfg->flag1 = cpu_to_le32(tg_cfg->atf_config |
 				     WMI_RSRC_CFG_FLAG1_BSS_CHANNEL_INFO_64);
+	if (tg_cfg->carrier_vow_optimization)
+		wmi_cfg->flag1 |= WMI_RSRC_CFG_FLAG1_VIDEO_OVER_WIFI_ENABLE;
 	wmi_cfg->peer_map_unmap_version = cpu_to_le32(tg_cfg->peer_map_unmap_version);
 	wmi_cfg->sched_params = cpu_to_le32(tg_cfg->sched_params);
 	wmi_cfg->twt_ap_pdev_count = cpu_to_le32(tg_cfg->twt_ap_pdev_count);
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2815,6 +2815,7 @@ struct ath12k_wmi_resource_config_arg {
 	enum ath12k_peer_metadata_version peer_metadata_ver;
 	u32 ema_max_vap_cnt;
 	u32 ema_max_profile_period;
+	bool carrier_vow_optimization;
 	bool is_reg_cc_ext_event_supported;
 	bool is_wds_null_frame_supported;
 	bool is_full_bw_nol_feature_supported;
@@ -2914,6 +2915,7 @@ struct wmi_ctrl_path_pmlo_telemetry_stat
 #define WMI_RSRC_CFG_HOST_SVC_FLAG_FULL_BW_NOL_SUPPORT_BIT	14
 #define WMI_RSRC_CFG_FLAGS2_RX_PEER_METADATA_VERSION		GENMASK(5, 4)
 #define WMI_RSRC_CFG_FLAG1_BSS_CHANNEL_INFO_64	BIT(5)
+#define WMI_RSRC_CFG_FLAG1_VIDEO_OVER_WIFI_ENABLE        BIT(23)
 #define WMI_RSRC_CFG_FLAGS2_CALC_NEXT_DTIM_COUNT_SET      BIT(9)
 #define WMI_RSRC_CFG_FLAGS2_SAWF_CONFIG_ENABLE_SET             BIT(13)
 #define WMI_RSRC_CFG_FLAGS2_INTRABSS_MEC_WDS_LEARNING_DISABLE  BIT(15)
