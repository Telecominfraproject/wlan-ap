+static int
+ath12k_mgmt_mlo_global_device_crash_info(struct ath12k_base *ab,
+				       const void *ptr,
+				       size_t len,
+				       struct ath12k_host_mlo_glb_device_crash_info *global_device_crash_info)
+{
+	u32 device_info;
+	struct mlo_glb_device_crash_info *tlv_data;
+
