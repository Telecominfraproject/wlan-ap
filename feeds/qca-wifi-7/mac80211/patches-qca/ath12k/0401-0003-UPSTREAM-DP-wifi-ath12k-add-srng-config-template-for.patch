From be2af8bb5a48de2b36e3710639605126e294806f Mon Sep 17 00:00:00 2001
From: Alok Singh <aloksing@qti.qualcomm.com>
Date: Mon, 9 Jun 2025 12:59:08 +0530
Subject: [PATCH 03/13] UPSTREAM: DP: wifi: ath12k: add srng config template
 for mon status ring

Currently, the hw_srng_config_template does not have a template for mon
status ring.

But srng config template is necessary during ring initialization. So add
a template for mon status ring.

Patch-dependency:
	0401-0002-UPSTREAM-DP-wifi-ath12k-avoid-call-ath12k_dp_mon_par.patch

Signed-off-by: Alok Singh <aloksing@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/hal.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/net/wireless/ath/ath12k/hal.h b/drivers/net/wireless/ath/ath12k/hal.h
index 326a7b8..a9cd1fd 100644
--- a/drivers/net/wireless/ath/ath12k/hal.h
+++ b/drivers/net/wireless/ath/ath12k/hal.h
@@ -295,6 +295,7 @@ enum hal_srng_ring_id {
 
 	HAL_SRNG_RING_ID_WMAC1_SW2RXMON_BUF0 = HAL_SRNG_RING_ID_PMAC1_ID_START,
 
+	HAL_SRNG_RING_ID_WMAC1_SW2RXDMA1_STATBUF,
 	HAL_SRNG_RING_ID_WMAC1_RXDMA2SW0,
 	HAL_SRNG_RING_ID_WMAC1_RXDMA2SW1,
 	HAL_SRNG_RING_ID_WMAC1_RXMON2SW0 = HAL_SRNG_RING_ID_WMAC1_RXDMA2SW1,
-- 
2.34.1

