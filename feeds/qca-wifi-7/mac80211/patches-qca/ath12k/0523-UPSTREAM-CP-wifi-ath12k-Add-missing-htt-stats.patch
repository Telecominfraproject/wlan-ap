From 661ec5b800bee647d9b03b1e059b40e5ae9fc667 Mon Sep 17 00:00:00 2001
From: Ashwant Krishna R <ashwantk@qti.qualcomm.com>
Date: Fri, 22 Aug 2025 20:53:11 +0530
Subject: [PATCH] UPSTREAM:CP:wifi: ath12k: Add missing htt stats

Add missing field mac_id in struct ath12k_htt_rx_pdev_be_ul_trig_stats_tlv
and update function ath12k_htt_print_be_bn_ul_trigger_stats_tlv to print
the field.

Previously, mac_id field was missing which caused the other fields to be
misaligned.

Usage :
echo 26 1 >/sys/kernel/debug/ath12k/pci-0003:01:00.0/mac0/htt_stats_type
cat /sys/kernel/debug/ath12k/pci-0003:01:00.0/mac0/htt_stats

Patch-dependency:
ath12k/0478-UPSTREAM-CP-wifi-ath12k-Add-missing-stats.patch

Patch-work: None

Fixes: Ia196c5a8625 ("UPSTREAM:CP:wifi: ath12k: Add missing stats")

Signed-off-by: Ashwant Krishna R <ashwantk@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c | 3 +++
 drivers/net/wireless/ath/ath12k/debugfs_htt_stats.h | 1 +
 2 files changed, 4 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
index d3cc4d0..6f97128 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
@@ -7935,6 +7935,9 @@ ath12k_htt_print_be_bn_ul_trigger_stats_tlv(const void *tag_buf, u16 tag_len,
 
 	len += scnprintf(buf + len, buf_len - len,
 			 "HTT_RX_PDEV_BE_BN_UL_TRIGGER_STATS_TLV:\n");
+	len += scnprintf(buf + len, buf_len - len, "mac_id = %u\n",
+			u32_get_bits(le32_to_cpu(stats_buf->mac_id_word),
+					ATH12K_HTT_STATS_MAC_ID));
 	len += scnprintf(buf + len, buf_len - len, "rx_11be_ul_ofdma = %u\n",
 			 le32_to_cpu(stats_buf->rx_11be_ul_ofdma));
 	len += print_array_to_buf(buf, len, "be_ul_ofdma_rx_mcs",
diff --git a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.h b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.h
index 84ed30f..da75a3c 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.h
+++ b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.h
@@ -4076,6 +4076,7 @@ struct htt_rx_pdev_be_ul_ofdma_user_stats_tlv {
 #define ATH12K_HTT_RX_NUM_BN_BW_COUNTERS	5
 
 struct ath12k_htt_rx_pdev_be_ul_trig_stats_tlv {
+	__le32 mac_id_word;
 	__le32 rx_11be_ul_ofdma;
 	__le32 be_ul_ofdma_rx_mcs[ATH12K_HTT_RX_NUM_BE_MCS_COUNTERS];
 	__le32 be_ul_ofdma_rx_gi[ATH12K_HTT_RX_NUM_GI_COUNTERS]
-- 
2.34.1

