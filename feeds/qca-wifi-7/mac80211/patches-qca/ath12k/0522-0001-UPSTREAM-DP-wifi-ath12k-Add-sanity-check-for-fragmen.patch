From 349f5b5acd75b2e02bf17b66bff7a339157a9c91 Mon Sep 17 00:00:00 2001
From: Sushant Butta <sbutta@qti.qualcomm.com>
Date: Tue, 19 Aug 2025 12:25:10 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Add sanity check for fragment
 length

In backpressure scenarios, the hardware logs packets with a length
less than 16 bytes (which includes the 802.3 header and padding).
This causes an incorrect calculation when subtracting 16 from the
packet length, resulting in a large invalid value and potentially
leading to a crash.

Adding a sanity check to ensure that the packet length is greater
than 16.

Patch-dependency:
0495-04-Upstream-DP-wifi-ath12k-Support-Ethernet-packet-capt.patch

Signed-off-by: Sushant Butta <sbutta@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c | 8 ++++++++
 1 file changed, 8 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -932,6 +932,14 @@ ath12k_wifi7_dp_mon_restitch_frags(struc
 	 */
 	frag_page_offset = ATH12K_DP_MON_DECAP_HDR_SIZE + ATH12K_DP_MON_L3_HDR_PAD;
 
+	if (unlikely(frag_size <= frag_page_offset)) {
+		ath12k_dbg(dp->ab, ATH12K_DBG_DP_MON_RX,
+			   "mon_rx_restitch: pkt size %u is less than frag offset %u\n",
+			   frag_size, frag_page_offset);
+		ret = -EINVAL;
+		goto free_mpdu;
+	}
+
 	frag_addr = ath12k_dp_mon_skb_get_frag_addr(mpdu, 1);
 	ethvlan = (struct vlan_ethhdr *)(frag_addr + ATH12K_DP_MON_L3_HDR_PAD);
 	if (ethvlan->h_vlan_proto == htons(ETH_P_8021Q))
