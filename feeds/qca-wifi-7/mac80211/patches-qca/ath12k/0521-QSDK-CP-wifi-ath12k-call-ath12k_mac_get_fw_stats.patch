From 799fbdb3f2966eb3d18b32a44d3e2a59c7c379d5 Mon Sep 17 00:00:00 2001
From: Rajat Soni <rajson@qti.qualcomm.com>
Date: Wed, 20 Aug 2025 13:34:01 +0530
Subject: [PATCH] QSDK:CP: wifi: ath12k: call ath12k_mac_get_fw_stats only
 for STA

When a large number of clients (e.g., 50+) are connected to the AP,
invoking iw dev station dump leads to timeouts in
ath12k_mac_get_fw_stats(), causing delays in command execution.

To address this, introduce a condition to call
ath12k_mac_get_fw_stats() only for iftype STA, reducing unnecessary
firmware stat requests and improving responsiveness.

Patch-work: None
Patch-dependency: None 

Signed-off-by: Rajat Soni <rajson@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 48 +++++++++++++++------------
 1 file changed, 27 insertions(+), 21 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 7806881..3644605 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -20282,19 +20282,22 @@ void ath12k_mac_op_link_sta_statistics(struct ieee80211_hw *hw,
 		      rssi_offset;
 
 	signal = rate_info.rssi_comb;
-	params.pdev_id = ar->pdev->pdev_id;
-	params.vdev_id = 0;
-	params.stats_id = WMI_REQUEST_VDEV_STAT;
+	if (ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA) {
+		/* Limit the requests to Firmware for fetching the signal strength */
+		if (time_after(jiffies, msecs_to_jiffies
+						(ATH12K_PDEV_SIGNAL_UPDATE_TIME_MSECS) +
+						 ar->last_signal_update)) {
+			params.pdev_id = ar->pdev->pdev_id;
+			params.vdev_id = 0;
+			params.stats_id = WMI_REQUEST_VDEV_STAT;
 
-	/* Limit the requests to Firmware for fetching the signal strength */
-	if (time_after(jiffies, msecs_to_jiffies(ATH12K_PDEV_SIGNAL_UPDATE_TIME_MSECS) +
-				ar->last_signal_update)) {
-		ath12k_mac_get_fw_stats(ar, &params);
-		ar->last_signal_update = jiffies;
+			ath12k_mac_get_fw_stats(ar, &params);
+			ar->last_signal_update = jiffies;
+		}
+		if (!signal)
+			signal = arsta->rssi_beacon;
 	}
 
-	if (!signal && ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA)
-		signal = arsta->rssi_beacon;
 
 	if (signal) {
 		link_sinfo->signal =
@@ -20381,19 +20384,22 @@ void ath12k_mac_op_sta_statistics(struct ieee80211_hw *hw,
 		      rssi_offset;
 
 	signal = rate_info.rssi_comb;
-	params.pdev_id = ar->pdev->pdev_id;
-	params.vdev_id = 0;
-	params.stats_id = WMI_REQUEST_VDEV_STAT;
 
-	/* Limit the requests to Firmware for fetching the signal strength */
-	if (time_after(jiffies, msecs_to_jiffies(ATH12K_PDEV_SIGNAL_UPDATE_TIME_MSECS) +
-				ar->last_signal_update)) {
-		ath12k_mac_get_fw_stats(ar, &params);
-		ar->last_signal_update = jiffies;
-	}
+	if (ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA) {
+		/* Limit the requests to Firmware for fetching the signal strength */
+		if (time_after(jiffies, msecs_to_jiffies
+						(ATH12K_PDEV_SIGNAL_UPDATE_TIME_MSECS) +
+						 ar->last_signal_update)) {
+			params.pdev_id = ar->pdev->pdev_id;
+			params.vdev_id = 0;
+			params.stats_id = WMI_REQUEST_VDEV_STAT;
+			ath12k_mac_get_fw_stats(ar, &params);
+			ar->last_signal_update = jiffies;
+		}
 
-	if (!signal && ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA)
-		signal = arsta->rssi_beacon;
+		if (!signal)
+			signal = arsta->rssi_beacon;
+	}
 
 	if (!(sinfo->filled & BIT_ULL(NL80211_STA_INFO_CHAIN_SIGNAL)) &&
 	    ahsta->ahvif->vdev_type == WMI_VDEV_TYPE_STA)
-- 
2.34.1

