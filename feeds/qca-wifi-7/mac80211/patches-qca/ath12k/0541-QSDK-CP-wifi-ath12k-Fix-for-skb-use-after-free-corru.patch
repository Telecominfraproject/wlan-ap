From b021ef4f29dfe7d0a5a75fb5a646ffa38947a1dc Mon Sep 17 00:00:00 2001
From: sivaraman <sivad@qti.qualcomm.com>
Date: Wed, 17 Sep 2025 13:19:13 +0530
Subject: [PATCH] QSDK:CP: wifi: ath12k: Fix for skb use-after-free corruption

In WMI mgmt Tx flow, hdr->addr1 from skb->data is printed post WMI send
in success case as part of debuggability enhancement.
In failure case, skb is freed in the same context in the same api.
In success case, skb is freed post TX completion in different context.
So there is a high chance of hitting skb use-after-free scenario where Tx
completion might be processed before debug print execution. Added
the changes to store the hdr->addr1 in local variable and print the same.

Patch-dependency:
0429-UPSTREAM-PROTOCOL-DP-wifi-ath12k-Add-connectivity-de.patch

Fixes: Ib6aa4a11685 (PROTOCOL:DP:wifi:ath12k:Add connectivity debug)

Signed-off-by: sivaraman <sivad@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index af6bd42..3d30c58 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -14184,6 +14184,7 @@ static int ath12k_mac_mgmt_tx_wmi(struct ath12k *ar, struct ath12k_link_vif *arv
 	u8 frm_stype = FIELD_GET(IEEE80211_FCTL_STYPE, hdr->frame_control);
 	int buf_id;
 	int ret;
+	u8 sta_addr[ETH_ALEN];
 
 	lockdep_assert_wiphy(ath12k_ar_to_hw(ar)->wiphy);
 
@@ -14233,6 +14234,8 @@ static int ath12k_mac_mgmt_tx_wmi(struct ath12k *ar, struct ath12k_link_vif *arv
 		tx_params_valid = true;
 #endif /* CPTCFG_ATH12K_CFR */
 
+	ether_addr_copy(sta_addr, hdr->addr1);
+
 	ret = ath12k_wmi_mgmt_send(ar, arvif->vdev_id, buf_id, skb,
 				   link_agnostic, tx_params_valid);
 	if (ret) {
@@ -14242,7 +14245,7 @@ static int ath12k_mac_mgmt_tx_wmi(struct ath12k *ar, struct ath12k_link_vif *arv
 
 	if (ATH12K_MGMT_MLME_FRAME(hdr->frame_control))
 		ath12k_dbg(ab, ATH12K_DBG_MLME, "Transmit %s to STA %pM over WMI\n",
-			   mgmt_frame_name[frm_stype], hdr->addr1);
+			   mgmt_frame_name[frm_stype], sta_addr);
 	return 0;
 
 err_unmap_buf:
-- 
