+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c
@@ -2072,6 +2072,9 @@ ath12k_wifi7_hal_mon_rx_parse_status_tlv(struct ath12k_hal *hal,
 		return HAL_RX_MON_STATUS_BUF_DONE;
 	case HAL_RX_HEADER:
 		return HAL_RX_MON_STATUS_RX_HDR;
+	case HAL_MON_DROP:
