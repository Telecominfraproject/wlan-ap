From f03b3cf418cdb4e2335d47defd1801b33974bc7e Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Tue, 8 Jul 2025 17:15:38 +0530
Subject: [PATCH 6/9] Upstream:DP:wifi:ath12k: add drop tlv handling while
 processing status buffer

Hardware provides drop TLV through the buffer which is getting fetched
from the monitor ring during backpressure scenario. During this scenario,
the entire TLV sequence for the ppdu is invalid and host needs to flush
this TLV. During flushing, if the buffer address TLV is present then free
the corresponding buffer otherwise the flush the corresponding ppdu
information.

Patch-dependency:
475-05-Upstream-DP-wifi-ath12k-Free-buffer-address-during-H.patch

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/hal_mon_cmn.h |   2 +
 .../net/wireless/ath/ath12k/wifi7/dp_mon2.c   | 170 +++++++++++-------
 .../net/wireless/ath/ath12k/wifi7/hal_mon.c   |   3 +
 3 files changed, 106 insertions(+), 69 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h b/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h
index c1af780..a16499a 100644
--- a/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h
+++ b/drivers/net/wireless/ath/ath12k/hal_mon_cmn.h
@@ -196,6 +196,7 @@ struct hal_rx_mon_ppdu_info {
 	u16 mpdu_retry_cnt;
 	struct hal_rx_mon_mpdu_info mpdu_info;
 	struct sk_buff_head mpdu_q;
+	bool is_drop_tlv;
 };
 
 struct hal_rx_mon_status_tlv_hdr {
@@ -212,6 +213,7 @@ enum hal_rx_mon_status {
 	HAL_RX_MON_STATUS_MPDU_END,
 	HAL_RX_MON_STATUS_MSDU_END,
 	HAL_RX_MON_STATUS_RX_HDR,
+	HAL_RX_MON_STATUS_DROP_TLV,
 };
 
 enum hal_tx_mon_status {
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
index 5457a2a..0ed412e 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -264,6 +264,75 @@ ath12k_wifi7_dp_mon_rx_parse_dest_tlv(struct ath12k_pdev_dp *dp_pdev,
 	return 0;
 }
 
+static void
+ath12k_wifi7_dp_mon_free_pkt_buf(struct ath12k_pdev_dp *pdev_dp,
+				 u8 *mon_buf, u16 mon_buf_len)
+{
+	struct ath12k_dp *dp = pdev_dp->dp;
+	struct dp_mon_packet_info *packet_info;
+	struct hal_tlv_64_hdr *tlv;
+	struct ath12k_dp_mon_desc *pkt_desc;
+	struct list_head mon_desc_used_list;
+	struct dp_rxdma_mon_ring *buf_ring = &dp->dp_mon->rxdma_mon_buf_ring;
+	u8 *ptr = mon_buf;
+	u16 tlv_tag, tlv_len;
+	int num_buf = 0;
+
+	INIT_LIST_HEAD(&mon_desc_used_list);
+
+	do {
+		tlv = (struct hal_tlv_64_hdr *)ptr;
+		tlv_tag = le64_get_bits(tlv->tl, HAL_TLV_64_HDR_TAG);
+		ptr += sizeof(*tlv);
+
+		if (tlv_tag == HAL_RX_PPDU_END)
+			tlv_len = sizeof(struct hal_rx_rxpcu_classification_overview);
+		else
+			tlv_len = le64_get_bits(tlv->tl, HAL_TLV_64_HDR_LEN);
+
+		if (tlv_tag == HAL_MON_BUF_ADDR) {
+			packet_info = (struct dp_mon_packet_info *)ptr;
+			pkt_desc = (struct ath12k_dp_mon_desc *)
+				    (uintptr_t)(packet_info->cookie);
+
+			if (unlikely(!pkt_desc)) {
+				ath12k_warn(dp, "mon_flush: NULL pkt_desc received in macid %d\n",
+					    pdev_dp->mac_id);
+				goto next_tlv;
+			}
+
+			if (unlikely(pkt_desc->magic != ATH12K_MON_MAGIC_VALUE)) {
+				ath12k_warn(dp, "mon_flush: invalid magic value in macid %d\n",
+					    pdev_dp->mac_id);
+				goto next_tlv;
+			}
+
+			list_add_tail(&pkt_desc->list, &mon_desc_used_list);
+			num_buf++;
+
+			if (unlikely(!pkt_desc->in_use)) {
+				ath12k_warn(dp, "mon_flush: in_use flag not set, macid %d\n",
+					    pdev_dp->mac_id);
+				pkt_desc->in_use = true;
+				goto next_tlv;
+			}
+
+			ath12k_core_dma_unmap_page(dp->dev, pkt_desc->paddr,
+						   ATH12K_DP_MON_RX_BUF_SIZE,
+						   DMA_FROM_DEVICE);
+			page_frag_free(pkt_desc->mon_buf);
+			pkt_desc->mon_buf = NULL;
+		}
+
+next_tlv:
+		ptr += tlv_len;
+		ptr = PTR_ALIGN(ptr, HAL_TLV_64_ALIGN);
+	} while ((ptr - mon_buf) < mon_buf_len);
+
+	if (likely(!list_empty(&mon_desc_used_list)))
+		ath12k_dp_mon_buf_replenish(dp, buf_ring, &mon_desc_used_list, num_buf);
+}
+
 static enum hal_rx_mon_status
 ath12k_wifi7_dp_mon_rx_parse_dest(struct ath12k_pdev_dp *dp_pdev,
 				  struct ath12k_dp_mon_desc *mon_desc)
@@ -275,6 +344,7 @@ ath12k_wifi7_dp_mon_rx_parse_dest(struct ath12k_pdev_dp *dp_pdev,
 	struct hal_tlv_parsed_hdr tlv_parsed_hdr = {0};
 	enum hal_rx_mon_status hal_status;
 	u16 tlv_tag, tlv_len, buf_len = mon_desc->buf_len, tlv_userid;
+	s16 rem_buf_len;
 	u8 *mon_buf = (u8 *)mon_desc->mon_buf;
 	u8 *ptr = mon_buf;
 	int ret;
@@ -331,6 +401,15 @@ ath12k_wifi7_dp_mon_rx_parse_dest(struct ath12k_pdev_dp *dp_pdev,
 		 (hal_status == HAL_RX_MON_STATUS_MSDU_END) ||
 		 (hal_status == HAL_RX_MON_STATUS_RX_HDR));
 
+	if (unlikely(pmon->mon_ppdu_info.is_drop_tlv)) {
+		rem_buf_len = ptr - mon_buf;
+		if (rem_buf_len > 0 && rem_buf_len < buf_len) {
+			buf_len -= rem_buf_len;
+			ath12k_wifi7_dp_mon_free_pkt_buf(dp_pdev, ptr, buf_len);
+			hal_status = HAL_RX_MON_STATUS_DROP_TLV;
+		}
+	}
+
 	if (mon_desc->end_of_ppdu)
 		hal_status = HAL_RX_MON_STATUS_PPDU_DONE;
 
@@ -447,77 +526,11 @@ ath12k_wifi7_dp_mon_rx_parse_ppdu_status(struct ath12k_pdev_dp *dp_pdev,
 static void ath12k_wifi7_dp_mon_h_flush_tlv(struct ath12k_pdev_dp *pdev_dp,
 					    struct ath12k_dp_mon_desc *mon_desc)
 {
