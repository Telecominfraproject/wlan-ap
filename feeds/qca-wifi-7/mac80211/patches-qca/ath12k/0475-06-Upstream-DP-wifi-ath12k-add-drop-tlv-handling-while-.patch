+	ath12k_wifi7_dp_mon_free_pkt_buf(pdev_dp, ptr, mon_buf_len);
 
 	page_frag_free(mon_buf);
 	mon_desc->mon_buf = NULL;
@@ -588,8 +601,9 @@ int ath12k_dp_mon_rx_dual_ring_process(struct ath12k_pdev_dp *pdev_dp, int mac_i
 	struct ath12k_link_sta *arsta;
 	struct ath12k_dp_link_peer *peer;
 	struct ath12k_neighbor_peer *nrp, *tmp;
-	struct ath12k_dp_mon_desc *mon_desc;
+	struct ath12k_dp_mon_desc *mon_desc, *tmp_mon_desc, *next_mon_desc;
 	struct list_head mon_desc_used_list;
+	struct sk_buff *mpdu;
 	u64 desc_va;
 	int num_buffs_reaped = 0, srng_id;
 	u32 hal_status, end_offset, info0, end_reason;
@@ -714,6 +728,24 @@ move_next:
 
 		hal_status = ath12k_wifi7_dp_mon_rx_parse_ppdu_status(pdev_dp, pmon,
 								      mon_desc, napi);
+		if (unlikely(hal_status == HAL_RX_MON_STATUS_DROP_TLV)) {
+			list_for_each_entry_safe(next_mon_desc, tmp_mon_desc,
+						 &mon_desc_used_list, list) {
+				if (next_mon_desc->mon_buf) {
+					ath12k_wifi7_dp_mon_h_flush_tlv(pdev_dp,
+									next_mon_desc);
+
+					if (!next_mon_desc->end_of_ppdu)
+						continue;
+
+					while ((mpdu = skb_dequeue(&ppdu_info->mpdu_q)))
+						dev_kfree_skb_any(mpdu);
+
+					goto free_buf;
+				}
+			}
+		}
+
 		if (hal_status != HAL_RX_MON_STATUS_PPDU_DONE) {
 			ppdu_info->ppdu_continuation = true;
 			page_frag_free(mon_buf);
