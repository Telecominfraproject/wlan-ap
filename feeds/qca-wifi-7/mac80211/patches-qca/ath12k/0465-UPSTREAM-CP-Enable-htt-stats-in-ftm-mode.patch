From 60460bd8fc95b9eb36c9d3d9ba6261a001e03b8f Mon Sep 17 00:00:00 2001
From: Narendhar Reddy <nare@qti.qualcomm.com>
Date: Thu, 24 Jul 2025 23:07:39 +0530
Subject: [PATCH] UPSTREAM:CP:ath12k:Enable htt stats in ftm mode.

Currently, HTT stats are not displayed if the radio is not up.
In FTM mode, the radio remains down, which prevents HTT stats
from being shown. 
Allow HTT stats to be displayed in FTM mode by adding a
condition to bypass the radio state check

Signed-off-by: Narendhar Reddy <nare@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
index d949c70..2399d1c 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs_htt_stats.c
@@ -8543,7 +8543,8 @@ static int ath12k_open_htt_stats(struct inode *inode,
 
 	wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
 
-	if (ah->state != ATH12K_HW_STATE_ON) {
+	if (ah->state != ATH12K_HW_STATE_ON &&
+	    ar->ab->fw_mode != ATH12K_FIRMWARE_MODE_FTM) {
 		ret = -ENETDOWN;
 		goto err_unlock;
 	}
-- 
2.34.1

