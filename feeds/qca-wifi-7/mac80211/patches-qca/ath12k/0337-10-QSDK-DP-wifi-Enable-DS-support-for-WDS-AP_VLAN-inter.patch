@@ -12568,6 +12660,10 @@ void ath12k_mac_op_remove_interface(stru
 		if (!arvif || !arvif->is_created)
 			continue;
 
+		if (vif->type == NL80211_IFTYPE_AP_VLAN) {
+			ath12k_ppeds_detach_link_apvlan_vif(arvif, ahvif->vlan_iface, link_id);
