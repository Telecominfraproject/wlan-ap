 	}
@@ -8436,6 +8437,7 @@ skip_mgmt_stats:
 			status->link_id = arsta->link_id;
 		}
 		spin_unlock_bh(&ab->base_lock);
+		ab->dp->device_stats.rx_pkt_null_frame_handled++;
 		ieee80211_rx_napi(ar->ah->hw, pubsta, skb, NULL);
 		goto exit;
