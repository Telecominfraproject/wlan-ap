From b1f63ed18235035274979d27fe71b6731ebde9fc Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 13:29:59 +0530
Subject: [PATCH 11/21] UPSTREAM: DP: Use local list for msdu chains in rx
 processing

Use local list for msdu chains in rx processing to make sure
we don't process incomplete msdu chains

Patch-dependency : None

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 30 ++++++++++---------
 1 file changed, 16 insertions(+), 14 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index 6dd6835..392321e 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -1393,6 +1393,7 @@ int ath12k_wifi7_dp_rx_process(struct ath12k_dp *dp, int ring_id,
 	struct ath12k_base *ab = dp->ab;
 	struct ath12k_dp_hw_group *dp_hw_grp = dp->dp_hw_grp;
 	struct list_head rx_desc_used_list[ATH12K_MAX_SOCS];
+	struct list_head rx_desc_local_list;
 	struct ath12k_dp_hw_link *hw_links = dp_hw_grp->hw_links;
 	int num_buffs_reaped[ATH12K_MAX_SOCS] = {};
 	struct ath12k_rx_desc_info *desc_info;
@@ -1400,11 +1401,12 @@ int ath12k_wifi7_dp_rx_process(struct ath12k_dp *dp, int ring_id,
 	struct hal_reo_dest_ring *desc;
 	struct ath12k_dp *partner_dp;
 	struct sk_buff_head msdu_list;
+	struct sk_buff_head local_msdu_list;
 	int total_msdu_reaped = 0;
 	u8 device_id;
 	struct hal_srng *srng;
 	struct sk_buff *msdu;
-	bool done = false;
+	bool done = true;
 	u64 desc_va;
 #ifndef CONFIG_IO_COHERENCY
 	int valid_entries;
@@ -1414,6 +1416,9 @@ int ath12k_wifi7_dp_rx_process(struct ath12k_dp *dp, int ring_id,
 	for (device_id = 0; device_id < ATH12K_MAX_SOCS; device_id++)
 		INIT_LIST_HEAD(&rx_desc_used_list[device_id]);
 
+	INIT_LIST_HEAD(&rx_desc_local_list);
+	__skb_queue_head_init(&local_msdu_list);
+
 	srng = &ab->hal.srng_list[dp->reo_dst_ring[ring_id].ring_id];
 
 	spin_lock_bh(&srng->lock);
@@ -1432,7 +1437,6 @@ try_again:
 #endif
 	while ((desc = ath12k_hal_srng_dst_get_next_cached_entry(ab, srng))) {
 		struct rx_mpdu_desc_info *mpdu_info;
-		enum hal_reo_dest_ring_push_reason push_reason;
 		struct hal_rx_spd_data *spd_desc_l;
 
 		desc_va = ((u64)le32_to_cpu(desc->buf_va_hi) << 32 |
@@ -1476,8 +1480,6 @@ try_again:
 		msdu = desc_info->skb;
 		desc_info->skb = NULL;
 
-		list_add_tail(&desc_info->list, &rx_desc_used_list[device_id]);
-
 		ath12k_core_dma_unmap_single(partner_dp->dev, desc_info->paddr,
 					     DP_RX_BUFFER_SIZE,
 					     DMA_FROM_DEVICE);
@@ -1486,26 +1488,26 @@ try_again:
 
 		dp->device_stats.reo_rx[ring_id][ab->device_id]++;
 
-		push_reason = spd_desc_l->reo_push_reason;
-		if (push_reason !=
-		    HAL_REO_DEST_RING_PUSH_REASON_ROUTING_INSTRUCTION) {
-			dev_kfree_skb_any(msdu);
-			dp->device_stats.hal_reo_error[ring_id]++;
-			continue;
-		}
-
 		mpdu_info = &spd_desc_l->rx_mpdu_info;
 
 		mpdu_info->peer_id =
 			ath12k_wifi7_dp_rx_get_peer_id(ab, dp->peer_metadata_ver,
 						       mpdu_info->peer_meta_data);
 
-		__skb_queue_tail(&msdu_list, msdu);
-
 		if (!spd_desc_l->rx_msdu_info.msdu_continuation) {
 			total_msdu_reaped++;
+			if (!done) {
+				list_splice_tail_init(&rx_desc_local_list,
+						      &rx_desc_used_list[device_id]);
+				skb_queue_splice_tail_init(&local_msdu_list, &msdu_list);
+			}
+
+			list_add_tail(&desc_info->list, &rx_desc_used_list[device_id]);
+			__skb_queue_tail(&msdu_list, msdu);
 			done = true;
 		} else {
+			list_add_tail(&desc_info->list, &rx_desc_local_list);
+			__skb_queue_tail(&local_msdu_list, msdu);
 			done = false;
 		}
 
-- 
