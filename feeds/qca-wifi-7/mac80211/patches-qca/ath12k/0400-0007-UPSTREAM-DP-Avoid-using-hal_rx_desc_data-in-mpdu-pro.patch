 	if (ret)
 		return -EINVAL;
 
@@ -2354,6 +2361,9 @@ static int ath12k_wifi7_dp_rx_h_null_q_d
 					    struct sk_buff_head *msdu_list,
 					    struct hal_rx_desc_data *rx_desc_data)
 {
