 	spin_lock_bh(&dp_hw->peer_lock);
 	mld_peer = ath12k_dp_peer_find(dp_hw, mld_peer->addr);
 	if (!mld_peer) {
-		spin_unlock_bh(&dp_hw->peer_lock);
 		ret = -ENOENT;
