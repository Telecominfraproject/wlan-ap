-		hal_tcl_desc = (void *)ath12k_hal_srng_src_begin_get_next_entry_nolock_fast(tcl_ring);
+		hal_tcl_desc =
+		(void *)ath12k_hal_srng_src_begin_get_next_entry_nolock_fast
+								(tcl_ring);
 		if (unlikely(!hal_tcl_desc)) {
 			/* NOTE: It is highly unlikely we'll be running out of tcl_ring
 			 * desc because the desc is directly enqueued onto hw queue.
@@ -973,7 +1049,10 @@ ath12k_wifi7_dp_tx(struct ath12k_pdev_dp *dp_pdev,
 			goto fail_remove_tx_buf;
 		}
 
-		memcpy(hal_tcl_desc, &tcl_desc, sizeof(tcl_desc));
+		ath12k_wifi7_dp_tx_populate_tcl_desc(dp_pdev, arvif,
