+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -1374,12 +1374,32 @@ int ath12k_mac_vdev_stop(struct ath12k_l
 {
 	struct ath12k_vif *ahvif = arvif->ahvif;
 	struct ath12k *ar = arvif->ar;
