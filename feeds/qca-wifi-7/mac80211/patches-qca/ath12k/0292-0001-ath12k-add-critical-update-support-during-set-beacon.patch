 		*flags |= WMI_VDEV_MBSSID_FLAGS_EMA_MODE;
@@ -10332,6 +10336,9 @@ int ath12k_mac_vdev_create(struct ath12k
 	spin_unlock_bh(&ar->ab->base_lock);
 
