 }
 
-static bool ath12k_mac_is_ml_arvif(struct ath12k_link_vif *arvif)
+bool ath12k_mac_is_ml_arvif(struct ath12k_link_vif *arvif)
 {
 	struct ath12k_vif *ahvif = arvif->ahvif;
 
