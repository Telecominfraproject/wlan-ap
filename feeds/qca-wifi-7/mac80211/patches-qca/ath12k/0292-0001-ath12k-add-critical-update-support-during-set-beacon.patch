 					params.aid = ahvif->aid;
@@ -9995,6 +9998,7 @@ static int ath12k_mac_setup_vdev_params_
 	} else {
 		return -EINVAL;
 	}
+	arvif->tx_vdev_id = *tx_vdev_id;
 
