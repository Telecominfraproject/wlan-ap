From fde05ace0a4b8cd6027e9fa87a7cf78528aa7e42 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Fri, 11 Jul 2025 15:32:25 +0530
Subject: [PATCH] QSDK: DP: wifi: ath12k: Set INVLDT_CACHE_FOR_ZERO_VLD bit in
 Reo General Enable Register

Set INVLDT_CACHE_FOR_ZERO_VLD bit in Reo General Enable Register as a WAR
to fix the issue of valid bit not getting set in the REO queues.

Patch-dependency: None

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/hal.h    | 1 +
 drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c | 3 ++-
 2 files changed, 3 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal.h b/drivers/net/wireless/ath/ath12k/wifi7/hal.h
index 6340775..1380d31 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal.h
@@ -339,6 +339,7 @@ extern const struct ath12k_hw_version_map ath12k_wifi7_hw_ver_map[];
 #define HAL_REO1_MISC_CTL_BAR_DST_RING			GENMASK(24, 21)
 #define HAL_REO1_GEN_ENABLE_AGING_LIST_ENABLE		BIT(2)
 #define HAL_REO1_GEN_ENABLE_AGING_FLUSH_ENABLE		BIT(3)
+#define HAL_REO1_GEN_ENABLE_INVLDT_CACHE_FOR_ZERO_VLD	BIT(28)
 #define HAL_REO1_SW_COOKIE_CFG_CMEM_BASE_ADDR_MSB	GENMASK(7, 0)
 #define HAL_REO1_SW_COOKIE_CFG_COOKIE_PPT_MSB		GENMASK(12, 8)
 #define HAL_REO1_SW_COOKIE_CFG_COOKIE_SPT_MSB		GENMASK(17, 13)
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
index 5d64da0..1bff1ef 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
@@ -985,7 +985,8 @@ void ath12k_wifi7_hal_reo_hw_setup(struct ath12k_base *ab, u32 ring_hash_map)
 	val = ath12k_hif_read32(ab, reo_base + HAL_REO1_GEN_ENABLE);
 
 	val |= u32_encode_bits(1, HAL_REO1_GEN_ENABLE_AGING_LIST_ENABLE) |
-	       u32_encode_bits(1, HAL_REO1_GEN_ENABLE_AGING_FLUSH_ENABLE);
+	       u32_encode_bits(1, HAL_REO1_GEN_ENABLE_AGING_FLUSH_ENABLE) |
+	       u32_encode_bits(1, HAL_REO1_GEN_ENABLE_INVLDT_CACHE_FOR_ZERO_VLD);
 	ath12k_hif_write32(ab, reo_base + HAL_REO1_GEN_ENABLE, val);
 
 	val = ath12k_hif_read32(ab, reo_base + HAL_REO1_MISC_CTRL_ADDR(hal));
-- 
2.34.1

