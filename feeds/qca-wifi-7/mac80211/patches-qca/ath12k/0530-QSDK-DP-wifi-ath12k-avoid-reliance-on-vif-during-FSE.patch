From 4d1b460677d30e25566c41d543ea088129fa6dfe Mon Sep 17 00:00:00 2001
From: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
Date: Tue, 9 Sep 2025 14:57:11 -0700
Subject: [PATCH] QSDK:DP:wifi:ath12k: avoid reliance on vif during FSE flow
 deletion

During FSE flow rule deletion, the VIF object may be null if the
interface has already been removed, leading to failed cleanup of the 
FST entry. This causes failure in subsequent FST rule addition in scenarios
where the flow has same parameters.

Fix this by removing the dependency on VIF and instead retrieving the
ab using wiphy_to_ieee80211_hw. Ensuring flow deletion proceeds
safely even when VIF is unavailable.

Patch-dependency:
	0337-01-QSDK-DP-wifi-Add-support-for-PPE-DS-Direct-switch-fe.patch

Fixes: I56018d1a5bb (0337-01-QSDK-DP-wifi-Add-support-for-PPE-DS-
Direct-switch-fe.patch)

Signed-off-by: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ppe.c |   18 ++++++++++--------
 1 file changed, 10 insertions(+), 8 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/ppe.c
+++ b/drivers/net/wireless/ath/ath12k/ppe.c
@@ -1994,8 +1994,10 @@ ath12k_dp_rx_ppeds_fse_add_flow_entry(st
 	wdev = dev->ieee80211_ptr;
 
 	vif = wdev_to_ieee80211_vif_vlan(wdev, false);
-	if (!vif)
+	if (!vif) {
+		pr_warn("FSE flow rule addition failed vif = NULL\n");
 		return false;
+	}
 
 	ahvif = ath12k_vif_to_ahvif(vif);
 
@@ -2039,10 +2041,9 @@ ath12k_dp_rx_ppeds_fse_del_flow_entry(st
 {
 	struct rx_flow_info flow_info = { 0 };
 	struct wireless_dev *wdev;
-	struct ieee80211_vif *vif;
 	struct ath12k_hw *ah;
+	struct ieee80211_hw *hw = NULL;
 	struct ath12k_base *ab = NULL;
-	struct ath12k_vif *ahvif;
 	struct net_device *dev = ppe_flow_info->dev;
 
 	if (!ath12k_fse_enable)
@@ -2053,13 +2054,14 @@ ath12k_dp_rx_ppeds_fse_del_flow_entry(st
 
 	wdev = dev->ieee80211_ptr;
 
-	vif = wdev_to_ieee80211_vif_vlan(wdev, false);
-	if (!vif)
-		return false;
+	hw = wiphy_to_ieee80211_hw(wdev->wiphy);
 
-	ahvif = ath12k_vif_to_ahvif(vif);
+	if (!hw) {
+		pr_warn("failed to find the ieee80211_hw for netdev %p\n", dev);
+		return false;
+	}
 
-	ah = ahvif->ah;
+	ah = hw->priv;
 	if (!ah) {
 		pr_warn("FSE flow rule deletion failed ah = NULL \n");
 		return false;
