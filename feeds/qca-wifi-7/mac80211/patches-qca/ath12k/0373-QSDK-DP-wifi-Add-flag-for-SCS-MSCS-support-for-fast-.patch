From d4e4dc0ab1c65be8cfa5f086902a16cd3585a0c7 Mon Sep 17 00:00:00 2001
From: Vivek Chettri <vchettri@qti.qualcomm.com>
Date: Tue, 24 Jun 2025 14:36:27 +0530
Subject: [PATCH 2/2] QSDK: DP: wifi: Add flag for SCS/MSCS support for fast
 path

SCS and MSCS fast path support requires the ECM to query the
SDWF meta data from WLAN driver.

Unlike SDWF where rules matching a service class is provisoined
via SPM, for SCS and MSCS the 5 tuple rule for a SCS/MSCS session
is programmed using nftables, and ECM tracks flow matching nftables
rules and queries WLAN driver for SDWF meta information.

To able to differentiate the query for SDWF meta data is for SCS/MSCS
or SDWF, add a field in the structure use to query the SDWF meta data
information.

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
---
 include/ath/ath_dp_accel_cfg.h | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/include/ath/ath_dp_accel_cfg.h b/include/ath/ath_dp_accel_cfg.h
index 38a0a4c..edba350 100644
--- a/include/ath/ath_dp_accel_cfg.h
+++ b/include/ath/ath_dp_accel_cfg.h
@@ -68,7 +68,8 @@ struct  sawf_param {
 struct	ath_dp_metadata_param {
 	uint8_t is_mlo_param_valid:1,
 		is_sawf_param_valid:1,
-		reserved:6;
+		is_scs_mscs:1,
+		reserved:5;
 	struct	mlo_param	mlo_param;
 	struct	sawf_param	sawf_param;
 };
