 	while (ATH12K_TX_COMPL_NEXT(tx_ring->tx_status_head) != tx_ring->tx_status_tail) {
-		desc = ath12k_hal_srng_dst_get_next_entry(ab, status_ring);
+		desc = ath12k_hal_srng_dst_get_next_cached_entry(ab, status_ring);
 		if (!desc)
 			break;
 
