+#define HTT_H2T_UMAC_RESET_MSG_TYPE     GENMASK(7, 0)
+#define HTT_H2T_UMAC_RESET_IS_INITIATOR_SET     BIT(8)
+#define HTT_H2T_UMAC_RESET_IS_TARGET_RECOVERY_SET       BIT(9)
