@@ -1576,6 +1576,31 @@ void ath12k_dp_tx_htt_rx_mgmt_flag0_mo_filter_set(u32 *ptr, u16 filter)
 				      (filter & FILTER_MGMT_ATIM) ? 1 : 0);
 }
 
