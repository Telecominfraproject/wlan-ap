+	HTT_RX_PKT_ENABLE_SUBTYPE_SET(*ptr, MD, MGMT, FLAGS0, ASSOC_RESP,
+				      (filter & FILTER_MGMT_ASSOC_RESP) ? 1 : 0);
+	HTT_RX_PKT_ENABLE_SUBTYPE_SET(*ptr, MD, MGMT, FLAGS0, REASSOC_REQ,
+				      (filter & FILTER_MGMT_REASSOC_REQ) ? 1 : 0);
