From ad64b24f8b981eeab67b5b76826753b961f37655 Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Date: Thu, 25 Sep 2025 16:22:09 +0530
Subject: [PATCH] QSDK:CP:wifi:ath12k:replace pr_devel with pr_info in
 ath12k_dbg()

eplace pr_devel() used in ath12k_dbg() with pr_info() when ab is NULL,
as pr_devel requires specific kernel config to be enabled and
may not produce output otherwise. This aligns with the behavior of ath12k_info().

Patch-dependency:none
Patch-work:none

Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debug.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/debug.c b/drivers/net/wireless/ath/ath12k/debug.c
index f9f07c9..6fd7721 100644
--- a/drivers/net/wireless/ath/ath12k/debug.c
+++ b/drivers/net/wireless/ath/ath12k/debug.c
@@ -76,7 +76,7 @@ void __ath12k_dbg(struct ath12k_base *ab, enum ath12k_debug_mask mask,
 		if (ab)
 			dev_dbg(ab->dev, "%pV", &vaf);
 		else
-			pr_devel("ath12k: %pV", &vaf);
+			pr_info("ath12k: %pV", &vaf);
 	}
 
 	/* TODO: trace log */
