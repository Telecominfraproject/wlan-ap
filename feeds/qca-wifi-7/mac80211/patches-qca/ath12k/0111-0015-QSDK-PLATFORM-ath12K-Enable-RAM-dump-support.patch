 		ab = ag->ab[i];
 		if (!ab)
 			continue;
 
+		ath12k_qmi_free_resource(ab);
 		ath12k_hif_power_up(ab);
 		ath12k_dbg(ab, ATH12K_DBG_BOOT, "reset started\n");
 	}
@@ -2242,5 +2246,30 @@ err_sc_free:
