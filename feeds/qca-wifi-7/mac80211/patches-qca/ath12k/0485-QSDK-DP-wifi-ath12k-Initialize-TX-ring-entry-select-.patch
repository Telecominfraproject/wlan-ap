From e39b3cf37598f4199a3d4cc3ecf982a0d10994db Mon Sep 17 00:00:00 2001
From: Sai Rupesh Chevuru <chevuru@qti.qualcomm.com>
Date: Tue, 5 Aug 2025 11:45:31 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Initialize TX ring entry select flag and
 clear scratch pad

This patch addresses a potential stability issues under TX ring full
conditions by initializing the TX ring entry select flag.
In certain cases uninitialized value could lead to parallel access of tx rings,
causing race conditions and system instability.
Additionally, the scratch pad memory is now explicitly cleared after freeing
SKBs to prevent stale pointer access.

Patch-dependency: None

Signed-off-by: Sai Rupesh Chevuru <chevuru@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index 6b76699..03d5053 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -839,7 +839,7 @@ ath12k_wifi7_dp_tx(struct ath12k_pdev_dp *dp_pdev,
 	int ret;
 	u16 peer_id;
 	u8 ring_selector, subtype, ring_map = 0;
-	bool tcl_ring_retry;
+	bool tcl_ring_retry = false;
 	bool msdu_ext_desc = false;
 	size_t hdrlen;
 	bool add_htt_metadata = false;
@@ -2161,6 +2161,7 @@ int ath12k_wifi7_dp_tx_completion_handler(struct ath12k_dp *dp, int ring_id, int
 								   sw_metadata->skb,
 								   tx_ring, sw_metadata,
 								   &ts, ring_id, htt_status);
+			sw_metadata->skb = NULL;
 			continue;
                 }
 
@@ -2190,6 +2191,7 @@ int ath12k_wifi7_dp_tx_completion_handler(struct ath12k_dp *dp, int ring_id, int
 			ath12k_wifi7_dp_tx_complete_msdu(dp_pdev, sw_metadata->skb, &ts,
 							 sw_metadata, sw_metadata->mac_id,
 							 ring_id);
+			sw_metadata->skb = NULL;
 		}
 
 		rcu_read_unlock();
-- 
2.34.1

