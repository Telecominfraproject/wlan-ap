From d2540611cb3487bf08680f2a439751b34a229ff5 Mon Sep 17 00:00:00 2001
From: Vignesh U <uvignesh@qti.qualcomm.com>
Date: Tue, 1 Jul 2025 10:01:13 +0530
Subject: [PATCH 1/5] UPSTREAM:PROTOCOL:ath12k: define puncture mask structures
 and constants for 6GHz PSD support

Introduce foundational definitions required to support minimum Power
Spectral Density (PSD) calculations for 6 GHz operation in ath12k. This
patch adds constants, macros, and data structures that will be used in
subsequent patches to compute regulatory masks and spectral power limits
based on channel puncturing configurations.

The patch defines puncture bitmap masks for 80, 160, and 320 MHz
bandwidths, along with special constants to represent invalid values used
in mask calculations. It also introduces scaling factors for Equivalent
Isotropically Radiated Power (EIRP) representation, which is necessary
because power values are expressed in hundredths of a decibel-milliwatts
unit.

A new structure, struct punct_mask, is introduced to represent offset
and decibel reduction values used in shaping the regulatory mask.
Additionally, an enumeration enum puncture_type is added to classify the
types of puncturing that can occur in a channel, such as edge puncture,
interim 20 MHz, and interim 20+ MHz configurations.

These definitions are essential for enabling Automated Frequency
Coordination (AFC) compliance in the 6 GHz band. AFC mandates dynamic PSD
adjustments based on frequency availability and interference constraints.
The structures and constants introduced here will enable precise shaping
of regulatory masks for both punctured and non-punctured channels.

This patch is self-contained and does not introduce any functional
changes. It serves as the base for subsequent patches that will implement
the logic for mask generation and PSD computation.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
ath12k/0346-10-wifi-ath12k-Add-6-GHz-switch-power-mode-support.patch

Signed-off-by: Vignesh U <uvignesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h |  1 +
 drivers/net/wireless/ath/ath12k/mac.h  | 62 ++++++++++++++++++++++++++
 2 files changed, 63 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index 0aad751..cb7ea96 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -824,6 +824,7 @@ struct ath12k_sta {
 #define ATH12K_INVALID_RSSI_EMPTY -128
 
 #define ATH12K_HALF_20MHZ_BW	10
+#define ATH12K_20MHZ_BW		20
 #define ATH12K_2GHZ_MIN_CENTER	2412
 #define ATH12K_2GHZ_MAX_CENTER	2484
 #define ATH12K_5GHZ_MIN_CENTER	4900
diff --git a/drivers/net/wireless/ath/ath12k/mac.h b/drivers/net/wireless/ath/ath12k/mac.h
index 7e9f076..e0f75b6 100644
--- a/drivers/net/wireless/ath/ath12k/mac.h
+++ b/drivers/net/wireless/ath/ath12k/mac.h
@@ -391,6 +391,68 @@ void ath12k_mac_bss_info_changed(struct ath12k *ar,
                                 struct ieee80211_bss_conf *info,
                                 u64 changed);
 int ath12k_mac_monitor_start(struct ath12k *ar);
+
+/* In the bitmap 0 indicates no puncturing and 1 indicated that sub channel is
+ * punctured
+ */
+#define ATH12K_PUNCTURE_INVALID		0xFFFF
+#define ATH12K_PUNCTURE_NONE		0x0000
+#define ATH12K_PUNCTURE_80MHZ_MASK	0x000F
+#define ATH12K_PUNCTURE_160MHZ_MASK	0x00FF
+#define ATH12K_PUNCTURE_320MHZ_MASK	0xFFFF
+#define ATH12K_PUNCTURE_40MHZ_MASK	0x0003
+
+/* Used to indicate an invalid edge in puncture mask calculations */
+#define ATH12K_INVALID_EDGE	0x0FFF
+/* Used to indicate an invalid dbr in puncture mask calculations */
+#define ATH12K_INVALID_DBR	100
+/* Used to indicate an invalid PSD in calculations */
+#define ATH12K_INVALID_PSD	(-1270) /* -127 multiplied by 10 */
+
+#define ATH12K_MAX_PUNC_MASK_LIMITS	3
+#define ATH12K_CHAN_MAX_PSD_POWER	127
+/* The eirp power values are in 0.01dBm units */
+#define ATH12K_EIRP_PWR_SCALE		100
+
+/**
+ * struct ath12k_punct_mask - Structure to hold puncture mask limits
+ * @offset: Array of offsets for puncture mask limits
+ * @dbr: Array of dbr values corresponding to the offsets
+ *
+ * This structure is used to define the puncture mask limits for different
+ * bandwidths. The `offset` array holds the offset values, and the `dbr` array
+ * holds the corresponding dbr values. The size of both arrays is defined by
+ * `MAX_PUNC_MASK_LIMITS`.
+ */
+struct ath12k_punct_mask {
+	s16 offset[ATH12K_MAX_PUNC_MASK_LIMITS];
+	s16 dbr[ATH12K_MAX_PUNC_MASK_LIMITS];
+};
+
+/**
+ * enum ath12k_puncture_type - Enumeration of puncture types
+ * @ATH12K_PUNCTURE_TYPE_EDGE: Represents edge puncture type
+ * @ATH12K_PUNCTURE_TYPE_INTERIM_20_PLUS: Represents interim puncture type with 20 MHz
+ * plus
+ * @ATH12K_PUNCTURE_TYPE_INTERIM_20: Represents interim puncture type with 20 MHz
+ * @ATH12K_PUNCTURE_TYPE_INVALID: Represents an invalid puncture type
+ * @ATH12K_PUNCTURE_TYPE_FIRST: Place holder to hold first value for boundary checks.
+ * @ATH12K_PUNCTURE_TYPE_LAST: Place holder to hold last value for boundary checks.
+ *
+ * This enumeration defines the different types of punctures that can occur
+ * within a given bandwidth. Each type specifies a unique puncture pattern
+ * and is used to determine the appropriate mask limits for the puncture.
+ */
+enum ath12k_puncture_type {
+	ATH12K_PUNCTURE_TYPE_EDGE = 0,
+	ATH12K_PUNCTURE_TYPE_INTERIM_20_PLUS,
+	ATH12K_PUNCTURE_TYPE_INTERIM_20,
+	ATH12K_PUNCTURE_TYPE_INVALID,
+
+	ATH12K_PUNCTURE_TYPE_FIRST = ATH12K_PUNCTURE_TYPE_EDGE,
+	ATH12K_PUNCTURE_TYPE_LAST  = ATH12K_PUNCTURE_TYPE_INTERIM_20,
+};
+
 enum ieee80211_neg_ttlm_res ath12k_mac_op_can_neg_ttlm(struct ieee80211_hw *hw,
 						       struct ieee80211_vif *vif,
 						       struct ieee80211_neg_ttlm *neg_ttlm);
