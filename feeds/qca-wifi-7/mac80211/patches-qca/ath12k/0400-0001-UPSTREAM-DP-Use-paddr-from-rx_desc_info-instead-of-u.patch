From c1686094b27a7272ac0929d717e6d57f3b2c4804 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 11 Jun 2025 15:12:18 +0530
Subject: [PATCH 01/21] UPSTREAM: DP: Use paddr from rx_desc_info instead of
 using from skb cb

Use paddr from rx_desc_info instead of using from skb cb to avoid
access to cb area of skb

Patch-dependency : None

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c          | 2 +-
 drivers/net/wireless/ath/ath12k/dp_rx.c       | 1 -
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 8 +++-----
 3 files changed, 4 insertions(+), 7 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index f054bbf..21ce682 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -1289,7 +1289,7 @@ static void ath12k_dp_cc_cleanup(struct ath12k_base *ab)
 			if (!skb)
 				continue;
 
-			ath12k_core_dma_unmap_single(ab->dev, ATH12K_SKB_RXCB(skb)->paddr,
+			ath12k_core_dma_unmap_single(ab->dev, desc_info[j].paddr,
 						     skb->len + skb_tailroom(skb), DMA_FROM_DEVICE);
 			dev_kfree_skb_any(skb);
 		}
diff --git a/drivers/net/wireless/ath/ath12k/dp_rx.c b/drivers/net/wireless/ath/ath12k/dp_rx.c
index 8691bb9..47ae08c 100644
--- a/drivers/net/wireless/ath/ath12k/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/dp_rx.c
@@ -386,7 +386,6 @@ int ath12k_dp_rx_bufs_replenish(struct ath12k_dp *dp,
 			goto fail_dma_unmap;
 
 		list_del(&rx_desc->list);
-		ATH12K_SKB_RXCB(skb)->paddr = paddr;
 
 		num_remain--;
 
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index 1b7eaf0..9ef656a 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -1447,7 +1447,7 @@ try_again:
 		list_add_tail(&desc_info->list, &rx_desc_used_list[device_id]);
 
 		rxcb = ATH12K_SKB_RXCB(msdu);
-		ath12k_core_dma_unmap_single(partner_dp->dev, rxcb->paddr,
+		ath12k_core_dma_unmap_single(partner_dp->dev, desc_info->paddr,
 					     msdu->len + skb_tailroom(msdu),
 					     DMA_FROM_DEVICE);
 
@@ -2042,7 +2042,6 @@ ath12k_wifi7_dp_process_rx_err_buf(struct ath12k_pdev_dp *dp_pdev,
 	struct hal_rx_desc_data rx_desc_data = {0};
 	struct hal_rx_desc *rx_desc;
 	struct sk_buff *msdu;
-	struct ath12k_skb_rxcb *rxcb;
 	u16 msdu_len;
 	u32 hal_rx_desc_sz = ab->hal.hal_desc_sz;
 	struct ath12k_rx_desc_info *desc_info;
@@ -2070,8 +2069,7 @@ ath12k_wifi7_dp_process_rx_err_buf(struct ath12k_pdev_dp *dp_pdev,
 
 	list_add_tail(&desc_info->list, used_list);
 
-	rxcb = ATH12K_SKB_RXCB(msdu);
-	ath12k_core_dma_unmap_single(ab->dev, rxcb->paddr,
+	ath12k_core_dma_unmap_single(ab->dev, desc_info->paddr,
 				     msdu->len + skb_tailroom(msdu),
 				     DMA_FROM_DEVICE);
 
@@ -2660,7 +2658,7 @@ int ath12k_wifi7_dp_rx_process_wbm_err(struct ath12k_dp *dp,
 		list_add_tail(&desc_info->list, &rx_desc_used_list[device_id]);
 
 		rxcb = ATH12K_SKB_RXCB(msdu);
-		ath12k_core_dma_unmap_single(partner_dp->dev, rxcb->paddr,
+		ath12k_core_dma_unmap_single(partner_dp->dev, desc_info->paddr,
 					     msdu->len + skb_tailroom(msdu),
 					     DMA_FROM_DEVICE);
 
-- 
