From c16ba077cdab1a7a4424063e165a4d373595c937 Mon Sep 17 00:00:00 2001
From: Karthik M <quic_karm@quicinc.com>
Date: Fri, 13 Dec 2024 15:48:04 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:wifi: Add ieee_link_id param during vdev
 create

Link-id in 2GHz/5GHz beacon perSta profile is 0 when CSA triggered at 6G Txvap.
It should be 2 as 6GHz is mapped to link-id 2.

During channel switch, per sta profile information will be populated based
on the hw_link_id. In upstream design, ieee_link_id will not be same as
hw_link_id. ieee_link_id for a link will not be same for
all vdev in a given pdev.

For example, consider Three MLD's
MLD 1 -  5GHz and 6GHz  (2link MLO)
MLD 2 -  6GHz           (1link SLO)
MLD 3 -  5GHz           (1link SLO)

Here the link ID assignment will be,

MLD 1 -  5GHz link (link id 0) and 6GHz link (link id 1)  -> 2 link MLO
MLD 2 -  6GHz link SLO (link id 0)                        -> 1 link SLO
MLD 3 -  5GHz link SLO (link id 0)                        -> 1 link SLO

FW need ieee_link_id through WMI during vdev start from
Host to correctly populate the values in per sta profile IE.
Add support to advertise ieee_link_id of both partner link and
self in wmi_vdev_start_mlo_params TLV

To assure backward compatability, Two flags has been introduced
for self and partner link. FW will parse the parameters based on these
flags.
1. ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID BIT(18)
2. ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID_PARTNER BIT(19)

Patch-work: None

Patch-dependency: FW

Co-developed-by: Hari Naraayana Desikan Kannan <quic_hnaraaya@quicinc.com>
Signed-off-by: Hari Naraayana Desikan Kannan <quic_hnaraaya@quicinc.com>
Signed-off-by: Karthik M <quic_karm@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/mac.c |  1 +
 drivers/net/wireless/ath/ath12k/wmi.c | 19 ++++++++++++++-----
 drivers/net/wireless/ath/ath12k/wmi.h |  2 ++
 3 files changed, 17 insertions(+), 5 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -11207,6 +11207,7 @@ ath12k_mac_mlo_get_vdev_args(struct ath1
 	 * link vdevs which are advertised as partners below
 	 */
 	ml_arg->link_add = true;
+	ml_arg->ieee_link_id = arvif->link_id;
 	partner_info = ml_arg->partner_info;
 
 	links = ahvif->links_map;
@@ -11230,6 +11231,7 @@ ath12k_mac_mlo_get_vdev_args(struct ath1
 
 		partner_info->vdev_id = arvif_p->vdev_id;
 		partner_info->hw_link_id = arvif_p->ar->pdev->hw_link_id;
+		partner_info->logical_link_idx = arvif_p->link_id;
 		ether_addr_copy(partner_info->addr, link_conf->addr);
 		ml_arg->num_partner_links++;
 		partner_info++;
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -1272,10 +1272,13 @@ int ath12k_wmi_vdev_start(struct ath12k
 				   le32_encode_bits(arg->ml.mcast_link,
 						    ATH12K_WMI_FLAG_MLO_MCAST_VDEV) |
 				   le32_encode_bits(arg->ml.link_add,
-						    ATH12K_WMI_FLAG_MLO_LINK_ADD);
+						    ATH12K_WMI_FLAG_MLO_LINK_ADD) |
+				   le32_encode_bits(1,
+						    ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID);
+		ml_params->ieee_link_id = arg->ml.ieee_link_id;
 
-		ath12k_dbg(ar->ab, ATH12K_DBG_WMI, "vdev %d start ml flags 0x%x\n",
-			   arg->vdev_id, ml_params->flags);
+		ath12k_dbg(ar->ab, ATH12K_DBG_WMI, "vdev %d start ml flags 0x%x ieee_link_id=%d\n",
+			   arg->vdev_id, ml_params->flags, ml_params->ieee_link_id);
 
 		ptr += sizeof(*ml_params);
 
@@ -1297,10 +1300,13 @@ int ath12k_wmi_vdev_start(struct ath12k
 				cpu_to_le32(arg->ml.partner_info[i].hw_link_id);
 			ether_addr_copy(partner_info->vdev_addr.addr,
 					arg->ml.partner_info[i].addr);
+			partner_info->ieee_link_id = arg->ml.partner_info[i].logical_link_idx;
+			partner_info->flags = le32_encode_bits(1,
+							       ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID_PARTNER);
 
-			ath12k_dbg(ar->ab, ATH12K_DBG_WMI, "partner vdev %d hw_link_id %d macaddr%pM\n",
+			ath12k_dbg(ar->ab, ATH12K_DBG_WMI, "partner vdev %d hw_link_id %d macaddr%pM flags:0x%x\n",
 				   partner_info->vdev_id, partner_info->hw_link_id,
-				   partner_info->vdev_addr.addr);
+				   partner_info->vdev_addr.addr, partner_info->flags);
 
 			partner_info++;
 		}
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2971,10 +2971,13 @@ struct wmi_vdev_create_mlo_params {
 #define ATH12K_WMI_FLAG_MLO_EMLSR_SUPPORT		BIT(6)
 #define ATH12K_WMI_FLAG_MLO_FORCED_INACTIVE		BIT(7)
 #define ATH12K_WMI_FLAG_MLO_LINK_ADD			BIT(8)
+#define ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID		BIT(18)
+#define ATH12K_WMI_FLAG_MLO_IEEE_LINK_IDX_VALID_PARTNER	BIT(19)
 
 struct wmi_vdev_start_mlo_params {
 	__le32 tlv_header;
 	__le32 flags;
+	__le32 ieee_link_id;
 } __packed;
 
 struct wmi_partner_link_info {
@@ -2982,6 +2985,8 @@ struct wmi_partner_link_info {
 	__le32 vdev_id;
 	__le32 hw_link_id;
 	struct ath12k_wmi_mac_addr_params vdev_addr;
+	__le32 flags;
+	__le32 ieee_link_id;
 } __packed;
 
 struct wmi_vdev_delete_cmd {
@@ -3145,6 +3150,7 @@ struct wmi_ml_arg {
 	bool assoc_link;
 	bool mcast_link;
 	bool link_add;
+	u32 ieee_link_id;
 	u8 num_partner_links;
 	struct wmi_ml_partner_info partner_info[ATH12K_WMI_MLO_MAX_LINKS];
 };
