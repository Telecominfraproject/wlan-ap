From 401b38f22e873aa05c91d9de1f698dc34e4e4229 Mon Sep 17 00:00:00 2001
From: Sathishkumar Muruganandam <murugana@qti.qualcomm.com>
Date: Mon, 7 Jul 2025 18:34:56 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: enable MD filter for NAC RSSI
 reporting

Since HW AST monitoring is currently enabled via
VDEV_FILTER_NEIGHBOR_RX_PACKETS_CMD for neighbor peers, MO filter
is no longer requied and MD filter should suffice the
HAL_RX_MPDU_START TLV update for neighbor peers.

Replaced NRP MAC address 2 field assignment with memcpy operations
from new inline function and fixed the RSSI update with nrp_info.

Patch-dependency: 0352-UPSTREAM-CP-wifi-ath12k-add-WBS-support-for
-ROC.patch
Feature: NAC RSSI

Signed-off-by: Sathishkumar Muruganandam <murugana@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h          |  6 ---
 .../net/wireless/ath/ath12k/dp_mon_filter.c   |  6 +--
 .../net/wireless/ath/ath12k/dp_mon_filter.h   |  7 ++++
 .../net/wireless/ath/ath12k/wifi7/dp_mon2.c   |  6 ++-
 .../net/wireless/ath/ath12k/wifi7/hal_mon.c   | 39 ++++++++++++-------
 5 files changed, 40 insertions(+), 24 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index b3d51d3497bc..db817822d5bd 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -909,12 +909,6 @@ static inline void ath12k_dp_get_mac_addr(u32 addr_l32, u16 addr_h16, u8 *addr)
 	memcpy(addr + 4, &addr_h16, ETH_ALEN - 4);
 }
 
-static inline void ath12k_dp_mon_get_mac_addr(u16 addr_l16, u32 addr_h32, u8 *addr)
-{
-	memcpy(addr, &addr_l16, 2);
-	memcpy(addr + 2, &addr_h32, ETH_ALEN - 2);
-}
-
 static inline struct ath12k_dp *
 ath12k_dp_hw_grp_to_dp(struct ath12k_dp_hw_group *dp_hw_grp, u8 device_id)
 {
diff --git a/drivers/net/wireless/ath/ath12k/dp_mon_filter.c b/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
index cbb0cd93d9a9..35422fa2a35e 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
@@ -530,10 +530,8 @@ ath12k_dp_mon_rx_setup_nrp_filters(struct ath12k_dp *dp,
 	rx_filter |= HTT_RX_FILTER_TLV_FLAGS_MPDU_END;
 
 	tlv_filter->rx_filter = rx_filter;
-	tlv_filter->enable_mo = 1;
-	tlv_filter->mo_mgmt_filter = FILTER_MGMT_ALL;
-	tlv_filter->mo_ctrl_filter = FILTER_CTRL_ALL;
-	tlv_filter->mo_data_filter = FILTER_DATA_ALL;
+	tlv_filter->enable_md = 1;
+	tlv_filter->md_data_filter = FILTER_DATA_ALL;
 
 	tlv_filter->rx_mon_mpdu_start_wmask =
 		ath12k_hal_mon_rx_mpdu_start_wmask(dp->hal);
diff --git a/drivers/net/wireless/ath/ath12k/dp_mon_filter.h b/drivers/net/wireless/ath/ath12k/dp_mon_filter.h
index 911610f4739b..ab30ccbc385f 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon_filter.h
+++ b/drivers/net/wireless/ath/ath12k/dp_mon_filter.h
@@ -32,6 +32,13 @@ enum dp_mon_filter_srng_type {
 	DP_MON_FILTER_SRNG_TYPE_MAX
 };
 
+enum dp_mpdu_filter_category {
+	DP_MPDU_FILTER_CATEGORY_FP,
+	DP_MPDU_FILTER_CATEGORY_MD,
+	DP_MPDU_FILTER_CATEGORY_MO,
+	DP_MPDU_FILTER_CATEGORY_FP_MO
+};
+
 int ath12k_dp_mon_rx_filter_alloc(struct ath12k_pdev_dp *dp_pdev);
 void ath12k_dp_mon_rx_filter_free(struct ath12k_pdev_dp *dp_pdev);
 void ath12k_dp_mon_rx_stats_config_filter(struct ath12k_pdev_dp *dp_pdev,
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
index 60c584dd8671..7b8531b632b9 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -269,6 +269,7 @@ int ath12k_dp_mon_rx_dual_ring_process(struct ath12k_pdev_dp *pdev_dp, int mac_i
 	int num_buffs_reaped = 0, srng_id, buf_id;
 	u32 hal_status, end_offset, info0, end_reason;
 	u8 pdev_idx = ath12k_hw_mac_id_to_pdev_id(ab->hw_params, pdev_dp->mac_id);
+	u8 filter_category = 0;
 
 	__skb_queue_head_init(&skb_list);
 	srng_id = ath12k_hw_mac_id_to_srng_id(ab->hw_params, pdev_idx);
@@ -377,12 +378,15 @@ move_next:
 		if (ppdu_info->peer_id == HAL_INVALID_PEERID)
 			goto free_skb;
 
+		filter_category = ppdu_info->userstats[ppdu_info->userid].filter_category;
 		rcu_read_lock();
 		spin_lock_bh(&dp->dp_lock);
 
 		if (!list_empty(&dp->neighbor_peers)) {
 			list_for_each_entry_safe(nrp, tmp, &dp->neighbor_peers, list) {
-				if (ether_addr_equal(nrp->addr, ppdu_info->addr2)) {
+				if (filter_category == DP_MPDU_FILTER_CATEGORY_MD &&
+					ether_addr_equal(nrp->addr,
+							 ppdu_info->nrp_info.mac_addr2)) {
 					nrp->rssi = ppdu_info->rssi_comb;
 					nrp->timestamp = ktime_to_ms(ktime_get_real());
 					goto next_skb;
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c
index f6f8a1bc482b..6ad0250d5f14 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_mon.c
@@ -1521,6 +1521,20 @@ ath12k_wifi7_hal_mon_rx_ppdu_eu_stats_info_get_compact(const void *tlv_data,
 	info[13] = __le32_to_cpu(ppdu_eu_stats->usr_resp_ref_ext);
 }
 
+static __always_inline void
+ath12k_wifi7_hal_mon_get_mac_addr(u32 addr_l32, u16 addr_h16, u8 *addr)
+{
+	memcpy(addr, &addr_l32, 4);
+	memcpy(addr + 4, &addr_h16, ETH_ALEN - 4);
+}
+
+static __always_inline void
+ath12k_wifi7_hal_mon_get_nrp_mac_addr(u16 addr_l16, u32 addr_h32, u8 *addr)
+{
+	memcpy(addr, &addr_l16, 2);
+	memcpy(addr + 2, &addr_h32, ETH_ALEN - 2);
+}
+
 enum hal_rx_mon_status
 ath12k_wifi7_hal_mon_rx_parse_status_tlv(struct ath12k_hal *hal,
 					 struct hal_rx_mon_ppdu_info *ppdu_info,
@@ -1720,8 +1734,8 @@ ath12k_wifi7_hal_mon_rx_parse_status_tlv(struct ath12k_hal *hal,
 		break;
 	}
 	case HAL_RX_MPDU_START: {
-		u16 peer_id;
-		u32 info[13];
+		u16 peer_id, addr_16;
+		u32 info[13], addr_32;
 
 		ath12k_hal_mon_rx_mpdu_start_info_get(hal, tlv_data, info);
 
@@ -1739,10 +1753,7 @@ ath12k_wifi7_hal_mon_rx_parse_status_tlv(struct ath12k_hal *hal,
 						    HAL_RX_MPDU_START_INFO5_MPDU_LEN);
 		ppdu_info->nrp_info.mac_addr2_valid =
 			u32_get_bits(info[3], HAL_RX_MPDU_START_INFO3_ADDR2_VALID);
-		*(u16 *)&ppdu_info->nrp_info.mac_addr2[0] =
-			u32_get_bits(info[7], HAL_RX_MPDU_START_INFO7_ADDR2_15_0);
-		*(u32 *)&ppdu_info->nrp_info.mac_addr2[2] =
-			u32_get_bits(info[8], HAL_RX_MPDU_START_INFO8_ADDR2_47_16);
+
 		ppdu_info->nrp_info.mcast_bcast =
 			u32_get_bits(info[5], HAL_RX_MPDU_START_INFO5_MCAST_BCAST);
 		ppdu_info->nrp_info.to_ds_flag =
@@ -1755,6 +1766,15 @@ ath12k_wifi7_hal_mon_rx_parse_status_tlv(struct ath12k_hal *hal,
 			u32_get_bits(info[6],
 				     HAL_RX_MPDU_START_INFO6_FC_FIELD);
 
+		addr_16 = u32_get_bits(info[7],
+				       HAL_RX_MPDU_START_INFO7_ADDR2_15_0);
+		addr_32 = u32_get_bits(info[8],
+				       HAL_RX_MPDU_START_INFO8_ADDR2_47_16);
+		if (ppdu_info->nrp_info.fc_valid &&
+		    ppdu_info->nrp_info.to_ds_flag &&
+		    ppdu_info->nrp_info.mac_addr2_valid)
+			ath12k_wifi7_hal_mon_get_nrp_mac_addr(addr_16, addr_32,
+							      ppdu_info->nrp_info.mac_addr2);
 		if (userid < HAL_MAX_UL_MU_USERS) {
 			ppdu_info->userid = userid;
 			ppdu_info->userstats[userid].sw_peer_id = peer_id;
@@ -1829,13 +1849,6 @@ ath12k_wifi7_hal_mon_rx_parse_status_tlv(struct ath12k_hal *hal,
 	return HAL_RX_MON_STATUS_PPDU_NOT_DONE;
 }
 
-static __always_inline void
-ath12k_wifi7_hal_mon_get_mac_addr(u32 addr_l32, u16 addr_h16, u8 *addr)
-{
-	memcpy(addr, &addr_l32, 4);
-	memcpy(addr + 4, &addr_h16, ETH_ALEN - 4);
-}
-
 enum hal_tx_mon_status
 ath12k_wifi7_hal_mon_tx_status_get_num_user(u16 tlv_tag,
 					    const void *tx_tlv,
-- 
2.25.1

