 {
 /*  From IEEE Std 802.11-2020 defined values for "Minimum MPDU Start Spacing":
@@ -3016,6 +3054,18 @@ static enum wmi_phy_mode ath12k_mac_get_
 	return MODE_UNKNOWN;
 }
 
