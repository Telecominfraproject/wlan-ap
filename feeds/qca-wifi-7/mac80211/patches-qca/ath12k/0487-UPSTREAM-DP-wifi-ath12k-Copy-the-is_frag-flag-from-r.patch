From 2c2fae6e8a161476584706cb801927da3a6dba3d Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Thu, 7 Aug 2025 10:55:57 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Copy the is_frag flag from
 reinjected packet.

Store the is_frag flag from reinject path into the sw rx desc.
Use it in the rx and wbm error paths as an indicator for
reinjected frag packet.

patch-dependency:
0400-0009-UPSTREAM-DP-Use-RX-HW-datastructures-in-rx-path.patch

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h          | 3 ++-
 drivers/net/wireless/ath/ath12k/dp_rx.c       | 2 ++
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 8 +++++++-
 3 files changed, 11 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 5210a94..26e392f 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -349,7 +349,8 @@ struct ath12k_rx_desc_info {
 	u32 cookie;
 	u8 in_use	: 1,
 	   device_id	: 3,
-	   reserved	: 4;
+	   is_frag	: 1,
+	   reserved	: 3;
 	struct sk_buff *skb;
 	u32 magic;
 	u64 rsvd0;
diff --git a/drivers/net/wireless/ath/ath12k/dp_rx.c b/drivers/net/wireless/ath/ath12k/dp_rx.c
index 272683f..f628a02 100644
--- a/drivers/net/wireless/ath/ath12k/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/dp_rx.c
@@ -414,6 +414,7 @@ static void ath12k_dp_rx_enqueue_free(struct ath12k_dp *dp,
 	/* Reset the use flag */
 	list_for_each_entry_safe(rx_desc, tmp_rx_desc, used_list, list) {
 		rx_desc->in_use = false;
+		rx_desc->is_frag = 0;
 
 		if (rx_desc->skb) {
 			skb = rx_desc->skb;
@@ -471,6 +472,7 @@ void ath12k_dp_rx_bufs_replenish(struct ath12k_dp *dp,
 		rx_desc->skb = skb;
 		rx_desc->paddr = paddr;
 		rx_desc->vaddr = skb->data;
+		rx_desc->is_frag = 0;
 	}
 
 	if (unlikely(is_dma_inv_done))
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index 11dac80..c8bc40c 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -1593,6 +1593,9 @@ int ath12k_wifi7_dp_rx_process(struct ath12k_dp *dp, int ring_id,
 		if (unlikely(desc_info->magic != ATH12K_DP_RX_DESC_MAGIC))
 			ath12k_warn(ab, "Check HW CC implementation");
 
+		mpdu_info->fragment_flag = desc_info->is_frag;
+		desc_info->is_frag = 0;
+
 		ath12k_core_dmac_inv_range_no_dsb(desc_info->vaddr,
 						  desc_info->vaddr + DP_RX_BUFFER_SIZE);
 
@@ -1818,7 +1821,6 @@ static int ath12k_wifi7_dp_rx_h_defrag(struct ath12k_pdev_dp *dp_pdev,
 
 	hdr = (struct ieee80211_hdr *)(first_frag->data + hal_rx_desc_sz);
 	hdr->frame_control &= ~__cpu_to_le16(IEEE80211_FCTL_MOREFRAGS);
-	ATH12K_SKB_RXCB(first_frag)->is_frag = 1;
 
 	if (ath12k_wifi7_dp_rx_h_verify_tkip_mic(dp_pdev, peer, enctype, first_frag,
 						 rx_desc_data))
@@ -1905,6 +1907,7 @@ ath12k_wifi7_dp_rx_h_defrag_reo_reinject(struct ath12k_dp *dp,
 	desc_info->in_use = true;
 	desc_info->paddr = buf_paddr;
 	desc_info->vaddr = defrag_skb->data;
+	desc_info->is_frag = 1;
 
 	list_del(&desc_info->list);
 	spin_unlock_bh(&dp->rx_desc_lock);
@@ -3058,11 +3061,14 @@ int ath12k_wifi7_dp_rx_process_wbm_err(struct ath12k_dp *dp,
 		rxcb->is_first_msdu = err_info.first_msdu;
 		rxcb->is_last_msdu = err_info.last_msdu;
 		rxcb->is_continuation = err_info.continuation;
+		rxcb->is_frag = desc_info->is_frag;
 		rxcb->peer_id =
 		ath12k_wifi7_dp_rx_get_peer_id(ab, dp->peer_metadata_ver,
 					       err_info.peer_metadata);
 		rxcb->rx_desc = msdu_data;
 
+		desc_info->is_frag = 0;
+
 		if (err_info.continuation) {
 			__skb_queue_tail(&scatter_msdu_list, msdu);
 			continue;
-- 
2.34.1

