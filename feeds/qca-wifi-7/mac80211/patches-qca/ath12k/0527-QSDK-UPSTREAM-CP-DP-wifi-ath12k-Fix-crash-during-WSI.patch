From 4eb31ef4a92300abc4270a9594d9429e43f2317a Mon Sep 17 00:00:00 2001
From: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
Date: Fri, 12 Sep 2025 14:21:23 +0530
Subject: [PATCH] QSDK:UPSTREAM:CP:DP:wifi:ath12k: Fix crash during WSI remap
 and umac reset

Driver needs to call ieee80211_stop_queues() before triggerring umac reset
during WSI remap sequence to not send packet during umac reset.

During umac reset tcl_data_ring and tcl_comp_ring are disabled and
not enabled back. This would cause TCL hung and trigger umac reset
with crash

Fixes: I293c6d248a57 ("UPSTREAM:DP:wifi:ath12k: Changes for supporting multiple archs")
Fixes: I8e46fb886e3 ("QSDK:Platform: wifi: ath12k: Add support for WSI HW link bypass
for power saving in multi-target systems"

Patch dependency:
0461-0002-QSDK-Platform-WSI-bypass-feature-support.patch
0500-0006-UPSTREAM-DP-Modularise-tcl-and-tx-completion-ring-se.patch

Signed-off-by: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c     | 13 ++++++++++++-
 drivers/net/wireless/ath/ath12k/dp.c       |  1 +
 drivers/net/wireless/ath/ath12k/dp.h       |  1 +
 drivers/net/wireless/ath/ath12k/wifi7/dp.c |  1 +
 4 files changed, 15 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.c b/drivers/net/wireless/ath/ath12k/core.c
index f3b544b..230f053 100644
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -4367,7 +4367,8 @@ static void ath12k_core_wsi_remap_reset(struct ath12k_base *ab)
 
 int ath12k_core_dynamic_wsi_remap(struct ath12k_base *ab)
 {
-	int ret = 0;
+	int ret = 0, i;
+	struct ath12k_hw *ah;
 	struct ath12k_hw_group *ag;
 
 	ag = ab->ag;
@@ -4375,8 +4376,18 @@ int ath12k_core_dynamic_wsi_remap(struct ath12k_base *ab)
 	ag->wsi_remap_in_progress = true;
 
 	ath12k_dbg(ab, ATH12K_DBG_WSI_BYPASS, "WSI Bypass: MLO teardown with Umac reset");
+	ath12k_core_mlo_hw_queues_stop(ab->ag);
+
 	ath12k_core_trigger_umac_reset(ab, WMI_MLO_TEARDOWN_REASON_DYNAMIC_WSI_REMAP);
 
+	for (i = 0; i < ag->num_hw; i++) {
+		ah = ag->ah[i];
+		if (!ah)
+			continue;
+
+		ieee80211_wake_queues(ah->hw);
+	}
+
 	if (ab->wsi_remap_state == ATH12K_WSI_BYPASS_REMOVE_DEVICE) {
 		/* Send WMI_PDEV_SUSPEND for the chip which is bypassed */
 		ret = ath12k_core_wsi_remap_pdev_suspend(ab);
diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index bd44826..e2f020a 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -2212,6 +2212,7 @@ void ath12k_umac_reset_handle_post_reset_start(struct ath12k_base *ab)
                 ath12k_warn(ab, "failed to setup link desc: %d\n", ret);
 
 	ath12k_dp_srng_common_setup(ab);
+	dp->arch_ops->dp_tx_ring_setup(ab);
         ath12k_dp_umac_txrx_desc_cleanup(ab);
 
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 03479a0..4b42e4c 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -502,6 +502,7 @@ struct ath12k_dp_arch_ops {
 	int (*sdwf_reinject_handler)(struct ath12k_pdev_dp *dp_pdev,
 				     struct ath12k_link_vif *arvif,
 				     struct sk_buff *skb, struct ath12k_link_sta *arsta);
+	int (*dp_tx_ring_setup)(struct ath12k_base *ab);
 };
 
 struct ath12k_bp_stats {
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp.c b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
index a8a15db..9b710ae 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp.c
@@ -344,6 +344,7 @@ static struct ath12k_dp_arch_ops ath12k_wifi7_dp_arch_ops = {
 	.dp_hw_group_alloc = ath12k_wifi7_dp_hw_group_alloc,
 	.peer_migrate_reo_cmd = ath12k_wifi7_dp_peer_migrate_reo_cmd,
 	.sdwf_reinject_handler = ath12k_wifi7_sdwf_reinject_handler,
+	.dp_tx_ring_setup = ath12k_wifi7_dp_tx_ring_setup,
 };
 
 /* TODO: remove export once this file is built with wifi7 ko */
