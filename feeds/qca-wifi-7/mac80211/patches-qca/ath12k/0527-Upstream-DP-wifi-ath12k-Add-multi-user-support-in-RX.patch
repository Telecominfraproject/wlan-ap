-	struct sk_buff_head mpdu_q;
+	struct hal_rx_mon_mpdu_info mpdu_info[HAL_MAX_UL_MU_USERS];
+	struct sk_buff_head mpdu_q[HAL_MAX_UL_MU_USERS];
