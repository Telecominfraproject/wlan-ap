@@ -320,7 +329,9 @@ static inline const char *ath12k_bd_ie_type_str(enum ath12k_bd_ie_type type)
 	case ATH12K_BD_IE_BOARD:
 		return "board data";
 	case ATH12K_BD_IE_REGDB:
-		return "regdb data";
