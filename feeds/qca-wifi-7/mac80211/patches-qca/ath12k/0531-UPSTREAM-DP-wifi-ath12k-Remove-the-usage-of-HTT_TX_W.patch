From 27de30f7c1e9832d82d6ef03adf0aed8fee3a513 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 10 Sep 2025 21:14:27 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Remove the usage of
 HTT_TX_WBM_COMP_STATUS_OFFSET

Remove the usage of HTT_TX_WBM_COMP_STATUS_OFFSET, as it is already
accounted for in the struct htt_tx_wbm_completion.

Patch-dependency:
0337-01-QSDK-DP-wifi-Add-support-for-PPE-DS-Direct-switch-fe.patch

Fixes: I56018d1a5bb6
(QSDK: DP: wifi: Package upgrade changes for datapath accelerator features)

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h     | 1 -
 drivers/net/wireless/ath/ath12k/dp_htt.h | 1 -
 drivers/net/wireless/ath/ath12k/dp_tx.h  | 2 +-
 3 files changed, 1 insertion(+), 3 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 96a9fa2..03479a0 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -22,7 +22,6 @@
 #define HTT_TCL_META_DATA_TYPE_SVC_ID_BASED	2
 #define HTT_TCL_META_DATA_SAWF_SVC_ID		GENMASK(10, 3)
 #define HTT_TCL_META_DATA_SAWF_TID_OVERRIDE	BIT(12)
-#define HTT_TX_WBM_COMP_STATUS_OFFSET 8
 
 #define HTT_TCL_META_DATA_TYPE_MISSION		GENMASK(1, 0)
 
diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.h b/drivers/net/wireless/ath/ath12k/dp_htt.h
index d768fa4..0e47810 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.h
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.h
@@ -42,7 +42,6 @@ struct ath12k_dp;
 #define HTT_TX_WBM_COMP_INFO3_VALID		BIT(21)
 
 #define ATH12K_DSCP_PRIORITY 7
-#define HTT_TX_WBM_COMP_STATUS_OFFSET 8
 
 #define SDWF_PEER_ID_SHIFT 0x6
 #define SDWF_PEER_ID_MASK 0x3ff
diff --git a/drivers/net/wireless/ath/ath12k/dp_tx.h b/drivers/net/wireless/ath/ath12k/dp_tx.h
index b8adacd..99ff21e 100644
--- a/drivers/net/wireless/ath/ath12k/dp_tx.h
+++ b/drivers/net/wireless/ath/ath12k/dp_tx.h
@@ -35,7 +35,7 @@ static inline bool ath12k_dp_tx_completion_valid(struct hal_wbm_release_ring *de
 
 	if (FIELD_GET(HAL_WBM_COMPL_TX_INFO0_REL_SRC_MODULE, desc->info0) ==
 			HAL_WBM_REL_SRC_MODULE_FW) {
-		status_desc = (struct htt_tx_wbm_completion *)(((u8 *)desc) + HTT_TX_WBM_COMP_STATUS_OFFSET);
+		status_desc = (struct htt_tx_wbm_completion *)desc;
 
 		/* Dont consider HTT_TX_COMP_STATUS_MEC_NOTIFY */
 		if (FIELD_GET(HTT_TX_WBM_COMP_INFO0_STATUS, status_desc->info0) ==
-- 
2.34.1

