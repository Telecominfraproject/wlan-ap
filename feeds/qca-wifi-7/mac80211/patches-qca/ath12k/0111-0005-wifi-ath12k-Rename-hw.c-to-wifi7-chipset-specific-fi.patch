From d3d65aa792935e04c12a642577f332ce5778bc77 Mon Sep 17 00:00:00 2001
From: Kiran Venkatappa <quic_kiranv@quicinc.com>
Date: Thu, 30 Jan 2025 20:48:36 +0530
Subject: [PATCH 05/11] wifi: ath12k: Rename hw.c to wifi7 chipset specific
 file

hw.c has configs specific to wifi7 chipset family. Rename this file to
hw_wifi7.c. This is done in preprartion to add separate module for
hw dependent code.

Tested-on: QCN9274 hw2.0 PCI WLAN.WBE.1.3.1-00173-QCAHKSWPL_SILICONZ-1
Tested-on: WCN7850 hw2.0 PCI WLAN.HMT.1.0.c5-00481-QCAHMTSWPL_V1.0_V2.0_SILICONZ-3

Signed-off-by: Kiran Venkatappa <quic_kiranv@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/Makefile             | 2 +-
 drivers/net/wireless/ath/ath12k/{hw.c => hw_wifi7.c} | 0
 2 files changed, 1 insertion(+), 1 deletion(-)
 rename drivers/net/wireless/ath/ath12k/{hw.c => hw_wifi7.c} (100%)

diff --git a/drivers/net/wireless/ath/ath12k/Makefile b/drivers/net/wireless/ath/ath12k/Makefile
index fb968884f656..f1105d7adaff 100644
--- a/drivers/net/wireless/ath/ath12k/Makefile
+++ b/drivers/net/wireless/ath/ath12k/Makefile
@@ -18,7 +18,7 @@ ath12k-y += core.o \
 	    ce_wifi7.o \
 	    peer.o \
 	    dbring.o \
-	    hw.o \
+	    hw_wifi7.o \
 	    mhi.o \
 	    mhi_wifi7.o \
 	    pci.o \
diff --git a/drivers/net/wireless/ath/ath12k/hw.c b/drivers/net/wireless/ath/ath12k/hw_wifi7.c
similarity index 100%
rename from drivers/net/wireless/ath/ath12k/hw.c
rename to drivers/net/wireless/ath/ath12k/hw_wifi7.c
-- 
