From 06098887837cf8d2dc334cbfece25117cc333b8b Mon Sep 17 00:00:00 2001
From: Narendhar Reddy <nare@qti.qualcomm.com>
Date: Sat, 12 Jul 2025 12:51:04 +0530
Subject: [PATCH] QSDK:PLATFORM ath12k:Fix warnings when CONFIG_DEBUG_LOCKDEP is enabled

1. Ensure ag mutex is held before creating a hw group.
2. Use lockdep_assert_wiphy for wiphy lock
3. Ensure ag mutex is held before setting hw group as
   mlo capable

Fixes: I45b66a1f1dc (CP: wifi: ath12k: PKG upgrade changes set 5)
Signed-off-by: Narendhar Reddy <nare@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c | 2 ++
 drivers/net/wireless/ath/ath12k/peer.c | 2 +-
 drivers/net/wireless/ath/ath12k/qmi.c  | 4 +---
 3 files changed, 4 insertions(+), 4 deletions(-)
--- a/drivers/net/wireless/ath/ath12k/peer.c
+++ b/drivers/net/wireless/ath/ath12k/peer.c
@@ -149,7 +149,7 @@ int ath12k_peer_delete(struct ath12k *ar
 {
 	int ret;
 
-	lockdep_assert_held(ath12k_ar_to_hw(ar)->wiphy);
+	lockdep_assert_wiphy(ath12k_ar_to_hw(ar)->wiphy);
 
 	ret = __ath12k_peer_delete(ar, vdev_id, addr);
 	if (ret)
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -4238,18 +4238,18 @@ int ath12k_core_init(struct ath12k_base
 	ath12k_dbg(ab, ATH12K_DBG_BOOT, "num devices %d num probed %d\n",
 		   ag->num_devices, ag->num_probed);
 
-	// TODO: fix the the locking sequence
 	mutex_lock(&ag->mutex);
 	is_ready = ath12k_core_hw_group_create_ready(ag);
-	mutex_unlock(&ag->mutex);
 
 	if (is_ready) {
 		ret = ath12k_core_hw_group_create(ag);
 		if (ret) {
 			ath12k_warn(ab, "unable to create hw group\n");
+			mutex_unlock(&ag->mutex);
 			goto err;
 		}
 	}
+	mutex_unlock(&ag->mutex);
 
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
 	/* Used for tracking the order of per ab's DS node in bringup sequence
--- a/drivers/net/wireless/ath/ath12k/qmi.c
+++ b/drivers/net/wireless/ath/ath12k/qmi.c
@@ -5667,9 +5667,8 @@ int ath12k_qmi_event_server_arrive(struc
 		/* Coldboot calibration mode */
 		ath12k_qmi_trigger_host_cap(ab);
 	} else {
-		ath12k_core_hw_group_set_mlo_capable(ag);
 		mutex_lock(&ag->mutex);
-
+		ath12k_core_hw_group_set_mlo_capable(ag);
 		if (ath12k_qmi_hw_group_host_cap_ready(ag)) {
 
 			for (i = 0; i < ag->num_devices; i++) {
