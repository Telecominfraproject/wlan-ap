From f003deacd27c7572f8d825f86d4c38ec4c3c0305 Mon Sep 17 00:00:00 2001
From: Amith A <amitajit@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 11:35:48 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: ath12k: Add an ath12k_ops to fetch
 AFC EIRP

Add an ath12k_ops, 'get_afc_eirp_pwr' to fetch the AFC value for a
given frequency from AFC payload if AFC power event is received.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Path-dependency:
subsys/0332-02-UPSTREAM-PROTOCOL-wifi-mac80211-Add-a-mac80211_config_op.patch

Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 17 +++++++++++++++++
 drivers/net/wireless/ath/ath12k/mac.h |  2 ++
 2 files changed, 19 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -23558,3 +23558,35 @@ int ath12k_mac_dynamic_wsi_remap(struct
 
 	return ret;
 }
+
+static struct ath12k *ath12k_mac_get_ar_by_center_freq(struct ieee80211_hw *hw,
+						       u16 center_freq)
+{
+	struct ath12k_hw *ah = hw->priv;
+	struct ath12k *ar;
+	int i;
+
+	for_each_ar(ah, ar, i) {
+		if (center_freq >= ar->chan_info.low_freq &&
+		    center_freq <= ar->chan_info.high_freq)
+			return ar;
+	}
+
+	return NULL;
+}
+
+int ath12k_mac_op_get_afc_eirp_pwr(struct ieee80211_hw *hw,
+				   u32 freq,
+				   u32 *eirp_pwr)
+{
+	struct ath12k *ar;
+
+	ar = ath12k_mac_get_ar_by_center_freq(hw, freq);
+	if (ar && ar->afc.is_6ghz_afc_power_event_received)
+		*eirp_pwr = ath12k_mac_get_afc_eirp_power(ar, freq, freq, 20);
+	else
+		*eirp_pwr = ATH12K_MAX_TX_POWER;
+
+	return 0;
+}
+EXPORT_SYMBOL(ath12k_mac_op_get_afc_eirp_pwr);
--- a/drivers/net/wireless/ath/ath12k/mac.h
+++ b/drivers/net/wireless/ath/ath12k/mac.h
@@ -654,4 +654,13 @@ int __ath12k_mac_mlo_setup(struct ath12k
 int ath12k_mac_dynamic_wsi_remap(struct ath12k_base *ab);
 void ath12k_mac_add_bridge_vdevs_iter(void *data, u8 *mac,
 				      struct ieee80211_vif *vif);
+
+/**
+ * ath12k_mac_op_get_afc_eirp_pwr - Get the 6 GHz AFC EIRP power value
+ * @hw: Input hardware
+ * @freq: Input freq
+ * @eirp_pwr: Output EIRP power
+ */
+int ath12k_mac_op_get_afc_eirp_pwr(struct ieee80211_hw *hw, u32 freq,
+				   u32 *eirp_pwr);
 #endif
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -1718,6 +1718,7 @@ static const struct ieee80211_ops ath12k
 	.set_radar_background           = ath12k_mac_op_set_radar_background,
 	.erp                            = ath12k_mac_op_erp,
 	.qos_mgmt_cfg                   = ath12k_mac_op_qos_mgmt_cfg,
+	.get_afc_eirp_pwr               = ath12k_mac_op_get_afc_eirp_pwr,
 };
 
 int ath12k_wifi7_hw_init(struct ath12k_base *ab)
