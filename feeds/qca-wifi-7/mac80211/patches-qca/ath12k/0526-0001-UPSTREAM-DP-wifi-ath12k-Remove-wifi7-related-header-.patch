-		spin_lock_bh(&ar->data_lock);
-		channel = ar->rx_channel;
-		if (channel) {
-			rxs->band = channel->band;
-			channel_num =
-				ieee80211_frequency_to_channel(channel->center_freq);
-		}
-		spin_unlock_bh(&ar->data_lock);
-	}
-
-	if (rxs->band < NUM_NL80211_BANDS)
