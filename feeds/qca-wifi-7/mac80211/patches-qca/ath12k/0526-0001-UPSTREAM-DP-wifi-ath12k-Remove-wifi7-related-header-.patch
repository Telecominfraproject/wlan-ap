-#include "wifi7/hal_qcn9274.h"
 #include "debugfs.h"
 #include "dp_mon_filter.h"
 
@@ -82,235 +81,6 @@ ath12k_dp_mon_fill_rx_stats_info(struct hal_rx_mon_ppdu_info *ppdu_info,
 }
