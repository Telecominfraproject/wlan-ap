From e1e86cbf9af681e9b83c9d18f50e5abf8450c5e6 Mon Sep 17 00:00:00 2001
From: Kenvish Butani <kbutani@qti.qualcomm.com>
Date: Thu, 11 Sep 2025 12:02:55 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Access DP vif under wiphy lock

Currently DP vif is dereferenced from ahvif outside of
wiphy lock, this may result in potential race conditions
where ahvif could get freed by mac80211.

This change will access dp vif from ahvif within wiphy
lock and wiphy lock shall prevent ahvif getting deleted
from mac80211.

Fixes:
Ic509d766796 (UPSTREAM: DP: wifi: ath12k: DP Telemetry in Tx Enqueue)

Patch-dependency:
0425-0002-UPSTREAM-DP-wifi-ath12k-DP-Telemetry-in-Tx-Enqueue.patch

Signed-off-by: Kenvish Butani <kbutani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs.c | 17 ++++++++++++-----
 1 file changed, 12 insertions(+), 5 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs.c b/drivers/net/wireless/ath/ath12k/debugfs.c
index 620d329..8abae75 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs.c
@@ -2852,16 +2852,23 @@ static ssize_t ath12k_read_mld_stats(struct file *file,
 	if (!ahvif)
 		return -EINVAL;
 
+	if (!ahvif->ah->hw->wiphy)
+		return -EINVAL;
+
+	wiphy = ahvif->ah->hw->wiphy;
+	wiphy_lock(wiphy);
+
 	dp_vif = &ahvif->dp_vif;
-	if (!dp_vif)
+	if (!dp_vif) {
+		wiphy_unlock(wiphy);
 		return -EINVAL;
+	}
 
 	buf = kzalloc(buf_len, GFP_KERNEL);
-	if (!buf)
+	if (!buf) {
+		wiphy_unlock(wiphy);
 		return -ENOMEM;
-
-	wiphy = ahvif->ah->hw->wiphy;
-	wiphy_lock(wiphy);
+	}
 
 	len += scnprintf(buf + len, buf_len - len,
 			 "Tx Packets Received from Stack\n");
-- 
