From 72559af2a27b8ab6fada77262b32c91ff35ad70e Mon Sep 17 00:00:00 2001
From: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Date: Mon, 23 Jun 2025 16:06:13 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: Add sanity checks for peer search

This patch is to fix following 3 issues:
1. In API ath12k_dp_link_peer_find_by_peerid_index, sanity check for
   hw_link_id is compared against ATH12K_NUM_MAX_LINKS which is incorrect
   and this may lead to out-of-bound access and hence result in corruption.

   This sanity check is to be done against ATH12K_GROUP_MAX_RADIO.
   Update proper sanity check in peer search API.

2. Sanity check for peer id is missing while searching for link peer in
   regular per pkt Rx path. Add sanity check for the same.

3. Peer id setting in dp_peer for non-mlo client is missing.
   Add code to set peer_id in dp_peer during link peer assignment.

Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_peer.c | 6 +++++-
 drivers/net/wireless/ath/ath12k/dp_rx.c   | 3 ++-
 2 files changed, 7 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_peer.c b/drivers/net/wireless/ath/ath12k/dp_peer.c
index c60c2fa..f37a9c0 100644
--- a/drivers/net/wireless/ath/ath12k/dp_peer.c
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.c
@@ -500,7 +500,7 @@ ath12k_dp_link_peer_find_by_peerid_index(struct ath12k_dp *dp,
 	RCU_LOCKDEP_WARN(!rcu_read_lock_held(),
 			 "ath12k dp link peer find by peerid index called without rcu lock");
 
-	if (dp_pdev->hw_link_id >= ATH12K_NUM_MAX_LINKS)
+	if (dp_pdev->hw_link_id >= ATH12K_GROUP_MAX_RADIO)
 		return NULL;
 
 	dp_peer = ath12k_dp_peer_find_by_peerid_index(dp, dp_pdev, peer_id);
@@ -620,6 +620,10 @@ int ath12k_dp_link_peer_assign(struct ath12k_dp *dp, u8 pdev_idx, u8 vdev_id,
 		goto err_dp_peer;
 	}
 
+	/* Set peer_id in dp_peer for non-mlo client, peer_id for mlo client is
+	   set during dp_peer create */
+	if (!dp_peer->is_mlo)
+		dp_peer->peer_id = peer->peer_id;
 	peer->dp_peer = dp_peer;
 	peer->hw_link_id = hw_link_id;
 	peer->tcl_metadata |= u32_encode_bits(0, HTT_TCL_META_DATA_TYPE) |
diff --git a/drivers/net/wireless/ath/ath12k/dp_rx.c b/drivers/net/wireless/ath/ath12k/dp_rx.c
index 1becfe9..1e54469 100644
--- a/drivers/net/wireless/ath/ath12k/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/dp_rx.c
@@ -1009,7 +1009,8 @@ void ath12k_dp_rx_deliver_msdu(struct ath12k_pdev_dp *dp_pdev,
 
 	pubsta = peer ? peer->sta : NULL;
 
-	link_peer = ath12k_dp_link_peer_find_by_peerid_index(dp, dp_pdev, rxcb->peer_id);
+	if (rxcb->peer_id)
+		link_peer = ath12k_dp_link_peer_find_by_peerid_index(dp, dp_pdev, rxcb->peer_id);
 
 	if (pubsta && pubsta->valid_links) {
 		status->link_valid = 1;
