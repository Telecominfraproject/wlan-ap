From 32b15b20dbffced4ae7d65fa0c20a6de3389023e Mon Sep 17 00:00:00 2001
From: Nagarajan Maran <nmaran@qti.qualcomm.com>
Date: Thu, 21 Aug 2025 15:47:36 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k: Change default QoS Service
 Interval value

Update the default values of QoS DL and UL Service Interval
from "0xFFFFFFFF" to "0", as required by firmware.

Patch-dependency: 0415-0001-UPSTREAM-CP-wifi-ath12k-Add-APIs-to-configure-QoS-pa.patch
Patch-work: None

Signed-off-by: Nagarajan Maran <nmaran@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/qos.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/qos.h b/drivers/net/wireless/ath/ath12k/qos.h
index e37b148b3562..5402ccd21980 100644
--- a/drivers/net/wireless/ath/ath12k/qos.h
+++ b/drivers/net/wireless/ath/ath12k/qos.h
@@ -65,7 +65,7 @@ enum QOS_PARAM_DEFAULTS {
 	QOS_PARAM_DEFAULT_MIN_THROUGHPUT = 0,
 	QOS_PARAM_DEFAULT_MAX_THROUGHPUT = 0xffffffff,
 	QOS_PARAM_DEFAULT_BURST_SIZE     = 0,
-	QOS_PARAM_DEFAULT_SVC_INTERVAL   = 0xffffffff,
+	QOS_PARAM_DEFAULT_SVC_INTERVAL   = 0,
 	QOS_PARAM_DEFAULT_DELAY_BOUND    = 0xffffffff,
 	QOS_PARAM_DEFAULT_TIME_TO_LIVE   = 0xffffffff,
 	QOS_PARAM_DEFAULT_PRIORITY       = 0,
-- 
2.34.1

