From acc9965a22977996069b36786c34c2f674ead800 Mon Sep 17 00:00:00 2001
From: Raj Kumar Bhagat <quic_rajkbhag@quicinc.com>
Date: Wed, 5 Jul 2023 15:33:15 +0530
Subject: [PATCH 2/2] ath12k: apply real noise floor offset instead of
 ATH12K_DEFAULT_NOISE_FLOOR

ATH12K_DEFAULT_NOISE_FLOOR is the approximate noise floor value of
the HW, that is used for rssi calculation. Hence use real noise floor
offset value for the calculation of the signal strength. This offset
is saved in ath12k structure (ar->rssi_offsets.rssi_offset) and it is
updated periodically by firmware through wmi event
WMI_PDEV_RSSI_DBM_CONVERSION_PARAMS_INFO_EVENTID.

Signed-off-by: Raj Kumar Bhagat <quic_rajkbhag@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/dp_mon.c | 5 +++--
 drivers/net/wireless/ath/ath12k/dp_tx.c  | 4 ++--
 drivers/net/wireless/ath/ath12k/mac.c    | 5 ++---
 drivers/net/wireless/ath/ath12k/wmi.c    | 2 +-
 4 files changed, 8 insertions(+), 8 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/dp_mon.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.c
@@ -2021,7 +2021,7 @@ static void ath12k_dp_mon_update_radiota
 	u8 *ptr = NULL;
 
 	rxs->flag |= RX_FLAG_MACTIME_START;
-	rxs->signal = ppduinfo->rssi_comb + ATH12K_DEFAULT_NOISE_FLOOR;
+	rxs->signal = (s8)(ppduinfo->rssi_comb + dp_pdev->ar->rssi_offsets.rssi_offset);
 	rxs->nss = ppduinfo->nss + 1;
 
 	if (ppduinfo->userstats[ppduinfo->userid].ampdu_present) {
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -13212,7 +13212,7 @@ void ath12k_mac_op_sta_statistics(struct
 	struct ath12k_link_sta *arsta;
 	struct ath12k *ar;
 	struct ath12k_base *ab;
-	s8 signal;
+	s8 signal, rssi_signal, rssi_offset;
 	bool db2dbm;
 	struct ath12k_dp *dp;
 	struct ath12k_dp_link_peer_rate_info rate_info = {0};
@@ -13258,9 +13258,12 @@ void ath12k_mac_op_sta_statistics(struct
 	}
 
 	spin_unlock_bh(&ab->base_lock);
-	/* TODO: Use real NF instead of default one. */
-	signal = rate_info.rssi_comb;
+	rssi_offset = rate_info.rssi_comb + ar->rssi_offsets.rssi_offset;
+	rssi_signal = rate_info.rssi_comb > ar->rssi_offsets.xlna_bypass_threshold ?
+		      rssi_offset + ar->rssi_offsets.xlna_bypass_offset :
+		      rssi_offset;
 
+	signal = rate_info.rssi_comb;
 	params.pdev_id = ar->pdev->pdev_id;
 	params.vdev_id = 0;
 	params.stats_id = WMI_REQUEST_VDEV_STAT;
@@ -13281,14 +13284,14 @@ void ath12k_mac_op_sta_statistics(struct
 		ath12k_mac_put_chain_rssi(sinfo, arsta);
 
 	if (signal) {
-		sinfo->signal = db2dbm ? signal : signal + ATH12K_DEFAULT_NOISE_FLOOR;
+		sinfo->signal = db2dbm ? rate_info.rssi_comb : rssi_signal;
 		sinfo->filled |= BIT_ULL(NL80211_STA_INFO_SIGNAL);
 	}
 
 	sinfo->signal_avg = rate_info.signal_avg;
 
 	if (!db2dbm)
-		sinfo->signal_avg += ATH12K_DEFAULT_NOISE_FLOOR;
+		sinfo->signal_avg += ar->rssi_offsets.rssi_offset;
 
 	sinfo->filled |= BIT_ULL(NL80211_STA_INFO_SIGNAL_AVG);
 }
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -7334,7 +7334,7 @@ static void ath12k_mgmt_rx_event(struct
 		status->freq = ieee80211_channel_to_frequency(rx_ev.channel,
 							      status->band);
 
-	status->signal = rx_ev.snr + ATH12K_DEFAULT_NOISE_FLOOR;
+	status->signal = rx_ev.snr + ar->rssi_offsets.rssi_offset;
 	status->rate_idx = ath12k_mac_bitrate_to_idx(sband, rx_ev.rate / 100);
 
 	hdr = (struct ieee80211_hdr *)skb->data;
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -502,7 +502,8 @@ ath12k_wifi7_dp_tx_htt_tx_complete_buf(s
 	if (ts->acked) {
 		if (!(info->flags & IEEE80211_TX_CTL_NO_ACK)) {
 			info->flags |= IEEE80211_TX_STAT_ACK;
-			info->status.ack_signal = ts->ack_rssi;
+			info->status.ack_signal = ar->rssi_offsets.rssi_offset +
+						  ts->ack_rssi;
 
 			if (!test_bit(WMI_TLV_SERVICE_HW_DB2DBM_CONVERSION_SUPPORT,
 				      ab->wmi_ab.svc_map))
@@ -768,7 +769,8 @@ static void ath12k_wifi7_dp_tx_complete_
 	case HAL_WBM_TQM_REL_REASON_FRAME_ACKED:
 		if (!(info->flags & IEEE80211_TX_CTL_NO_ACK)) {
 			info->flags |= IEEE80211_TX_STAT_ACK;
-			info->status.ack_signal = ts->ack_rssi;
+			info->status.ack_signal = dp_pdev->ar->rssi_offsets.rssi_offset +
+						  ts->ack_rssi;
 
 			if (!test_bit(WMI_TLV_SERVICE_HW_DB2DBM_CONVERSION_SUPPORT,
 				      ab->wmi_ab.svc_map))
