From 73ee7dac357ce2222e0213ad48aba4a6515850c1 Mon Sep 17 00:00:00 2001
From: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Date: Mon, 7 Jul 2025 10:42:00 -0700
Subject: [PATCH 07/24] QSDK:CP:wifi:ath12K: register handler for peer info

Configure handler for peer information to be called by telemetry
agent for processing data.

Patch-dependency:
0462-06-QSDK-CP-wifi-ath12K-register-handler-for-pdev-info.patch

Signed-off-by: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 .../wireless/ath/ath12k/telemetry_agent_if.c  | 24 +++++++++++++------
 1 file changed, 17 insertions(+), 7 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/telemetry_agent_if.c
+++ b/drivers/net/wireless/ath/ath12k/telemetry_agent_if.c
@@ -361,6 +361,27 @@ int ath12k_get_pdev_info(void *obj, stru
 	return 0;
 }
 
+int ath12k_get_peer_info(void *obj, struct agent_peer_iface_init_obj *stats)
+{
+	struct ath12k_dp_link_peer *peer = (struct ath12k_dp_link_peer *)obj;
+
+	if (!peer)
+		return -EINVAL;
+
+	if (peer->is_bridge_peer)
+		return -EINVAL;
+
+	memset(stats, 0, sizeof(*stats));
+	ether_addr_copy(stats->peer_mld_mac, peer->ml_addr);
+	ether_addr_copy(stats->peer_link_mac, peer->addr);
+
+	ath12k_dbg(NULL, ATH12K_DBG_RM,
+		   "peer info peer: %p addr: %pM ml addr: %pM\n",
+		   peer, peer->addr, peer->ml_addr);
+
+	return 0;
+}
+
 int register_telemetry_agent_ops(struct telemetry_agent_ops *agent_ops)
 
 {
@@ -403,12 +424,6 @@ int ath12k_get_pdev_stats(void *obj, str
 	return -1;
 }
 
-int ath12k_get_peer_info(void *obj, struct agent_peer_iface_init_obj *stats)
-{
-	ath12k_err(NULL, "ath12k_get_peer_info - not implemented \n");
-	return -1;
-}
-
 int ath12k_get_peer_stats(void *obj, struct agent_peer_iface_stats_obj *stats)
 {
 	ath12k_err(NULL, "ath12k_get_peer_stats - not implemented \n");
