From b32fc0fb98e604a78823c83762bbd0768dd57bcc Mon Sep 17 00:00:00 2001
From: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
Date: Mon, 8 Sep 2025 21:00:49 +0530
Subject: [PATCH] UPSTREAM:ath12k:DP: Increase TX ring size for 512MB

Improve performance by increasing the TX descriptor and completion
ring size from 8K to 16K. This change raises the MPDU aggregation
rate from 112 to 200, resulting in a 300 Mbps improvement in TCP
download throughput.

Patch-dependency: 0124-0003-wifi-ath12k-Add-512MB-support-changes.patch

Signed-off-by: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.h | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index 178f2dd..83080a0 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -206,8 +206,8 @@ enum ath12k_dp_eapol_key_type {
 #define DP_IDLE_SCATTER_BUFS_MAX 16
 
 #if defined(CONFIG_ATH12K_MEM_PROFILE_512M) || defined (CPTCFG_ATH12K_MEM_PROFILE_512M)
-#define DP_TX_COMP_RING_SIZE            8192
-#define ATH12K_NUM_POOL_TX_DESC        8192
+#define DP_TX_COMP_RING_SIZE           16384
+#define ATH12K_NUM_POOL_TX_DESC        16384
 #define DP_REO2PPE_RING_SIZE	2048
 #define DP_PPE2TCL_RING_SIZE	2048
 #define DP_PPE_WBM2SW_RING_SIZE	8192
-- 
2.34.1

