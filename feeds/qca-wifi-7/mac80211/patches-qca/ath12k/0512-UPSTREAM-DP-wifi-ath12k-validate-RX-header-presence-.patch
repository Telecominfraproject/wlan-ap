From 2944ba38289f4cc664f3e6dd0745f6ecbb4ad38a Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Sun, 10 Aug 2025 07:19:31 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: validate RX header presence before
 processing monitor packet

wifi: ath12k: fix incorrect skb pointer in monitor RX fragment handling

Currently, in ath12k_wifi7_dp_mon_parse_status_rx_hdr(), the code
incorrectly passes the main skb pointer to ath12k_dp_mon_add_rx_frag()
even when a new temporary skb (tmp_skb) is allocated for the fragment.
This leads to fragment data being added to the wrong skb, which can
result in memory corruption, invalid fragment lists, and eventual
kernel crashes when the skb is later freed or processed.

Fix this by adding the rx_hdr check before processing the packet tlv
which prevent memory corruption though hardware reports it wrongly.

This issue is observed in monitor mode with non-RAW decap types, where
multiple fragments may be handled per packet. When tmp_skb is not the
same as the main skb, failing to update the fragment in the correct skb
causes the fragment list to become inconsistent, triggering skb
corruption checks and kernel panics.

Fix this by always passing tmp_skb to ath12k_dp_mon_add_rx_frag(), so
that the fragment is appended to the correct skb instance. This ensures
fragment lists are consistent and prevents memory corruption in monitor
rx processing.

Fixes : I4966ec2a21c (UPSTREAM:DP:wifi:ath12k: add support for ethernet
packet capture in monitor mode)

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
index f217f17..2e53a11 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -138,6 +138,14 @@ ath12k_wifi7_dp_mon_rx_parse_status_buf(struct ath12k_pdev_dp *dp_pdev,
 		goto buf_replenish;
 	}
 
+	if (unlikely(!ppdu_info->mpdu_info.rx_hdr_rcvd)) {
+		ath12k_warn(dp, "pkt buf: packet buffer without rx hdr in mac_id %d\n",
+			    dp_pdev->mac_id);
+		page_frag_free(mon_buf);
+		mon_stats->pkt_tlv_free++;
+		goto buf_replenish;
+	}
+
 	if (unlikely(ppdu_info->mpdu_info.decap_type == DP_RX_DECAP_TYPE_INVALID)) {
 		ath12k_warn(dp, "pkt buf: invalid decap type in mac_id %d\n",
 			    dp_pdev->mac_id);
@@ -268,7 +276,7 @@ ath12k_wifi7_dp_mon_parse_status_rx_hdr(struct ath12k_pdev_dp *dp_pdev,
 			ath12k_dp_mon_append_skb(skb, tmp_skb);
 		}
 
-		ath12k_dp_mon_add_rx_frag(skb, mon_buf, offset, frag_len, true);
+		ath12k_dp_mon_add_rx_frag(tmp_skb, mon_buf, offset, frag_len, true);
 		if (tmp_skb != skb)
 			ath12k_dp_mon_update_skb_len(skb, frag_len);
 	}
