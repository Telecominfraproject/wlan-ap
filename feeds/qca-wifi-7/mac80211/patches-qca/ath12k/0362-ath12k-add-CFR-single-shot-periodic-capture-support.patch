--- a/drivers/net/wireless/ath/ath12k/Kconfig
+++ b/drivers/net/wireless/ath/ath12k/Kconfig
@@ -99,6 +99,15 @@ config ATH12K_MEM_PROFILE_512M
 
 endchoice
 
+config ATH12K_CFR
+	bool "QCA ath12k CFR support"
+	depends on ATH12K_DEBUGFS
+	depends on RELAY
+	help
+	  Enable ath12k cfr dump support
+
+	  Say Y to enable access to collect cfr data dump via debugfs.
+
 config ATH12K_SPECTRAL
 	bool "QTI ath12k spectral scan support"
 	depends on ATH12K_DEBUGFS
--- a/drivers/net/wireless/ath/ath12k/Makefile
+++ b/drivers/net/wireless/ath/ath12k/Makefile
@@ -42,7 +42,7 @@ ath12k-$(CPTCFG_NL80211_TESTMODE) += tes
 ath12k-$(CPTCFG_ATH12K_SPECTRAL) += spectral.o
 ath12k-$(CPTCFG_WANT_DEV_COREDUMP) += coredump.o
 ath12k-$(CONFIG_THERMAL) += thermal.o
-ath12k-$(CPTCFG_ATH12K_SPECTRAL) += spectral.o
+ath12k-$(CPTCFG_ATH12K_CFR) += cfr.o
 
 # for tracing framework to find trace.h
 CFLAGS_trace.o := -I$(src)
--- /dev/null
+++ b/drivers/net/wireless/ath/ath12k/cfr.c
@@ -0,0 +1,877 @@
