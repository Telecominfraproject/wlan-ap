From 4ca537adbc6251ec329cbd4ad176885ca9a3709a Mon Sep 17 00:00:00 2001
From: Kiran Venkatappa <kiranv@qti.qualcomm.com>
Date: Thu, 26 Jun 2025 12:22:18 +0530
Subject: [PATCH 2/5] wifi:ath12k: Remove HAL defines dependency in shared ahb
 files

ath12k/ahb.c uses HAL defines for accessing WFSS reg base and CMEM
offset. WFSS reg base is already available in hw_params as part of
ce_remap structure. Store this value in ahb context and use them
directly instead of using HAL defines.
CMEM offset is also used in the same ce_remap context. Add this also
in ce_remap and use in the shared code.

Signed-off-by: Kiran Venkatappa <kiranv@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ahb.c      | 8 ++++----
 drivers/net/wireless/ath/ath12k/ce.h       | 1 +
 drivers/net/wireless/ath/ath12k/core.h     | 1 +
 drivers/net/wireless/ath/ath12k/wifi7/hw.c | 1 +
 4 files changed, 7 insertions(+), 4 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/ahb.c
+++ b/drivers/net/wireless/ath/ath12k/ahb.c
@@ -139,7 +139,7 @@ enum ext_irq_num {
 
 static u32 ath12k_ahb_read32(struct ath12k_base *ab, u32 offset)
 {
-	if (ab->ce_remap && offset < HAL_SEQ_WCSS_CMEM_OFFSET)
+	if (ab->ce_remap && offset < ab->cmem_offset)
 		return ioread32(ab->mem_ce + offset);
 	return ioread32(ab->mem + offset);
 }
@@ -147,7 +147,7 @@ static u32 ath12k_ahb_read32(struct ath1
 static void ath12k_ahb_write32(struct ath12k_base *ab, u32 offset,
 			       u32 value)
 {
-	if (ab->ce_remap && offset < HAL_SEQ_WCSS_CMEM_OFFSET)
+	if (ab->ce_remap && offset < ab->cmem_offset)
 		iowrite32(value, ab->mem_ce + offset);
 	else
 		iowrite32(value, ab->mem + offset);
@@ -1455,7 +1455,8 @@ static int ath12k_ahb_resource_init(stru
 			goto err_mem_unmap;
 		}
 		ab->ce_remap = true;
-		ab->ce_remap_base_addr = HAL_IPQ5332_CE_WFSS_REG_BASE;
+		ab->cmem_offset = ce_remap->cmem_offset;
+		ab->ce_remap_base_addr = ce_remap->base;
 	}
 
 	return 0;
--- a/drivers/net/wireless/ath/ath12k/ce.h
+++ b/drivers/net/wireless/ath/ath12k/ce.h
@@ -92,6 +92,7 @@ struct ce_ie_addr {
 struct ce_remap {
 	u32 base;
 	u32 size;
+	u32 cmem_offset;
 };
 
 struct ce_attr {
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -1289,6 +1289,7 @@ struct ath12k_base {
 
 	void __iomem *mem_ce;
 	u32 ce_remap_base_addr;
+	u32 cmem_offset;
 	bool ce_remap;
 	bool htt_flag;
 	bool stats_disable;
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -455,6 +455,7 @@ static const struct ce_ie_addr ath12k_wi
 static const struct ce_remap ath12k_wifi7_ce_remap_ipq5332 = {
 	.base = HAL_IPQ5332_CE_WFSS_REG_BASE,
 	.size = HAL_IPQ5332_CE_SIZE,
+	.cmem_offset = HAL_SEQ_WCSS_CMEM_OFFSET,
 };
 
 static const struct ce_ie_addr ath12k_wifi7_ce_ie_addr_ipq5424 = {
@@ -466,6 +467,7 @@ static const struct ce_ie_addr ath12k_wi
 static const struct ce_remap ath12k_wifi7_ce_remap_ipq5424 = {
 	.base = HAL_IPQ5424_CE_WFSS_REG_BASE,
 	.size = HAL_IPQ5424_CE_SIZE,
+	.cmem_offset = HAL_SEQ_WCSS_CMEM_OFFSET,
 };
 
 static struct ath12k_hw_params ath12k_wifi7_hw_params[] = {
