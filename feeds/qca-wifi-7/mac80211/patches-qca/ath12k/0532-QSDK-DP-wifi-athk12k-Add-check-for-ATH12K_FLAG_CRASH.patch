From dc65359b6db77db30d6fc7efb70967933496a911 Mon Sep 17 00:00:00 2001
From: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Date: Mon, 15 Sep 2025 17:01:11 +0530
Subject: [PATCH] QSDK:DP:wifi:athk12k: Add check for ATH12K_FLAG_CRASH_FLUSH
 in Tx path

Add check for ATH12K_FLAG_CRASH_FLUSH in API ath12k_wifi7_mac_op_tx()
for multicast frames in order to handle the transmission of frames
in case when driver is expecting recovery.

Patch-dependency: 0119-0001-wifi-ath12k-ieee80211_ops-Tx-callback-for-wifi7.patch

Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/hw.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hw.c b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
index 0c81cc6..dcf59ab 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -1584,6 +1584,9 @@ static void ath12k_wifi7_mac_op_tx(struct ieee80211_hw *hw,
 				continue;
 
 			tmp_ar = tmp_arvif->ar;
+			if (unlikely(test_bit(ATH12K_FLAG_CRASH_FLUSH, &tmp_ar->ab->dev_flags)))
+				continue;
+
 			tmp_dp_pdev = ath12k_dp_to_dp_pdev(tmp_ar->ab->dp, tmp_ar->pdev_idx);
 			if (!tmp_dp_pdev)
 				continue;
-- 
