From 48ede3a307f919afda447d0fa35fafdb4f4d657a Mon Sep 17 00:00:00 2001
From: Harish Rachakonda <rachakon@qti.qualcomm.com>
Date: Fri, 5 Sep 2025 14:25:54 +0530
Subject: [PATCH] QSDK:CP: ath12k: Fix ap_ps enable when monitor VAP is present

Previously, ap_ps not enabled if any VAP is not of type AP, which
incorrectly excluded cases where a monitor VAP present. Updated the
logic to allow ap_ps enablement when all VDEVs are either
AP or MONITOR type.

Patch-dependency: 0227-ath12k-Add-support-for-Green-AP.patch
Patch-rework: None

Signed-off-by: Harish Rachakonda <rachakon@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 834df16..639bef6 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -5209,7 +5209,8 @@ void ath12k_mac_ap_ps_recalc(struct ath12k *ar)
 	lockdep_assert_wiphy(ath12k_ar_to_hw(ar)->wiphy);
 
 	list_for_each_entry(arvif, &ar->arvifs, list) {
-		if (arvif->ahvif->vdev_type != WMI_VDEV_TYPE_AP) {
+		if (arvif->ahvif->vdev_type != WMI_VDEV_TYPE_AP &&
+		    arvif->ahvif->vdev_type != WMI_VDEV_TYPE_MONITOR) {
 			allow_ap_ps = false;
 			break;
 		}
-- 
