From 1d35ea381dd2b6f1c8fa9c2f0d2cab0b1c0b6728 Mon Sep 17 00:00:00 2001
From: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
Date: Fri, 6 Jun 2025 15:01:08 +0530
Subject: [PATCH] UPSTREAM: CP: Set
 WMI_RSRC_CFG_HOST_AFC_TRIGGER_ON_DEFAULT_CC_EVENT

Currently, the AFC expiry event is received from the firmware only when a
WMI_INIT_COUNTRY_CMD_ID is sent from the Host.

The firmware shall send the AFC expiry event only if the Host
sets the WMI_RSRC_CFG_HOST_AFC_TRIGGER_ON_DEFAULT_CC_EVENT_BIT
in the host_service flags as part of the WMI_INIT_CMD.

Since AFC Expiry event is required from the firmware during the
bootup time (followed by the WMI_REG_CHAN_LIST_CC_EXT_EVENT), set the
WMI_RSRC_CFG_HOST_AFC_TRIGGER_ON_DEFAULT_CC_EVENT_BIT in the
host_service_flags which is sent to the firmware as part of the
WMI_INIT_CMD.

Tag: 6G_REGULATORY
Patch-dependency: 0346-02-wifi-ath12k-Add-support-for-processing-AFC-power-eve.patch
                  0375-UPSTREAM-PROTOCOL-wifi-ath12k-Add-module-params-for-.patch

Signed-off-by: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.c | 3 +++
 1 file changed, 3 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -5480,6 +5480,11 @@ ath12k_wmi_copy_resource_config(struct a
 			cpu_to_le32(1 << WMI_RSRC_CFG_HOST_SVC_FLAG_REO_QREF_SUPPORT_BIT);
 	wmi_cfg->host_service_flags |=
 			cpu_to_le32(1 << WMI_RSRC_CFG_HOST_SVC_FLAG_FULL_BW_NOL_SUPPORT_BIT);
+	if (!ath12k_afc_reg_no_action) {
+		wmi_cfg->host_service_flags |=
+			cpu_to_le32(1 << WMI_RSRC_CFG_HOST_AFC_TRIGGER_ON_DEFAULT_CC_EVENT_BIT);
+	}
+
 	wmi_cfg->ema_max_vap_cnt = cpu_to_le32(tg_cfg->ema_max_vap_cnt);
 	wmi_cfg->ema_max_profile_period = cpu_to_le32(tg_cfg->ema_max_profile_period);
 	wmi_cfg->flags2 |= cpu_to_le32(WMI_RSRC_CFG_FLAGS2_CALC_NEXT_DTIM_COUNT_SET);
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2802,6 +2802,7 @@ struct wmi_ctrl_path_pmlo_telemetry_stat
 #define WMI_RSRC_CFG_HOST_AFC_DIS_REQ_ID_CHECK_BIT             9
 #define WMI_RSRC_CFG_HOST_AFC_INDOOR_SUPPORT                  10
 #define WMI_RSRC_CFG_HOST_AFC_OUTDOOR_SUPPORT                 11
+#define WMI_RSRC_CFG_HOST_AFC_TRIGGER_ON_DEFAULT_CC_EVENT_BIT 22
 
 struct ath12k_wmi_resource_config_params {
 	__le32 tlv_header;
