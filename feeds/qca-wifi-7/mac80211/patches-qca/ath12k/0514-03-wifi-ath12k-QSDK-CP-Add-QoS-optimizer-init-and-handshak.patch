From bd7b766ec96487204f0a4ae8ad6fae4e47677c1f Mon Sep 17 00:00:00 2001
From: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Date: Tue, 12 Aug 2025 18:10:58 -0700
Subject: [PATCH 3/5] wifi: ath12k: QSDK: CP: Add QoS optimizer init and handshake
 support

Enable vendor app initialize and handshake sequence between kernel
resources and vendor app containerize application.

Rename ATH12K_UNUSED_RM_IFLI_PROXY_SERVICE as ATH12K_VENDOR_APP_QOS_OPTIMIZER

 ┌───────────────────────────────────────────────────────────────┐
 │                                                               │
 │    GW APP GW APP          ATH12K            TELEMETRY_AGENT   │
 │      A     B                                                  │
 │      │     │               │                 │                │
 │      │     │  E/INIT       │                 │                │
 │  [1] ┼─────┼──────────────►│ [2]OP->DE/INIT  │                │
 │      │     │               ┼────────────────►│                │
 │      │     │[3] DE/INIT  DE/INIT DONE       DEI/INIT DONE     │
 │      │     ┼──────────────►│ [4]OP->DE/INIT  │                │
 │      │     │               ┼────────────────►│                │
 │      │     │               │                 │                │
 │      │     │               │                 │                │
 │      │     │               │                 │                │
 │      │     │               │  [5] DE/INIT    │                │
 │      │     │               ◄─────────────────┼                │
 │      │     │ [7]RESPONSE   │                 │                │
 │      ◄─────┼───────────────┤                 │                │
 │      │     │  SOC,LINK     │   [6] DE/INIT   │                │
 │      │     │               ◄─────────────────┼                │
 │      │     │ [8]RESPONSE   │                 │                │
 │      │     │◄──────────────┼                 │                │
 │      │     │  SOC,LINK     │                 │                │
 └────────────│───────────────│──────────────────────────────────┘

Patch-dependency: None

Signed-off-by: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/vendor_services.c | 4 ++++
 drivers/net/wireless/ath/ath12k/vendor_services.h | 2 +-
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/vendor_services.c b/drivers/net/wireless/ath/ath12k/vendor_services.c
index 9b03ef1..2931b65 100644
--- a/drivers/net/wireless/ath/ath12k/vendor_services.c
+++ b/drivers/net/wireless/ath/ath12k/vendor_services.c
@@ -401,6 +401,10 @@ void ath12k_vendor_services_init(void)
 		ath12k_vendor_service_common_init;
 	ath12k_vendor_service_deinit[ATH12K_VENDOR_APP_ERP_SERVICE] =
 		ath12k_vendor_service_common_deinit;
+	ath12k_vendor_service_init[ATH12K_VENDOR_APP_QOS_OPTIMIZER] =
+		ath12k_vendor_dynamic_service_init;
+	ath12k_vendor_service_deinit[ATH12K_VENDOR_APP_QOS_OPTIMIZER] =
+		ath12k_vendor_dynamic_service_deinit;
 	/* Initialize other serives as needed */
 }
 EXPORT_SYMBOL(ath12k_vendor_services_init);
diff --git a/drivers/net/wireless/ath/ath12k/vendor_services.h b/drivers/net/wireless/ath/ath12k/vendor_services.h
index dc894aa..c42b5e7 100644
--- a/drivers/net/wireless/ath/ath12k/vendor_services.h
+++ b/drivers/net/wireless/ath/ath12k/vendor_services.h
@@ -19,7 +19,7 @@ enum ath12k_vendor_service_id {
 	ATH12K_VENDOR_APP_ERP_SERVICE,
 	ATH12K_UNUSED_RM_ADMCTRL_SERVICE,
 	ATH12K_VENDOR_APP_ENERGY_SERVICE,
-	ATH12K_UNUSED_RM_IFLI_PROXY_SERVICE,
+	ATH12K_VENDOR_APP_QOS_OPTIMIZER, //or same as ATH12K_UNUSED_RM_IFLI_PROXY_SERVICE,
 	ATH12K_RM_MAX_SERVICE
 };
 
