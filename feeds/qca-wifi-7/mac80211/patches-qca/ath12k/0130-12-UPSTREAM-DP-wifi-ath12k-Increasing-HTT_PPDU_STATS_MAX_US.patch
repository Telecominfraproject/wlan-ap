From 3ffaecca19cefaa867cdb0a75c2daa42971ee0dc Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <quic_hramanat@quicinc.com>
Date: Tue, 15 Apr 2025 18:45:34 +0530
Subject: [PATCH 13/15] UPSTREAM: DP: wifi: ath12k: Increasing
HTT_PPDU_STATS_MAX_USERS from 8 to 37

Currently, in ath12k HTT_PPDU_STATS_MAX_USERS count is 8,
So that getting warning HTT PPDU STATS event has
unexpected num_users 8.

Hence, to fix increasing the HTT_PPDU_STATS_MAX_USERS count from 8 to 37
by refferring in ath11k.

Original Patch:
985-QSDK-DP-wifi-ath12k-Increasing-HTT_PPDU_STATS_MAX_US.patch

Patch-dependency: 069-ath11k-add-HE-stats-in-peer-stats.patch

Signed-off-by: Sowjanya vardhineni <quic_svardhin@quicinc.com>
Signed-off-by: Hariharan Ramanathan <quic_hramanat@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/dp_htt.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.h b/drivers/net/wireless/ath/ath12k/dp_htt.h
index 9703c60..39e3626 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.h
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.h
@@ -1278,7 +1278,7 @@ struct htt_ppdu_user_stats {
 	struct htt_ppdu_stats_usr_cmpltn_ack_ba_status ack_ba;
 };
 
-#define HTT_PPDU_STATS_MAX_USERS	8
+#define HTT_PPDU_STATS_MAX_USERS	37
 #define HTT_PPDU_DESC_MAX_DEPTH	16
 
 struct htt_ppdu_stats {
-- 
2.34.1

