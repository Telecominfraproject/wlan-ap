From c60108a01f8c75bb02f5a67df06004df6e48d067 Mon Sep 17 00:00:00 2001
From: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
Date: Fri, 8 Aug 2025 11:45:52 +0530
Subject: [PATCH] UPSTREAM:DP:wifi: ath12k: Modify warning message to dbg log

Modify peer fail log in ath12k_wifi7_dp_rx_h_unauth_wds_err()
to ath12k_dbg log to avoid printing the logs by default in console.

patch dependency:
0451-UPSTREAM-DP-wifi-ath12k-ath12k-handle-4addr-EAPOL-fr.patch

Signed-off-by: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index dbfe1f3..e7cebff 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -2794,9 +2794,9 @@ static int ath12k_wifi7_dp_rx_h_unauth_wds_err(struct ath12k_pdev_dp *dp_pdev,
 	peer = ath12k_dp_peer_find_by_peerid_index(dp, dp_pdev,
 						   rxcb->peer_id);
 	if (!peer) {
-		ath12k_warn(dp->ab,
-			    "failed to find the peer to process unauth wds err handling peer_id %d\n",
-			    rxcb->peer_id);
+		ath12k_dbg(dp->ab, ATH12K_DBG_DATA,
+			   "failed to find the peer to process unauth wds err handling peer_id %d\n",
+			   rxcb->peer_id);
 		drop = true;
 		goto exit;
 	}
-- 
