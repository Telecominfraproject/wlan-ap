From 68960ba519a6084468f2b5697a14eabf70b2e78f Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <quic_hramanat@quicinc.com>
Date: Tue, 15 Apr 2025 18:45:58 +0530
Subject: [PATCH 14/15] UPSTREAM:DP: wifi: ath12k: Adjusted RCU Lock
in PPDU stats

Refactor the handling of rcu_lock for ar during PPDU stats collection.
Move the spinlock_bh outside the RCU lock to prevent RCU stalls
during stats collection, as ar is not an RCU-protected variable and
unlocking the RCU at the end of stats collection is unnecessary.

Orignal Patch:
90-UPSTREAM-DP-wifi-ath12k-Adjusted-RCU-Lock-in-PPDU-stats.patch

Patch-dependency: None
patch-work: None

Signed-off-by: Gautham Kumar Senthilkumaran <quic_gauthamk@quicinc.com>
Signed-off-by: Hariharan Ramanathan <quic_hramanat@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/dp_htt.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.c b/drivers/net/wireless/ath/ath12k/dp_htt.c
index 3d12699..2f20060 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.c
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.c
@@ -570,6 +570,7 @@ static int ath12k_htt_pull_ppdu_stats(struct ath12k_base *ab,
 		ret = -EINVAL;
 		goto exit;
 	}
+	rcu_read_unlock();
 
 	spin_lock_bh(&dp_pdev->ppdu_list_lock);
 	ppdu_info = ath12k_dp_htt_get_ppdu_desc(dp_pdev, ppdu_id);
@@ -641,8 +642,6 @@ static int ath12k_htt_pull_ppdu_stats(struct ath12k_base *ab,
 	spin_unlock_bh(&dp_pdev->ppdu_list_lock);
 
 exit:
-	rcu_read_unlock();
-
 	return ret;
 }
 
-- 
