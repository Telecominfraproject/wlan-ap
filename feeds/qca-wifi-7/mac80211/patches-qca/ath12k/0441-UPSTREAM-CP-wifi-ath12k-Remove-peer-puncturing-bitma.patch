From 189400701aa3fd1fefd8c7d6b883e5f25eb9b7c8 Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Date: Mon, 21 Jul 2025 16:17:45 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k:Remove peer puncturing bitmap for STA

During channel change, host will send WMI_PEER_CHAN_WIDTH_SWITCH_CMDID
which will update puncturing bitmap and also the channel width changed.

Current code updates peer puncturing bitmap for STA along with channel
width. But when this peer param is sent, phymode not updated yet in
firmware. Due to this bandwidth exceeds the phymode causing an assert.

Since in QSDK, both puncturing bitmap and channel switch is updated
through another WMI cmd, removing the change.

Changes brought in through upstream below commit
https://lore.kernel.org/all/20240408083047.22548-1-quic_kangyang@quicinc.com/

Patch-dependency:
	0279-001-ath12k-add-num_stations-counter-for-each-interface.patch
	0279-002-ath12k-add-peer-channel-width-switch-command-support.patch
	0279-003-ath12k-fix-RU-puncturing-pattern-for-peers-after-CSA.patch
Patch-work: None

Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 60 ---------------------------
 drivers/net/wireless/ath/ath12k/wmi.h | 14 -------
 2 files changed, 74 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 254a946..95bd0b9 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -16407,57 +16407,6 @@ ath12k_mac_change_chanctx_fill_iter(void *data, u8 *mac,
 	}
 }
 
-static u32 ath12k_mac_nlwidth_to_wmiwidth(enum nl80211_chan_width width)
-{
-	switch (width) {
-	case NL80211_CHAN_WIDTH_20:
-		return WMI_CHAN_WIDTH_20;
-	case NL80211_CHAN_WIDTH_40:
-		return WMI_CHAN_WIDTH_40;
-	case NL80211_CHAN_WIDTH_80:
-		return WMI_CHAN_WIDTH_80;
-	case NL80211_CHAN_WIDTH_160:
-		return WMI_CHAN_WIDTH_160;
-	case NL80211_CHAN_WIDTH_80P80:
-		return WMI_CHAN_WIDTH_80P80;
-	case NL80211_CHAN_WIDTH_5:
-		return WMI_CHAN_WIDTH_5;
-	case NL80211_CHAN_WIDTH_10:
-		return WMI_CHAN_WIDTH_10;
-	case NL80211_CHAN_WIDTH_320:
-		return WMI_CHAN_WIDTH_320;
-	default:
-		WARN_ON(1);
-		return WMI_CHAN_WIDTH_20;
-	}
-}
-
-static int ath12k_mac_update_peer_puncturing_width(struct ath12k *ar,
-						   struct ath12k_link_vif *arvif,
-						   struct cfg80211_chan_def def)
-{
-	u32 param_id, param_value;
-	int ret;
-
-	if (arvif->ahvif->vdev_type != WMI_VDEV_TYPE_STA)
-		return 0;
-
-	param_id = WMI_PEER_CHWIDTH_PUNCTURE_20MHZ_BITMAP;
-	param_value = ath12k_mac_nlwidth_to_wmiwidth(def.width) |
-		u32_encode_bits((~def.punctured),
-				WMI_PEER_PUNCTURE_BITMAP);
-
-	ath12k_dbg(ar->ab, ATH12K_DBG_MAC,
-		   "punctured bitmap %02x width %d vdev %d\n",
-		   def.punctured, def.width, arvif->vdev_id);
-
-	ret = ath12k_wmi_set_peer_param(ar, arvif->bssid,
-					arvif->vdev_id, param_id,
-					param_value);
-
-	return ret;
-}
-
 static void
 ath12k_mac_update_peer_ru_punct_bitmap_iter(void *data,
 					    struct ieee80211_sta *sta)
@@ -16606,15 +16555,6 @@ beacon_tmpl_setup:
 		return ret;
 	}
 
-	ret = ath12k_mac_update_peer_puncturing_width(ar, arvif, new_ctx->def);
-
-	if (ret) {
-		 ath12k_warn(ar->ab,
-			     "failed to update puncturing bitmap %02x and width %d: %d\n",
-			     new_ctx->def.punctured,
-			     new_ctx->def.width, ret);
-	}
-
 	return ret;
 }
 
diff --git a/drivers/net/wireless/ath/ath12k/wmi.h b/drivers/net/wireless/ath/ath12k/wmi.h
index 218764f..d5910d2 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2608,7 +2608,6 @@ enum wmi_peer_param {
 	WMI_PEER_SET_MAX_TX_RATE = 17,
 	WMI_PEER_SET_MIN_TX_RATE = 18,
 	WMI_PEER_SET_DEFAULT_ROUTING = 19,
-	WMI_PEER_CHWIDTH_PUNCTURE_20MHZ_BITMAP = 39,
 };
 
 #define WMI_PEER_PUNCTURE_BITMAP		GENMASK(23, 8)
@@ -3153,19 +3152,6 @@ struct ath12k_wmi_soc_hal_reg_caps_params {
 	__le32 num_phy;
 } __packed;
 
-enum wmi_channel_width {
-	WMI_CHAN_WIDTH_20 = 0,
-	WMI_CHAN_WIDTH_40 = 1,
-	WMI_CHAN_WIDTH_80 = 2,
-	WMI_CHAN_WIDTH_160 = 3,
-	WMI_CHAN_WIDTH_80P80 = 4,
-	WMI_CHAN_WIDTH_5 = 5,
-	WMI_CHAN_WIDTH_10 = 6,
-	WMI_CHAN_WIDTH_165 = 7,
-	WMI_CHAN_WIDTH_160P160 = 8,
-	WMI_CHAN_WIDTH_320 = 9,
-};
-
 #define WMI_MAX_EHTCAP_MAC_SIZE  2
 #define WMI_MAX_EHTCAP_PHY_SIZE  3
 #define WMI_MAX_EHTCAP_RATE_SET  3
-- 
2.34.1

