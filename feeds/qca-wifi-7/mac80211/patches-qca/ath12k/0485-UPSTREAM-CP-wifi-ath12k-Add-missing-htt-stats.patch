+	len += scnprintf(buf + len, buf_len - len, "HTT_PDEV_TDMA_STATS_TLV:\n");
+	len += scnprintf(buf + len, buf_len - len, "mac_id = %u\n",
+			 u32_get_bits(__le32_to_cpu(htt_stats_buf->mac_id__word),
+				      ATH12K_HTT_STATS_TDMA_MAC_ID_M));
