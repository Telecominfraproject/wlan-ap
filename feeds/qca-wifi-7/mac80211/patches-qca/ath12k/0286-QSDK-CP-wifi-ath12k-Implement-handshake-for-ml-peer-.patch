From 5d9501f024f2f0ba0bbdb772bb4f514374e51399 Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <ramya.gnanasekar@oss.qualcomm.com>
Date: Wed, 22 Jan 2025 00:36:23 +0530
Subject: [PATCH] QSDK: CP: wifi: ath12k: Implement handshake for ml peer id

Maxmimum ml peer id supported by firmware depends on the platform. Since
ml_peer_id is generated by host, firmware shares the information in MLO
setup complete event.

Add code changes to decode the information from TLV and use it while
allocating the peer id.

Fixes: I11d96d3c8fdb4(UPSTREAM:CP:wifi:ath12k: Change ml peer id
allocation logic)

Signed-off-by: Ramya Gnanasekar <quic_rgnanase@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/core.h | 1 +
 drivers/net/wireless/ath/ath12k/peer.c | 6 +++---
 drivers/net/wireless/ath/ath12k/wmi.c  | 1 +
 drivers/net/wireless/ath/ath12k/wmi.h  | 1 +
 4 files changed, 6 insertions(+), 3 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -874,6 +874,8 @@ struct ath12k_hw {
 	struct ath12k_dp_hw dp_hw;
 	u32 max_ml_peers_supported;
 	u32 num_ml_peers;
+	u32 max_ml_peer_ids;
+	u16 last_ml_peer_id;
 
 	/* Keep last */
 	struct ath12k radio[] __aligned(sizeof(void *));
@@ -1260,6 +1262,7 @@ struct ath12k_base {
 
 	/* Number of ML peers supported by firmware */
 	u32 max_ml_peer_supported;
+	u32 max_ml_peer_ids;
 
 	/* must be last */
 	u8 drv_priv[] __aligned(sizeof(void *));
--- a/drivers/net/wireless/ath/ath12k/peer.c
+++ b/drivers/net/wireless/ath/ath12k/peer.c
@@ -258,6 +258,7 @@ int ath12k_peer_create(struct ath12k *ar
 u16 ath12k_peer_ml_alloc(struct ath12k_hw *ah)
 {
 	u16 ml_peer_id;
+	int i;
 
 	lockdep_assert_wiphy(ah->hw->wiphy);
 
@@ -267,7 +268,13 @@ u16 ath12k_peer_ml_alloc(struct ath12k_h
 		return -ENOMEM;
 	}
 
-	for (ml_peer_id = 0; ml_peer_id < ATH12K_MAX_MLO_PEERS; ml_peer_id++) {
+	ml_peer_id = ah->last_ml_peer_id;
+	for (i = 0; i <= ah->max_ml_peer_ids; i++) {
+		ml_peer_id = (ml_peer_id + 1) % ah->max_ml_peer_ids;
+
+		if (!ml_peer_id)
+			continue;
+
 		if (test_bit(ml_peer_id, ah->free_ml_peer_id_map))
 			continue;
 
@@ -275,7 +282,8 @@ u16 ath12k_peer_ml_alloc(struct ath12k_h
 		break;
 	}
 
-	if (ml_peer_id == ATH12K_MAX_MLO_PEERS)
+	ah->last_ml_peer_id = ml_peer_id;
+	if (i == ah->max_ml_peer_ids)
 		ml_peer_id = ATH12K_MLO_PEER_ID_INVALID;
 
 	ath12k_dbg(NULL, ATH12K_DBG_PEER, "Allocated ml_peer_id:%d", ml_peer_id);
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -9518,6 +9518,7 @@ static void ath12k_wmi_event_mlo_setup_c
 	const struct wmi_mlo_setup_complete_event *ev;
 	struct ath12k *ar = NULL;
 	struct ath12k_pdev *pdev;
+	u32 max_ml_peer_ids;
 	const void **tb;
 	int ret, i;
 
@@ -9555,6 +9556,8 @@ skip_lookup:
 	}
 
 	ar->mlo_setup_status = le32_to_cpu(ev->status);
+	max_ml_peer_ids = le32_to_cpu(ev->max_ml_peer_ids);
+	ar->ah->max_ml_peer_ids = max_ml_peer_ids ? max_ml_peer_ids : ATH12K_MAX_MLO_PEERS;
 	complete(&ar->mlo_setup_done);
 
 out:
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -5816,6 +5816,7 @@ struct wmi_mlo_teardown_cmd {
 struct wmi_mlo_setup_complete_event {
 	__le32 pdev_id;
 	__le32 status;
+	__le32 max_ml_peer_ids;
 } __packed;
 
 struct wmi_mlo_teardown_complete_event {
