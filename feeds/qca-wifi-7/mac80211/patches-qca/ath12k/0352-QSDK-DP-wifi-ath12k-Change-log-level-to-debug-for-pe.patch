From 06cc35600f1427686d31471262074264e9901f8e Mon Sep 17 00:00:00 2001
From: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 10:44:58 +0530
Subject: [PATCH] QSDK: DP: wifi: ath12k: Change log level to debug for peer
 not found case

Change log level to debug for peer not found case in Tx completion path
to avoid prints flood on console as NULL peer is expected in scenario where
station gets disconnected while traffic is ongoing.


Signed-off-by: Harsh Kumar Bijlani<hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index 8f0394f..1959c62 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -910,7 +910,7 @@ static void ath12k_wifi7_dp_tx_complete_msdu(struct ath12k_pdev_dp *dp_pdev,
 	spin_lock_bh(&dp->dp_lock);
 	peer = ath12k_dp_link_peer_find_by_id(dp, ts->peer_id);
 	if (!peer || !peer->sta) {
-		ath12k_err(ab,
+		ath12k_dbg(ab, ATH12K_DBG_DATA,
 			   "dp_tx: failed to find the peer with peer_id %d\n",
 			   ts->peer_id);
 		spin_unlock_bh(&dp->dp_lock);
-- 
2.34.1

