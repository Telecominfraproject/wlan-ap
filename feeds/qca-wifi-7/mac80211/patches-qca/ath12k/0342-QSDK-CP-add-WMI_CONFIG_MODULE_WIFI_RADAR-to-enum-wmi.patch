From 75420b29865d30ff1abfbb41d2f45ba1ce94667b Mon Sep 17 00:00:00 2001
From: Harish Rachakonda <rachakon@qti.qualcomm.com>
Date: Mon, 9 Jun 2025 10:45:27 +0530
Subject: [PATCH] QSDK:CP add WMI_CONFIG_MODULE_WIFI_RADAR to enum
 wmi_direct_buffer_module

Due to missmatch in enum spectral_scan_ctl debugfs file for
spectral scm is not created. Update the enum with
WMI_CONFIG_MODULE_WIFI_RADAR.

Note: This variable is added to enum as part of the following patch
ath12k/890-ath12k-add-CFR-single-shot-periodic-capture-support.patch.
Current patch needs to be deleted while rebasing CFR patches.

Signed-off-by: Harish Rachakonda <rachakon@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/net/wireless/ath/ath12k/wmi.h b/drivers/net/wireless/ath/ath12k/wmi.h
index 69a305d..b1ca6d4 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.h
+++ b/drivers/net/wireless/ath/ath12k/wmi.h
@@ -2481,6 +2481,7 @@ enum wmi_direct_buffer_module {
 	WMI_DIRECT_BUF_SPECTRAL = 0,
 	WMI_DIRECT_BUF_CFR = 1,
 	WMI_CONFIG_MODULE_CV_UPLOAD = 2,
+	WMI_CONFIG_MODULE_WIFI_RADAR = 3,
 
 	/* keep it last */
 	WMI_DIRECT_BUF_MAX
-- 
2.34.1

