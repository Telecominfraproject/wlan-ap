From 9740c02d89084c8626bbcafdf06e59768664b1a2 Mon Sep 17 00:00:00 2001
From: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Date: Wed, 3 Sep 2025 23:52:25 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Free Tx and Rx Link peer stats in
 Peer Unmap

Currently Tx and Rx link peer stats are freed in link peer unassign but
peer list in link peer and link peer itself is freed in peer unmap event,
This creates a race condition and use after free situation wherein
Tx and Rx peer stats can be freed but still the peer list exist and
peer can be retrieved from peer list.

With this change Tx and Rx peer stats gets freed after the peer list
of link peer and before the peer free.

Fixes:
Id83378d8582 (UPSTREAM: DP: Package Upgrade for Monitor Patches)
I7f29b1ebe55 (UPSTREAM:DP:wifi:ath12k: Support for Tx ext stats)
I01fa5b21808 (QSDK: wifi: ath12k: DP: Add SDWF telemetry stats support)

Patch-dependency:
0131-03-UPSTREAM-DP-wifi-ath12k-allocate-and-update-rx_stats-when-ext_rx.patch
0350-UPSTREAM-DP-wifi-ath12k-Add-support-for-tx_stats.patch
0464-02-QSDK-wifi-ath12k-DP-Add-SDWF-stats-struct-and-peer-link.patch

Signed-off-by: Kenvish Butani <kbutani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_peer.c | 18 ++++++++++--------
 1 file changed, 10 insertions(+), 8 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp_peer.c b/drivers/net/wireless/ath/ath12k/dp_peer.c
index e9d30d2..c8d0520 100644
--- a/drivers/net/wireless/ath/ath12k/dp_peer.c
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.c
@@ -190,6 +190,16 @@ void ath12k_peer_unmap_event(struct ath12k_base *ab, u16 peer_id)
 		   peer->vdev_id, peer->addr, peer_id);
 
 	list_del(&peer->list);
+
+	if (peer->peer_stats.rx_stats)
+		kfree(peer->peer_stats.rx_stats);
+
+	if (peer->peer_stats.tx_stats)
+		kfree(peer->peer_stats.tx_stats);
+
+	if (peer->peer_stats.qos_stats)
+		kfree(peer->peer_stats.qos_stats);
+
 	kfree(peer);
 	wake_up(&ab->peer_mapping_wq);
 
@@ -750,14 +760,6 @@ void ath12k_dp_link_peer_unassign(struct ath12k *ar, u8 vdev_id, u8 *addr)
 
 	spin_unlock_bh(&dp_hw->peer_lock);
 
-	if (peer->peer_stats.rx_stats)
-		kfree(peer->peer_stats.rx_stats);
-
-	if (peer->peer_stats.tx_stats)
-		kfree(peer->peer_stats.tx_stats);
-
-	kfree(peer->peer_stats.qos_stats);
-
 	/* To handle roaming and split phy scenario */
 	temp_peer = ath12k_dp_link_peer_find_by_addr(dp, addr);
 	if (temp_peer && temp_peer->hw_link_id == ar->hw_link_id)
-- 
