From decccb9a83275a3077bea925177f54282347898d Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <quic_hramanat@quicinc.com>
Date: Tue, 22 Apr 2025 18:42:53 +0530
Subject: [PATCH 11/15] UPSTREAM:DP:wifi:ath12k:Add WARN_ON checks for
nss value

NSS should not have a value of 0 and should always
have a value from 1 to 8.

To ensure this statement is true, WARN_ON checks
have been added to monitor this value.

Original Patch:
970-wifi-ath12k-Add-WARN_ON-checks-for-nss-value.patch

Signed-off-by: Thomas Wu <quic_wthomas@quicinc.com>
Signed-off-by: Hariharan Ramanathan <quic_hramanat@quicinc.com>
---
 drivers/net/wireless/ath/ath12k/mac.c         | 4 ++++
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 3 +++
 2 files changed, 7 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 4201225..fdc2a55 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -3345,6 +3345,10 @@ static void ath12k_peer_assoc_prepare(struct ath12k *ar,
 	ath12k_peer_assoc_h_mlo(arsta, arg);
 
 	arsta->peer_nss = arg->peer_nss;
+
+	WARN_ON_ONCE(arsta->peer_nss < 1 ||
+             (arsta->peer_nss > hweight32(ar->pdev->cap.tx_chain_mask)));
+
 	/* TODO: amsdu_disable req? */
 }
 
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index c4e384a..01decff 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -554,6 +554,9 @@ ath12k_wifi7_dp_tx_update_txcompl(struct ath12k_pdev_dp *dp_pdev,
 		txrate.nss = arsta->peer_nss;
 	spin_unlock_bh(&dp->dp_lock);
 
+	WARN_ON_ONCE(txrate.nss < 1 ||
+             (txrate.nss > hweight32(dp_pdev->ar->pdev->cap.tx_chain_mask)));
+
 	switch (ts->pkt_type) {
 	case HAL_TX_RATE_STATS_PKT_TYPE_11A:
 	case HAL_TX_RATE_STATS_PKT_TYPE_11B:
-- 
2.34.1

