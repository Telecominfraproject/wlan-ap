From 32ba4605312f5f18c5d40f78ad981050e561d70d Mon Sep 17 00:00:00 2001
From: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
Date: Sun, 31 Aug 2025 00:17:45 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Update link specific tcl_metadata

During 4-address multicast Tx on native wifi mode the
tcl_metadata should be updated as link specific value.
Checking primarly link is unnecessary as arsta is already
available. This would cause Tx failure when primary link
is not assigned.

Fixes: Ia144589f0f9 ("QSDK: CP: wifi: ath12k: Add debugfs support to configure primary link")

Signed-off-by: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 8 +-------
 1 file changed, 1 insertion(+), 7 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -1075,7 +1075,6 @@ ath12k_wifi7_dp_tx(struct ath12k_pdev_dp
 	struct ath12k_dp_vif *dp_vif = &ahvif->dp_vif;
 	struct ath12k_dp_link_vif *dp_link_vif = &dp_vif->dp_link_vif[arvif->link_id];
 	struct dp_tx_ring *tx_ring;
-	struct ath12k_sta *ahsta;
 	u8 pool_id;
 	u8 hal_ring_id;
 	int ret;
@@ -1111,13 +1110,7 @@ ath12k_wifi7_dp_tx(struct ath12k_pdev_dp
 		ti.lookup_override = true;
 	} else if (ieee80211_has_a4(hdr->frame_control) &&
 	    is_multicast_ether_addr(hdr->addr3) && arsta) {
-		ahsta = arsta->ahsta;
-		if (unlikely(!ahsta->link[ahsta->primary_link_id])) {
-			ath12k_err(ab, "arsta not found on primary link");
-			err = DP_TX_ENQ_DROP_ARSTA_NA;
-			goto fail_remove_tx_buf;
-		}
-		ti.meta_data_flags = ahsta->link[ahsta->primary_link_id]->tcl_metadata;
+		ti.meta_data_flags = arsta->tcl_metadata;
 		ti.flags0 |= FIELD_PREP(HAL_TCL_DATA_CMD_INFO2_TO_FW, 1);
 	} else {
 		ti.meta_data_flags = dp_link_vif->tcl_metadata;
