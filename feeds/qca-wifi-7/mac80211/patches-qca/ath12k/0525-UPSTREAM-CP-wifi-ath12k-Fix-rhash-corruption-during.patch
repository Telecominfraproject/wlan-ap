From 065424b60ae5161764d90a8fc3aac0e52d9b517b Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Sun, 24 Aug 2025 22:05:07 +0530
Subject: [PATCH] UPSTREAM:CP wifi:ath12k: Fix rhash corruption during deflink
 remap in link STA migration

When migrating from the next available valid link to deflink,
the entire structure is copied using memcpy(). This includes the
rhash_addr field, which contains hash linkage pointers. If the
original link is freed after the copy, deflink have retain stale
pointers if proper remap is not done, leading to potential rhash
corruption or use-after-free during hash operations.

Resolve this issue by:

1. Remove the original link from the rhash table using
   ath12k_link_sta_rhash_delete() under base_lock.
2. Free the original link only after its hash entry is safely removed.
3. Re-add deflink to the rhash table using ath12k_link_sta_rhash_add()
   under base_lock.

Ensure deflink does not retain stale hash linkage from the freed
link, preventing hash list corruption and maintaining RCU safety.

Patch-dependency:
	0325-0005-wifi-ath12k-Handle-link-sta-delete-for-AP-STA-mode-s.patch

Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 32 +++++++++++++++++++++++----
 1 file changed, 28 insertions(+), 4 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -12042,10 +12042,10 @@ int ath12k_mac_op_change_sta_links(struc
 	struct ath12k_vif *ahvif = ath12k_vif_to_ahvif(vif);
 	struct ath12k_sta *ahsta = ath12k_sta_to_ahsta(sta);
 	struct ath12k_hw *ah = hw->priv;
-	struct ath12k_link_vif *arvif;
+	struct ath12k_link_vif *arvif, *tmp_arvif;
 	struct ath12k_link_sta *arsta, *tmp_arsta, *def_arsta;
 	unsigned long valid_links;
-	struct ath12k *ar;
+	struct ath12k *ar, *tmp_ar;
 	u16 removed_link_map;
 	u8 link_id, tmp_link_id, pri_link_id;
 	int ret;
@@ -12221,17 +12221,43 @@ int ath12k_mac_op_change_sta_links(struc
 		    hweight32(ahsta->links_map) >= 1) {
 			tmp_link_id = ffs(ahsta->links_map) - 1;
 
-			tmp_arsta = wiphy_dereference(ah->hw->wiphy, ahsta->link[tmp_link_id]);
+			tmp_arsta = wiphy_dereference(ah->hw->wiphy,
+						      ahsta->link[tmp_link_id]);
+			tmp_arvif = wiphy_dereference(hw->wiphy,
+						      ahvif->link[tmp_link_id]);
+			tmp_ar = tmp_arvif->ar;
+			if (!tmp_ar) {
+				ath12k_warn(ar->ab,
+					    "%s: Failed to remap deflink, ar not found\n",
+					    __func__);
+				return -EINVAL;
+			}
+
 			if (tmp_arsta) {
 				wiphy_work_cancel(ar->ah->hw->wiphy, &tmp_arsta->update_wk);
 				memcpy(&ahsta->deflink, tmp_arsta,
 				       sizeof(*tmp_arsta));
+
+				/* Free the moved link memory after removing
+				 * entry from rhash table.
+				 */
+				spin_lock_bh(&tmp_ar->ab->base_lock);
+				ath12k_link_sta_rhash_delete(tmp_ar->ab, tmp_arsta);
+				spin_unlock_bh(&tmp_ar->ab->base_lock);
+				kfree(tmp_arsta);
+
 				def_arsta = &ahsta->deflink;
+				def_arsta->rhash_done = false;
 				wiphy_work_init(&def_arsta->update_wk, ath12k_sta_rc_update_wk);
-				ahsta->assoc_link_id = tmp_arsta->link_id;
-				rcu_assign_pointer(ahsta->link[tmp_link_id], &ahsta->deflink);
+				ahsta->assoc_link_id = tmp_link_id;
+				rcu_assign_pointer(ahsta->link[tmp_link_id], def_arsta);
 				synchronize_rcu();
-				kfree(tmp_arsta);
+
+				/* Re-add the deflink addr to hash table
+				 */
+				spin_lock_bh(&tmp_ar->ab->base_lock);
+				ath12k_link_sta_rhash_add(tmp_ar->ab, def_arsta);
+				spin_unlock_bh(&tmp_ar->ab->base_lock);
 			}
 		}
 	}
