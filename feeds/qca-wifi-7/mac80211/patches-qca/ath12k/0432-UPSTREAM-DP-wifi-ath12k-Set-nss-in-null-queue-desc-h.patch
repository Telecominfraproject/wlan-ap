From a92acddd1730903bccb7c12b561bdbddb05fef4a Mon Sep 17 00:00:00 2001
From: Ripan Deuri <rdeuri@qti.qualcomm.com>
Date: Thu, 10 Jul 2025 12:42:42 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: Set nss in null queue desc
 handling

In case of encoding type RX_ENC_HT, rate_idx depends on the nss.
nss is not set currently in null queue desc handling.

Set nss value in null queue desc handling to fix the issue.

Also, set other mandantory fields in this path.

Patch-dependency: 0400-0007-UPSTREAM-DP-Avoid-using-hal_rx_desc_data-in-mpdu-pro.patch
Fixes: cae8e6f17ba6 (UPSTREAM: DP: RX path performance improvement changes)

Signed-off-by: Ripan Deuri <rdeuri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index d21aa03..ae592a8 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -2408,7 +2408,7 @@ static int ath12k_wifi7_dp_rx_h_null_q_desc(struct ath12k_pdev_dp *dp_pdev,
 {
 	struct rx_msdu_desc_info rx_msdu_info;
 	struct rx_mpdu_desc_info rx_mpdu_info;
-	struct rx_tlv_info_1 tlv_info;
+	struct rx_tlv_info_1 tlv_info = {0};
 	struct ath12k_dp *dp = dp_pdev->dp;
 	struct ath12k_base *ab = dp->ab;
 	u16 msdu_len = rx_desc_data->msdu_len;
@@ -2477,6 +2477,10 @@ static int ath12k_wifi7_dp_rx_h_null_q_desc(struct ath12k_pdev_dp *dp_pdev,
 	tlv_info.decap = rx_desc_data->decap;
 	tlv_info.rate_mcs = rx_desc_data->rate_mcs;
 	tlv_info.freq = rx_desc_data->freq;
+	tlv_info.nss = rx_desc_data->nss;
+	tlv_info.pkt_type = rx_desc_data->pkt_type;
+	tlv_info.bw = rx_desc_data->bw;
+	tlv_info.sgi = rx_desc_data->sgi;
 
 	ret = ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, status, &tlv_info,
 					(ATH12K_SKB_RXCB(msdu))->err_rel_src);
-- 
