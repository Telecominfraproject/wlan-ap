From ea7f9fc2dedd14d9d97bfe1434d874d343a91a20 Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Thu, 17 Jul 2025 16:41:50 +0530
Subject: [PATCH] UPSTREAM:CP ath12k:wifi: Fix bridge vdev crash and peer
 association regression

Recent changes to punc_bitmap introduced a kernel crash during bridge
vdev start on branch 4.0. Additionally, a firmware assert occurs
during bridge peer association due to incorrect num_partner_links being
sent.

This is caused by the change of ahsta->links_map from u32 to u16, which
is insufficient for bridge link IDs 23 and 24.
This patch addresses both issues.

Fixes: Ica174584267 : (UPSTREAM:CP: wifi: ath12k: Cleanup patch for
       links_map access)
       I53ba36be4e9 : (PKG upgrade rebase Progressive DFS/AGDFS)

Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h |  2 +-
 drivers/net/wireless/ath/ath12k/mac.c  | 27 +++++++++++++-------------
 2 files changed, 15 insertions(+), 14 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index fe494db..98c8346 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -836,7 +836,7 @@ struct ath12k_sta {
 	struct ath12k_link_sta deflink;
 	struct ath12k_link_sta __rcu *link[ATH12K_NUM_MAX_LINKS];
 	/* indicates bitmap of link sta created in FW */
-	u16 links_map;
+	u32 links_map;
 	u8 assoc_link_id;
 	u16 ml_peer_id;
 	u8 num_peer;
diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 6e6e47b..a07dc3a 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -9820,8 +9820,9 @@ static int ath12k_mac_set_peer_ch_switch_data(struct ath12k_link_vif *arvif,
 
 	rcu_read_unlock();
 
-	if (test_bit(WMI_TLV_SERVICE_SW_PROG_DFS_SUPPORT, ar->ab->wmi_ab.svc_map) &&
-	    cfg80211_chandef_device_present(&def)) {
+	if (!is_bridge_vdev &&
+	    (test_bit(WMI_TLV_SERVICE_SW_PROG_DFS_SUPPORT, ar->ab->wmi_ab.svc_map) &&
+	    cfg80211_chandef_device_present(&def))) {
 		ru_punct_bitmap = ath12k_mac_set_punct_bitmap_device(def.chan->center_freq,
 								     def.width_device,
 								     def.center_freq_device,
@@ -16144,22 +16145,22 @@ ath12k_mac_vdev_start_restart(struct ath12k_link_vif *arvif,
 		arg.max_power = chandef->chan->max_power;
 		arg.max_reg_power = chandef->chan->max_reg_power;
 		arg.max_antenna_gain = chandef->chan->max_antenna_gain;
+		if (!is_bridge_vdev &&
+		    test_bit(WMI_TLV_SERVICE_SW_PROG_DFS_SUPPORT, ar->ab->wmi_ab.svc_map) &&
+		    cfg80211_chandef_device_present(chandef)) {
+			arg.width_device = chandef->width_device;
+			arg.center_freq_device = chandef->center_freq_device;
+			punct_bitmap = ath12k_mac_set_punct_bitmap_device(chandef->chan->center_freq,
+									 chandef->width_device,
+									 chandef->center_freq_device,
+									 punct_bitmap);
+		}
 	}
 
+	arg.punct_bitmap = ~punct_bitmap;
 	arg.pref_tx_streams = ar->num_tx_chains;
 	arg.pref_rx_streams = ar->num_rx_chains;
 
-	if (test_bit(WMI_TLV_SERVICE_SW_PROG_DFS_SUPPORT, ar->ab->wmi_ab.svc_map) &&
-	    cfg80211_chandef_device_present(chandef)) {
-		arg.width_device = chandef->width_device;
-		arg.center_freq_device = chandef->center_freq_device;
-		punct_bitmap = ath12k_mac_set_punct_bitmap_device(chandef->chan->center_freq,
-								 chandef->width_device,
-								 chandef->center_freq_device,
-								 punct_bitmap);
-	}
-
-	arg.punct_bitmap = ~punct_bitmap;
 	if (is_bridge_vdev)
 		arg.mbssid_flags = 0;
 	else
-- 
2.34.1

