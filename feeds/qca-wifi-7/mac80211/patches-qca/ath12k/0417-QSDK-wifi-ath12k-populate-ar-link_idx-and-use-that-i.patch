From 9e66c7d8c2d3e97255ece46d1906d3e3fffaa522 Mon Sep 17 00:00:00 2001
From: Avula Sri Charan <asrichar@qti.qualcomm.com>
Date: Thu, 17 Jul 2025 10:48:30 +0530
Subject: QSDK:wifi:ath12k: populate ar->radio_idx and use that in debugfs_register

Currently the symlinks in /sys/kernel/debug/ieee80211/ath12k_hw%d is using
ar->hw_link_id instead of the ar index in ah->radio[]. But the test scripts
will rely on the iw dev index value which is advertised based on the ar index
in ah->radio[].

To resolve this save the index position in ar->radio_idx and reused that in
debugfs_register.

Also change the parameter name from hw_link_id to radio_id to avoid ambiguity.

NOTE: This patch to be removed once the new design changes are downstreamed.

Signed-off-by: Avula Sri Charan <asrichar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h    | 9 +++++----
 drivers/net/wireless/ath/ath12k/debugfs.c | 2 +-
 drivers/net/wireless/ath/ath12k/mac.c     | 1 +
 3 files changed, 7 insertions(+), 5 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -1042,6 +1042,7 @@ struct ath12k {
 	u8 pdev_idx;
 	u8 lmac_id;
 	u8 hw_link_id;
+	u8 radio_idx;
 
 	struct completion peer_assoc_done;
 	struct completion peer_delete_done;
@@ -1910,13 +1911,13 @@ static inline struct ath12k_hw *ath12k_h
 	return hw->priv;
 }
 
-static inline struct ath12k *ath12k_ah_to_ar(struct ath12k_hw *ah, u8 hw_link_id)
+static inline struct ath12k *ath12k_ah_to_ar(struct ath12k_hw *ah, u8 radio_id)
 {
-	if (WARN(hw_link_id >= ah->num_radio,
-		 "bad hw link id %d, so switch to default link\n", hw_link_id))
-		hw_link_id = 0;
+	if (WARN(radio_id >= ah->num_radio,
+		 "bad radio id %d, so switch to default link\n", radio_id))
+		radio_id = 0;
 
-	return &ah->radio[hw_link_id];
+	return &ah->radio[radio_id];
 }
 
 static inline struct ath12k_hw *ath12k_ar_to_ah(struct ath12k *ar)
--- a/drivers/net/wireless/ath/ath12k/debugfs.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs.c
@@ -4623,7 +4623,7 @@ void ath12k_debugfs_register(struct ath1
 	} else {
 		char dirname[32] = {0};
 
-		snprintf(dirname, 32, "ath12k_hw%d", ar->hw_link_id);
+		snprintf(dirname, 32, "ath12k_hw%d", ar->radio_idx);
 		ar->debug.debugfs_pdev_symlink =
 			debugfs_create_symlink(dirname,
 					       hw->wiphy->debugfsdir,
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -20941,6 +20941,7 @@ static struct ath12k_hw *ath12k_mac_hw_a
 		ar->hw_link_id = pdev->hw_link_id;
 		ar->pdev = pdev;
 		ar->pdev_idx = pdev_idx;
+		ar->radio_idx = i;
 		pdev->ar = ar;
 
 		ath12k_dp_cmn_update_hw_links(ab->dp, ag, ar);
