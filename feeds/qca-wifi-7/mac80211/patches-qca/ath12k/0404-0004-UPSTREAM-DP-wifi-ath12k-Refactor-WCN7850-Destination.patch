+static bool
+ath12k_wifi7_dp_mon_rxdesc_mpdu_valid(struct ath12k_base *ab,
+				      struct hal_rx_desc *rx_desc)
+{
+	u32 tlv_tag;
+
+	tlv_tag = hal_rx_desc_get_mpdu_start_tag(&ab->hal, rx_desc);
+
+	return tlv_tag == HAL_RX_MPDU_START;
+}
