From 68d7b372c4dbd4c0098cb988a77c0ae1eb84761f Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Thu, 19 Jun 2025 16:27:50 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Disable monitor and PPDU stats
 collection when stats_disable is set

Currently, as part of interface enablement, default rx statistics are
requested via the monitor ring, and PPDU statistics are pulled through
HTT using pull PPDU stats. These statistics are useful for debugging
and updating extended per sta statistics

However, during performance validation, the processing of these
statistics consumes significant CPU cycles. This overhead interferes
with regular data packet handling, leading to degraded performance.

Fix this by conditionally disabling monitor and PPDU statistics
collection when the user sets the `stats_disable` flag via debugfs.
Re-enable them when the flag is cleared. This ensures that performance
validation can proceed without unnecessary CPU overhead from stats
processing.

To disable the stats:
echo 1 > /sys/kernel/debug/ath12k/pci-0000:01:00.0/stats_disable

To enable the stats:
echo 0 > /sys/kernel/debug/ath12k/pci-0000:01:00.0/stats_disable

Patch-dependency: 0337-wifi-ath12k-DP-enable-perf-mode-and-call-netif-direc.patch

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs.c | 28 +++++++++++++++++------
 drivers/net/wireless/ath/ath12k/mac.c     |  2 +-
 drivers/net/wireless/ath/ath12k/mac.h     |  1 +
 3 files changed, 23 insertions(+), 8 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/debugfs.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs.c
@@ -480,20 +480,34 @@ static ssize_t ath12k_write_stats_disabl
 					  size_t count, loff_t *ppos)
 {
 	struct ath12k_base *ab = file->private_data;
-	bool disable;
-	int ret, i;
 	struct ath12k_pdev *pdev;
+	u32 mask = 0;
+	int ret, i;
+	bool disable;
 
 	if (kstrtobool_from_user(user_buf, count, &disable))
 		return -EINVAL;
 
-	if (disable != ab->stats_disable)
+	if (disable != ab->stats_disable) {
 		ab->stats_disable = disable;
 
-	for (i = 0; i < ab->num_radios; i++) {
-		pdev = &ab->pdevs[i];
-		if (pdev && pdev->ar)
-			pdev->ar->ah->hw->perf_mode = disable;
+		for (i = 0; i < ab->num_radios; i++) {
+			pdev = &ab->pdevs[i];
+			if (pdev && pdev->ar) {
+				wiphy_lock(ath12k_ar_to_hw(pdev->ar)->wiphy);
+				ath12k_mac_config_mon_status_default(pdev->ar, !disable);
+				wiphy_unlock(ath12k_ar_to_hw(pdev->ar)->wiphy);
+
+				pdev->ar->ah->hw->perf_mode = disable;
+				if (!disable)
+					mask = HTT_PPDU_STATS_TAG_DEFAULT;
+
+				ath12k_dp_tx_htt_h2t_ppdu_stats_req(pdev->ar, mask);
+
+				ath12k_info(ab, "Monitor disable %u PPDU stats mask 0x%x",
+					    disable, mask);
+			}
+		}
 	}
 
 	ret = count;
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -11845,7 +11845,7 @@ void ath12k_mac_drain_tx(struct ath12k *
 	ath12k_mgmt_over_wmi_tx_purge(ar);
 }
 
-static int ath12k_mac_config_mon_status_default(struct ath12k *ar, bool enable)
+int ath12k_mac_config_mon_status_default(struct ath12k *ar, bool enable)
 {
 	struct htt_rx_ring_tlv_filter tlv_filter = {};
 	struct ath12k_base *ab = ar->ab;
--- a/drivers/net/wireless/ath/ath12k/mac.h
+++ b/drivers/net/wireless/ath/ath12k/mac.h
@@ -366,6 +366,7 @@ void ath12k_mac_parse_tx_pwr_env(struct
 int ath12k_mac_start(struct ath12k *ar);
 int ath12k_mac_vif_link_chan(struct ieee80211_vif *vif, u8 link_id,
                                     struct cfg80211_chan_def *def);
+int ath12k_mac_config_mon_status_default(struct ath12k *ar, bool enable);
 void ath12k_mac_bss_info_changed(struct ath12k *ar,
                                 struct ath12k_link_vif *arvif,
                                 struct ieee80211_bss_conf *info,
