From eb232e36df92e39c4b437062b984fc4819e6cdf8 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <bramar@qti.qualcomm.com>
Date: Sat, 23 Aug 2025 18:15:22 +0530
Subject: [PATCH] UPSTREAM: wifi: ath12k: Fix scan vdev cleanup

Updated ath12k_scan_vdev_clean_work() to skip cleanup if arvif is
not a scan vdev, preventing unintended vdev deletion.

Improved the condition in ath12k_mac_assign_vif_to_vdev() to ensure
correct vdev assignment only when arvif is not the default link and
belongs to a different radio, thereby preventing unintended deletion.

Removed debug printk from ath12k_mac_get_6g_start_frequency()
for cleaner logs.

Signed-off-by: Balamurugan Ramar <bramar@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 8a99ecb..ed98994 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -7343,7 +7343,7 @@ static void ath12k_scan_vdev_clean_work(struct wiphy *wiphy, struct wiphy_work *
 	 * arvif is already deleted. Alternatively, if the scan vdev is not
 	 * being used as an actual vdev, then do not delete it.
 	 */
-	if (!arvif || arvif->is_started)
+	if (!arvif || arvif->is_started || !arvif->is_scan_vif)
 		goto work_complete;
 
 	ath12k_dbg(ar->ab, ATH12K_DBG_MAC, "mac clean scan vdev (link id %u)",
@@ -8742,7 +8742,6 @@ static u16 ath12k_mac_get_6g_start_frequency(struct cfg80211_chan_def *chan_def)
          * with center frequency 5955, its diff is 6025 - 5955 = 70.
          */
 
-	printk("%s:%d> chandef %p \n", __func__, __LINE__, chan_def);
 	if (!chan_def)
 		return 0;
 
