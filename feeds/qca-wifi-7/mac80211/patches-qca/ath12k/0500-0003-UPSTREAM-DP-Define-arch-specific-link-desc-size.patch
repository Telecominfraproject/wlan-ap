From 3f709c618a4ef3e90481582955f4e1acb804a3ff Mon Sep 17 00:00:00 2001
From: Nandha Kishore Easwaran <nandhaki@qti.qualcomm.com>
Date: Wed, 9 Jul 2025 13:59:04 +0530
Subject: [PATCH 3/8] UPSTREAM: DP: Define arch specific link desc size

Define arch specific link desc size and link descriptor
related params. Add new members in hal params for differentiating
these params across different architectures.

Dependency:
0500-0002-UPSTREAM-DP-Rename-wbm_rbm_map-as-cmp_rbm_map.patch

Signed-off-by: Nandha Kishore Easwaran <nandhaki@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c          | 20 ++++++++++---------
 drivers/net/wireless/ath/ath12k/hal.h         | 12 +++++------
 drivers/net/wireless/ath/ath12k/wifi7/hal.h   |  6 ++++++
 .../wireless/ath/ath12k/wifi7/hal_qcn9274.c   | 10 ++++++++++
 .../wireless/ath/ath12k/wifi7/hal_wcn7850.c   |  5 +++++
 5 files changed, 38 insertions(+), 15 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index 526ebe5..2c119f3 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -851,6 +851,7 @@ static int ath12k_dp_scatter_idle_link_desc_setup(struct ath12k_base *ab,
 	int ret = 0;
 	u32 end_offset, cookie;
 	enum hal_rx_buf_return_buf_manager rbm = dp->idle_link_rbm;
+	u16 link_desc_size = ab->hal.hal_params->link_desc_size;
 
 	n_entries_per_buf = HAL_WBM_IDLE_SCATTER_BUF_SIZE /
 		ath12k_hal_srng_get_entrysize(ab, HAL_WBM_IDLE_LINK);
@@ -879,14 +880,14 @@ static int ath12k_dp_scatter_idle_link_desc_setup(struct ath12k_base *ab,
 		align_bytes = link_desc_banks[i].vaddr -
 			      link_desc_banks[i].vaddr_unaligned;
 		n_entries = (DP_LINK_DESC_ALLOC_SIZE_THRESH - align_bytes) /
-			     HAL_LINK_DESC_SIZE;
+			     link_desc_size;
 		paddr = link_desc_banks[i].paddr;
 		while (n_entries) {
 			cookie = DP_LINK_DESC_COOKIE_SET(n_entries, i);
 			ath12k_hal_set_link_desc_addr(hal, scatter_buf, cookie,
 						      paddr, rbm);
 			n_entries--;
-			paddr += HAL_LINK_DESC_SIZE;
+			paddr += link_desc_size;
 			if (rem_entries) {
 				rem_entries--;
 				scatter_buf++;
@@ -988,18 +989,18 @@ static int ath12k_wbm_idle_ring_setup(struct ath12k_base *ab, u32 *n_link_desc)
 	int ret = 0;
 
 	n_mpdu_link_desc = (DP_NUM_TIDS_MAX * DP_AVG_MPDUS_PER_TID_MAX) /
-			   HAL_NUM_MPDUS_PER_LINK_DESC;
+			   ab->hal.hal_params->num_mpdus_per_link_desc;
 
 	n_mpdu_queue_desc = n_mpdu_link_desc /
-			    HAL_NUM_MPDU_LINKS_PER_QUEUE_DESC;
+			    ab->hal.hal_params->num_mpdu_links_per_queue_desc;
 
 	n_tx_msdu_link_desc = (DP_NUM_TIDS_MAX * DP_AVG_FLOWS_PER_TID *
 			       DP_AVG_MSDUS_PER_FLOW) /
-			      HAL_NUM_TX_MSDUS_PER_LINK_DESC;
+			      ab->hal.hal_params->num_tx_msdus_per_link_desc;
 
 	n_rx_msdu_link_desc = (DP_NUM_TIDS_MAX * DP_AVG_MPDUS_PER_TID_MAX *
 			       DP_AVG_MSDUS_PER_MPDU) /
-			      HAL_NUM_RX_MSDUS_PER_LINK_DESC;
+			      ab->hal.hal_params->num_rx_msdus_per_link_desc;
 
 	*n_link_desc = n_mpdu_link_desc + n_mpdu_queue_desc +
 		      n_tx_msdu_link_desc + n_rx_msdu_link_desc;
@@ -1030,8 +1031,9 @@ int ath12k_dp_link_desc_setup(struct ath12k_base *ab,
 	int i, ret;
 	u32 cookie;
 	enum hal_rx_buf_return_buf_manager rbm = dp->idle_link_rbm;
+	u16 link_desc_size = ab->hal.hal_params->link_desc_size;
 
-	tot_mem_sz = n_link_desc * HAL_LINK_DESC_SIZE;
+	tot_mem_sz = n_link_desc * link_desc_size;
 	tot_mem_sz += HAL_LINK_DESC_ALIGN;
 
 	if (tot_mem_sz <= DP_LINK_DESC_ALLOC_SIZE_THRESH) {
@@ -1088,7 +1090,7 @@ int ath12k_dp_link_desc_setup(struct ath12k_base *ab,
 		align_bytes = link_desc_banks[i].vaddr -
 			      link_desc_banks[i].vaddr_unaligned;
 		n_entries = (link_desc_banks[i].size - align_bytes) /
-			    HAL_LINK_DESC_SIZE;
+			    link_desc_size;
 		paddr = link_desc_banks[i].paddr;
 		while (n_entries &&
 		       (desc = ath12k_hal_srng_src_get_next_entry(ab, srng))) {
@@ -1096,7 +1098,7 @@ int ath12k_dp_link_desc_setup(struct ath12k_base *ab,
 			ath12k_hal_set_link_desc_addr(dp->hal, desc, cookie, paddr,
 						      rbm);
 			n_entries--;
-			paddr += HAL_LINK_DESC_SIZE;
+			paddr += link_desc_size;
 		}
 	}
 
diff --git a/drivers/net/wireless/ath/ath12k/hal.h b/drivers/net/wireless/ath/ath12k/hal.h
index 75fac54..bcebe4d 100644
--- a/drivers/net/wireless/ath/ath12k/hal.h
+++ b/drivers/net/wireless/ath/ath12k/hal.h
@@ -22,12 +22,7 @@ struct rx_mpdu_desc_info;
 #define HAL_RING_BASE_ALIGN	8
 #define HAL_REO_QLUT_ADDR_ALIGN 256
 
-#define HAL_LINK_DESC_SIZE			(32 << 2)
 #define HAL_LINK_DESC_ALIGN			128
-#define HAL_NUM_MPDUS_PER_LINK_DESC		6
-#define HAL_NUM_TX_MSDUS_PER_LINK_DESC		7
-#define HAL_NUM_RX_MSDUS_PER_LINK_DESC		6
-#define HAL_NUM_MPDU_LINKS_PER_QUEUE_DESC	12
 #define HAL_MAX_AVAIL_BLK_RES			3
 
 /* SRNG registers are split into two groups R0 and R2 */
@@ -1019,7 +1014,12 @@ struct hal_reo_status_header {
 
 struct ath12k_hw_hal_params {
 	enum hal_rx_buf_return_buf_manager rx_buf_rbm;
-	u32	  wbm2sw_cc_enable;
+	u32 wbm2sw_cc_enable;
+	u16 link_desc_size;
+	u16 num_mpdus_per_link_desc;
+	u16 num_tx_msdus_per_link_desc;
+	u16 num_rx_msdus_per_link_desc;
+	u16 num_mpdu_links_per_queue_desc;
 };
 
 struct ath12k_hw_regs {
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal.h b/drivers/net/wireless/ath/ath12k/wifi7/hal.h
index 9d30e16..1947ca1 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal.h
@@ -34,6 +34,12 @@ extern const struct ath12k_hw_version_map ath12k_wifi7_hw_ver_map[];
 #define HAL_SHADOW_REG(x) (HAL_SHADOW_BASE_ADDR + (4 * (x)))
 #define HAL_REO_QDESC_MAX_PEERID               8191
 
+#define HAL_LINK_DESC_SIZE			(32 << 2)
+#define HAL_NUM_MPDUS_PER_LINK_DESC		6
+#define HAL_NUM_TX_MSDUS_PER_LINK_DESC		7
+#define HAL_NUM_RX_MSDUS_PER_LINK_DESC		6
+#define HAL_NUM_MPDU_LINKS_PER_QUEUE_DESC	12
+
 /* WCSS Relative address */
 #define HAL_SEQ_WCSS_CMEM_OFFSET		0x00100000
 #define HAL_SEQ_WCSS_UMAC_OFFSET		0x00a00000
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
index bb47453..5c49e50 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
@@ -693,6 +693,11 @@ const struct ath12k_hw_hal_params ath12k_wifi7_hw_hal_params_ipq5332 = {
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW3_EN |
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW4_EN |
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW5_EN,
+	.link_desc_size = HAL_LINK_DESC_SIZE,
+	.num_mpdus_per_link_desc = HAL_NUM_MPDUS_PER_LINK_DESC,
+	.num_tx_msdus_per_link_desc = HAL_NUM_TX_MSDUS_PER_LINK_DESC,
+	.num_rx_msdus_per_link_desc = HAL_NUM_RX_MSDUS_PER_LINK_DESC,
+	.num_mpdu_links_per_queue_desc = HAL_NUM_MPDU_LINKS_PER_QUEUE_DESC,
 };
 
 const struct ath12k_hw_hal_params ath12k_wifi7_hw_hal_params_qcn9274 = {
@@ -704,6 +709,11 @@ const struct ath12k_hw_hal_params ath12k_wifi7_hw_hal_params_qcn9274 = {
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW4_EN |
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW5_EN |
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW6_EN,
+	.link_desc_size = HAL_LINK_DESC_SIZE,
+	.num_mpdus_per_link_desc = HAL_NUM_MPDUS_PER_LINK_DESC,
+	.num_tx_msdus_per_link_desc = HAL_NUM_TX_MSDUS_PER_LINK_DESC,
+	.num_rx_msdus_per_link_desc = HAL_NUM_RX_MSDUS_PER_LINK_DESC,
+	.num_mpdu_links_per_queue_desc = HAL_NUM_MPDU_LINKS_PER_QUEUE_DESC,
 };
 
 u32 ath12k_wifi7_hal_rx_h_mpdu_err_qcn9274(struct hal_rx_desc *desc)
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c
index 5f63d72..17aeccc 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c
@@ -598,6 +598,11 @@ const struct ath12k_hw_hal_params ath12k_wifi7_hw_hal_params_wcn7850 = {
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW2_EN |
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW3_EN |
 			    HAL_WBM_SW_COOKIE_CONV_CFG_WBM2SW4_EN,
+	.link_desc_size = HAL_LINK_DESC_SIZE,
+	.num_mpdus_per_link_desc = HAL_NUM_MPDUS_PER_LINK_DESC,
+	.num_tx_msdus_per_link_desc = HAL_NUM_TX_MSDUS_PER_LINK_DESC,
+	.num_rx_msdus_per_link_desc = HAL_NUM_RX_MSDUS_PER_LINK_DESC,
+	.num_mpdu_links_per_queue_desc = HAL_NUM_MPDU_LINKS_PER_QUEUE_DESC,
 };
 
 static
-- 
