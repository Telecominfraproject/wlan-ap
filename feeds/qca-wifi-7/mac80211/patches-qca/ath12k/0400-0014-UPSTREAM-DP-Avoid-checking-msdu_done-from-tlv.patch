From 4a598941060d8a615651bd12017a7b7796a34a30 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 18 Jun 2025 18:00:03 +0530
Subject: [PATCH 14/21] UPSTREAM: DP: Avoid checking msdu_done from tlv

Avoid checking msdu_done as it is not neccessary anymore

Patch-dependency : None

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/hal.h               | 3 +--
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c       | 9 ++++-----
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h       | 7 +++----
 drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c | 4 +---
 drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.h | 3 +--
 drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c | 4 +---
 drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.h | 3 +--
 7 files changed, 12 insertions(+), 21 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/hal.h b/drivers/net/wireless/ath/ath12k/hal.h
index 77c829b..215a99e 100644
--- a/drivers/net/wireless/ath/ath12k/hal.h
+++ b/drivers/net/wireless/ath/ath12k/hal.h
@@ -1287,8 +1287,7 @@ struct hal_ops {
 				     struct hal_rx_desc *rx_desc,
 				     struct hal_rx_desc *ldesc);
 	void (*extract_rx_spd_data)(struct hal_rx_spd_data *rx_info,
-				    struct hal_rx_desc *rx_desc,
-				    struct hal_rx_desc *ldesc);
+				    struct hal_rx_desc *rx_desc);
 	void (*ce_dst_setup)(struct ath12k_base *ab,
 			     struct hal_srng *srng, int ring_num);
 	void (*set_umac_srng_ptr_addr)(struct ath12k_base *ab,
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index bf3ca4c..b7ec30c 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -1173,13 +1173,14 @@ static int ath12k_wifi7_dp_rx_process_msdu(struct ath12k_pdev_dp *dp_pdev,
 	struct rx_mpdu_desc_info *rx_mpdu_info;
 	struct rx_tlv_info_1 *tlv_info;
 	struct ath12k_dp *dp = dp_pdev->dp;
-	struct hal_rx_desc *rx_desc, *lrx_desc;
+	struct hal_rx_desc *rx_desc;
 	struct hal_rx_spd_data *spd_desc_l;
 	struct sk_buff *last_buf;
 	u8 l3_pad_bytes;
 	u16 msdu_len;
 	int ret;
-	u32 hal_rx_desc_sz = dp->hal->hal_desc_sz;
+	struct ath12k_hal *hal = dp->hal;
+	u32 hal_rx_desc_sz = hal->hal_desc_sz;
 
 	spd_desc_l = (struct hal_rx_spd_data *) ATH12K_SKB_RXCB_RAW(msdu);
 	rx_msdu_info = &spd_desc_l->rx_msdu_info;
@@ -1195,9 +1196,7 @@ static int ath12k_wifi7_dp_rx_process_msdu(struct ath12k_pdev_dp *dp_pdev,
 		goto free_out;
 	}
 
-	lrx_desc = (struct hal_rx_desc *)last_buf->data;
-
-	ath12k_wifi7_dp_extract_rx_spd_data(dp, spd_desc_l, rx_desc, lrx_desc);
+	ath12k_wifi7_dp_extract_rx_spd_data(hal, spd_desc_l, rx_desc);
 
 	msdu_len = rx_msdu_info->msdu_length;
 	l3_pad_bytes = rx_msdu_info->l3_header_padding_msb ? 2 : 0;
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h
index 4dae616..4f67c53 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h
@@ -68,12 +68,11 @@ int ath12k_wifi7_dp_rx_fst_attach(struct ath12k_dp *dp, struct dp_rx_fst *fst);
 void ath12k_wifi7_dp_rx_fst_detach(struct ath12k_dp *dp, struct dp_rx_fst *fst);
 
 static inline
-void ath12k_wifi7_dp_extract_rx_spd_data(struct ath12k_dp *dp,
+void ath12k_wifi7_dp_extract_rx_spd_data(struct ath12k_hal *hal,
 					 struct hal_rx_spd_data *rx_info,
-					 struct hal_rx_desc *rx_desc,
-					 struct hal_rx_desc *ldesc)
+					 struct hal_rx_desc *rx_desc)
 {
-	dp->hw_params->hal_ops->extract_rx_spd_data(rx_info, rx_desc, ldesc);
+	hal->hal_ops->extract_rx_spd_data(rx_info, rx_desc);
 }
 
 static inline
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
index b4d9f9d..42802e3 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.c
@@ -819,10 +819,8 @@ void ath12k_wifi7_hal_extract_rx_desc_data_qcn9274(struct hal_rx_desc_data *rx_d
 }
 
 void ath12k_wifi7_hal_extract_rx_spd_data_qcn9274(struct hal_rx_spd_data *rx_info,
-						  struct hal_rx_desc *rx_desc,
-						  struct hal_rx_desc *ldesc)
+						  struct hal_rx_desc *rx_desc)
 {
-	rx_info->tlv_info.msdu_done = ath12k_wifi7_hal_rx_h_msdu_done_qcn9274(ldesc);
 	rx_info->tlv_info.freq = ath12k_wifi7_hal_rx_h_freq_qcn9274(rx_desc);
 	rx_info->tlv_info.pkt_type = ath12k_wifi7_hal_rx_h_pkt_type_qcn9274(rx_desc);
 	rx_info->tlv_info.bw = ath12k_wifi7_hal_rx_h_rx_bw_qcn9274(rx_desc);
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.h b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.h
index 204ec8b..25091b7 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_qcn9274.h
@@ -24,8 +24,7 @@ void ath12k_wifi7_hal_extract_rx_desc_data_qcn9274(struct hal_rx_desc_data *rx_d
 						   struct hal_rx_desc *rx_desc,
 						   struct hal_rx_desc *ldesc);
 void ath12k_wifi7_hal_extract_rx_spd_data_qcn9274(struct hal_rx_spd_data *rx_info,
-						  struct hal_rx_desc *rx_desc,
-						  struct hal_rx_desc *ldesc);
+						  struct hal_rx_desc *rx_desc);
 static inline
 bool ath12k_wifi7_hal_rx_h_first_msdu_qcn9274(struct hal_rx_desc *desc)
 {
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c
index e25cdaf..c1796a0 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.c
@@ -420,10 +420,8 @@ void ath12k_wifi7_hal_extract_rx_desc_data_wcn7850(struct hal_rx_desc_data *rx_d
 }
 
 void ath12k_wifi7_hal_extract_rx_spd_data_wcn7850(struct hal_rx_spd_data *rx_info,
-                                                 struct hal_rx_desc *rx_desc,
-                                                 struct hal_rx_desc *ldesc)
+                                                 struct hal_rx_desc *rx_desc)
 {
-	rx_info->tlv_info.msdu_done = ath12k_wifi7_hal_rx_h_msdu_done_wcn7850(ldesc);
 	rx_info->tlv_info.freq = ath12k_wifi7_hal_rx_h_freq_wcn7850(rx_desc);
 	rx_info->tlv_info.pkt_type = ath12k_wifi7_hal_rx_h_pkt_type_wcn7850(rx_desc);
 	rx_info->tlv_info.bw = ath12k_wifi7_hal_rx_h_rx_bw_wcn7850(rx_desc);
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.h b/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.h
index 49cd1a5..8863aff 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_wcn7850.h
@@ -21,8 +21,7 @@ void ath12k_wifi7_hal_extract_rx_desc_data_wcn7850(struct hal_rx_desc_data *rx_d
 						   struct hal_rx_desc *rx_desc,
 						   struct hal_rx_desc *ldesc);
 void ath12k_wifi7_hal_extract_rx_spd_data_wcn7850(struct hal_rx_spd_data *rx_info,
-						  struct hal_rx_desc *rx_desc,
-						  struct hal_rx_desc *ldesc);
+						  struct hal_rx_desc *rx_desc);
 static inline
 bool ath12k_wifi7_hal_wmask_compaction_rx_tlv_supported_wcn7850(void)
 {
-- 
