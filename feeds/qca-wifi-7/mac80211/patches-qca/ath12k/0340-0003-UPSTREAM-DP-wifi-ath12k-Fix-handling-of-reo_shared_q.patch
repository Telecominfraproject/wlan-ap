From 814305c4959deaf5b2cb819d8a2284bba461d9e4 Mon Sep 17 00:00:00 2001
From: Nithyanantham Paramasivam <nithp@qti.qualcomm.com>
Date: Fri, 6 Jun 2025 10:53:18 +0530
Subject: [PATCH 3/3] UPSTREAM: DP: wifi: ath12k: Fix handling of
 reo_shared_qaddr_cache_clear()

reo_shared_qaddr_cache_clear() should be executed only when the
REO LUT is enabled. A conditional check ensures it runs only
under this condition.

Signed-off-by: Nithyanantham Paramasivam <nithp@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
index 2de1b3b..2ea4ec0 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
@@ -920,6 +920,10 @@ void ath12k_wifi7_hal_reo_shared_qaddr_cache_clear(struct ath12k_base *ab)
 
 	lockdep_assert_held(&ab->base_lock);
 
+	if (!ab->hw_params->reoq_lut_support)
+		return;
+
+
 	val = ath12k_hif_read32(ab, HAL_SEQ_WCSS_UMAC_REO_REG +
 				HAL_REO1_QDESC_ADDR(hal));
 
-- 
2.17.1

