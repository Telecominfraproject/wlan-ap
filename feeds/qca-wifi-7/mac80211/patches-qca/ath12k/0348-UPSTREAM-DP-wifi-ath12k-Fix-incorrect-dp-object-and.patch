From e0720b803f6562750a9fedc4d4c911a8496fa8b3 Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Mon, 16 Jun 2025 21:18:23 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: Fix incorrect dp object and
 link_peer retrieval in RX and WBM error paths

Fix incorrect retrieval of dp_link_peer in ath12k_dp_rx_deliver_msdu()
by using ath12k_dp_link_peer_find_by_peerid_index() API.

Also fix an issue where the wrong dp object was passed with the received
MSDU, leading to failure in locating the correct dp_peer. This was due
to incorrect retrieval of dp_pdev, which is now corrected by passing
the appropriate dp object per MSDU.

Apply the same fix in the WBM error path, where
ath12k_dp_rx_bufs_replenish() was also using an incorrect dp object.

Patch-dependency: 0113-0007-wifi-ath12k-Refactor-data-path-pdev-struct.patch

Co-developed-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_rx.c       | 7 +++++--
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 6 +++---
 2 files changed, 8 insertions(+), 5 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/dp_rx.c
@@ -1008,8 +1008,7 @@ void ath12k_dp_rx_deliver_msdu(struct at
 
 	pubsta = peer ? peer->sta : NULL;
 
-	if (rxcb->peer_id)
-		link_peer = ath12k_dp_link_peer_find_by_id(dp, rxcb->peer_id);
+	link_peer = ath12k_dp_link_peer_find_by_peerid_index(dp, dp_pdev, rxcb->peer_id);
 
 	if (pubsta && pubsta->valid_links) {
 		status->link_valid = 1;
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -1226,7 +1226,7 @@ ath12k_wifi7_dp_rx_process_received_pack
 			continue;
 		}
 
-		dp_pdev = ath12k_dp_to_dp_pdev(dp, pdev_id);
+		dp_pdev = ath12k_dp_to_dp_pdev(partner_dp, pdev_id);
 		if (!dp_pdev) {
 			dev_kfree_skb_any(msdu);
 			continue;
@@ -2601,7 +2601,7 @@ int ath12k_wifi7_dp_rx_process_wbm_err(s
 			continue;
 		}
 
-		hw_link_id = ath12k_wifi7_dp_rx_get_msdu_src_link(dp, rxcb->rx_desc);
+		hw_link_id = ath12k_wifi7_dp_rx_get_msdu_src_link(partner_dp, rxcb->rx_desc);
 
 		if (hw_link_id >= ATH12K_GROUP_MAX_RADIO) {
 			dev_kfree_skb_any(msdu);
@@ -2649,7 +2649,7 @@ int ath12k_wifi7_dp_rx_process_wbm_err(s
 		partner_dp = ath12k_dp_hw_grp_to_dp(dp_hw_grp, device_id);
 		rx_ring = &partner_dp->rx_refill_buf_ring;
 
-		ath12k_dp_rx_bufs_replenish(dp, rx_ring,
+		ath12k_dp_rx_bufs_replenish(partner_dp, rx_ring,
 					    &rx_desc_used_list[device_id],
 					    num_buffs_reaped[device_id]);
 	}
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -1049,6 +1049,7 @@ int ath12k_dp_pdev_alloc(struct ath12k_b
 		 */
 		dp_pdev->ar = ar;
 		dp_pdev->dp_hw = &ar->ah->dp_hw;
+		dp_pdev->hw_link_id = ar->hw_link_id;
 
 		ret = ath12k_dp_rx_pdev_alloc(ab, i);
 		if (ret) {
