 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 92 +++++++++++++++++--
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.h |  2 +
 .../net/wireless/ath/ath12k/wifi7/hal_tx.h    |  6 ++
 drivers/net/wireless/ath/ath12k/wifi7/hw.c    | 47 ++++++++++
 7 files changed, 151 insertions(+), 11 deletions(-)

