From fdad7b9a57ab92490ea7d795ec3a0a0478bf2bb6 Mon Sep 17 00:00:00 2001
From: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Date: Fri, 14 Mar 2025 18:30:01 -0700
Subject: [PATCH 18/24] QSDK:CP:wifi:ath12k: enable ERP vendor service

Initialize and de-initialize ERP vendor service.

Patch-dependency:
0462-11-QSDK-CP-wifi-ath12K-implement-handshake-between-driv.patch

Signed-off-by: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/vendor_services.c | 2 ++
 drivers/net/wireless/ath/ath12k/vendor_services.h | 2 +-
 2 files changed, 3 insertions(+), 1 deletion(-)

--- a/drivers/net/wireless/ath/ath12k/vendor_services.c
+++ b/drivers/net/wireless/ath/ath12k/vendor_services.c
@@ -395,7 +395,10 @@ void ath12k_vendor_services_init(void)
 		ath12k_vendor_service_common_init;
 	ath12k_vendor_service_deinit[ATH12K_RM_ENERGY_SERVICE] =
 		ath12k_vendor_service_common_deinit;
-
+	ath12k_vendor_service_init[ATH12K_RM_ERP_SERVICE] =
+		ath12k_vendor_service_common_init;
+	ath12k_vendor_service_deinit[ATH12K_RM_ERP_SERVICE] =
+		ath12k_vendor_service_common_deinit;
 	/* Initialize other serives as needed */
 }
 EXPORT_SYMBOL(ath12k_vendor_services_init);
--- a/drivers/net/wireless/ath/ath12k/vendor_services.h
+++ b/drivers/net/wireless/ath/ath12k/vendor_services.h
@@ -16,7 +16,7 @@ enum ath12k_vendor_service_id {
 	ATH12K_RM_MAIN_SERVICE = 0,
 	ATH12K_UNUSED_RM_PMLO_SERVICE,
 	ATH12K_UNUSED_RM_DETSCHED_SERVICE,
-	ATH12K_UNUSED_RM_ERP_SERVICE,
+	ATH12K_RM_ERP_SERVICE,
 	ATH12K_UNUSED_RM_ADMCTRL_SERVICE,
 	ATH12K_RM_ENERGY_SERVICE,
 	ATH12K_UNUSED_RM_IFLI_PROXY_SERVICE,
