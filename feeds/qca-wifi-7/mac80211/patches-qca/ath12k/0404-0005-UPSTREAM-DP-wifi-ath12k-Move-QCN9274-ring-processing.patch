+static inline void
+ath12k_wifi7_dp_mon_rx_parse_status_msdu_end(struct ath12k_mon_data *pmon,
+					     struct hal_rx_mon_ppdu_info *ppdu_info)
+{
+	pmon->err_bitmap = ppdu_info->errmap;
+	pmon->decap_format = ppdu_info->decap_format;
