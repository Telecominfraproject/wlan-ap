From 21b3db74c1652b5979c3e4f253e70cbc0f9cd2a8 Mon Sep 17 00:00:00 2001
From: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Date: Tue, 12 Aug 2025 17:46:26 -0700
Subject: [PATCH 1/5] wifi: ath12k: QSDK: CP: Rename vendor service enum

Rename `RM` to `VENDOR_APP` for existing services

Patch-dependency:
	0480-11-QSDK-CP-wifi-ath12K-implement-handshake-between-driv.patch

Signed-off-by: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c             | 2 +-
 drivers/net/wireless/ath/ath12k/vendor_services.c | 8 ++++----
 drivers/net/wireless/ath/ath12k/vendor_services.h | 4 ++--
 3 files changed, 7 insertions(+), 7 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 0b7723d..12df80d 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -5188,7 +5188,7 @@ void ath12k_mac_ap_ps_recalc(struct ath12k *ar)
 		}
 	}
 
-	if (ath12k_vendor_is_service_enabled(ATH12K_RM_ENERGY_SERVICE))
+	if (ath12k_vendor_is_service_enabled(ATH12K_VENDOR_APP_ENERGY_SERVICE))
 		allow_ap_ps = false;
 
 	if (!allow_ap_ps)
diff --git a/drivers/net/wireless/ath/ath12k/vendor_services.c b/drivers/net/wireless/ath/ath12k/vendor_services.c
index d9e70ad..c16ce3c 100644
--- a/drivers/net/wireless/ath/ath12k/vendor_services.c
+++ b/drivers/net/wireless/ath/ath12k/vendor_services.c
@@ -391,13 +391,13 @@ void ath12k_vendor_services_init(void)
 		ath12k_vendor_main_service_init;
 	ath12k_vendor_service_deinit[ATH12K_RM_MAIN_SERVICE] =
 		ath12k_vendor_main_service_deinit;
-	ath12k_vendor_service_init[ATH12K_RM_ENERGY_SERVICE] =
+	ath12k_vendor_service_init[ATH12K_VENDOR_APP_ENERGY_SERVICE] =
 		ath12k_vendor_service_common_init;
-	ath12k_vendor_service_deinit[ATH12K_RM_ENERGY_SERVICE] =
+	ath12k_vendor_service_deinit[ATH12K_VENDOR_APP_ENERGY_SERVICE] =
 		ath12k_vendor_service_common_deinit;
-	ath12k_vendor_service_init[ATH12K_RM_ERP_SERVICE] =
+	ath12k_vendor_service_init[ATH12K_VENDOR_APP_ERP_SERVICE] =
 		ath12k_vendor_service_common_init;
-	ath12k_vendor_service_deinit[ATH12K_RM_ERP_SERVICE] =
+	ath12k_vendor_service_deinit[ATH12K_VENDOR_APP_ERP_SERVICE] =
 		ath12k_vendor_service_common_deinit;
 	/* Initialize other serives as needed */
 }
diff --git a/drivers/net/wireless/ath/ath12k/vendor_services.h b/drivers/net/wireless/ath/ath12k/vendor_services.h
index 6931af2..742224e 100644
--- a/drivers/net/wireless/ath/ath12k/vendor_services.h
+++ b/drivers/net/wireless/ath/ath12k/vendor_services.h
@@ -16,9 +16,9 @@ enum ath12k_vendor_service_id {
 	ATH12K_RM_MAIN_SERVICE = 0,
 	ATH12K_UNUSED_RM_PMLO_SERVICE,
 	ATH12K_UNUSED_RM_DETSCHED_SERVICE,
-	ATH12K_RM_ERP_SERVICE,
+	ATH12K_VENDOR_APP_ERP_SERVICE,
 	ATH12K_UNUSED_RM_ADMCTRL_SERVICE,
-	ATH12K_RM_ENERGY_SERVICE,
+	ATH12K_VENDOR_APP_ENERGY_SERVICE,
 	ATH12K_UNUSED_RM_IFLI_PROXY_SERVICE,
 	ATH12K_RM_MAX_SERVICE
 };
-- 
