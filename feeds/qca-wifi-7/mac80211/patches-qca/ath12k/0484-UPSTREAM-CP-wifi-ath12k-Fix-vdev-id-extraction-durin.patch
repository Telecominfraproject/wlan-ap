From 6f983327217be7e776c13d5ef5b246c693f4a490 Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Date: Fri, 25 Jul 2025 12:47:07 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k:Fix vdev id extraction during CU
 update

CU update is taken care of all the radios and all the VAPs configured in
the radio. To extract the vdev id, allocated vdev map is OR'ed with bit
for the range of 0 - 16. But in case of split phy, the vdev is span from
0-16*number of radios. This causes loop to exit without checking vdev id
17 - 31 for another radio. When highest index 16 is returned, iterator
might not find the arvif which causes below warning to get flooded:

[123862.309682] ath12k_wifi7_pci 0001:01:00.0: No VIF found for vdev 17
[123862.426378] ath12k_wifi7_pci 0001:01:00.0: No VIF found for vdev 16

Add a new variable to keep track of maximum vdev supported in SoC which
will help to loop through all the vdev created.

Patch-work:None
Patch-dependency:
0292-0003-ath12k-Handle-CU-and-BPCC-for-probe-and-assoc-respon.patch

Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h |  1 +
 drivers/net/wireless/ath/ath12k/mac.c  |  1 +
 drivers/net/wireless/ath/ath12k/wmi.c  | 17 +++++++++++------
 3 files changed, 13 insertions(+), 6 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -1799,6 +1799,7 @@ struct ath12k_base {
 	bool is_bypassed;
 	enum ath12k_wsi_bypass_action wsi_remap_state;
 	bool is_static_bypassed;
+	u32 num_max_vdev_supported;
 
 	/* must be last */
 	u8 drv_priv[] __aligned(sizeof(void *));
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -22028,6 +22028,7 @@ static void ath12k_mac_set_device_defaul
 	spin_lock_bh(&ab->base_lock);
 	total_vdevs = ath12k_core_get_total_num_vdevs(ab);
 	ab->free_vdev_map = (1LL << (ab->num_radios * total_vdevs)) - 1;
+	ab->num_max_vdev_supported = (ab->num_radios * total_vdevs);
 	spin_unlock_bh(&ab->base_lock);
 }
 
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -8550,17 +8550,19 @@ static int ath12k_wmi_tlv_mgmt_rx_parse(
 	return 0;
 }
 
-static u32 ath12k_get_ar_next_vdev_pos(struct ath12k *ar, u32 pos)
+static bool ath12k_get_ar_next_vdev_pos(struct ath12k *ar, u32 *pos)
 {
 	bool bit;
 	u32 i = 0;
 
-	for (i = pos; i < MAX_AP_MLDS_PER_LINK; i++) {
+	for (i = *pos; i < ar->ab->num_max_vdev_supported; i++) {
 		bit = ar->allocated_vdev_map & (1LL << i);
-		if (bit)
-			break;
+		if (bit) {
+			*pos = i;
+			return true;
+		}
 	}
-	return i;
+	return false;
 }
 
 static void ath12k_update_cu_params(struct ath12k_base *ab,
@@ -8589,7 +8591,10 @@ static void ath12k_update_cu_params(stru
 
 			pos = 0;
 			for (i = 0; i < ar->num_created_vdevs; i++) {
-				pos = ath12k_get_ar_next_vdev_pos(ar, pos);
+				if (!ath12k_get_ar_next_vdev_pos(ar, &pos)) {
+					pos++;
+					continue;
+				}
 				vdev_id = pos;
 				pos++;
 				arvif = ath12k_mac_get_arvif(ar, vdev_id);
