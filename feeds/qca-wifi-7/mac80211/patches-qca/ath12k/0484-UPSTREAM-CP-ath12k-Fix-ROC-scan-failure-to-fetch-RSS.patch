From 3ad04a61f13f175da76bff8ea177970adb739cc7 Mon Sep 17 00:00:00 2001
From: Banka Sai Krishna <banksaik@qti.qualcomm.com>
Date: Fri, 22 Aug 2025 18:32:30 +0530
Subject: [PATCH] UPSTREAM:CP:ath12k: Fix ROC scan failure to fetch RSSI for
 non-associated 6GHz clients

Ensure `append_chan_list` is set when the requested channel is found during ROC scan.
Previously, this flag was not set for 6GHz channels, causing RSSI fetch to fail for
non-associated clients. The change enables proper channel list construction and
successful scan by correctly appending the requested channel.

Signed-off-by: Banka Sai Krishna <banksaik@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wmi.c b/drivers/net/wireless/ath/ath12k/wmi.c
index 2f6535b..fb0278a 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -3413,7 +3413,6 @@ int ath12k_wmi_update_scan_chan_list(struct ath12k *ar,
 
 	arg->pdev_id = ar->pdev->pdev_id;
 	arg->nallchans = num_channels;
-	arg->append_chan_list = true;
 
 	ch = arg->channel;
 	chandef = req_arg ? req_arg->chandef : NULL;
@@ -3451,6 +3450,7 @@ int ath12k_wmi_update_scan_chan_list(struct ath12k *ar,
 
                                ch->phy_mode = req_arg->chan_list.chan[0].phymode;
                                channel = req_channel;
+			       arg->append_chan_list = true;
                                found = true;
                        } else {
                                ch->mhz = channel->center_freq;
-- 
2.34.1

