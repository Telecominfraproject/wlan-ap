From 6061c81c80d8b87c8ba5189be96ade8710c9b3ea Mon Sep 17 00:00:00 2001
From: Sarika Sharma <sarika.sharma@oss.qualcomm.com>
Date: Tue, 23 Sep 2025 09:50:17 +0530
Subject: [PATCH] UPSTREAM:DP: wifi:ath12k: update tx completion logic to
 support MLD peer lookup

Replace legacy peer lookup with MLD-aware resolution using
ath12k_dp_peer_find_by_peerid_index(). This ensures correct peer
mapping in multi-link scenarios by referencing the appropriate
link_peers[stats_link_id].

Clean up unused peer_id override logic in tx_complete_msdu and
ensure txrate and stats updates are applied to the correct peer.

Patch-dependency: 0532-wifi-ath12k-update-ts-peer_id-with-link_id-to-fix-pe.patch

Signed-off-by: Sarika Sharma <sarika.sharma@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 20 +++++++++----------
 1 file changed, 10 insertions(+), 10 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -1797,14 +1797,22 @@ ath12k_wifi7_dp_tx_update_txcompl(struct
 	struct ath12k_dp_link_peer *peer;
 	struct ieee80211_sta *sta;
 	struct ath12k_sta *ahsta;
+	struct ath12k_dp_peer *dp_peer;
 	struct ath12k_link_sta *arsta;
 	struct rate_info txrate = {0};
 	u16 rate, ru_tones;
 	u8 rate_idx = 0;
 	int ret;
 
+	dp_peer = ath12k_dp_peer_find_by_peerid_index(dp, dp_pdev, ts->peer_id);
+	if (!dp_peer) {
+		ath12k_dbg(ab, ATH12K_DBG_DP_TX,
+			   "MLD peer NA with peer_id: %u\n", ts->peer_id);
+		return;
+	}
+
 	spin_lock_bh(&dp->dp_lock);
-	peer = ath12k_dp_link_peer_find_by_id(dp, ts->peer_id);
+	peer = rcu_dereference(dp_peer->link_peers[dp_peer->stats_link_id]);
 	if (!peer || !peer->sta) {
 		ath12k_dbg(ab, ATH12K_DBG_DP_TX,
 			   "failed to find the peer by id %u\n", ts->peer_id);
@@ -1908,7 +1916,7 @@ ath12k_wifi7_dp_tx_update_txcompl(struct
 	}
 
 	spin_lock_bh(&dp->dp_lock);
-	peer = ath12k_dp_link_peer_find_by_id(dp, ts->peer_id);
+	peer = rcu_dereference(dp_peer->link_peers[dp_peer->stats_link_id]);
 	if (peer)
 		peer->txrate = txrate;
 	else
@@ -2010,9 +2018,6 @@ static void ath12k_wifi7_dp_tx_complete_
 	if (peer) {
 		link_id = ath12k_dp_get_link_id(dp_pdev, ts, peer);
 		peer->stats_link_id = link_id;
-		link_peer = rcu_dereference(peer->link_peers[link_id]);
-		if (link_peer)
-			ts->peer_id = link_peer->peer_id;
 		ath12k_dp_tx_update_peer_basic_stats(peer, msdu_len, ts->status,
 						     link_id, ring);
 
