From abd44a50067d6658a21381c1469bf2aaebb7410f Mon Sep 17 00:00:00 2001
From: Uraj Sasan <usasan@qti.qualcomm.com>
Date: Tue, 10 Jun 2025 11:59:48 +0530
Subject: [PATCH 2/2] UPSTREAM:PROTOCOL:wifi:ath12k: Update wiphy sband for
 2GHz if duplicated

When 2GHz band capabilities VHT_EXT_NSS_BW_CAPABLE is checked and if the support
is not there wiphy duplicates the sband info in ieee80211_register_hw().
Due to this the wiphy sband between the mac layer and driver is not same.

Now when the user changes the tx/rx chinmask the VHT_MCS is updated but
since the sband info stored in the driver is different from the sband info
in the wiphy the userspace does not receive the updated vht_mcs values.

Make sure to update vhtmcs when sband is duplicated during chainmask change.

Signed-off-by: Uraj Sasan <usasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index a9e4818..3c15089 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -9152,7 +9152,7 @@ static void ath12k_mac_setup_ht_vht_cap(struct ath12k *ar,
 					struct ath12k_pdev_cap *cap,
 					u32 *ht_cap_info)
 {
-	struct ieee80211_supported_band *band;
+	struct ieee80211_supported_band *band, *band_wiphy;
 	u32 rate_cap_tx_chainmask;
 	u32 rate_cap_rx_chainmask;
 	u32 ht_cap;
@@ -9162,6 +9162,7 @@ static void ath12k_mac_setup_ht_vht_cap(struct ath12k *ar,
 
 	if (cap->supported_bands & WMI_HOST_WLAN_2GHZ_CAP) {
 		band = &ar->mac.sbands[NL80211_BAND_2GHZ];
+		band_wiphy = ar->ah->hw->wiphy->bands[NL80211_BAND_2GHZ];
 		ht_cap = cap->band[NL80211_BAND_2GHZ].ht_cap_info;
 		if (ht_cap_info)
 			*ht_cap_info = ht_cap;
@@ -9169,6 +9170,14 @@ static void ath12k_mac_setup_ht_vht_cap(struct ath12k *ar,
 						    rate_cap_rx_chainmask);
 		band->vht_cap = ath12k_create_vht_cap(ar, rate_cap_tx_chainmask,
 						    rate_cap_rx_chainmask);
+		/* Update wiphy sband info if sband structure is set/cleared */
+		if (band != band_wiphy) {
+			band_wiphy->ht_cap =  band->ht_cap;
+			band_wiphy->vht_cap = band->vht_cap;
+			/* set/clear the value if it was duped */
+			band_wiphy->vht_cap.vht_mcs.tx_highest ^=
+				cpu_to_le16(IEEE80211_VHT_EXT_NSS_BW_CAPABLE);
+		}
 	}
 
 	if (cap->supported_bands & WMI_HOST_WLAN_5GHZ_CAP &&
-- 
