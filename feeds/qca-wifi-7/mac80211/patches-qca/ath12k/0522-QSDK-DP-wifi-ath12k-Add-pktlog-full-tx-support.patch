-        trace_ath12k_htt_pktlog_tx_handler(ar, pl_tgt_hdr, pl_hdr.size,
+	struct ath12k *ar;
+	struct ath12k_htt_pktlog_msg *msg;
+	u16 payload_size;
+	u8 pdev_id;
+
+	if (!skb->data)
+		return;
