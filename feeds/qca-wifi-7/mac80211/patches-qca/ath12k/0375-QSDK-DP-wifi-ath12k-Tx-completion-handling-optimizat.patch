+
+	tx_status_entry = (struct ath12k_wifi7_tx_status_entry *)dp_hw_grp->tx_status_buf[ring_id];
+	while (n_entry--) {
+		tx_status = &tx_status_entry->tx_status;
+		sw_metadata = &tx_status_entry->sw_metadata;
+
+		tx_status_entry++;
+
