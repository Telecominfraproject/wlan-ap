From faa35c976b86c06d4f9b121e7427b39b8332ea16 Mon Sep 17 00:00:00 2001
From: Yuvasree Sivasankaran <ysivasan@qti.qualcomm.com>
Date: Thu, 26 Jun 2025 16:46:35 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k:add support to count rx retries

Add support to count station level rx retries.
It denotes the number of data frames(MPDUs) received
with rx retry bit set and also Add rx_retries count
per station per link.

This patch combines changes of below patches
869-b-wifi-ath12k-add-support-to-count-rx-retries.patch
962-QSDK-ath12k-show-rx_retries-packets-at-link-level.patch

root@OpenWrt:~# cat /sys/kernel/debug/ieee80211/phy00/netdev:phy00.1-0/stations/
00:03:7f:01:a9:40/link-0/rx_mpdu_retries
42

root@OpenWrt:~# iw phy00.1-0.sta1 station dump
Station 00:03:7f:01:a3:34 (on phy00.1-0.sta1 - link0)
        inactive time:  6730 ms
        rx bytes:       182093
        rx packets:     1957
        tx bytes:       68225
.
.
.
        current time:   1749764166565 ms
        rx retries:     42

Patch Dependency: 0285-UPSTREAM-DP-wifi-cfg80211-add-support-to-count-rx.patch

Signed-off-by: Hari Chandrakanthan <haric@qti.qualcomm.com>
Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
Signed-off-by: Yuvasree Sivasankaran <ysivasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs_sta.c | 59 +++++++++++++++++++
 drivers/net/wireless/ath/ath12k/dp_cmn.h      |  1 +
 drivers/net/wireless/ath/ath12k/dp_mon.c      | 11 ++++
 drivers/net/wireless/ath/ath12k/dp_peer.c     |  1 +
 drivers/net/wireless/ath/ath12k/dp_peer.h     |  1 +
 drivers/net/wireless/ath/ath12k/hal.h         |  2 +
 drivers/net/wireless/ath/ath12k/mac.c         |  3 +
 .../net/wireless/ath/ath12k/wifi7/hal_rx.h    |  4 +-
 8 files changed, 81 insertions(+), 1 deletion(-)

--- a/drivers/net/wireless/ath/ath12k/debugfs_sta.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs_sta.c
@@ -1342,6 +1342,61 @@ static const struct file_operations fops
 	.llseek = default_llseek,
 };
 
+static ssize_t
+ath12k_dbg_sta_read_rx_retries(struct file *file, char __user *user_buf,
+			       size_t count, loff_t *ppos)
+{
+	struct ieee80211_link_sta *link_sta = file->private_data;
+	struct ieee80211_sta *sta = link_sta->sta;
+	u8 link_id = link_sta->link_id;
+	struct ath12k_sta *ahsta = ath12k_sta_to_ahsta(sta);
+	struct ath12k_hw *ah = ahsta->ahvif->ah;
+	struct ath12k_link_sta *arsta;
+	struct ath12k *ar;
+        struct ath12k_dp_link_peer *link_peer;
+        struct ath12k_dp *dp;
+	char buf[32];
+	size_t len;
+
+        wiphy_lock(ah->hw->wiphy);
+
+        if (!(BIT(link_id) & ahsta->links_map)) {
+                wiphy_unlock(ah->hw->wiphy);
+                return -ENOENT;
+        }
+
+        arsta = wiphy_dereference(ah->hw->wiphy, ahsta->link[link_id]);
+        if (!arsta || !arsta->arvif->ar) {
+                wiphy_unlock(ah->hw->wiphy);
+                return -ENOENT;
+        }
+
+        ar = arsta->arvif->ar;
+
+        dp = ath12k_ab_to_dp(ar->ab);
+        spin_lock_bh(&dp->dp_lock);
+
+        link_peer = ath12k_dp_link_peer_find_by_addr(dp, arsta->addr);
+        if (!link_peer) {
+                spin_unlock_bh(&dp->dp_lock);
+                wiphy_unlock(ah->hw->wiphy);
+                return -ENOENT;
+        }
+
+	len = scnprintf(buf, sizeof(buf), "%u\n", link_peer->peer_stats.rx_retries);
+	spin_unlock_bh(&dp->dp_lock);
+	wiphy_unlock(ah->hw->wiphy);
+
+	return simple_read_from_buffer(user_buf, count, ppos, buf, len);
+}
+
+static const struct file_operations fops_rx_retries = {
+	.read = ath12k_dbg_sta_read_rx_retries,
+	.open = simple_open,
+	.owner = THIS_MODULE,
+	.llseek = default_llseek,
+};
+
 void ath12k_debugfs_link_sta_op_add(struct ieee80211_hw *hw,
 				    struct ieee80211_vif *vif,
 				    struct ieee80211_link_sta *link_sta,
@@ -1379,5 +1434,9 @@ void ath12k_debugfs_link_sta_op_add(stru
 		debugfs_create_file("htt_peer_stats_reset", 0600, dir, link_sta,
 				    &fops_htt_peer_stats_reset);
 
+	debugfs_create_file("rx_mpdu_retries", 0400, dir, link_sta,
+			    &fops_rx_retries);
+
+
 }
 EXPORT_SYMBOL(ath12k_debugfs_link_sta_op_add);
--- a/drivers/net/wireless/ath/ath12k/dp_cmn.h
+++ b/drivers/net/wireless/ath/ath12k/dp_cmn.h
@@ -75,6 +75,7 @@ struct ath12k_dp_link_peer_rate_info {
 	s8 signal_avg;
 	u16 tx_retry_count;
 	u16 tx_retry_failed;
+	u32 rx_retries;
 };
 
 void ath12k_dp_cmn_device_deinit(struct ath12k_dp *dp);
--- a/drivers/net/wireless/ath/ath12k/dp_mon.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon.c
@@ -1660,10 +1660,13 @@ ath12k_dp_mon_rx_parse_status_tlv(struct
 		u16 peer_id;
 
 		info[1] = __le32_to_cpu(mpdu_start->info1);
+		info[2] = __le32_to_cpu(mpdu_start->info3);
 		peer_id = u32_get_bits(info[1], HAL_RX_MPDU_START_INFO1_PEERID);
 		if (peer_id)
 			ppdu_info->peer_id = peer_id;
 
+		ppdu_info->mpdu_retry += info[2] & HAL_RX_MPDU_START_INFO3_MPDU_RETRY;
+
 		ppdu_info->mpdu_len += u32_get_bits(info[1],
 						    HAL_RX_MPDU_START_INFO2_MPDU_LEN);
 		if (userid < HAL_MAX_UL_MU_USERS) {
@@ -1672,6 +1675,8 @@ ath12k_dp_mon_rx_parse_status_tlv(struct
 			ppdu_info->userstats[userid].sw_peer_id = peer_id;
 			ppdu_info->userstats[userid].ampdu_id =
 				u32_get_bits(info[0], HAL_RX_MPDU_START_INFO0_PPDU_ID);
+			ppdu_info->userstats[userid].mpdu_retry +=
+				info[2] & HAL_RX_MPDU_START_INFO3_MPDU_RETRY;
 		}
 
 		return HAL_RX_MON_STATUS_MPDU_START;
@@ -3262,6 +3267,7 @@ static void ath12k_dp_mon_rx_update_peer
 	if (!ath12k_debugfs_is_extd_rx_stats_enabled(pdev_dp->ar) || !rx_stats)
 		return;
 
+	peer->peer_stats.rx_retries += ppdu_info->mpdu_retry;
 	num_msdu = ppdu_info->tcp_msdu_count + ppdu_info->tcp_ack_msdu_count +
 		   ppdu_info->udp_msdu_count + ppdu_info->other_msdu_count;
 
@@ -3442,6 +3448,11 @@ ath12k_dp_mon_rx_update_user_stats(struc
 		return;
 	}
 
+	peer->peer_stats.rx_retries = user_stats->mpdu_retry;
+
+	if (!ath12k_debugfs_is_extd_rx_stats_enabled(pdev_dp->ar))
+		return;
+
 	rx_stats = peer->peer_stats.rx_stats;
 	if (!rx_stats)
 		return;
--- a/drivers/net/wireless/ath/ath12k/dp_peer.c
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.c
@@ -735,6 +735,7 @@ void ath12k_link_peer_get_sta_rate_info_
 	rate_info->signal_avg = ewma_avg_rssi_read(&link_peer->avg_rssi);
 	rate_info->tx_retry_count = link_peer->tx_retry_count;
 	rate_info->tx_retry_failed = link_peer->tx_retry_failed;
+	rate_info->rx_retries = link_peer->peer_stats.rx_retries;
 
 	spin_unlock_bh(&dp->dp_lock);
 }
--- a/drivers/net/wireless/ath/ath12k/dp_peer.h
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.h
@@ -100,6 +100,7 @@ struct ath12k_dp_peer_stats {
 	struct ath12k_htt_tx_stats *tx_stats;
 	struct ath12k_rx_peer_stats *rx_stats;
 	struct ath12k_dp_mon_peer_stats dp_mon_stats;
+	u32 rx_retries;
 };
 
 DECLARE_EWMA(avg_rssi, 10, 8)
--- a/drivers/net/wireless/ath/ath12k/hal.h
+++ b/drivers/net/wireless/ath/ath12k/hal.h
@@ -565,6 +565,7 @@ struct hal_rx_user_status {
 	bool ampdu_present;
 	u16 ampdu_id;
 	u32 errmap;
+	u32 mpdu_retry;
 };
 
 #define HAL_MAX_UL_MU_USERS	37
@@ -692,6 +693,7 @@ struct hal_rx_mon_ppdu_info {
 	struct hal_rx_eht_info eht_info;
 	struct hal_rx_tlv_aggr_info tlv_aggr;
 	u32 errmap;
+	u32 mpdu_retry;
 };
 
 
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -17501,6 +17501,9 @@ void ath12k_mac_op_sta_statistics(struct
 
 	sinfo->filled |= BIT_ULL(NL80211_STA_INFO_SIGNAL_AVG);
 
+	sinfo->rx_retries = rate_info.rx_retries;
+	sinfo->filled |= BIT_ULL(NL80211_STA_INFO_RX_RETRIES);
+
 	sinfo->tx_retries = rate_info.tx_retry_count;
 	sinfo->tx_failed = rate_info.tx_retry_failed;
 	sinfo->filled |= BIT_ULL(NL80211_STA_INFO_TX_RETRIES);
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.h
@@ -287,11 +287,13 @@ struct hal_rx_phyrx_rssi_legacy_info {
 #define HAL_RX_MPDU_START_INFO1_PEERID			GENMASK(29, 16)
 #define HAL_RX_MPDU_START_INFO1_DEVICE_ID		GENMASK(31, 30)
 #define HAL_RX_MPDU_START_INFO2_MPDU_LEN		GENMASK(13, 0)
+#define HAL_RX_MPDU_START_INFO3_MPDU_RETRY		BIT(19)
 struct hal_rx_mpdu_start {
 	__le32 rsvd0[9];
 	__le32 info0;
 	__le32 info1;
-	__le32 rsvd1[2];
+	__le32 info3;
+	__le32 rsvd1;
 	__le32 info2;
 	__le32 rsvd2[16];
 } __packed;
