From a58c02accb40ce5f41939833e88b879a04a53508 Mon Sep 17 00:00:00 2001
From: Uraj Sasan <usasan@qti.qualcomm.com>
Date: Mon, 9 Jun 2025 14:48:24 +0530
Subject: [PATCH] QSDK:CP: Fix issue in updating the VHT, HE and HT IE's

When the chanmask values are being updated using the following

$ iw phy set antenna TX RX

there is change  in the values stored in ar->cfg_tx_chainmask and
ar->cfg_rx_chainmask. These values are used for updating the IE's
and also setting the respective enabled bit. Since the value
stored can be any user configured value not only the max supported by
the hardware we will have issue when user configures values like 4,5,6, etc.
i.e non continue 11's and so the IE's will be updated incorrectly

E.g lets say user configures the values as 4 for tx and rx
i.e ar->num_tx_chains=1 and rate_cap_tx_chainmask= 0100

      if (i < ar->num_tx_chains && rate_cap_tx_chainmask & BIT(i))
		txmcs_map |= IEEE80211_VHT_MCS_SUPPORT_0_9 << (i * 2);
      else
		txmcs_map |= IEEE80211_VHT_MCS_NOT_SUPPORTED << (i * 2);

now based on the loop we will not set the VHT_MCS_SUPPORTED_0_9 for any
of the mask so changing the loop as below
      if (i < ar->num_tx_chains)
		txmcs_map |= IEEE80211_VHT_MCS_SUPPORT_0_9 << (i * 2);
      else
		txmcs_map |= IEEE80211_VHT_MCS_NOT_SUPPORTED << (i * 2);

Above loop will  enable 1SS for VHT_MCS_SUPPORTED_0_9 and rest disabled.
Similar behaviour is seen in other places also so correcting it across
the code flow

Signed-off-by: Uraj Sasan <usasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 11 ++++-------
 1 file changed, 4 insertions(+), 7 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index bb63a77..cf363a4 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -9000,7 +9000,6 @@ ath12k_create_ht_cap(struct ath12k *ar, u32 ar_ht_cap, u32 rate_cap_rx_chainmask
 		ht_cap.cap |= IEEE80211_HT_CAP_MAX_AMSDU;
 
 	for (i = 0; i < ar->num_rx_chains; i++) {
-		if (rate_cap_rx_chainmask & BIT(i))
 			ht_cap.mcs.rx_mask[i] = 0xFF;
 	}
 
@@ -9122,12 +9121,12 @@ ath12k_create_vht_cap(struct ath12k *ar, u32 rate_cap_tx_chainmask,
 	rxmcs_map = 0;
 	txmcs_map = 0;
 	for (i = 0; i < 8; i++) {
-		if (i < ar->num_tx_chains && rate_cap_tx_chainmask & BIT(i))
+		if (i < ar->num_tx_chains)
 			txmcs_map |= IEEE80211_VHT_MCS_SUPPORT_0_9 << (i * 2);
 		else
 			txmcs_map |= IEEE80211_VHT_MCS_NOT_SUPPORTED << (i * 2);
 
-		if (i < ar->num_rx_chains && rate_cap_rx_chainmask & BIT(i))
+		if (i < ar->num_rx_chains)
 			rxmcs_map |= IEEE80211_VHT_MCS_SUPPORT_0_9 << (i * 2);
 		else
 			rxmcs_map |= IEEE80211_VHT_MCS_NOT_SUPPORTED << (i * 2);
@@ -9336,14 +9335,12 @@ static void ath12k_mac_set_hemcsmap(struct ath12k *ar,
 	u32 i;
 
 	for (i = 0; i < 8; i++) {
-		if (i < ar->num_tx_chains &&
-		    (ar->cfg_tx_chainmask >> cap->tx_chain_mask_shift) & BIT(i))
+		if (i < ar->num_rx_chains)
 			txmcs_map |= IEEE80211_HE_MCS_SUPPORT_0_11 << (i * 2);
 		else
 			txmcs_map |= IEEE80211_HE_MCS_NOT_SUPPORTED << (i * 2);
 
-		if (i < ar->num_rx_chains &&
-		    (ar->cfg_rx_chainmask >> cap->tx_chain_mask_shift) & BIT(i))
+		if (i < ar->num_rx_chains)
 			rxmcs_map |= IEEE80211_HE_MCS_SUPPORT_0_11 << (i * 2);
 		else
 			rxmcs_map |= IEEE80211_HE_MCS_NOT_SUPPORTED << (i * 2);
