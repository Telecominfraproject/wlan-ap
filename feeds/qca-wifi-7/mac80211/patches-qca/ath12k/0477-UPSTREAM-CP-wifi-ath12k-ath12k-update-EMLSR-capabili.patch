From 91a85b75f8cf0b82dae585c8d5cacac870a8c570 Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Date: Mon, 28 Jul 2025 21:33:55 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k:update EMLSR capabilities of ML Station

EMLSR capabilities of ML station should be copied in peer assoc WMI
along with ML param flag to indicate that firmware should look for EML
capabilities. Update the same in ml params flag and copy the EMLSR from
sta structure in driver.

Fixes:Idd214a7c81e(pkg upgrade Added subsys, ath11k and ath12k patches
for win.wlan_host_opensource.4.0)

Patch-work:
https://lore.kernel.org/all/20250327051320.3253783-5-
quic_ramess@quicinc.com/
[PATCH ath-next]
wifi: ath12k: Set EMLSR support flag in MLO flags for EML-capable stations

Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 1 +
 drivers/net/wireless/ath/ath12k/wmi.c | 1 +
 2 files changed, 2 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 254a946..0e3bbac 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -4203,6 +4203,7 @@ static void ath12k_peer_assoc_h_mlo(struct ath12k_link_sta *arsta,
 	ml->ieee_link_id = arsta->link_id;
 	ml->bridge_peer = arsta->is_bridge_peer;
 	ml->num_partner_links = 0;
+	ml->eml_cap = sta->eml_cap;
 	links = ahsta->links_map;
 
 	rcu_read_lock();
diff --git a/drivers/net/wireless/ath/ath12k/wmi.c b/drivers/net/wireless/ath/ath12k/wmi.c
index e2aa1ac..184789b 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -3198,6 +3198,7 @@ int ath12k_wmi_send_peer_assoc_cmd(struct ath12k *ar,
 		/* Transition timeout */
 		eml_trans_timeout = ath12k_wmi_get_emlsr_trans_timeout_us(eml_cap);
 		ml_params->emlsr_trans_timeout_us = cpu_to_le32(eml_trans_timeout);
+		ml_params->flags |= cpu_to_le32(ATH12K_WMI_FLAG_MLO_EMLSR_SUPPORT);
 		ath12k_dbg(ar->ab, ATH12K_DBG_WMI, "wmi peer (%pM) emlsr padding delay %u, trans delay %u trans timeout %u",
 			   arg->peer_mac, ml_params->emlsr_padding_delay_us,
 			   ml_params->emlsr_trans_delay_us,
-- 
