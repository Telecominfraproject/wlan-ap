From ea7195e7648bc48fb8487543fc2f348c64a2327b Mon Sep 17 00:00:00 2001
From: Adwait Nayak <adwaitn@qti.qualcomm.com>
Date: Fri, 22 Aug 2025 03:08:47 +0530
Subject: [PATCH] QSDK:DP: wifi: ath12k: Add pktlog support for ftm mode

Add support to collect packet log in ftm mode.

Signed-off-by: Adwait Nayak <adwaitn@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs.c | 5 +++--
 drivers/net/wireless/ath/ath12k/pktlog.c  | 4 ++--
 2 files changed, 5 insertions(+), 4 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs.c b/drivers/net/wireless/ath/ath12k/debugfs.c
index e2bed25..7e144e0 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs.c
@@ -5603,7 +5603,8 @@ static ssize_t ath12k_write_pktlog_filter(struct file *file,
 	bool enable = true;
 
 	wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
-	if (ar->ah->state != ATH12K_HW_STATE_ON) {
+	if (!ath12k_ftm_mode &&
+	    ar->ah->state != ATH12K_HW_STATE_ON) {
 		ret = -ENETDOWN;
 		goto exit;
 	}
@@ -5682,7 +5683,7 @@ static ssize_t ath12k_read_pktlog_filter(struct file *file,
         int len = 0;
 
 	wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
-	if (ar->ah->state != ATH12K_HW_STATE_ON) {
+	if (!ath12k_ftm_mode && ar->ah->state != ATH12K_HW_STATE_ON) {
 		wiphy_unlock(ath12k_ar_to_hw(ar)->wiphy);
 		return -ENETDOWN;
 	}
diff --git a/drivers/net/wireless/ath/ath12k/pktlog.c b/drivers/net/wireless/ath/ath12k/pktlog.c
index 0f6fc89..fafd288 100644
--- a/drivers/net/wireless/ath/ath12k/pktlog.c
+++ b/drivers/net/wireless/ath/ath12k/pktlog.c
@@ -215,7 +215,7 @@ static ssize_t ath12k_pktlog_read(struct file *file, char __user *userbuf,
 		return 0;
 
 	wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
-	if (ar->ah->state != ATH12K_HW_STATE_ON) {
+	if (!ath12k_ftm_mode && ar->ah->state != ATH12K_HW_STATE_ON) {
 		final_ret = -ENETDOWN;
 		goto unlock;
 	}
@@ -394,7 +394,7 @@ static ssize_t ath12k_write_pktlog_start(struct file *file, const char __user *u
 		return err;
 
 	wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
-	if (ar->ah->state != ATH12K_HW_STATE_ON) {
+	if (!ath12k_ftm_mode && ar->ah->state != ATH12K_HW_STATE_ON) {
 		err = -ENETDOWN;
 		goto exit;
 	}
-- 
2.34.1

