From d5015370a04ebbede7ea8f20840252853a36f08d Mon Sep 17 00:00:00 2001
From: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
Date: Wed, 24 Sep 2025 14:50:20 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Set HW ENCAP for SAWF reinject eth
 packet

In DS mode, SAWF reinjected packets are Ethernet frames. To ensure correct
handling during datapath TX processing, set the IEEE80211_TX_CTL_HW_80211_ENCAP
flag in ieee80211_tx_info. This allows the packet to be identified as an
Ethernet frame and processed accordingly.

Patch dependency: 0532-UPSTREAM-DP-wifi-ath12k-Initialize-ieee80211-header-.patch

Signed-off-by: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_tx.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/dp_tx.c b/drivers/net/wireless/ath/ath12k/dp_tx.c
index 48a0189..bcde91c 100644
--- a/drivers/net/wireless/ath/ath12k/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/dp_tx.c
@@ -195,6 +195,7 @@ int ath12k_sdwf_reinject_handler(struct ath12k_base *ab, struct sk_buff *skb,
 	u8 msduq;
 	int ret;
 	u8 tid;
+	struct ieee80211_tx_info *tx_info = IEEE80211_SKB_CB(skb);
 
 	peer_id = le32_get_bits(status_desc->info2, HTT_TX_WBM_REINJECT_SW_PEER_ID_M);
 	data_length = le32_get_bits(status_desc->info2, HTT_TX_WBM_REINJECT_DATA_LEN_M);
@@ -244,6 +245,7 @@ int ath12k_sdwf_reinject_handler(struct ath12k_base *ab, struct sk_buff *skb,
 
 	skb_cb = ATH12K_SKB_CB(skb);
 	skb_cb->flags |= ATH12K_SKB_HW_80211_ENCAP;
+	tx_info->flags |= IEEE80211_TX_CTL_HW_80211_ENCAP;
 
 	arsta = ath12k_peer_get_link_sta(ab, peer);
 	spin_unlock_bh(&dp->dp_lock);
-- 
