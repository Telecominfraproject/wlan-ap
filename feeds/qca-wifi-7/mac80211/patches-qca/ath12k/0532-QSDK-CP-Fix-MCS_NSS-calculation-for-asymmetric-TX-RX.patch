From efbef7a137522b92ac01f95340d7444f9099027d Mon Sep 17 00:00:00 2001
From: Harish Rachakonda <rachakon@qti.qualcomm.com>
Date: Mon, 15 Sep 2025 10:02:37 +0530
Subject: [PATCH] QSDK:CP: Fix MCS_NSS calculation for asymmetric TX/RX chain
 mask configuration

Currently, MCS_NSS is calculated based only on the TX
chain mask, which is causing issues when TX and RX chain
masks are configured asymmetrically.

Updated the logic to consider both TX and RX chain masks
for accurate MCS_NSS computation.

Patch-dependency: 0351-UPSTEAM-CP-ath12k-Adds-support-to-update-EHT-MCS-NSS.patch
Patch-work: None

Signed-off-by: Harish Rachakonda <rachakon@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 44 ++++++++++++++-------------
 1 file changed, 23 insertions(+), 21 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index e72481e..643f2df 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -13577,7 +13577,7 @@ static void ath12k_mac_set_hemcsmap(struct ath12k *ar,
 	u32 i;
 
 	for (i = 0; i < 8; i++) {
-		if (i < ar->num_rx_chains)
+		if (i < ar->num_tx_chains)
 			txmcs_map |= IEEE80211_HE_MCS_SUPPORT_0_11 << (i * 2);
 		else
 			txmcs_map |= IEEE80211_HE_MCS_NOT_SUPPORTED << (i * 2);
@@ -13594,7 +13594,7 @@ static void ath12k_mac_set_hemcsmap(struct ath12k *ar,
 			txmcs_map_160 |= IEEE80211_HE_MCS_NOT_SUPPORTED << (i * 2);
 
 		if (i < maxrxnss_160 &&
-		    (ar->cfg_tx_chainmask >> cap->tx_chain_mask_shift) & BIT(i))
+		    (ar->cfg_rx_chainmask >> cap->rx_chain_mask_shift) & BIT(i))
 			rxmcs_map_160 |= IEEE80211_HE_MCS_SUPPORT_0_11 << (i * 2);
 		else
 			rxmcs_map_160 |= IEEE80211_HE_MCS_NOT_SUPPORTED << (i * 2);
@@ -13658,7 +13658,7 @@ static void ath12k_mac_copy_he_cap(struct ath12k *ar,
 }
 
 static
-u32 intersect_eht_mcsnss_map_nss(u32 eht_mcs_nss, u8 nss, bool is_20only_map)
+u32 intersect_eht_mcsnss_map_nss(u32 eht_mcs_nss, u8 tx_nss, u8 rx_nss, bool is_20only_map)
 {
 	u8 tx_mcs_0_7, tx_mcs_8_9, tx_mcs_10_11, tx_mcs_12_13;
 	u8 rx_mcs_0_7, rx_mcs_8_9, rx_mcs_10_11, rx_mcs_12_13;
@@ -13666,10 +13666,10 @@ u32 intersect_eht_mcsnss_map_nss(u32 eht_mcs_nss, u8 nss, bool is_20only_map)
 	u32 eht_map;
 
 	if (is_20only_map) {
-		rx_mcs_0_7 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
-		rx_mcs_8_9 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
-		rx_mcs_10_11 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
-		rx_mcs_12_13 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_3, nss);
+		rx_mcs_0_7 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, rx_nss);
+		rx_mcs_8_9 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, rx_nss);
+		rx_mcs_10_11 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, rx_nss);
+		rx_mcs_12_13 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_3, rx_nss);
 
 		rx_map = u32_encode_bits(rx_mcs_0_7,
 					 EHT_MCS_20_MHZ_ONLY_0_7_RX) |
@@ -13680,11 +13680,11 @@ u32 intersect_eht_mcsnss_map_nss(u32 eht_mcs_nss, u8 nss, bool is_20only_map)
 			 u32_encode_bits(rx_mcs_12_13,
 					 EHT_MCS_20_MHZ_ONLY_12_13_RX);
 
-		tx_mcs_0_7 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
-		tx_mcs_8_9 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
+		tx_mcs_0_7 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, tx_nss);
+		tx_mcs_8_9 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, tx_nss);
 
-		tx_mcs_10_11 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
-		tx_mcs_12_13 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_3, nss);
+		tx_mcs_10_11 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, tx_nss);
+		tx_mcs_12_13 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_3, tx_nss);
 		tx_map = u32_encode_bits(tx_mcs_0_7,
 					 EHT_MCS_20_MHZ_ONLY_0_7_TX) |
 			 u32_encode_bits(tx_mcs_8_9,
@@ -13695,18 +13695,18 @@ u32 intersect_eht_mcsnss_map_nss(u32 eht_mcs_nss, u8 nss, bool is_20only_map)
 					 EHT_MCS_20_MHZ_ONLY_12_13_TX);
 		eht_map = rx_map | tx_map;
 	} else {
-		rx_mcs_0_7 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
+		rx_mcs_0_7 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, rx_nss);
 		rx_mcs_8_9 = rx_mcs_0_7;
-		rx_mcs_10_11 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
-		rx_mcs_12_13 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
+		rx_mcs_10_11 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, rx_nss);
+		rx_mcs_12_13 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, rx_nss);
 		rx_map = u32_encode_bits(rx_mcs_8_9, EHT_MCS_NSS_0_9_RX) |
 			 u32_encode_bits(rx_mcs_10_11, EHT_MCS_NSS_10_11_RX) |
 			 u32_encode_bits(rx_mcs_12_13, EHT_MCS_NSS_12_13_RX);
 
-		tx_mcs_0_7 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
+		tx_mcs_0_7 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, tx_nss);
 		tx_mcs_8_9 = tx_mcs_0_7;
-		tx_mcs_10_11 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
-		tx_mcs_12_13 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
+		tx_mcs_10_11 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, tx_nss);
+		tx_mcs_12_13 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, tx_nss);
 		tx_map = u32_encode_bits(tx_mcs_8_9, EHT_MCS_NSS_0_9_TX) |
 			 u32_encode_bits(tx_mcs_10_11, EHT_MCS_NSS_10_11_TX) |
 			 u32_encode_bits(tx_mcs_12_13, EHT_MCS_NSS_12_13_TX);
@@ -13724,6 +13724,8 @@ ath12k_mac_copy_eht_mcs_nss(struct ath12k *ar, struct ath12k_band_cap *band_cap,
 {
 	u8 maxtxnss_160 = ath12k_get_nss_160mhz(ar, ar->num_tx_chains);
 	u8 maxtxnss_320 = ath12k_get_nss_320mhz(ar, ar->num_tx_chains);
+	u8 maxrxnss_160 = ath12k_get_nss_160mhz(ar, ar->num_rx_chains);
+	u8 maxrxnss_320 = ath12k_get_nss_320mhz(ar, ar->num_rx_chains);
 	u32 eht_map;
 
 	if ((he_cap->phy_cap_info[0] &
@@ -13732,7 +13734,7 @@ ath12k_mac_copy_eht_mcs_nss(struct ath12k *ar, struct ath12k_band_cap *band_cap,
 	      IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_160MHZ_IN_5G |
 	      IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_80PLUS80_MHZ_IN_5G)) == 0) {
 		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_20_only,
-						       ar->num_tx_chains,
+						       ar->num_tx_chains, ar->num_rx_chains,
 						       true);
 		memcpy(&mcs_nss->only_20mhz, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_20mhz_only));
@@ -13742,7 +13744,7 @@ ath12k_mac_copy_eht_mcs_nss(struct ath12k *ar, struct ath12k_band_cap *band_cap,
 	    (IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_40MHZ_IN_2G |
 	     IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_40MHZ_80MHZ_IN_5G)) {
 		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_80,
-						       ar->num_tx_chains,
+						       ar->num_tx_chains, ar->num_rx_chains,
 						       false);
 		memcpy(&mcs_nss->bw._80, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_bw));
@@ -13751,14 +13753,14 @@ ath12k_mac_copy_eht_mcs_nss(struct ath12k *ar, struct ath12k_band_cap *band_cap,
 	if (he_cap->phy_cap_info[0] &
 	    IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_160MHZ_IN_5G) {
 		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_160,
-						       maxtxnss_160, false);
+						       maxtxnss_160, maxrxnss_160, false);
 		memcpy(&mcs_nss->bw._160, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_bw));
 	}
 
 	if (eht_cap->phy_cap_info[0] & IEEE80211_EHT_PHY_CAP0_320MHZ_IN_6GHZ) {
 		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_320,
-						       maxtxnss_320, false);
+						       maxtxnss_320, maxrxnss_320, false);
 		memcpy(&mcs_nss->bw._320, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_bw));
 	}
-- 
2.34.1

