From 7f4ea496d148a860dce99e387e38cb775828c73a Mon Sep 17 00:00:00 2001
From: Yuvasree Sivasankaran <ysivasan@qti.qualcomm.com>
Date: Wed, 3 Sep 2025 14:05:30 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Support for rx pkts flow in and out
 of driver

Add debugfs entry to display rx pkts flow in and out of driver
for each peer associated

Command to display rx pkt flow:
cat /sys/kernel/debug/ieee80211/phyX/netdev\:wlanX/stations/
XX\:XX\:XX\:XX\:XX\:XX/driver_rx_pkts_flow

Sample Output:
cat /sys/kernel/debug/ieee80211/phy00/netdev:wlan0/stations/
00:03:7f:01:59:40/link-0/driver_rx_pkts_flow
Rx packets inflow from HW:2717048

Rx packets outflow from driver:2717048

Signed-off-by: Yuvasree Sivasankaran <ysivasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/debugfs_sta.c | 88 +++++++++++++++++++
 1 file changed, 88 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/debugfs_sta.c b/drivers/net/wireless/ath/ath12k/debugfs_sta.c
index 954c4de..ad013a9 100644
--- a/drivers/net/wireless/ath/ath12k/debugfs_sta.c
+++ b/drivers/net/wireless/ath/ath12k/debugfs_sta.c
@@ -1400,6 +1400,92 @@ static const struct file_operations fops_reset_tx_stats = {
         .llseek = default_llseek,
 };
 
+static ssize_t
+ath12k_dbg_sta_dump_driver_rx_pkts_flow(struct file *file,
+					char __user *user_buf,
+					size_t count, loff_t *ppos)
+{
+	struct ieee80211_link_sta *link_sta = file->private_data;
+	struct ath12k_sta *ahsta = ath12k_sta_to_ahsta(link_sta->sta);
+	const int size = ATH12K_STA_RX_STATS_BUF_SIZE;
+	struct ath12k_hw *ah = ahsta->ahvif->ah;
+	struct ath12k_link_sta *arsta;
+	struct ath12k *ar;
+	struct ath12k_dp_link_peer *link_peer;
+	struct ath12k_dp_peer *peer;
+	struct ath12k_dp *dp;
+	struct ath12k_dp_peer_stats *peer_stats;
+	u8 link_id = link_sta->link_id;
+	int len = 0, i, ret = 0, stats_link_id;
+	u32 recv_from_reo = 0, sent_to_stack = 0;
+
+	wiphy_lock(ah->hw->wiphy);
+
+	if (!(BIT(link_id) & ahsta->links_map)) {
+		wiphy_unlock(ah->hw->wiphy);
+		return -ENOENT;
+	}
+
+	arsta = wiphy_dereference(ah->hw->wiphy, ahsta->link[link_id]);
+	if (!arsta || !arsta->arvif->ar) {
+		wiphy_unlock(ah->hw->wiphy);
+		return -ENOENT;
+	}
+
+	ar = arsta->arvif->ar;
+
+	dp = ath12k_ab_to_dp(ar->ab);
+	spin_lock_bh(&dp->dp_lock);
+
+	link_peer = ath12k_dp_link_peer_find_by_addr(dp, arsta->addr);
+	if (!link_peer) {
+		spin_unlock_bh(&dp->dp_lock);
+		wiphy_unlock(ah->hw->wiphy);
+		return -ENOENT;
+	}
+
+	u8 *buf __free(kfree) = kzalloc(size, GFP_ATOMIC);
+	if (!buf) {
+		spin_unlock_bh(&dp->dp_lock);
+		wiphy_unlock(ah->hw->wiphy);
+		return -ENOENT;
+	}
+
+	peer = link_peer->dp_peer;
+	stats_link_id = peer->hw_links[ar->hw_link_id];
+	peer_stats = &peer->stats[stats_link_id];
+
+	for (i = 0; i < DP_REO_DST_RING_MAX; i++)
+		recv_from_reo += peer_stats->rx[i].recv_from_reo.packets;
+
+	len += scnprintf(buf + len, size - len,
+			 "Rx packets inflow from HW:%u\n", recv_from_reo);
+
+	for (i = 0; i < DP_REO_DST_RING_MAX; i++) {
+		sent_to_stack += peer_stats->rx[i].sent_to_stack.packets;
+		sent_to_stack += peer_stats->rx[i].sent_to_stack_fast.packets;
+	}
+
+	len += scnprintf(buf + len, size - len,
+			 "\nRx packets outflow from driver:%u\n", sent_to_stack);
+
+	len += scnprintf(buf + len, size - len, "\n");
+
+	spin_unlock_bh(&dp->dp_lock);
+	if (len)
+		ret = simple_read_from_buffer(user_buf, count, ppos, buf, len);
+
+	wiphy_unlock(ah->hw->wiphy);
+	return ret;
+}
+
+static const struct file_operations fops_driver_rx_pkts_flow = {
+	.read = ath12k_dbg_sta_dump_driver_rx_pkts_flow,
+	.open = simple_open,
+	.owner = THIS_MODULE,
+	.llseek = default_llseek,
+};
+
 static
 u32 ath12k_dbg_sta_dump_rate_stats(u8 *buf, u32 offset, const int size,
 				   bool he_rates_avail,
@@ -1788,6 +1874,8 @@ void ath12k_debugfs_link_sta_op_add(struct ieee80211_hw *hw,
 				    &fops_rx_stats);
 		debugfs_create_file("reset_rx_stats", 0200, dir, link_sta,
 				    &fops_reset_rx_stats);
+		debugfs_create_file("driver_rx_pkts_flow", 0400, dir, link_sta,
+				    &fops_driver_rx_pkts_flow);
 	}
 
 	debugfs_create_file("htt_peer_stats", 0400, dir, link_sta,
-- 
