 	ppdu_info->nrp_info.mcast_bcast =
-		u32_get_bits(info[5], HAL_RX_MPDU_START_INFO5_MCAST_BCAST);
+		u32_get_bits(info[5], HAL_RX_MPDU_START_INFO5_MCAST_BCAST_CMPCT);
 	ppdu_info->nrp_info.frame_control =
 		u32_get_bits(info[6],
