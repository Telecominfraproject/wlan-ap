-					 HAL_RX_MPDU_START_INFO1_SW_GRP_ID);
+					 HAL_RX_MPDU_START_INFO1_SW_GRP_ID_CMPCT);
 
-	peer_id = u32_get_bits(info[2], HAL_RX_MPDU_START_INFO2_PEERID);
+	peer_id = u32_get_bits(info[2], HAL_RX_MPDU_START_INFO2_PEERID_CMPCT);
