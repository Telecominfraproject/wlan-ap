 	ppdu_info->fc_valid =
 		u32_get_bits(info[2],
-			     HAL_RX_PPDU_END_USER_STATS_INFO2_FC_VALID);
+			     HAL_RX_PPDU_END_USER_STATS_INFO2_FC_VALID_CMPCT);
 	ppdu_info->preamble_type =
 		u32_get_bits(info[2],
