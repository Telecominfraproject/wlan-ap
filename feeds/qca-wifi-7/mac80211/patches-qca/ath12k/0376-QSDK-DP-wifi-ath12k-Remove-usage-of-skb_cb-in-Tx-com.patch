 				       struct sk_buff *msdu,
 				       struct dp_tx_ring *tx_ring,
 				       struct ath12k_dp_htt_wbm_tx_status *ts,
@@ -522,42 +542,50 @@ ath12k_wifi7_dp_tx_htt_tx_complete_buf(struct ath12k_base *ab,
 	struct ieee80211_vif *vif;
