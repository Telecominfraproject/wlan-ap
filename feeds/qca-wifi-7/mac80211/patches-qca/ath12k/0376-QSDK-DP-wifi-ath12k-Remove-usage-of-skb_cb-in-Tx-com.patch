From 146529235bfab83653ad08d7e4cd5c08b94c6630 Mon Sep 17 00:00:00 2001
From: Ripan Deuri <rdeuri@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 23:59:25 +0530
Subject: [PATCH 3/3] QSDK: DP: wifi: ath12k: Remove usage of skb_cb in Tx
 completion path

Currently in Tx completion path, we use the skb_cb for paddr, len,
paddr_ext_desc and paddr_ext_len. Accessing this in that path results in
KPI and CPU load.

In order to optimize this, avoid accessing skb_cb in that path and instead
store the same values in SW Tx descriptor ath12k_tx_desc_info and scratch pad
buffer ath12k_tx_sw_metadata and use them in that path.

Signed-off-by: Ripan Deuri <rdeuri@qti.qualcomm.com>
Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c          |   6 +-
 drivers/net/wireless/ath/ath12k/dp.h          |   4 +
 drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c | 136 +++++++++++-------
 3 files changed, 91 insertions(+), 55 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index e4666d1..29ac1e7 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -1304,7 +1304,7 @@ static void ath12k_dp_cc_cleanup(struct ath12k_base *ab)
 
 				if (tx_desc_info[k].skb_ext_desc) {
 					ath12k_core_dma_unmap_single(ab->dev,
-								     ATH12K_SKB_CB(skb)->paddr_ext_desc,
+								     tx_desc_info[k].paddr_ext_desc,
 								     tx_desc_info[k].skb_ext_desc->len,
 								     DMA_TO_DEVICE);
 					dev_kfree_skb_any(tx_desc_info[k].skb_ext_desc);
@@ -1321,8 +1321,8 @@ static void ath12k_dp_cc_cleanup(struct ath12k_base *ab)
 						wake_up(&ar->dp.tx_empty_waitq);
 				}
 
-				ath12k_core_dma_unmap_single(ab->dev, ATH12K_SKB_CB(skb)->paddr,
-							     skb->len, DMA_TO_DEVICE);
+				ath12k_core_dma_unmap_single(ab->dev, tx_desc_info[k].paddr,
+							     tx_desc_info[k].len, DMA_TO_DEVICE);
 				dev_kfree_skb_any(skb);
 
 				tx_desc_info[k].in_use = false;
diff --git a/drivers/net/wireless/ath/ath12k/dp.h b/drivers/net/wireless/ath/ath12k/dp.h
index fce113e..fee87e1 100644
--- a/drivers/net/wireless/ath/ath12k/dp.h
+++ b/drivers/net/wireless/ath/ath12k/dp.h
@@ -388,7 +388,11 @@ struct ath12k_tx_desc_info {
 	struct list_head list;
 	struct sk_buff *skb;
 	struct sk_buff *skb_ext_desc;
+	dma_addr_t paddr;
+	dma_addr_t paddr_ext_desc;
 	u32 desc_id; /* Cookie */
+	u16 len;
+	u16 ext_desc_len;
 	u8 mac_id	: 5,
 	   in_use	: 1,
 	   flags	: 1;
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
index 4abac0f..89a4b14 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_tx.c
@@ -16,15 +16,25 @@
 struct ath12k_tx_sw_metadata {
 	struct sk_buff *skb;
 	struct sk_buff *skb_ext_desc;
-	u8 mac_id       : 5,
-	  flags        : 1;
+	u64 paddr : 40,
+	    len   : 16,
+	    mac_id: 5,
+	    flags : 1,
+	    rsvd  : 2;
+	u64 paddr_ext_desc : 40,
+	    ext_desc_len   : 16,
+	    rsvd2          : 8;
 } __packed __aligned(32);
 
+static_assert(sizeof(struct ath12k_tx_sw_metadata) == 32, "size of struct ath12k_tx_sw_metadata is not 32 bytes!");
+
 struct ath12k_wifi7_tx_status_entry {
 	struct hal_wbm_completion_ring_tx tx_status;
 	struct ath12k_tx_sw_metadata sw_metadata;
 } __packed;
 
+static_assert(sizeof(struct ath12k_wifi7_tx_status_entry) == 64, "size of struct ath12k_wifi7_tx_status_entry is not 64 bytes!");
+
 static enum hal_tcl_encap_type
 ath12k_dp_tx_get_encap_type(struct ath12k_base *ab, struct sk_buff *skb)
 {
@@ -346,8 +356,11 @@ skip_htt_metadata:
 	tx_desc->mac_id = dp_link_vif->pdev_idx;
 	ti.desc_id = tx_desc->desc_id;
 	ti.data_len = skb->len;
-	skb_cb->paddr = ti.paddr;
-	skb_cb->paddr_ext_desc = 0;
+
+	tx_desc->paddr = ti.paddr;
+	tx_desc->len = ti.data_len;
+
+	tx_desc->paddr_ext_desc = 0;
 
 	if (msdu_ext_desc) {
 		skb_ext_desc = dev_alloc_skb(sizeof(struct hal_tx_msdu_ext_desc));
@@ -384,7 +397,8 @@ skip_htt_metadata:
 		ti.data_len = skb_ext_desc->len;
 		ti.type = HAL_TCL_DESC_TYPE_EXT_DESC;
 
-		skb_cb->paddr_ext_desc = ti.paddr;
+		tx_desc->paddr_ext_desc = ti.paddr;
+		tx_desc->ext_desc_len = ti.data_len;
 		tx_desc->skb_ext_desc = skb_ext_desc;
 	}
 
@@ -453,9 +467,9 @@ skip_htt_metadata:
 	return 0;
 
 fail_unmap_dma_ext:
-	if (skb_cb->paddr_ext_desc)
-		ath12k_core_dma_unmap_single(dp->dev, skb_cb->paddr_ext_desc,
-					     skb_ext_desc->len,
+	if (tx_desc->paddr_ext_desc)
+		ath12k_core_dma_unmap_single(dp->dev, tx_desc->paddr_ext_desc,
+					     tx_desc->ext_desc_len,
 					     DMA_TO_DEVICE);
 fail_free_ext_skb:
 	if (skb_ext_desc)
@@ -484,31 +498,37 @@ static void ath12k_wifi7_dp_tx_free_txbuf(struct ath12k_dp *dp,
 					  struct ath12k_tx_sw_metadata *sw_metadata)
 {
 	struct ath12k_pdev_dp *dp_pdev;
-	struct ath12k_skb_cb *skb_cb;
 	struct sk_buff *skb_ext_desc = sw_metadata->skb_ext_desc;
 	u8 pdev_id = ath12k_hw_mac_id_to_pdev_id(dp->hw_params, sw_metadata->mac_id);
 
-	skb_cb = ATH12K_SKB_CB(msdu);
-	dp_pdev = dp->dp_pdevs[pdev_id];
-
-	ath12k_core_dma_unmap_single(dp->dev, skb_cb->paddr, msdu->len, DMA_TO_DEVICE);
-	if (skb_cb->paddr_ext_desc) {
-		ath12k_core_dma_unmap_single(dp->dev, skb_cb->paddr_ext_desc,
-					     skb_ext_desc->len, DMA_TO_DEVICE);
+	ath12k_core_dma_unmap_single(dp->dev, sw_metadata->paddr, sw_metadata->len, DMA_TO_DEVICE);
+	if (sw_metadata->paddr_ext_desc) {
+		ath12k_core_dma_unmap_single(dp->dev, sw_metadata->paddr_ext_desc,
+					     sw_metadata->ext_desc_len, DMA_TO_DEVICE);
 		dev_kfree_skb_any(skb_ext_desc);
 	}
 
+	rcu_read_lock();
+
+	dp_pdev = ath12k_dp_to_dp_pdev(dp, pdev_id);
+	if (!dp_pdev) {
+		rcu_read_unlock();
+		return;
+	}
+
 	if (atomic_dec_and_test(&dp_pdev->num_tx_pending))
 		wake_up(&dp_pdev->tx_empty_waitq);
 
 	if (sw_metadata->flags & DP_TX_DESC_FLAG_FAST)
 		dev_kfree_skb_any(msdu);
 	else
-		ieee80211_free_txskb(dp_pdev->hw, msdu);
+		ieee80211_free_txskb(ath12k_dp_pdev_to_hw(dp_pdev), msdu);
+
+	rcu_read_unlock();
 }
 
