From 01d2d2a7f196967e9850567bde8357b593df5189 Mon Sep 17 00:00:00 2001
From: Sriram R <srirrama@qti.qualcomm.com>
Date: Wed, 11 Jun 2025 18:42:54 +0530
Subject: [PATCH] UPSTREAM: DP: wifi: ath12k: Drop packets with invalid rate
 info in Rx path

The following issues are addressed in this patch:

1. Rarely we see frames received with invalid channel number
in rx descriptor. Fetching the band based on this channel
leads to warning in mac80211. In such cases dump the rx desc
to identify the channel/freq received from HW.

2. If sband is NULL during ath12k_wifi7_dp_rx_h_ppdu call for 6G band, then
rx_status->freq is not filled. Due to this, facing panic_on_warn_on
in ieee80211_rx_monitor function when trying to get hw_idx from the
same frequency value. Fixing this by properly filling the
rx_status->freq value in sband NULL case.

3. Currently, some packets received with invalid MCS  trigger a WARN_ON.
This is because some clients support higher capabilities than the AP,
allowing them to send packets in higher MCS 12 and 13 rates, causing
this issue. Hence, add a WARN_ON_ONCE in driver and drop the invalid
mcs packets.

4. Currently, warn_on is getting trigger due to the presence of
corrupted packets associated with an invalid band from the
WBM error ring.
This issue can lead to unnecessary warnings and potential disruptions

Hence, add a check to drop the packets if it has invalid band and
originating from the WBM error path.

This will ensure corrupted packets are dropped and prevent the
warn_on trigger.

5. Move check for rx_desc_data->is_drop_packet after API
ath12k_wifi7_dp_rx_h_mpdu() in regular Rx processing as flag is set
inside this API.

Signed-off-by: Sriram R <srirrama@qti.qualcomm.com>
Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
Signed-off-by: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
Signed-off-by: Vinith Kumar R <vinithku@qti.qualcomm.com>
Signed-off-by: Harsh Kumar Bijlani <hbijlani@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c        |  5 ++
 drivers/net/wireless/ath/ath12k/hal.h         |  1 +
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 72 ++++++++++++++++---
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h |  3 +-
 4 files changed, 70 insertions(+), 11 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.c b/drivers/net/wireless/ath/ath12k/core.c
index 6e6b194..5c1c2ba 100644
--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -102,6 +102,11 @@ module_param_array_named(rfs_core_mask, ath12k_rfs_core_mask, int, NULL, 0644);
 MODULE_PARM_DESC(rfs_core_mask, "Default RFS core mask, mask for 2G, mask for 5G,\n"
 		 "mask for 6G. One bit for one CPU core\n");
 
+bool ath12k_debug_critical = false;
+module_param_named(debug_critical, ath12k_debug_critical, bool, 0644);
+MODULE_PARM_DESC(debug_critical, "Debug critical issue (0 - disable, 1 - enable)");
+EXPORT_SYMBOL(ath12k_debug_critical);
+
 /* protected with ath12k_hw_group_mutex */
 static struct list_head ath12k_hw_group_list = LIST_HEAD_INIT(ath12k_hw_group_list);
 
diff --git a/drivers/net/wireless/ath/ath12k/hal.h b/drivers/net/wireless/ath/ath12k/hal.h
index a80f86a..fa2e19e 100644
--- a/drivers/net/wireless/ath/ath12k/hal.h
+++ b/drivers/net/wireless/ath/ath12k/hal.h
@@ -700,6 +700,7 @@ struct hal_rx_desc_data {
 	u8 is_to_ds:1,
 	   is_from_ds:1;
 	bool no_8023_flag;
+	bool is_invalid_rate_drop;
 };
 
 struct ath12k_buffer_address {
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index 1c1feba..ec965fa 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -27,6 +27,8 @@
 
 #define ATH12K_DP_RX_FRAGMENT_TIMEOUT_MS (2 * HZ)
 
+extern bool ath12k_debug_critical;
+
 static int ath12k_wifi7_peer_rx_tid_delete_handler(struct ath12k_base *ab,
 						   struct ath12k_dp_rx_tid *rx_tid,
 						   u8 tid);
@@ -951,6 +953,8 @@ static void ath12k_wifi7_dp_rx_h_rate(struct ath12k_pdev_dp *dp_pdev,
 	u8 rate_mcs = rx_desc_data->rate_mcs, nss = rx_desc_data->nss;
 	bool is_cck;
 
+	rx_desc_data->is_invalid_rate_drop = false;
+
 	switch (pkt_type) {
 	case RX_MSDU_START_PKT_TYPE_11A:
 	case RX_MSDU_START_PKT_TYPE_11B:
@@ -962,9 +966,11 @@ static void ath12k_wifi7_dp_rx_h_rate(struct ath12k_pdev_dp *dp_pdev,
 	case RX_MSDU_START_PKT_TYPE_11N:
 		rx_status->encoding = RX_ENC_HT;
 		if (rate_mcs > ATH12K_HT_MCS_MAX) {
+			rx_desc_data->is_invalid_rate_drop = true;
 			ath12k_warn(dp->ab,
 				    "Received with invalid mcs in HT mode %d\n",
 				     rate_mcs);
+			WARN_ON_ONCE(1);
 			break;
 		}
 		rx_status->rate_idx = rate_mcs + (8 * (nss - 1));
@@ -976,9 +982,11 @@ static void ath12k_wifi7_dp_rx_h_rate(struct ath12k_pdev_dp *dp_pdev,
 		rx_status->encoding = RX_ENC_VHT;
 		rx_status->rate_idx = rate_mcs;
 		if (rate_mcs > ATH12K_VHT_MCS_MAX) {
+			rx_desc_data->is_invalid_rate_drop = true;
 			ath12k_warn(dp->ab,
 				    "Received with invalid mcs in VHT mode %d\n",
 				     rate_mcs);
+			WARN_ON_ONCE(1);
 			break;
 		}
 		rx_status->nss = nss;
@@ -989,9 +997,11 @@ static void ath12k_wifi7_dp_rx_h_rate(struct ath12k_pdev_dp *dp_pdev,
 	case RX_MSDU_START_PKT_TYPE_11AX:
 		rx_status->rate_idx = rate_mcs;
 		if (rate_mcs > ATH12K_HE_MCS_MAX) {
+			rx_desc_data->is_invalid_rate_drop = true;
 			ath12k_warn(dp->ab,
 				    "Received with invalid mcs in HE mode %d\n",
 				    rate_mcs);
+			WARN_ON_ONCE(1);
 			break;
 		}
 		rx_status->encoding = RX_ENC_HE;
@@ -1003,9 +1013,11 @@ static void ath12k_wifi7_dp_rx_h_rate(struct ath12k_pdev_dp *dp_pdev,
 		rx_status->rate_idx = rate_mcs;
 
 		if (rate_mcs > ATH12K_EHT_MCS_MAX) {
+			rx_desc_data->is_invalid_rate_drop = true;
 			ath12k_warn(dp->ab,
 				    "Received with invalid mcs in EHT mode %d\n",
 				    rate_mcs);
+			WARN_ON_ONCE(1);
 			break;
 		}
 
@@ -1021,11 +1033,14 @@ static void ath12k_wifi7_dp_rx_h_rate(struct ath12k_pdev_dp *dp_pdev,
 
 void ath12k_wifi7_dp_rx_h_ppdu(struct ath12k_pdev_dp *dp_pdev,
 			       struct ieee80211_rx_status *rx_status,
-			       struct hal_rx_desc_data *rx_desc_data)
+			       struct hal_rx_desc_data *rx_desc_data,
+			       struct sk_buff *msdu)
 {
 	u8 channel_num;
 	u32 center_freq, meta_data;
 	struct ieee80211_channel *channel;
+	struct ath12k *ar = dp_pdev->ar;
+	struct ath12k_skb_rxcb *rxcb = ATH12K_SKB_RXCB(msdu);
 
 	rx_status->freq = 0;
 	rx_status->rate_idx = 0;
@@ -1040,16 +1055,35 @@ void ath12k_wifi7_dp_rx_h_ppdu(struct ath12k_pdev_dp *dp_pdev,
 	channel_num = meta_data;
 	center_freq = meta_data >> 16;
 
+	rx_status->band = NUM_NL80211_BANDS;
+
 	if (center_freq >= ATH12K_MIN_6GHZ_FREQ &&
 	    center_freq <= ATH12K_MAX_6GHZ_FREQ) {
 		rx_status->band = NL80211_BAND_6GHZ;
 		rx_status->freq = center_freq;
-	} else if (channel_num >= 1 && channel_num <= 14) {
+	} else if (center_freq >= ATH12K_MIN_2GHZ_FREQ &&
+		   center_freq <= ATH12K_MAX_2GHZ_FREQ) {
 		rx_status->band = NL80211_BAND_2GHZ;
-	} else if (channel_num >= 36 && channel_num <= 173) {
+	} else if (center_freq >= ATH12K_MIN_5GHZ_FREQ &&
+		   center_freq <= ATH12K_MAX_5GHZ_FREQ) {
 		rx_status->band = NL80211_BAND_5GHZ;
-	} else {
-		struct ath12k *ar = dp_pdev->ar;
+	}
+
+	if (unlikely(rx_status->band == NUM_NL80211_BANDS ||
+		!dp_pdev->hw->wiphy->bands[rx_status->band])) {
+		if (rxcb->err_rel_src == HAL_WBM_REL_SRC_MODULE_REO ||
+		    rxcb->err_rel_src == HAL_WBM_REL_SRC_MODULE_RXDMA) {
+			if(ath12k_debug_critical)
+				WARN_ON_ONCE(1);
+			rx_desc_data->is_invalid_rate_drop = true;
+			return;
+		}
+		else {
+			ath12k_err(ar->ab,
+				   "sband is NULL for status band %d channel_num %d center_freq %d pdev_id %d\n",
+				   rx_status->band, channel_num, center_freq,
+				   ar->pdev_idx);
+		}
 
 		spin_lock_bh(&ar->data_lock);
 		channel = ar->rx_channel;
@@ -1057,14 +1091,21 @@ void ath12k_wifi7_dp_rx_h_ppdu(struct ath12k_pdev_dp *dp_pdev,
 			rx_status->band = channel->band;
 			channel_num =
 				ieee80211_frequency_to_channel(channel->center_freq);
+		} else {
+			ath12k_err(ar->ab, "unable to determine channel, band for rx packet");
 		}
 		spin_unlock_bh(&ar->data_lock);
+
+		rx_status->freq = ieee80211_channel_to_frequency(channel_num,
+								 rx_status->band);
+		goto h_rate;
 	}
 
 	if (rx_status->band != NL80211_BAND_6GHZ)
 		rx_status->freq = ieee80211_channel_to_frequency(channel_num,
 								 rx_status->band);
 
+h_rate:
 	ath12k_wifi7_dp_rx_h_rate(dp_pdev, rx_status, rx_desc_data);
 }
 
@@ -1167,13 +1208,17 @@ static int ath12k_wifi7_dp_rx_process_msdu(struct ath12k_pdev_dp *dp_pdev,
 	if (*fast_rx)
 		return 0;
 
-	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, rx_status, rx_desc_data);
-
 	if (rx_desc_data->is_drop_packet) {
 		ret = -EINVAL;
 		goto free_out;
 	}
 
+	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, rx_status, rx_desc_data, msdu);
+	if (unlikely(rx_desc_data->is_invalid_rate_drop)) {
+		ret = -EINVAL;
+		goto free_out;
+	}
+
 	rx_status->flag |= RX_FLAG_SKIP_MONITOR | RX_FLAG_DUP_VALIDATED;
 
 	return 0;
@@ -1506,7 +1551,10 @@ mic_fail:
 	if (unlikely(!ath12k_dp_rx_check_nwifi_hdr_len_valid(dp, rx_desc, msdu)))
 		return -EINVAL;
 
-	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, rxs, rx_desc_data);
+	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, rxs, rx_desc_data, msdu);
+	if (unlikely(rx_desc_data->is_invalid_rate_drop))
+		return -EINVAL;
+
 	ath12k_wifi7_dp_rx_h_undecap(dp_pdev, msdu, rx_desc,
 				     HAL_ENCRYPT_TYPE_TKIP_MIC, rxs, true, rx_desc_data, NULL);
 	if (rx_desc_data->is_drop_packet)
@@ -2294,7 +2342,9 @@ static int ath12k_wifi7_dp_rx_h_null_q_desc(struct ath12k_pdev_dp *dp_pdev,
 	if (unlikely(!ath12k_dp_rx_check_nwifi_hdr_len_valid(dp, desc, msdu)))
 		return -EINVAL;
 
-	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, status, rx_desc_data);
+	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, status, rx_desc_data, msdu);
+	if (unlikely(rx_desc_data->is_invalid_rate_drop))
+		return -EINVAL;
 
 	ath12k_wifi7_dp_rx_h_mpdu(dp_pdev, msdu, desc, status, rx_desc_data, &fast_rx);
 	if (rx_desc_data->is_drop_packet)
@@ -2373,7 +2423,9 @@ static bool ath12k_wifi7_dp_rx_h_tkip_mic_err(struct ath12k_pdev_dp *dp_pdev,
 	if (unlikely(!ath12k_dp_rx_check_nwifi_hdr_len_valid(dp, desc, msdu)))
 		return true;
 
-	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, status, rx_desc_data);
+	ath12k_wifi7_dp_rx_h_ppdu(dp_pdev, status, rx_desc_data, msdu);
+	if (unlikely(rx_desc_data->is_invalid_rate_drop))
+		return true;
 
 	status->flag |= (RX_FLAG_MMIC_STRIPPED | RX_FLAG_MMIC_ERROR |
 				     RX_FLAG_DECRYPTED);
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h
index 689ed0a..212e404 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.h
@@ -35,7 +35,8 @@ void ath12k_wifi7_dp_rx_peer_tid_delete(struct ath12k *ar,
 					struct ath12k_dp_link_peer *peer, u8 tid);
 void ath12k_wifi7_dp_rx_h_ppdu(struct ath12k_pdev_dp *dp_pdev,
 			       struct ieee80211_rx_status *rx_status,
-			       struct hal_rx_desc_data *rx_desc_data);
+			       struct hal_rx_desc_data *rx_desc_data,
+			       struct sk_buff *msdu);
 int ath12k_wifi7_dp_reo_cache_flush(struct ath12k_base *ab,
 				    struct ath12k_dp_rx_tid *rx_tid);
 int ath12k_wifi7_peer_rx_tid_reo_update(struct ath12k *ar,
-- 
2.34.1

