From 3c272bbff8fc5d76235b9e83d5d2c4440f8a3f77 Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Mon, 29 Sep 2025 16:25:47 +0530
Subject: [PATCH] UPSTREAM:DP: wifi: ath12k: Fix missing DMA unmap for dropped
 TLV residual monitor buffers

Currently, ath12k_wifi7_dp_mon_rx_h_drop_tlv does not unmap DMA for
monitor buffers when handling dropped TLV residuals. The code checks
if status_desc->mon_buf is present and then directly calls
ath12k_wifi7_dp_mon_h_flush_tlv to free the buffer. However, it
misses the required call to ath12k_core_dma_unmap_page before freeing
the buffer.

This omission can lead to DMA resource leaks and potential memory
corruption, as buffers may remain mapped after being freed or reused.

Fix this by adding a call to ath12k_core_dma_unmap_page before
flushing the TLV buffer. This ensures that all monitor buffers are
correctly unmapped before being released, matching the handling in
other buffer free paths.

Patch-dependency:
0524-Upstream-DP-wifi-ath12k-Zero-MPDU-metadata-region-in.patch

Fixes: Icff1100d3e1 (UPSTREAM:DP: wifi: ath12k: DP: Add Workqueue
Support for Rx Monitor)

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
index e0e1d42..16b3345 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_mon2.c
@@ -1153,6 +1153,12 @@ static void ath12k_wifi7_dp_mon_rx_h_empty_desc(struct ath12k_pdev_dp *pdev_dp)
 
 	for (desc_cnt = 0; desc_cnt < last_ppdu_desc->status_desc_cnt; desc_cnt++) {
 		status_desc = &last_ppdu_desc->status_desc[desc_cnt];
+		if (unlikely(!status_desc->mon_buf))
+			continue;
+
+		ath12k_core_dma_unmap_page(pdev_dp->dp->dev, status_desc->paddr,
+					   ATH12K_DP_MON_RX_BUF_SIZE,
+					   DMA_FROM_DEVICE);
 		ath12k_wifi7_dp_mon_h_flush_tlv(pdev_dp, status_desc);
 	}
 
@@ -1178,6 +1184,12 @@ ath12k_wifi7_dp_mon_flush_used_list(struct ath12k_pdev_dp *dp_pdev,
 
 	list_for_each_entry_safe(entry_desc, tmp_desc,
 				 mon_desc_used_list, list) {
+		if (unlikely(!entry_desc->mon_buf))
+			continue;
+
+		ath12k_core_dma_unmap_page(dp_pdev->dp->dev, entry_desc->paddr,
+					   ATH12K_DP_MON_RX_BUF_SIZE,
+					   DMA_FROM_DEVICE);
 		desc.mon_buf = entry_desc->mon_buf;
 		desc.buf_len = entry_desc->buf_len;
 		desc.end_of_ppdu = entry_desc->end_of_ppdu;
@@ -1305,6 +1317,8 @@ ath12k_wifi7_dp_mon_rx_h_drop_tlv(struct ath12k_pdev_dp *pdev_dp,
 		if (!status_desc->mon_buf)
 			continue;
 
+		ath12k_core_dma_unmap_page(pdev_dp->dp->dev, status_desc->paddr,
+					   ATH12K_DP_MON_RX_BUF_SIZE, DMA_FROM_DEVICE);
 		ath12k_wifi7_dp_mon_h_flush_tlv(pdev_dp, status_desc);
 	}
 
