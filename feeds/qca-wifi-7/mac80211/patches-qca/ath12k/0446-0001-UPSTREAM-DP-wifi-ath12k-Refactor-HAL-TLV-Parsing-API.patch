 .../net/wireless/ath/ath12k/wifi7/hal_mon.c   | 336 ++++++++----------
 .../net/wireless/ath/ath12k/wifi7/hal_mon.h   |  44 ++-
 .../ath/ath12k/wifi7/hal_mon_wcn7850.c        | 161 ++++++++-
 4 files changed, 368 insertions(+), 202 deletions(-)

