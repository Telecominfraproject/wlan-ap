 	int (*update_telemetry_stats)(struct ath12k_base *ab,
 				       const int pdev_id);
+	int (*rx_filter_alloc)(struct ath12k_pdev_dp *dp_pdev);
+	void (*rx_filter_free)(struct ath12k_pdev_dp *dp_pdev);
