From 7433e4ad28a8ab84e59b6972e6ba2f59c5f405cc Mon Sep 17 00:00:00 2001
From: Sowjanya vardhineni <svardhin@qti.qualcomm.com>
Date: Wed, 4 Jun 2025 14:32:33 +0530
Subject: [PATCH] wifi: ath12k: set RX_FLAG_SKIP_MONITOR in WBM error path

Packets delivered to mac80211 from the WBM error path currently do not
have the RX_FLAG_SKIP_MONITOR flag set. As a result, mac80211 performs
unnecessary monitor mode checks on each packet, even though these packets 
are not intended for monitor mode processing. In regular rx path, this
flag is explicitly set to avoid such overhead. Align the WBM error path
behavior by setting RX_FLAG_SKIP_MONITOR to prevent redundant per-packet 
checks in mac80211.

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
Signed-off-by: Sowjanya vardhineni <svardhin@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index a7e3fe5..3143fc4 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -2287,6 +2287,7 @@ static void ath12k_wifi7_dp_rx_wbm_err(struct ath12k_pdev_dp *dp_pdev,
 		dev_kfree_skb_any(msdu);
 		return;
 	}
+	rxs.flag |= RX_FLAG_SKIP_MONITOR;
 
 	ath12k_dp_rx_deliver_msdu(dp_pdev, napi, msdu, &rxs, &rx_desc_data);
 }
