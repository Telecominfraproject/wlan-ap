From 483efefeda3cbfe2dcce45f39299ec15a0e6e639 Mon Sep 17 00:00:00 2001
From: Uraj Sasan <usasan@qti.qualcomm.com>
Date: Thu, 7 Aug 2025 18:12:21 +0530
Subject: [PATCH] UPSTREAM:CP:ath12k: Fix QGenie reported issues

Fix issues reported by Qgenie in the code.

Signed-off-by: Uraj Sasan <usasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ini.h | 2 +-
 drivers/net/wireless/ath/ath12k/mac.c | 4 ++--
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/ini.h b/drivers/net/wireless/ath/ath12k/ini.h
index 24df52b..6beabf8 100644
--- a/drivers/net/wireless/ath/ath12k/ini.h
+++ b/drivers/net/wireless/ath/ath12k/ini.h
@@ -188,7 +188,7 @@ struct ath12k_cfg_values {
 #define MAC_ADDR_FMT "%pM"
 #define MAC_ADDR_REF(a) (a)
 
-#define ath12k_cfg_get(ab, id) __ath12_cfg_get(ab, __##id)
+#define ath12k_cfg_get(ab, id) __ath12k_cfg_get(ab, __##id)
 #define __ath12k_cfg_get(ab, id) (ath12k_cfg_get_values( \
 			(struct ath12k_base *)ab)->id##_internal)
 
diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index d9769a2..8d852b4 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -2953,7 +2953,7 @@ static u8 ath12k_get_nss_320mhz(struct ath12k *ar,
 
 	switch (nss_ratio_info) {
 	case WMI_NSS_RATIO_1BY2_NSS:
-		max_sup_nss = max_nss >> 2;
+		max_sup_nss = max_nss >> 1;
 		break;
 	case WMI_NSS_RATIO_3BY4_NSS:
 		ath12k_warn(ar->ab, "WMI_NSS_RATIO_3BY4_NSS not supported\n");
@@ -13029,7 +13029,7 @@ ath12k_mac_copy_eht_mcs_nss(struct ath12k *ar, struct ath12k_band_cap *band_cap,
 	}
 
 	if (eht_cap->phy_cap_info[0] & IEEE80211_EHT_PHY_CAP0_320MHZ_IN_6GHZ) {
-		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_160,
+		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_320,
 						       maxtxnss_320, false);
 		memcpy(&mcs_nss->bw._320, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_bw));
-- 
2.34.1

