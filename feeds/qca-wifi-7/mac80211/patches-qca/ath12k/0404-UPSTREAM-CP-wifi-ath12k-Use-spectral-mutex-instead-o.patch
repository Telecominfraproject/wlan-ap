From d9a29912edb471cbbf5b7cbd7d56a4539a36c631 Mon Sep 17 00:00:00 2001
From: Aaradhana Sahu <aarasahu@qti.qualcomm.com>
Date: Tue, 8 Jul 2025 15:03:47 +0530
Subject: [PATCH 2/2] UPSTREAM:CP: wifi: ath12k: Use spectral mutex instead of
 wiphy_lock in ath12k_spectral_deinit()

Replace wiphy_lock() with the spectral mutex in ath12k_spectral_deinit()
to protect spectral-related operations. Spectral already has its own
mutex lock, making the use of wiphy_lock() unnecessary.

Additionally, ath12k_spectral_scan_config() called from
ath12k_spectral_deinit() resets arvif->spectral_enabled and
ar->spectral.mode.
Add a check to call ath12k_spectral_scan_config() only if
ar->spectral.mode is not already set to ATH12K_SPECTRAL_DISABLED.

Patch-dependency: "0203-ath12k-add-spectral-support.patch"
Patch-work: None

Signed-off-by: Aaradhana Sahu <aarasahu@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/spectral.c | 19 +++++++++++++------
 1 file changed, 13 insertions(+), 6 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/spectral.c
+++ b/drivers/net/wireless/ath/ath12k/spectral.c
@@ -997,24 +997,24 @@ void ath12k_spectral_deinit(struct ath12
 		ar = ab->pdevs[i].ar;
 		sp = &ar->spectral;
 
-		wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
 		if (sp->spectral_cap.fft_size_caps) {
 			kfree(sp->spectral_cap.fft_size_caps);
 			sp->spectral_cap.fft_size_caps = NULL;
 		}
 
-		if (!sp->enabled) {
-			wiphy_unlock(ath12k_ar_to_hw(ar)->wiphy);
+		if (!sp->enabled)
 			continue;
-		}
-
-		ath12k_spectral_scan_config(ar, ATH12K_SPECTRAL_DISABLED);
-		wiphy_unlock(ath12k_ar_to_hw(ar)->wiphy);
 
 		spin_lock_bh(&sp->lock);
 		sp->enabled = false;
 		spin_unlock_bh(&sp->lock);
 
+		if (ar->spectral.mode != ATH12K_SPECTRAL_DISABLED) {
+			wiphy_lock(ath12k_ar_to_hw(ar)->wiphy);
+			ath12k_spectral_scan_config(ar, ATH12K_SPECTRAL_DISABLED);
+			wiphy_unlock(ath12k_ar_to_hw(ar)->wiphy);
+		}
+
 		ath12k_spectral_debug_unregister(ar);
 		ath12k_spectral_ring_free(ar);
 	}
