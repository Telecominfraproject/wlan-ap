+	 * BIT [25 : 25] - doppler_indication
+	 * BIT [29 : 26] - spatial_reuse for HE_SU,HE_MU and HE_EXT_SU format PPDU
+	 *                 HTT_PPDU_STATS_SPATIAL_REUSE
+	 * BIT [31 : 30] - reserved
+	 */
+	__le16 phy_ppdu_tx_time_us;
+	u8 num_ul_expected_users;
+	u8 reserved;
 } __packed;
 
