From 154ed8f427deb89b78c64d78d9b07150e7e6ee30 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 10 Sep 2025 15:11:00 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:ath12k: Fix the buf type check handling API
 in rx error path

Fix the buf type check handling API in rx error path by returnig the
correct error value.

patch-dependency:
0334-UPSTREAM-DP-wifi-ath12k-fix-reap-procedure-of-Rx-err.patch

Fixes: I222b3d4485b1
(UPSTREAM: DP: wifi: ath12k: Package upgrade changes for data path)

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
index 2981697..032d1fd 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hal_rx.c
@@ -351,7 +351,6 @@ int ath12k_wifi7_hal_desc_reo_parse_err(struct ath12k_dp *dp,
 	enum hal_reo_dest_ring_push_reason push_reason;
 	enum hal_reo_dest_ring_error_code err_code;
 	u32 cookie, val;
-	int ret = 0;
 
 	push_reason = le32_get_bits(desc->info0,
 				    HAL_REO_DEST_RING_INFO0_PUSH_REASON);
@@ -368,7 +367,7 @@ int ath12k_wifi7_hal_desc_reo_parse_err(struct ath12k_dp *dp,
 
 	val = le32_get_bits(desc->info0, HAL_REO_DEST_RING_INFO0_BUFFER_TYPE);
 	if (val == HAL_REO_DEST_RING_BUFFER_TYPE_MSDU) {
-		ret = -EOPNOTSUPP;
+		return -EOPNOTSUPP;
 	} else if (val != HAL_REO_DEST_RING_BUFFER_TYPE_LINK_DESC) {
 		ath12k_warn(ab, "expected buffer type link_desc, val %d", val);
 		return -EINVAL;
-- 
2.34.1

