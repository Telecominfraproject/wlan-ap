@@ -89,4 +123,7 @@ int ath12k_dp_link_peer_rhash_add(struct ath12k_dp *dp,
 				  struct ath12k_dp_link_peer *peer);
 int ath12k_dp_link_peer_rhash_delete(struct ath12k_dp *dp,
