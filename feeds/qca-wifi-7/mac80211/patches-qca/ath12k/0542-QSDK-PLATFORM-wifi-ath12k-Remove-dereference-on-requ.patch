From 04a036169d6ecad5c9c7da4b7555d532739be4f2 Mon Sep 17 00:00:00 2001
From: Saravanakumar Duraisamy <saradura@qti.qualcomm.com>
Date: Wed, 17 Sep 2025 22:47:35 +0530
Subject: [PATCH] QSDK:PLATFORM:wifi:ath12k:Remove dereference on
 request_firmware failure

Dereference fw data struct when request_firmware failure cause
crash. Remove the unwanted print which cause the crash

Signed-off-by: Saravanakumar Duraisamy <saradura@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c b/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c
index 33c338a..37c96f1 100644
--- a/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c
+++ b/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c
@@ -158,7 +158,6 @@ static int athdbg_qmi_send_qdss_config(struct ath12k_base *ab)
 			 ATH12K_QMI_DEFAULT_QDSS_CONFIG_FILE_NAME);
 
 	ret = request_firmware(&fw_entry, filename, dev);
-	pr_info("boot firmware request %s size %zu\n", filename, fw_entry->size);
 	if (ret) {
 		/* for backward compatibility */
 		snprintf(filename, sizeof(filename), "%s",
-- 
2.34.1

