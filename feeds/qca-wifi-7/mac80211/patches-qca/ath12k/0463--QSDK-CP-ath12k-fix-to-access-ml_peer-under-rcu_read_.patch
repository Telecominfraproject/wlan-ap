From 5e5e6318e018aed74fe0877366f6579c99a85056 Mon Sep 17 00:00:00 2001
From: Narendhar Reddy <nare@qti.qualcomm.com>
Date: Wed, 23 Jul 2025 22:29:40 +0530
Subject: [PATCH] QSDK:CP:ath12k: fix to access ml_peer under rcu_read_lock

move ml_peer under rcu_read_lock to avoid invalid memory
access in case of race condition.

Signed-off-by: Narendhar Reddy <nare@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 1b78d0b..3d44d7b 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -1985,13 +1985,13 @@ static void ath12k_wmi_migration_cmd_work(struct work_struct *work)
 		/* TODO: Need to check if we ml_peer_id validation
 		 */
 		ml_peer = rcu_dereference(ah->dp_hw.dp_peer_list[peer_node->ml_peer_id]);
-		rcu_read_unlock();
 
 		if (ml_peer) {
 			ahsta = ath12k_sta_to_ahsta(ml_peer->sta);
 			ahsta->is_migration_in_progress = false;
 		}
 
+		rcu_read_unlock();
 		list_del(&peer_node->list);
 		kfree(peer_node);
 	}
@@ -11969,13 +11969,13 @@ ath12k_mac_free_link_migr_peer_list(struct ath12k_hw *ah,
 		/* TODO: Need to check if we ml_peer_id validation
 		 */
 		ml_peer = rcu_dereference(ah->dp_hw.dp_peer_list[peer_node->ml_peer_id]);
-		rcu_read_unlock();
 
 		if (ml_peer) {
 			ahsta = ath12k_sta_to_ahsta(ml_peer->sta);
 			ahsta->is_migration_in_progress = false;
 		}
 
+		rcu_read_unlock();
 		list_del(&peer_node->list);
 		kfree(peer_node);
 	}
-- 
2.34.1

