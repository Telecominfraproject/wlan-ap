From 0c4536f8b66c2359a6a391ee6bde1265f69f4f6f Mon Sep 17 00:00:00 2001
From: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
Date: Mon, 15 Sep 2025 16:58:46 -0700
Subject: [PATCH] QSDK:DP:wifi:ath12k: Avoid PPE DS interrupt registration
 during UMAC Reset

Currently PPE DS interrupts are not freed for the non-asserted chips.
Hence during the PPE DS interrupt registration sequence, Add a check
to allow PPE DS interrupt registration only for the asserted chips.

Additionally ath12k_ahb_ppeds_free_interrupts() function only
disables the interrupt but doesn't free them. This change adds the
missing devm_free_irq().

Patch-Dependency:
	0348-QSDK-DP-wifi-ath12k-Enable-UMAC-reset-support-for-DS-mode.patch

Fixes: I0fa6f91d531 (QSDK:DP:wifi: ath12k: Enable UMAC reset support 
		     for DS mode)

Signed-off-by: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ahb.c |    5 +++++
 drivers/net/wireless/ath/ath12k/dp.c  |    3 ++-
 2 files changed, 7 insertions(+), 1 deletion(-)

--- a/drivers/net/wireless/ath/ath12k/ahb.c
+++ b/drivers/net/wireless/ath/ath12k/ahb.c
@@ -948,8 +948,13 @@ void ath12k_ahb_ppeds_irq_enable(struct
 void ath12k_ahb_ppeds_free_interrupts(struct ath12k_base *ab)
 {
 	disable_irq_nosync(ab->dp->ppe.ppeds_irq[PPEDS_IRQ_PPE2TCL]);
+	devm_free_irq(ab->dev, ab->dp->ppe.ppeds_irq[PPEDS_IRQ_PPE2TCL], ab);
+
 	disable_irq_nosync(ab->dp->ppe.ppeds_irq[PPEDS_IRQ_REO2PPE]);
+	devm_free_irq(ab->dev, ab->dp->ppe.ppeds_irq[PPEDS_IRQ_REO2PPE], ab);
+
 	disable_irq_nosync(ab->dp->ppe.ppeds_irq[PPEDS_IRQ_PPE_WBM2SW_REL]);
+	devm_free_irq(ab->dev, ab->dp->ppe.ppeds_irq[PPEDS_IRQ_PPE_WBM2SW_REL], ab);
 }
 #endif
 
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -473,7 +473,8 @@ skip_dma_alloc:
 	params.num_entries = num_entries;
 	ath12k_dp_srng_msi_setup(ab, &params, type, ring_num + mac_id);
 
-	if (ab->hw_params->ds_support && ab->hif.bus == ATH12K_BUS_AHB)
+	if (ab->hw_params->ds_support && ab->hif.bus == ATH12K_BUS_AHB &&
+	    !ath12k_dp_umac_reset_in_progress(ab))
 		ath12k_hif_ppeds_register_interrupts(ab, type, vector, ring_num);
 
 	switch (type) {
