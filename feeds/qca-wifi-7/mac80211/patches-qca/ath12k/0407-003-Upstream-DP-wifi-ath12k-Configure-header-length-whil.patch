From cb283a61900ab4448350f7ce881aa0c101a5b5d2 Mon Sep 17 00:00:00 2001
From: P Praneesh <ppranees@qti.qualcomm.com>
Date: Fri, 4 Jul 2025 11:08:07 +0530
Subject: [PATCH] Upstream:DP:wifi: ath12k: Configure header length while
 enabling monitor length

Currently rx_hdr_len is not configured and as a default option 256bytes
of hardware header is getting passed from monitor destination ring for
each MPDUs. But host needs only 64 bytes to construct the packet header.
So reducing the rx header size from 256 bytes to 64 bytes to avoid the
extra header subscription which helps to reduce the CPU cycles while
processing this TLV.

Patch-dependency : None

Signed-off-by: P Praneesh <ppranees@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_htt.c        | 4 ++++
 drivers/net/wireless/ath/ath12k/dp_htt.h        | 8 ++++++++
 drivers/net/wireless/ath/ath12k/dp_mon_filter.c | 3 +++
 3 files changed, 15 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.c b/drivers/net/wireless/ath/ath12k/dp_htt.c
index a75d7bf..4d943af 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.c
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.c
@@ -1824,6 +1824,10 @@ int ath12k_dp_tx_htt_rx_filter_setup(struct ath12k_base *ab, u32 ring_id,
 				       HTT_RX_RING_SELECTION_CFG_CMD_INFO1_CONF_LEN_CTRL);
 	cmd->info1 |= le32_encode_bits(tlv_filter->conf_len_data,
 				       HTT_RX_RING_SELECTION_CFG_CMD_INFO1_CONF_LEN_DATA);
+	if (!tlv_filter->rxmon_disable)
+		cmd->info1 |=
+			le32_encode_bits(tlv_filter->rx_hdr_len,
+					 HTT_RX_RING_SEL_CFG_CMD_INFO1_CONF_HDR_LEN);
 
 	word = 0;
 	ath12k_dp_tx_htt_rx_mgmt_flag0_filter_set(&word, tlv_filter);
diff --git a/drivers/net/wireless/ath/ath12k/dp_htt.h b/drivers/net/wireless/ath/ath12k/dp_htt.h
index 2f50844..53f00bf 100644
--- a/drivers/net/wireless/ath/ath12k/dp_htt.h
+++ b/drivers/net/wireless/ath/ath12k/dp_htt.h
@@ -653,6 +653,7 @@ enum htt_stats_frametype {
 #define HTT_RX_RING_SELECTION_CFG_CMD_INFO1_CONF_LEN_MGMT	GENMASK(18, 16)
 #define HTT_RX_RING_SELECTION_CFG_CMD_INFO1_CONF_LEN_CTRL	GENMASK(21, 19)
 #define HTT_RX_RING_SELECTION_CFG_CMD_INFO1_CONF_LEN_DATA	GENMASK(24, 22)
+#define HTT_RX_RING_SEL_CFG_CMD_INFO1_CONF_HDR_LEN		GENMASK(26, 25)
 
 #define HTT_RX_RING_SELECTION_CFG_CMD_INFO2_DROP_THRESHOLD	GENMASK(9, 0)
 #define HTT_RX_RING_SELECTION_CFG_CMD_INFO2_EN_LOG_MGMT_TYPE	BIT(17)
@@ -826,6 +827,12 @@ enum htt_rx_data_pkt_filter_tlv_flasg3 {
 	HTT_RX_MO_DATA_PKT_FILTER_TLV_FLASG3_NULL_DATA	= BIT(26),
 };
 
+enum htt_rx_hdr_len_type {
+	HTT_RX_HDR_LEN_64_BYTES = 1,
+	HTT_RX_HDR_LEN_128_BYTES,
+	HTT_RX_HDR_LEN_256_BYTES,
+};
+
 #define HTT_RX_MON_FILTER_TLV_FLAGS \
 		(HTT_RX_FILTER_TLV_FLAGS_MPDU_START | \
 		HTT_RX_FILTER_TLV_FLAGS_PPDU_START | \
@@ -955,6 +962,7 @@ struct htt_rx_ring_tlv_filter {
 	u16 rx_tlv_offset;
 	bool drop_threshold_valid;
 	bool rxmon_disable;
+	u8 rx_hdr_len;
 };
 
 #define HTT_STATS_FRAME_CTRL_TYPE_MGMT  0x0
diff --git a/drivers/net/wireless/ath/ath12k/dp_mon_filter.c b/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
index 784a5f9..add3f22 100644
--- a/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
+++ b/drivers/net/wireless/ath/ath12k/dp_mon_filter.c
@@ -291,6 +291,8 @@ void ath12k_dp_mon_rx_prepare_filter(struct ath12k_dp *dp,
 					src_tlv_filter->drop_threshold_valid;
 		dst_tlv_filter->rx_drop_threshold |=
 					src_tlv_filter->rx_drop_threshold;
+		dst_tlv_filter->rx_hdr_len |=
+					src_tlv_filter->rx_hdr_len;
 		dst_tlv_filter->enable_log_mgmt_type |=
 					src_tlv_filter->enable_log_mgmt_type;
 		dst_tlv_filter->enable_log_ctrl_type |=
@@ -422,6 +424,7 @@ ath12k_dp_mon_rx_setup_mon_mode_filter(struct ath12k_dp *dp,
 	tlv_filter->rx_filter = rx_mon_tlv_filter_flags;
 	tlv_filter->drop_threshold_valid = true;
 	tlv_filter->rx_drop_threshold = HTT_RX_RING_TLV_DROP_THRESHOLD_VALUE;
+	tlv_filter->rx_hdr_len = HTT_RX_HDR_LEN_64_BYTES;
 
 	tlv_filter->enable_log_mgmt_type = true;
 	tlv_filter->enable_log_ctrl_type = true;
-- 
2.34.1

