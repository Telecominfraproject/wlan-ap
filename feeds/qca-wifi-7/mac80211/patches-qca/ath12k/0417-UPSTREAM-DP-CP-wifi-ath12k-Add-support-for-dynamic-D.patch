+#define HAL_TX_NUM_DSCP_REG_SIZE 32
 
 /* dscp_tid_map - Default DSCP-TID mapping
  *=================
@@ -69,6 +71,68 @@ void ath12k_wifi7_hal_tx_cmd_desc_setup(struct ath12k_base *ab,
