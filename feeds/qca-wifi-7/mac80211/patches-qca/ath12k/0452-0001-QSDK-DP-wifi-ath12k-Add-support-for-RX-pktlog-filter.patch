+         HTT_RX_FILTER_TLV_FLAGS_PPDU_END_USER_STATS | \
+         HTT_RX_FILTER_TLV_FLAGS_PPDU_END_USER_STATS_EXT | \
+         HTT_RX_FILTER_TLV_FLAGS_PPDU_END_STATUS_DONE | \
