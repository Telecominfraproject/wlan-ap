From 13735f6b6a5831caeae56fd5295db1dcb5a29f9a Mon Sep 17 00:00:00 2001
From: Uraj Sasan <usasan@qti.qualcomm.com>
Date: Tue, 17 Jun 2025 17:03:56 +0530
Subject: [PATCH] UPSTREAM:CP:ath12k:Add support to update EHT MCS NSS

Update the EHT MCS NSS map whenever the chainmask values are modified,
as this was not handled in the current implementation.

Introduce a function to compute the intersection of the chainmask and
derive the EHT MCS NSS map for various bandwidth modes.

Signed-off-by: Uraj Sasan <usasan@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.h |  31 ++++++
 drivers/net/wireless/ath/ath12k/mac.c  | 125 +++++++++++++++++++++++--
 2 files changed, 146 insertions(+), 10 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/core.h b/drivers/net/wireless/ath/ath12k/core.h
index 28ba58e..70acd11 100644
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -108,6 +108,37 @@ enum ath12k_bdf_search {
 #define ATH12K_HE_MCS_MAX	11
 #define ATH12K_EHT_MCS_MAX	15
 
+/* EHT MCS_NSS_FOR_20_MHZ_ONLY_STA */
+#define EHT_MCS_20_MHZ_ONLY_0_7_RX    GENMASK(3, 0)
+#define EHT_MCS_20_MHZ_ONLY_0_7_TX    GENMASK(7, 4)
+#define EHT_MCS_20_MHZ_ONLY_8_9_RX    GENMASK(11, 8)
+#define EHT_MCS_20_MHZ_ONLY_8_9_TX    GENMASK(15, 12)
+#define EHT_MCS_20_MHZ_ONLY_10_11_RX  GENMASK(19, 16)
+#define EHT_MCS_20_MHZ_ONLY_10_11_TX  GENMASK(23, 20)
+#define EHT_MCS_20_MHZ_ONLY_12_13_RX  GENMASK(27, 24)
+#define EHT_MCS_20_MHZ_ONLY_12_13_TX  GENMASK(31, 28)
+
+/* EHT MCS_NSS FOR AP MLD */
+#define EHT_MCS_NSS_0_9_RX    GENMASK(3, 0)
+#define EHT_MCS_NSS_0_9_TX    GENMASK(7, 4)
+#define EHT_MCS_NSS_10_11_RX  GENMASK(11, 8)
+#define EHT_MCS_NSS_10_11_TX  GENMASK(15, 12)
+#define EHT_MCS_NSS_12_13_RX  GENMASK(19, 16)
+#define EHT_MCS_NSS_12_13_TX  GENMASK(23, 20)
+
+#define EHT_MCS_NSS_IDX_0 0
+#define EHT_MCS_NSS_IDX_1 8
+#define EHT_MCS_NSS_IDX_2 16
+#define EHT_MCS_NSS_IDX_3 24
+
+#define GET_RX_MCS(eht_map, idx, nss) \
+		   (min(u8_get_bits((eht_map) >> (idx), \
+		   IEEE80211_EHT_MCS_NSS_RX), nss))
+
+#define GET_TX_MCS(eht_map, idx, nss) \
+		   (min(u8_get_bits((eht_map) >> (idx), \
+		   IEEE80211_EHT_MCS_NSS_TX), nss))
+
 enum ath12k_crypt_mode {
 	/* Only use hardware crypto engine */
 	ATH12K_CRYPT_MODE_HW,
diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 7b89680..7df7fb3 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -2777,6 +2777,34 @@ static u8 ath12k_get_nss_160mhz(struct ath12k *ar,
 	return max_sup_nss;
 }
 
+static u8 ath12k_get_nss_320mhz(struct ath12k *ar,
+				u8 max_nss)
+{
+	u8 nss_ratio_info = ar->pdev->cap.nss_ratio_info;
+	u8 max_sup_nss = 0;
+
+	switch (nss_ratio_info) {
+	case WMI_NSS_RATIO_1BY2_NSS:
+		max_sup_nss = max_nss >> 2;
+		break;
+	case WMI_NSS_RATIO_3BY4_NSS:
+		ath12k_warn(ar->ab, "WMI_NSS_RATIO_3BY4_NSS not supported\n");
+		break;
+	case WMI_NSS_RATIO_1_NSS:
+		max_sup_nss = max_nss;
+		break;
+	case WMI_NSS_RATIO_2_NSS:
+		ath12k_warn(ar->ab, "WMI_NSS_RATIO_2_NSS not supported\n");
+		break;
+	default:
+		ath12k_warn(ar->ab, "invalid nss ratio received from fw: %d\n",
+			    nss_ratio_info);
+		break;
+	}
+
+	return max_sup_nss;
+}
+
 static void ath12k_peer_assoc_h_vht(struct ath12k *ar,
 				    struct ath12k_link_vif *arvif,
 				    struct ath12k_link_sta *arsta,
@@ -10963,34 +10991,111 @@ static void ath12k_mac_copy_he_cap(struct ath12k *ar,
 		ath12k_gen_ppe_thresh(&band_cap->he_ppet, he_cap->ppe_thres);
 }
 
+static
+u32 intersect_eht_mcsnss_map_nss(u32 eht_mcs_nss, u8 nss, bool is_20only_map)
+{
+	u8 tx_mcs_0_7, tx_mcs_8_9, tx_mcs_10_11, tx_mcs_12_13;
+	u8 rx_mcs_0_7, rx_mcs_8_9, rx_mcs_10_11, rx_mcs_12_13;
+	u32 rx_map, tx_map;
+	u32 eht_map;
+
+	if (is_20only_map) {
+		rx_mcs_0_7 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
+		rx_mcs_8_9 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
+		rx_mcs_10_11 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
+		rx_mcs_12_13 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_3, nss);
+
+		rx_map = u32_encode_bits(rx_mcs_0_7,
+					 EHT_MCS_20_MHZ_ONLY_0_7_RX) |
+			 u32_encode_bits(rx_mcs_8_9,
+					 EHT_MCS_20_MHZ_ONLY_8_9_RX) |
+			 u32_encode_bits(rx_mcs_10_11,
+					 EHT_MCS_20_MHZ_ONLY_10_11_RX) |
+			 u32_encode_bits(rx_mcs_12_13,
+					 EHT_MCS_20_MHZ_ONLY_12_13_RX);
+
+		tx_mcs_0_7 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
+		tx_mcs_8_9 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
+
+		tx_mcs_10_11 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
+		tx_mcs_12_13 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_3, nss);
+		tx_map = u32_encode_bits(tx_mcs_0_7,
+					 EHT_MCS_20_MHZ_ONLY_0_7_TX) |
+			 u32_encode_bits(tx_mcs_8_9,
+					 EHT_MCS_20_MHZ_ONLY_8_9_TX) |
+			 u32_encode_bits(tx_mcs_10_11,
+					 EHT_MCS_20_MHZ_ONLY_10_11_TX) |
+			 u32_encode_bits(tx_mcs_12_13,
+					 EHT_MCS_20_MHZ_ONLY_12_13_TX);
+		eht_map = rx_map | tx_map;
+	} else {
+		rx_mcs_0_7 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
+		rx_mcs_8_9 = rx_mcs_0_7;
+		rx_mcs_10_11 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
+		rx_mcs_12_13 = GET_RX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
+		rx_map = u32_encode_bits(rx_mcs_8_9, EHT_MCS_NSS_0_9_RX) |
+			 u32_encode_bits(rx_mcs_10_11, EHT_MCS_NSS_10_11_RX) |
+			 u32_encode_bits(rx_mcs_12_13, EHT_MCS_NSS_12_13_RX);
+
+		tx_mcs_0_7 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_0, nss);
+		tx_mcs_8_9 = tx_mcs_0_7;
+		tx_mcs_10_11 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_1, nss);
+		tx_mcs_12_13 = GET_TX_MCS(eht_mcs_nss, EHT_MCS_NSS_IDX_2, nss);
+		tx_map = u32_encode_bits(tx_mcs_8_9, EHT_MCS_NSS_0_9_TX) |
+			 u32_encode_bits(tx_mcs_10_11, EHT_MCS_NSS_10_11_TX) |
+			 u32_encode_bits(tx_mcs_12_13, EHT_MCS_NSS_12_13_TX);
+		eht_map = rx_map | tx_map;
+	}
+
+	return eht_map;
+}
+
 static void
-ath12k_mac_copy_eht_mcs_nss(struct ath12k_band_cap *band_cap,
+ath12k_mac_copy_eht_mcs_nss(struct ath12k *ar, struct ath12k_band_cap *band_cap,
 			    struct ieee80211_eht_mcs_nss_supp *mcs_nss,
 			    const struct ieee80211_he_cap_elem *he_cap,
 			    const struct ieee80211_eht_cap_elem_fixed *eht_cap)
 {
+	u8 maxtxnss_160 = ath12k_get_nss_160mhz(ar, ar->num_tx_chains);
+	u8 maxtxnss_320 = ath12k_get_nss_320mhz(ar, ar->num_tx_chains);
+	u32 eht_map;
+
 	if ((he_cap->phy_cap_info[0] &
 	     (IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_40MHZ_IN_2G |
 	      IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_40MHZ_80MHZ_IN_5G |
 	      IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_160MHZ_IN_5G |
-	      IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_80PLUS80_MHZ_IN_5G)) == 0)
-		memcpy(&mcs_nss->only_20mhz, &band_cap->eht_mcs_20_only,
+	      IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_80PLUS80_MHZ_IN_5G)) == 0) {
+		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_20_only,
+						       ar->num_tx_chains,
+						       true);
+		memcpy(&mcs_nss->only_20mhz, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_20mhz_only));
+	}
 
 	if (he_cap->phy_cap_info[0] &
 	    (IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_40MHZ_IN_2G |
-	     IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_40MHZ_80MHZ_IN_5G))
-		memcpy(&mcs_nss->bw._80, &band_cap->eht_mcs_80,
+	     IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_40MHZ_80MHZ_IN_5G)) {
+		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_80,
+						       ar->num_tx_chains,
+						       false);
+		memcpy(&mcs_nss->bw._80, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_bw));
+	}
 
 	if (he_cap->phy_cap_info[0] &
-	    IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_160MHZ_IN_5G)
-		memcpy(&mcs_nss->bw._160, &band_cap->eht_mcs_160,
+	    IEEE80211_HE_PHY_CAP0_CHANNEL_WIDTH_SET_160MHZ_IN_5G) {
+		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_160,
+						       maxtxnss_160, false);
+		memcpy(&mcs_nss->bw._160, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_bw));
+	}
 
-	if (eht_cap->phy_cap_info[0] & IEEE80211_EHT_PHY_CAP0_320MHZ_IN_6GHZ)
-		memcpy(&mcs_nss->bw._320, &band_cap->eht_mcs_320,
+	if (eht_cap->phy_cap_info[0] & IEEE80211_EHT_PHY_CAP0_320MHZ_IN_6GHZ) {
+		eht_map = intersect_eht_mcsnss_map_nss(band_cap->eht_mcs_160,
+						       maxtxnss_320, false);
+		memcpy(&mcs_nss->bw._320, &eht_map,
 		       sizeof(struct ieee80211_eht_mcs_nss_supp_bw));
+	}
 }
 
 static void ath12k_mac_copy_eht_ppe_thresh(struct ath12k_wmi_ppe_threshold_arg *fw_ppet,
@@ -11124,7 +11229,7 @@ static void ath12k_mac_copy_eht_cap(struct ath12k *ar,
 		break;
 	}
 
-	ath12k_mac_copy_eht_mcs_nss(band_cap, &eht_cap->eht_mcs_nss_supp,
+	ath12k_mac_copy_eht_mcs_nss(ar, band_cap, &eht_cap->eht_mcs_nss_supp,
 				    he_cap_elem, eht_cap_elem);
 
 	if (eht_cap_elem->phy_cap_info[5] &
