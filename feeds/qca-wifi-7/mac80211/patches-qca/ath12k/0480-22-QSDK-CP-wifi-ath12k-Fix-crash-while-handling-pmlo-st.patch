From be17ac921c3e4cca4bb640c9650689c9f7a65f3f Mon Sep 17 00:00:00 2001
From: Arpitha Ramesha <arpirame@qti.qualcomm.com>
Date: Mon, 21 Jul 2025 12:01:15 -0700
Subject: [PATCH 22/24] QSDK:CP:wifi:ath12k: Fix crash while handling pmlo
 stats

Calltrace:
Unable to handle kernel write to read-only memory at virtual address
[   42.293364] ath12k_wmi_event_tbttoffset_update+0x1998/0x26ac [ath12k]
[   42.295625] ath12k_htc_rx_completion_handler+0x4e8/0x4f8 [ath12k]

-Changed vmalloc to kzmalloc since vmalloc is a sleeping call
not allowed in ISR
-Removed free of status pointer before its use and added its free logic
once the stats are consumed
-Added a missed free of wmi_list missed during prior porting from 3.0
-Changed the use of data structure in ath12k_wmi_ctrl_path_stats_event
to handle pmlo stats along with pdev stats and calling
corresponding ath12k_wmi_crl_path_stats_list_free function to free the
list and its status pointer

Patch-dependency: None

Signed-off-by: Arpitha Ramesha <arpirame@qti.qualcomm.com>
Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.c | 26 ++++++++++++--------------
 1 file changed, 12 insertions(+), 14 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -12605,7 +12605,7 @@ int wmi_print_ctrl_path_btcoex_stats_tlv
 	return 0;
 }
 
-static void
+/*static void
 ath12k_wmi_ctrl_path_pdev_stats_list_free(struct list_head *head)
 {
 	struct wmi_ctrl_path_pdev_stats *stats_list, *tmp;
@@ -12621,6 +12621,8 @@ ath12k_wmi_ctrl_path_stats_list_free(str
 {
 	ath12k_wmi_ctrl_path_pdev_stats_list_free(&param->pdev_stats);
 }
+*/
+
 
 int wmi_print_ctrl_path_awgn_stats_tlv(struct ath12k_base *ab, u16 len,
 				       const void *ptr, void *data)
@@ -12777,7 +12779,7 @@ int wmi_print_ctrl_path_pmlo_stats_tlv(s
        if (!stats)
                return -ENOMEM;
 
-       pmlo_stats = vmalloc(sizeof(*pmlo_stats));
+	pmlo_stats = kzalloc(sizeof(*pmlo_stats), GFP_ATOMIC);
        if (!pmlo_stats) {
                kfree(stats);
                return -ENOMEM;
@@ -12790,7 +12792,7 @@ int wmi_print_ctrl_path_pmlo_stats_tlv(s
        ar = ath12k_mac_get_ar_by_pdev_id(ab, pmlo_stats_skb->pdev_id);
        if (!ar) {
                ath12k_warn(ab, "Failed to get ar for wmi ctrl stats\n");
-               vfree(pmlo_stats);
+		kfree(pmlo_stats);
                list_del(&stats->list);
                kfree(stats);
                return -EINVAL;
@@ -12807,11 +12809,10 @@ int wmi_print_ctrl_path_pmlo_stats_tlv(s
        ar->stats.telemetry_stats.estimated_air_time_ac_vo =
                u32_get_bits(value, GENMASK(31, 24));
 
-       //ath12k_wmi_crl_path_stats_list_free(ar, &ar->debug.period_wmi_list);
+	ath12k_wmi_crl_path_stats_list_free(ar,
+					    &ar->debug.wmi_ctrl_path_stats.pdev_stats);
        spin_unlock_bh(&ar->debug.wmi_ctrl_path_stats_lock);
-       ar->debug.wmi_ctrl_path_stats_tagid = WMI_CTRL_PATH_PMLO_STATS;
        stats_buff->ar = ar;
-       vfree(pmlo_stats);
        return 0;
 }
 
@@ -12894,7 +12895,7 @@ static int ath12k_wmi_ctrl_stats_event_p
 static void ath12k_wmi_ctrl_path_stats_event(struct ath12k_base *ab, struct sk_buff *skb)
 {
 	struct wmi_ctrl_path_stats_event *fixed_param;
-	struct ath12k_wmi_ctrl_path_stats_list param = {0};
+	struct wmi_ctrl_path_stats_ev_parse_param param = {0};
 	struct ath12k_wmi_ctrl_path_stats_list *stats;
 	const struct wmi_tlv *tlv;
 	struct list_head *src, *dst;
@@ -12925,7 +12926,7 @@ static void ath12k_wmi_ctrl_path_stats_e
 		return;
 	}
 
-	INIT_LIST_HEAD(&param.pdev_stats);
+	INIT_LIST_HEAD(&param.list);
 
 	fixed_param = ptr;
 	ret = ath12k_wmi_tlv_iter(ab, skb->data, skb->len,
@@ -12948,7 +12949,7 @@ static void ath12k_wmi_ctrl_path_stats_e
 
 	switch (tag_id) {
 	case WMI_TAG_CTRL_PATH_PDEV_STATS:
-		src = &param.pdev_stats;
+		src = &param.list;
 		dst = &stats->pdev_stats;
 		break;
 	case WMI_CTRL_PATH_PMLO_STATS:
@@ -12961,15 +12962,14 @@ static void ath12k_wmi_ctrl_path_stats_e
 	spin_lock_bh(&ar->debug.wmi_ctrl_path_stats_lock);
 	if (!more) {
 		if (!ar->debug.wmi_ctrl_path_stats_more_enabled)
-			ath12k_wmi_ctrl_path_stats_list_free(stats);
+			ath12k_wmi_crl_path_stats_list_free(ar, &stats->pdev_stats);
 		else
 			ar->debug.wmi_ctrl_path_stats_more_enabled = false;
-
 		list_splice_tail_init(src, dst);
 		complete(&ar->debug.wmi_ctrl_path_stats_rcvd);
 	} else {
 		if (!ar->debug.wmi_ctrl_path_stats_more_enabled) {
-			ath12k_wmi_ctrl_path_stats_list_free(stats);
+			ath12k_wmi_crl_path_stats_list_free(ar, &stats->pdev_stats);
 			ar->debug.wmi_ctrl_path_stats_more_enabled = true;
 		}
 		list_splice_tail_init(src, dst);
@@ -12978,7 +12978,7 @@ static void ath12k_wmi_ctrl_path_stats_e
 	return;
 free:
 	spin_lock_bh(&ar->debug.wmi_ctrl_path_stats_lock);
-	ath12k_wmi_ctrl_path_stats_list_free(&param);
+	ath12k_wmi_crl_path_stats_list_free(ar, &param.list);
 	spin_unlock_bh(&ar->debug.wmi_ctrl_path_stats_lock);
 }
 #else
