From 8ce3496cddb77458d75df739efcd3f972e3bb8f6 Mon Sep 17 00:00:00 2001
From: Hariharan Ramanathan <hramanat@qti.qualcomm.com>
Date: Fri, 26 Sep 2025 16:26:58 +0530
Subject: [PATCH 2/2] UPSTREAM:DP:wifi:ath12k: Free DP QoS context in case of
 FW recovery

The DP peer QoS context is allocated when the first MSDUQ is created for
a QoS flow and it is deleted as part of the peer delete.

With FW recovery, the DP peer object is deleted in a separate path
so the QoS context if already allocated should also be deleted.

Delete the QoS context if alloacted, as part of the peer delete in case of FW
recovery.

Fixes:
I4ada24b6105 UPSTREAM: wifi: ath12k: Add support for Wifi QoS

Patch-dependency:
0415-0003-UPSTREAM-DP-wifi-ath12k-Add-support-for-QoS-Datapath.patch

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Signed-off-by: Hariharan Ramanathan <hramanat@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 7432f84..fa7f6a9 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -1556,6 +1556,8 @@ void ath12k_mac_dp_peer_cleanup(struct ath12k_hw *ah,
 		list_del(&dp_peer->list);
 		if (dp_peer->qos && dp_peer->qos->telemetry_peer_ctx)
 			ath12k_telemetry_peer_ctx_free(dp_peer->qos->telemetry_peer_ctx);
+
+		kfree(dp_peer->qos);
 		kfree(dp_peer);
 	}
 
