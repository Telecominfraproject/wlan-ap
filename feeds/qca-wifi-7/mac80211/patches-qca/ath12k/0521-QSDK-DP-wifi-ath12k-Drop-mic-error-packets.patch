From 5279ddf9796351e662e9159534c6976cf31dbaac Mon Sep 17 00:00:00 2001
From: Ripan Deuri <rdeuri@qti.qualcomm.com>
Date: Thu, 31 Jul 2025 16:08:54 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Drop mic error packets

Sending mic error packet to mac80211 result in an uninitialized rx_status
being passed to mac80211, leading to a call trace. Drop mic error packet
in wbm error path.

Patch-dependency: 0083-wifi-ath12k-add-rx_info-to-capture-required-field-fr.patch
Fixes: Idd214a7c81e ("pkg upgrade Added subsys, ath11k and ath12k patches for win.wlan_host_opensource.4.0")

Signed-off-by: Ripan Deuri <rdeuri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
index c2dc641f..2173b088 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/dp_rx.c
@@ -3103,7 +3103,8 @@ static bool ath12k_wifi7_dp_rx_h_rxdma_err(struct ath12k_pdev_dp *dp_pdev,
 	case HAL_REO_ENTR_RING_RXDMA_ECODE_DECRYPT_ERR:
 	case HAL_REO_ENTR_RING_RXDMA_ECODE_TKIP_MIC_ERR:
 		if (rx_desc_data->err_bitmap & HAL_RX_MPDU_ERR_TKIP_MIC) {
-			ath12k_wifi7_dp_rx_h_tkip_mic_err(dp_pdev, msdu, status, rx_desc_data);
+			drop = ath12k_wifi7_dp_rx_h_tkip_mic_err(dp_pdev, msdu, status,
+								 rx_desc_data);
 			break;
 		}
 		fallthrough;
-- 
