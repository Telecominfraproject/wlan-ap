From 5e53b6423975107cdc2744df08c767597a4b24b8 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Fri, 5 Sep 2025 17:56:00 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Do not process umac reset when target
 recovery is in progress

Do not process stand alone umac reset when target recovery is in progress,
as this will lead to race conditions with on going target recovery process

Patch-dependency: None

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/umac_reset.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/drivers/net/wireless/ath/ath12k/umac_reset.c b/drivers/net/wireless/ath/ath12k/umac_reset.c
index f61c1be..e0853f3 100644
--- a/drivers/net/wireless/ath/ath12k/umac_reset.c
+++ b/drivers/net/wireless/ath/ath12k/umac_reset.c
@@ -416,6 +416,9 @@ void ath12k_dp_umac_reset_action(struct ath12k_base *ab,
 		target_recovery = true;
 		fallthrough;
 	case ATH12K_UMAC_RESET_INIT_UMAC_RECOVERY:
+		if (!target_recovery && ab->is_reset)
+			return;
+
 		ret = ath12k_umac_reset_initiate_recovery(ab, target_recovery);
 		if (!ret) {
 			ab->dp_umac_reset.ts.trigger_start = jiffies_to_msecs(jiffies);
-- 
2.34.1

