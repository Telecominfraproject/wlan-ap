+
+#define NELEMS ARRAY_SIZE
+
+#define CREATE_CFIS_LST(_gopcls) \
+	CFISLST_TYPE CFISLST(_gopcls) = {NELEMS(CFISARR(_gopcls)), CFISARR(_gopcls)}
