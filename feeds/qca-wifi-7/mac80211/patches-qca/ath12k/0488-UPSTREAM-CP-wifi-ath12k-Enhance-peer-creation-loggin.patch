From b5d906579430398d343547610132af7a601cb842 Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Thu, 7 Aug 2025 16:30:25 +0530
Subject: [PATCH] UPSTREAM:CP wifi:ath12k: Enhance peer creation logging with
 MLME debug mask

Add MLME debug mask to existing peer creation and conf event logs
to improve traceability during peer association issues. This allows
developers to selectively enable MLME logs for targeted debugging
without relying on verbose PEER or WMI logs.

Changes:
- Extended debug mask in peer create command to include ATH12K_DBG_MLME
- Extended debug mask in peer create confirmation event to include
  ATH12K_DBG_MLME

Patch-dependency:
0429-UPSTREAM-PROTOCOL-DP-wifi-ath12k-Add-connectivity-de.patch

Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wmi.c b/drivers/net/wireless/ath/ath12k/wmi.c
index 2f6535b..2cbdba9 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -1678,7 +1678,7 @@ int ath12k_wmi_send_peer_create_cmd(struct ath12k *ar,
 
 	ptr += sizeof(*ml_param);
 
-	ath12k_dbg(ar->ab, ATH12K_DBG_PEER,
+	ath12k_dbg(ar->ab, ATH12K_DBG_PEER | ATH12K_DBG_MLME,
 		   "WMI peer create vdev_id %d peer_addr %pM ml_flags 0x%x num_peer:%d bridge peer %d\n",
 		   arg->vdev_id, arg->peer_addr, ml_param->flags, ar->num_peers, arg->mlo_bridge_peer);
 
@@ -13450,7 +13450,7 @@ static void ath12k_wmi_peer_create_conf_event(struct ath12k_base *ab,
 		return;
 	}
 
-	ath12k_dbg(ab, ATH12K_DBG_WMI,
+	ath12k_dbg(ab, ATH12K_DBG_WMI | ATH12K_DBG_MLME,
 		   "Peer create conf event for %pM status %d",
 		   arg.mac_addr, arg.status);
 }
-- 
