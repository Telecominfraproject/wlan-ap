From 356bbbd2d674f15191d3dc5d6870a92cfa15b390 Mon Sep 17 00:00:00 2001
From: Nagarajan Maran <nmaran@qti.qualcomm.com>
Date: Mon, 18 Aug 2025 14:34:02 +0530
Subject: [PATCH] QSDK: DP: wifi: ath12k: Fix infinite loop in
 service_class view command

Prevent the service_class view command from entering an infinite loop
when displaying all 128 service classes. Ensure the dump_it handler
resumes from the correct service class ID instead of restarting
from the beginning when the buffer is full.

Initialize the correct svc_id to continue dumping remaining
service classes to userspace.

Fixes: c071555bf442 ("QSDK: wifi: ath12k: Add SDWF config and DP support")
Patch-dependency: 0416-0002-QSDK-CP-wifi-ath12k-Add-support-for-SDWF-config-usin.patch
Patch-work: None

Signed-off-by: Nagarajan Maran <nmaran@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/vendor.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/vendor.c b/drivers/net/wireless/ath/ath12k/vendor.c
index 329aece7b4f6..cf5d142acda0 100644
--- a/drivers/net/wireless/ath/ath12k/vendor.c
+++ b/drivers/net/wireless/ath/ath12k/vendor.c
@@ -5235,7 +5235,7 @@ static int ath12k_vendor_view_sdwf_config(struct wiphy *wiphy,
 		return -ENOBUFS;
 
 	tailroom = skb_tailroom(msg);
-	for (i = (svc_id);
+	for (i = (svc_id) ? (svc_id - 1) : (*storage);
 	     i < QOS_PROFILES_MAX && tailroom > nested_range;
 	     i += (svc_id) ? (QOS_PROFILES_MAX) : (1)) {
 		u16 id_dl = qos_ctx->svc_class[i].dl_qos_id;
-- 
2.34.1

