+	(INI, STRING, char *, name, min_len, max_len, -1, desc, def)
+#define ATH12K_CFG_INI_MAC(name, def, desc) \
+	(INI, MAC_ADDR, struct ini_mac_addr, name, -1, -1, -1, desc, def)
