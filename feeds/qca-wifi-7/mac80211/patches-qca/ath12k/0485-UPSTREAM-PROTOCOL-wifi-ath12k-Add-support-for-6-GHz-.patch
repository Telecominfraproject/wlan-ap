From 849cc528320558eed8c4eab2eae9d9b4a71628f1 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Tue, 5 Aug 2025 09:39:31 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: ath12k: Add support for 6 GHz client
 type

Currently, the default client type for 6 GHz is set to regular client.
Using regular client may be suboptimal for few regulatory domains
where the Tx powers of regular client is lower than that of a
subordinate client.

Add the 6 GHz client type received from the Firmware to the wiphy
regulatory domain. Also, advertise the support
for regular client in the wiphy regd irrespective of the client type
received from the firmware. This is to ensure that the regular client,
which is the default client type, is always available for use.

Also, parse the TPE IE only for the corresponding client type.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
subsys/0048-cfg80211-mac80211-regulatory-awgn-and-6g-channel-cha.patch
subsys/0340-UPSTREAM-PROTOCOL-cfg80211-mac80211-Store-6-GHz-powe.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 3 ++-
 drivers/net/wireless/ath/ath12k/reg.c | 7 +++++++
 2 files changed, 9 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index 34fc4fcb5459..520ce178d001 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -9462,7 +9462,8 @@ void ath12k_mac_parse_tx_pwr_env(struct ath12k *ar,
 		return;
 	}
 
-	client_type = WMI_REG_DEFAULT_CLIENT;
+	client_type = ieee80211_get_6ghz_client_type(ath12k_ar_to_hw(ar)->wiphy,
+						     bss_conf->power_type - 1);
 	if (client_type == WMI_REG_SUBORDINATE_CLIENT &&
 	    bss_conf->power_type - 1 == NL80211_REG_AP_SP &&
 	    ar->ab->sp_rule)
diff --git a/drivers/net/wireless/ath/ath12k/reg.c b/drivers/net/wireless/ath/ath12k/reg.c
index fdd2739534a6..a8b78789d3fc 100644
--- a/drivers/net/wireless/ath/ath12k/reg.c
+++ b/drivers/net/wireless/ath/ath12k/reg.c
@@ -1156,6 +1156,12 @@ ath12k_reg_build_regd(struct ath12k_base *ab,
 
 	kfree(ab->sp_rule);
 	ab->sp_rule = sp_rule;
+	/* Also include the default client type to indicate that it is always
+	 * supported in the 6 GHz band, regardless of the target's preferred
+	 * client type.
+	 */
+	new_regd->supp_cli_bitmap_6ghz = BIT(WMI_REG_DEFAULT_CLIENT);
+	new_regd->supp_cli_bitmap_6ghz |= BIT(reg_info->client_type);
 	new_regd->n_reg_rules = num_rules;
 
 ret:
@@ -2375,6 +2381,7 @@ ath12k_reg_build_new_regd_for_afc(struct ath12k *ar,
 	memcpy(alpha2, regd->alpha2, REG_ALPHA2_LEN + 1);
 	alpha2[2] = '\0';
 	new_regd->dfs_region = regd->dfs_region;
+	new_regd->supp_cli_bitmap_6ghz = regd->supp_cli_bitmap_6ghz;
 	ath12k_dbg(ab, ATH12K_DBG_AFC,
 		   "\nAFC: Country %s, CFG Regdomain %s, num_reg_rules %d\n",
 		   alpha2, ath12k_reg_get_regdom_str(new_regd->dfs_region),
-- 
2.34.1

