 struct ath12k_device_dp_stats {
 #ifdef CPTCFG_ATH12K_PPE_DS_SUPPORT
 	u32 ppe_vp_mode_update_fail;
@@ -491,8 +497,6 @@ struct ath12k_device_dp_stats {
 	u32 invalid_rbm;
