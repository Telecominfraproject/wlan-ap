From 366554f9b8031c1ad697359588940d439123cf02 Mon Sep 17 00:00:00 2001
From: Harish Rachakonda <rachakon@qti.qualcomm.com>
Date: Wed, 17 Sep 2025 11:47:43 +0530
Subject: [PATCH] QSDK:CP: ath12k: Add NULL check for link_sta->sta before
 accessing ath12k_sta

Previously, link_sta->sta is assigned from ieee80211_sta::deflink
during link addition but not reset after link removal. This led to
stale pointer access during operations like NL80211_CMD_GET_STATION,
resulting in crashes and memory corruption. This patch ensures
link_sta->sta is explicitly set to NULL after link removal and adds
a defensive check before accessing it in
ath12k_mac_op_link_sta_statistics().

Patch-dependency: None
Patch-rework: None

Signed-off-by: Harish Rachakonda <rachakon@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/drivers/net/wireless/ath/ath12k/mac.c b/drivers/net/wireless/ath/ath12k/mac.c
index af6bd42..3dc920d 100644
--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -20569,7 +20569,7 @@ void ath12k_mac_op_link_sta_statistics(struct ieee80211_hw *hw,
 				       struct ieee80211_link_sta *link_sta,
 				       struct link_station_info *link_sinfo)
 {
-	struct ath12k_sta *ahsta = ath12k_sta_to_ahsta(link_sta->sta);
+	struct ath12k_sta *ahsta;
 	struct ath12k_dp_link_peer_rate_info rate_info = {0};
 	struct ath12k_fw_stats_req_params params = {};
 	s8 signal, rssi_signal, rssi_offset;
@@ -20579,6 +20579,12 @@ void ath12k_mac_op_link_sta_statistics(struct ieee80211_hw *hw,
 	struct ath12k *ar;
 	bool db2dbm;
 
+	if (!link_sta->sta) {
+		ath12k_err(NULL, "Failed to proceed: link_sta->sta is NULL");
+		return;
+	}
+
+	ahsta = ath12k_sta_to_ahsta(link_sta->sta);
 	lockdep_assert_wiphy(hw->wiphy);
 
 	arsta = wiphy_dereference(hw->wiphy, ahsta->link[link_sta->link_id]);
-- 
