From 86e4a38e011ee97961b959542cd20fe7537a29c9 Mon Sep 17 00:00:00 2001
From: Shwetha G K <kshwetha@qti.qualcomm.com>
Date: Mon, 23 Jun 2025 21:34:33 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: ath12k: Add offload mode - advertised TTLM status
 event notify handlers

When driver offloaded advertised TTLM is started, firmware sends few
status events to driver via WMI. The status is then to be stored under
ieee80211_link_data_ap and send to userspace application to take further
decisions.
This change introduces an API which notifies mac80211 about the status
indication from firmware.
The status from firmware includes :
  - MST update in TSF format to be used in probe response frames
  - MST expired event indicating the mapping applied successfully and
its going to be effective until ED expires.
  - ED expired event indicating TTLM is no longer effective

Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/mac.c | 16 ++++++++++++++++
 drivers/net/wireless/ath/ath12k/mac.h |  3 +++
 2 files changed, 19 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/mac.c
+++ b/drivers/net/wireless/ath/ath12k/mac.c
@@ -21504,6 +21504,17 @@ ath12k_mac_op_can_neg_ttlm(struct ieee80
 }
 EXPORT_SYMBOL(ath12k_mac_op_can_neg_ttlm);
 
+void ath12k_tid_to_link_mapping_evt_notify(struct ath12k_link_vif *arvif,
+					   u16 mapping_switch_tsf,
+					   u32 tid_to_link_mapping_status)
+{
+	if (arvif->is_created)
+		ieee80211_advertised_ttlm_evt_notify(arvif->ahvif->vif,
+						     mapping_switch_tsf,
+						     tid_to_link_mapping_status,
+						     arvif->link_id);
+}
+
 static void ath12k_mac_handle_ttlm_neg(struct ieee80211_hw *hw,
 				       struct ieee80211_vif *vif,
 				       struct ieee80211_sta *sta)
--- a/drivers/net/wireless/ath/ath12k/mac.h
+++ b/drivers/net/wireless/ath/ath12k/mac.h
@@ -500,6 +500,9 @@ enum ieee80211_neg_ttlm_res ath12k_mac_o
 void ath12k_mac_op_apply_neg_ttlm_per_client(struct ieee80211_hw *hw,
 					     struct ieee80211_vif *vif,
 					     struct ieee80211_sta *sta);
+void ath12k_tid_to_link_mapping_evt_notify(struct ath12k_link_vif *arvif,
+					   u16 mapping_switch_tsf,
+					   u32 tid_to_link_mapping_status);
 
 int ath12k_mac_op_set_radar_background(struct ieee80211_hw *hw,
 				       struct cfg80211_chan_def *def);
