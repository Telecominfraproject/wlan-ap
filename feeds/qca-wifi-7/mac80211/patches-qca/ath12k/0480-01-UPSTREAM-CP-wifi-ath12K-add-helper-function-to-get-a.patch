From c3a8c7666fb24705a44bb2d92da97b2fc2bd8fe1 Mon Sep 17 00:00:00 2001
From: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Date: Thu, 3 Jul 2025 10:53:55 -0700
Subject: [PATCH 01/24] UPSTREAM:CP:wifi:ath12K: add helper function to get ag

Add helper function to get ath12k hardware group.

Patch-dependency: none

Signed-off-by: Sidhanta Sahu <sidhanta.sahu@oss.qualcomm.com>
Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/core.c | 11 +++++++++++
 drivers/net/wireless/ath/ath12k/core.h |  1 +
 2 files changed, 12 insertions(+)

--- a/drivers/net/wireless/ath/ath12k/core.c
+++ b/drivers/net/wireless/ath/ath12k/core.c
@@ -4784,6 +4784,17 @@ error:
 	return index;
 }
 
+struct ath12k_hw_group *ath12k_core_get_ag(void)
+{
+	struct ath12k_hw_group *ag;
+
+	mutex_lock(&ath12k_hw_group_mutex);
+	ag = list_first_entry_or_null(&ath12k_hw_group_list,
+				      struct ath12k_hw_group, list);
+	mutex_unlock(&ath12k_hw_group_mutex);
+	return ag;
+}
+
 int ath12k_core_init(struct ath12k_base *ab)
 {
 	struct ath12k_hw_group *ag;
--- a/drivers/net/wireless/ath/ath12k/core.h
+++ b/drivers/net/wireless/ath/ath12k/core.h
@@ -2237,4 +2237,5 @@ void ath12k_core_pci_link_speed(struct a
 void ath12k_core_radio_cleanup(struct ath12k *ar);
 void ath12k_telemetry_notify_breach(u8 *mac_addr, u8 svc_id, u8 param,
 				    bool set_clear, u8 tid);
+struct ath12k_hw_group *ath12k_core_get_ag(void);
 #endif /* _CORE_H_ */
