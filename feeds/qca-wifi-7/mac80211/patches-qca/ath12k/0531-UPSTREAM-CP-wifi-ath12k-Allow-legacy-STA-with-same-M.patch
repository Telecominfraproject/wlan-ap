From 0e1724599ccf7c0a8efba72a711e488a793802ea Mon Sep 17 00:00:00 2001
From: Nagarajan Maran <nmaran@qti.qualcomm.com>
Date: Fri, 12 Sep 2025 17:06:38 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:ath12k: Allow legacy STA with same MAC

Fix firmware crash caused by assigning the same MAC address to both the
peer's address and another peer's MLD address. This regression stems
from a change in dp_peer_create that permits dp peer creation when
two STA(MLD, legacy) with same MAC associates with different interfaces.

Permit dp peer creation for legacy STA if an existing peer entry with the
same MAC is also a legacy STA. Reject peer creation if either the
connecting STA or the existing peer entry is MLO/SLO STA. Also reject if
the legacy dp peer's STA structure matches the STA structure currently
being created.

Fixes: 428df7355c30 ("UPSTREAM:DP:wifi:ath12k: Add API for ath12k_dp_peer search using address and ieee80211_sta")
Patch-dependency: 0478-UPSTREAM-DP-wifi-ath12k-Add-API-for-ath12k_dp_peer-s.patch

Signed-off-by: Nagarajan Maran <nmaran@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp_peer.c | 24 ++++++++++++++++++++++-
 drivers/net/wireless/ath/ath12k/dp_peer.h |  3 +++
 2 files changed, 26 insertions(+), 1 deletion(-)

--- a/drivers/net/wireless/ath/ath12k/dp_peer.c
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.c
@@ -490,6 +490,25 @@ struct ath12k_dp_peer *ath12k_dp_peer_fi
 	return NULL;
 }
 
+struct ath12k_dp_peer *ath12k_dp_peer_create_find(struct ath12k_dp_hw *dp_hw, u8 *addr,
+						  struct ieee80211_sta *sta,
+						  bool mlo_peer)
+{
+	struct ath12k_dp_peer *dp_peer;
+
+	lockdep_assert_held(&dp_hw->peer_lock);
+
+	list_for_each_entry(dp_peer, &dp_hw->peers, list) {
+		if (ether_addr_equal(dp_peer->addr, addr)) {
+			if (!sta || mlo_peer || dp_peer->is_mlo ||
+			    dp_peer->sta == sta)
+				return dp_peer;
+		}
+	}
+
+	return NULL;
+}
+
 #define PEER_TABLE_SOC_ID_SHIFT        10
 
 u16 ath12k_dp_peer_get_peerid_index(struct ath12k_dp *dp, u16 peer_id)
@@ -547,7 +566,7 @@ int ath12k_dp_peer_create(struct ath12k_
 	struct wireless_dev *wdev;
 
 	spin_lock_bh(&dp_hw->peer_lock);
-	dp_peer = ath12k_dp_peer_find_by_addr_and_sta(dp_hw, addr, params->sta);
+	dp_peer = ath12k_dp_peer_create_find(dp_hw, addr, params->sta, params->is_mlo);
 
 	if (dp_peer) {
 		spin_unlock_bh(&dp_hw->peer_lock);
--- a/drivers/net/wireless/ath/ath12k/dp_peer.h
+++ b/drivers/net/wireless/ath/ath12k/dp_peer.h
@@ -250,6 +250,9 @@ struct ath12k_dp_peer *ath12k_dp_peer_fi
 					   u8 *addr);
 struct ath12k_dp_peer *ath12k_dp_peer_find_by_addr_and_sta(struct ath12k_dp_hw *dp_hw,
 							   u8 *addr, struct ieee80211_sta *sta);
+struct ath12k_dp_peer *ath12k_dp_peer_create_find(struct ath12k_dp_hw *dp_hw, u8 *addr,
+						  struct ieee80211_sta *sta,
+						  bool mlo_peer);
 struct ath12k_dp_link_peer *
 ath12k_dp_link_peer_find_by_vdev_id_and_addr(struct ath12k_dp *dp,
 					     int vdev_id, const u8 *addr);
