+
+	/* protects data fields like dp_pdevs */
+	spinlock_t dp_lock;
+	struct ath12k_pdev_dp __rcu *dp_pdevs[MAX_RADIOS];
+	u8 num_radios;
+
 	struct ath12k_dp_hw_group *dp_hw_grp;
 	u8 device_id;
 
