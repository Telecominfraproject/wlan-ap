+	atf_peer_param.atf_flags = atf_peer_param.atf_flags |
+				   FIELD_PREP(WMI_ATF_PEER_VALID_PDEV, 1);
 
-	ath12k_dbg(ar->ab, ATH12K_DBG_WMI,
-		   "WMI ATF peer config for num_peers %u pdev id %u atf_flags %u\n",
