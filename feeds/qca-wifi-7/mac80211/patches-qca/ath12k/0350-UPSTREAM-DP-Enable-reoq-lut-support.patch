From 1820b3ae8ecdb0b1ce25224ba5c47b8c5982ba4e Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 11 Jun 2025 14:35:16 +0530
Subject: [PATCH] UPSTREAM: DP: Enable reoq lut support

Enable reoq lut support in qcn9274 and family of chipsets.
Also fix a minor issue of configuring paddr for reoq_lut,
where right shift of the value to 8 bits was missing.

Patch-dependency:
	0114-0010-wifi-ath12k-Move-the-hardware-specifc-HAL-APIs-to-wi.patch

Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c       |  3 ++-
 drivers/net/wireless/ath/ath12k/wifi7/hw.c | 10 +++++-----
 2 files changed, 7 insertions(+), 6 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index c6f463f..9e20efc 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -1758,8 +1758,9 @@ static int ath12k_dp_reoq_lut_setup(struct ath12k_base *ab)
 	 * design supports paddr upto 4 GB max hence it fits in 32 bit register only
 	 */
 
-	ath12k_hal_write_reoq_lut_addr(ab, dp->reoq_lut.paddr);
+	ath12k_hal_write_reoq_lut_addr(ab, dp->reoq_lut.paddr >> 8);
 	ath12k_hal_write_ml_reoq_lut_addr(ab, dp->ml_reoq_lut.paddr >> 8);
+
 	ath12k_hal_reoq_lut_addr_read_enable(ab);
 	ath12k_hal_reoq_lut_set_max_peerid(ab);
 
diff --git a/drivers/net/wireless/ath/ath12k/wifi7/hw.c b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
index 63d749e..763ec7c 100644
--- a/drivers/net/wireless/ath/ath12k/wifi7/hw.c
+++ b/drivers/net/wireless/ath/ath12k/wifi7/hw.c
@@ -584,7 +584,7 @@ static const struct ath12k_hw_params ath12k_wifi7_hw_params[] = {
 		.download_calib = false,
 		.supports_suspend = true,
 		.tcl_ring_retry = false,
-		.reoq_lut_support = false,
+		.reoq_lut_support = true,
 		.supports_shadow_regs = true,
 
 		.num_tcl_banks = 7,
@@ -677,7 +677,7 @@ static const struct ath12k_hw_params ath12k_wifi7_hw_params[] = {
 		.download_calib = true,
 		.supports_suspend = false,
 		.tcl_ring_retry = true,
-		.reoq_lut_support = false,
+		.reoq_lut_support = true,
 		.supports_shadow_regs = false,
 
 		.num_tcl_banks = 48,
@@ -777,7 +777,7 @@ static const struct ath12k_hw_params ath12k_wifi7_hw_params[] = {
 		.download_calib = true,
 		.supports_suspend = false,
 		.tcl_ring_retry = true,
-		.reoq_lut_support = false,
+		.reoq_lut_support = true,
 		.supports_shadow_regs = false,
 
 		.num_tcl_banks = 48,
@@ -869,7 +869,7 @@ static const struct ath12k_hw_params ath12k_wifi7_hw_params[] = {
 		.download_calib = true,
 		.supports_suspend = false,
 		.tcl_ring_retry = true,
-		.reoq_lut_support = false,
+		.reoq_lut_support = true,
 		.supports_shadow_regs = false,
 
 		.num_tcl_banks = 48,
@@ -940,7 +940,7 @@ static const struct ath12k_hw_params ath12k_wifi7_hw_params[] = {
 		.download_calib = true,
 		.supports_suspend = false,
 		.tcl_ring_retry = true,
-		.reoq_lut_support = false,
+		.reoq_lut_support = true,
 		.supports_shadow_regs = false,
 
 		.num_tcl_banks = 48,
-- 
2.34.1

