From 1b0679479a4a31d1300be3d93c9811afe6908c55 Mon Sep 17 00:00:00 2001
From: Vivek Chettri <vchettri@qti.qualcomm.com>
Date: Thu, 10 Jul 2025 00:08:33 +0530
Subject: [PATCH] QSDK: wifi: ath12k: Check ECM driver support for ECM calls

ECM calls into the WLAN driver could happen for flows matching vifs
supported by radios of ath11k and ath12k driver.

Since supporting ECM callback requires looking into ath12k vif and
other driver objects and the same would not be available for ath11k vif,
resulting in crashes.

So when ECM calls into WLAN driver, check if the call is for
ath11k vif or ath12k vif, and since ECM cb is not supported for ath11k
devices, return an error.

Optimize some of the prints in the NSS ECM callbacks into the WLAN
driver.

Patch-dependency:
0416-0003-QSDK-DP-Add-fast-path-DP-support-for-QoS-features.patch
Fixes:I988786c25ecc0e874d9c8a83f76eccc0665818d2 QSDK: wifi: ath12k: Add
SDWF config and DP support

Signed-off-by: Vivek Chettri <vchettri@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/accel_cfg.c | 19 +++++++++++--------
 drivers/net/wireless/ath/ath12k/sdwf.c      |  5 +++--
 2 files changed, 14 insertions(+), 10 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/accel_cfg.c b/drivers/net/wireless/ath/ath12k/accel_cfg.c
index 4249fc3..c0faf07 100644
--- a/drivers/net/wireless/ath/ath12k/accel_cfg.c
+++ b/drivers/net/wireless/ath/ath12k/accel_cfg.c
@@ -43,16 +43,8 @@ void ath12k_get_ingress_mlo_dev_info(struct net_device *ndev,
 	struct  ath12k_sta *ahsta;
 	struct  ath12k_link_vif *arvif;
 	struct  ath12k_base *ab;
-	struct  ieee80211_hw *hw;
 	struct  ieee80211_vif *vif;
 
-	if (!wdev)
-		return;
-
-	hw = wiphy_to_ieee80211_hw(wdev->wiphy);
-	if (!ieee80211_hw_check(hw, SUPPORT_ECM_REGISTRATION))
-		return;
-
 	vif = wdev_to_ieee80211_vif_vlan(wdev, false);
 
 	if (!vif)
@@ -140,6 +132,7 @@ u32 ath12k_get_metadata_info(struct ath_dp_metadata_param *md_param)
 {
 	struct net_device *dest_dev = NULL;
 	struct  wireless_dev *wdev = NULL;
+	struct  ieee80211_hw *hw;
 	u32 metadata = 0;
 	u16 msduq_peer;
 	u8 *dest_mac = NULL;
@@ -163,6 +156,16 @@ u32 ath12k_get_metadata_info(struct ath_dp_metadata_param *md_param)
 	}
 
 	wdev = ath12k_get_wdev_from_netdev(dest_dev);
+
+	if (!wdev)
+		return metadata;
+
+	hw = wiphy_to_ieee80211_hw(wdev->wiphy);
+	if (!ieee80211_hw_check(hw, SUPPORT_ECM_REGISTRATION)) {
+		ath12k_err(NULL, "ECM cb not supported");
+		return metadata;
+	}
+
 	ath12k_get_ingress_mlo_dev_info(dest_dev, wdev, dest_mac,
 					&node_id, &link_id);
 
diff --git a/drivers/net/wireless/ath/ath12k/sdwf.c b/drivers/net/wireless/ath/ath12k/sdwf.c
index db55e91..c08ce1f 100644
--- a/drivers/net/wireless/ath/ath12k/sdwf.c
+++ b/drivers/net/wireless/ath/ath12k/sdwf.c
@@ -255,7 +255,8 @@ struct ath12k *ath12k_sdwf_get_ar_from_vif(struct wireless_dev *wdev,
 
 	sta = ieee80211_find_sta_by_ifaddr(ahvif->ah->hw, peer_mac, NULL);
 	if (!sta) {
-		pr_err("Peer:%pM not present", peer_mac);
+		ath12k_dbg(ab, ATH12K_DBG_QOS,
+			   "Peer: %pM not present", peer_mac);
 		sta = wdev_to_ieee80211_vlan_sta(wdev);
 		if (!sta)
 			return NULL;
@@ -323,7 +324,7 @@ u16 ath12k_sdwf_get_msduq(struct wireless_dev *wdev,
 
 	ar = ath12k_sdwf_get_ar_from_vif(wdev, vif, peer_mac, &peer_id);
 	if (!ar) {
-		ath12k_err(NULL, "ar is NULL");
+		ath12k_dbg(NULL, ATH12K_DBG_QOS, "ar is NULL");
 		return ret_msduq;
 	}
 
-- 
