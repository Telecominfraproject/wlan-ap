From df52a25c3f9e309b5a9634bbff49127ccb7e5050 Mon Sep 17 00:00:00 2001
From: Amith A <amitajit@qti.qualcomm.com>
Date: Wed, 24 Sep 2025 15:21:49 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:KW: wifi: ath12k: Fix KW issues in radar
 detected WMI handling

Fix the following KW issues:

1) In ath12k_dfs_calculate_subchannels(), 'ar' is being dereferenced before
   checking for NULL pointer. Add a check to validate 'ar' before
   dereferencing it.

2) In ath12k_wmi_pdev_dfs_radar_detected_event(), 'ret' is being used
   without getting initialized. As it is unnecessary in the function,
   remove it.

Tag: DFS
Patch-dependency: 0234-01-ath12k-radar-bitmap-generation-durin-DFS-radar-detec.patch

Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/wmi.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/wmi.c b/drivers/net/wireless/ath/ath12k/wmi.c
index 0866547..7f189e0 100644
--- a/drivers/net/wireless/ath/ath12k/wmi.c
+++ b/drivers/net/wireless/ath/ath12k/wmi.c
@@ -11864,6 +11864,11 @@ ath12k_dfs_calculate_subchannels(struct ath12k_base *ab,
 	int i;
 
 	ar = ath12k_mac_get_ar_by_pdev_id(ab, radar->pdev_id);
+	if (!ar) {
+		ath12k_warn(ab, "Failed to fetch ar for pdev %d\n",
+			    radar->pdev_id);
+		return;
+	}
 	arg.ar = ar;
 	arg.chanctx_conf = NULL;
 	if (!radar->detector_id) {
@@ -11949,7 +11954,6 @@ ath12k_wmi_pdev_dfs_radar_detected_event(struct ath12k_base *ab, struct sk_buff
 	const struct wmi_pdev_radar_flags_param *rf_ev;
 	const struct ath12k_wmi_pdev_radar_event *ev;
 	struct ath12k *ar;
-	int ret;
 	bool do_full_bw_nol = false;
 	bool is_full_bw_nol_feature_supported = false;
 	const struct wmi_tlv *tlv;
@@ -11961,7 +11965,7 @@ ath12k_wmi_pdev_dfs_radar_detected_event(struct ath12k_base *ab, struct sk_buff
 
 	len += sizeof(*ev) + TLV_HDR_SIZE;
 	if (skb->len < len) {
-		ath12k_warn(ab, "failed to parse tlv: %d\n", ret);
+		ath12k_warn(ab, "Radar event is of incorrect length\n");
 		return;
 	}
 
