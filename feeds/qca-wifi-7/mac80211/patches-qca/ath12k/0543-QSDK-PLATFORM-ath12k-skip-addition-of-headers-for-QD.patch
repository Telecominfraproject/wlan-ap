From 4ea23892fefa50836b981a966966380d378c2a37 Mon Sep 17 00:00:00 2001
From: Narendhar Reddy <nare@qti.qualcomm.com>
Date: Thu, 18 Sep 2025 22:45:34 +0530
Subject: [PATCH] QSDK:PLATFORM:ath12k: skip addition of headers for QDSS and
 PHY dumps.

As FW doesn't require headers for parsing QDSS and PHY dumps.
collect QDSS and PHY dump without appending headers

Signed-off-by: Narendhar Reddy <nare@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c | 2 +-
 drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qmi.c  | 2 +-
 drivers/net/wireless/ath/ath12k/athdbg_if.c             | 2 +-
 drivers/net/wireless/ath/ath12k/athdbg_if.h             | 4 ++--
 4 files changed, 5 insertions(+), 5 deletions(-)

--- a/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c
+++ b/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qdss.c
@@ -338,7 +338,7 @@ void athdbg_coredump_qdss_dump(struct at
 				segment->len);
 		segment->type = FW_CRASH_DUMP_QDSS_DATA;
 	}
-	athdbg_base->dbg_to_ath_ops->coredump_build_inline(ab, segment, 1);
+	athdbg_base->dbg_to_ath_ops->coredump_dump_segment(ab, segment, segment->len);
 out:
 	vfree(segment);
 	vfree(dump);
--- a/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qmi.c
+++ b/drivers/net/wireless/ath/ath12k/ath_debug/athdbg_qmi.c
@@ -420,7 +420,8 @@ int athdbg_qmi_event_qdss_trace_misc_hdl
 		segment->len = total_size;
 		segment->vaddr = qdss_trace_data;
 		segment->type = FW_CRASH_DUMP_QDSS_DATA;
-		athdbg_base->dbg_to_ath_ops->coredump_build_inline(ab, segment, 1);
+		athdbg_base->dbg_to_ath_ops->coredump_dump_segment(ab,
+							segment, segment->len);
 		vfree(segment);
 	} else {
 		pr_err("dump collection failed: remaining-%u response end-%u\n",
--- a/drivers/net/wireless/ath/ath12k/athdbg_if.c
+++ b/drivers/net/wireless/ath/ath12k/athdbg_if.c
@@ -10,7 +10,7 @@ extern struct ath_debug_base *athdbg_bas
 
 const struct athdbg_to_ath12k_ops dbg_to_ath_ops = {
 	.get_reserved_mem_by_name = ath12k_core_get_reserved_mem_by_name,
-	.coredump_build_inline = ath12k_coredump_build_inline,
+	.coredump_dump_segment = ath12k_coredump_dump_segment,
 	.dev_running_status = athdbg_if_check_dev_running,
 	.set_dbg_mask = athdbg_if_setmask,
 	.get_link_vif_from_vdev_id = ath12k_mac_get_arvif_by_vdev_id,
--- a/drivers/net/wireless/ath/ath12k/athdbg_if.h
+++ b/drivers/net/wireless/ath/ath12k/athdbg_if.h
@@ -18,8 +18,8 @@ struct athdbg_to_ath12k_ops {
 	struct reserved_mem *(*get_reserved_mem_by_name)(struct ath12k_base *ab, const char *name);
 	void (*coredump_qdss_dump)(struct ath12k_base *ab,
 			struct ath12k_qmi_event_qdss_trace_save_data *event_data);
-	void (*coredump_build_inline)(struct ath12k_base *ab,
-			struct ath12k_dump_segment *segments, int num_seg);
+	void (*coredump_dump_segment)(struct ath12k_base *ab,
+			struct ath12k_dump_segment *segments, size_t seg_len);
 	bool (*dev_running_status)(struct ath12k_base *drv_ab);
 	void (*set_dbg_mask)(unsigned int debug_mask);
 	struct ath12k_link_vif *(*get_link_vif_from_vdev_id)(struct ath12k_base *ab,
