From 4a8f442e5747ae9f4a504409d6c384bac974a9d0 Mon Sep 17 00:00:00 2001
From: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
Date: Wed, 17 Sep 2025 17:00:45 +0530
Subject: [PATCH] QSDK:DP:wifi:ath12k: Allow rxole config for non-DS radio

Allow rxole configuration for the radio that does not support DS when
it is part of MLD. This enables PPE-DS configuration for such radio,
ensuring proper packet processing in multi-link environments.

Patch-dependency: 0337-01-QSDK-DP-wifi-Add-support-for-PPE-DS-Direct-switch-fe.patch

Signed-off-by: Thiraviyam Mariyappan <tmariyap@qti.qualcomm.com>
Signed-off-by: Pavankumar Nandeshwar <pnandesh@qti.qualcomm.com>
---
 drivers/net/wireless/ath/ath12k/dp.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/drivers/net/wireless/ath/ath12k/dp.c b/drivers/net/wireless/ath/ath12k/dp.c
index e085fd3..a669407 100644
--- a/drivers/net/wireless/ath/ath12k/dp.c
+++ b/drivers/net/wireless/ath/ath12k/dp.c
@@ -72,9 +72,6 @@ int ath12k_dp_ppe_rxole_rxdma_cfg(struct ath12k_base *ab)
 	struct ath12k_dp_htt_rxdma_ppe_cfg_param param = {0};
 	int ret;
 
-	if (!test_bit(ATH12K_FLAG_PPE_DS_ENABLED, &ab->dev_flags))
-		return 0;
-
 	param.override = 1;
 	param.reo_dst_ind = HAL_REO2PPE_DST_IND;
 	param.multi_buffer_msdu_override_en = 0;
-- 
2.34.1

