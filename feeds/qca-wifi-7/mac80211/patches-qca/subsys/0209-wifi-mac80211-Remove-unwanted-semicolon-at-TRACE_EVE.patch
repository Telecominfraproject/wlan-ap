From 4d5ed686bdfa3d9d61346a631fdac9240c253d32 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:50 +0530
Subject: [PATCH] mac80211: wifi Remove unwanted semicolon at TRACE_EVENT

compilation error due to unwanted semi-colon at TRACE_EVENT
declaration.Remove unwanted semicolon.

depends on: 199-001-mac80211-add-nss-support.patch

Signed-off-by: Saravanakumar Duraisamy <quic_saradura@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/trace.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/net/mac80211/trace.h b/net/mac80211/trace.h
index 2a2fba9..2b23ee7 100644
--- a/net/mac80211/trace.h
+++ b/net/mac80211/trace.h
@@ -433,7 +433,7 @@ TRACE_EVENT(drv_nss_bss_info_changed,
 		LOCAL_ENTRY
 		VIF_ENTRY
 		__field(u32, changed)
-		__field(bool, nss_ap_isolate);
+		__field(bool, nss_ap_isolate)
 	),
 
 	TP_fast_assign(
-- 
2.34.1

