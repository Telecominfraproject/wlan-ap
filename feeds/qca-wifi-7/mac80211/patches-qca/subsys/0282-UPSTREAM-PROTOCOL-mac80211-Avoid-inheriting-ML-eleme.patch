From 33454161afe0f41c35764ff4b1854531cd726368 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:23 +0530
Subject: [PATCH] mac80211: UPSTREAMPROTOCOL Avoid inheriting ML element for 
 non-transmitting profiles in MBSSID

As per IEEE 802.11be - 2024 (35.3.20 MLO in a multiple BSSID set or
co-hosted BSSID set - Note 2). An AP MLD, which is non-transmitting
BSS in an MBSSID set shall not include Multi-link(ML) element in its
non-inheritance elements list as ML IE shall never be inherited from
Transmitting BSS frame body. A non-AP MLD should always consider ML IE
(all variants) present in its non-transmitting BSS profile.

Currently, when a non-AP MLD parses the beacon/probe response, it
inherits the Multi-Link element and adds it to the non-transmitting
BSS profile. When ML Reconfiguration link removal is triggered
on the Transmitting BSS, the non-AP MLD(s) associated to the
non-transmitted BSS of that MBSSID set inherits the Multi-Link
Reconfiguration element and removes the link(s) Associated.

Current check_inherit in _ieee802_11_parse_elems_full() is based
on presence of non-inheritance element, but there could be cases
where there is no non-inheritance element present, but still
certain IEs (MBSSID IE, ML IE) should not be inherited from
Transmitted BSS. cfg80211_is_element_inherited() already has
necessary conditions to avoid inheriting such IEs, hence
pass an additional argument to _ieee802_11_parse_elems_full()
to indicate when to(while parsing a Non-TX profile) perform
inheritance checks.

Patch-dependency: None

Patch-work:

Signed-off-by: Yuvarani V <quic_yuvarani@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/parse.c | 16 +++++++++++-----
 1 file changed, 11 insertions(+), 5 deletions(-)

diff --git a/net/mac80211/parse.c b/net/mac80211/parse.c
index 9ae443f..8da893f 100644
--- a/net/mac80211/parse.c
+++ b/net/mac80211/parse.c
@@ -304,7 +304,8 @@ static void ieee802_11_parse_elems_vendor_qcn(const u8 *pos, u8 elen,
 static u32
 _ieee802_11_parse_elems_full(struct ieee80211_elems_parse_params *params,
 			     struct ieee80211_elems_parse *elems_parse,
-			     const struct element *check_inherit)
+			     const struct element *check_inherit,
+			     bool bcheck_inherit)
 {
 	struct ieee802_11_elems *elems = &elems_parse->elems;
 	const struct element *elem;
@@ -321,7 +322,7 @@ _ieee802_11_parse_elems_full(struct ieee80211_elems_parse_params *params,
 		u8 elen = elem->datalen;
 		const u8 *pos = elem->data;
 
-		if (check_inherit &&
+		if (bcheck_inherit && check_inherit &&
 		    !cfg80211_is_element_inherited(elem,
 						   check_inherit))
 			continue;
@@ -964,7 +965,8 @@ static void ieee80211_mle_parse_link(struct ieee80211_elems_parse *elems_parse,
 
 	non_inherit = cfg80211_find_ext_elem(WLAN_EID_EXT_NON_INHERITANCE,
 					     sub.start, sub.len);
-	_ieee802_11_parse_elems_full(&sub, elems_parse, non_inherit);
+	_ieee802_11_parse_elems_full(&sub, elems_parse, non_inherit,
+				     non_inherit ? true : false);
 }
 
 static void
@@ -1018,6 +1020,7 @@ ieee802_11_parse_elems_full(struct ieee80211_elems_parse_params *params)
 	u8 *nontransmitted_profile;
 	int nontransmitted_profile_len = 0;
 	size_t scratch_len = params->scratch_len ?: 2 * params->len;
+	bool check_inherit = false;
 
 	BUILD_BUG_ON(offsetof(typeof(*elems_parse), elems) != 0);
 
@@ -1047,8 +1050,11 @@ ieee802_11_parse_elems_full(struct ieee80211_elems_parse_params *params)
 					     nontransmitted_profile,
 					     nontransmitted_profile_len);
 
+	if (non_inherit || nontransmitted_profile_len)
+		check_inherit = true;
+
 	elems->crc = _ieee802_11_parse_elems_full(params, elems_parse,
-						  non_inherit);
+						  non_inherit, check_inherit);
 
 	/* Override with nontransmitted profile, if found */
 	if (nontransmitted_profile_len) {
@@ -1060,7 +1066,7 @@ ieee802_11_parse_elems_full(struct ieee80211_elems_parse_params *params)
 			.link_id = params->link_id,
 		};
 
-		_ieee802_11_parse_elems_full(&sub, elems_parse, NULL);
+		_ieee802_11_parse_elems_full(&sub, elems_parse, NULL, false);
 	}
 
 	ieee80211_mle_parse_link(elems_parse, params);
-- 
