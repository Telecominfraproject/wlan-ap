From 0bca25cb5594f31514d8160985b9c459f58aaacd Mon Sep 17 00:00:00 2001
From: Gunaal R <gunar@qti.qualcomm.com>
Date: Wed, 6 Aug 2025 14:59:07 +0530
Subject: [PATCH] UPSTREAM: CP: nl80211: Fix HE GI and LTF mask initialization
 when EHT is unsupported

Previously, the HE GI and LTF fields in the TX bitrate mask were being
set only after checking for EHT capabilities. On devices like ath11k
that do not support EHT, this check fails and the code path skips
initializing `he_gi` and `he_ltf`, leaving them at 0x00 instead of the
intended default value of 0xFF.

This causes incorrect bitrate settings and leads to issues such as
ping failures due to improper rate configuration.

Move the initialization of `he_gi` and `he_ltf` before the EHT
capability check to ensure they are always set correctly, regardless
of EHT support.

With this fix, bitrate is set properly and ping functionality is
restored.

Patch-work: None
Patch-dependency: 571-nl80211-beacon-EHT-rate-support.patch

Signed-off-by: Gunaal R <gunar@qti.qualcomm.com>
---
 net/wireless/nl80211.c | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/net/wireless/nl80211.c b/net/wireless/nl80211.c
index e50e693..f12d8bd 100644
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -6252,6 +6252,9 @@ static int nl80211_parse_tx_bitrate_mask(struct genl_info *info,
 		he_tx_mcs_map = he_get_txmcsmap(info, link_id, he_cap);
 		he_build_mcs_mask(he_tx_mcs_map, mask->control[i].he_mcs);
 
+		mask->control[i].he_gi = 0xFF;
+		mask->control[i].he_ltf = 0xFF;
+
 		eht_cap = ieee80211_get_eht_iftype_cap(sband, wdev->iftype);
 		if (!eht_cap)
 			continue;
@@ -6259,9 +6262,6 @@ static int nl80211_parse_tx_bitrate_mask(struct genl_info *info,
 		eht_build_mcs_mask(info, he_cap, eht_cap,
 				   mask->control[i].eht_mcs);
 
-		mask->control[i].he_gi = 0xFF;
-		mask->control[i].he_ltf = 0xFF;
-
 		mask->control[i].eht_gi = 0xFF;
 		mask->control[i].eht_ltf = 0xFF;
 
