From 0080c38a08cccd55edd3fd7836654fb492696ac3 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:11 +0530
Subject: [PATCH] mac80211: UPSTREAMCPKWathkFix KW issue to avoid banned 
 function.

As 'sprintf' has been deprecated and it is not safe, replace it
with a safe function 'snprintf'

Patch-dependency: [None]
Patch-work:       [None]
Fixes:            [None]

Signed-off-by: Arulanbu Balusamy <quic_abalusam@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/debugfs.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/net/mac80211/debugfs.c b/net/mac80211/debugfs.c
index 39f93be..c29d7fc 100644
--- a/net/mac80211/debugfs.c
+++ b/net/mac80211/debugfs.c
@@ -708,7 +708,7 @@ static ssize_t queues_read(struct file *file, char __user *user_buf,
 
 	spin_lock_irqsave(&local->queue_stop_reason_lock, flags);
 	for (q = 0; q < local->hw.queues; q++)
-		res += sprintf(buf + res, "%02d: %#.8lx/%d\n", q,
+		res += snprintf(buf + res, sizeof(buf) + res, "%02d: %#.8lx/%d\n", q,
 				local->queue_stop_reasons[q],
 				skb_queue_len(&local->pending[q]));
 	spin_unlock_irqrestore(&local->queue_stop_reason_lock, flags);
-- 
2.34.1

