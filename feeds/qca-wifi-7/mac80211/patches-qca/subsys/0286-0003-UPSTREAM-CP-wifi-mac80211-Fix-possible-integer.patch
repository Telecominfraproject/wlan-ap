From 8a2a40ee5154099047418aecad6e80365510467b Mon Sep 17 00:00:00 2001
From: Ilan Peer <ilan.peer@intel.com>
Date: Wed, 4 Jun 2025 15:39:41 +0530
Subject: [PATCH v0286 3/3] UPSTREAM:CP: wifi: mac80211: Fix possible integer
 promotion issue

Fix a possible integer promotion issue in mac80211 in ieee80211_ml_epcs()

Fixes: de86c5f60839 ("wifi: mac80211: Add support for EPCS configuration")
Reported-by: Dan Carpenter <dan.carpenter@linaro.org>
Signed-off-by: Ilan Peer <ilan.peer@intel.com>

Patch-work: https://patchwork.kernel.org/project/linux-wireless/patch/20250214074721.1613549-1-ilan.peer@intel.com/
Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>b
---
 net/mac80211/mlme.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/net/mac80211/mlme.c b/net/mac80211/mlme.c
index ab89dda..5c2b161 100644
--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -10691,7 +10691,7 @@ static void ieee80211_ml_epcs(struct ieee80211_sub_if_data *sdata,
 						  elems->ml_epcs_len,
 						  scratch, scratch_len,
 						  IEEE80211_MLE_SUBELEM_FRAGMENT);
-		if (len < sizeof(control))
+		if (len < (ssize_t)sizeof(control))
 			continue;
 
 		pos = scratch + sizeof(control);
-- 
2.34.1

