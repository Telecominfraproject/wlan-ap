From 8057fb1fac52be09865128d98799f3f73f590269 Mon Sep 17 00:00:00 2001
From: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
Date: Wed, 20 Aug 2025 13:28:51 -0700
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: cfg80211: reset SSID length on
 stop_ap()

Userspace may send NL80211_CMD_STOP_AP/NL80211_CMD_DEL_BEACON
command to stop AP interfaces, modify configurations and reload
the same by sending NL80211_CMD_START_AP.

Currently reloading fails for the first link from MLD if the new
configuration has a different SSID because nl80211_start_ap()
compares new SSID with the old one which is not cleared after
links are stopped.

Reset SSID length to 0 on successful stop_ap() operation to
allow new SSID upon reloading an MLD.

Patch-dependency: none

Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 net/wireless/ap.c | 12 ++++++++++++
 1 file changed, 12 insertions(+)

--- a/net/wireless/ap.c
+++ b/net/wireless/ap.c
@@ -16,6 +16,8 @@ static int ___cfg80211_stop_ap(struct cf
 			       bool notify)
 {
 	struct wireless_dev *wdev = dev->ieee80211_ptr;
+	unsigned int temp_link_id;
+	bool all_links_stopped = true;
 	int err;
 
 	lockdep_assert_wiphy(wdev->wiphy);
@@ -48,9 +50,18 @@ static int ___cfg80211_stop_ap(struct cf
 			 * link, otherwise consider that some link is present
 			 */
 			wdev->conn_owner_nlportid = 0;
-			wdev->u.ap.ssid_len = 0;
 		}
 
+		for_each_valid_link(wdev, temp_link_id) {
+			if (wdev->links[temp_link_id].ap.beacon_interval) {
+				all_links_stopped = false;
+				break;
+			}
+		}
+
+		if (all_links_stopped)
+			wdev->u.ap.ssid_len = 0;
+
 		rdev_set_qos_map(rdev, dev, NULL, link_id);
 		if (notify)
 			nl80211_send_ap_stopped(wdev, link_id);
