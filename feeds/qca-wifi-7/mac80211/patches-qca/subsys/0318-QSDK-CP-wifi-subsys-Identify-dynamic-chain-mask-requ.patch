From 5b8165f8715e159b6698f2bf7e3c935589c091a8 Mon Sep 17 00:00:00 2001
From: Rajat Soni <rajson@qti.qualcomm.com>
Date: Mon, 7 Jul 2025 15:32:34 +0530
Subject: [PATCH 3/3] QSDK: CP: wifi: subsys: Identify dynamic chain mask
 request

Introduce NL80211_ATTR_DYNAMIC_CHAIN_MASK nl80211 attribute to
identify that the dynamic chain mask change is requested.

Signed-off-by: Rajat Soni <rajson@qti.qualcomm.com>
---
 include/net/cfg80211.h       | 3 ++-
 include/net/mac80211.h       | 2 +-
 include/uapi/linux/nl80211.h | 1 +
 net/mac80211/cfg.c           | 6 +++---
 net/mac80211/driver-ops.h    | 5 +++--
 net/wireless/nl80211.c       | 6 +++++-
 net/wireless/rdev-ops.h      | 5 +++--
 7 files changed, 18 insertions(+), 10 deletions(-)

--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -5339,7 +5339,8 @@ struct cfg80211_ops {
 						   struct wireless_dev *wdev,
 						   struct mgmt_frame_regs *upd);
 
-	int	(*set_antenna)(struct wiphy *wiphy, u32 tx_ant, u32 rx_ant, u8 radio_id);
+	int	(*set_antenna)(struct wiphy *wiphy, u32 tx_ant, u32 rx_ant, u8 radio_id,
+			       bool is_dynamic);
 	int	(*get_antenna)(struct wiphy *wiphy, u32 *tx_ant, u32 *rx_ant,
 			       u8 radio_id);
 
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -4968,7 +4968,7 @@ struct ieee80211_ops {
 			       struct ieee80211_vif *vif,
 			       struct ieee80211_channel_switch *ch_switch);
 	int (*set_antenna)(struct ieee80211_hw *hw, u32 tx_ant, u32 rx_ant,
-			   u8 radio_id);
+			   u8 radio_id, bool is_dynamic);
 	int (*get_antenna)(struct ieee80211_hw *hw, u32 *tx_ant, u32 *rx_ant,
 			   u8 radio_id);
 
--- a/include/uapi/linux/nl80211.h
+++ b/include/uapi/linux/nl80211.h
@@ -3617,6 +3617,7 @@ enum nl80211_attrs {
 	NL80211_ATTR_AP_REMOVAL_COUNT,
 	NL80211_ATTR_TSF,
 	NL80211_ATTR_RXMGMT_LINK_REMOVAL_UPDATE,
+	NL80211_ATTR_DYNAMIC_CHAIN_MASK,
 	NL80211_ATTR_ML_MAX_REC_LINKS,
 
 	NL80211_ATTR_ERP,
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -4807,15 +4807,15 @@ ieee80211_update_mgmt_frame_registration
 }
 
 static int ieee80211_set_antenna(struct wiphy *wiphy, u32 tx_ant, u32 rx_ant,
-				 u8 radio_id)
+				 u8 radio_id, bool is_dynamic)
 {
 	struct ieee80211_local *local = wiphy_priv(wiphy);
 	int ret;
 
-	if (local->started)
+	if (local->started && !is_dynamic)
 		return -EOPNOTSUPP;
 
-	ret = drv_set_antenna(local, tx_ant, rx_ant, radio_id);
+	ret = drv_set_antenna(local, tx_ant, rx_ant, radio_id, is_dynamic);
 	if (ret)
 		return ret;
 
--- a/net/mac80211/driver-ops.h
+++ b/net/mac80211/driver-ops.h
@@ -797,13 +797,14 @@ static inline void drv_channel_switch(st
 
 
 static inline int drv_set_antenna(struct ieee80211_local *local,
-				  u32 tx_ant, u32 rx_ant, u8 radio_id)
+				  u32 tx_ant, u32 rx_ant, u8 radio_id,
+				  bool is_dynamic)
 {
 	int ret = -EOPNOTSUPP;
 	might_sleep();
 	lockdep_assert_wiphy(local->hw.wiphy);
 	if (local->ops->set_antenna)
-		ret = local->ops->set_antenna(&local->hw, tx_ant, rx_ant, radio_id);
+		ret = local->ops->set_antenna(&local->hw, tx_ant, rx_ant, radio_id, is_dynamic);
 	trace_drv_set_antenna(local, tx_ant, rx_ant, ret);
 	return ret;
 }
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -989,6 +989,7 @@ static const struct nla_policy nl80211_p
 	[NL80211_ATTR_VIF_RADIO_MASK] = { .type = NLA_U32 },
 	[NL80211_ATTR_BEACON_TX_MODE] = NLA_POLICY_RANGE(NLA_U32, 1, 2),
 	[NL80211_ATTR_ERP] = NLA_POLICY_NESTED(nl80211_erp_policy),
+	[NL80211_ATTR_DYNAMIC_CHAIN_MASK] = { .type = NLA_U8 },
 	[NL80211_ATTR_ML_MAX_REC_LINKS] = NLA_POLICY_RANGE(NLA_U8, 0, 15),
 	[NL80211_ATTR_ADVERTISED_TTLM] =
 		NLA_POLICY_NESTED(nl80211_advertised_ttlm_policy),
@@ -4291,7 +4292,10 @@ static int nl80211_set_wiphy(struct sk_b
 		tx_ant = tx_ant & rdev->wiphy.available_antennas_tx;
 		rx_ant = rx_ant & rdev->wiphy.available_antennas_rx;
 
-		result = rdev_set_antenna(rdev, tx_ant, rx_ant, radio_id);
+		if (info->attrs[NL80211_ATTR_DYNAMIC_CHAIN_MASK])
+			result = rdev_set_antenna(rdev, tx_ant, rx_ant, radio_id, true);
+		else
+			result = rdev_set_antenna(rdev, tx_ant, rx_ant, radio_id, false);
 		if (result)
 			return result;
 	}
--- a/net/wireless/rdev-ops.h
+++ b/net/wireless/rdev-ops.h
@@ -860,11 +860,12 @@ rdev_update_mgmt_frame_registrations(str
 }
 
 static inline int rdev_set_antenna(struct cfg80211_registered_device *rdev,
-				   u32 tx_ant, u32 rx_ant, u8 radio_id)
+				   u32 tx_ant, u32 rx_ant, u8 radio_id,
+				   bool is_dynamic)
 {
 	int ret;
 	trace_rdev_set_antenna(&rdev->wiphy, tx_ant, rx_ant);
-	ret = rdev->ops->set_antenna(&rdev->wiphy, tx_ant, rx_ant, radio_id);
+	ret = rdev->ops->set_antenna(&rdev->wiphy, tx_ant, rx_ant, radio_id, is_dynamic);
 	trace_rdev_return_int(&rdev->wiphy, ret);
 	return ret;
 }
