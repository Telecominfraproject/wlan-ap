From e5365d6e8d9a66304b33f8ee7fedf3ad0f59c4ea Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Wed, 2 Apr 2025 18:17:34 +0530
Subject: [PATCH 12/25] mac80211: Add compatibility fix for skb_list

Add compatibility fix for skb_list for different
kernel versions by adjusting the data structures
and functions used for free_list

Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
Signed-off-by: Kaviarasu Sanjeevi <quic_kaviaras@quicinc.com>
---
 include/net/mac80211.h | 4 ++++
 net/mac80211/status.c  | 4 ++++
 2 files changed, 8 insertions(+)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index 513ca32..b3a93cc 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -1350,7 +1350,11 @@ struct ieee80211_tx_status {
 	ktime_t ack_hwtstamp;
 	u8 n_rates;
 
+#if LINUX_VERSION_IS_GEQ(4,19,0)
 	struct list_head *free_list;
+#else
+	struct sk_buff_head *free_list;
+#endif
 };
 
 /**
diff --git a/net/mac80211/status.c b/net/mac80211/status.c
index 5f28f36..6774d2b 100644
--- a/net/mac80211/status.c
+++ b/net/mac80211/status.c
@@ -1254,7 +1254,11 @@ free:
 
 	ieee80211_report_used_skb(local, skb, false, status->ack_hwtstamp);
 	if (status->free_list)
+#if LINUX_VERSION_IS_GEQ(4,19,0)
 		list_add_tail(&skb->list, status->free_list);
+#else
+		__skb_queue_tail(status->free_list, skb);
+#endif
 	else
 		dev_kfree_skb(skb);
 }
-- 
