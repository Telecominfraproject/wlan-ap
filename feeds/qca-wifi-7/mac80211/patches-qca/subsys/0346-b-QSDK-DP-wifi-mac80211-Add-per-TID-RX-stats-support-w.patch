+	RX_DROP_BAD_AMSDU_CIPHER,
+	RX_DROP_INVALID_8023,
+	RX_DROP_RUNT_ACTION,
+	RX_DROP_UNPROT_ACTION,
+	RX_DROP_ACTION_UNKNOWN_SRC,
+	RX_DROP_REJECTED_ACTION_RESPONSE,
+	RX_DROP_EXPECT_DEFRAG_PROT,
+	RX_DROP_WEP_DEC_FAIL,
+	RX_DROP_NO_IV,
+	RX_DROP_NO_ICV,
+	RX_DROP_AP_RX_GROUPCAST,
+	RX_DROP_SHORT_MMIC,
+	RX_DROP_MMIC_FAIL,
+	RX_DROP_SHORT_TKIP,
+	RX_DROP_TKIP_FAIL,
+	RX_DROP_SHORT_CCMP,
+	RX_DROP_SHORT_CCMP_MIC,
+	RX_DROP_SHORT_GCMP,
+	RX_DROP_SHORT_GCMP_MIC,
+	RX_DROP_SHORT_CMAC,
+	RX_DROP_SHORT_CMAC256,
+	RX_DROP_SHORT_GMAC,
+	RX_DROP_UNEXPECTED_4ADDR_FRAME,
+	RX_DROP_BAD_BCN_KEYIDX,
+	RX_DROP_BAD_MGMT_KEYIDX,
+	RX_DROP_INVALID_SKB,
+	RX_DROP_SHORT_HDR,
+	RX_DROP_NO_PUBSTA,
+	RX_DROP_NO_SET_STA,
+	RX_DROP_NO_FAST_RX,
+	RX_DROP_NO_LINK_STA,
+	RX_DROP_FRAME_ERR,
+	RX_DROP_REASON_MAX
