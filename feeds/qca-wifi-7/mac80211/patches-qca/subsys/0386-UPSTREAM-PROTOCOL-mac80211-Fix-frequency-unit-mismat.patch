From ef748ef17c11155a9ab2546d6e15c5e9078c5440 Mon Sep 17 00:00:00 2001
From: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
Date: Mon, 8 Sep 2025 15:32:09 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: mac80211: Fix frequency unit mismatch
and radio count handling in RX path

The RX path compares channel and status frequencies to determine the
radio index, but the values were in MHz while
ieee80211_get_radio_idx_by_freq() expects kHz. Because of this mismatch,
both lookups return -1, causing the comparison to succeed and iteration
to stop on the first check instead of finding the correct interface.

Convert both frequencies to kHz before the comparison to ensure proper
link index resolution.

Also replace the use of wiphy->num_hw, which is not initialised,
with wiphy->n_radio. This correctly reflects the number of radios and
ensures proper link iteration for MLD handling.

Signed-off-by: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
---
 net/mac80211/rx.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

--- a/net/mac80211/rx.c
+++ b/net/mac80211/rx.c
@@ -6075,20 +6075,21 @@ static void __ieee80211_rx_handle_packet
 
 		if (sdata->vif.type == NL80211_IFTYPE_MONITOR ||
 		    sdata->vif.type == NL80211_IFTYPE_AP_VLAN)
 			continue;
 
-		if (valid_links && wiphy->num_hw) {
+		if (valid_links && wiphy->n_radio) {
 			for_each_set_bit(link_id, &valid_links,
 					 IEEE80211_MLD_MAX_NUM_LINKS) {
 				bss_conf = rcu_dereference(sdata->vif.link_conf[link_id]);
 				if (!bss_conf)
 					continue;
 				conf = rcu_dereference(bss_conf->chanctx_conf);
 				if (conf && conf->def.chan) {
-					u32 ctr_freq = conf->def.chan->center_freq;
-					u32 sts_freq = status->freq;
+					u32 ctr_freq =
+						MHZ_TO_KHZ(conf->def.chan->center_freq);
+					u32 sts_freq = MHZ_TO_KHZ(status->freq);
 
 					if (ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    ctr_freq) ==
 					    ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    sts_freq) ||
@@ -6100,18 +6101,19 @@ static void __ieee80211_rx_handle_packet
 			}
 			if (!flag && sdata->vif.type == NL80211_IFTYPE_STATION &&
 			    sdata->vif.is_roc)
 				flag = true;
 
-		} else if (wiphy->num_hw) {
+		} else if (wiphy->n_radio) {
 			bss_conf = &sdata->vif.bss_conf;
 
 			if (bss_conf) {
 				conf = rcu_dereference(bss_conf->chanctx_conf);
 				if (conf && conf->def.chan) {
-					u32 ctr_freq = conf->def.chan->center_freq;
-					u32 sts_freq = status->freq;
+					u32 ctr_freq =
+						MHZ_TO_KHZ(conf->def.chan->center_freq);
+					u32 sts_freq = MHZ_TO_KHZ(status->freq);
 
 					if (ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    ctr_freq) ==
 					    ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    sts_freq) ||
@@ -6127,11 +6129,11 @@ static void __ieee80211_rx_handle_packet
 		 * frame is destined for this interface, but if it's
 		 * not also for the previous one we handle that after
 		 * the loop to avoid copying the SKB once too much
 		 */
 
-		if (!wiphy->num_hw || flag) {
+		if (!wiphy->n_radio || flag) {
 			if (!prev) {
 				prev_linkid = valid_links ? link_id : -1;
 				prev = sdata;
 				prev_flag = flag;
 				continue;
@@ -6149,11 +6151,11 @@ static void __ieee80211_rx_handle_packet
 			prev = sdata;
 			prev_flag = flag;
 		}
 	}
 
-	if (prev && wiphy->num_hw) {
+	if (prev && wiphy->n_radio) {
 		unsigned int link_id;
 		struct ieee80211_bss_conf *bss_conf;
 		struct ieee80211_chanctx_conf *conf;
 		unsigned long valid_links = prev->vif.valid_links;
 		bool flag = false;
@@ -6165,12 +6167,13 @@ static void __ieee80211_rx_handle_packet
 
 				if (!bss_conf)
 					continue;
 				conf = rcu_dereference(bss_conf->chanctx_conf);
 				if (conf && conf->def.chan) {
-					u32 ctr_freq = conf->def.chan->center_freq;
-					u32 sts_freq = status->freq;
+					u32 ctr_freq =
+						MHZ_TO_KHZ(conf->def.chan->center_freq);
+					u32 sts_freq = MHZ_TO_KHZ(status->freq);
 
 					if (ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    ctr_freq) ==
 					    ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    sts_freq) ||
@@ -6187,12 +6190,13 @@ static void __ieee80211_rx_handle_packet
 			bss_conf = &prev->vif.bss_conf;
 
 			if (bss_conf) {
 				conf = rcu_dereference(bss_conf->chanctx_conf);
 				if (conf && conf->def.chan) {
-					u32 ctr_freq = conf->def.chan->center_freq;
-					u32 sts_freq = status->freq;
+					u32 ctr_freq =
+						MHZ_TO_KHZ(conf->def.chan->center_freq);
+					u32 sts_freq = MHZ_TO_KHZ(status->freq);
 
 					if (ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    ctr_freq) ==
 					    ieee80211_get_radio_idx_by_freq(hw->wiphy,
 									    sts_freq) ||
