From 4827bff4aaef586530cd9596c7df5fc567eb75c2 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:25:50 +0530
Subject: [PATCH] mac80211: athk Add PPE config definition to enabledisable PPE
  support

Added PPE macro definition to enable/disable PPE support.

Signed-off-by: Balamurugan Selvarajan <quic_bselvara@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 local-symbols        | 3 ++-
 net/mac80211/Kconfig | 9 +++++++++
 2 files changed, 11 insertions(+), 1 deletion(-)

diff --git a/local-symbols b/local-symbols
index f83fbbf..1947a22 100644
--- a/local-symbols
+++ b/local-symbols
@@ -57,7 +57,8 @@ MAC80211_MESH_PS_DEBUG=
 MAC80211_TDLS_DEBUG=
 MAC80211_DEBUG_COUNTERS=
 MAC80211_STA_HASH_MAX_SIZE=
-AC80211_NSS_SUPPORT=
+MAC80211_NSS_SUPPORT=
+MAC80211_PPE_SUPPORT=
 WLAN=
 ATH_COMMON=
 WLAN_VENDOR_ATH=
diff --git a/net/mac80211/Kconfig b/net/mac80211/Kconfig
index efb96b7..4712b79 100644
--- a/net/mac80211/Kconfig
+++ b/net/mac80211/Kconfig
@@ -124,6 +124,15 @@ config MAC80211_NSS_SUPPORT
 
 	  If unsure, say Y to enable NSS offload support.
 
+config MAC80211_PPE_SUPPORT
+       bool "QTI mac80211 ppe support"
+       depends on ATH12K
+       default n
+       ---help---
+         Enables PPE support for ATH12K driver
+
+         If unsure, say N.
+
 config MAC80211_NOINLINE
 	bool "Do not inline TX/RX handlers"
 	depends on MAC80211_DEBUG_MENU
-- 
2.34.1

