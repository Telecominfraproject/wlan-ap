From 6ef31640f25c07dd3242639fbc7b56c557f53ecb Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:25:19 +0530
Subject: [PATCH] mac80211: process addba req during invalid ext element

Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/agg-rx.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/net/mac80211/agg-rx.c b/net/mac80211/agg-rx.c
index f3fbe5a..aa00c0e 100644
--- a/net/mac80211/agg-rx.c
+++ b/net/mac80211/agg-rx.c
@@ -204,6 +204,9 @@ u8 ieee80211_retrieve_addba_ext_data(struct sta_info *sta,
 	if (elem_len <= 0)
 		return 0;
 
+	if (((u8 *)elem_data)[0] != WLAN_EID_ADDBA_EXT)
+		return 0;
+
 	elems = ieee802_11_parse_elems(elem_data, elem_len, true, NULL);
 
 	if (elems && !elems->parse_error && elems->addba_ext_ie) {
-- 
2.34.1

