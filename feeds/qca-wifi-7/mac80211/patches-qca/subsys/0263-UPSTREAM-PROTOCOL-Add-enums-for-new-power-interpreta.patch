From 5c6e35b3feb1a539d17f0f2eb96c24e6f9851f1c Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:13 +0530
Subject: [PATCH] mac80211: UPSTREAMPROTOCOLAdd enums for new power 
 interpretations of  Indoor SP AP

Add enum IEEE80211_TPE_ADDITIONAL_REG_CLIENT_EIRP and
IEEE80211_TPE_ADDITIONAL_REG_CLIENT_EIRP_PSD to enum
ieee80211_tx_power_intrpt_type to be used to parse TPE IE from
an Indoor SP AP.

Signed-off-by: Amith A <quic_amitajit@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 include/linux/ieee80211.h | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/include/linux/ieee80211.h b/include/linux/ieee80211.h
index 9033b59..0321523 100644
--- a/include/linux/ieee80211.h
+++ b/include/linux/ieee80211.h
@@ -2877,6 +2877,8 @@ enum ieee80211_tx_power_intrpt_type {
 	IEEE80211_TPE_LOCAL_EIRP_PSD,
 	IEEE80211_TPE_REG_CLIENT_EIRP,
 	IEEE80211_TPE_REG_CLIENT_EIRP_PSD,
+	IEEE80211_TPE_ADDITIONAL_REG_CLIENT_EIRP,
+	IEEE80211_TPE_ADDITIONAL_REG_CLIENT_EIRP_PSD,
 };
 
 /* category type of transmit power envelope element */
-- 
2.34.1

