From 9e6fb94a52edb7ca7067764dc1e5a73118d494f7 Mon Sep 17 00:00:00 2001
From: Narendhar Reddy <nare@qti.qualcomm.com>
Date: Thu, 3 Jul 2025 20:05:42 +0530
Subject: [PATCH] UPSTREAM:wifi:CP:ath12k: Clear dangling entry in RB tree on BSS free

In the cfg80211 subsystem, all scan results of a BSS are stored in an RB tree to
facilitate easier search operations. Each BSS entry's reference count is
incremented during various association parameter updates and decremented
after usage. When the reference count reaches zero, the BSS is deleted.

However, a corner case was identified where a BSS entry could be freed before its
entry is cleared from the RB tree. This premature deletion leads to a crash due to
a dangling pointer dereference when rb_erase is called.

To address this issue, the BSS entry is now erased from the RB tree before it is
freed. This ensures that no attempts are made to access the BSS after it has been
freed, thereby preventing crashes.

Depends on : 0275-UPSTREAM-CP-wifi-cfg80211-fix-bss-rbn-double-erase-i.patch
Co-developed-by : Saravanakumar Duraisamy <quic_saradura@quicinc.com>
Signed-off-by: Sowmiya Sree Elavalagan <quic_ssreeela@quicinc.com>
Signed-off-by: Narendhar Reddy <nare@qti.qualcomm.com>
---
 net/wireless/scan.c | 24 ++++++++++++++++++++----
 1 file changed, 20 insertions(+), 4 deletions(-)

--- a/net/wireless/scan.c
+++ b/net/wireless/scan.c
@@ -125,8 +125,13 @@ static inline void bss_ref_put(struct cf
 
 		hbss = bss_from_pub(bss->pub.hidden_beacon_bss);
 		hbss->refcount--;
-		if (hbss->refcount == 0)
+		if (hbss->refcount == 0) {
+			if (hbss->in_rbtree == true) {
+				rb_erase(&hbss->rbn, &rdev->bss_tree);
+				hbss->in_rbtree = false;
+			}
 			bss_free(hbss);
+		}
 	}
 
 	if (bss->pub.transmitted_bss) {
@@ -134,13 +139,23 @@ static inline void bss_ref_put(struct cf
 
 		tbss = bss_from_pub(bss->pub.transmitted_bss);
 		tbss->refcount--;
-		if (tbss->refcount == 0)
+		if (tbss->refcount == 0) {
+			if (tbss->in_rbtree == true) {
+				rb_erase(&tbss->rbn, &rdev->bss_tree);
+				tbss->in_rbtree = false;
+			}
 			bss_free(tbss);
+		}
 	}
 
 	bss->refcount--;
-	if (bss->refcount == 0)
+	if (bss->refcount == 0) {
+		if (bss->in_rbtree == true) {
+			rb_erase(&bss->rbn, &rdev->bss_tree);
+			bss->in_rbtree = false;
+		}
 		bss_free(bss);
+	}
 }
 
 static bool __cfg80211_unlink_bss(struct cfg80211_registered_device *rdev,
@@ -166,6 +181,7 @@ static bool __cfg80211_unlink_bss(struct
 	list_del_init(&bss->pub.nontrans_list);
 	if (bss->in_rbtree)
 		rb_erase(&bss->rbn, &rdev->bss_tree);
+	bss->in_rbtree = false;
 	rdev->bss_entries--;
 	WARN_ONCE((rdev->bss_entries == 0) ^ list_empty(&rdev->bss_list),
 		  "rdev bss entries[%d]/list[empty:%d] corruption\n",
@@ -1665,9 +1681,9 @@ static bool rb_insert_bss(struct cfg8021
 			p = &(*p)->rb_right;
 	}
 
-	bss->in_rbtree = true;
 	rb_link_node(&bss->rbn, parent, p);
 	rb_insert_color(&bss->rbn, &rdev->bss_tree);
+	bss->in_rbtree = true;
 	return true;
 }
 
