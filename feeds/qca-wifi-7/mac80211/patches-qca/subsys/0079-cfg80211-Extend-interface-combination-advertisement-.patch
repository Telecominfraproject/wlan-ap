+					&ctx->conf.def);
+
+ 		if (idx >= 0)
+  			params->per_hw[idx].iftype_num[sdata->wdev.iftype]++;
+   		else
+    			params->iftype_num[sdata->wdev.iftype]++;
+
+     		if (total)
+      			(*total)++;
+       	}
