+
+	  	ctx = ieee80211_link_get_chanctx(link);
+	   	if (ctx &&
+		    ctx->replace_state == IEEE80211_CHANCTX_WILL_BE_REPLACED)
+			ctx = ctx->replace_ctx;
+
+ 		idx = -1;
+  		if (ctx)
