+static void
+ieee80211_get_per_hw_sdata_active_iface(struct ieee80211_sub_if_data *sdata,
+					struct iface_combination_params *params,
+					int *total)
+{
+ 	struct ieee80211_local *local = sdata->local;
+  	unsigned int link_id;
+   	int idx;
