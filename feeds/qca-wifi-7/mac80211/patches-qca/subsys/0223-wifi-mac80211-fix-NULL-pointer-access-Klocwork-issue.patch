From 1f2c613d434d04f52d2be773a9d65da77859c0b0 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:56 +0530
Subject: [PATCH] mac80211: KW wifi fix NULL pointer access Klocwork issue

Currently, we are dereferencing params->chan pointer without
a NULL check in ieee80211_mgmt_tx function.
Fix this issue by adding a NULL check.

Patch-dependency: none
Patch-work: none
Fixes: a2fcfccbad43 (mac80211: move off-channel/mgmt-tx code to offchannel.c)
Note: ath.git commit id is mentioned in the Fixes tag

Signed-off-by: Monika Korada <quic_koramoni@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/offchannel.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/net/mac80211/offchannel.c b/net/mac80211/offchannel.c
index 5b687e1..c96e764 100644
--- a/net/mac80211/offchannel.c
+++ b/net/mac80211/offchannel.c
@@ -1079,11 +1079,16 @@ int ieee80211_mgmt_tx(struct wiphy *wiphy, struct wireless_dev *wdev,
 			local->hw.offchannel_tx_hw_queue;
 
 	/* This will handle all kinds of coalescing and immediate TX */
+	if (!params->chan) {
+		ret = -EINVAL;
+		goto out_unlock;
+	}
 	ret = ieee80211_start_roc_work(local, sdata, params->chan,
 				       params->wait, cookie, skb,
 				       IEEE80211_ROC_TYPE_MGMT_TX);
 	if (ret)
 		ieee80211_free_txskb(&local->hw, skb);
+
  out_unlock:
 	return ret;
 }
