From 0a78ff784c78ff4b79c1ca4a33dec0324f88df18 Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Sun, 21 Sep 2025 16:14:57 +0530
Subject: [PATCH] QSDK:CP wifi:mac80211: Handle channel synchronization for
 independent monitor vdev

Following the UD package upgrade, monitor mode behavior has changed
due to the upstream introduction of NO VIRTUAL MONITOR mode. This
results in the monitor vdev operating independently of AP vdevs on
the same radio, requiring explicit channel synchronization.

Issue description:
- Monitor vdev was initialized on channel 44/80 MHz based on wireless
  config
- Hostapd performed OBSS scan and switched primary channel from 44 to
  48 based on scan results.
- This led to a mismatch between AP and monitor vdev channels,
  configuring firmware with dual home channels leading to the FW
  assert.

Synchronize monitor vdev channel context if AP vdev is brought up on
a different channel on the same radio. This ensures consistent channel
configuration across vdevs and avoids issues during scan, CSA, or DFS
operations.

Fix:
1.Channel Context Check Before AP Bring-Up: During the start_ap process,
  if the AP's configured channel differs from the existing one, mac80211
  attempts to allocate and assign a new ieee80211_chan_ctx. Before invoking
  the driver call to assign this new context to the AP interface, the system
  checks for any pre-existing channel contexts for the same radio.

2.Context Switch for Monitor Interface: If an existing channel context is
  found (typically associated with a monitor vdev), the fix should ensures
  that the monitor interface is first unassigned from the old context and
  then reassigned to the new one. This switch is necessary to maintain
  channel synchronization, especially when the monitor vdev operates
  independently.

3.Cleanup of Unused Channel Contexts: Once the reassignment is complete,
  the older channel context is deallocated and destroyed if no other
  interfaces or links are using it

Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 net/mac80211/chan.c | 54 ++++++++++++++++++++++++++++++++++++++++++++-
 1 file changed, 53 insertions(+), 1 deletion(-)

--- a/net/mac80211/chan.c
+++ b/net/mac80211/chan.c
@@ -1917,6 +1917,48 @@ void __ieee80211_link_release_channel(st
 		ieee80211_vif_use_reserved_switch(local);
 }
 
+int ieee80211_update_chanctx_for_radio(struct ieee80211_local *local,
+				       struct ieee80211_chanctx *ctx,
+				       int radio_idx)
+{
+	struct ieee80211_chanctx *temp_ctx;
+	struct ieee80211_link_data *tmp_link;
+	struct ieee80211_sub_if_data *tmp_sdata;
+	int ret = 0;
+	bool found = false;
+
+	lockdep_assert_wiphy(local->hw.wiphy);
+
+	list_for_each_entry(temp_ctx, &local->chanctx_list, list) {
+		if (temp_ctx == ctx)
+			continue;
+		if (temp_ctx->conf.radio_idx == radio_idx) {
+			found = true;
+			break;
+		}
+	}
+
+	if (!found)
+		return 0;
+
+	list_for_each_entry(tmp_link, &temp_ctx->assigned_links, assigned_chanctx_list) {
+		tmp_sdata = tmp_link->sdata;
+		if (tmp_sdata->wdev.iftype != NL80211_IFTYPE_MONITOR)
+			continue;
+
+		sdata_info(tmp_sdata,
+			   "Switching channel for monitor iface to %d\n",
+			   ctx->conf.def.chan->center_freq);
+		ret = ieee80211_set_monitor_channel(tmp_sdata->wdev.wiphy,
+						    tmp_sdata->dev,
+						    &ctx->conf.def);
+		WARN_ON(ieee80211_add_chanctx(local, ctx));
+		break;
+	}
+
+	return ret;
+}
+
 int _ieee80211_link_use_channel(struct ieee80211_link_data *link,
 				const struct ieee80211_chan_req *chanreq,
 				enum ieee80211_chanctx_mode mode,
@@ -1956,16 +1998,30 @@ int _ieee80211_link_use_channel(struct i
 
 	ctx = ieee80211_find_chanctx(local, link, chanreq, mode);
 	/* Note: context is now reserved */
-	if (ctx)
+	if (ctx) {
 		reserved = true;
-	else
+	} else {
+		radio_idx = cfg80211_get_hw_idx_by_chan(sdata->wdev.wiphy,
+							chanreq->oper.chan);
 		ctx = ieee80211_new_chanctx(local, chanreq, mode,
 					    assign_on_failure, radio_idx);
+	}
+
 	if (IS_ERR(ctx)) {
 		ret = PTR_ERR(ctx);
 		goto out;
 	}
 
+	/* Check if any Monitor vdev is there on the same radio with
+	 * different chanctx
+	 */
+	if (!reserved && ieee80211_hw_check(&local->hw,
+					    SUPPORTS_SINGLE_CHANNEL)) {
+		ret = ieee80211_update_chanctx_for_radio(local, ctx, radio_idx);
+		if (ret)
+			goto out;
+	}
+
 	ieee80211_link_update_chanreq(link, chanreq);
 
 	ret = ieee80211_assign_link_chanctx(link, ctx, assign_on_failure);
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -3116,6 +3116,9 @@ struct ieee80211_txq {
  *	HW flag so drivers can opt in according to their own control, e.g. in
  *	testing.
  *
+ * @IEEE80211_HW_SUPPORTS_SINGLE_CHANNEL: Hardware only supports single
+ *	channel operation.
+ *
  * @NUM_IEEE80211_HW_FLAGS: number of hardware flags, used for sizing arrays
  */
 enum ieee80211_hw_flags {
@@ -3187,6 +3190,7 @@ enum ieee80211_hw_flags {
 	IEEE80211_HW_SUPPORTS_CONC_AP_MON_IN_80211_FORMAT,
 	IEEE80211_HW_SUPPORTS_EXT_REMAIN_ON_CHAN,
 	IEEE80211_HW_SUPPORTS_DSCP_TID_MAP,
+	IEEE80211_HW_SUPPORTS_SINGLE_CHANNEL,
 
 	/* keep last, obviously */
 	NUM_IEEE80211_HW_FLAGS
--- a/net/mac80211/debugfs.c
+++ b/net/mac80211/debugfs.c
@@ -645,6 +645,7 @@ static const char *hw_flag_names[] = {
 	FLAG(SUPPORTS_CONC_AP_MON_IN_80211_FORMAT),
 	FLAG(SUPPORTS_EXT_REMAIN_ON_CHAN),
 	FLAG(SUPPORTS_DSCP_TID_MAP),
+	FLAG(SUPPORTS_SINGLE_CHANNEL),
 #undef FLAG
 };
 
