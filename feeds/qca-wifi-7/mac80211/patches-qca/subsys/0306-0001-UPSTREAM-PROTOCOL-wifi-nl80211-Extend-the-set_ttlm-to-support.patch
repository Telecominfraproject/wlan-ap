From 4d696b8c8226b17c07023d683d6ef7b86736de36 Mon Sep 17 00:00:00 2001
From: Shwetha G K <kshwetha@qti.qualcomm.com>
Date: Fri, 20 Jun 2025 08:55:34 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: nl80211/mac80211: Enhance TTLM
negotiation on AP interface

Add changes to support TTLM negotiation on AP MLD (the action frames
are generated externally) using which lower layers are notified to
map the HW TIDs accordingly.

- Extended 'cfg80211_ttlm_params' to include mld_mac_addr,
  which identifies the STA MLD involved in the TTLM negotiation.
- Updated nl80211_set_ttlm() to handle AP interface type and validate the
  presence of the MLD MAC address attribute when operating as an AP.
- Defined IEEE80211_MAX_NUM_TIDS and IEEE80211_MAX_TTLM_DIRECTION to
  support flexible TID mapping across multiple directions.
- Ensured that lower layers are notified with the appropriate TTLM
  parameters, including the peer STA MLD MAC address, to allow correct
  hardware TID-to-link mapping.

Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
Signed-off-by: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
---
 include/net/cfg80211.h |  2 ++
 net/wireless/nl80211.c | 13 +++++++++++--
 2 files changed, 13 insertions(+), 2 deletions(-)

--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -1969,10 +1969,13 @@ struct link_station_del_parameters {
  *     (TID-To-Link Mapping element) in Draft P802.11be_D4.0.
  * @ulink: Uplink TID to link mapping, as defined in section 9.4.2.314
  *     (TID-To-Link Mapping element) in Draft P802.11be_D4.0.
+ * @mld_mac_addr: STA mld mac with which negotitation attempted on
+ *      AP MLD
  */
 struct cfg80211_ttlm_params {
-	u16 dlink[8];
-	u16 ulink[8];
+	u16 dlink[IEEE80211_MAX_NUM_TIDS];
+	u16 ulink[IEEE80211_MAX_NUM_TIDS];
+	const u8 *mld_mac_addr;
 };
 
 /**
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -17853,16 +17853,21 @@ nl80211_set_ttlm(struct sk_buff *skb, st
 	struct wireless_dev *wdev = dev->ieee80211_ptr;
 
 	if (wdev->iftype != NL80211_IFTYPE_STATION &&
-	    wdev->iftype != NL80211_IFTYPE_P2P_CLIENT)
+	    wdev->iftype != NL80211_IFTYPE_P2P_CLIENT &&
+	    wdev->iftype != NL80211_IFTYPE_AP)
 		return -EOPNOTSUPP;
 
-	if (!wdev->connected)
+	if (wdev->iftype != NL80211_IFTYPE_AP && !wdev->connected)
 		return -ENOLINK;
 
 	if (!info->attrs[NL80211_ATTR_MLO_TTLM_DLINK] ||
 	    !info->attrs[NL80211_ATTR_MLO_TTLM_ULINK])
 		return -EINVAL;
 
+	if (wdev->iftype == NL80211_IFTYPE_AP &&
+	    !info->attrs[NL80211_ATTR_MLD_ADDR])
+		return -EINVAL;
+
 	nla_memcpy(params.dlink,
 		   info->attrs[NL80211_ATTR_MLO_TTLM_DLINK],
 		   sizeof(params.dlink));
@@ -17870,6 +17875,10 @@ nl80211_set_ttlm(struct sk_buff *skb, st
 		   info->attrs[NL80211_ATTR_MLO_TTLM_ULINK],
 		   sizeof(params.ulink));
 
+	if (info->attrs[NL80211_ATTR_MLD_ADDR])
+		params.mld_mac_addr =
+			nla_data(info->attrs[NL80211_ATTR_MLD_ADDR]);
+
 	return rdev_set_ttlm(rdev, dev, &params);
 }
 
--- a/include/linux/ieee80211.h
+++ b/include/linux/ieee80211.h
@@ -5747,4 +5747,7 @@ static inline bool ieee80211_tid_to_link
 				 _data + ieee80211_mle_common_size(_data),\
 				 _len - ieee80211_mle_common_size(_data))
 
+#define IEEE80211_MAX_TTLM_DIRECTION 2
+#define IEEE80211_MAX_NUM_TIDS 8
+
 #endif /* LINUX_IEEE80211_H */
