From 408d41f9648e2d4c9c0795e93af2cf9c46a66416 Mon Sep 17 00:00:00 2001
From: Aaradhana Sahu <aaradhana.sahu@oss.qualcomm.com>
Date: Wed, 30 Jul 2025 10:28:39 +0530
Subject: [PATCH] UPSTREAM:CP:wifi:mac80211: Fix missing
 NL80211_CMD_REMAIN_ON_CHANNEL event during P2P discovery

During P2P connection setup, the driver fails to send the
NL80211_CMD_REMAIN_ON_CHANNEL event to userspace, preventing the
device from listening on the intended channel and causing P2P
discovery to fail.

Fix this by adding correct check of cfg80211_chandef_identical()
inside _ieee80211_start_next_roc(), ensuring the ROC event is properly
triggered.

Patch-dependency:
0344-UPSTREAM-CP-wifi-mac80211-Allow-probe-request-frame-.patch
Patch-work: None

Signed-off-by: Aaradhana Sahu <aaradhana.sahu@oss.qualcomm.com>
---
 net/mac80211/offchannel.c | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/net/mac80211/offchannel.c b/net/mac80211/offchannel.c
index d4799d5..6f75b7c 100644
--- a/net/mac80211/offchannel.c
+++ b/net/mac80211/offchannel.c
@@ -322,7 +322,7 @@ static void _ieee80211_start_next_roc(struct ieee80211_local *local)
 		if (tmp == roc)
 			continue;
 		if (tmp->sdata != roc->sdata ||
-		    cfg80211_chandef_identical(&tmp->chandef, &roc->chandef))
+		    !cfg80211_chandef_identical(&tmp->chandef, &roc->chandef))
 			break;
 		max_dur = max(tmp->duration, max_dur);
 		min_dur = min(tmp->duration, min_dur);
@@ -343,7 +343,7 @@ static void _ieee80211_start_next_roc(struct ieee80211_local *local)
 			 */
 			list_for_each_entry(tmp, &local->roc_list, list) {
 				if (tmp->sdata != roc->sdata ||
-				    cfg80211_chandef_identical(&tmp->chandef,
+				    !cfg80211_chandef_identical(&tmp->chandef,
 							       &roc->chandef))
 					break;
 				tmp->started = true;
@@ -356,7 +356,7 @@ static void _ieee80211_start_next_roc(struct ieee80211_local *local)
 		/* we'll notify about the start once the HW calls back */
 		list_for_each_entry(tmp, &local->roc_list, list) {
 			if (tmp->sdata != roc->sdata ||
-			    cfg80211_chandef_identical(&tmp->chandef, &roc->chandef))
+			    !cfg80211_chandef_identical(&tmp->chandef, &roc->chandef))
 				break;
 			tmp->started = true;
 		}
