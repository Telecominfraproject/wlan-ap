From 98efceee05796130fd9c0701e55edd35f17f29e2 Mon Sep 17 00:00:00 2001
From: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Date: Mon, 4 Aug 2025 14:49:47 +0530
Subject: [PATCH] UPSTREAM:wifi:nl80211:Avoid frequency config for non-AP
 station

Channel configuration through userspace is not allowed for non-AP
station. Current code allows this configuration which leads to crash.
While configuring channel, kernel checks whether interface type allows
the channel configuration but since wdev is NULL, the function return
true which leads to a false positive and while configuring channel this
causes crash.

Fix the API nl80211_can_set_dev_channel() which validates the interface
type to avoid configuring the channel for non-AP sta.

Patch-work:none
Patch-dependency:none

Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
---
 net/wireless/nl80211.c | 17 ++++++++++++-----
 1 file changed, 12 insertions(+), 5 deletions(-)

diff --git a/net/wireless/nl80211.c b/net/wireless/nl80211.c
index 4b8e141..331edf5 100644
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -3904,11 +3904,18 @@ static bool nl80211_can_set_dev_channel(struct wireless_dev *wdev)
 	 * whatever else is going on, so they have their own special
 	 * operation to set the monitor channel if possible.
 	 */
-	return !wdev ||
-		wdev->iftype == NL80211_IFTYPE_AP ||
-		wdev->iftype == NL80211_IFTYPE_MESH_POINT ||
-		wdev->iftype == NL80211_IFTYPE_MONITOR ||
-		wdev->iftype == NL80211_IFTYPE_P2P_GO;
+	if (!wdev)
+		return false;
+
+	switch (wdev->iftype) {
+	case NL80211_IFTYPE_AP:
+	case NL80211_IFTYPE_MESH_POINT:
+	case NL80211_IFTYPE_MONITOR:
+	case NL80211_IFTYPE_P2P_GO:
+		return true;
+	default:
+		return false;
+	}
 }
 
 static int _nl80211_parse_chandef(struct cfg80211_registered_device *rdev,
