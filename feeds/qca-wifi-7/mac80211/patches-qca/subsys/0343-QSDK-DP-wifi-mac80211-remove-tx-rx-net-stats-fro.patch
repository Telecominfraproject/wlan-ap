From 3df74053e1c1ee8e0112c0c47c7945fa5ecf26b1 Mon Sep 17 00:00:00 2001
From: Sarika Sharma <sarishar@qti.qualcomm.com>
Date: Mon, 28 Jul 2025 09:31:51 +0530
Subject: [PATCH] QSDK:DP: wifi:mac80211: remove tx/rx net stats from
 ethtool

Currently tx/rx net dev stats are added in ethtool, but these stats are
already exposed through ip stats. It is just an duplicate to add these
stats at ethtool as well.

Hence, removing these stats from ethtool interface.

Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
---
 include/net/mac80211.h |  2 --
 net/mac80211/ethtool.c | 10 ----------
 2 files changed, 12 deletions(-)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index c7f9840..b91f802 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -8400,8 +8400,6 @@ enum ieee80211_gstrings_stats {
 	IEEE80211_CH_TIME_TX,
 	IEEE80211_TX_DEV_DROPPED,
 	IEEE80211_RX_DEV_DROPPED,
-	IEEE80211_TX_NET_PACKETS,
-	IEEE80211_RX_NET_PACKETS,
 	IEEE80211_STATS_MAX,
 };
 
diff --git a/net/mac80211/ethtool.c b/net/mac80211/ethtool.c
index 4c25a4d..0ca073e 100644
--- a/net/mac80211/ethtool.c
+++ b/net/mac80211/ethtool.c
@@ -75,8 +75,6 @@ static const char ieee80211_gstrings_sta_stats[][ETH_GSTRING_LEN] = {
 	[IEEE80211_CH_TIME_TX] = "ch_time_tx",
 	[IEEE80211_TX_DEV_DROPPED] = "tx_dev_dropped",
 	[IEEE80211_RX_DEV_DROPPED] = "rx_dev_dropped",
-	[IEEE80211_TX_NET_PACKETS] = "tx_net_packets",
-	[IEEE80211_RX_NET_PACKETS] = "rx_net_packets",
 };
 
 #define STA_STATS_LEN	ARRAY_SIZE(ieee80211_gstrings_sta_stats)
@@ -109,9 +107,6 @@ static void ieee80211_get_stats(struct net_device *dev,
 	struct survey_info survey;
 	int q;
 	unsigned long int i;
-	struct rtnl_link_stats64 rtnl_stats = {0};
-
-	dev_fetch_sw_netstats(&rtnl_stats, dev->tstats);
 
 #define STA_STATS_SURVEY_LEN 7
 
@@ -243,11 +238,6 @@ do_survey:
 	data[IEEE80211_RX_DEV_DROPPED] = sdata->rx_dropped;
 	i++;
 
-	data[IEEE80211_TX_NET_PACKETS] = rtnl_stats.tx_packets;
-	i++;
-	data[IEEE80211_RX_NET_PACKETS] = rtnl_stats.rx_packets;
-	i++;
-
 	if (WARN_ON(i != STA_STATS_LEN))
 		return;
 
-- 
2.34.1

