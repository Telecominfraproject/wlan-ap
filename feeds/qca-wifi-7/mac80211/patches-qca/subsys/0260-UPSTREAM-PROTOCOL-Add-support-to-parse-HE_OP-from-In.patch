From 87b97aab68af0de3b7dbbc1f6074df72805d9b5b Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:13 +0530
Subject: [PATCH] mac80211: UPSTREAMPROTOCOLAdd support to parse HE_OP from 
 Indoor  SP AP

An Indoor SP(Composite) AP advertises its power mode as 0x08 in the
regulatory element of HE_OP IE. Add support in the STA to parse this
new power mode.

When the STA receives the regulatory info as Indoor SP AP, convert it
to SP AP internally so that the STA treats the root AP as a regular
SP AP.

Tag: 6G_REGULATORY

Signed-off-by: Amith A <quic_amitajit@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 include/linux/ieee80211.h |  2 +-
 net/mac80211/util.c       | 14 ++++++++++++++
 2 files changed, 15 insertions(+), 1 deletion(-)

Index: backports-20250213-6.6.47-9a0dddfb30f1/include/linux/ieee80211.h
===================================================================
--- backports-20250213-6.6.47-9a0dddfb30f1.orig/include/linux/ieee80211.h
+++ backports-20250213-6.6.47-9a0dddfb30f1/include/linux/ieee80211.h
@@ -2839,7 +2839,7 @@ static inline bool ieee80211_he_capa_siz
 #define IEEE80211_6GHZ_CTRL_REG_SP_AP		1
 #define IEEE80211_6GHZ_CTRL_REG_VLP_AP		2
 #define IEEE80211_6GHZ_CTRL_REG_INDOOR_LPI_AP	3
-#define IEEE80211_6GHZ_CTRL_REG_INDOOR_SP_AP	4
+#define IEEE80211_6GHZ_CTRL_REG_INDOOR_SP_AP	8
 
 /**
  * struct ieee80211_he_6ghz_oper - HE 6 GHz operation Information field
@@ -2857,7 +2857,7 @@ struct ieee80211_he_6ghz_oper {
 #define		IEEE80211_HE_6GHZ_OPER_CTRL_CHANWIDTH_80MHZ	2
 #define		IEEE80211_HE_6GHZ_OPER_CTRL_CHANWIDTH_160MHZ	3
 #define IEEE80211_HE_6GHZ_OPER_CTRL_DUP_BEACON	0x4
-#define IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO	0x38
+#define IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO	0x78
 #define IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO_LSB 3
 	u8 control;
 	u8 ccfs0;
Index: backports-20250213-6.6.47-9a0dddfb30f1/net/mac80211/util.c
===================================================================
--- backports-20250213-6.6.47-9a0dddfb30f1.orig/net/mac80211/util.c
+++ backports-20250213-6.6.47-9a0dddfb30f1/net/mac80211/util.c
@@ -3378,6 +3378,13 @@ struct ieee80211_channel
 	reg_info = (he_6ghz_oper->control & IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO) >>
 		   IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO_LSB;
 
+	/*
+	 * If the root AP is Indoor SP AP, convert the received control field
+	 * to SP AP.
+	 */
+	if (reg_info == IEEE80211_6GHZ_CTRL_REG_INDOOR_SP_AP)
+		reg_info = IEEE80211_6GHZ_CTRL_REG_SP_AP;
+
 	/* 6G Power mode configured by the user */
 	reg_6g_power_mode = sdata->wdev.reg_6g_power_mode;
 
@@ -3432,6 +3439,13 @@ bool ieee80211_chandef_he_6ghz_oper(stru
 	reg_info = (he_6ghz_oper->control & IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO) >>
 		    IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO_LSB;
 
+	/*
+	 * If the root AP is Indoor SP AP, convert the received control field
+	 * to SP AP.
+	 */
+	if (reg_info == IEEE80211_6GHZ_CTRL_REG_INDOOR_SP_AP)
+		reg_info = IEEE80211_6GHZ_CTRL_REG_SP_AP;
+
 	/* 6G Power mode configured by the user */
 	reg_6g_power_mode = sdata->wdev.reg_6g_power_mode;
 
