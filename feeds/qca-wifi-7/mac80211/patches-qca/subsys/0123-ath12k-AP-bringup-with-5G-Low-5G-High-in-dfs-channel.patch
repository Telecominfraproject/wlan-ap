 net/mac80211/chan.c        | 17 ++++++++++++-----
 net/mac80211/ieee80211_i.h |  3 ++-
 net/mac80211/offchannel.c  |  3 ++-
 net/mac80211/scan.c        | 19 ++++++++++++-------
 net/mac80211/util.c        |  8 ++++----
 net/wireless/chan.c        |  3 +++
