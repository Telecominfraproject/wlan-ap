 int
 cfg80211_get_hw_idx_by_chan(struct wiphy *wiphy,
-     			    const struct cfg80211_chan_def *chandef)
+			    const struct ieee80211_channel *chan)
 {
- 	int i;
+	const struct wiphy_radio_freq_range *freq_range;
