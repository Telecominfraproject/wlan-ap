+				if (MHZ_TO_KHZ(chan->center_freq) >= freq_range[j].start_freq &&
+				    MHZ_TO_KHZ(chan->center_freq) <= freq_range[j].end_freq)
+					return i;
+			}
+		}
+	}
 
 	return -1;
 }
