From 34d014fb9764952aa61caf4e3d7a4442b38078b7 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:24 +0530
Subject: [PATCH] mac80211: athk Add SAWF tx delay stats support

Signed-off-by: Tamizh Chelvam Raja <quic_tamizhr@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 include/net/mac80211.h | 4 ++++
 net/mac80211/tx.c      | 3 +++
 2 files changed, 7 insertions(+)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index 6cd409a..bfd37c6 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -1336,6 +1336,10 @@ struct ieee80211_tx_info {
 		u8 pad[36];
 		u32 tx_start_time;
 	} latency;
+		struct {
+			u8 pad[36];
+			u32 nw_delay;
+		} sawf;
 	};
 };
 
diff --git a/net/mac80211/tx.c b/net/mac80211/tx.c
index 31ae426..b436719 100644
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -4425,6 +4425,7 @@ void __ieee80211_subif_start_xmit(struct sk_buff *skb,
 		}
 
 		info = IEEE80211_SKB_CB(skb);
+		info->sawf.nw_delay = (u32) ktime_to_us(net_timedelta(skb->tstamp));
 		if (info->flags & IEEE80211_TX_CTL_HW_80211_ENCAP) {
 		    	if (sta)
 				key = rcu_dereference(sta->ptk[sta->ptk_idx]);
@@ -4808,6 +4809,7 @@ static void ieee80211_8023_xmit(struct ieee80211_sub_if_data *sdata,
 	memset(info, 0, sizeof(*info));
 
 	info->flags |= info_flags;
+	info->sawf.nw_delay = (u32) ktime_to_us(net_timedelta(skb->tstamp));
 	info->hw_queue = sdata->vif.hw_queue[queue];
 
 	if (sdata->vif.type == NL80211_IFTYPE_AP_VLAN &&
@@ -4895,6 +4897,7 @@ void ieee80211_8023_xmit_ap(struct ieee80211_sub_if_data *sdata,
 
 	info->flags |= IEEE80211_TX_CTL_HW_80211_ENCAP;
 	info->control.vif = &sdata->vif;
+	info->sawf.nw_delay = (u32) ktime_to_us(net_timedelta(skb->tstamp));
 
 	if (key)
 		info->control.hw_key = &key->conf;
-- 
2.34.1

