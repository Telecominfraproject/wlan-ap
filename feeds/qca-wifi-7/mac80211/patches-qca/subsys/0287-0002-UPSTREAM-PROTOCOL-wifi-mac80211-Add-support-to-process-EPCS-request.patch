From 4f24cf5f6266572093d65a293f006cd83b77b3bf Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Mon, 12 May 2025 19:11:17 +0530
Subject: [PATCH 2/2] mac80211: UPSTREAMPROTOCOL Add support to process EPCS request frame

Add support to process Emergency Preparedness Communications Service (EPCS)
request action frame from AP MLD. The non-AP MLD receives and parses this
frame and sends a EPCS response action frame to AP MLD.

As per IEEE P802.11be/D7.0 - 35.16, validate the below conditions to set
the status code in EPCS response action frame.
1. EPCS feature must be enabled.
2. Current state of the EPCS must be disabled.
3. EPCS request action frame contents must be parsed and valid.

If the above conditions are true, set the status code to WLAN_STATUS_SUCCESS
and send the EPCS response action frame. Set the EPCS state to enabled.
Else set the status code to WLAN_STATUS_EPCS_DENIED and send the EPCS
response action frame. Set the EPCS state to disabled.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 include/linux/ieee80211.h  |  2 ++
 net/mac80211/ieee80211_i.h |  2 ++
 net/mac80211/iface.c       |  4 +++
 net/mac80211/mlme.c        | 65 ++++++++++++++++++++++++++++++++++++++
 net/mac80211/rx.c          |  9 ++++++
 5 files changed, 82 insertions(+)

diff --git a/include/linux/ieee80211.h b/include/linux/ieee80211.h
index 420c7f9aa6ee..d06e1d139e10 100644
--- a/include/linux/ieee80211.h
+++ b/include/linux/ieee80211.h
@@ -3510,6 +3510,7 @@ enum ieee80211_statuscode {
 	WLAN_STATUS_UNKNOWN_AUTHENTICATION_SERVER = 109,
 	WLAN_STATUS_SAE_HASH_TO_ELEMENT = 126,
 	WLAN_STATUS_SAE_PK = 127,
+	WLAN_STATUS_EPCS_DENIED = 132,
 	WLAN_STATUS_DENIED_TID_TO_LINK_MAPPING = 133,
 	WLAN_STATUS_PREF_TID_TO_LINK_MAPPING_SUGGESTED = 134,
 };
@@ -5585,6 +5586,7 @@ static inline bool ieee80211_mle_reconf_sta_prof_size_ok(const u8 *data,
 
 #define IEEE80211_MLE_STA_EPCS_CONTROL_LINK_ID			0x000f
 #define IEEE80211_EPCS_ENA_RESP_BODY_LEN                        3
+#define IEEE80211_EPCS_ENA_REQ_BODY_LEN				1
 
 static inline bool ieee80211_tid_to_link_map_size_ok(const u8 *data, size_t len)
 {
diff --git a/net/mac80211/ieee80211_i.h b/net/mac80211/ieee80211_i.h
index 30809f0b35f7..a7918996af59 100644
--- a/net/mac80211/ieee80211_i.h
+++ b/net/mac80211/ieee80211_i.h
@@ -2801,6 +2801,8 @@ void ieee80211_process_epcs_ena_resp(struct ieee80211_sub_if_data *sdata,
 				     struct ieee80211_mgmt *mgmt, size_t len);
 void ieee80211_process_epcs_teardown(struct ieee80211_sub_if_data *sdata,
 				     struct ieee80211_mgmt *mgmt, size_t len);
+void ieee80211_process_epcs_ena_req(struct ieee80211_sub_if_data *sdata,
+				    struct ieee80211_mgmt *mgmt, size_t len);
 
 int ieee80211_mgd_assoc_ml_reconf(struct ieee80211_sub_if_data *sdata,
 				  struct cfg80211_ml_reconf_req *req);
diff --git a/net/mac80211/iface.c b/net/mac80211/iface.c
index 7c27f3cd841c..423feeb12d8d 100644
--- a/net/mac80211/iface.c
+++ b/net/mac80211/iface.c
@@ -1613,6 +1613,10 @@ static void ieee80211_iface_process_skb(struct ieee80211_local *local,
 				ieee80211_process_ml_reconf_resp(sdata, mgmt,
 								 skb->len);
 				break;
+			case WLAN_PROTECTED_EHT_ACTION_EPCS_ENABLE_REQ:
+				ieee80211_process_epcs_ena_req(sdata, mgmt,
+							       skb->len);
+				break;
 			case WLAN_PROTECTED_EHT_ACTION_EPCS_ENABLE_RESP:
 				ieee80211_process_epcs_ena_resp(sdata, mgmt,
 								skb->len);
diff --git a/net/mac80211/mlme.c b/net/mac80211/mlme.c
index b84150dbfe8c..e4c706e58b6d 100644
--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -10800,3 +10800,69 @@ void ieee80211_process_epcs_teardown(struct ieee80211_sub_if_data *sdata,
 	ieee80211_epcs_teardown(sdata);
 	ieee80211_epcs_changed(sdata, false);
 }
+
+void ieee80211_mgd_send_epcs_resp(struct ieee80211_sub_if_data *sdata,
+				  u16 status_code)
+{
+	struct ieee80211_local *local = sdata->local;
+	struct ieee80211_mgmt *mgmt;
+	struct sk_buff *skb;
+	/* frame_len (29): mgmt hdr (24) + action category (1) + action code (1) +
+	 *		   dialog token (1) + status code (2)
+	 */
+	int frame_len = offsetofend(struct ieee80211_mgmt, u.action.u.epcs_resp);
+
+	skb = dev_alloc_skb(local->hw.extra_tx_headroom + frame_len);
+	if (!skb)
+		return;
+
+	skb_reserve(skb, local->hw.extra_tx_headroom);
+	mgmt = skb_put_zero(skb, frame_len);
+	mgmt->frame_control = cpu_to_le16(IEEE80211_FTYPE_MGMT | IEEE80211_STYPE_ACTION);
+	memcpy(mgmt->da, sdata->vif.cfg.ap_addr, ETH_ALEN);
+	memcpy(mgmt->sa, sdata->vif.addr, ETH_ALEN);
+	memcpy(mgmt->bssid, sdata->vif.cfg.ap_addr, ETH_ALEN);
+
+	mgmt->u.action.category = WLAN_CATEGORY_PROTECTED_EHT;
+	mgmt->u.action.u.epcs_resp.action_code =
+		WLAN_PROTECTED_EHT_ACTION_EPCS_ENABLE_RESP;
+	mgmt->u.action.u.epcs_resp.dialog_token = sdata->u.mgd.epcs.dialog_token;
+	mgmt->u.action.u.epcs_resp.status_code = cpu_to_le16(status_code);
+
+	ieee80211_epcs_changed(sdata, !status_code);
+	ieee80211_tx_skb(sdata, skb);
+}
+
+void ieee80211_process_epcs_ena_req(struct ieee80211_sub_if_data *sdata,
+				    struct ieee80211_mgmt *mgmt, size_t len)
+{
+	struct ieee802_11_elems *elems;
+	size_t ies_len;
+	u8 *pos;
+	u16 status_code = WLAN_STATUS_SUCCESS;
+
+	pos = mgmt->u.action.u.epcs.variable;
+	sdata->u.mgd.epcs.dialog_token = *pos;
+
+	if (!ieee80211_mgd_epcs_supp(sdata) || sdata->u.mgd.epcs.enabled ||
+	    !sdata->u.mgd.epcs.dialog_token) {
+		status_code = WLAN_STATUS_EPCS_DENIED;
+		goto send_frame;
+	}
+
+	pos += IEEE80211_EPCS_ENA_REQ_BODY_LEN;
+	ies_len = len - offsetof(struct ieee80211_mgmt, u.action.u.epcs.variable) -
+		  IEEE80211_EPCS_ENA_REQ_BODY_LEN;
+
+	elems = ieee802_11_parse_elems(pos, ies_len, true, NULL);
+	if (!elems) {
+		status_code = WLAN_STATUS_EPCS_DENIED;
+		goto send_frame;
+	}
+
+	ieee80211_ml_epcs(sdata, elems);
+	kfree(elems);
+
+send_frame:
+	ieee80211_mgd_send_epcs_resp(sdata, status_code);
+}
diff --git a/net/mac80211/rx.c b/net/mac80211/rx.c
index 09beb65d6108..231d5ae498a5 100644
--- a/net/mac80211/rx.c
+++ b/net/mac80211/rx.c
@@ -3831,6 +3831,15 @@ ieee80211_rx_h_action(struct ieee80211_rx_data *rx)
 					u.action.u.ml_reconf_resp) + 3)
 				goto invalid;
 			goto queue;
+		case WLAN_PROTECTED_EHT_ACTION_EPCS_ENABLE_REQ:
+			if (sdata->vif.type != NL80211_IFTYPE_STATION)
+				break;
+
+			if (len < offsetofend(typeof(*mgmt),
+					      u.action.u.epcs) +
+			    IEEE80211_EPCS_ENA_REQ_BODY_LEN)
+				goto invalid;
+			goto queue;
 		case WLAN_PROTECTED_EHT_ACTION_EPCS_ENABLE_RESP:
 			if (sdata->vif.type != NL80211_IFTYPE_STATION)
 				break;
-- 
