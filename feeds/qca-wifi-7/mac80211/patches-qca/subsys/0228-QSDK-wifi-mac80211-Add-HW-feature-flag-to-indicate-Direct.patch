From 5de24446ce76950afed76b7e346512e597765352 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:58 +0530
Subject: [PATCH] mac80211: QSDK Add HW feature flag to indicate Direct 
 Switching support

Add Hardware feature flag to indicate support for Direct Switching.
Drivers use this to advertize the capability.

Patch-depdendency: None

Signed-off-by: Pradeep Kumar Chitrapu <quic_pradeepc@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 include/net/mac80211.h | 3 +++
 net/mac80211/debugfs.c | 1 +
 2 files changed, 4 insertions(+)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index f89c1db..b0d6d9c 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -2983,6 +2983,8 @@ struct ieee80211_txq {
  * @IEE80211_HW_HAS_TX_QUEUE: Hardware/drivers has tx queue, does skb queuing itself,
  *	the stack will not do tx queuing.
  *
+ * @IEE80211_HW_SUPPORT_ECM_REGISTRATION: driver supports ECM registration
+ *
  * @NUM_IEEE80211_HW_FLAGS: number of hardware flags, used for sizing arrays
  */
 enum ieee80211_hw_flags {
@@ -3048,6 +3050,7 @@ enum ieee80211_hw_flags {
 	IEEE80211_HW_SUPPORTS_TID_CLASS_OFFLOAD,
 	IEEE80211_HW_SUPPORTS_AP_PS,
 	IEEE80211_HW_HAS_TX_QUEUE,
+	IEEE80211_HW_SUPPORT_ECM_REGISTRATION,
 
 	/* keep last, obviously */
 	NUM_IEEE80211_HW_FLAGS
diff --git a/net/mac80211/debugfs.c b/net/mac80211/debugfs.c
index 4ac4dce..2bd0388 100644
--- a/net/mac80211/debugfs.c
+++ b/net/mac80211/debugfs.c
@@ -631,6 +631,7 @@ static const char *hw_flag_names[] = {
 	FLAG(SUPPORTS_TID_CLASS_OFFLOAD),
 	FLAG(SUPPORTS_AP_PS),
 	FLAG(HAS_TX_QUEUE),
+	FLAG(SUPPORT_ECM_REGISTRATION),
 #undef FLAG
 };
 
-- 
2.34.1

