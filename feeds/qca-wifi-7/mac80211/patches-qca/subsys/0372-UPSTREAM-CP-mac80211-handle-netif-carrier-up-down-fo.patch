From 5ab56b713760cb438300b3668caa4fadbbff3b52 Mon Sep 17 00:00:00 2001
From: Yuvarani V <yuvarani@qti.qualcomm.com>
Date: Wed, 13 Aug 2025 23:34:14 +0530
Subject: [PATCH] UPSTREAM: CP: mac80211: handle netif carrier up/down for
 AP_VLAN case

The current code no longer sets link[] for VLAN interfaces.
Because of this, checking beaconing links using
ieee80211_num_beaconing_links() no longer works correctly for
VLAN interfaces.

Remove `AP_VLAN` from `ieee80211_num_beaconing_links()` type checks,
as AP VLANs do not independently beacon.

Call the netif_carrier_up() only if any valid links are
shared between the AP and its VLAN and call the netif_carrier_down()
only when no valid links are shared with the AP.

Fixes: Iac38b060c (QSDK:CP: wifi: mac80211: Backport upstream AP_VLAN
interface link handling)
I5b39fd597 (wifi: mac80211: pkg upgrade changes set 24)

Patch-dependency: None

Patch-work: None

Signed-off-by: Yuvarani V <yuvarani@qti.qualcomm.com>
---
 net/mac80211/cfg.c | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -1439,8 +1439,7 @@ static u8 ieee80211_num_beaconing_links(
 	u8 link_id, num = 0;
 
 	if (sdata->vif.type != NL80211_IFTYPE_AP &&
-	    sdata->vif.type != NL80211_IFTYPE_P2P_GO &&
-	    sdata->vif.type != NL80211_IFTYPE_AP_VLAN)
+	    sdata->vif.type != NL80211_IFTYPE_P2P_GO)
 		return num;
 
 	if (!sdata->vif.valid_links)
@@ -1740,7 +1739,7 @@ static int ieee80211_start_ap(struct wip
 		netif_carrier_on(dev);
 
 	list_for_each_entry(vlan, &sdata->u.ap.vlans, u.vlan.list) {
-		if (ieee80211_num_beaconing_links(vlan) <= 1)
+		if (sdata->vif.valid_links & (vlan->vif.valid_links | BIT(link_id)))
 			netif_carrier_on(vlan->dev);
 	}
 
@@ -1910,7 +1909,7 @@ static int ieee80211_stop_ap(struct wiph
 
 	/* turn off carrier for this interface and dependent VLANs */
 	list_for_each_entry(vlan, &sdata->u.ap.vlans, u.vlan.list) {
-		if (ieee80211_num_beaconing_links(vlan) < 1)
+		if (!(sdata->vif.valid_links & (vlan->vif.valid_links & ~BIT(link_id))))
 			netif_carrier_off(vlan->dev);
 	}
 
