From 006242415b71a76577e6942e53a9216a260cabc5 Mon Sep 17 00:00:00 2001
From: Shwetha G K <kshwetha@qti.qualcomm.com>
Date: Wed, 13 Aug 2025 10:58:06 +0530
Subject: [PATCH 1/2] UPSTREAM:PROTOCOL: wifi: nl80211: Add changes to start
 advertised ttlm during start ap

Extend cfg80211_ap_settings to accept the advertised ttlm parameters from
userspace application & populate same with corressponding NL attributes
during start_ap.

Dynamic link addition to an already existing MLD with its own advertised
ttlm needs the ttlm to be re-applied on the new link getting added to the
MLD. This is needed to make sure the new link does not beacon if its marked
as disabled in ttlm config OR to make sure the new link includes ttlm
element in its beacon if its marked as enabled in ttlm config.

Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
---
 include/net/cfg80211.h |  2 ++
 net/wireless/nl80211.c | 10 ++++++++++
 2 files changed, 12 insertions(+)

diff --git a/include/net/cfg80211.h b/include/net/cfg80211.h
index 27aa6cd..4f7e8ea 100644
--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -1786,6 +1786,7 @@ struct cfg80211_ttlm_params {
  * @beacon_tx_mode: Beacon Tx Mode setting
  * @ml_max_rec_links_valid: Indicates valid ML Max recommended links
  * @ml_max_rec_links: ML Max recommended links
+ * @ttlm_params: tid-to-link mapping parameters
  */
 struct cfg80211_ap_settings {
 	struct cfg80211_chan_def chandef;
@@ -1826,6 +1827,7 @@ struct cfg80211_ap_settings {
 	bool ml_max_rec_links_valid;
 	u8 ml_max_rec_links;
 	enum nl80211_regulatory_power_modes he_6ghz_power_type;
+	struct cfg80211_ttlm_params ttlm_params;
 };
 
 
diff --git a/net/wireless/nl80211.c b/net/wireless/nl80211.c
index b324954..423a12c 100644
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -7472,6 +7472,16 @@ static int nl80211_start_ap(struct sk_buff *skb, struct genl_info *info)
 		params->ml_max_rec_links_valid = true;
 	}
 
+	/* parse ttlm nl attributes and populate ap params */
+	if (info->attrs[NL80211_ATTR_ADVERTISED_TTLM] &&
+	    wiphy_ext_feature_isset(&rdev->wiphy,
+				    NL80211_EXT_FEATURE_BEACON_ADVERTISED_TTLM_OFFLOAD)) {
+		params->ttlm_params.type = TTLM_CMD_TYPE_ADVERTISED;
+		err = nl80211_parse_adv_ttlm_params(info, &params->ttlm_params);
+		if (err)
+			goto out;
+	}
+
 	/* FIXME: validate MLO/link-id against driver capabilities */
 
 	err = rdev_start_ap(rdev, dev, params);
-- 
