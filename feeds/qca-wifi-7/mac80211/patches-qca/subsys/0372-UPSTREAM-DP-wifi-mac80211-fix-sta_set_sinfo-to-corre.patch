From 9eb96da362818ef955dfb02c7d2d3035831c1b05 Mon Sep 17 00:00:00 2001
From: Sarika Sharma <sarishar@qti.qualcomm.com>
Date: Wed, 13 Aug 2025 22:19:48 +0530
Subject: [PATCH] UPSTREAM:DP: wifi: mac80211: fix sta_set_sinfo() to correctly
 iterate over valid_links

Currently in sta_set_sinfo(), when sinfo->valid_links is initially 0
and sta->sta.valid_links contains bits not set for link_id = 0, then
loop for_each_valid_link(sinfo, link_id) will only execute for
link_id = 0 and terminates, since sinfo->valid_links remains 0.
As a result, link-level station info is not populated for any link,
and only MLD-level information is reported to user-space.

To fix this, sinfo->valid_links is now initialized with
sta->sta.valid_links before the loop. During iteration, invalid links
are masked out to ensure only valid link information is reported.

Fixes: I316b5ff8418 ("UPSTREAM:DP: wifi:cfg80211/mac80211: add support to handle per link statistics of multi-link station")
Patch-dependency: None
Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
---
 net/mac80211/sta_info.c | 10 +++++++---
 1 file changed, 7 insertions(+), 3 deletions(-)

diff --git a/net/mac80211/sta_info.c b/net/mac80211/sta_info.c
index b8297c9..92e0de5 100644
--- a/net/mac80211/sta_info.c
+++ b/net/mac80211/sta_info.c
@@ -3238,6 +3238,10 @@ void sta_set_sinfo(struct sta_info *sta, struct station_info *sinfo,
 		struct ieee80211_link_data *link;
 		struct link_sta_info *link_sta;
 
+		/* currently assigning all valid links to sinfo in order
+		 * to iterate over all possible links
+		 */
+		sinfo->valid_links = sta->sta.valid_links;
 		ether_addr_copy(sinfo->mld_addr, sta->addr);
 		for_each_valid_link(sinfo, link_id) {
 			link_sta = wiphy_dereference(sta->local->hw.wiphy,
@@ -3245,10 +3249,10 @@ void sta_set_sinfo(struct sta_info *sta, struct station_info *sinfo,
 			link = wiphy_dereference(sdata->local->hw.wiphy,
 						 sdata->link[link_id]);
 
-			if (!link_sta || !sinfo->links[link_id] || !link)
+			if (!link_sta || !sinfo->links[link_id] || !link) {
+				sinfo->valid_links &= ~BIT(link_id);
 				continue;
-
-			sinfo->valid_links = sta->sta.valid_links;
+			}
 			sta_set_link_sinfo(sta, sinfo->links[link_id],
 					   link, tidstats);
 		}
