From 5414fc4e642383f008d9732d6686643c35df7f44 Mon Sep 17 00:00:00 2001
From: Yuvarani V <yuvarani@qti.qualcomm.com>
Date: Mon, 23 Jun 2025 15:03:04 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL wifi: mac80211: Cancel CSA/CCA in ML
 Reconfig work in STA

Currently, when a channel switch with block tx set and
ML reconfigure link removal is triggered on same link with
less tbtt which results in the link to be removed first.
This scenario leads to tx to be blocked - ping fails.
This happens because block_tx is set during
CSA, and the vif_queues are stopped during the channel switch.

Since the link is removed before the channel switch completes,
block_tx should be unset before removing the link.

To fix this issue, wake up the queues and allow them to continue
transmitting data before removing the link.
Also, unset the CSA and CCA flags before removing the link.

Patch-dependency: ML Reconfiguration Link Removal

Patch-work: None

Signed-off-by: Yuvarani V <yuvarani@qti.qualcomm.com>
Signed-off-by: Manish Dharanenthiran <mdharane@qti.qualcomm.com>
---
 net/mac80211/mlme.c | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -6546,6 +6546,8 @@ static void ieee80211_ml_reconf_work(str
 	struct sta_info *sta;
 	struct ieee80211_local *local = sdata->local;
 	u16 new_valid_links, new_active_links, new_dormant_links, link_id;
+	struct ieee80211_bss_conf *link_conf;
+	struct ieee80211_link_data *link;
 	int ret;
 
 	if (!sdata->u.mgd.removed_links)
@@ -6592,6 +6594,22 @@ static void ieee80211_ml_reconf_work(str
 		}
 	}
 
+	/* Set the active flag to false and wake up queues if blocked on
+	 * the removed link
+	 */
+	for_each_set_bit(link_id, &sdata->u.mgd.removed_links,
+			 IEEE80211_MLD_MAX_NUM_LINKS) {
+		link = wiphy_dereference(wiphy, sdata->link[link_id]);
+		link_conf = link->conf;
+
+		link_conf->csa_active = false;
+		link_conf->color_change_active = false;
+		if (link->csa_block_tx) {
+			ieee80211_vif_unblock_queues_csa(sdata);
+			link->csa_block_tx = false;
+		}
+	}
+
 	new_dormant_links = sdata->vif.dormant_links & ~sdata->u.mgd.removed_links;
 
 	ret = ieee80211_vif_set_links(sdata, new_valid_links,
