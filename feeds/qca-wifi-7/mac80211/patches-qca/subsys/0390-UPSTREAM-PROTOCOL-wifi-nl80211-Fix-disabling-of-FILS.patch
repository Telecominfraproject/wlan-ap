From f1ffe4ce911ea9067e30786ffc672c7a217f21c6 Mon Sep 17 00:00:00 2001
From: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
Date: Mon, 22 Sep 2025 12:41:39 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi:nl80211: Fix disabling of FILS/UBPR

Currently, when FILS max interval or UBPR interval is set to zero to
disable FILS or UBPR, the feature is not disabled. This is because
the parsing logic fails to indicate that there is an update for the
feature.

Fix the issue by setting the update flag to true, when FILS
max interval or UBPR interval is zero.

Signed-off-by: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
---
 net/wireless/nl80211.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/net/wireless/nl80211.c b/net/wireless/nl80211.c
index 80d52a0..cbccb4e 100644
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -6889,8 +6889,10 @@ static int nl80211_parse_fils_discovery(struct cfg80211_registered_device *rdev,
 
 	fd->max_interval = nla_get_u32(tb[NL80211_FILS_DISCOVERY_ATTR_INT_MAX]);
 
-	if (!fd->max_interval)
+	if (!fd->max_interval) {
+		fd->update = true;
 		return 0;
+	}
 
 
 	if (!tb[NL80211_FILS_DISCOVERY_ATTR_INT_MIN] ||
@@ -6931,8 +6933,10 @@ nl80211_parse_unsol_bcast_probe_resp(struct cfg80211_registered_device *rdev,
 
 	presp->interval = nla_get_u32(tb[NL80211_UNSOL_BCAST_PROBE_RESP_ATTR_INT]);
 
-	if (!presp->interval)
+	if (!presp->interval) {
+		presp->update = true;
 		return 0;
+	}
 
 	if (!tb[NL80211_UNSOL_BCAST_PROBE_RESP_ATTR_INT] ||
 	    !tb[NL80211_UNSOL_BCAST_PROBE_RESP_ATTR_TMPL])
-- 
2.34.1

