From 4943527b8148e8d2d6fa8cd63e4fce34113b16d5 Mon Sep 17 00:00:00 2001
From: Abishek Ganapathy <abishekg@qti.qualcomm.com>
Date: Sat, 19 Jul 2025 02:03:51 +0530
Subject: [PATCH] UPSTREAM:CP: wifi: mac80211: Handle non-assoc link
connection failure

With present code, when there is a failure in non-assoc link connection,
vdev delete is invoked directly without invoking vdev down and vdev stop
which results in a FW assert. This is due to the valid_links bitmap not
being updated for the non-assoc link before invoking
ieee80211_sta_remove_link API resulting in change_sta_links API to be
skipped from being invoked.

Resolve this issue by invoking ieee80211_sta_activate_link API before
checking the status of the links, which in failure case would later call
ieee80211_sta_remove_link API.

Signed-off-by: Abishek Ganapathy <abishekg@qti.qualcomm.com>
---
 net/mac80211/mlme.c | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/net/mac80211/mlme.c b/net/mac80211/mlme.c
index b730443..fd10f75 100644
--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -5968,17 +5968,17 @@ static bool ieee80211_assoc_success(struct ieee80211_sub_if_data *sdata,
 						 &changed[link_id]))
 			goto out_err;
 
-		if (assoc_data->link[link_id].status != WLAN_STATUS_SUCCESS) {
-			valid_links &= ~BIT(link_id);
-			ieee80211_sta_remove_link(sta, link_id, true);
-			continue;
-		}
-
 		if (link_id != assoc_data->assoc_link_id) {
 			err = ieee80211_sta_activate_link(sta, link_id);
 			if (err)
 				goto out_err;
 		}
+
+		if (assoc_data->link[link_id].status != WLAN_STATUS_SUCCESS) {
+			valid_links &= ~BIT(link_id);
+			ieee80211_sta_remove_link(sta, link_id, true);
+			continue;
+		}
 	}
 
 	/* links might have changed due to rejected ones, set them again */

