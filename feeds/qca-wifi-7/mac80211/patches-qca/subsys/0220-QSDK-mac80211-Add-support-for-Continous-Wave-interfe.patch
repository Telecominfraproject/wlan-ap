+ *	using %NL80211_ATTR_INTERFERENCE_TYPE.
  * @NL80211_CMD_MAX: highest used command number
  * @__NL80211_CMD_AFTER_LAST: internal use
  */
@@ -1621,9 +1624,14 @@ enum nl80211_commands {
 
