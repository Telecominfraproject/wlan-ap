From 9bb32e029c581258011b62603dd5b7b3e92020e1 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:20 +0530
Subject: [PATCH] mac80211: wifi SSR mode MLO HW restart

Implement proper reconfiguration for interfaces that are
doing MLO, in order to be able to recover from HW restart
correctly.

Signed-off-by: Sathishkumar Muruganandam <quic_murugana@quicinc.com>
Signed-off-by: Harish Rachakonda <quic_rachakon@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/key.c  | 2 ++
 net/mac80211/main.c | 1 +
 net/mac80211/util.c | 1 +
 3 files changed, 4 insertions(+)

diff --git a/net/mac80211/key.c b/net/mac80211/key.c
index b156762..7ada4dc 100644
--- a/net/mac80211/key.c
+++ b/net/mac80211/key.c
@@ -986,6 +986,8 @@ void ieee80211_reenable_keys(struct ieee80211_sub_if_data *sdata)
 		list_for_each_entry(key, &sdata->key_list, list) {
 			increment_tailroom_need_count(sdata);
 			ieee80211_key_enable_hw_accel(key);
+
+			msleep(40);
 		}
 	}
 }
diff --git a/net/mac80211/main.c b/net/mac80211/main.c
index b68d886..74fa78e 100644
--- a/net/mac80211/main.c
+++ b/net/mac80211/main.c
@@ -337,6 +337,7 @@ EXPORT_SYMBOL(ieee80211_emulate_switch_vif_chanctx);
 
 #define BSS_CHANGED_VIF_CFG_FLAGS (BSS_CHANGED_ASSOC |\
 				   BSS_CHANGED_IDLE |\
+				   BSS_CHANGED_PS |\
 				   BSS_CHANGED_IBSS |\
 				   BSS_CHANGED_ARP_FILTER |\
 				   BSS_CHANGED_SSID |\
diff --git a/net/mac80211/util.c b/net/mac80211/util.c
index cd588d4..a5f758e 100644
--- a/net/mac80211/util.c
+++ b/net/mac80211/util.c
@@ -1892,6 +1892,7 @@ static void ieee80211_reconfig_stations(struct ieee80211_sub_if_data *sdata)
 		     state < sta->sta_state; state++)
 			WARN_ON(drv_sta_state(local, sta->sdata, sta, state,
 					      state + 1));
+		msleep(40);
 	}
 }
 
