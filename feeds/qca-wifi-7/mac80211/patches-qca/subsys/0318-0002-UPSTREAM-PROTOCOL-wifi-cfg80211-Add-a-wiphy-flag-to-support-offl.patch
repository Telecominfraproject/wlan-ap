From 7d9cd8ec2a1d9dbd31eb4902a7420b9c3beb9317 Mon Sep 17 00:00:00 2001
From: Shwetha G K <kshwetha@qti.qualcomm.com>
Date: Mon, 23 Jun 2025 15:24:26 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: cfg80211: Add an ext feature flag to support offload
 mode of TTLM

Add an extended feature flag
NL80211_EXT_FEATURE_BEACON_ADVERTISED_TTLM_OFFLOAD to advertise the
support to offload advertisement of TTLM in beacons.

Interested driver modules to set this feature flag and handle the TTLM
as part of ieee80211_vif_cfg_change_notify.

This feature flag can be used to offload TTLM handling from mac80211 to the
driver, providing vendors with greater flexibility. The current mac80211
implementation forcibly disables or removes a link if it is not included
in the TTLM value, marking it as dormant or suspended—behavior that may
not align with all vendor requirements.

Ex: When negotiated mapping is heterogeneous (each TID can map to a
different link set), disabling the links in upper layer won't help
in distributing the traffic. There can be a chance that all links
are enabled but are distributed among TIDs in both UL and DL direction.

Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 include/net/cfg80211.h | 3 +++
 1 file changed, 3 insertions(+)

--- a/include/uapi/linux/nl80211.h
+++ b/include/uapi/linux/nl80211.h
@@ -6930,6 +6930,9 @@ enum nl80211_feature_flags {
  *       mode where channel selection after AFC response will be done
  *       by the application layers.
  *
+ * @NL80211_EXT_FEATURE_BEACON_ADVERTISED_TTLM_OFFLOAD: Driver supports offload
+ *	of advertisement of TTLM in beacon
+ *
  * @NUM_NL80211_EXT_FEATURES: number of extended features.
  * @MAX_NL80211_EXT_FEATURES: highest extended feature index.
  */
@@ -7013,6 +7016,7 @@ enum nl80211_ext_feature_index {
 	NL80211_EXT_FEATURE_ERP,
 	NL80211_EXT_FEATURE_TARGET_AND_HOST_AFC_SUPPORT,
 	NL80211_EXT_FEATURE_RETAIL_AFC_SUPPORT,
+	NL80211_EXT_FEATURE_BEACON_ADVERTISED_TTLM_OFFLOAD,
 
 	/* add new features before the definition below */
 	NUM_NL80211_EXT_FEATURES,
