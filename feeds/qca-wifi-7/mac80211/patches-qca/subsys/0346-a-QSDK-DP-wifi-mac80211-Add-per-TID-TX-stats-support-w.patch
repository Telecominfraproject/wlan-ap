 #undef DEF
 };
 
+enum _tx_pkt_type {
+	TX_ETH_PKT,
+	TX_NWIFI_PKT,
+	TX_MONITOR_PKT,
+};
+
+enum tx_drop_reasons {
+	TX_DROP_SKB_ALLOC_FAIL,
+	TX_DROP_SKB_QUEUE_FULL,
+	TX_DROP_SKB_SANITY_CHECK_FAIL,
+	TX_DROP_SKB_RESIZE_FAIL,
+	TX_DROP_TX_SKB_FIXUP_FAIL,
+	TX_DROP_NOT_ASSOC_STA,
+	TX_DROP_KEY_FAIL,
+	TX_DROP_STA_MAX_BUFFER,
+	TX_DROP_SDATA_STATE,
+	TX_DROP_UNAUTHORIZED_STA,
+	TX_DROP_QUEUE_PURGE,
+	TX_DROP_MISC,
+	TX_DROP_BAD_CHANCTX_CONF,
+	TX_DROP_BAD_LINK_CONF,
+	TX_DROP_UNKNOWN_VIF_TYPE,
+	TX_DROP_UNAUTH_PORT,
+	TX_DROP_BAD_LINK_ID,
+	TX_DROP_HW_CHECK_FAIL,
+	TX_DROP_RA_STA_FAIL,
+	TX_DROP_WEP,
+	TX_DROP_REASON_MAX
+};
+
+static inline void ieee80211_tx_drop_stats(struct ieee80211_sub_if_data *sdata,
+					   u8 tid, u32 reason);
 #define RX_RES_IS_UNUSABLE(result)	\
 	(((__force u32)(result) & SKB_DROP_REASON_SUBSYS_MASK) == ___RX_DROP_UNUSABLE)
 
