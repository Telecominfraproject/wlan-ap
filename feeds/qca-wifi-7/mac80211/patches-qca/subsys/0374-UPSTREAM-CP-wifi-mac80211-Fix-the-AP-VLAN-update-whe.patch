From 3b24d72d8d57f3655c19d67672ccf9bdaec5003a Mon Sep 17 00:00:00 2001
From: Amith A <amitajit@qti.qualcomm.com>
Date: Tue, 26 Aug 2025 14:07:29 +0530
Subject: [PATCH] UPSTREAM:CP: wifi: mac80211: Fix the AP-VLAN update when
 netdev is reused

Currently whenever an AP-VLAN netdev is reused we are trying to use the
sta->valid_links bmap to fetch the mac address from vlansdata's
vif->link_conf[link_id] and update it in wdev->link[link_id].bssid
but in some cases where the previous APVLAN interfaces sdata's
vif.valid_links is not same as current STA associated we will end
up accessing link that dosent exist.

To fix this update the links first so that AP-VLAN links are updated as per
the STA valid_links and later copy the mac address to avoid such mismatch.

Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 net/mac80211/cfg.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/net/mac80211/cfg.c b/net/mac80211/cfg.c
index 56b1ffa..777fbb8 100644
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -2580,22 +2580,22 @@ static int ieee80211_change_station(struct wiphy *wiphy,
 				u16 new_links = master->vif.valid_links &
 						sta->sta.valid_links;
 
+				wdev->valid_links = new_links;
+
+				ieee80211_vif_set_links(vlansdata, new_links, 0);
+
 				for_each_set_bit(link_id, &master_iter,
 						 IEEE80211_MLD_MAX_NUM_LINKS) {
 					if (!(sta->sta.valid_links & BIT(link_id))) {
 						memset(wdev->links[link_id].addr,
 						       0, ETH_ALEN);
-						wdev->valid_links &= ~BIT(link_id);
 					}
 					else {
 						memcpy(wdev->links[link_id].addr,
 						       vlansdata->vif.link_conf[link_id]->bssid,
 							ETH_ALEN);
-						wdev->valid_links |= BIT(link_id);
 					}
 				}
-
-				ieee80211_vif_set_links(vlansdata, new_links, 0);
 			}
 		}
 
