From 341d3f97f44ae129d914bf8c319aeb7035044038 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:25:44 +0530
Subject: [PATCH] mac80211: Add support to display EHT rx rate info in iw 
 station

Change-Id: I0e3ca7ce694e7054b72d33eb834027a7986d2219

Signed-off-by: Balamurugan Mahalingam <quic_bmahalin@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 include/net/mac80211.h  | 1 +
 net/mac80211/sta_info.c | 1 +
 2 files changed, 2 insertions(+)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index 133a82d..99df181 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -1640,6 +1640,7 @@ enum mac80211_rx_encoding {
 	RX_ENC_HT,
 	RX_ENC_VHT,
 	RX_ENC_HE,
+	RX_ENC_S1G,
 	RX_ENC_EHT,
 };
 
diff --git a/net/mac80211/sta_info.c b/net/mac80211/sta_info.c
index dfae3f6..1bb3e98 100644
--- a/net/mac80211/sta_info.c
+++ b/net/mac80211/sta_info.c
@@ -2505,6 +2505,7 @@ static void sta_stats_decode_rate(struct ieee80211_local *local, u32 rate,
 		rinfo->nss = STA_STATS_GET(EHT_NSS, rate);
 		rinfo->eht_gi = STA_STATS_GET(EHT_GI, rate);
 		rinfo->eht_ru_alloc = STA_STATS_GET(EHT_RU, rate);
+		rinfo->he_dcm = STA_STATS_GET(HE_DCM, rate);
 		break;
 	}
 }
-- 
