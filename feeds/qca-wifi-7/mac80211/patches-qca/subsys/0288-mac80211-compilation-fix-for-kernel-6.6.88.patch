From a4bd294eb3c687f876dfde779d9e1ae85536fd0d Mon Sep 17 00:00:00 2001
From: Kaviarasu Sanjeevi <kaviaras@qti.qualcomm.com>
Date: Tue, 17 Jun 2025 15:42:56 +0530
Subject: [PATCH] mac80211: compilation fix for kernel 6.6.88

Add compilation fix for kernel minor version upgrade
from 6.6.47 to 6.6.88 for genlmsg_multicast_allns
function by removing the kernel flag for kernel
version greater than or equal to 6.6.59

Signed-off-by: Kaviarasu Sanjeevi <kaviaras@qti.qualcomm.com>
---
 net/wireless/nl80211.c | 10 ++++++++++
 1 file changed, 10 insertions(+)

--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -19089,7 +19089,7 @@ void nl80211_common_reg_change_event(enu
 		goto nla_put_failure;
 
 	genlmsg_end(msg, hdr);
-#if LINUX_VERSION_IS_GEQ(6,11,0)
+#if LINUX_VERSION_IS_GEQ(6,6,59)
 	genlmsg_multicast_allns(&nl80211_fam, msg, 0,
 				NL80211_MCGRP_REGULATORY);
 #else
@@ -19888,7 +19888,7 @@ void nl80211_send_beacon_hint_event(stru
 	nla_nest_end(msg, nl_freq);
 
 	genlmsg_end(msg, hdr);
-#if LINUX_VERSION_IS_GEQ(6,11,0)
+#if LINUX_VERSION_IS_GEQ(6,6,59)
 	genlmsg_multicast_allns(&nl80211_fam, msg, 0,
 				NL80211_MCGRP_REGULATORY);
 #else
