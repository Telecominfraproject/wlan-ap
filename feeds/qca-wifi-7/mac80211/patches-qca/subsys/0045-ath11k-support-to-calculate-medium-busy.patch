From 556f7ea635a84a34210e34169287017ee3cd9447 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:25:34 +0530
Subject: [PATCH] mac80211: athk support to calculate medium busy

Signed-off-by: Hari Chandrakanthan <haric@codeaurora.org>
Signed-off-by: Gautham Kumar Senthilkumaran <quic_gauthamk@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 include/net/mac80211.h      |  1 +
 net/mac80211/mesh_hwmp.c    | 10 ++++++----
 net/mac80211/mesh_pathtbl.c |  5 +++--
 3 files changed, 10 insertions(+), 6 deletions(-)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index ab844d5..c02292b 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -3152,6 +3152,7 @@ struct ieee80211_hw {
 	const s8 *tx_power_levels;
 	u8 max_txpwr_levels_idx;
 	u32 dbg_mask;
+	u8 medium_busy;
 };
 
 static inline bool _ieee80211_hw_check(struct ieee80211_hw *hw,
diff --git a/net/mac80211/mesh_hwmp.c b/net/mac80211/mesh_hwmp.c
index cb410fd..417900e 100644
--- a/net/mac80211/mesh_hwmp.c
+++ b/net/mac80211/mesh_hwmp.c
@@ -564,11 +564,12 @@ static u32 hwmp_route_info_get(struct ieee80211_sub_if_data *sdata,
                                 signal_avg = -ewma_signal_read(&sta->deflink.rx_stats_avg.signal);
                                 mpath_dbg(sdata, "MESH MPLMU DIRECT dst %pM next hop"
                                           " %pM metric from %d to %d ft 0x%x signal %d"
-                                          "dbm signal_avg %d dbm\n",
+                                          "dbm signal_avg %d dbm medium_busy %u\n",
                                           mpath->dst, sta->deflink.addr, mpath->metric,
                                           new_metric, action,
                                           sta->deflink.rx_stats.last_signal,
-                                          signal_avg);
+                                          signal_avg,
+                                          sta->local->hw.medium_busy);
                                 mpath_metric_change = 1;
                         }
 			mesh_path_assign_nexthop(mpath, sta);
@@ -639,11 +640,12 @@ static u32 hwmp_route_info_get(struct ieee80211_sub_if_data *sdata,
                                 signal_avg = -ewma_signal_read(&sta->deflink.rx_stats_avg.signal);
                                 mpath_dbg(sdata, "MESH MPLMU DIRECT dst %pM next hop"
                                           " %pM metric from %d to %d ft 0x%x signal %d"
-                                          "dbm signal_avg %d dbm\n",
+                                          "dbm signal_avg %d dbm medium_busy %u\n",
                                           mpath->dst, sta->deflink.addr, mpath->metric,
                                           new_metric, action,
                                           sta->deflink.rx_stats.last_signal,
-                                          signal_avg);
+                                          signal_avg,
+                                          sta->local->hw.medium_busy);
                                 mpath_metric_change = 1;
                         }
 			mesh_path_assign_nexthop(mpath, sta);
diff --git a/net/mac80211/mesh_pathtbl.c b/net/mac80211/mesh_pathtbl.c
index bb334b8..ff5c391 100644
--- a/net/mac80211/mesh_pathtbl.c
+++ b/net/mac80211/mesh_pathtbl.c
@@ -907,10 +907,11 @@ void mesh_plink_broken(struct sta_info *sta)
 	if (paths_deactivated) {
 		signal_avg = -ewma_signal_read(&sta->deflink.rx_stats_avg.signal);
 		sdata_info(sta->sdata, " MESH MPL link to %pM is broken and"
-			   " %d path deactivated signal %d dbm signal_avg %d dbm\n",
+			   " %d path deactivated signal %d dbm signal_avg %d dbm"
+			   " medium_busy : %d\n",
 			   sta->deflink.addr, paths_deactivated,
 			   sta->deflink.rx_stats.last_signal,
-			   signal_avg);
+			   signal_avg, sta->local->hw.medium_busy);
 		mesh_continuous_tx_fail_cnt(sta, NL80211_MPATH_BROKEN_NOTIFY);
 	}
 }
-- 
2.34.1

