From 4f90e486530b276333521d8fbe67559c1f6c7b25 Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Sun, 6 Jul 2025 10:33:49 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:wifi:cfg80211: Add QoS Management data
 structures

Introduce data structures and macros in cfg80211 to support
QoS Management (QM) requests from user space and provide
corresponding responses.

Define structures for QM descriptors, including TCLAS Type 4
and Type 10 classifiers, QoS attributes, and request/response
containers. These additions lay the groundwork for user space
tools (e.g., hostapd) to configure QoS parameters via cfg80211.

Patch-dependency:
0330-02-UPSTREAM-PROTOCOL-wifi-nl80211-Add-QoS-Management-cmd-and-attr.patch
Patch-work: NA
Tag: SCS

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 include/net/cfg80211.h | 259 +++++++++++++++++++++++++++++++++++++++++
 1 file changed, 259 insertions(+)

diff --git a/include/net/cfg80211.h b/include/net/cfg80211.h
index 7bdd66b..fdee220 100644
--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -4536,6 +4536,261 @@ struct cfg80211_erp_params {
 	enum cfg80211_erp_status status;
 };
 
+
+/* IP address lengths */
+#define IPV4_LEN	4
+#define IPV6_LEN	16
+
+/* QoS Management descriptor limits */
+#define QM_MAX_DESCRIPTORS_PER_PEER			10
+#define QM_MAX_DESCPRIPTORS_PER_REQUEST		4
+#define QM_MAX_TCLAS_ELEMENTS_PER_QM_DESCRIPTOR	2
+
+/* Control Info Bitfield Masks using GENMASK */
+#define QM_CTRL_INFO_DIRECTION_MASK	GENMASK(1, 0)
+#define QM_CTRL_INFO_TID_MASK		GENMASK(5, 2)
+#define QM_CTRL_INFO_UP_MASK		GENMASK(8, 6)
+#define QM_CTRL_INFO_BITMAP_MASK	GENMASK(24, 9)
+#define QM_CTRL_INFO_LINK_ID_MASK	GENMASK(28, 25)
+#define QM_CTRL_INFO_RESERVED_MASK	GENMASK(31, 29)
+
+/* MSDU Delivery Info Bitfield Masks using GENMASK */
+#define QM_MSDU_DELIVERY_INFO_RATIO_MASK		GENMASK(3, 0)
+#define QM_MSDU_DELIVERY_INFO_COUNT_EXPONENT_MASK	GENMASK(7, 4)
+
+/* Field extraction macro for ctrl_info */
+#define GET_FIELD_FROM_QM_CTRL_INFO(ctrl_info, FIELD) \
+	u32_get_bits((ctrl_info), QM_CTRL_INFO_##FIELD##_MASK)
+
+/* Field extraction macro for msdu_delivery_info */
+#define GET_FIELD_FROM_QM_MSDU_DELIVERY_INFO(msdu_delivery_info, FIELD) \
+	u8_get_bits((msdu_delivery_info), QM_MSDU_DELIVERY_INFO_##FIELD##_MASK)
+
+/**
+ * enum cfg80211_ip_version - IP protocol version identifiers
+ *
+ * This enumeration defines the supported IP versions used in
+ * cfg80211-related traffic classification and QoS management.
+ *
+ * @IP_VERSION_4: Internet Protocol version 4 (IPv4)
+ * @IP_VERSION_6: Internet Protocol version 6 (IPv6)
+ */
+enum cfg80211_ip_version {
+	IP_VERSION_4 = 4,
+	IP_VERSION_6 = 6,
+};
+
+/**
+ * enum cfg80211_qm_tclas_classifier - TCLAS classifier types
+ *
+ * Specifies the type of classifier used in Traffic Classification (TCLAS)
+ * elements for QoS Management.
+ *
+ * @TCLAS_CLASSIFIER_TYPE4: Classifier type 4 (Tuple-based classification)
+ * @TCLAS_CLASSIFIER_TYPE10: Classifier type 10 (Filter-based classification)
+ */
+enum cfg80211_qm_tclas_classifier {
+	TCLAS_CLASSIFIER_TYPE4 = 4,
+	TCLAS_CLASSIFIER_TYPE10 = 10,
+};
+
+/**
+ * struct cfg80211_qm_tclas4_params - TCLAS classifier type 4 parameters
+ *
+ * Parameters used for 5 tuple based traffic classification.
+ *
+ * @classifier_mask: Bitmask indicating which fields are used for classification
+ * @ip_ver: IP version (IPv4 or IPv6)
+ * @src_ip: Source IP address (IPv4 or IPv6)
+ * @dst_ip: Destination IP address (IPv4 or IPv6)
+ * @src_port: Source port number
+ * @dst_port: Destination port number
+ * @dscp: Differentiated Services Code Point
+ * @protocol: IP protocol number
+ * @next_header: Next header field (for IPv6)
+ * @flow_label: Flow label (for IPv6)
+ */
+struct cfg80211_qm_tclas4_params {
+	u8 classifier_mask;
+	enum cfg80211_ip_version ip_ver;
+	union {
+		u8 ipv4[IPV4_LEN];
+		u8 ipv6[IPV6_LEN];
+	} src_ip;
+	union {
+		u8 ipv4[IPV4_LEN];
+		u8 ipv6[IPV6_LEN];
+	} dst_ip;
+	u16 src_port;
+	u16 dst_port;
+	u8 dscp;
+	u8 protocol;
+	u8 next_header;
+	u8 flow_label[NL80211_TCLAS_TYPE4_FLOW_LABEL_LEN];
+};
+
+/**
+ * struct cfg80211_qm_tclas10_params - TCLAS classifier type 10 parameters
+ *
+ * Parameters used for filter-based traffic classification.
+ *
+ * @protocol_instance: Instance identifier for the protocol
+ * @protocol_number: Protocol number
+ * @filter_value: Filter value bytes
+ * @filter_mask: Filter mask bytes
+ * @filter_len: Length of the filter
+ */
+struct cfg80211_qm_tclas10_params {
+	u8 protocol_instance;
+	u8 protocol_number;
+	u8 filter_value[NL80211_TCLAS_TYPE10_MAX_FILTER_LEN];
+	u8 filter_mask[NL80211_TCLAS_TYPE10_MAX_FILTER_LEN];
+	u8 filter_len;
+};
+
+/**
+ * struct cfg80211_qm_tclas_elements - TCLAS element container
+ *
+ * Represents a single TCLAS element used in QoS Management.
+ *
+ * @up: User priority
+ * @classifier_type: Classifier type (Type 4 or 10)
+ * @tclas_elem: Union of classifier-specific parameters
+ */
+struct cfg80211_qm_tclas_elements {
+	u8 up;
+	u8 classifier_type;
+	union tclas_elem {
+		struct cfg80211_qm_tclas4_params type4_params;
+		struct cfg80211_qm_tclas10_params type10_params;
+	} tclas_elem;
+};
+
+/**
+ * struct cfg80211_qm_qos_attributes - QoS attributes for a QoS Management
+ * request
+ *
+ * Describes the QoS parameters associated with a QoS Management request.
+ *
+ * @direction: Direction of traffic (uplink/downlink)
+ * @tid: Traffic Identifier
+ * @up: User Priority
+ * @bitmap: Bitmap value
+ * @link_id: Link identifier
+ * @reserved: Reserved bits
+ * @min_service_interval: Minimum service interval in microseconds
+ * @max_service_interval: Maximum service interval in microseconds
+ * @min_data_rate: Minimum data rate in kbps
+ * @delay_bound: Delay bound value in microseconds
+ * @max_msdu_size: Maximum MSDU size in bytes
+ * @service_start_time: Service start time in microseconds
+ * @service_start_time_link_id: Link ID for service start time
+ * @mean_data_rate: Mean data rate in kbps
+ * @burst_size: Burst size in bytes
+ * @msdu_lifetime: Lifetime of MSDU in milliseconds
+ * @msdu_delivery_ratio: Delivery ratio (4 bits)
+ * @msdu_count_exponent: Count exponent (4 bits)
+ * @medium_time: Medium time in units of 32 microseconds
+ */
+struct cfg80211_qm_qos_attributes {
+	u32 direction:2,
+	    tid:4,
+	    up:3,
+	    bitmap:16,
+	    link_id:4,
+	    reserved:3;
+	u32 min_service_interval;
+	u32 max_service_interval;
+	u32 min_data_rate;
+	u32 delay_bound;
+	u16 max_msdu_size;
+	u32 service_start_time;
+	u8 service_start_time_link_id;
+	u32 mean_data_rate;
+	u32 burst_size;
+	u16 msdu_lifetime;
+	u8 msdu_delivery_ratio:4,
+	   msdu_count_exponent:4;
+	u16 medium_time;
+};
+
+/**
+ * struct cfg80211_qm_req_desc_data - QoS Management request descriptor
+ *
+ * Describes a single QoS Management request descriptor, including
+ * traffic classification and QoS parameters.
+ *
+ * @qm_id: Identifier for the QoS Management request
+ * @request_type: Type of QoS request (add, delete, modify)
+ * @priority: Priority value
+ * @num_tclas_elements: Number of TCLAS elements present
+ * @tclas: Array of TCLAS elements used for traffic classification
+ * @tclas_processing: TCLAS processing (match-all or match-any)
+ * @is_qos_present: Indicates whether QoS attributes are present
+ * @qos_attr: QoS attributes associated with the request
+ */
+
+struct cfg80211_qm_req_desc_data {
+	u8 qm_id;
+	u8 request_type;
+	u8 priority;
+	u8 num_tclas_elements;
+	struct cfg80211_qm_tclas_elements
+		tclas[QM_MAX_TCLAS_ELEMENTS_PER_QM_DESCRIPTOR];
+	u8 tclas_processing;
+	bool is_qos_present;
+	struct cfg80211_qm_qos_attributes qos_attr;
+};
+
+/**
+ * struct cfg80211_qm_req_data - QoS Management request container
+ *
+ * Represents a complete QoS Management request for a peer,
+ * including one or more descriptors and associated metadata.
+ *
+ * @peer_mac: MAC address of the peer
+ * @qm_type: Type of QoS Management (SCS, other QM types)
+ * @dialog_token: Dialog token used to identify QM request frame
+ * @num_qm_desc: Number of QoS descriptors included
+ * @qm_req_desc: Array of QoS request descriptors
+ */
+struct cfg80211_qm_req_data {
+	u8 peer_mac[ETH_ALEN];
+	u8 qm_type;
+	u8 dialog_token;
+	u8 num_qm_desc;
+	struct cfg80211_qm_req_desc_data
+			qm_req_desc[QM_MAX_DESCPRIPTORS_PER_REQUEST];
+};
+
+/**
+ * struct cfg80211_qm_resp_desc_data - QoS Management response descriptor
+ *
+ * Describes the result of processing a single QoS Management request
+ * descriptor.
+ *
+ * @qm_id: Identifier for the QoS Management request
+ * @status: Status of the response (success, failure)
+ */
+struct cfg80211_qm_resp_desc_data {
+	u8 qm_id;
+	u8 status;
+};
+
+/**
+ * struct cfg80211_qm_resp_data - QoS Management response container
+ *
+ * Represents a complete QoS Management response, typically sent in reply
+ * to a QM request, with status for each descriptor.
+ *
+ * @qm_resp_desc: Array of response descriptors corresponding to request
+ * descriptors
+ */
+struct cfg80211_qm_resp_data {
+	struct cfg80211_qm_resp_desc_data
+			qm_resp_desc[QM_MAX_DESCPRIPTORS_PER_REQUEST];
+};
+
 /**
  * struct cfg80211_ops - backend description for wireless configuration
  *
-- 
2.34.1

