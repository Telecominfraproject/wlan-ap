From 92f73c796ada7d13959a0afcaf4ff5f63e0c3ea5 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:40 +0530
Subject: [PATCH] mac80211: athk Fixing with correct arugment in function

In DECLARE_EVENT_CLASS is expecting the dynamic array as char string but
this is different in the rebased code. Adding correct arugment in the
function DECLARE_EVENT_CLASS for avoiding the compilation issue.

Signed-off-by: Gautham Kumar Senthilkumaran <quic_gauthamk@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/trace_msg.h | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/net/mac80211/trace_msg.h b/net/mac80211/trace_msg.h
index 5ac4dbf..cf9dea5 100644
--- a/net/mac80211/trace_msg.h
+++ b/net/mac80211/trace_msg.h
@@ -22,11 +22,13 @@ DECLARE_EVENT_CLASS(mac80211_msg_event,
 	TP_ARGS(vaf),
 
 	TP_STRUCT__entry(
-		__vstring(msg, vaf->fmt, vaf->va)
+		__dynamic_array(char, msg, MAX_MSG_LEN)
 	),
 
 	TP_fast_assign(
-		__assign_vstr(msg, vaf->fmt, vaf->va);
+		WARN_ON_ONCE(vsnprintf(__get_dynamic_array(msg),
+				       MAX_MSG_LEN, vaf->fmt,
+				       *vaf->va) >= MAX_MSG_LEN);
 	),
 
 	TP_printk("%s", __get_str(msg))
-- 
2.34.1

