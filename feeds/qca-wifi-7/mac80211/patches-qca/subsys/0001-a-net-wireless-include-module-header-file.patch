From 31a9aff9ddcba4d70398ba3f5e4e7f0f481929f4 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Wed, 2 Apr 2025 18:02:52 +0530
Subject: [PATCH 10/25] net: wireless: include module header file

This change include the module.h header file,
which is necessary for reg.c compilation

Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
Signed-off-by: Kaviarasu Sanjeevi <quic_kaviaras@quicinc.com>
---
 net/wireless/reg.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/net/wireless/reg.c b/net/wireless/reg.c
index 8bafc75..2c7474c 100644
--- a/net/wireless/reg.c
+++ b/net/wireless/reg.c
@@ -57,6 +57,7 @@
 #include <linux/verification.h>
 #include <linux/moduleparam.h>
 #include <linux/firmware.h>
+#include <linux/module.h>
 #include <linux/units.h>
 
 #include <net/cfg80211.h>
