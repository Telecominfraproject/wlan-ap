From 980db4828b173c663356ce3bb56058a9cab7bad0 Mon Sep 17 00:00:00 2001
From: Rajat Soni <rajson@qti.qualcomm.com>
Date: Tue, 3 Jun 2025 12:35:34 +0530
Subject: [PATCH] QSDK: CP: subsys: Fix compilation issue in debug profile

Fix compilation issue in debug profile.

Signed-off-by: Rajat Soni <rajson@qti.qualcomm.com>
---
 net/mac80211/trace.h | 2 +-
 net/wireless/trace.h | 3 ++-
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/net/mac80211/trace.h b/net/mac80211/trace.h
index ae294c5..c553e92 100644
--- a/net/mac80211/trace.h
+++ b/net/mac80211/trace.h
@@ -33,7 +33,7 @@
 			__string(vif_name, sdata->name)
 #define VIF_ASSIGN	__entry->vif_type = sdata->vif.type; __entry->sdata = sdata;	\
 			__entry->p2p = sdata->vif.p2p;					\
-			__assign_str(vif_name)
+			__assign_str(vif_name, sdata->name)
 #define VIF_PR_FMT	" vif:%s(%d%s)"
 #define VIF_PR_ARG	__get_str(vif_name), __entry->vif_type, __entry->p2p ? "/p2p" : ""
 
diff --git a/net/wireless/trace.h b/net/wireless/trace.h
index d91558f..5a67202 100644
--- a/net/wireless/trace.h
+++ b/net/wireless/trace.h
@@ -461,7 +461,7 @@ TRACE_EVENT(rdev_add_virtual_intf,
 	),
 	TP_fast_assign(
 		WIPHY_ASSIGN;
-		__assign_str(vir_intf_name);
+		__assign_str(vir_intf_name, name ? name : "<noname>");
 		__entry->type = type;
 	),
 	TP_printk(WIPHY_PR_FMT ", virtual intf name: %s, type: %d",
@@ -2457,6 +2457,7 @@ TRACE_EVENT(rdev_channel_switch,
 		__field(u8, count)
 		__dynamic_array(u16, bcn_ofs, params->n_counter_offsets_beacon)
 		__dynamic_array(u16, pres_ofs, params->n_counter_offsets_presp)
+		__field(unsigned int, link_id)
 	),
 	TP_fast_assign(
 		WIPHY_ASSIGN;
-- 
2.34.1

