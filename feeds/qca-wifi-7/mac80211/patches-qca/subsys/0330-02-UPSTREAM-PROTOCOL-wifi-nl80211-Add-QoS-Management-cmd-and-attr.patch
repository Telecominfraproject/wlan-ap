+	[NL80211_TCLAS_TYPE4_ATTR_NEXT_HEADER] = { .type = NLA_U8 },
+	[NL80211_TCLAS_TYPE4_ATTR_FLOW_LABEL] =
+		NLA_POLICY_EXACT_LEN(NL80211_TCLAS_TYPE4_FLOW_LABEL_LEN),
+};
+
+static const struct nla_policy
+nl80211_tclas_type10_policy[NL80211_TCLAS_TYPE10_ATTR_MAX + 1] = {
