+
+static const struct nla_policy
+nl80211_tclas_policy[NL80211_TCLAS_ATTR_MAX + 1] = {
+	[NL80211_TCLAS_ATTR_USER_PRIORITY] = { .type = NLA_U8 },
+	[NL80211_TCLAS_ATTR_CLASSIFIER_TYPE] = { .type = NLA_U8 },
+	[NL80211_TCLAS_ATTR_TYPE4_PARAMS] =
+			NLA_POLICY_NESTED(nl80211_tclas_type4_policy),
+	[NL80211_TCLAS_ATTR_TYPE10_PARAMS] =
+			NLA_POLICY_NESTED(nl80211_tclas_type10_policy),
+};
+
+static const struct nla_policy
