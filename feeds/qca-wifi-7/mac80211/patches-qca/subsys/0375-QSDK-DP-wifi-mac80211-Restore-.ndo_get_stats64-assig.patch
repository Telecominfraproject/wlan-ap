From e95d15aa175529a0182ce8461f57dd71d9bb1ba1 Mon Sep 17 00:00:00 2001
From: Kenvish Butani <kbutani@qti.qualcomm.com>
Date: Mon, 18 Aug 2025 20:24:01 +0530
Subject: [PATCH] QSDK:DP:wifi:mac80211: Restore .ndo_get_stats64 assignment
 due to missing support

Undo commit c018411d3555 ("wifi: mac80211: Remove generic .ndo_get_stats64")
which removed the assignment of .ndo_get_stats64 to dev_fetch_sw_netstats().

mac80211 sets NETDEV_PCPU_STAT_TSTATS to indicate use of pcpu_sw_netstats.
When set, the driver must provide stats via dev_fetch_sw_netstats(), either
directly or via fallback in dev_get_tstats64().

The removal assumed fallback support from an upstream patch [1], which is
not present in the kernel currently in use. This breaks stats reporting.

Restore .ndo_get_stats64 for accurate stats until kernel support is present.

Remove this change once the kernel includes patch [1].

[1] https://patchew.org/linux/20240228113125.3473685-1-leitao@debian.org/

Patch-dependency: None

Signed-off-by: Kenvish Butani <kbutani@qti.qualcomm.com>
---
 net/mac80211/iface.c | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/net/mac80211/iface.c b/net/mac80211/iface.c
index 8a64a78..5bce387 100644
--- a/net/mac80211/iface.c
+++ b/net/mac80211/iface.c
@@ -892,6 +892,12 @@ static void ieee80211_uninit(struct net_device *dev)
 	ieee80211_teardown_sdata(sdata);
 }
 
+static void
+ieee80211_get_stats64(struct net_device *dev, struct rtnl_link_stats64 *stats)
+{
+	dev_fetch_sw_netstats(stats, dev->tstats);
+}
+
 static int ieee80211_change_mtu(struct net_device *dev, int mtu)
 {
 	struct ieee80211_sub_if_data *sdata = IEEE80211_DEV_TO_SUB_IF(dev);
@@ -936,6 +942,7 @@ static const struct net_device_ops ieee80211_dataif_ops = {
 	.ndo_change_mtu		= ieee80211_change_mtu,
 	.ndo_select_queue       = ieee80211_netdev_select_queue,
 	.ndo_init               = ieee80211_init,
+	.ndo_get_stats64	= ieee80211_get_stats64,
 };
 
 #if LINUX_VERSION_IS_GEQ(5,2,0)
@@ -986,6 +993,7 @@ static const struct net_device_ops ieee80211_monitorif_ops = {
 	.ndo_set_rx_mode	= ieee80211_set_multicast_list,
 	.ndo_set_mac_address 	= ieee80211_change_mac,
 	.ndo_select_queue	= ieee80211_monitor_select_queue,
+	.ndo_get_stats64	= ieee80211_get_stats64,
 };
 
 static const struct net_device_ops ieee80211_dataif_8023_ops = {
@@ -999,6 +1007,7 @@ static const struct net_device_ops ieee80211_dataif_8023_ops = {
 	.ndo_change_mtu		= ieee80211_change_mtu,
 	.ndo_select_queue       = ieee80211_netdev_select_queue,
 	.ndo_init               = ieee80211_init,
+	.ndo_get_stats64	= ieee80211_get_stats64,
 };
 
 static bool ieee80211_iftype_supports_hdr_offload(enum nl80211_iftype iftype)
