From 1274ca0878b65e144ea95f831d63ddcc84e755f6 Mon Sep 17 00:00:00 2001
From: Shwetha G K <kshwetha@qti.qualcomm.com>
Date: Tue, 5 Aug 2025 22:22:47 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:wifi:mac80211: Enhance TTLM processing
 to support offload mode in client

When the expected duration expires in TTLM, the current implementation
enables the links back by setting the active and dormant links in host
using ieee80211_vif_set_links() API. The firmware is not notified about
the changes in the state of links. This results in firmware and host not
being in sync about the state of the links. This might lead to firmware
crashes. To address this, firmware's capability of managing links
internally by mapping the TIDs to link can be utilized. After expected
duration expires, there will be no more TTLM IE observed in the beacons.
When no TTLM IE is found in the beacons after the expected duration,
send the WMI_MLO_AP_VDEV_TID_TO_LINK_MAP_CMDID with default mapping where
all TIDs are mapped to all links. This results in enabling the links back
and host-firmware are ensured to be in sync.

Fixes: None
Patch-work: None
Feature: TTLM
Path-dependency:
0318-0002-UPSTREAM-PROTOCOL-wifi-cfg80211-Add-a-wiphy-flag-to-support-offl.patch

Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
---
 net/mac80211/mlme.c | 57 ++++++++++++++++++++++++++++++---------------
 1 file changed, 38 insertions(+), 19 deletions(-)

--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -6848,6 +6848,12 @@ out:
 	return ret;
 }
 
+static bool ieee80211_is_ttlm_offload_supported(struct wiphy *wiphy)
+{
+	return wiphy_ext_feature_isset(wiphy,
+		NL80211_EXT_FEATURE_BEACON_ADVERTISED_TTLM_OFFLOAD);
+}
+
 static void ieee80211_tid_to_link_map_work(struct wiphy *wiphy,
 					   struct wiphy_work *work)
 {
@@ -6855,17 +6861,22 @@ static void ieee80211_tid_to_link_map_wo
 	struct ieee80211_sub_if_data *sdata =
 		container_of(work, struct ieee80211_sub_if_data,
 			     u.mgd.ttlm_work.work);
+	bool offload_mode = ieee80211_is_ttlm_offload_supported(wiphy);
 
-	new_active_links = sdata->vif.adv_ttlm.u.mgd.ttlm_info.map &
-		sdata->vif.valid_links;
-	new_dormant_links = ~sdata->vif.adv_ttlm.u.mgd.ttlm_info.map &
-		sdata->vif.valid_links;
-
-	ieee80211_vif_set_links(sdata, sdata->vif.valid_links, 0);
-	if (ieee80211_ttlm_set_links(sdata, new_active_links, new_dormant_links,
-				     0))
-		return;
-
+	if (!offload_mode) {
+		new_active_links = sdata->vif.adv_ttlm.u.mgd.ttlm_info.map &
+			sdata->vif.valid_links;
+		new_dormant_links = ~sdata->vif.adv_ttlm.u.mgd.ttlm_info.map &
+			sdata->vif.valid_links;
+
+		ieee80211_vif_set_links(sdata, sdata->vif.valid_links, 0);
+		if (ieee80211_ttlm_set_links(sdata, new_active_links,
+					     new_dormant_links,
+					     0))
+			return;
+	} else {
+		ieee80211_vif_cfg_change_notify(sdata, BSS_CHANGED_MLD_ADV_TTLM);
+	}
 	sdata->vif.adv_ttlm.u.mgd.ttlm_info.active = true;
 	sdata->vif.adv_ttlm.u.mgd.ttlm_info.switch_time = 0;
 }
@@ -6959,12 +6970,34 @@ ieee80211_parse_adv_t2l(struct ieee80211
 	return 0;
 }
 
+static void ieee80211_set_default_mapping(struct ieee80211_sub_if_data *sdata)
+{
+	int ret;
+	bool offload_mode = ieee80211_is_ttlm_offload_supported(sdata->local->hw.wiphy);
+
+	if (!offload_mode) {
+		ret = ieee80211_vif_set_links(sdata,
+					      sdata->vif.valid_links,
+					      0);
+		if (ret) {
+			sdata_info(sdata, "Failed setting valid/dormant links\n");
+			return;
+		}
+		ieee80211_vif_cfg_change_notify(sdata,
+						BSS_CHANGED_MLD_VALID_LINKS);
+	} else {
+		sdata->vif.adv_ttlm.u.mgd.ttlm_info.map =
+			sdata->vif.valid_links;
+		ieee80211_vif_cfg_change_notify(sdata,
+						BSS_CHANGED_MLD_ADV_TTLM);
+	}
+}
+
 static void ieee80211_process_adv_ttlm(struct ieee80211_sub_if_data *sdata,
-					  struct ieee802_11_elems *elems,
-					  u64 beacon_ts)
+				       struct ieee802_11_elems *elems,
+				       u64 beacon_ts)
 {
 	u8 i;
-	int ret;
 
 	if (!ieee80211_vif_is_mld(&sdata->vif))
 		return;
@@ -6980,15 +7013,7 @@ static void ieee80211_process_adv_ttlm(s
 			/* if no TID-to-link element, set to default mapping in
 			 * which all TIDs are mapped to all setup links
 			 */
-			ret = ieee80211_vif_set_links(sdata,
-						      sdata->vif.valid_links,
-						      0);
-			if (ret) {
-				sdata_info(sdata, "Failed setting valid/dormant links\n");
-				return;
-			}
-			ieee80211_vif_cfg_change_notify(sdata,
-							BSS_CHANGED_MLD_VALID_LINKS);
+			ieee80211_set_default_mapping(sdata);
 		}
 		memset(&sdata->vif.adv_ttlm.u.mgd.ttlm_info, 0,
 		       sizeof(sdata->vif.adv_ttlm.u.mgd.ttlm_info));
