From 2a780d17170686bc246495ed2b02d20c1dd09808 Mon Sep 17 00:00:00 2001
From: Priyadarshnee Srinivasan <priys@qti.qualcomm.com>
Date: Fri, 11 Jul 2025 21:26:35 +0530
Subject: [PATCH] UPSTREAM: PROTOCOL: wifi: mac80211: Support parsing and
 handling of additional TPE PSD/EIRP elements for composite APs

Update ieee80211_parse_tpe() and ieee80211_clear_tpe() to handle
parsing and clearing of additional TPE PSD and EIRP elements
received from the root AP.
Extend ieee80211_valid_tpe_element() to recognize additional
PSD and EIRP elements as valid TPE element types.
Add 'additional_max_reg_client' and 'additional_psd_reg_client' arrays
to the ieee80211_parsed_tpe structure to store parsed composite AP
PSD and EIRP values for default and subordinate client types.
Update ieee80211_rearrange_tpe() to rearrange additional TPE PSD
values according to the channel bonding order.
Modify ieee80211_config_bw() to dynamically parse updated HEOP
information from the root AP.
If the power type indicated in the root AP’s HEOP differs
from the STA’s current power type (link->conf->power_type), trigger
a callback to the ath12k driver to send updated TPE/TPC information
for the new power mode.

These changes ensure proper handling of composite AP power
information and dynamic updates to TPE parsing and transmission logic.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency: None
Signed-off-by: Priyadarshnee Srinivasan <priys@qti.qualcomm.com>
---
 include/linux/ieee80211.h |  2 ++
 include/net/mac80211.h    |  2 ++
 net/mac80211/mlme.c       | 53 ++++++++++++++++++++++++++-------------
 net/mac80211/parse.c      | 13 ++++++++++
 net/mac80211/util.c       | 11 ++++++++
 5 files changed, 64 insertions(+), 17 deletions(-)

Index: backports-20250213-6.6.47-9a0dddfb30f1/include/linux/ieee80211.h
===================================================================
--- backports-20250213-6.6.47-9a0dddfb30f1.orig/include/linux/ieee80211.h
+++ backports-20250213-6.6.47-9a0dddfb30f1/include/linux/ieee80211.h
@@ -2955,6 +2955,7 @@ static inline bool ieee80211_valid_tpe_e
 	switch (interpret) {
 	case IEEE80211_TPE_LOCAL_EIRP:
 	case IEEE80211_TPE_REG_CLIENT_EIRP:
+	case IEEE80211_TPE_ADDITIONAL_REG_CLIENT_EIRP:
 		if (count > 3)
 			return false;
 
@@ -2969,6 +2970,7 @@ static inline bool ieee80211_valid_tpe_e
 		return true;
 	case IEEE80211_TPE_LOCAL_EIRP_PSD:
 	case IEEE80211_TPE_REG_CLIENT_EIRP_PSD:
+	case IEEE80211_TPE_ADDITIONAL_REG_CLIENT_EIRP_PSD:
 		if (count > 4)
 			return false;
 
Index: backports-20250213-6.6.47-9a0dddfb30f1/include/net/mac80211.h
===================================================================
--- backports-20250213-6.6.47-9a0dddfb30f1.orig/include/net/mac80211.h
+++ backports-20250213-6.6.47-9a0dddfb30f1/include/net/mac80211.h
@@ -613,6 +613,8 @@ struct ieee80211_parsed_tpe_psd {
 struct ieee80211_parsed_tpe {
 	struct ieee80211_parsed_tpe_eirp max_local[2], max_reg_client[2];
 	struct ieee80211_parsed_tpe_psd psd_local[2], psd_reg_client[2];
+	struct ieee80211_parsed_tpe_eirp additional_max_reg_client[2];
+	struct ieee80211_parsed_tpe_psd additional_psd_reg_client[2];
 };
 
 /**
Index: backports-20250213-6.6.47-9a0dddfb30f1/net/mac80211/mlme.c
===================================================================
--- backports-20250213-6.6.47-9a0dddfb30f1.orig/net/mac80211/mlme.c
+++ backports-20250213-6.6.47-9a0dddfb30f1/net/mac80211/mlme.c
@@ -904,6 +904,7 @@ static void ieee80211_rearrange_tpe(stru
 
 		ieee80211_rearrange_tpe_psd(&tpe->psd_local[i], ap, used);
 		ieee80211_rearrange_tpe_psd(&tpe->psd_reg_client[i], ap, used);
+		ieee80211_rearrange_tpe_psd(&tpe->additional_psd_reg_client[i], ap, used);
 
 		/* limit this to the widths we actually need */
 		needed_pwr_count = ieee80211_chandef_num_widths(used);
@@ -911,6 +912,8 @@ static void ieee80211_rearrange_tpe(stru
 			tpe->max_local[i].count = needed_pwr_count;
 		if (needed_pwr_count < tpe->max_reg_client[i].count)
 			tpe->max_reg_client[i].count = needed_pwr_count;
+		if (needed_pwr_count < tpe->additional_max_reg_client[i].count)
+			tpe->additional_max_reg_client[i].count = needed_pwr_count;
 	}
 }
 
@@ -1145,6 +1148,23 @@ free:
 	return ERR_PTR(ret);
 }
 
+static enum ieee80211_ap_reg_power
+ieee80211_ap_power_type(u8 control)
+{
+	switch (u8_get_bits(control, IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO)) {
+	case IEEE80211_6GHZ_CTRL_REG_LPI_AP:
+	case IEEE80211_6GHZ_CTRL_REG_INDOOR_LPI_AP:
+		return IEEE80211_REG_LPI_AP;
+	case IEEE80211_6GHZ_CTRL_REG_SP_AP:
+	case IEEE80211_6GHZ_CTRL_REG_INDOOR_SP_AP:
+		return IEEE80211_REG_SP_AP;
+	case IEEE80211_6GHZ_CTRL_REG_VLP_AP:
+		return IEEE80211_REG_VLP_AP;
+	default:
+		return IEEE80211_REG_UNSET_AP;
+	}
+}
+
 static int ieee80211_config_bw(struct ieee80211_link_data *link,
 			       struct ieee802_11_elems *elems,
 			       bool update, u64 *changed,
@@ -1211,12 +1231,27 @@ static int ieee80211_config_bw(struct ie
 
 	if (ap_chandef.chan->band == NL80211_BAND_6GHZ &&
 	    link->u.mgd.conn.mode >= IEEE80211_CONN_MODE_HE) {
+		const struct ieee80211_he_6ghz_oper *he_6ghz_oper;
+
 		ieee80211_rearrange_tpe(&elems->tpe, &ap_chandef,
 					&chanreq.oper);
 		if (memcmp(&link->conf->tpe, &elems->tpe, sizeof(elems->tpe))) {
 			link->conf->tpe = elems->tpe;
 			*changed |= BSS_CHANGED_TPE;
 		}
+		he_6ghz_oper = ieee80211_he_6ghz_oper(elems->he_operation);
+		if (he_6ghz_oper) {
+			enum ieee80211_ap_reg_power ap_power_type =
+				ieee80211_ap_power_type(he_6ghz_oper->control);
+			if (ap_power_type != link->conf->power_type) {
+				link_info(link,
+					  "AP changed power type, old type: %d,  new type is %d\n",
+					  link->conf->power_type,
+					  ap_power_type);
+				link->conf->power_type = ap_power_type;
+				*changed |= BSS_CHANGED_6GHZ_POWER_MODE;
+			}
+		}
 	}
 
 	if (ieee80211_chanreq_identical(&chanreq, &link->conf->chanreq))
@@ -5825,22 +5860,6 @@ ieee80211_determine_our_sta_mode_assoc(s
 			       conn->bw_limit, tmp.bw_limit);
 }
 
-static enum ieee80211_ap_reg_power
-ieee80211_ap_power_type(u8 control)
-{
-	switch (u8_get_bits(control, IEEE80211_HE_6GHZ_OPER_CTRL_REG_INFO)) {
-	case IEEE80211_6GHZ_CTRL_REG_LPI_AP:
-	case IEEE80211_6GHZ_CTRL_REG_INDOOR_LPI_AP:
-		return IEEE80211_REG_LPI_AP;
-	case IEEE80211_6GHZ_CTRL_REG_SP_AP:
-	case IEEE80211_6GHZ_CTRL_REG_INDOOR_SP_AP:
-		return IEEE80211_REG_SP_AP;
-	case IEEE80211_6GHZ_CTRL_REG_VLP_AP:
-		return IEEE80211_REG_VLP_AP;
-	default:
-		return IEEE80211_REG_UNSET_AP;
-	}
-}
 
 static int ieee80211_prep_channel(struct ieee80211_sub_if_data *sdata,
 				  struct ieee80211_link_data *link,
