From e1773224ccbc7c1fde75afad0e40f1f65bd98b26 Mon Sep 17 00:00:00 2001
From: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
Date: Wed, 10 Sep 2025 14:47:04 +0530
Subject: [PATCH] UPSTREAM:DP:wifi:mac80211: Update sdata info after queue stop
 condition check

In certain scenario where a multicast(ARP) packet received in mesh,
will try transferring through other interfaces(AP, AP_VLAN) in the bridge
along with mesh forwarding. There will be queue stop sequence during mesh
forwarding, due to that packets from other interfaces are stored in
pending queue until wake queue from mesh formwarding path.

Currently vif is updated with AP's vif before transferring packet
to driver as well as before storing into pending queue.
When trying to transfer the packet from pending queue with the
AP's vif it fails to fetch sta object for the multicast frame.

Driver has the logic to send 4-address multicast frame with
the help of sta object. Since the sta object not available
the packet transferred in 3-address and leading to ping failure.
To address this issue update AP's vif info after pending queue
checks in __ieee80211_tx_8023().

Patch dependency: None

Signed-off-by: Tamizh Chelvam Raja <tamizhr@qti.qualcomm.com>
---
 net/mac80211/tx.c | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/net/mac80211/tx.c b/net/mac80211/tx.c
index 19374d9..8c0a1ef 100644
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -4970,6 +4970,13 @@ static bool __ieee80211_tx_8023(struct ieee80211_sub_if_data *sdata,
 
 	spin_unlock_irqrestore(queue_stop_reason_lock, flags);
 
+	if (sdata->vif.type == NL80211_IFTYPE_AP_VLAN &&
+		!ieee80211_hw_check(&local->hw, SUPPORTS_NSS_OFFLOAD)) {
+		sdata = container_of(sdata->bss,
+				     struct ieee80211_sub_if_data, u.ap);
+	}
+
+	info->control.vif = &sdata->vif;
 	if (sta && sta->uploaded)
 		pubsta = &sta->sta;
 
@@ -5098,11 +5105,6 @@ static void ieee80211_8023_xmit(struct ieee80211_sub_if_data *sdata,
 	info->hw_queue = sdata->vif.hw_queue[queue];
 	info->tid = tid;
 
-	if (sdata->vif.type == NL80211_IFTYPE_AP_VLAN &&
-		!ieee80211_hw_check(&local->hw, SUPPORTS_NSS_OFFLOAD))
-		sdata = container_of(sdata->bss,
-				     struct ieee80211_sub_if_data, u.ap);
-
 	info->flags |= IEEE80211_TX_CTL_HW_80211_ENCAP;
 	info->control.vif = &sdata->vif;
 	if (local->enable_tx_latency_stats)
-- 
