From 953d731e260d5c5accf43166e32571263411606d Mon Sep 17 00:00:00 2001
From: Logapriya P <logapriy@qti.qualcomm.com>
Date: Tue, 8 Jul 2025 10:55:20 +0530
Subject: [PATCH] UPSTREAM:DP: mac80211: fix rx bitrate missing issue

In current implementation of RX stats, the Rx bitrate is not getting
updated for Repeater nodes in mesh mode.

Modify the implementation to update the RX rate and verify the changes.

Patch Dependency: None

Signed-off-by: Logapriya P <logapriy@qti.qualcomm.com>
---
 net/mac80211/rx.c | 14 +++++++++-----
 1 file changed, 9 insertions(+), 5 deletions(-)

diff --git a/net/mac80211/rx.c b/net/mac80211/rx.c
index 27ed0ec..6f37987 100644
--- a/net/mac80211/rx.c
+++ b/net/mac80211/rx.c
@@ -5252,6 +5252,7 @@ static bool ieee80211_invoke_fast_rx(struct ieee80211_rx_data *rx,
 	} addrs __aligned(2);
 	struct ieee80211_sta_rx_stats *stats;
 	u8 da_offs = fast_rx->da_offs, sa_offs = fast_rx->sa_offs;
+	u32 last_rate;
 
 	/* for parallel-rx, we need to have DUP_VALIDATED, otherwise we write
 	 * to a common data structure; drivers can implement that per queue
@@ -5354,9 +5355,17 @@ static bool ieee80211_invoke_fast_rx(struct ieee80211_rx_data *rx,
 	/* push the addresses in front */
 	memcpy(skb_push(skb, sizeof(addrs)), &addrs, sizeof(addrs));
 
+	if (fast_rx->uses_rss)
+		stats = this_cpu_ptr(rx->link_sta->pcpu_rx_stats);
+	else
+		stats = &rx->link_sta->rx_stats;
+
+	last_rate = sta_stats_encode_rate(status);
 	res = ieee80211_rx_mesh_data(rx->sdata, rx->sta, rx->skb);
 	switch (res) {
 	case RX_QUEUED:
+		stats->last_rx = jiffies;
+		stats->last_rate = last_rate;
 		return true;
 	case RX_CONTINUE:
 		break;
@@ -5370,11 +5379,6 @@ static bool ieee80211_invoke_fast_rx(struct ieee80211_rx_data *rx,
  drop:
 	dev_kfree_skb(skb);
 
-	if (fast_rx->uses_rss)
-		stats = this_cpu_ptr(rx->link_sta->pcpu_rx_stats);
-	else
-		stats = &rx->link_sta->rx_stats;
-
 	stats->dropped++;
 	return true;
 }
