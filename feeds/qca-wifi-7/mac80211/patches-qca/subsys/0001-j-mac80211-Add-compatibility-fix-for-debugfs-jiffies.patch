From 7f1630748d00f4e930f145543b8adc290073e8a1 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Wed, 2 Apr 2025 20:23:09 +0530
Subject: [PATCH 19/25] mac80211: Add compatibility fix for debugfs jiffies

Add compatibility fix for renaming the debugfs netdev entries

Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
Signed-off-by: Kaviarasu Sanjeevi <quic_kaviaras@quicinc.com>
---
 net/mac80211/debugfs_netdev.c | 4 ++++
 net/wireless/core.c           | 5 ++++-
 2 files changed, 8 insertions(+), 1 deletion(-)

--- a/net/mac80211/debugfs_netdev.c
+++ b/net/mac80211/debugfs_netdev.c
@@ -1034,6 +1034,9 @@ void ieee80211_debugfs_remove_netdev(str
 
 void ieee80211_debugfs_rename_netdev(struct ieee80211_sub_if_data *sdata)
 {
+#if LINUX_VERSION_IS_GEQ(6,14,0)
+	debugfs_change_name(sdata->vif.debugfs_dir, "netdev:%s", sdata->name);
+#else
 	struct dentry *dir;
 	char buf[10 + IFNAMSIZ];
 
@@ -1042,8 +1045,9 @@ void ieee80211_debugfs_rename_netdev(str
 	if (IS_ERR_OR_NULL(dir))
 		return;
 
-	sprintf(buf, "netdev:%s", sdata->name);
+	snprintf(buf, sizeof(buf), "netdev:%s", sdata->name);
 	debugfs_rename(dir->d_parent, dir, dir->d_parent, buf);
+#endif
 }
 
 void ieee80211_debugfs_recreate_netdev(struct ieee80211_sub_if_data *sdata,
--- a/net/wireless/core.c
+++ b/net/wireless/core.c
@@ -143,11 +143,14 @@ int cfg80211_dev_rename(struct cfg80211_
 	if (result)
 		return result;
 
+#if LINUX_VERSION_IS_GEQ(6,14,0)
+	debugfs_change_name(rdev->wiphy.debugfsdir, "%s", newname);
+#else
 	if (!IS_ERR_OR_NULL(rdev->wiphy.debugfsdir))
 		debugfs_rename(rdev->wiphy.debugfsdir->d_parent,
 			       rdev->wiphy.debugfsdir,
 			       rdev->wiphy.debugfsdir->d_parent, newname);
-
+#endif
 	nl80211_notify_wiphy(rdev, NL80211_CMD_NEW_WIPHY);
 
 	return 0;
