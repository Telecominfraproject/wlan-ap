From d3ed3ce4a50436d48951be89b43fe3ae521214e8 Mon Sep 17 00:00:00 2001
From: Sarika Sharma <sarishar@qti.qualcomm.com>
Date: Sat, 28 Jun 2025 19:35:23 +0530
Subject: [PATCH wireless-next v2 2/2] wifi: cfg80211: Nullify freed pointers
 in cfg80211_sinfo_release_content()

Currently, cfg80211_sinfo_release_content() frees dynamically
allocated memory but does not reset the associated pointers.
This can lead to potential use-after-free issues if those pointers
are accessed later in the code path.

Hence to prevent against accidental dereferencing of dangling pointers,
explicitly set the freed pointers to NULL.

Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
---
 include/net/cfg80211.h | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/include/net/cfg80211.h b/include/net/cfg80211.h
index 4a092da3a9de..8b2b61efa92d 100644
--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -8612,11 +8612,14 @@ int cfg80211_link_sinfo_alloc_tid_stats(struct link_station_info *link_sinfo,
 static inline void cfg80211_sinfo_release_content(struct station_info *sinfo)
 {
 	kfree(sinfo->pertid);
+	sinfo->pertid = NULL;
 
 	for (int link_id = 0; link_id < ARRAY_SIZE(sinfo->links); link_id++) {
 		if (sinfo->links[link_id]) {
 			kfree(sinfo->links[link_id]->pertid);
+			sinfo->links[link_id]->pertid = NULL;
 			kfree(sinfo->links[link_id]);
+			sinfo->links[link_id] = NULL;
 		}
 	}
 }
