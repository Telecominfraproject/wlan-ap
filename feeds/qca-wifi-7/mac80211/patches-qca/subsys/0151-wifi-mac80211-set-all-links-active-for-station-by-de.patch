From c5ab993b5313eed13c2c427e625269e2353e3515 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:26 +0530
Subject: [PATCH] mac80211: wifi set all links active for station by default - 
 2d37217f46b17cd7bf993e1f2d850a844a1c01b5 wifi: mac80211: isolate  driver from
  inactive links

Signed-off-by: Wen Gong <quic_wgong@quicinc.com>
Signed-off-by: Amutha Ravikumar <quic_aravikum@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/link.c | 10 +---------
 1 file changed, 1 insertion(+), 9 deletions(-)

diff --git a/net/mac80211/link.c b/net/mac80211/link.c
index 5e7dad3..71911a3 100644
--- a/net/mac80211/link.c
+++ b/net/mac80211/link.c
@@ -281,17 +281,9 @@ static void ieee80211_set_vif_links_bitmaps(struct ieee80211_sub_if_data *sdata,
 	switch (sdata->vif.type) {
 	case NL80211_IFTYPE_AP:
 	case NL80211_IFTYPE_AP_VLAN:
-		/* in an AP all links are always active */
-		sdata->vif.active_links = valid_links;
-
-		/* AP links are not expected to be disabled */
-		WARN_ON(dormant_links);
-		break;
 	case NL80211_IFTYPE_STATION:
-		if (sdata->vif.active_links)
-			break;
+		/* in an AP and STA all links are always active */
 		sdata->vif.active_links = valid_links & ~dormant_links;
-		WARN_ON(hweight16(sdata->vif.active_links) > 1);
 		break;
 	default:
 		WARN_ON(1);
-- 
2.34.1

