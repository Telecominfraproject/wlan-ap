From fed438ea1f1bb2d6dadb68efe343ac3ece1aa505 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:54 +0530
Subject: [PATCH] mac80211: KW wifi fix NULL pointer access, Klocwork issue

Currently we are dereferencing dev pointer without a NULL
check.

Fix this issue by adding a NULL check.

Patch-dependency: none
Patch-work: none
Fixes: 4b7afb52c8e2 (mac80211: reorganize code to remove a forward declaration)
Note: ath.git commit id is mentioned in the Fixes tag

Signed-off-by: Monika Korada <quic_koramoni@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/iface.c | 12 ++++++++----
 1 file changed, 8 insertions(+), 4 deletions(-)

diff --git a/net/mac80211/iface.c b/net/mac80211/iface.c
index c32b5c4..3315e34 100644
--- a/net/mac80211/iface.c
+++ b/net/mac80211/iface.c
@@ -1464,7 +1464,8 @@ int ieee80211_do_open(struct wireless_dev *wdev, bool coming_up)
 				ieee80211_link_vlan_copy_chanctx(&sdata->deflink);
 			}
 
-			netif_carrier_on(dev);
+			if (dev)
+				netif_carrier_on(dev);
 
 			if (ieee80211_hw_check(&local->hw, SUPPORTS_NSS_OFFLOAD)) {
 				ieee80211_set_sdata_offload_flags(sdata);
@@ -1475,7 +1476,8 @@ int ieee80211_do_open(struct wireless_dev *wdev, bool coming_up)
 
 			ieee80211_set_vif_encap_ops(sdata);
 		} else {
-			netif_carrier_off(dev);
+			if (dev)
+				netif_carrier_off(dev);
 		}
 		break;
 	case NL80211_IFTYPE_MONITOR:
@@ -1507,7 +1509,8 @@ int ieee80211_do_open(struct wireless_dev *wdev, bool coming_up)
 		ieee80211_recalc_offload(local);
 		ieee80211_recalc_idle(local);
 
-		netif_carrier_on(dev);
+		if (dev)
+			netif_carrier_on(dev);
 		break;
 	default:
 		if (coming_up) {
@@ -1551,7 +1554,8 @@ int ieee80211_do_open(struct wireless_dev *wdev, bool coming_up)
 		case NL80211_IFTYPE_AP:
 		case NL80211_IFTYPE_MESH_POINT:
 		case NL80211_IFTYPE_OCB:
-			netif_carrier_off(dev);
+			if (dev)
+				netif_carrier_off(dev);
 			break;
 		case NL80211_IFTYPE_P2P_DEVICE:
 		case NL80211_IFTYPE_NAN:
-- 
2.34.1

