From 61637c4913fe61bd4775f899e6229e22590d4c66 Mon Sep 17 00:00:00 2001
From: Amith A <amitajit@qti.qualcomm.com>
Date: Mon, 23 Jun 2025 22:14:02 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: wifi: mac80211: Add support for TTLM expected duration
 updates per link

Introduce ieee80211_ttlm_info_expec_dur_update() to allow drivers to update
the expected duration for TTLM per link. This includes:

- Adding the new API in mac80211.h and implementing it in cfg.c.
- Updating ieee80211_rx_h_userspace_mgmt() to set the TTLM expected
  duration update flag when applicable.
- Ensuring the updated duration is stored in the corresponding wireless_dev
  link structure and flagged for user-space notification.

Signed-off-by: Amith A <amitajit@qti.qualcomm.com>
Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
---
 include/net/mac80211.h |  9 +++++++++
 net/mac80211/cfg.c     | 14 ++++++++++++++
 net/mac80211/rx.c      |  4 ++++
 3 files changed, 27 insertions(+)

--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -8412,4 +8412,13 @@ ieee80211_advertised_ttlm_evt_notify(str
 				     enum advertised_ttlm_status_type status,
 				     unsigned int link_id);
 
+/** ieee80211_ttlm_info_expec_dur_update - Update expected duration for each
+ * link for which the update was received.
+ * @vif: BSS in which the expected duration is to be update
+ * @link_id: Link id of the link for which expected duration is to be updated
+ * @expec_dur: current expected duration value from driver
+ */
+void ieee80211_ttlm_info_expec_dur_update(struct ieee80211_vif *vif,
+					  unsigned int link_id, u32 expec_dur);
+
 #endif /* MAC80211_H */
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -226,6 +226,20 @@ void ieee80211_advertised_ttlm_evt_notif
 				     link->link_id);
 }
 
+void ieee80211_ttlm_info_expec_dur_update(struct ieee80211_vif *vif,
+					  unsigned int link_id, u32 expec_dur)
+{
+	struct wireless_dev *wdev = ieee80211_vif_to_wdev(vif);
+
+	if (!wdev->valid_links ||
+	    WARN_ON(link_id >= IEEE80211_MLD_MAX_NUM_LINKS))
+		return;
+
+	wdev->links[link_id].ttlm_expec_dur = expec_dur;
+	wdev->ttlm_expec_dur_update_flag = true;
+}
+EXPORT_SYMBOL(ieee80211_ttlm_info_expec_dur_update);
+
 static struct wireless_dev *ieee80211_add_iface(struct wiphy *wiphy,
 						const char *name,
 						unsigned char name_assign_type,
--- a/net/mac80211/rx.c
+++ b/net/mac80211/rx.c
@@ -4138,6 +4138,7 @@ ieee80211_rx_h_userspace_mgmt(struct iee
 		.have_link_id = rx->link_id >= 0,
 		.critical_update = 0,
 		.link_removal_update = 0,
+		.ttlm_expec_dur_update = 0,
 	};
 
 	stype = mgmt->frame_control & cpu_to_le16(IEEE80211_FCTL_STYPE);
@@ -4149,6 +4150,9 @@ ieee80211_rx_h_userspace_mgmt(struct iee
 
 		if (wdev->link_removal_flag)
 			info.link_removal_update = 1;
+
+		if (wdev->ttlm_expec_dur_update_flag)
+			info.ttlm_expec_dur_update = 1;
 	}
 	/* skip known-bad action frames and return them in the next handler */
 	if (status->rx_flags & IEEE80211_RX_MALFORMED_ACTION_FRM)
