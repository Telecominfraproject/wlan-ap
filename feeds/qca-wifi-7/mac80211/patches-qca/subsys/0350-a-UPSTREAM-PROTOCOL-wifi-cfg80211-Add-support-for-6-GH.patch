From ea884371f1a0e08b5964c924cc3ae0dfe408011f Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Tue, 5 Aug 2025 16:09:40 +0530
Subject: [PATCH 1/2] UPSTREAM:PROTOCOL: wifi: cfg80211: Add support for 6 GHz
 client type

Add a new field to the regulatory domain structure to indicate
the client types supported for the regulatory domain. This is
a bitmask field that can indicate the various supported client
types.

The underlying hardware may indicate the supported client types
for the regulatory domain as part of the new regd field.

Add support in cfg80211 for determining the client type for 6 GHz
based on the regulatory domain and the 6 GHz AP power mode.
Note that the subordinate client is valid only for LPI power mode.
Use regular client for all other power modes.

Use regular client type for 6 GHz APs if the regulatory domain
does not indicate the supported client types.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
subsys/0048-cfg80211-mac80211-regulatory-awgn-and-6g-channel-cha.patch
subsys/0340-UPSTREAM-PROTOCOL-cfg80211-mac80211-Store-6-GHz-powe.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 include/net/cfg80211.h   | 20 ++++++++++++++++++++
 include/net/regulatory.h |  1 +
 net/wireless/util.c      | 26 ++++++++++++++++++++++++++
 3 files changed, 47 insertions(+)

diff --git a/include/net/cfg80211.h b/include/net/cfg80211.h
index 83d7636f8081..7ca7d9aba390 100644
--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -7569,6 +7569,26 @@ ieee80211_frequency_to_channel(int freq)
 	return ieee80211_freq_khz_to_channel(MHZ_TO_KHZ(freq));
 }
 
+/**
+ * ieee80211_get_6ghz_client_type - get the 6 GHz client type for the given
+ *                                  6 GHz AP power mode
+ *
+ * @wiphy: pointer to the struct wiphy
+ * @ap_mode: the 6 GHz AP power mode to get the client type for
+ *
+ * If the underlying hardware has advertised preferential support for
+ * a subordinate client type for the regulatory domain, this function
+ * will return the subordinate client type for an LPI AP.
+ *
+ * For other AP power modes, or if the hardware has not advertised
+ * preferential support for any 6 GHz client type, this function will
+ * return the regular client type as default.
+ *
+ * Return: The 6 GHz client type for the given AP power mode.
+ */
+u8 ieee80211_get_6ghz_client_type(struct wiphy *wiphy,
+				  enum nl80211_regulatory_power_modes ap_mode);
+
 /**
  * ieee80211_get_valid_6ghz_power_mode - get a valid 6 Ghz power mode
  *
diff --git a/include/net/regulatory.h b/include/net/regulatory.h
index 1907cb270c16..0134ef5c2893 100644
--- a/include/net/regulatory.h
+++ b/include/net/regulatory.h
@@ -219,6 +219,7 @@ struct ieee80211_regdomain {
 	struct rcu_head rcu_head;
 	u32 n_reg_rules;
 	char alpha2[3];
+	u8 supp_cli_bitmap_6ghz;
 	enum nl80211_dfs_regions dfs_region;
 	struct ieee80211_reg_rule reg_rules[];
 };
diff --git a/net/wireless/util.c b/net/wireless/util.c
index 90880adb64dc..efcb62db001d 100644
--- a/net/wireless/util.c
+++ b/net/wireless/util.c
@@ -159,6 +159,32 @@ int ieee80211_freq_khz_to_channel(u32 freq)
 }
 EXPORT_SYMBOL(ieee80211_freq_khz_to_channel);
 
+u8 ieee80211_get_6ghz_client_type(struct wiphy *wiphy,
+				  enum nl80211_regulatory_power_modes ap_mode)
+{
+	const struct ieee80211_regdomain *regd;
+	u8 supp_6ghz_client_types;
+
+	rcu_read_lock();
+	regd = rcu_dereference(wiphy->regd);
+	if (!regd) {
+		rcu_read_unlock();
+		return NL80211_REG_REGULAR_CLIENT;
+	}
+	supp_6ghz_client_types = regd->supp_cli_bitmap_6ghz;
+	rcu_read_unlock();
+
+	/* Currently, subordinate clients are supported only for LPI APs.
+	 * If the AP is not LPI, then use REGULAR_CLIENT.
+	 */
+	if (ap_mode == NL80211_REG_AP_LPI &&
+	    (supp_6ghz_client_types & BIT(NL80211_REG_SUBORDINATE_CLIENT)))
+		return NL80211_REG_SUBORDINATE_CLIENT;
+
+	return NL80211_REG_REGULAR_CLIENT;
+}
+EXPORT_SYMBOL(ieee80211_get_6ghz_client_type);
+
 enum nl80211_regulatory_power_modes
 ieee80211_get_valid_6ghz_power_mode(struct wiphy *wiphy, u32 freq)
 {
