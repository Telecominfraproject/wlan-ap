From ee9eab3c8de67115ec9a9dfde0cfd1e01a3cc175 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Wed, 28 May 2025 11:46:27 +0530
Subject: [PATCH 1/2] mac80211: UPSTREAMPROTOCOL Define EPCS response Action frame

As per the IEEE P802.11be/D7.0 spec - 9.6.38.6 EPCS Priority Access Enable
Response frame format, define the EPCS response action frame to send from
non-AP MLD to AP MLD.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 include/linux/ieee80211.h | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/include/linux/ieee80211.h b/include/linux/ieee80211.h
index d06e1d139e10..b7263aa3b8dc 100644
--- a/include/linux/ieee80211.h
+++ b/include/linux/ieee80211.h
@@ -1547,6 +1547,11 @@ struct ieee80211_mgmt {
 					u8 action_code;
 					u8 variable[];
 				} __packed epcs;
+				struct {
+					u8 action_code;
+					u8 dialog_token;
+					__le16 status_code;
+				} __packed epcs_resp;
 			} u;
 		} __packed action;
 		DECLARE_FLEX_ARRAY(u8, body); /* Generic frame body */
-- 
