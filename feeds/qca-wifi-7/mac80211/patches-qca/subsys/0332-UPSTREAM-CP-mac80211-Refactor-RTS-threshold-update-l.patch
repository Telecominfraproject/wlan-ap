From 8c448467a658281c55149a98baff23c055de64ca Mon Sep 17 00:00:00 2001
From: Paulson Raja L <lraja@qti.qualcomm.com>
Date: Mon, 14 Jul 2025 22:27:30 +0530
Subject: [PATCH] UPSTREAM:CP: mac80211: Refactor RTS threshold update logic
 and optimize locking

The old RTS threshold value does not need to be stored in a separate
variable, as it remains unchanged if drv_set_rts_threshold fails. This
change refactors the code to remove the redundant backup of the old value
and ensures more optimal use of RCU locking.

Patch-dependency:
	0011-wifi-mac80211-Set-RTS-threshold-on-per-radio-basis.patch
	0112-mac80211-add-rts-threshold-support-for-MLO.patch

Signed-off-by: Paulson Raja L <lraja@qti.qualcomm.com>
---
 net/mac80211/cfg.c | 37 +++++++++++++------------------------
 1 file changed, 13 insertions(+), 24 deletions(-)

--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -3370,7 +3370,7 @@ static int ieee80211_set_wiphy_params(st
 {
 	struct ieee80211_local *local = wiphy_priv(wiphy);
 	struct ieee80211_sub_if_data *sdata;
-	int err, old_rts_threshold = 0;
+	int err = 0;
 	struct ieee80211_bss_conf *link_conf = NULL;
 
 
@@ -3401,34 +3401,24 @@ static int ieee80211_set_wiphy_params(st
 		u32 rts_threshold;
 
 		sdata = IEEE80211_WDEV_TO_SUB_IF(wdev);
-		rcu_read_lock();
-		link_conf = rcu_dereference(sdata->vif.link_conf[link_id]);
-		if (!link_conf) {
-			rcu_read_unlock();
-			return -ENOLINK;
-		}
-		old_rts_threshold = link_conf->rts_threshold;
-		if (radio_id >= wiphy->n_radio)
-			rts_threshold = wiphy->rts_threshold;
-		else
-			rts_threshold = wiphy->radio_cfg[radio_id].rts_threshold;
-
 		if (changed & WIPHY_PARAM_RTS_THRESHOLD) {
-			link_conf->rts_threshold = rts_threshold;
-			rcu_read_unlock();
+			if (radio_id >= wiphy->n_radio)
+				rts_threshold = wiphy->rts_threshold;
+			else
+				rts_threshold = wiphy->radio_cfg[radio_id].rts_threshold;
+
 			err = drv_set_rts_threshold(local, radio_id, rts_threshold, sdata, link_id);
-			if (err) {
-				rcu_read_lock();
-				link_conf = rcu_dereference(sdata->vif.link_conf[link_id]);
-				link_conf->rts_threshold = old_rts_threshold;
-				rcu_read_unlock();
+			if (err)
 				return err;
+			rcu_read_lock();
+			link_conf = rcu_dereference(sdata->vif.link_conf[link_id]);
+			if (!link_conf) {
+				rcu_read_unlock();
+				return -ENOLINK;
 			}
+			link_conf->rts_threshold = rts_threshold;
+			rcu_read_unlock();
 		}
-		rcu_read_unlock();
-
-		if (err)
-			return err;
 	} else {
 		if (changed & WIPHY_PARAM_RTS_THRESHOLD && !wiphy->num_hw) {
 			err = drv_set_rts_threshold(local, radio_id, wiphy->rts_threshold, NULL, link_id);
