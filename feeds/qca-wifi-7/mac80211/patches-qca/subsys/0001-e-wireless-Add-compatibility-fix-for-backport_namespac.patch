From 12cdf41eb7c158ca6350d12b8de04377a4b077e6 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Wed, 2 Apr 2025 18:30:23 +0530
Subject: [PATCH 14/25] wireless: Add compatibility fix for backport_namespace

Add compatibility fix for ifferent kernel versions
by adjusting the function parameters accordingly
for wiphy_namespace

Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
Signed-off-by: Kaviarasu Sanjeevi <quic_kaviaras@quicinc.com>
---
 net/wireless/sysfs.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/net/wireless/sysfs.c b/net/wireless/sysfs.c
index 62f2661..4f855bf 100644
--- a/net/wireless/sysfs.c
+++ b/net/wireless/sysfs.c
@@ -154,7 +154,11 @@ static SIMPLE_DEV_PM_OPS(wiphy_pm_ops, wiphy_suspend, wiphy_resume);
 #define WIPHY_PM_OPS NULL
 #endif
 
+#if LINUX_VERSION_IS_GEQ(6,2,0)
 static const void *wiphy_namespace(const struct device *d)
+#else
+static const void *wiphy_namespace(struct device *d)
+#endif
 {
 	struct wiphy *wiphy = container_of(d, struct wiphy, dev);
 
--
