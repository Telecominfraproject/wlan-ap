From f45be460d2c61e9003540b636718e7b90ae36bf7 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:23 +0530
Subject: [PATCH] mac80211: QSDK athk Add debug logs for the CR and CR

Patch-dependency: None

Signed-off-by: Karthikeyan Periyasamy <periyasa@codeaurora.org>
Signed-off-by: Gautham Kumar Senthilkumaran <quic_gauthamk@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/cfg.c  | 1 +
 net/mac80211/rx.c   | 8 ++++++--
 net/mac80211/scan.c | 9 ++++++++-
 net/mac80211/tx.c   | 1 +
 4 files changed, 16 insertions(+), 3 deletions(-)

diff --git a/net/mac80211/cfg.c b/net/mac80211/cfg.c
index eff2596..fd31046 100644
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -4692,6 +4692,7 @@ int ieee80211_attach_ack_skb(struct ieee80211_local *local, struct sk_buff *skb,
 
 	if (id < 0) {
 		kfree_skb(ack_skb);
+		printk(KERN_ERR "attach ack fail %d\n", id);
 		return -ENOMEM;
 	}
 
diff --git a/net/mac80211/rx.c b/net/mac80211/rx.c
index b531049..3908464 100644
--- a/net/mac80211/rx.c
+++ b/net/mac80211/rx.c
@@ -5816,12 +5816,16 @@ void ieee80211_rx_list(struct ieee80211_hw *hw, struct ieee80211_sta *pubsta,
 		}
 	}
 
-	if (WARN_ON(status->band >= NUM_NL80211_BANDS))
+	if (WARN_ON(status->band >= NUM_NL80211_BANDS)) {
+		printk("invalid status band %d freq %d\n", status->band, status->freq);
 		goto drop;
+	}
 
 	sband = local->hw.wiphy->bands[status->band];
-	if (WARN_ON(!sband))
+	if (WARN_ON(!sband)) {
+		printk("NULL sband status band %d freq %d\n", status->band, status->freq);
 		goto drop;
+	}
 
 	/*
 	 * If we're suspending, it is possible although not too likely
diff --git a/net/mac80211/scan.c b/net/mac80211/scan.c
index d6108c7..62c54f8 100644
--- a/net/mac80211/scan.c
+++ b/net/mac80211/scan.c
@@ -680,9 +680,16 @@ static void ieee80211_scan_state_send_probe(struct ieee80211_local *local,
 	int i;
 	struct ieee80211_sub_if_data *sdata;
 	struct cfg80211_scan_request *scan_req;
-	enum nl80211_band band = local->hw.conf.chandef.chan->band;
+	enum nl80211_band band;
 	u32 flags = 0, tx_flags;
 
+	if (!local->hw.conf.chandef.chan) {
+		printk("channel NULL\n");
+		WARN_ON(1);
+		return;
+	}
+
+	band = local->hw.conf.chandef.chan->band;
 	scan_req = rcu_dereference_protected(local->scan_req,
 					     lockdep_is_held(&local->hw.wiphy->mtx));
 
diff --git a/net/mac80211/tx.c b/net/mac80211/tx.c
index 41f2cad..06f4aae 100644
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -2658,6 +2658,7 @@ static u16 ieee80211_store_ack_skb(struct ieee80211_local *local,
 			}
 		} else {
 			kfree_skb(ack_skb);
+			printk(KERN_ERR "store ack fail %d\n", id);
 		}
 	}
 
-- 
2.34.1

