From ee0d8e100ea0543c1df3e678f4f2646ea67e663f Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:14 +0530
Subject: [PATCH] mac80211: UPSTREAMCP wifi Fix the BSSID for MLO STA

Use the associated AP link BSSID address to get the MLO STA info instead of
using the deflink BSSID in the function ieee80211_change_iface().

This fixes the upstream commit b65567b03 (wifi: mac80211: mlme: track
AP (MLD) address separately)

Patch-work: None
Patch-dependency: None

Signed-off-by: Maharaja Kennadyrajan <quic_mkenna@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/cfg.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/net/mac80211/cfg.c b/net/mac80211/cfg.c
index 0eddf6c..66a2622 100644
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -291,7 +291,7 @@ static int ieee80211_change_iface(struct wiphy *wiphy,
 		if (!ifmgd->associated)
 			return 0;
 
-		sta = sta_info_get(sdata, sdata->deflink.u.mgd.bssid);
+		sta = sta_info_get(sdata, sdata->vif.cfg.ap_addr);
 		if (sta)
 			drv_sta_set_4addr(local, sdata, &sta->sta,
 					  params->use_4addr);
-- 
