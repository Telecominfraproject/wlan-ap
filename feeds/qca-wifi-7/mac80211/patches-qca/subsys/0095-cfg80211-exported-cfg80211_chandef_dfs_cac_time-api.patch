From cc995fd101e6b12751e4881afa85698e92ca42a3 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:01 +0530
Subject: [PATCH] mac80211: exported cfg_chandef_dfs_cac_time api

Driver needs this cfg80211_chandef_dfs_cac_time for calculating
the dfs_cac_time across the chandef

Signed-off-by: Karthik M <quic_karm@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 include/net/cfg80211.h | 23 +++++++++++------------
 1 file changed, 11 insertions(+), 12 deletions(-)

diff --git a/include/net/cfg80211.h b/include/net/cfg80211.h
index 031f788..9bfab4f 100644
--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -1106,18 +1106,6 @@ int cfg80211_chandef_dfs_required(struct wiphy *wiphy,
 bool cfg80211_chandef_dfs_usable(struct wiphy *wiphy,
 				 const struct cfg80211_chan_def *chandef);
 
-/**
- * cfg80211_chandef_dfs_cac_time - get the DFS CAC time (in ms) for given
- *				   channel definition
- * @wiphy: the wiphy to validate against
- * @chandef: the channel definition to check
- *
- * Returns: DFS CAC time (in ms) which applies for this channel definition
- */
-unsigned int
-cfg80211_chandef_dfs_cac_time(struct wiphy *wiphy,
-			      const struct cfg80211_chan_def *chandef);
-
 /**
  * cfg80211_chandef_primary - calculate primary 40/80/160 MHz freq
  * @chandef: chandef to calculate for
@@ -1178,6 +1166,17 @@ ieee80211_chandef_rate_flags(struct cfg80211_chan_def *chandef)
 	return ieee80211_chanwidth_rate_flags(chandef->width);
 }
 
+/**
+ * cfg80211_chandef_dfs_cac_time - get maximum dfs cac time traversing
+ * through the entire channel width
+ * @wiphy: the wiphy to validate against
+ * @chandef: the channel definition to check
+ * @is_bgcac: background cac state
+ * Returns: dfs cac time, or 0 is none found
+ */
+unsigned int cfg80211_chandef_dfs_cac_time(struct wiphy *wiphy,
+                                           const struct cfg80211_chan_def *chandef);
+
 /**
  * ieee80211_chandef_max_power - maximum transmission power for the chandef
  *
-- 
2.34.1

