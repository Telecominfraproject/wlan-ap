From 115d23eaad650383d80039ab55aba198bdde0a8d Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:27:06 +0530
Subject: [PATCH] mac80211: wifi Remove fast_xmit override for mesh fast xmit

This change will make use of fast_xmit flag for mesh mode
which will utilise the fast_tx path in the driver

Patch dependency: none

Signed-off-by: Ramanathan Choodamani <quic_rchoodam@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/tx.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/net/mac80211/tx.c b/net/mac80211/tx.c
index eadfd08..b552ec9 100644
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -4658,9 +4658,6 @@ netdev_tx_t ieee80211_subif_start_xmit(struct sk_buff *skb,
 
 #ifdef CPTCFG_MAC80211_NSS_SUPPORT
 	ieee80211_xmit_nss_fixup(skb, dev);
-#endif
-#ifdef CPTCFG_MAC80211_SFE_SUPPORT
-	skb->fast_xmit = 0;
 #endif
 	if (likely(!is_multicast_ether_addr(eth->h_dest)))
 		goto normal;
-- 
2.34.1

