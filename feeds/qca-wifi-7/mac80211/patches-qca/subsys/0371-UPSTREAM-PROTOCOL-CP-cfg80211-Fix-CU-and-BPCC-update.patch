From fe0d9b85d8f1a4c0245e4d15a22ca892d52c3c69 Mon Sep 17 00:00:00 2001
From: Yuvarani V <yuvarani@qti.qualcomm.com>
Date: Fri, 8 Aug 2025 16:47:02 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:CP: cfg80211: Fix CU and BPCC update
 post CSA

Currently CU and BPCC are not updated post CSA.
This is due to resetting elemid_modified in post csa
beacon.

Fix this by resetting the elemid_modified in
ieee80211_csa_finalize_work and not in
ieee80211_set_after_csa_beacon.

Fixes: I1e48e31437(wifi: mac80211: pkg upgrade changes set 18) 

Signed-off-by: Yuvarani V <yuvarani@qti.qualcomm.com>
---
 net/mac80211/cfg.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/net/mac80211/cfg.c b/net/mac80211/cfg.c
index 27d05e8..e2811d7 100644
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -4341,7 +4341,6 @@ static int ieee80211_set_after_csa_beacon(struct ieee80211_link_data *link_data,
 		return -EINVAL;
 	}
 
-	link_conf->elemid_modified = 0;
 	return 0;
 }
 
@@ -4444,6 +4443,7 @@ void ieee80211_csa_finalize_work(struct wiphy *wiphy, struct wiphy_work *work)
 		return;
 
 	ieee80211_csa_finalize(link);
+	link->conf->elemid_modified = false;
 }
 
 static int ieee80211_set_csa_beacon(struct ieee80211_link_data *link_data,
-- 
2.34.1

