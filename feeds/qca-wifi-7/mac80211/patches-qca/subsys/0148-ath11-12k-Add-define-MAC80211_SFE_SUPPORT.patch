From c9afcb355fef505df56ab3ab2a9cfd07f070cb6f Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:26:26 +0530
Subject: [PATCH] mac80211: athk Add define MAC_SFE_SUPPORT

This patch add define MAC80211_SFE_SUPPORT to avoid compilation
error. the nss sfe pvt changes in kernel will cause compilaiton
error when built with upstream kernel.

Signed-off-by: Bhagavathi Perumal S <quic_bperumal@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 local-symbols        | 1 +
 net/mac80211/Kconfig | 7 +++++++
 net/mac80211/tx.c    | 9 ++++++---
 3 files changed, 14 insertions(+), 3 deletions(-)

diff --git a/local-symbols b/local-symbols
index 29b396e..c85a50f 100644
--- a/local-symbols
+++ b/local-symbols
@@ -59,6 +59,7 @@ MAC80211_DEBUG_COUNTERS=
 MAC80211_STA_HASH_MAX_SIZE=
 MAC80211_NSS_SUPPORT=
 MAC80211_PPE_SUPPORT=
+MAC80211_SFE_SUPPORT=
 WLAN=
 ATH_COMMON=
 WLAN_VENDOR_ATH=
diff --git a/net/mac80211/Kconfig b/net/mac80211/Kconfig
index 4712b79..e04ddb0 100644
--- a/net/mac80211/Kconfig
+++ b/net/mac80211/Kconfig
@@ -124,6 +124,13 @@ config MAC80211_NSS_SUPPORT
 
 	  If unsure, say Y to enable NSS offload support.
 
+config MAC80211_SFE_SUPPORT
+	bool "QTI mac80211 sfe support"
+	depends on ATH12K
+	default n
+	---help---
+	  Enables sfe support for ATH12K driver
+
 config MAC80211_PPE_SUPPORT
        bool "QTI mac80211 ppe support"
        depends on ATH12K
diff --git a/net/mac80211/tx.c b/net/mac80211/tx.c
index 70a0cf0..f7855aa 100644
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -4644,8 +4644,9 @@ netdev_tx_t ieee80211_subif_start_xmit(struct sk_buff *skb,
 #ifdef CPTCFG_MAC80211_NSS_SUPPORT
 	ieee80211_xmit_nss_fixup(skb, dev);
 #endif
+#ifdef CPTCFG_MAC80211_SFE_SUPPORT
 	skb->fast_xmit = 0;
-
+#endif
 	if (likely(!is_multicast_ether_addr(eth->h_dest)))
 		goto normal;
 
@@ -4945,6 +4946,7 @@ void ieee80211_8023_xmit_ap(struct ieee80211_sub_if_data *sdata,
 netdev_tx_t ieee80211_subif_start_xmit_8023(struct sk_buff *skb,
 					    struct net_device *dev)
 {
+#ifdef CPTCFG_MAC80211_SFE_SUPPORT
 	struct ieee80211_sub_if_data *sdata = IEEE80211_DEV_TO_SUB_IF(dev);
 	struct ieee80211_tx_info *info = IEEE80211_SKB_CB(skb);
 	struct ieee80211_tx_control control = {};
@@ -4979,9 +4981,10 @@ out:
 		}
 
 		return NETDEV_TX_OK;
-	} else {
-		return __ieee80211_subif_start_xmit_8023(skb, dev, 0, 0, NULL);
 	}
+#endif
+	return __ieee80211_subif_start_xmit_8023(skb, dev, 0, 0, NULL);
+
 }
 
 netdev_tx_t __ieee80211_subif_start_xmit_8023(struct sk_buff *skb,
-- 
2.34.1

