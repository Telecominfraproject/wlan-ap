From 026b94ee74c4e34398b4ea61cd3b0aad053d5a28 Mon Sep 17 00:00:00 2001
From: Balamurugan Ramar <quic_bramar@quicinc.com>
Date: Thu, 10 Apr 2025 23:25:59 +0530
Subject: [PATCH] mac80211: get link information of associated station

fill valid_link value for each interface.

Signed-off-by: Aaradhana Sahu <quic_aarasahu@quicinc.com>
Signed-off-by: Balamurugan Ramar <quic_bramar@quicinc.com>
---
 net/mac80211/sta_info.c | 21 ++++++++++++++++++++-
 1 file changed, 20 insertions(+), 1 deletion(-)

diff --git a/net/mac80211/sta_info.c b/net/mac80211/sta_info.c
index 1bb3e98..9f65609 100644
--- a/net/mac80211/sta_info.c
+++ b/net/mac80211/sta_info.c
@@ -2609,8 +2609,9 @@ void sta_set_sinfo(struct sta_info *sta, struct station_info *sinfo,
 	struct ieee80211_sub_if_data *sdata = sta->sdata;
 	struct ieee80211_local *local = sdata->local;
 	u32 thr = 0;
-	int i, ac, cpu;
+	int i, ac, cpu, link_id = 0;
 	struct ieee80211_sta_rx_stats *last_rxstats;
+	struct link_sta_info *link_sta = NULL;
 
 	last_rxstats = sta_get_last_rx_stats(sta);
 
@@ -2641,6 +2642,24 @@ void sta_set_sinfo(struct sta_info *sta, struct station_info *sinfo,
 	sinfo->assoc_at = sta->assoc_at;
 	sinfo->inactive_time =
 		jiffies_to_msecs(jiffies - ieee80211_sta_last_active(sta));
+	/* bitmap of valid links for MLO or 0 for non MLO */
+	sinfo->valid_links = sta->sta.valid_links;
+
+	if (sinfo->valid_links) {
+		for_each_valid_link(sinfo, link_id) {
+			rcu_read_lock();
+			link_sta = rcu_dereference(sta->link[link_id]);
+
+			if (!link_sta) {
+				rcu_read_unlock();
+				continue;
+			}
+
+			memcpy(sinfo->links[link_id].addr, link_sta->addr,
+			       ETH_ALEN);
+			rcu_read_unlock();
+		}
+	}
 
 	if (!(sinfo->filled & (BIT_ULL(NL80211_STA_INFO_TX_BYTES64) |
 			       BIT_ULL(NL80211_STA_INFO_TX_BYTES)))) {
-- 
