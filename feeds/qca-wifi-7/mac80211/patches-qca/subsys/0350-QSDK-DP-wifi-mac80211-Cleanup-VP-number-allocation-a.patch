From 8e179fb5d28c73ccf4f1f48abbc60d9eefc86c96 Mon Sep 17 00:00:00 2001
From: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
Date: Mon, 7 Jul 2025 12:58:18 -0700
Subject: [PATCH] QSDK:DP:wifi:mac80211: Cleanup VP number allocation and
 deallocation

VP allocation and deallocation logic is moved into ath_client module.
As a result, clean up the redundant logic in mac80211

Patch-dependency:
	0221-QSDK-mac80211-Handle-vendor-command-for-interface-offload.patch

Signed-off-by: Ganesh Kariganuru Mahabalesh <gkarigan@qti.qualcomm.com>
---
 net/mac80211/iface.c |   80 ---------------------------------------------------
 1 file changed, 80 deletions(-)

--- a/net/mac80211/iface.c
+++ b/net/mac80211/iface.c
@@ -827,15 +827,6 @@ static int ieee80211_stop(struct net_dev
 	if (sdata->vif.type == NL80211_IFTYPE_AP)
 		ieee80211_stop_mbssid(sdata, -1);
 
-#ifdef CPTCFG_MAC80211_PPE_SUPPORT
-	/* Free VP port here for PPE_VP mode */
-	if (ppe_vp_accel && sdata->vif.ppe_vp_num != -1) {
-		ppe_vp_free(sdata->vif.ppe_vp_num);
-		sdata_info(sdata, "Destroyed PPE VP port no:%d for dev:%s\n",
-			   sdata->vif.ppe_vp_num, dev->name);
-		sdata->vif.ppe_vp_num = -1;
-	}
-#endif
 	ieee80211_do_stop(sdata, true);
 
 	return 0;
@@ -1316,58 +1307,6 @@ void receive_from_nss(struct net_device
 }
 #endif
 
-#ifdef CPTCFG_MAC80211_PPE_SUPPORT
-/*
- * This callback is registered for Tx path.
- * PPE will invoke this callback and the skb is
- * routed to the driver.
- */
-static bool ieee80211_process_dst_ppe_vp(struct ppe_vp_cb_info *ppe_vp_info, void *cb_data)
-{
-	struct sk_buff *skb = ppe_vp_info->skb;
-	struct net_device *dev = ppe_vp_info->napi->dev;
-	if (unlikely(dev == NULL)) {
-		dev_kfree_skb_any(skb);
-		return false;
-	}
-
-	skb->dev = dev;
-	dev_queue_xmit(skb);
-
-	return true;
-}
-
-/*
- * Register with PPE virtual port(vp) on VAP creation.
- * Allocate a new virtual port and returns ppe vp no on success.
- * on failure returns -1;
- */
-static int ieee80211_ppe_vp_802_3_redir_vap(struct ieee80211_sub_if_data *sdata,
-					    struct net_device *dev,
-					    int ppe_vp_type)
-{
-	struct ppe_vp_ai vpai;
-	int vp = MAC80211_INVALID_PPE_VP_NUM;
-
-	memset(&vpai, 0, sizeof(struct ppe_vp_ai));
-
-	vpai.type = PPE_VP_TYPE_SW_L2;
-	vpai.net_dev_type = PPE_VP_NET_DEV_TYPE_WIFI;
-	vpai.dst_cb = ieee80211_process_dst_ppe_vp;
-	vpai.dst_cb_data = &sdata->vif;
-	vpai.src_cb = NULL;
-	vpai.src_cb_data = NULL;
-	vpai.queue_num = 0;
-
-	/* Allocate VP port here for PPE_VP mode */
-	vp = ppe_vp_alloc(dev, &vpai);
-	if (vp <= 0)
-		return -1;
-
-	return vp;
-}
-#endif
-
 /*
  * NOTE: Be very careful when changing this function, it must NOT return
  * an error on interface type changes that have been pre-checked, so most
@@ -1381,9 +1320,6 @@ int ieee80211_do_open(struct wireless_de
 	u64 changed = 0;
 	int res;
 	u32 hw_reconf_flags = 0;
-#ifdef CPTCFG_MAC80211_PPE_SUPPORT
-	int vp;
-#endif
 
 	lockdep_assert_wiphy(local->hw.wiphy);
 
@@ -1634,22 +1570,6 @@ int ieee80211_do_open(struct wireless_de
        }
 #endif
 
-#ifdef CPTCFG_MAC80211_PPE_SUPPORT
-	/* for PPE RFS, driver handles VP allocation for non VLAN interfaces */
-	if (ppe_vp_accel) {
-		vp = ieee80211_ppe_vp_802_3_redir_vap(sdata, dev,
-						      wdev->ppe_vp_type);
-		if (vp > 0) {
-			sdata->vif.ppe_vp_num = vp;
-			sdata_info(sdata, "Allocated vp:%d for device:%s\n",
-				   sdata->vif.ppe_vp_num, dev->name);
-		} else {
-			sdata->vif.ppe_vp_num = -1;
-			sdata_err(sdata, "Failed to register with PPE VP\n");
-		}
-	}
-#endif
-
 	set_bit(SDATA_STATE_RUNNING, &sdata->state);
 
 	return 0;
