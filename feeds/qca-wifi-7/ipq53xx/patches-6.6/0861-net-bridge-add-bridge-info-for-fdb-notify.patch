From 9a35cd133fe8eb6f940494b071cdb7f2aea76397 Mon Sep 17 00:00:00 2001
From: Amit Gupta <quic_amitgupt@quicinc.com>
Date: Thu, 13 Mar 2025 15:05:47 +0530
Subject: [PATCH] [net][bridge] add bridge info for fdb notify

Change to add bridge info in fdb event sent
during fdb add or delete notification

Change-Id: I223f8214d96079f1266c6b4f016339db92f28a85
Signed-off-by: Amit Gupta <quic_amitgupt@quicinc.com>
---
 net/bridge/br_fdb.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/net/bridge/br_fdb.c b/net/bridge/br_fdb.c
index 6c6286f0be0f..0b590f012796 100644
--- a/net/bridge/br_fdb.c
+++ b/net/bridge/br_fdb.c
@@ -219,6 +219,7 @@ static void fdb_notify(struct net_bridge *br,
 			event = BR_FDB_EVENT_DEL;
 
 		fdb_event.dev = fdb->dst->dev;
+		fdb_event.br = br;
 		ether_addr_copy(fdb_event.addr, fdb->key.addr.addr);
 		fdb_event.is_local = test_bit(BR_FDB_LOCAL, &fdb->flags);
 		atomic_notifier_call_chain(&br_fdb_notifier_list,
-- 
2.34.1

