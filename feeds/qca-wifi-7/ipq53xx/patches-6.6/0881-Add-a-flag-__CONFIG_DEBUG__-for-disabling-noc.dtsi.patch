From a3e440617997b96c8ca2b2918f48e78df5c6cb95 Mon Sep 17 00:00:00 2001
From: Adarsh Anand <quic_adaana@quicinc.com>
Date: Tue, 1 Apr 2025 15:43:08 +0530
Subject: [PATCH] Add a flag __CONFIG_DEBUG__ for disabling noc.dtsi

Change-Id: Id5cc18f14d061a51e9e88002fafa84981b14cf6e
Signed-off-by: Adarsh Anand <quic_adaana@quicinc.com>
---
 scripts/Makefile.lib | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/scripts/Makefile.lib b/scripts/Makefile.lib
index 103607a5f699..bd9447204fac 100644
--- a/scripts/Makefile.lib
+++ b/scripts/Makefile.lib
@@ -277,6 +277,10 @@ ifeq ($(CONFIG_IO_COHERENCY),y)
 dtc_cpp_flags += -D __CONFIG_IO_COHERENCY__
 endif
 
+ifeq ($(CONFIG_DEBUG),y)
+dtc_cpp_flags += -D __CONFIG_DEBUG__
+endif
+
 ifdef CONFIG_OBJTOOL
 
 objtool := $(objtree)/tools/objtool/objtool
-- 
