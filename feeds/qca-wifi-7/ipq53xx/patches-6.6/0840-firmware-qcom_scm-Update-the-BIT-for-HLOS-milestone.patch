From c0220dff2d7467621d3c68f73a5b260d57b00958 Mon Sep 17 00:00:00 2001
From: Kathiravan Thirumoorthy <quic_kathirav@quicinc.com>
Date: Mon, 27 Jan 2025 15:21:37 +0530
Subject: [PATCH] firmware: qcom_scm: Update the BIT for HLOS milestone

As per the new failsafe design, both bootloader and HLOS will use the same bit position. So update the HLOS bit position to 8 from 9.

While at it, drop the unused macros related to milestone bit.

Change-Id: Ic25d0dad7eac897bcec4b35afb4f38e2c74ac296
Signed-off-by: Kathiravan Thirumoorthy <quic_kathirav@quicinc.com>
---
 drivers/firmware/qcom_scm.c            | 3 +--
 include/linux/firmware/qcom/qcom_scm.h | 1 -
 2 files changed, 1 insertion(+), 3 deletions(-)

diff --git a/drivers/firmware/qcom_scm.c b/drivers/firmware/qcom_scm.c
index a1b2c3827b67..cbf56734f5b2 100644
--- a/drivers/firmware/qcom_scm.c
+++ b/drivers/firmware/qcom_scm.c
@@ -85,7 +85,6 @@ static const u8 qcom_scm_cpu_warm_bits[QCOM_SCM_BOOT_MAX_CPUS] = {
 #define QCOM_SMC_WAITQ_FLAG_WAKE_ALL	BIT(1)
 
 #define QCOM_DLOAD_MASK		GENMASK(5, 4)
-#define QCOM_MILESTONE_MASK	BIT(9)
 enum qcom_dload_mode {
 	QCOM_DLOAD_NODUMP	= 0,
 	QCOM_DLOAD_FULLDUMP	= 1,
@@ -3529,7 +3528,7 @@ struct scm_priv_data ipq9574_data = {
 };
 
 struct scm_priv_data ipq5424_data = {
-	.milestone_mask = BIT(12)
+	.milestone_mask = BIT(8)
 };
 
 static const struct of_device_id qcom_scm_dt_match[] = {
diff --git a/include/linux/firmware/qcom/qcom_scm.h b/include/linux/firmware/qcom/qcom_scm.h
index 98457d188007..f4f109e40f95 100644
--- a/include/linux/firmware/qcom/qcom_scm.h
+++ b/include/linux/firmware/qcom/qcom_scm.h
@@ -25,7 +25,6 @@
 #define QTI_TZ_LOG_NO_UPDATE		-6
 #define QTI_SCM_SVC_FUSE		0x8
 #define QTI_TRYBIT			BIT(12)
-#define HLOS_MILESTONE_BIT		BIT(12)
 
 #define MAX_MSM_ICE_KEY_LUT_SIZE	32
 #define DATA_COTEXT_LEN			128
-- 
2.34.1

