From 7e8d90dbd850dd4125c129fa6e77cfd5e3b482b8 Mon Sep 17 00:00:00 2001
From: Sridharan S N <quic_sridsn@quicinc.com>
Date: Fri, 7 Feb 2025 17:34:20 +0530
Subject: [PATCH] include: linux: remoteproc: Add io_ptr in rproc_dump_segment

Add io_ptr member rproc_dump_segment to do ioremap once
and store.

Change-Id: I1db3a7035fb80ea377001f6acf05689788342f18
Signed-off-by: Sridharan S N <quic_sridsn@quicinc.com>
---
 include/linux/remoteproc.h | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/include/linux/remoteproc.h b/include/linux/remoteproc.h
index 6dc8fc58faff..1ecb079ca724 100644
--- a/include/linux/remoteproc.h
+++ b/include/linux/remoteproc.h
@@ -471,7 +471,9 @@ enum rproc_dump_mechanism {
  * struct rproc_dump_segment - segment info from ELF header
  * @node:	list node related to the rproc segment list
  * @da:		device address of the segment
+ * @va:		virtual device address of the segment
  * @size:	size of the segment
+ * @io_ptr:	ptr to store the ioremapped dump segment
  * @priv:	private data associated with the dump_segment
  * @dump:	custom dump function to fill device memory segment associated
  *		with coredump
@@ -484,6 +486,7 @@ struct rproc_dump_segment {
 	dma_addr_t va;
 	size_t size;
 
+	void *io_ptr;
 	void *priv;
 	void (*dump)(struct rproc *rproc, struct rproc_dump_segment *segment,
 		     void *dest, size_t offset, size_t size);
-- 
2.34.1

