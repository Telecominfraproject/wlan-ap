From 976e7f8d44033a090a1e53cc197416b40850ae2d Mon Sep 17 00:00:00 2001
From: Vignesh Viswanathan <viswanat@qti.qualcomm.com>
Date: Mon, 24 Nov 2025 17:00:07 +0530
Subject: [PATCH] tty: serial: msm_serial: Fix random TX hang on UARTDM

The msm_serial driver can experience random TX hangs during device
bootup or reboot stress testing, where the serial console becomes
unresponsive. The hang manifests as userspace writes to /dev/console
and /dev/ttyMSM0 getting stuck, while kernel printk continues to work.
Pressing Ctrl+C temporarily recovers the console.

Analysis of register dumps revealed the root cause: the UARTDM_NCF_TX
register gets stuck at 0x88 (136 characters) from a previous incomplete
TX operation, with the TXLEV interrupt enabled but TX not progressing.
This occurs because stale hardware state from bootloader or previous
boots interferes with driver initialization.

This patch implements three fixes to ensure clean hardware state:

1. msm_console_setup(): Add explicit UART reset before console
   configuration and enable TX/RX. This ensures the console starts
   in a known clean state, preventing interference from bootloader
   or previous boot state.

2. msm_startup(): Add UART reset and interrupt disable at the
   beginning of port startup. This clears any stale state from
   previous operations, which is critical during reboot stress
   testing where hardware may retain state.

3. msm_reset(): For UARTDM hardware, explicitly clear the
   UARTDM_NCF_TX register and reset TX_READY status. This addresses
   the specific issue where NCF_TX gets stuck with a stale character
   count, preventing further TX operations.

These changes ensure the UART hardware is properly initialized from
a clean state, eliminating the random TX hang issue observed during
bootup and reboot stress testing.

Tested on IPQ5332 SoC with UARTDM v1.4 during extensive reboot stress
testing. The issue no longer occurs with these fixes applied.

Change-Id: Ied68381ef19caa92a314e33299ce893c39db4a02
Signed-off-by: Vignesh Viswanathan <viswanat@qti.qualcomm.com>
---
 drivers/tty/serial/msm_serial.c | 22 +++++++++++++++++++++-
 1 file changed, 21 insertions(+), 1 deletion(-)

diff --git a/drivers/tty/serial/msm_serial.c b/drivers/tty/serial/msm_serial.c
index 35d7b192c2bd..8a59c5c05004 100644
--- a/drivers/tty/serial/msm_serial.c
+++ b/drivers/tty/serial/msm_serial.c
@@ -1016,8 +1016,13 @@ static void msm_reset(struct uart_port *port)
 	msm_write(port, mr, MSM_UART_MR1);
 
 	/* Disable DM modes */
-	if (msm_port->is_uartdm)
+	if (msm_port->is_uartdm) {
 		msm_write(port, 0, UARTDM_DMEN);
+		/* Clear any stale NCF_TX value that might cause hangs */
+		msm_write(port, 0, UARTDM_NCF_TX);
+		/* Reset TX_READY to clear any pending state */
+		msm_write(port, MSM_UART_CR_CMD_RESET_TX_READY, MSM_UART_CR);
+	}
 }
 
 static void msm_set_mctrl(struct uart_port *port, unsigned int mctrl)
@@ -1206,6 +1211,13 @@ static int msm_startup(struct uart_port *port)
 
 	msm_init_clock(port);
 
+	/*
+	 * Reset and disable UART to clear any stale state.
+	 * This is critical to avoid TX hangs from previous state.
+	 */
+	msm_reset(port);
+	msm_write(port, 0, MSM_UART_IMR);
+
 	if (likely(port->fifosize > 12))
 		rfr_level = port->fifosize - 12;
 	else
@@ -1687,6 +1699,7 @@ static void msm_console_write(struct console *co, const char *s,
 static int msm_console_setup(struct console *co, char *options)
 {
 	struct uart_port *port;
+	struct msm_port *msm_port;
 	int baud = 115200;
 	int bits = 8;
 	int parity = 'n';
@@ -1696,12 +1709,19 @@ static int msm_console_setup(struct console *co, char *options)
 		return -ENXIO;
 
 	port = msm_get_port_from_line(co->index);
+	msm_port = to_msm_port(port);
 
 	if (unlikely(!port->membase))
 		return -ENXIO;
 
 	msm_init_clock(port);
 
+	/* Reset the UART before configuration to ensure clean state */
+	msm_reset(port);
+
+	/* Ensure TX and RX are enabled for console */
+	msm_write(port, MSM_UART_CR_TX_ENABLE | MSM_UART_CR_RX_ENABLE, MSM_UART_CR);
+
 	if (options)
 		uart_parse_options(options, &baud, &parity, &bits, &flow);
 
-- 
