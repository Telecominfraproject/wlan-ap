From 801d038dfc1d99896bd9e14959ad8c84752de3cb Mon Sep 17 00:00:00 2001
From: Timple Raj M <timple@qti.qualcomm.com>
Date: Mon, 14 Jul 2025 10:07:36 +0530
Subject: [PATCH] drivers: pinctrl: Add TLMM support

This patch adds the TLMM support for the
IPQ52xx chipset

Change-Id: I203bccbf3e4fdb2d73e24520082db82cbc21de69
Signed-off-by: Timple Raj M <timple@qti.qualcomm.com>
---
 drivers/pinctrl/qcom/Kconfig.msm | 14 +++++++++++---
 drivers/pinctrl/qcom/Makefile    |  1 +
 2 files changed, 12 insertions(+), 3 deletions(-)

diff --git a/drivers/pinctrl/qcom/Kconfig.msm b/drivers/pinctrl/qcom/Kconfig.msm
index d2c01085f15e..d469f092204f 100644
--- a/drivers/pinctrl/qcom/Kconfig.msm
+++ b/drivers/pinctrl/qcom/Kconfig.msm
@@ -49,9 +49,17 @@ config PINCTRL_IPQ5424
 	tristate "Qualcomm Technologies, Inc. IPQ5424 pin controller driver"
 	help
 	  This is the pinctrl, pinmux, pinconf and gpiolib driver for
-          the Qualcomm Technologies Inc. TLMM block found on the
-          Qualcomm Technologies Inc. IPQ5424 platform. Select this for
-          IPQ5424.
+	  the Qualcomm Technologies Inc. TLMM block found on the
+	  Qualcomm Technologies Inc. IPQ5424 platform. Select this for
+	  IPQ5424.
+
+config PINCTRL_IPQ5200
+	tristate "Qualcomm Technologies, Inc. IPQ5200 pin controller driver"
+	help
+	  This is the pinctrl, pinmux, pinconf and gpiolib driver for
+	  the Qualcomm Technologies Inc. TLMM block found on the
+	  Qualcomm Technologies Inc. IPQ5200 platform. Select this for
+	  IPQ5200.
 
 config PINCTRL_IPQ8074
 	tristate "Qualcomm Technologies, Inc. IPQ8074 pin controller driver"
diff --git a/drivers/pinctrl/qcom/Makefile b/drivers/pinctrl/qcom/Makefile
index 5c686d4c8ef3..b16443ec799c 100644
--- a/drivers/pinctrl/qcom/Makefile
+++ b/drivers/pinctrl/qcom/Makefile
@@ -6,6 +6,7 @@ obj-$(CONFIG_PINCTRL_APQ8084)	+= pinctrl-apq8084.o
 obj-$(CONFIG_PINCTRL_IPQ4019)	+= pinctrl-ipq4019.o
 obj-$(CONFIG_PINCTRL_IPQ5018)	+= pinctrl-ipq5018.o
 obj-$(CONFIG_PINCTRL_IPQ8064)	+= pinctrl-ipq8064.o
+obj-$(CONFIG_PINCTRL_IPQ5200)	+= pinctrl-ipq5200.o
 obj-$(CONFIG_PINCTRL_IPQ5332)	+= pinctrl-ipq5332.o
 obj-$(CONFIG_PINCTRL_IPQ5424)	+= pinctrl-ipq5424.o
 obj-$(CONFIG_PINCTRL_IPQ8074)	+= pinctrl-ipq8074.o
-- 
2.34.1

