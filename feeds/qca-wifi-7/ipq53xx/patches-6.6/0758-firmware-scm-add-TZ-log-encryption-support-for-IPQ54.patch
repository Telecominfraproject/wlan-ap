From 84c7ed41c77c1d0c96baa7d5badbc14c0dd3f380 Mon Sep 17 00:00:00 2001
From: Kathiravan Thirumoorthy <quic_kathirav@quicinc.com>
Date: Mon, 25 Nov 2024 14:03:45 +0530
Subject: [PATCH] firmware: scm: add TZ log encryption support for IPQ54xx

There is a new enhancement added to the Log encryption feature from
ipq54xx which it requires an additional input of seg_id for
the encyrption scm call.

Change-Id: Ic8d87bd6bde80b4878e3ff2c8e577bf4d3f6336b
Signed-off-by: Kathiravan Thirumoorthy <quic_kathirav@quicinc.com>
---
 drivers/firmware/qcom_scm.c            | 13 +++++++++++--
 include/linux/firmware/qcom/qcom_scm.h |  3 ++-
 2 files changed, 13 insertions(+), 3 deletions(-)

diff --git a/drivers/firmware/qcom_scm.c b/drivers/firmware/qcom_scm.c
index f6fee5431325..85889771d3c2 100644
--- a/drivers/firmware/qcom_scm.c
+++ b/drivers/firmware/qcom_scm.c
@@ -2411,7 +2411,8 @@ int qcom_sec_upgrade_auth(unsigned int scm_cmd_id, unsigned int sw_type,
 }
 EXPORT_SYMBOL_GPL(qcom_sec_upgrade_auth);
 
-int qti_scm_get_encrypted_tz_log(void *ker_buf, u32 buf_len, u32 log_id)
+int qti_scm_get_encrypted_tz_log(void *ker_buf, u32 buf_len, u32 log_id,
+				 u32 seg_id)
 {
 	int ret;
 	dma_addr_t log_buf;
@@ -2432,7 +2433,15 @@ int qti_scm_get_encrypted_tz_log(void *ker_buf, u32 buf_len, u32 log_id)
 	desc.args[0] = log_buf;
 	desc.args[1] = buf_len;
 	desc.args[2] = log_id;
-	desc.arginfo = QCOM_SCM_ARGS(3, QCOM_SCM_RW, QCOM_SCM_VAL, QCOM_SCM_VAL);
+
+	if (seg_id) {
+		desc.args[3] = seg_id;
+		desc.arginfo = QCOM_SCM_ARGS(4, QCOM_SCM_RW, QCOM_SCM_VAL,
+					     QCOM_SCM_VAL, QCOM_SCM_VAL);
+	} else {
+		desc.arginfo = QCOM_SCM_ARGS(3, QCOM_SCM_RW, QCOM_SCM_VAL,
+					     QCOM_SCM_VAL);
+	}
 
 	ret = qcom_scm_call(__scm->dev, &desc, &res);
 	dma_unmap_single(__scm->dev, log_buf, buf_len, DMA_FROM_DEVICE);
diff --git a/include/linux/firmware/qcom/qcom_scm.h b/include/linux/firmware/qcom/qcom_scm.h
index 509ae71e3b62..43f337686d48 100644
--- a/include/linux/firmware/qcom/qcom_scm.h
+++ b/include/linux/firmware/qcom/qcom_scm.h
@@ -350,7 +350,8 @@ extern int qti_set_qcekey_sec(void *buf, int size);
 extern int qcom_qcekey_release_xpu_prot(void);
 
 extern int qti_scm_is_tz_log_encrypted(void);
-extern int qti_scm_get_encrypted_tz_log(void *ker_buf, u32 buf_len, u32 log_id);
+extern int qti_scm_get_encrypted_tz_log(void *ker_buf, u32 buf_len, u32 log_id,
+					u32 seg_id);
 extern int qti_scm_is_tz_log_encryption_supported(void);
 extern int qti_scm_tz_log(void *ker_buf, u32 buf_len);
 extern int qti_scm_hvc_log(void *ker_buf, u32 buf_len);
-- 
2.34.1

