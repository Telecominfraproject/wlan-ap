From 37c499332235c1e8f96196a84708d272c5784763 Mon Sep 17 00:00:00 2001
From: Sridharan S N <sridsn@qti.qualcomm.com>
Date: Sat, 14 Jun 2025 21:26:42 +0530
Subject: [PATCH] arm: mach-qcom: Add support for IPQ9679

Enable the GICV3 driver for IPQ9679 target.

Change-Id: I19c799ed7a69ab5c700c6d6ee537dcf71eaa769a
Signed-off-by: Sridharan S N <sridsn@qti.qualcomm.com>
---
 arch/arm/mach-qcom/Kconfig | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/arch/arm/mach-qcom/Kconfig b/arch/arm/mach-qcom/Kconfig
index 25ec3aee424a..498d047b48bf 100644
--- a/arch/arm/mach-qcom/Kconfig
+++ b/arch/arm/mach-qcom/Kconfig
@@ -21,6 +21,10 @@ config ARCH_IPQ5424
 	bool "Enable support for IPQ5424"
 	select ARM_GIC_V3
 
+config ARCH_IPQ9679
+	bool "Enable support for IPQ9679"
+	select ARM_GIC_V3
+
 config ARCH_MSM8X60
 	bool "Enable support for MSM8X60"
 	select CLKSRC_QCOM
-- 
2.34.1

