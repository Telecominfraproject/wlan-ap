From 9ea03a6e85fc4a01c96a975dd806017a18c4da82 Mon Sep 17 00:00:00 2001
From: Vishnu Vardhan Bantanahal <vishvard@qti.qualcomm.com>
Date: Sat, 12 Apr 2025 03:03:10 +0530
Subject: [PATCH] net: Add new socket option (SO_OFFLOAD) for Datapath offload.

Change-Id: If2638c9cbe5611ea17176b32085bac84a12e4790
Signed-off-by: Vishnu Vardhan Bantanahal <vishvard@qti.qualcomm.com>
---
 include/net/sock.h                |  3 +++
 include/uapi/asm-generic/socket.h |  3 +++
 net/core/sock.c                   | 16 ++++++++++++++++
 3 files changed, 22 insertions(+)

diff --git a/include/net/sock.h b/include/net/sock.h
index 5942b5ff4c78..2994446f4a75 100644
--- a/include/net/sock.h
+++ b/include/net/sock.h
@@ -517,6 +517,9 @@ struct sock {
 	u8			sk_txtime_deadline_mode : 1,
 				sk_txtime_report_errors : 1,
 				sk_txtime_unused : 6;
+	u8			offload : 1,
+				offload_appid : 3,
+				reserved : 4;
 	bool			sk_use_task_frag;
 
 	struct socket		*sk_socket;
diff --git a/include/uapi/asm-generic/socket.h b/include/uapi/asm-generic/socket.h
index 8ce8a39a1e5f..3a9b810242cc 100644
--- a/include/uapi/asm-generic/socket.h
+++ b/include/uapi/asm-generic/socket.h
@@ -135,6 +135,9 @@
 #define SO_PASSPIDFD		76
 #define SO_PEERPIDFD		77
 
+/* Socket option for Offload to kernel */
+#define SO_OFFLOAD		95
+
 #if !defined(__KERNEL__)
 
 #if __BITS_PER_LONG == 64 || (defined(__x86_64__) && defined(__ILP32__))
diff --git a/net/core/sock.c b/net/core/sock.c
index 777aea65a30f..1e6ee4e6b33c 100644
--- a/net/core/sock.c
+++ b/net/core/sock.c
@@ -1564,6 +1564,18 @@ int sk_setsockopt(struct sock *sk, int level, int optname,
 		WRITE_ONCE(sk->sk_txrehash, (u8)val);
 		break;
 
+	case SO_OFFLOAD:
+		if (val < 0 || val > 7) {
+			ret = -EPERM;
+			break;
+		}
+
+		if (val)
+			sk->offload_appid = val;
+
+		sk->offload = val ? 1 : 0;
+		break;
+
 	default:
 		ret = -ENOPROTOOPT;
 		break;
@@ -2019,6 +2031,10 @@ int sk_getsockopt(struct sock *sk, int level, int optname,
 		v.val = READ_ONCE(sk->sk_txrehash);
 		break;
 
+	case SO_OFFLOAD:
+		v.val = sk->offload ? sk->offload_appid : 0;
+		break;
+
 	default:
 		/* We implement the SO_SNDLOWAT etc to not be settable
 		 * (1003.1g 7).
-- 
2.34.1

