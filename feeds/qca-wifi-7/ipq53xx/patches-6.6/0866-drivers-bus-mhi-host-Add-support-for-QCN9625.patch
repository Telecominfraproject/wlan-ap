From fdbf36315ef8bd3547b61b2f68153ce1ab78bd2d Mon Sep 17 00:00:00 2001
From: Vignesh Viswanathan <quic_viswanat@quicinc.com>
Date: Thu, 13 Mar 2025 17:01:03 +0530
Subject: [PATCH] drivers: bus: mhi: host: Add support for QCN9625

Add support for QCN9625 and simplify common checks between QCN9224 and
QCN9625.

Also add some debugs in pcie-ep driver for phy link up check for
QCN9624.

Change-Id: I479a4e3b37ee295626dce8ec9cbe63c1590cb4a3
Signed-off-by: Vignesh Viswanathan <quic_viswanat@quicinc.com>
---
 drivers/bus/mhi/host/boot.c                  |  2 +-
 drivers/bus/mhi/host/internal.h              | 10 ++++++++--
 drivers/pci/controller/dwc/pcie-designware.c |  2 +-
 3 files changed, 10 insertions(+), 4 deletions(-)

diff --git a/drivers/bus/mhi/host/boot.c b/drivers/bus/mhi/host/boot.c
index e7881c2cba63..22d2c162183d 100644
--- a/drivers/bus/mhi/host/boot.c
+++ b/drivers/bus/mhi/host/boot.c
@@ -662,7 +662,7 @@ int mhi_download_amss_image(struct mhi_controller *mhi_cntrl)
 		return ret;
 	}
 
-	if (IS_QCN9224_DEV(mhi_cntrl)) {
+	if (IS_LICENSE_DOWN_REQ(mhi_cntrl)) {
 		/* Download the License */
 		mhi_download_fw_license(mhi_cntrl);
 	}
diff --git a/drivers/bus/mhi/host/internal.h b/drivers/bus/mhi/host/internal.h
index cc4e552ad00b..c5a28d4046c6 100644
--- a/drivers/bus/mhi/host/internal.h
+++ b/drivers/bus/mhi/host/internal.h
@@ -15,8 +15,9 @@ extern struct bus_type mhi_bus_type;
 #define MHI_SOC_RESET_REQ_OFFSET			0xb0
 #define MHI_SOC_RESET_REQ				BIT(0)
 
-#define QCN9224_FAMILY_NUM				(0x4)
+#define QCN9XXX_FAMILY_NUM				(0x4)
 #define QCN9224_DEVICE_NUM				(0x1A)
+#define QCN9625_DEVICE_NUM				(0x47)
 #define SOC_HW_VERSION_OFFS				0x224
 #define SOC_HW_VERSION_FAM_NUM_BMSK			GENMASK(31, 28)
 #define SOC_HW_VERSION_DEV_NUM_BMSK			GENMASK(27, 16)
@@ -26,9 +27,14 @@ extern struct bus_type mhi_bus_type;
 #define QCN9224_SOC_HW_VERSION_MINOR_VER_BMSK		GENMASK(7, 4)
 
 #define IS_QCN9224_DEV(mhi_cntrl) \
-	((mhi_cntrl->family_number == QCN9224_FAMILY_NUM && \
+	((mhi_cntrl->family_number == QCN9XXX_FAMILY_NUM && \
 	  mhi_cntrl->device_number == QCN9224_DEVICE_NUM) ? true : false)
 
+#define IS_LICENSE_DOWN_REQ(mhi_cntrl) \
+	((mhi_cntrl->family_number == QCN9XXX_FAMILY_NUM && \
+	  ((mhi_cntrl->device_number == QCN9224_DEVICE_NUM) || \
+	   (mhi_cntrl->device_number == QCN9625_DEVICE_NUM))) ? true : false)
+
 struct mhi_ctxt {
 	struct mhi_event_ctxt *er_ctxt;
 	struct mhi_chan_ctxt *chan_ctxt;
diff --git a/drivers/pci/controller/dwc/pcie-designware.c b/drivers/pci/controller/dwc/pcie-designware.c
index daa7c2f151b1..93cd92ac41f7 100644
--- a/drivers/pci/controller/dwc/pcie-designware.c
+++ b/drivers/pci/controller/dwc/pcie-designware.c
@@ -679,7 +679,7 @@ int dw_pcie_wait_for_link(struct dw_pcie *pci)
 		usleep_range(LINK_WAIT_USLEEP_MIN, LINK_WAIT_USLEEP_MAX);
 	}
 
-	if (retries >= LINK_WAIT_MAX_RETRIES) {
+	if (retries >= max_link_retries) {
 		dev_info(pci->dev, "Phy link never came up\n");
 		return -ETIMEDOUT;
 	}
-- 
2.34.1

