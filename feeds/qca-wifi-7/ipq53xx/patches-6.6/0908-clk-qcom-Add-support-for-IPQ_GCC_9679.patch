From 2222c0170f3326ce4b10526812bbd83edf76eeeb Mon Sep 17 00:00:00 2001
From: Sridharan S N <sridharan.sn@oss.qualcomm.com>
Date: Wed, 28 May 2025 13:08:46 +0530
Subject: [PATCH] clk: qcom: Add support for IPQ_GCC_9679

Change-Id: I596e3722cd344eafbccee870c429e1618acbec4f
Signed-off-by: Sridharan S N <sridharan.sn@oss.qualcomm.com>
---
 drivers/clk/qcom/Kconfig  | 8 ++++++++
 drivers/clk/qcom/Makefile | 1 +
 2 files changed, 9 insertions(+)

diff --git a/drivers/clk/qcom/Kconfig b/drivers/clk/qcom/Kconfig
index 8951283f2337..795cc34e7ae2 100644
--- a/drivers/clk/qcom/Kconfig
+++ b/drivers/clk/qcom/Kconfig
@@ -224,6 +224,14 @@ config IPQ_GCC_9574
 	  i2c, USB, SD/eMMC, etc. Select this for the root clock
 	  of ipq9574.
 
+config IPQ_GCC_9679
+	tristate "IPQ9574 Global Clock Controller"
+	help
+	  Support for global clock controller on ipq9679 devices.
+	  Say Y if you want to use peripheral devices such as UART, SPI,
+	  i2c, USB, SD/eMMC, etc. Select this for the root clock
+	  of ipq9679.
+
 config IPQ_NSSCC_5332
         tristate "IPQ5332 NSS Clock Controller"
         depends on IPQ_GCC_5332
diff --git a/drivers/clk/qcom/Makefile b/drivers/clk/qcom/Makefile
index 23cb25473eae..3198c869f0b5 100644
--- a/drivers/clk/qcom/Makefile
+++ b/drivers/clk/qcom/Makefile
@@ -33,6 +33,7 @@ obj-$(CONFIG_IPQ_GCC_6018) += gcc-ipq6018.o
 obj-$(CONFIG_IPQ_GCC_806X) += gcc-ipq806x.o
 obj-$(CONFIG_IPQ_GCC_8074) += gcc-ipq8074.o
 obj-$(CONFIG_IPQ_GCC_9574) += gcc-ipq9574.o
+obj-$(CONFIG_IPQ_GCC_9679) += gcc-ipq9679.o
 obj-$(CONFIG_IPQ_NSSCC_5332) += nsscc-ipq5332.o
 obj-$(CONFIG_IPQ_NSSCC_5424) += nsscc-ipq5424.o
 obj-$(CONFIG_IPQ_NSSCC_9574) += nsscc-ipq9574.o
-- 
2.34.1

