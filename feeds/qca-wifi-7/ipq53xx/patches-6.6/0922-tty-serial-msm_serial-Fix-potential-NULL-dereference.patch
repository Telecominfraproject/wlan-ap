From 8460c479eafba435bf1e14078bc523374ddd3a6f Mon Sep 17 00:00:00 2001
From: Sridharan S N <sridsn@qti.qualcomm.com>
Date: Wed, 9 Jul 2025 17:01:06 +0530
Subject: [PATCH] tty: serial: msm_serial:  Fix potential NULL dereference in
 msm_complete_rx_dma()

This patch caches the character from dma->virt[i] into a local
variable before releasing the spinlock, ensuring safe access during uart_handle_sysrq_char() and tty_insert_flip_char() calls.

Call trace:
 msm_complete_rx_dma+0x2cc/0x358
 vchan_complete+0x1e0/0x248
 tasklet_action_common.constprop.0+0xc0/0x120
 tasklet_action+0x24/0x2c
 __do_softirq+0x1c0/0x224
 irq_exit+0x58/0x6c
 __handle_domain_irq+0x7c/0xb0
 gic_handle_irq+0x74/0xbc
 el1_irq+0xb8/0x140
 arch_cpu_idle+0x10/0x18
 cpuidle_idle_call+0x2c/0x54
 do_idle+0xb4/0xb8
 cpu_startup_entry+0x20/0x58
 rest_init+0xb0/0xbc
 arch_call_rest_init+0xc/0x14
 start_kernel+0x414/0x450
Code: 35ffff80 350003c1 35fff8e3 f9400ea0 (38776801)
---[ end trace 48672fd72a6a6653 ]---

Change-Id: Ia09548f368734f3b28431c5b98e55d6af8d1f9d1
Signed-off-by: Sridharan S N <sridsn@qti.qualcomm.com>
---
 drivers/tty/serial/msm_serial.c | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/drivers/tty/serial/msm_serial.c b/drivers/tty/serial/msm_serial.c
index 7629668d40dd..35d7b192c2bd 100644
--- a/drivers/tty/serial/msm_serial.c
+++ b/drivers/tty/serial/msm_serial.c
@@ -575,8 +575,9 @@ static void msm_complete_rx_dma(void *args)
 
 	for (i = 0; i < count; i++) {
 		char flag = TTY_NORMAL;
+		unsigned char ch = dma->virt[i];
 
-		if (msm_port->break_detected && dma->virt[i] == 0) {
+		if (msm_port->break_detected && ch == 0) {
 			port->icount.brk++;
 			flag = TTY_BREAK;
 			msm_port->break_detected = false;
@@ -588,10 +589,10 @@ static void msm_complete_rx_dma(void *args)
 			flag = TTY_NORMAL;
 
 		spin_unlock_irqrestore(&port->lock, flags);
-		sysrq = uart_handle_sysrq_char(port, dma->virt[i]);
+		sysrq = uart_handle_sysrq_char(port, ch);
 		spin_lock_irqsave(&port->lock, flags);
 		if (!sysrq)
-			tty_insert_flip_char(tport, dma->virt[i], flag);
+			tty_insert_flip_char(tport, ch, flag);
 	}
 
 	msm_start_rx_dma(msm_port);
-- 
