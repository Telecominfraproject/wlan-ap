From d56a1b8123f617b484add8cdb3c862193516d5f4 Mon Sep 17 00:00:00 2001
From: Ken Zhu <guigenz@qti.qualcomm.com>
Date: Fri, 16 May 2025 12:08:05 -0700
Subject: [PATCH] Revert "nft: the conn is not collected after use"

This reverts commit c51f19be402ba5e0b857f071070f5aa02154f181.

Change-Id: I878ff35daeeb5f56da403368b885825fbdbfb43c
Signed-off-by: Ken Zhu <guigenz@qti.qualcomm.com>
---
 net/netfilter/nft_connlimit.c | 11 -----------
 1 file changed, 11 deletions(-)

diff --git a/net/netfilter/nft_connlimit.c b/net/netfilter/nft_connlimit.c
index 24ae9dfdb4d1..de9d1980df69 100644
--- a/net/netfilter/nft_connlimit.c
+++ b/net/netfilter/nft_connlimit.c
@@ -43,17 +43,6 @@ static inline void nft_connlimit_do_eval(struct nft_connlimit *priv,
 		return;
 	}
 
-	local_bh_disable();
-	nf_conncount_gc_list(nft_net(pkt), priv->list);
-	local_bh_enable();
-
-	count = priv->list->count;
-
-	if ((count >= priv->limit) ^ priv->invert) {
-		regs->verdict.code = NFT_BREAK;
-		return;
-	}
-
 	if (nf_conncount_add(nft_net(pkt), priv->list, tuple_ptr, zone)) {
 		regs->verdict.code = NF_DROP;
 		return;
-- 
2.34.1

