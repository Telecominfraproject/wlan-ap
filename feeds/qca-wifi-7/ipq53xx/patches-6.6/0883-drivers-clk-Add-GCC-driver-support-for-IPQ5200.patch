From 3174002c446c442fca62d9ee7541dbd10203fc12 Mon Sep 17 00:00:00 2001
From: Timple Raj M <quic_timple@quicinc.com>
Date: Thu, 24 Apr 2025 01:54:02 +0530
Subject: [PATCH] drivers: clk: Add GCC driver support for IPQ5200

This patch adds the GCC clock driver support for IPQ5200

Change-Id: Id59f53ba68ada8241d5d605741a0b04986a687dc
Signed-off-by: Timple Raj M <quic_timple@quicinc.com>
---
 drivers/clk/qcom/Kconfig  | 7 +++++++
 drivers/clk/qcom/Makefile | 1 +
 2 files changed, 8 insertions(+)

diff --git a/drivers/clk/qcom/Kconfig b/drivers/clk/qcom/Kconfig
index e41332cffac1..8951283f2337 100644
--- a/drivers/clk/qcom/Kconfig
+++ b/drivers/clk/qcom/Kconfig
@@ -161,6 +161,13 @@ config IPQ_GCC_5018
 	  Say Y if you want to use peripheral devices such as UART, SPI,
 	  i2c, USB, SD/eMMC, etc.
 
+config IPQ_GCC_5200
+	tristate "IPQ5200 Global Clock Controller"
+	help
+	  Support for the global clock controller on ipq5200 devices.
+	  Say Y if you want to use peripheral devices such as UART, SPI,
+	  i2c, USB, SD/eMMC, etc.
+
 config IPQ_GCC_5332
 	tristate "IPQ5332 Global Clock Controller"
 	help
diff --git a/drivers/clk/qcom/Makefile b/drivers/clk/qcom/Makefile
index d3a643348755..23cb25473eae 100644
--- a/drivers/clk/qcom/Makefile
+++ b/drivers/clk/qcom/Makefile
@@ -28,6 +28,7 @@ obj-$(CONFIG_IPQ_GCC_4019) += gcc-ipq4019.o
 obj-$(CONFIG_IPQ_GCC_5018) += gcc-ipq5018.o
 obj-$(CONFIG_IPQ_GCC_5332) += gcc-ipq5332.o
 obj-$(CONFIG_IPQ_GCC_5424) += gcc-ipq5424.o
+obj-$(CONFIG_IPQ_GCC_5200) += gcc-ipq5200.o
 obj-$(CONFIG_IPQ_GCC_6018) += gcc-ipq6018.o
 obj-$(CONFIG_IPQ_GCC_806X) += gcc-ipq806x.o
 obj-$(CONFIG_IPQ_GCC_8074) += gcc-ipq8074.o
-- 
2.34.1

