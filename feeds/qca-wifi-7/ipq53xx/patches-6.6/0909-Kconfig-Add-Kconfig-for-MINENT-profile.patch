From d3c527ac6af9f9100ce17049b9c46b7050340481 Mon Sep 17 00:00:00 2001
From: Pritam Jha <quic_pritamku@quicinc.com>
Date: Fri, 11 Apr 2025 18:31:07 +0530
Subject: [PATCH] Kconfig: Add Kconfig for MINENT profile

- Add Kconfig IPQ_PROFILE_MINENT to differentiate MINENT
profile, this is required to enable/disable UBI.
- Add __IPQ_PROFILE_MINENT__ device tree flag to build
the necessary DTS property.

Change-Id: I6d697a9366645167e9101d27c9d545d9786c2ede
Signed-off-by: Pritam Jha <quic_pritamku@quicinc.com>
---
 arch/arm/mach-qcom/Kconfig | 7 +++++++
 arch/arm64/Kconfig         | 7 +++++++
 scripts/Makefile.lib       | 4 ++++
 3 files changed, 18 insertions(+)

diff --git a/arch/arm/mach-qcom/Kconfig b/arch/arm/mach-qcom/Kconfig
index 25ec3aee424a..e4b149a01192 100644
--- a/arch/arm/mach-qcom/Kconfig
+++ b/arch/arm/mach-qcom/Kconfig
@@ -74,4 +74,11 @@ config IO_COHERENCY
 	help
 	  Enable/Disable IO Coherency for kernel modules.
 
+config IPQ_PROFILE_MINENT
+	bool "Select minent build profile"
+	default n
+	help
+	  Enable/Disable MINENT profile. Based on this UBI is enabled
+	  or disabled in device tree.
+
 endif
diff --git a/arch/arm64/Kconfig b/arch/arm64/Kconfig
index e4964161cd95..c529c116a060 100644
--- a/arch/arm64/Kconfig
+++ b/arch/arm64/Kconfig
@@ -2280,6 +2280,13 @@ config IO_COHERENCY
 	help
 	  Enable/Disable IO Coherency for kernel modules.
 
+config IPQ_PROFILE_MINENT
+	bool "Select minent build profile"
+	default n
+	help
+	  Enable/Disable MINENT profile. Based on this UBI is enabled
+	  or disabled in device tree.
+
 endmenu # "Kernel Features"
 
 menu "Boot options"
diff --git a/scripts/Makefile.lib b/scripts/Makefile.lib
index a7fcb5c3aaf4..dc7f1fd71894 100644
--- a/scripts/Makefile.lib
+++ b/scripts/Makefile.lib
@@ -285,6 +285,10 @@ ifeq ($(CONFIG_PCIE_QCOM_EARLY_CAL_SUPPORT),y)
 dtc_cpp_flags += -D __PCIE_QCOM_EARLY_CAL_SUPPORT__
 endif
 
+ifeq ($(CONFIG_IPQ_PROFILE_MINENT),y)
+dtc_cpp_flags += -D __IPQ_PROFILE_MINENT__
+endif
+
 ifdef CONFIG_OBJTOOL
 
 objtool := $(objtree)/tools/objtool/objtool
-- 
2.34.1

