From bf7d24e75f9428d94a5aacd5b0ef39635816faee Mon Sep 17 00:00:00 2001
From: Devi Priya <quic_devipriy@quicinc.com>
Date: Tue, 9 Sep 2025 15:33:39 +0530
Subject: [PATCH] i2c: qcom-geni: update the counter values to fix I2C timing
 parameters

Update the I2C counter values corresponding to standard mode
in geni_i2c_clk_map_32mhz table to meet the (setup/hold) timing
spec requirements.

Change-Id: Ica8156ba75f5f409caada73f54d07e6233397849
Signed-off-by: Devi Priya <quic_devipriy@quicinc.com>
---
 drivers/i2c/busses/i2c-qcom-geni.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/i2c/busses/i2c-qcom-geni.c b/drivers/i2c/busses/i2c-qcom-geni.c
index a114967f2972..c60925d6b685 100644
--- a/drivers/i2c/busses/i2c-qcom-geni.c
+++ b/drivers/i2c/busses/i2c-qcom-geni.c
@@ -156,7 +156,7 @@ static const struct geni_i2c_clk_fld geni_i2c_clk_map_19p2mhz[] = {
 
 /* source_clock = 32 MHz */
 static const struct geni_i2c_clk_fld geni_i2c_clk_map_32mhz[] = {
-       {KHZ(100), 8, 14, 18, 38},
+       {KHZ(100), 12, 9, 10, 25},
        {KHZ(400), 4,  3,  9, 19},
        {KHZ(1000), 2, 3,  5, 15},
        {},
-- 
2.34.1

