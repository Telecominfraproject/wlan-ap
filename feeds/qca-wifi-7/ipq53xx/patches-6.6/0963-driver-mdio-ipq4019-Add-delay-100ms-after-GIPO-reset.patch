From 1d68cea436b1be75b72ce4b0e51a41e622d48e39 Mon Sep 17 00:00:00 2001
From: Luo Jie <luoj@qti.qualcomm.com>
Date: Mon, 12 Jan 2026 10:42:29 +0800
Subject: [PATCH] driver: mdio: ipq4019: Add delay 100ms after GIPO reset

Change-Id: Ie7c6cea54d013a4a6bb362b5f0aa69ed6c3d0755
Signed-off-by: Luo Jie <luoj@qti.qualcomm.com>
---
 drivers/net/mdio/mdio-ipq4019.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/net/mdio/mdio-ipq4019.c b/drivers/net/mdio/mdio-ipq4019.c
index 8acedd556c99..879035991d0a 100644
--- a/drivers/net/mdio/mdio-ipq4019.c
+++ b/drivers/net/mdio/mdio-ipq4019.c
@@ -931,6 +931,8 @@ static int ipq_mdio_reset(struct mii_bus *bus)
 		gpiod_set_array_value_cansleep(priv->reset_gpios->ndescs, priv->reset_gpios->desc,
 				priv->reset_gpios->info, values);
 		bitmap_free(values);
+
+		fsleep(IPQ_PHY_SET_DELAY_US);
 	}
 
 	/* Configure MDIO clock source frequency if clock is specified in the device tree */
-- 
2.34.1

