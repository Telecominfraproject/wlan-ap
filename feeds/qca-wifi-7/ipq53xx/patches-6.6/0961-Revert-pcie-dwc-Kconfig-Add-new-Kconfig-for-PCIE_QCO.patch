From 1b9e171369d79e128030333568bc13e0582f3abe Mon Sep 17 00:00:00 2001
From: Vignesh Viswanathan <viswanat@qti.qualcomm.com>
Date: Thu, 27 Nov 2025 16:48:00 +0530
Subject: [PATCH] Revert "pcie: dwc: Kconfig: Add new Kconfig for
 PCIE_QCOM_EARLY_CAL_SUPPORT"

This flag is no longer used in DTS. Remove this from Makefile.lib

This reverts commit c5acdafe60a6ca33603fe583b22127c148500db8.

Change-Id: Icecc1d5d65d9622967e2d8f0cb939b5cf40a360a
Signed-off-by: Vignesh Viswanathan <viswanat@qti.qualcomm.com>
---
 drivers/pci/controller/dwc/Kconfig | 7 -------
 scripts/Makefile.lib               | 4 ----
 2 files changed, 11 deletions(-)

diff --git a/drivers/pci/controller/dwc/Kconfig b/drivers/pci/controller/dwc/Kconfig
index 29f5ed10b031..07f4a49194a6 100644
--- a/drivers/pci/controller/dwc/Kconfig
+++ b/drivers/pci/controller/dwc/Kconfig
@@ -284,13 +284,6 @@ config PCIE_QCOM
 	  PCIe controller uses the DesignWare core plus Qualcomm-specific
 	  hardware wrappers.
 
-config PCIE_QCOM_EARLY_CAL_SUPPORT
-	bool "Qualcomm PCIe Early Calibration Support"
-	depends on PCIE_QCOM
-	default n
-	help
-	  Say Y here if Early Calibration for PCIe EPs is supported in uboot.
-
 config PCIE_QCOM_EP
 	tristate "Qualcomm PCIe controller (endpoint mode)"
 	depends on OF && (ARCH_QCOM || COMPILE_TEST)
diff --git a/scripts/Makefile.lib b/scripts/Makefile.lib
index f5e41d587f9b..b55b1caf0da8 100644
--- a/scripts/Makefile.lib
+++ b/scripts/Makefile.lib
@@ -281,10 +281,6 @@ ifeq ($(CONFIG_DEBUG),y)
 dtc_cpp_flags += -D __CONFIG_DEBUG__
 endif
 
-ifeq ($(CONFIG_PCIE_QCOM_EARLY_CAL_SUPPORT),y)
-dtc_cpp_flags += -D __PCIE_QCOM_EARLY_CAL_SUPPORT__
-endif
-
 ifeq ($(CONFIG_IPQ_PROFILE_MINENT),y)
 dtc_cpp_flags += -D __IPQ_PROFILE_MINENT__
 endif
-- 
2.34.1

