From cd12f6d70a7890cb87e11539ba397bd4f9d8b38d Mon Sep 17 00:00:00 2001
From: Sneha Maganahalli <quic_smaganah@quicinc.com>
Date: Wed, 22 Jan 2025 09:59:52 +0530
Subject: [PATCH] net: Do not initialize global fast tc filter variable as
 false

Global variables doesn't need to be initialized as false/zero/NULL.

Change-Id: I34739f11bf9836d0e860eab38fcefeda642592c4
Signed-off-by: Sneha Maganahalli <quic_smaganah@quicinc.com>
---
 net/core/dev.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/net/core/dev.c b/net/core/dev.c
index f24768e5a7ce..243f31cf8ef0 100644
--- a/net/core/dev.c
+++ b/net/core/dev.c
@@ -2068,7 +2068,10 @@ static int call_netdevice_notifiers_mtu(unsigned long val,
 	return call_netdevice_notifiers_info(val, &info.info);
 }
 
-bool fast_tc_filter = false;
+/*
+ *	By default Fast TC Filter will be disabled.
+ */
+bool fast_tc_filter;
 EXPORT_SYMBOL_GPL(fast_tc_filter);
 
 #ifdef CONFIG_NET_INGRESS
-- 
2.34.1

