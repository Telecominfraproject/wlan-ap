From 33d23d5b99d963df2e42163dbd46f95bb85bd616 Mon Sep 17 00:00:00 2001
From: Sridharan S N <sridsn@qti.qualcomm.com>
Date: Wed, 6 Aug 2025 10:22:42 +0530
Subject: [PATCH] pcie: qcom: Add PCIe support for IPQ96xx chipset

This patch adds the PCIe support for the IPQ96xx
chipset

Change-Id: I401712269a0b7e38207f8fa2c0eed2b3c1a809b2
Signed-off-by: Sridharan S N <sridsn@qti.qualcomm.com>
---
 drivers/pci/controller/dwc/pcie-qcom.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/pci/controller/dwc/pcie-qcom.c b/drivers/pci/controller/dwc/pcie-qcom.c
index bedfddd21588..da205b56470f 100644
--- a/drivers/pci/controller/dwc/pcie-qcom.c
+++ b/drivers/pci/controller/dwc/pcie-qcom.c
@@ -2315,6 +2315,7 @@ static const struct of_device_id qcom_pcie_match[] = {
 	{ .compatible = "qcom,pcie-ipq8074", .data = &cfg_2_3_3 },
 	{ .compatible = "qcom,pcie-ipq8074-gen3", .data = &cfg_2_9_0 },
 	{ .compatible = "qti,pcie-ipq9574", .data = &cfg_1_27_0 },
+	{ .compatible = "qcom,pcie-ipq9679", .data = &cfg_1_27_0 },
 	{ .compatible = "qcom,pcie-msm8996", .data = &cfg_2_3_2 },
 	{ .compatible = "qcom,pcie-qcs404", .data = &cfg_2_4_0 },
 	{ .compatible = "qcom,pcie-sa8540p", .data = &cfg_1_9_0 },
