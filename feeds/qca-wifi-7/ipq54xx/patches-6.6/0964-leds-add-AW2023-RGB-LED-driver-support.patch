From a086f013c5b9583fc8628e8cbbcf695337753a77 Mon Sep 17 00:00:00 2001
From: guoxijun <guoxijun@cigtech.com>
Date: Fri, 15 May 2026 11:03:38 +0800
Subject: [PATCH] leds: add AW2023 RGB LED driver support

Add Kconfig option and Makefile entry for the AW2023 RGB LED
driver. The AW2023 is a 3-channel RGB LED controller connected
via I2C.

Signed-off-by: guoxijun <guoxijun@cigtech.com>
---
 drivers/leds/Kconfig  | 6 ++++++
 drivers/leds/Makefile | 1 +
 2 files changed, 7 insertions(+)

diff --git a/drivers/leds/Kconfig b/drivers/leds/Kconfig
index da8d1a9..37ed32b 100755
--- a/drivers/leds/Kconfig
+++ b/drivers/leds/Kconfig
@@ -118,6 +118,12 @@ config LEDS_AW2013
 	  To compile this driver as a module, choose M here: the module
 	  will be called leds-aw2013.
 
+config LEDS_AW2023
+	tristate "LED Support for AW2023"
+	depends on LEDS_CLASS && I2C
+	help
+	  This option enables support for the AW2023 RGB LED connected
+	  through I2C. Say Y to enable support for the AW2023 LED
 
 config LEDS_BCM6328
 	tristate "LED Support for Broadcom BCM6328"
diff --git a/drivers/leds/Makefile b/drivers/leds/Makefile
index d7348e8..8cb97c2 100755
--- a/drivers/leds/Makefile
+++ b/drivers/leds/Makefile
@@ -16,6 +16,7 @@ obj-$(CONFIG_LEDS_APU)			+= leds-apu.o
 obj-$(CONFIG_LEDS_ARIEL)		+= leds-ariel.o
 obj-$(CONFIG_LEDS_AW200XX)		+= leds-aw200xx.o
 obj-$(CONFIG_LEDS_AW2013)		+= leds-aw2013.o
+obj-$(CONFIG_LEDS_AW2023)		+= leds-aw2023.o
 obj-$(CONFIG_LEDS_BCM6328)		+= leds-bcm6328.o
 obj-$(CONFIG_LEDS_BCM6358)		+= leds-bcm6358.o
 obj-$(CONFIG_LEDS_BD2606MVV)		+= leds-bd2606mvv.o
-- 
2.34.1

