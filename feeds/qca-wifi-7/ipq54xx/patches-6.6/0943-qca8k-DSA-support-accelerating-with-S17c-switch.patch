From 381506bdfc38a9a12815b8d25613822a34548da9 Mon Sep 17 00:00:00 2001
From: qiangqiang cheng <qiangqia@qti.qualcomm.com>
Date: Mon, 1 Sep 2025 17:43:36 +0800
Subject: [PATCH] [qca8k]: DSA support accelerating with S17c switch

Change-Id: If03cf9fbe4099d2db11a782293ea349d14d9622f
Signed-off-by: qiangqiang cheng <qiangqia@qti.qualcomm.com>
---
 drivers/net/dsa/qca/qca8k-8xxx.c | 23 +++++++++--------------
 drivers/net/dsa/qca/qca8k.h      |  2 ++
 2 files changed, 11 insertions(+), 14 deletions(-)

diff --git a/drivers/net/dsa/qca/qca8k-8xxx.c b/drivers/net/dsa/qca/qca8k-8xxx.c
index c8ecb7ac58b4..76ce870d5ecc 100644
--- a/drivers/net/dsa/qca/qca8k-8xxx.c
+++ b/drivers/net/dsa/qca/qca8k-8xxx.c
@@ -359,13 +359,11 @@ qca8k_read_mii(struct qca8k_priv *priv, uint32_t reg, uint32_t *val)
 
 	mutex_lock_nested(&bus->mdio_lock, MDIO_MUTEX_NESTED);
 
-	ret = qca8k_set_page(priv, page);
-	if (ret < 0)
-		goto exit;
-
+	bus->write(bus, 0x18, 0, page);
+	udelay(100);
 	ret = qca8k_mii_read32(bus, 0x10 | r2, r1, val);
+	bus->write(bus, 0x18, 0, HIGH_ADDR_DFLT);
 
-exit:
 	mutex_unlock(&bus->mdio_lock);
 	return ret;
 }
@@ -401,13 +399,11 @@ qca8k_write_mii(struct qca8k_priv *priv, uint32_t reg, uint32_t val)
 
 	mutex_lock_nested(&bus->mdio_lock, MDIO_MUTEX_NESTED);
 
-	ret = qca8k_set_page(priv, page);
-	if (ret < 0)
-		goto exit;
-
+	bus->write(bus, 0x18, 0, page);
+	udelay(100);
 	qca8k_mii_write32(bus, 0x10 | r2, r1, val);
+	bus->write(bus, 0x18, 0, HIGH_ADDR_DFLT);
 
-exit:
 	mutex_unlock(&bus->mdio_lock);
 	return ret;
 }
@@ -455,10 +451,8 @@ qca8k_regmap_update_bits_mii(struct qca8k_priv *priv, uint32_t reg,
 
 	mutex_lock_nested(&bus->mdio_lock, MDIO_MUTEX_NESTED);
 
-	ret = qca8k_set_page(priv, page);
-	if (ret < 0)
-		goto exit;
-
+	bus->write(bus, 0x18, 0, page);
+	udelay(100);
 	ret = qca8k_mii_read32(bus, 0x10 | r2, r1, &val);
 	if (ret < 0)
 		goto exit;
@@ -466,6 +460,7 @@ qca8k_regmap_update_bits_mii(struct qca8k_priv *priv, uint32_t reg,
 	val &= ~mask;
 	val |= write_val;
 	qca8k_mii_write32(bus, 0x10 | r2, r1, val);
+	bus->write(bus, 0x18, 0, HIGH_ADDR_DFLT);
 
 exit:
 	mutex_unlock(&bus->mdio_lock);
diff --git a/drivers/net/dsa/qca/qca8k.h b/drivers/net/dsa/qca/qca8k.h
index 79d780972786..e294f43d782a 100644
--- a/drivers/net/dsa/qca/qca8k.h
+++ b/drivers/net/dsa/qca/qca8k.h
@@ -43,6 +43,8 @@
 #define QCA8K_HDR_TYPE_2B				0
 #define QCA8K_HDR_TYPE_4B				1
 
+#define HIGH_ADDR_DFLT	0x200
+
 /* Global control registers */
 #define QCA8K_REG_MASK_CTRL				0x000
 #define   QCA8K_MASK_CTRL_REV_ID_MASK			GENMASK(7, 0)
-- 
2.34.1

