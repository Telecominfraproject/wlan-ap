From c3178b968595df44c1a3f09ec2c3561e43b06883 Mon Sep 17 00:00:00 2001
From: Sridharan S N <sridsn@qti.qualcomm.com>
Date: Thu, 9 Oct 2025 16:35:33 +0530
Subject: [PATCH] mm: kfence: Update the MEM_PROFILE specific condition

Ignore sample_interval from kernel config CONFIG_KFENCE_SAMPLE_INTERVAL for Low-mem profiles.

Fixes: 7abf7929993e1 ("kfence: enable the kfence parameters by default")
Change-Id: I647744270f6fd139ca51ddfb4febdd0be590c554
Signed-off-by: Sridharan S N <sridsn@qti.qualcomm.com>
(cherry picked from commit cb00cb61ebdeb1b4c78c7b71fdb6966b66e000e5)
---
 mm/kfence/core.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mm/kfence/core.c b/mm/kfence/core.c
index a1ef02b4b9ac..d057ee94d80d 100644
--- a/mm/kfence/core.c
+++ b/mm/kfence/core.c
@@ -57,7 +57,7 @@ static bool disabled_by_warn __read_mostly;
  * For LM512, KFENCE can be enabled from bootargs.
  * For other profiles, KFENCE enabled by default.
  */
-#if ((CONFIG_IPQ_MEM_PROFILE != 512) || (CONFIG_IPQ_MEM_PROFILE != 256))
+#if (CONFIG_IPQ_MEM_PROFILE == 0)
 unsigned long kfence_sample_interval __read_mostly = CONFIG_KFENCE_SAMPLE_INTERVAL;
 #else
 unsigned long kfence_sample_interval __read_mostly;
-- 
2.34.1

