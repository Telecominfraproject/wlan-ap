From 49bca3bd6b052b1ab1f031ff4881d1577ff509b5 Mon Sep 17 00:00:00 2001
From: Timple Raj M <quic_timple@quicinc.com>
Date: Fri, 21 Mar 2025 16:43:42 +0530
Subject: [PATCH] drivers: pci: Add QCOM FPGA pci driver support

This patch adds the QCOM FPGA pci driver support to
access the FPGA via PCI

Change-Id: I815f7247d75a73495db2642987a6fa6c80afdaf2
Signed-off-by: Timple Raj M <quic_timple@quicinc.com>
---
 drivers/pci/Kconfig  | 7 +++++++
 drivers/pci/Makefile | 1 +
 2 files changed, 8 insertions(+)

diff --git a/drivers/pci/Kconfig b/drivers/pci/Kconfig
index bfd309bced9e..ddcc33209b8b 100644
--- a/drivers/pci/Kconfig
+++ b/drivers/pci/Kconfig
@@ -294,6 +294,13 @@ config VGA_ARB_MAX_GPUS
 	  Reserves space in the kernel to maintain resource locking for
 	  multiple GPUS.  The overhead for each GPU is very small.
 
+config QCOM_FPGA_PCI
+	tristate "Qualcomm FPGA PCIe driver"
+	depends on PCI
+	help
+	  Say Y here to enable Qualcomm FPGA PCIe driver.
+	  This driver enables the support to access the FPGA via PCI
+
 source "drivers/pci/hotplug/Kconfig"
 source "drivers/pci/controller/Kconfig"
 source "drivers/pci/endpoint/Kconfig"
diff --git a/drivers/pci/Makefile b/drivers/pci/Makefile
index cc8b4e01e29d..7b15a607ffcb 100644
--- a/drivers/pci/Makefile
+++ b/drivers/pci/Makefile
@@ -41,3 +41,4 @@ obj-y				+= controller/
 obj-y				+= switch/
 
 subdir-ccflags-$(CONFIG_PCI_DEBUG) := -DDEBUG
+obj-$(CONFIG_QCOM_FPGA_PCI)	+= qcom-fpga-pci.o
-- 
2.34.1

