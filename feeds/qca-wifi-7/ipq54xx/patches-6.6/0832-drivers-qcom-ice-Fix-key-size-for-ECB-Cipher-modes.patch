From 4275058399391f7da461d5bb4377a194c62c7c6a Mon Sep 17 00:00:00 2001
From: Vignesh Viswanathan <quic_viswanat@quicinc.com>
Date: Fri, 17 Jan 2025 16:21:40 +0530
Subject: [PATCH] drivers: qcom: ice: Fix key size for ECB Cipher modes

ECB cipher mode's key sizes was passed incorrectly leading to SCM call
failure.

Fix the ECB cipher mode's key sizes and also add print in case SCM call
fails.

Change-Id: I0b8d8a754c28a9e62790559a9c899d51b17e2b4d
Signed-off-by: Vignesh Viswanathan <quic_viswanat@quicinc.com>
---
 drivers/soc/qcom/ice.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/drivers/soc/qcom/ice.c b/drivers/soc/qcom/ice.c
index d265f77a37bf..13d33ebdd942 100644
--- a/drivers/soc/qcom/ice.c
+++ b/drivers/soc/qcom/ice.c
@@ -205,6 +205,10 @@ static int sdhci_msm_ice_set_hwkey_config(struct qcom_ice *ice,
 	}
 	ret = qcom_config_sec_ice(ice_settings, sizeof(struct ice_config_sec));
 	kfree(ice_settings);
+
+	if (ret)
+		dev_err(dev, "Failed to program ICE HW key: %d", ret);
+
 	return ret;
 }
 
@@ -252,10 +256,10 @@ static int qcom_ice_get_algo_mode(struct qcom_ice *ice, u8 algorithm_id,
 			return -EINVAL;
 		}
 		if (key_size == QCOM_ICE_CRYPTO_KEY_SIZE_256) {
-			*cipher = QCOM_SCM_ICE_CIPHER_AES_128_ECB;
+			*cipher = QCOM_SCM_ICE_CIPHER_AES_256_ECB;
 			*key_len = AES_256_CBC_KEY_SIZE;
 		} else {
-			*cipher = QCOM_SCM_ICE_CIPHER_AES_256_ECB;
+			*cipher = QCOM_SCM_ICE_CIPHER_AES_128_ECB;
 			*key_len = AES_128_CBC_KEY_SIZE;
 		}
 		break;
-- 
2.34.1

