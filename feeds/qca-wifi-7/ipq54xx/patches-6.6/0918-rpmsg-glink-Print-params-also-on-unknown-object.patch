From 3c6efc6746db96c3531ba54bf00e084dab409ca4 Mon Sep 17 00:00:00 2001
From: Manikanta Mylavarapu <mmanikan@qti.qualcomm.com>
Date: Wed, 9 Sep 2020 19:31:18 +0530
Subject: [PATCH] rpmsg: glink:  Print params also on unknown object

print param1 and param2 when the glink worker detects
the queued object as unknown. This will help identify if
the command is valid glink command or a random corruption.

Change-Id: I5809d479d72e305755dc44eb123cf05a3f91a9dc
Signed-off-by: Saravanan Jaganathan <sjaganat@codeaurora.org>
Signed-off-by: Sivaprakash Murugesan <sivaprak@codeaurora.org>
Signed-off-by: Manikanta Mylavarapu <mmanikan@qti.qualcomm.com>
---
 drivers/rpmsg/qcom_glink_native.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/drivers/rpmsg/qcom_glink_native.c b/drivers/rpmsg/qcom_glink_native.c
index 8598b51ca3b9..25750e4faf5f 100644
--- a/drivers/rpmsg/qcom_glink_native.c
+++ b/drivers/rpmsg/qcom_glink_native.c
@@ -1736,7 +1736,9 @@ static void qcom_glink_work(struct work_struct *work)
 			qcom_glink_handle_intent_req(glink, param1, param2);
 			break;
 		default:
-			WARN(1, "Unknown defer object %d\n", cmd);
+			WARN(1,
+			     "Unknown defer object cmd : %d, param1 : %d, param2 : %d\n",
+			     cmd, param1, param2);
 			break;
 		}
 
-- 
2.34.1

