From 1ffaaeb1a23e60d3c3ad144a56a44393259ffe7e Mon Sep 17 00:00:00 2001
From: Tushar Ganatra <quic_tganatra@quicinc.com>
Date: Fri, 21 Mar 2025 10:29:39 +0530
Subject: [PATCH] [netfilter] : fix linux kernel patch from openwrt

in openwrt target/linux/generic/pending-6.6/611-netfilter_match_bypass_default_table.patch
whcih is doing match bypass default table

This change addresses a race condition where the private table is not protected, which could lead to a crash.

Change-Id: I05b005845da13e834e594fcab26a734a9728b3cf
Signed-off-by: Tushar Ganatra <quic_tganatra@quicinc.com>
---
 net/ipv4/netfilter/ip_tables.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/net/ipv4/netfilter/ip_tables.c b/net/ipv4/netfilter/ip_tables.c
index 1dd98901a547..9859d1f27b16 100644
--- a/net/ipv4/netfilter/ip_tables.c
+++ b/net/ipv4/netfilter/ip_tables.c
@@ -294,6 +294,7 @@ ipt_do_table(void *priv,
 	/* Initialization */
 	WARN_ON(!(table->valid_hooks & (1 << hook)));
 	local_bh_disable();
+	addend = xt_write_recseq_begin();
 	private = READ_ONCE(table->private); /* Address dependency. */
 	cpu        = smp_processor_id();
 	table_base = private->entries;
@@ -304,6 +305,7 @@ ipt_do_table(void *priv,
 
 		counter = xt_get_this_cpu_counter(&e->counters);
 		ADD_COUNTER(*counter, skb->len, 1);
+		xt_write_recseq_end(addend);
 		local_bh_enable();
 		return verdict;
 	}
@@ -313,7 +315,6 @@ ipt_do_table(void *priv,
 	indev = state->in ? state->in->name : nulldevname;
 	outdev = state->out ? state->out->name : nulldevname;
 
-	addend = xt_write_recseq_begin();
 	jumpstack  = (struct ipt_entry **)private->jumpstack[cpu];
 
 	/* Switch to alternate jumpstack if we're being invoked via TEE.
-- 
2.34.1

