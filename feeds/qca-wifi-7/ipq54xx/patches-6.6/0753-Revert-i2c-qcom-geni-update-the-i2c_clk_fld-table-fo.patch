From afa8c6d16299cec1b0434cc29cbc2c847150634f Mon Sep 17 00:00:00 2001
From: Devi Priya <quic_devipriy@quicinc.com>
Date: Tue, 10 Dec 2024 09:54:49 +0530
Subject: [PATCH] Revert "i2c: qcom-geni: update the i2c_clk_fld table for
 32MHz"

This reverts commit 6a67dd4512a205a195821452f5db56e3658714e3.

Reason for revert: <Change to derive SCL clock from 32MHz source clock is picked from upstream>

Change-Id: I556e3776e26e3d58fe2e4bfff4a9c692362368b4
Signed-off-by: Devi Priya <quic_devipriy@quicinc.com>
---
 drivers/i2c/busses/i2c-qcom-geni.c | 16 +++-------------
 1 file changed, 3 insertions(+), 13 deletions(-)

diff --git a/drivers/i2c/busses/i2c-qcom-geni.c b/drivers/i2c/busses/i2c-qcom-geni.c
index 00317906f91b..43241a2e8b1a 100644
--- a/drivers/i2c/busses/i2c-qcom-geni.c
+++ b/drivers/i2c/busses/i2c-qcom-geni.c
@@ -145,21 +145,11 @@ struct geni_i2c_clk_fld {
  * time of full period of SCL: t_cycle = (t_cycle_cnt * clk_div) / source_clock
  * clk_freq_out = t / t_cycle
  * source_clock = 19.2 MHz
- *
- * static const struct geni_i2c_clk_fld geni_i2c_clk_map[] = {
- * 	{KHZ(100), 7, 10, 11, 26},
- * 	{KHZ(400), 2,  5, 12, 24},
- * 	{KHZ(1000), 1, 3,  9, 18},
- * };
-*/
-
-/*
- * source_clock = 32 MHz
  */
 static const struct geni_i2c_clk_fld geni_i2c_clk_map[] = {
-	{KHZ(100), 7, 14, 18, 40},
-	{KHZ(400), 4,  3, 11, 20},
-	{KHZ(1000), 4, 3,  6, 15},
+	{KHZ(100), 7, 10, 11, 26},
+	{KHZ(400), 2,  5, 12, 24},
+	{KHZ(1000), 1, 3,  9, 18},
 };
 
 static int geni_i2c_clk_map_idx(struct geni_i2c_dev *gi2c)
