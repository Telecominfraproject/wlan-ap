From 90b9aed35a8f2c139b230fe1e52cfc7d673dcbee Mon Sep 17 00:00:00 2001
From: Pritam Jha <quic_pritamku@quicinc.com>
Date: Tue, 18 Mar 2025 05:36:19 -0700
Subject: [PATCH] Revert "[tcrypt] AHASH changes for kernel"

This reverts commit 1a21c5913c52fc9812e0f18f88a3947f8f613208.

Reason for revert: Retain the test case under macro
and enable it for specific profile where supported.

Change-Id: I5d8ea4aee9944ef44956cc240bb7711ff0865169
Signed-off-by: Tushar Ganatra <quic_tganatra@quicinc.com>
Signed-off-by: Pritam Jha <quic_pritamku@quicinc.com>
---
 crypto/Kconfig   | 2 +-
 crypto/testmgr.c | 6 ++++++
 2 files changed, 7 insertions(+), 1 deletion(-)

diff --git a/crypto/Kconfig b/crypto/Kconfig
index 0b2e73417259..e32b6f33911e 100644
--- a/crypto/Kconfig
+++ b/crypto/Kconfig
@@ -256,7 +256,7 @@ config CRYPTO_DISABLE_AHASH_TYPE1_TESTS
 
 config CRYPTO_DISABLE_AHASH_TYPE2_TESTS
 	bool "Disable AHASH type 2 test cases"
-	default y
+	default n
 	help
 	  Disable AHASH type 2 tests
 
diff --git a/crypto/testmgr.c b/crypto/testmgr.c
index c322c588643e..ab869b53eb67 100644
--- a/crypto/testmgr.c
+++ b/crypto/testmgr.c
@@ -437,6 +437,11 @@ static const struct testvec_config default_hash_testvec_configs[] = {
 		.key_offset = 1,
 		.key_offset_relative_to_alignmask = true,
 	},
+#ifndef CONFIG_CRYPTO_DISABLE_AHASH_TYPE2_TESTS
+	/*
+	 * Update in testmgr requires the result back whereas HW hides result from the user
+	 * TODO : Require support for ahash multiple update
+	 */
 	{
 		.name = "init+update+update+final two even splits",
 		.src_divs = {
@@ -448,6 +453,7 @@ static const struct testvec_config default_hash_testvec_configs[] = {
 		},
 		.finalization_type = FINALIZATION_TYPE_FINAL,
 	},
+#endif
 	{
 		.name = "digest uneven misaligned splits, may sleep",
 		.req_flags = CRYPTO_TFM_REQ_MAY_SLEEP,
-- 
2.34.1

