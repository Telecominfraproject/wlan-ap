From 3b9f050d37ce51604824de38af689c032371ccb7 Mon Sep 17 00:00:00 2001
From: Sourav Poddar <quic_souravp@quicinc.com>
Date: Tue, 28 Jan 2025 19:24:02 +0530
Subject: [PATCH] [linux] Invoke debug object api before KASAN poisoning

Change-Id: I0fb62e43b6932614ecc0acc50a19754e3c9824fd
Signed-off-by: Sourav Poddar <quic_souravp@quicinc.com>
---
 net/core/skbuff.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/net/core/skbuff.c b/net/core/skbuff.c
index 1badb974d25c..35be0c8cd247 100644
--- a/net/core/skbuff.c
+++ b/net/core/skbuff.c
@@ -1662,8 +1662,8 @@ static void napi_skb_cache_put(struct sk_buff *skb)
 	struct napi_alloc_cache *nc = this_cpu_ptr(&napi_alloc_cache);
 	u32 i;
 
-	kasan_poison_object_data(skbuff_cache, skb);
 	skbuff_debugobj_deactivate(skb);
+	kasan_poison_object_data(skbuff_cache, skb);
 	nc->skb_cache[nc->skb_count++] = skb;
 
 	if (unlikely(nc->skb_count == NAPI_SKB_CACHE_SIZE)) {
-- 
2.34.1

