From 422685f122400d8a2aa30521c1a85fd9527295bd Mon Sep 17 00:00:00 2001
From: Sridharan S N <sridharan.sn@oss.qualcomm.com>
Date: Sun, 1 Jun 2025 13:05:18 +0530
Subject: [PATCH] pinctrl: qcom: Add build support for ipq9679 pinctrl driver

Change-Id: I6719d71a57d78c5a886a9abd6a0930206c1240de
Signed-off-by: Sridharan S N <sridharan.sn@oss.qualcomm.com>
---
 drivers/pinctrl/qcom/Kconfig.msm | 8 ++++++++
 drivers/pinctrl/qcom/Makefile    | 1 +
 2 files changed, 9 insertions(+)

diff --git a/drivers/pinctrl/qcom/Kconfig.msm b/drivers/pinctrl/qcom/Kconfig.msm
index d469f092204f..68b5b998ce2f 100644
--- a/drivers/pinctrl/qcom/Kconfig.msm
+++ b/drivers/pinctrl/qcom/Kconfig.msm
@@ -87,6 +87,14 @@ config PINCTRL_IPQ9574
           Qualcomm Technologies Inc. IPQ9574 platform. Select this for
           IPQ9574.
 
+config PINCTRL_IPQ9679
+	tristate "Qualcomm Technologies, Inc. IPQ9679 pin controller driver"
+	help
+	  This is the pinctrl, pinmux, pinconf and gpiolib driver for
+	  the Qualcomm Technologies Inc. TLMM block found on the
+	  Qualcomm Technologies Inc. IPQ9679 platform. Select this for
+	  IPQ9679.
+
 config PINCTRL_MSM8226
 	tristate "Qualcomm 8226 pin controller driver"
 	depends on ARM || COMPILE_TEST
diff --git a/drivers/pinctrl/qcom/Makefile b/drivers/pinctrl/qcom/Makefile
index b16443ec799c..989818a857da 100644
--- a/drivers/pinctrl/qcom/Makefile
+++ b/drivers/pinctrl/qcom/Makefile
@@ -12,6 +12,7 @@ obj-$(CONFIG_PINCTRL_IPQ5424)	+= pinctrl-ipq5424.o
 obj-$(CONFIG_PINCTRL_IPQ8074)	+= pinctrl-ipq8074.o
 obj-$(CONFIG_PINCTRL_IPQ6018)	+= pinctrl-ipq6018.o
 obj-$(CONFIG_PINCTRL_IPQ9574)	+= pinctrl-ipq9574.o
+obj-$(CONFIG_PINCTRL_IPQ9679)	+= pinctrl-ipq9679.o
 obj-$(CONFIG_PINCTRL_MSM8226)	+= pinctrl-msm8226.o
 obj-$(CONFIG_PINCTRL_MSM8660)	+= pinctrl-msm8660.o
 obj-$(CONFIG_PINCTRL_MSM8960)	+= pinctrl-msm8960.o
-- 
2.34.1

