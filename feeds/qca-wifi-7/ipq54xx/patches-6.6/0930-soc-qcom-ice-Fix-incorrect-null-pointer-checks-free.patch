From 69b8d52117b5e9f751a94bf45720fe51524c73d6 Mon Sep 17 00:00:00 2001
From: Poovendhan Selvaraj <poovendh@qti.qualcomm.com>
Date: Wed, 30 Jul 2025 12:26:01 +0530
Subject: [PATCH] soc: qcom: ice: Fix incorrect null pointer checks free

Update the corresponding kfree() call to free 'ice_settings'
instead of the incorrect 'ice' pointer in the default case.
These changes prevent potential null dereference during hw key configuration.

Change-Id: I28f545c38f1e008b761947b033f3d4bbc071f57c
Signed-off-by: Poovendhan Selvaraj <poovendh@qti.qualcomm.com>
---
 drivers/soc/qcom/ice.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/soc/qcom/ice.c b/drivers/soc/qcom/ice.c
index 13d33ebdd942..c0282d7dbb25 100644
--- a/drivers/soc/qcom/ice.c
+++ b/drivers/soc/qcom/ice.c
@@ -173,7 +173,7 @@ static int sdhci_msm_ice_set_hwkey_config(struct qcom_ice *ice,
 	int ret;
 
 	ice_settings = kzalloc(sizeof(struct ice_config_sec), GFP_KERNEL);
-	if (!ice)
+	if (!ice_settings)
 		return -ENOMEM;
 
 	switch (cipher) {
@@ -200,7 +200,7 @@ static int sdhci_msm_ice_set_hwkey_config(struct qcom_ice *ice,
 	default:
 		dev_err_ratelimited(dev, "Unhandled cipher for HW Key support;"
 					"cipher_id=%d\n", cipher);
-		kfree(ice);
+		kfree(ice_settings);
 		return -EINVAL;
 	}
 	ret = qcom_config_sec_ice(ice_settings, sizeof(struct ice_config_sec));
-- 
2.34.1

