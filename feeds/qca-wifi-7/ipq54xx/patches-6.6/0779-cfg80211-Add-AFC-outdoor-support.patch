From 676ec6ee1573d444be253d9b204ff94bb9f7d95c Mon Sep 17 00:00:00 2001
From: Shwetha G K <quic_kshwetha@quicinc.com>
Date: Fri, 6 Dec 2024 10:57:06 +0530
Subject: [PATCH] cfg80211: Add AFC outdoor support

Add AFC parameter in ap_settings to support AFC
outdoor feature. Driver to make use of this parameter
as part of start/stop ap to distinguish between AFC
intended start/stop or not.

Change-Id: I2bfc3d9e7785aad9556a6f3b5804ff00975641b6
Signed-off-by: Shwetha G K <quic_kshwetha@quicinc.com>
---
 include/net/cfg80211.h       | 2 ++
 include/uapi/linux/nl80211.h | 1 +
 net/wireless/ap.c            | 4 ++++
 net/wireless/nl80211.c       | 4 ++++
 4 files changed, 11 insertions(+)

diff --git a/include/net/cfg80211.h b/include/net/cfg80211.h
index 3dd25e1fa5d4..11da36ca087b 100644
--- a/include/net/cfg80211.h
+++ b/include/net/cfg80211.h
@@ -1371,6 +1371,7 @@ struct cfg80211_unsol_bcast_probe_resp {
  *	a 20 MHz channel, lowest bit corresponding to the lowest channel.
  *	Bit set to 1 indicates that the channel is punctured.
  * @reconfig: whether reconfiguration or not
+ * @afc: whether ap is start/stopped for afc or not
  */
 struct cfg80211_ap_settings {
 	struct cfg80211_chan_def chandef;
@@ -1407,6 +1408,7 @@ struct cfg80211_ap_settings {
 	struct cfg80211_mbssid_config mbssid_config;
 	u16 punct_bitmap;
 	bool reconfig;
+	bool afc;
 };
 
 /**
diff --git a/include/uapi/linux/nl80211.h b/include/uapi/linux/nl80211.h
index b35cd6001377..a9a9e2fdca22 100644
--- a/include/uapi/linux/nl80211.h
+++ b/include/uapi/linux/nl80211.h
@@ -3433,6 +3433,7 @@ enum nl80211_attrs {
 
 	NL80211_ATTR_RADIO_IFACE = 350,
 	NL80211_ATTR_MLO_AP_RECONFIG,
+	NL80211_ATTR_MLO_AP_AFC,
 
 	/* add attributes here, update the policy in nl80211.c */
 
diff --git a/net/wireless/ap.c b/net/wireless/ap.c
index e820e5421e31..1e809bba7167 100644
--- a/net/wireless/ap.c
+++ b/net/wireless/ap.c
@@ -35,6 +35,10 @@ static int ___cfg80211_stop_ap(struct cfg80211_registered_device *rdev,
 		params.reconfig =
 			nla_get_flag(info->attrs[NL80211_ATTR_MLO_AP_RECONFIG]);
 
+	if (info && info->attrs[NL80211_ATTR_MLO_AP_AFC])
+		params.afc =
+			nla_get_flag(info->attrs[NL80211_ATTR_MLO_AP_AFC]);
+
 	err = rdev_stop_ap(rdev, dev, link_id, &params);
 	if (!err) {
 		wdev->links[link_id].ap.beacon_interval = 0;
diff --git a/net/wireless/nl80211.c b/net/wireless/nl80211.c
index 712322554edc..f29ec1aec69b 100644
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -826,6 +826,7 @@ static const struct nla_policy nl80211_policy[NUM_NL80211_ATTR] = {
 	[NL80211_ATTR_AP_REMOVAL_COUNT] = { .type = NLA_U16 },
 	[NL80211_ATTR_TSF] = { .type = NLA_U64 },
 	[NL80211_ATTR_MLO_AP_RECONFIG] = { .type = NLA_FLAG },
+	[NL80211_ATTR_MLO_AP_AFC] = { .type = NLA_FLAG },
 };
 
 /* policy for the key attributes */
@@ -6165,6 +6166,9 @@ static int nl80211_start_ap(struct sk_buff *skb, struct genl_info *info)
 	if (info->attrs[NL80211_ATTR_MLO_AP_RECONFIG])
 		params->reconfig =
 			nla_get_flag(info->attrs[NL80211_ATTR_MLO_AP_RECONFIG]);
+	if (info->attrs[NL80211_ATTR_MLO_AP_AFC])
+		params->afc =
+			nla_get_flag(info->attrs[NL80211_ATTR_MLO_AP_AFC]);
 
 	err = cfg80211_validate_beacon_int(rdev, dev->ieee80211_ptr->iftype,
 					   params->beacon_interval);
-- 
2.34.1

