From d69f19e69315fcc54be76685121815515ee92d75 Mon Sep 17 00:00:00 2001
From: Poovendhan Selvaraj <quic_poovendh@quicinc.com>
Date: Fri, 13 Dec 2024 16:40:01 +0530
Subject: [PATCH] block2mtd : For exculssive access pass the block device
 holder

To enable exclusive access mode, pass the block device holder instead of NULL.

Change-Id: I08deb91afe052e5122160f0d9c1421cfcace0f12
Signed-off-by: Poovendhan Selvaraj <quic_poovendh@quicinc.com>
---
 drivers/mtd/devices/block2mtd.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/mtd/devices/block2mtd.c b/drivers/mtd/devices/block2mtd.c
index 3c6146dec684..5548827a2c06 100644
--- a/drivers/mtd/devices/block2mtd.c
+++ b/drivers/mtd/devices/block2mtd.c
@@ -228,7 +228,7 @@ static void block2mtd_free_device(struct block2mtd_dev *dev)
 	if (dev->blkdev) {
 		invalidate_mapping_pages(dev->blkdev->bd_inode->i_mapping,
 					0, -1);
-		blkdev_put(dev->blkdev, NULL);
+		blkdev_put(dev->blkdev, dev->blkdev->bd_holder);
 	}
 
 	kfree(dev);
-- 
2.34.1

