From a389bdb344e1ccf226c8f094017a0c173385b782 Mon Sep 17 00:00:00 2001
From: Saahil Tomar <saahtoma@qti.qualcomm.com>
Date: Tue, 30 Sep 2025 12:32:38 +0530
Subject: [PATCH] drivers: Remove support for IPQ9679 & IPQ5200

Change-Id: I19309c574d784238a8c1c4e1927de81d9db596a4
Signed-off-by: Saahil Tomar <saahtoma@qti.qualcomm.com>
---
 arch/arm/mach-qcom/Kconfig    |  4 ----
 drivers/clk/qcom/Kconfig      | 29 -----------------------------
 drivers/clk/qcom/Makefile     |  4 ----
 drivers/pinctrl/qcom/Makefile |  2 --
 4 files changed, 39 deletions(-)

diff --git a/arch/arm/mach-qcom/Kconfig b/arch/arm/mach-qcom/Kconfig
index 8a6773c1b0bd..e4b149a01192 100644
--- a/arch/arm/mach-qcom/Kconfig
+++ b/arch/arm/mach-qcom/Kconfig
@@ -21,10 +21,6 @@ config ARCH_IPQ5424
 	bool "Enable support for IPQ5424"
 	select ARM_GIC_V3
 
-config ARCH_IPQ9679
-	bool "Enable support for IPQ9679"
-	select ARM_GIC_V3
-
 config ARCH_MSM8X60
 	bool "Enable support for MSM8X60"
 	select CLKSRC_QCOM
diff --git a/drivers/clk/qcom/Kconfig b/drivers/clk/qcom/Kconfig
index 9e8a1e6f7e39..961f246ef4a6 100644
--- a/drivers/clk/qcom/Kconfig
+++ b/drivers/clk/qcom/Kconfig
@@ -161,13 +161,6 @@ config IPQ_GCC_5018
 	  Say Y if you want to use peripheral devices such as UART, SPI,
 	  i2c, USB, SD/eMMC, etc.
 
-config IPQ_GCC_5200
-	tristate "IPQ5200 Global Clock Controller"
-	help
-	  Support for the global clock controller on ipq5200 devices.
-	  Say Y if you want to use peripheral devices such as UART, SPI,
-	  i2c, USB, SD/eMMC, etc.
-
 config IPQ_GCC_5332
 	tristate "IPQ5332 Global Clock Controller"
 	help
@@ -224,20 +217,6 @@ config IPQ_GCC_9574
 	  i2c, USB, SD/eMMC, etc. Select this for the root clock
 	  of ipq9574.
 
-config IPQ_GCC_9679
-	tristate "IPQ9574 Global Clock Controller"
-	help
-	  Support for global clock controller on ipq9679 devices.
-	  Say Y if you want to use peripheral devices such as UART, SPI,
-	  i2c, USB, SD/eMMC, etc. Select this for the root clock
-	  of ipq9679.
-
-config IPQ_NSSCC_5200
-        tristate "IPQ5200 NSS Clock Controller"
-        depends on IPQ_GCC_5200
-        help
-          Support for NSS clock controller on ipq5200 devices.
-
 config IPQ_NSSCC_5332
         tristate "IPQ5332 NSS Clock Controller"
         depends on IPQ_GCC_5332
@@ -256,14 +235,6 @@ config IPQ_NSSCC_5424
         help
           Support for NSS clock controller on ipq5424 devices.
 
-config IPQ_NSSCC_9679
-	tristate "IPQ9679 NSS Clock Controller"
-	depends on IPQ_GCC_9679
-	help
-	  Support for NSS clock controller on ipq9679 devices.
-	  Say Y or M if you want to enable the Network SubSystem
-	  for the Ethernet functions.
-
 config MSM_GCC_8660
 	tristate "MSM8660 Global Clock Controller"
 	depends on ARM || COMPILE_TEST
diff --git a/drivers/clk/qcom/Makefile b/drivers/clk/qcom/Makefile
index f617ebc4d3c6..d3a643348755 100644
--- a/drivers/clk/qcom/Makefile
+++ b/drivers/clk/qcom/Makefile
@@ -28,17 +28,13 @@ obj-$(CONFIG_IPQ_GCC_4019) += gcc-ipq4019.o
 obj-$(CONFIG_IPQ_GCC_5018) += gcc-ipq5018.o
 obj-$(CONFIG_IPQ_GCC_5332) += gcc-ipq5332.o
 obj-$(CONFIG_IPQ_GCC_5424) += gcc-ipq5424.o
-obj-$(CONFIG_IPQ_GCC_5200) += gcc-ipq5200.o
 obj-$(CONFIG_IPQ_GCC_6018) += gcc-ipq6018.o
 obj-$(CONFIG_IPQ_GCC_806X) += gcc-ipq806x.o
 obj-$(CONFIG_IPQ_GCC_8074) += gcc-ipq8074.o
 obj-$(CONFIG_IPQ_GCC_9574) += gcc-ipq9574.o
-obj-$(CONFIG_IPQ_GCC_9679) += gcc-ipq9679.o
-obj-$(CONFIG_IPQ_NSSCC_5200) += nsscc-ipq5200.o
 obj-$(CONFIG_IPQ_NSSCC_5332) += nsscc-ipq5332.o
 obj-$(CONFIG_IPQ_NSSCC_5424) += nsscc-ipq5424.o
 obj-$(CONFIG_IPQ_NSSCC_9574) += nsscc-ipq9574.o
-obj-$(CONFIG_IPQ_NSSCC_9679) += nsscc-ipq9679.o
 obj-$(CONFIG_IPQ_LCC_806X) += lcc-ipq806x.o
 obj-$(CONFIG_MDM_GCC_9607) += gcc-mdm9607.o
 obj-$(CONFIG_MDM_GCC_9615) += gcc-mdm9615.o
diff --git a/drivers/pinctrl/qcom/Makefile b/drivers/pinctrl/qcom/Makefile
index 989818a857da..5c686d4c8ef3 100644
--- a/drivers/pinctrl/qcom/Makefile
+++ b/drivers/pinctrl/qcom/Makefile
@@ -6,13 +6,11 @@ obj-$(CONFIG_PINCTRL_APQ8084)	+= pinctrl-apq8084.o
 obj-$(CONFIG_PINCTRL_IPQ4019)	+= pinctrl-ipq4019.o
 obj-$(CONFIG_PINCTRL_IPQ5018)	+= pinctrl-ipq5018.o
 obj-$(CONFIG_PINCTRL_IPQ8064)	+= pinctrl-ipq8064.o
-obj-$(CONFIG_PINCTRL_IPQ5200)	+= pinctrl-ipq5200.o
 obj-$(CONFIG_PINCTRL_IPQ5332)	+= pinctrl-ipq5332.o
 obj-$(CONFIG_PINCTRL_IPQ5424)	+= pinctrl-ipq5424.o
 obj-$(CONFIG_PINCTRL_IPQ8074)	+= pinctrl-ipq8074.o
 obj-$(CONFIG_PINCTRL_IPQ6018)	+= pinctrl-ipq6018.o
 obj-$(CONFIG_PINCTRL_IPQ9574)	+= pinctrl-ipq9574.o
-obj-$(CONFIG_PINCTRL_IPQ9679)	+= pinctrl-ipq9679.o
 obj-$(CONFIG_PINCTRL_MSM8226)	+= pinctrl-msm8226.o
 obj-$(CONFIG_PINCTRL_MSM8660)	+= pinctrl-msm8660.o
 obj-$(CONFIG_PINCTRL_MSM8960)	+= pinctrl-msm8960.o
-- 
2.34.1

