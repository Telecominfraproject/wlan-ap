From 2e46ad60420e28efe9830dc797c63cf8094460d5 Mon Sep 17 00:00:00 2001
From: Vishnu Vardhan Bantanahal <vishvard@qti.qualcomm.com>
Date: Tue, 22 Jul 2025 15:34:27 +0530
Subject: [PATCH] net: Enabling various return values for SO_OFFLOAD option.

ret:  0 for successful offload enablement.
     -EINVAL for invalid app_id configuration.
     -ENOPKG when no subscriber registered to the notifier.
     -EPERM when enabling offload operation has failed.

Change-Id: Ie73975779443803bdea4bc656afba16e830649fa
Signed-off-by: Vishnu Vardhan Bantanahal <vishvard@qti.qualcomm.com>
---
 net/core/sock.c | 13 ++++++++++---
 1 file changed, 10 insertions(+), 3 deletions(-)

diff --git a/net/core/sock.c b/net/core/sock.c
index 81651667550a..433965f3dd89 100644
--- a/net/core/sock.c
+++ b/net/core/sock.c
@@ -1611,12 +1611,12 @@ int sk_setsockopt(struct sock *sk, int level, int optname,
 
 	case SO_OFFLOAD:
 		if (val < 0 || val > 7) {
-			ret = -EPERM;
+			ret = -EINVAL;
 			break;
 		}
 
 		if (val == sk->offload_appid) {
-			ret = -EPERM;
+			ret = -EINVAL;
 			break;
 		}
 
@@ -1630,7 +1630,14 @@ int sk_setsockopt(struct sock *sk, int level, int optname,
 			SOCK_OFFLOAD_NOTIFY, (void *)sk);
 		mutex_unlock(&sock_notifier.mutex);
 
-		ret = (ret == NOTIFY_OK) ? 0 : -EOPNOTSUPP;
+		if (ret == NOTIFY_OK) {
+			ret = 0;
+		} else if (ret == NOTIFY_DONE) {
+			ret = -ENOPKG;
+		} else if (ret == NOTIFY_BAD) {
+			ret = -EPERM;
+		}
+
 		if (ret) {
 			sk->offload_appid = 0;
 			sk->offload = 0;
-- 
2.34.1

