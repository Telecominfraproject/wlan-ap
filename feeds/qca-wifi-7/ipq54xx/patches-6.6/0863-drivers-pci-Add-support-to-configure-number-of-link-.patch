From dbd0434b42f3b502d1279d8e4a59514814b638e1 Mon Sep 17 00:00:00 2001
From: Vignesh Viswanathan <quic_viswanat@quicinc.com>
Date: Thu, 13 Mar 2025 23:24:36 +0530
Subject: [PATCH] drivers: pci: Add support to configure number of link retries

Currently during enumeration, link_retry_count is set to default of 10.
Make this configurable via devicetree so that while trying to enumerate
pre-silicon emulation platforms, link_retry_count can be set to a higher
number via devicetree.

Change-Id: Ia26c581016ffd29e161535b37eef365c20b5b41d
Signed-off-by: Selvam Sathappan Periakaruppan <speriaka@codeaurora.org>
Signed-off-by: Vignesh Viswanathan <quic_viswanat@quicinc.com>
---
 drivers/pci/controller/dwc/pcie-designware.c | 9 +++++++--
 drivers/pci/controller/dwc/pcie-designware.h | 1 +
 drivers/pci/controller/dwc/pcie-qcom.c       | 6 ++++++
 3 files changed, 14 insertions(+), 2 deletions(-)

diff --git a/drivers/pci/controller/dwc/pcie-designware.c b/drivers/pci/controller/dwc/pcie-designware.c
index d31aadddefdf..daa7c2f151b1 100644
--- a/drivers/pci/controller/dwc/pcie-designware.c
+++ b/drivers/pci/controller/dwc/pcie-designware.c
@@ -664,10 +664,15 @@ void dw_pcie_disable_atu(struct dw_pcie *pci, u32 dir, int index)
 int dw_pcie_wait_for_link(struct dw_pcie *pci)
 {
 	u32 offset, val;
-	int retries;
+	int retries, max_link_retries;
+
+	if (pci->link_retries_count)
+		max_link_retries = pci->link_retries_count;
+	else
+		max_link_retries = LINK_WAIT_MAX_RETRIES;
 
 	/* Check if the link is up or not */
-	for (retries = 0; retries < LINK_WAIT_MAX_RETRIES; retries++) {
+	for (retries = 0; retries < max_link_retries; retries++) {
 		if (dw_pcie_link_up(pci))
 			break;
 
diff --git a/drivers/pci/controller/dwc/pcie-designware.h b/drivers/pci/controller/dwc/pcie-designware.h
index 53a9a116bb9c..304fc8895ca4 100644
--- a/drivers/pci/controller/dwc/pcie-designware.h
+++ b/drivers/pci/controller/dwc/pcie-designware.h
@@ -389,6 +389,7 @@ struct dw_pcie {
 	void __iomem		*dbi_base2;
 	void __iomem		*atu_base;
 	size_t			atu_size;
+	u32			link_retries_count;
 	u32			num_ib_windows;
 	u32			num_ob_windows;
 	u32			region_align;
diff --git a/drivers/pci/controller/dwc/pcie-qcom.c b/drivers/pci/controller/dwc/pcie-qcom.c
index 7c7ec269a063..c5764421fbeb 100644
--- a/drivers/pci/controller/dwc/pcie-qcom.c
+++ b/drivers/pci/controller/dwc/pcie-qcom.c
@@ -1814,6 +1814,12 @@ static int qcom_pcie_probe(struct platform_device *pdev)
 				&num_lanes);
 	pcie->num_lanes = num_lanes;
 
+	of_property_read_u32(pdev->dev.of_node, "link_retries_count",
+			     &pci->link_retries_count);
+	if (pci->link_retries_count)
+		dev_info(dev, "pcie link_retries_count set to %d",
+			 pci->link_retries_count);
+
 	/* MHI region is optional */
 	res = platform_get_resource_byname(pdev, IORESOURCE_MEM, "mhi");
 	if (res) {
-- 
2.34.1

