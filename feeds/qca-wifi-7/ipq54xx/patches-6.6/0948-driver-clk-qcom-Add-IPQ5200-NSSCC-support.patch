From 71100332c308cfcf9d503fc297ea3859579b267c Mon Sep 17 00:00:00 2001
From: Luo Jie <luoj@qti.qualcomm.com>
Date: Thu, 31 Jul 2025 18:50:13 +0800
Subject: [PATCH] driver: clk: qcom: Add IPQ5200 NSSCC support

Change-Id: Ibcb1f94a73fdd2ed805455900f509dee89ac87aa
Signed-off-by: Luo Jie <luoj@qti.qualcomm.com>
---
 drivers/clk/qcom/Kconfig  | 6 ++++++
 drivers/clk/qcom/Makefile | 1 +
 2 files changed, 7 insertions(+)

diff --git a/drivers/clk/qcom/Kconfig b/drivers/clk/qcom/Kconfig
index 79a9d3efbf22..7d83a73ec080 100644
--- a/drivers/clk/qcom/Kconfig
+++ b/drivers/clk/qcom/Kconfig
@@ -232,6 +232,12 @@ config IPQ_GCC_9679
 	  i2c, USB, SD/eMMC, etc. Select this for the root clock
 	  of ipq9679.
 
+config IPQ_NSSCC_5200
+        tristate "IPQ5200 NSS Clock Controller"
+        depends on IPQ_GCC_5200
+        help
+          Support for NSS clock controller on ipq5200 devices.
+
 config IPQ_NSSCC_5332
         tristate "IPQ5332 NSS Clock Controller"
         depends on IPQ_GCC_5332
diff --git a/drivers/clk/qcom/Makefile b/drivers/clk/qcom/Makefile
index 3198c869f0b5..d00392a3f03a 100644
--- a/drivers/clk/qcom/Makefile
+++ b/drivers/clk/qcom/Makefile
@@ -34,6 +34,7 @@ obj-$(CONFIG_IPQ_GCC_806X) += gcc-ipq806x.o
 obj-$(CONFIG_IPQ_GCC_8074) += gcc-ipq8074.o
 obj-$(CONFIG_IPQ_GCC_9574) += gcc-ipq9574.o
 obj-$(CONFIG_IPQ_GCC_9679) += gcc-ipq9679.o
+obj-$(CONFIG_IPQ_NSSCC_5200) += nsscc-ipq5200.o
 obj-$(CONFIG_IPQ_NSSCC_5332) += nsscc-ipq5332.o
 obj-$(CONFIG_IPQ_NSSCC_5424) += nsscc-ipq5424.o
 obj-$(CONFIG_IPQ_NSSCC_9574) += nsscc-ipq9574.o
-- 
2.34.1

