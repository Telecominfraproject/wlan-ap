From 9aef65d51a4e25b998de4736437fb6ef4cc7e872 Mon Sep 17 00:00:00 2001
From: qiangqiang cheng <quic_qiangqia@quicinc.com>
Date: Mon, 20 Jan 2025 15:17:36 +0800
Subject: [PATCH] [dsa]: recover master's ethtool_ops to origin in shutdown
 process

Change-Id: I23e8c73211a143262f77154e7dd6077a8695769f
Signed-off-by: qiangqiang cheng <quic_qiangqia@quicinc.com>
---
 net/dsa/dsa.c | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/net/dsa/dsa.c b/net/dsa/dsa.c
index 900d61ed4145..127a460d7a42 100644
--- a/net/dsa/dsa.c
+++ b/net/dsa/dsa.c
@@ -1621,8 +1621,12 @@ void dsa_switch_shutdown(struct dsa_switch *ds)
 	/* Disconnect from further netdevice notifiers on the master,
 	 * since netdev_uses_dsa() will now return false.
 	 */
-	dsa_switch_for_each_cpu_port(dp, ds)
+	dsa_switch_for_each_cpu_port(dp, ds) {
+		dp->master->ethtool_ops = dp->orig_ethtool_ops;
+		dp->orig_ethtool_ops = NULL;
+
 		dp->master->dsa_ptr = NULL;
+	}
 
 	rtnl_unlock();
 out:
-- 
2.34.1

