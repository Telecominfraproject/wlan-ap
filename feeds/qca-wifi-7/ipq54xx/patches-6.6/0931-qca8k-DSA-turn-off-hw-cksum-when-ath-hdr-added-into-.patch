From 33445db303f4d9c1743d463e901a3e4c2301de66 Mon Sep 17 00:00:00 2001
From: qiangqiang cheng <qiangqia@qti.qualcomm.com>
Date: Wed, 6 Aug 2025 17:01:07 +0800
Subject: [PATCH] [qca8k]: DSA turn off hw cksum when ath hdr added into pkt

Change-Id: I5960538210fc4ea291f605a3759c80a68e039d3b
Signed-off-by: qiangqiang cheng <qiangqia@qti.qualcomm.com>
---
 net/dsa/slave.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/net/dsa/slave.c b/net/dsa/slave.c
index 99e9363d9832..9cc870025126 100644
--- a/net/dsa/slave.c
+++ b/net/dsa/slave.c
@@ -2558,8 +2558,8 @@ void dsa_slave_setup_tagger(struct net_device *slave)
 	if (ds->needs_standalone_vlan_filtering)
 		slave->features |= NETIF_F_HW_VLAN_CTAG_FILTER;
 
-	/* for ath hdr based DSA cksum should be done by stack */
-	if (DSA_TAG_PROTO_4B_QCA == cpu_dp->tag_ops->proto)
+	/* for pkt with ath hdr cksum should be done by stack */
+	if (DSA_TAG_PROTO_4B_QCA == cpu_dp->tag_ops->proto || dp->ds->fc_group != NULL)
 		slave->features &= (~NETIF_F_HW_CSUM | NETIF_F_IP_CSUM | NETIF_F_IPV6_CSUM);
 }
 
-- 
2.34.1

