From 78ad44e5dd32a5d9c80d2d54a91cc0c1c92e3ebf Mon Sep 17 00:00:00 2001
From: Timple Raj M <timple@qti.qualcomm.com>
Date: Mon, 2 Jun 2025 23:53:48 +0530
Subject: [PATCH] drivers: phy: qualcomm: Add USB support

This patch adds the USB support for the IPQ52xx chipset

Change-Id: Ic067b42b14c6ec444d1c52142f01d4861871a672
Signed-off-by: Timple Raj M <timple@qti.qualcomm.com>
---
 Documentation/devicetree/bindings/phy/qcom,qusb2-phy.yaml      | 1 +
 .../bindings/phy/qcom,sc8280xp-qmp-usb3-uni-phy.yaml           | 2 ++
 drivers/phy/qualcomm/phy-qcom-qmp-usb.c                        | 3 +++
 drivers/phy/qualcomm/phy-qcom-qusb2.c                          | 3 +++
 4 files changed, 9 insertions(+)

diff --git a/Documentation/devicetree/bindings/phy/qcom,qusb2-phy.yaml b/Documentation/devicetree/bindings/phy/qcom,qusb2-phy.yaml
index 3673f672d27b..30885c0ffc9c 100644
--- a/Documentation/devicetree/bindings/phy/qcom,qusb2-phy.yaml
+++ b/Documentation/devicetree/bindings/phy/qcom,qusb2-phy.yaml
@@ -22,6 +22,7 @@ properties:
               - qcom,ipq8074-qusb2-phy
               - qcom,ipq9574-qusb2-phy
               - qcom,ipq5424-qusb2-phy
+              - qcom,ipq5200-qusb2-phy
               - qcom,msm8953-qusb2-phy
               - qcom,msm8996-qusb2-phy
               - qcom,msm8998-qusb2-phy
diff --git a/Documentation/devicetree/bindings/phy/qcom,sc8280xp-qmp-usb3-uni-phy.yaml b/Documentation/devicetree/bindings/phy/qcom,sc8280xp-qmp-usb3-uni-phy.yaml
index 25818ddb7a3d..065af0356e2b 100644
--- a/Documentation/devicetree/bindings/phy/qcom,sc8280xp-qmp-usb3-uni-phy.yaml
+++ b/Documentation/devicetree/bindings/phy/qcom,sc8280xp-qmp-usb3-uni-phy.yaml
@@ -18,6 +18,7 @@ properties:
     enum:
       - qcom,ipq9574-qmp-usb3-phy
       - qcom,ipq5424-qmp-usb3-phy
+      - qcom,ipq5200-qmp-usb3-phy
       - qcom,qcm2290-qmp-usb3-phy
       - qcom,sa8775p-qmp-usb3-uni-phy
       - qcom,sc8280xp-qmp-usb3-uni-phy
@@ -77,6 +78,7 @@ allOf:
             enum:
               - qcom,ipq9574-qmp-usb3-phy
               - qcom,ipq5424-qmp-usb3-phy
+              - qcom,ipq5200-qmp-usb3-phy
     then:
       properties:
         clock-names:
diff --git a/drivers/phy/qualcomm/phy-qcom-qmp-usb.c b/drivers/phy/qualcomm/phy-qcom-qmp-usb.c
index 86f3ad607d18..b470b54a1228 100644
--- a/drivers/phy/qualcomm/phy-qcom-qmp-usb.c
+++ b/drivers/phy/qualcomm/phy-qcom-qmp-usb.c
@@ -2249,6 +2249,9 @@ static const struct of_device_id qmp_usb_of_match_table[] = {
 	}, {
 		.compatible = "qcom,ipq5424-qmp-usb3-phy",
 		.data = &ipq9574_usb3phy_cfg,
+	}, {
+		.compatible = "qcom,ipq5200-qmp-usb3-phy",
+		.data = &ipq9574_usb3phy_cfg,
 	}, {
 		.compatible = "qcom,msm8996-qmp-usb3-phy",
 		.data = &msm8996_usb3phy_cfg,
diff --git a/drivers/phy/qualcomm/phy-qcom-qusb2.c b/drivers/phy/qualcomm/phy-qcom-qusb2.c
index 7a795c59ab11..c533ef328bf4 100644
--- a/drivers/phy/qualcomm/phy-qcom-qusb2.c
+++ b/drivers/phy/qualcomm/phy-qcom-qusb2.c
@@ -916,6 +916,9 @@ static const struct of_device_id qusb2_phy_of_match_table[] = {
 	}, {
 		.compatible	= "qcom,ipq5424-qusb2-phy",
 		.data		= &ipq6018_phy_cfg,
+	}, {
+		.compatible	= "qcom,ipq5200-qusb2-phy",
+		.data		= &ipq6018_phy_cfg,
 	}, {
 		.compatible	= "qcom,msm8953-qusb2-phy",
 		.data		= &msm8996_phy_cfg,
-- 
2.34.1

