From afe6df13b36f6cc8a84d1d8f5b4279b78101a1fc Mon Sep 17 00:00:00 2001
From: "Hardik S. Panchal" <quic_hpanchal@quicinc.com>
Date: Mon, 11 Nov 2024 12:53:41 +0530
Subject: [PATCH] bpf: Export tcp_eat_skb()

User need to call this API before consuming SKB received using tcp_read_skb(). This API updates TCP Socket's sequence and updates internal ack state.

Change-Id: I65412cf2407573a1baa3f6dc71b2a8298ee174ed
Signed-off-by: Hardik S. Panchal <quic_hpanchal@quicinc.com>
---
 net/ipv4/tcp_bpf.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/net/ipv4/tcp_bpf.c b/net/ipv4/tcp_bpf.c
index 53b0d62fd2c2..ab2a29b467a2 100644
--- a/net/ipv4/tcp_bpf.c
+++ b/net/ipv4/tcp_bpf.c
@@ -28,6 +28,7 @@ void tcp_eat_skb(struct sock *sk, struct sk_buff *skb)
 	tcp_rcv_space_adjust(sk);
 	__tcp_cleanup_rbuf(sk, skb->len);
 }
+EXPORT_SYMBOL_GPL(tcp_eat_skb);
 
 static int bpf_tcp_ingress(struct sock *sk, struct sk_psock *psock,
 			   struct sk_msg *msg, u32 apply_bytes, int flags)
-- 
2.34.1

