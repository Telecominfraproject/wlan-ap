From c51f19be402ba5e0b857f071070f5aa02154f181 Mon Sep 17 00:00:00 2001
From: Ken Zhu <quic_guigenz@quicinc.com>
Date: Thu, 27 Mar 2025 14:27:54 -0700
Subject: [PATCH] nft: the conn is not collected after use

collect the expired connection before add new connection.

Change-Id: I58eb2578625e3dbd7de2581bff9c48b7e904d92a
Signed-off-by: Ken Zhu <quic_guigenz@quicinc.com>
---
 net/netfilter/nft_connlimit.c | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/net/netfilter/nft_connlimit.c b/net/netfilter/nft_connlimit.c
index de9d1980df69..24ae9dfdb4d1 100644
--- a/net/netfilter/nft_connlimit.c
+++ b/net/netfilter/nft_connlimit.c
@@ -43,6 +43,17 @@ static inline void nft_connlimit_do_eval(struct nft_connlimit *priv,
 		return;
 	}
 
+	local_bh_disable();
+	nf_conncount_gc_list(nft_net(pkt), priv->list);
+	local_bh_enable();
+
+	count = priv->list->count;
+
+	if ((count >= priv->limit) ^ priv->invert) {
+		regs->verdict.code = NFT_BREAK;
+		return;
+	}
+
 	if (nf_conncount_add(nft_net(pkt), priv->list, tuple_ptr, zone)) {
 		regs->verdict.code = NF_DROP;
 		return;
-- 
2.34.1

