From: Timple Raj M <timple@qti.qualcomm.com>
Date: Fri, 20 Jun 2025 11:22:03 +0530
Subject: [PATCH] pcie: qcom: Add PCIe support for IPQ52xx chipset

This patch adds the PCIe support for the IPQ52xx
chipset

Change-Id: If8619382e867cb7519dffa4541b78fea856116e0
Signed-off-by: Timple Raj M <timple@qti.qualcomm.com>
---
 drivers/pci/controller/dwc/pcie-qcom.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/pci/controller/dwc/pcie-qcom.c b/drivers/pci/controller/dwc/pcie-qcom.c
index 52863dc5ac0e..bedfddd21588 100644
--- a/drivers/pci/controller/dwc/pcie-qcom.c
+++ b/drivers/pci/controller/dwc/pcie-qcom.c
@@ -2308,6 +2308,7 @@ static const struct of_device_id qcom_pcie_match[] = {
 	{ .compatible = "qcom,pcie-ipq4019", .data = &cfg_2_4_0 },
 	{ .compatible = "qti,pcie-ipq5332", .data = &cfg_1_27_0 },
 	{ .compatible = "qcom,pcie-ipq5424", .data = &cfg_1_27_0 },
+	{ .compatible = "qcom,pcie-ipq5200", .data = &cfg_1_27_0 },
 	{ .compatible = "qcom,pcie-ipq6018", .data = &cfg_2_9_0 },
 	{ .compatible = "qcom,pcie-ipq8064", .data = &cfg_2_1_0 },
 	{ .compatible = "qcom,pcie-ipq8064-v2", .data = &cfg_2_1_0 },
