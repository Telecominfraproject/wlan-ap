From ea5e2bb45e9300ad5844315c9350033170af11d9 Mon Sep 17 00:00:00 2001
From: Hariharan K <quic_harihk@quicinc.com>
Date: Fri, 3 Jan 2025 12:33:20 +0530
Subject: [PATCH] firmware: scm: Remove FUSEPROV_SECDAT_LOCK_BLOWN macro

Removing FUSEPROV_SECDAT_LOCK_BLOWN macro as it is
not used in the sec-upgrade driver.

Change-Id: If7cf1466884a9d451237906978db6a15a77a5595
Signed-off-by: Hariharan K <quic_harihk@quicinc.com>
---
 include/linux/firmware/qcom/qcom_scm.h | 1 -
 1 file changed, 1 deletion(-)

diff --git a/include/linux/firmware/qcom/qcom_scm.h b/include/linux/firmware/qcom/qcom_scm.h
index 43f337686d48..98457d188007 100644
--- a/include/linux/firmware/qcom/qcom_scm.h
+++ b/include/linux/firmware/qcom/qcom_scm.h
@@ -227,7 +227,6 @@ enum qcom_scm_ice_cipher {
 #define FUSEPROV_SUCCESS           0x0
 #define QCOM_SCM_SVC_FUSE          0x8
 #define FUSEPROV_INVALID_HASH      0x9
-#define FUSEPROV_SECDAT_LOCK_BLOWN 0xB
 #define IMAGE_AUTH_FAILURE         0x101
 #define QCOM_KERNEL_AUTH_CMD       0x15
 #define TZ_BLOW_FUSE_SECDAT        0x20
