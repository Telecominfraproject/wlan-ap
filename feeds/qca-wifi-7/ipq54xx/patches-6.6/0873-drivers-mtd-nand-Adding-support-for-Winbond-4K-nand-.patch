From: Saahil Tomar <quic_saahtoma@quicinc.com>
Date: Thu, 24 Apr 2025 12:40:57 +0530
Subject: [PATCH] drivers: mtd: nand: Adding support for Winbond 4K nand
 (W25N04LW)

Change-Id: Iecb8c89bb693e6b452fd0e753008c7270759940b
Signed-off-by: Saahil Tomar <quic_saahtoma@quicinc.com>
---
 drivers/mtd/nand/raw/nand_ids.c   | 4 +++-
 drivers/mtd/nand/raw/qcom_nandc.c | 3 +++
 2 files changed, 6 insertions(+), 1 deletion(-)

diff --git a/drivers/mtd/nand/raw/nand_ids.c b/drivers/mtd/nand/raw/nand_ids.c
index 3bbef47a909e..66ef24b3b003 100644
--- a/drivers/mtd/nand/raw/nand_ids.c
+++ b/drivers/mtd/nand/raw/nand_ids.c
@@ -85,7 +85,9 @@ struct nand_flash_dev nand_flash_ids[] = {
 	{"MX35UF4GE4AD-Z4I SPI NAND 4G 1.8V",
 		{ .id = {0xc2, 0xb7} },
 		SZ_4K, SZ_512, SZ_256K, 0, 2, 256, NAND_ECC_INFO(8, SZ_512)},
-
+	{"W25N04LW SPI NAND 4G 1.8V",
+		{ .id = {0xef, 0xb2} },
+		SZ_4K, SZ_512, SZ_256K, 0, 2, 256, NAND_ECC_INFO(8, SZ_512)},
 	{"MX35UF2GE4AD-Z4I SPI NAND 2G 1.8V",
 		{ .id = {0xc2, 0xa6} },
 		SZ_2K, SZ_256, SZ_128K, 0, 2, 128, NAND_ECC_INFO(8, SZ_512)},
diff --git a/drivers/mtd/nand/raw/qcom_nandc.c b/drivers/mtd/nand/raw/qcom_nandc.c
index cecac0e8fd38..f4f2573f6e75 100644
--- a/drivers/mtd/nand/raw/qcom_nandc.c
+++ b/drivers/mtd/nand/raw/qcom_nandc.c
@@ -324,6 +324,9 @@ struct nand_flash_dev qspinand_flash_ids_2k[] = {
 	{"MX35UF4GE4AD-Z4I SPI NAND 1G 1.8V",
 			{ .id = {0xc2, 0xb7} },
 		SZ_2K, SZ_256, SZ_128K, 0, 2, 128, NAND_ECC_INFO(8, SZ_512)},
+	{"W25N04LW SPI NAND 4G 1.8V",
+			{ .id = {0xef, 0xb2} },
+		SZ_2K, SZ_256, SZ_128K, 0, 2, 128, NAND_ECC_INFO(8, SZ_512)},
 	{NULL}
 };
 
