diff -urN a/src/ap/wpa_auth_ft.c b/src/ap/wpa_auth_ft.c
--- a/src/ap/wpa_auth_ft.c	2026-07-22 17:04:58.657822900 +0800
+++ b/src/ap/wpa_auth_ft.c	2026-07-22 17:05:49.970249900 +0800
