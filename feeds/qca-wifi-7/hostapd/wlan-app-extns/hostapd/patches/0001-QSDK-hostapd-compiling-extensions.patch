From 876840b7c0f771ee3cef7dc9ddbbe1c704f29fc5 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Thu, 17 Jul 2025 01:55:29 +0530
Subject: [PATCH 1/2] hostapd-extn: Add support to compile extensions code for hostapd

Define new macro CONFIG_QCN_EXTN for compiling extensions code.
Add this macro to compile extensions speicifc code for hostap
and wpa_supplicant.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Signed-off-by: Venkateswara Swamy Bandaru <vbandaru@qti.qualcomm.com>

---
 hostapd/Makefile              | 12 ++++++++++++
 src/build.rules               | 14 ++++++++++++++
 wpa_supplicant/Makefile       | 10 ++++++++++

diff --git a/hostapd/Makefile b/hostapd/Makefile
index a920435..0cd4cfb 100644
--- a/hostapd/Makefile
+++ b/hostapd/Makefile
@@ -67,6 +71,10 @@ ifdef CONFIG_RADIUS_SERVER
 OBJS += radius.o
 endif
 
+ifdef CONFIG_QCN_EXTN
+include ../qcn_extns/Makefile
+endif
+
 OBJS += ../src/ap/hostapd.o
 OBJS += ../src/ap/wpa_auth_glue.o
 OBJS += ../src/ap/drv_callbacks.o
diff --git a/src/build.rules b/src/build.rules
index eb6759a..bbb9c21 100644
--- a/src/build.rules
+++ b/src/build.rules
@@ -90,6 +96,13 @@ $(BUILDDIR)/$(PROJ)/%.o: %.c $(CONFIG_FILE) | _make_dirs
 	@echo $(CURDIR): '$(CC) -c -o $@ $(CFLAGS) $<' >$@.cmd
 	$(Q)$(CC) -c -o $@ $(CFLAGS) $<
 	@$(E) "  CC " $<
+
+ifdef CONFIG_QCN_EXTN
+$(BUILDDIR)/$(PROJ)/qcn_extns/%.o: $(ROOTDIR)qcn_extns/%.c $(CONFIG_FILE) | _make_dirs
+	$(Q)$(CC) -c -o $@ $(CFLAGS) $<
+	@$(E) "  CC " $<
+endif
+
 # for the fuzzing tests
 $(BUILDDIR)/$(PROJ)/wpa_supplicant/%.o: $(ROOTDIR)wpa_supplicant/%.c $(CONFIG_FILE) | _make_dirs
 	@echo $(CURDIR): '$(CC) -c -o $@ $(CFLAGS) $<' >$@.cmd
diff --git a/wpa_supplicant/Makefile b/wpa_supplicant/Makefile
index 13194c1..c6be666 100644
--- a/wpa_supplicant/Makefile
+++ b/wpa_supplicant/Makefile
@@ -2121,6 +2125,10 @@ ifdef CONFIG_NO_TKIP
 CFLAGS += -DCONFIG_NO_TKIP
 endif
 
+ifdef CONFIG_QCN_EXTN
+include ../qcn_extns/Makefile
+endif
+
 dynamic_eap_methods: $(EAPDYN)
 
 _OBJS_VAR := OBJS_priv
-- 
diff --git a/tests/hwsim/example-hostapd.config b/tests/hwsim/example-hostapd.config
index 383368b..9ae581f 100644
--- a/tests/hwsim/example-hostapd.config
+++ b/tests/hwsim/example-hostapd.config
@@ -120,3 +120,4 @@ CONFIG_PASN=y
 CONFIG_AIRTIME_POLICY=y
 CONFIG_IEEE80211BE=y
 CONFIG_NAN_USD=y
+CONFIG_QCN_EXTN=y
diff --git a/tests/hwsim/example-wpa_supplicant.config b/tests/hwsim/example-wpa_supplicant.config
index b10be47..e590af1 100644
--- a/tests/hwsim/example-wpa_supplicant.config
+++ b/tests/hwsim/example-wpa_supplicant.config
@@ -163,3 +163,4 @@ CONFIG_DPP3=y
 CONFIG_WEP=y
 CONFIG_PASN=y
 CONFIG_NAN_USD=y
+CONFIG_QCN_EXTN=y
diff --git a/tests/hwsim/vm/kernel-config b/tests/hwsim/vm/kernel-config
index 2aff20a..b82e558 100644
--- a/tests/hwsim/vm/kernel-config
+++ b/tests/hwsim/vm/kernel-config
@@ -173,3 +173,4 @@ CONFIG_LATENCYTOP=y
 CONFIG_FUNCTION_TRACER=y
 # CONFIG_STRICT_DEVMEM is not set
 # CONFIG_X86_VERBOSE_BOOTUP is not set
+CONFIG_QCN_EXTN=y
2.34.1

