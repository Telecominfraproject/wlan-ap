From bafe654f9b08b51e308c7fff3e578b2d11d611eb Mon Sep 17 00:00:00 2001
From: Arunpandi Kannan <quic_arunpand@quicinc.com>
Date: Tue, 11 Feb 2025 12:31:27 +0530
Subject: [PATCH] QSDK:PROTOCOL:HOSTAPD:WAR: Fix to resolve issue with FT
 roaming  re-assoc with source AP.

If driver issues low ack command to disassoc roaming client during re-add,
prevent disassociating the client by checking whether auth algorithm
is FT auth and whether hostapd issued STA re-add to driver.

Tag: FT over Air
Patch-depdendency: 994-09-wifi-ath12k-add-support-to-migrate-peers-to-other-link-when-prim.patch
Patch-work: none

Signed-off-by: Arunpandi Kannan <quic_arunpand@quicinc.com>
---
 src/ap/drv_callbacks.c | 4 +++-
 src/ap/ieee802_11.c    | 3 +++
 src/ap/sta_info.h      | 1 +
 src/ap/wpa_auth_glue.c | 1 +
 4 files changed, 8 insertions(+), 1 deletion(-)

--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -1111,7 +1111,9 @@ void hostapd_event_sta_low_ack(struct ho
 #endif /* CONFIG_IEEE80211BE */
 
 	if (!sta || (!hapd->conf->disassoc_low_ack && num_packets != 0xFFFF) ||
-	    sta->agreed_to_steer)
+	    sta->agreed_to_steer ||
+	    (sta->auth_alg == WLAN_AUTH_FT && sta->ft_re_add == true &&
+	     num_packets == 0xFFFF))
 		return;
 
 	if (num_packets == 0xFFFF)
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -7421,6 +7421,9 @@ static void handle_assoc_cb(struct hosta
 		ap_sta_set_authorized(hapd, sta, 1);
 	}
 
+	if (sta->auth_alg == WLAN_AUTH_FT)
+		sta->ft_re_add = false;
+
 	if (reassoc)
 		mlme_reassociate_indication(hapd, sta);
 	else
--- a/src/ap/sta_info.h
+++ b/src/ap/sta_info.h
@@ -333,6 +333,7 @@ struct sta_info {
 			   * units of 1000 TUs */
 
 	u64 last_known_sta_id_timestamp;
+	bool ft_re_add;
 };
 
 
--- a/src/ap/wpa_auth_glue.c
+++ b/src/ap/wpa_auth_glue.c
@@ -1369,6 +1369,7 @@ static int hostapd_wpa_auth_add_sta_ft(v
 		 * previous association. */
 		wpa_printf(MSG_DEBUG,
 			   "FT: Remove and re-add driver STA entry after successful FT authentication");
+		sta->ft_re_add = true;
 		return ap_sta_re_add(hapd, sta, 0);
 	}
 
