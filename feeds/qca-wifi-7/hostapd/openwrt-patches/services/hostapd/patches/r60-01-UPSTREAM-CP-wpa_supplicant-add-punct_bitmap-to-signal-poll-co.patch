From 022b02913853b9bc5a378935d0c503ee823d822e Mon Sep 17 00:00:00 2001
From: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
Date: Sun, 26 Jan 2025 19:03:37 -0800
Subject: [PATCH 1/4] UPSTREAM:CP:wpa_supplicant: add punct_bitmap to signal poll
 commands

Add puncturing bitmap in structure wpa_signal_info and include
the value in the output for wpa_cli commands signal_poll and
mlo_signal_poll. These commands are used by WDS scripts to get
frequency information for the station interface.

Patch-dependency: none

Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 src/drivers/driver.h        |  1 +
 wpa_supplicant/ctrl_iface.c | 11 +++++++++++
 2 files changed, 12 insertions(+)

diff --git a/src/drivers/driver.h b/src/drivers/driver.h
index 51a2ad7ab25a..b074093584a5 100644
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -2858,6 +2858,7 @@ struct wpa_signal_info {
 	enum chan_width chanwidth;
 	int center_frq1;
 	int center_frq2;
+	u32 punct_bitmap;
 };
 
 struct wpa_mlo_signal_info {
diff --git a/wpa_supplicant/ctrl_iface.c b/wpa_supplicant/ctrl_iface.c
index 025be8f97259..59fc0e220cd8 100644
--- a/wpa_supplicant/ctrl_iface.c
+++ b/wpa_supplicant/ctrl_iface.c
@@ -8469,6 +8469,11 @@ static int wpa_supplicant_signal_poll(struct wpa_supplicant *wpa_s, char *buf,
 		if (os_snprintf_error(end - pos, ret))
 			return -1;
 		pos += ret;
+
+		ret = os_snprintf(pos, end - pos, "PUNCT_BITMAP=%u\n", si.punct_bitmap);
+		if (os_snprintf_error(end - pos, ret))
+			return -1;
+		pos += ret;
 	}
 
 	if (si.center_frq1 > 0) {
@@ -12096,6 +12101,12 @@ static int wpas_ctrl_iface_mlo_signal_poll(struct wpa_supplicant *wpa_s,
 			if (os_snprintf_error(end - pos, ret))
 				return -1;
 			pos += ret;
+
+			ret = os_snprintf(pos, end - pos, "PUNCT_BITMAP=%u\n",
+					  mlo_si.links[i].punct_bitmap);
+			if (os_snprintf_error(end - pos, ret))
+				return -1;
+			pos += ret;
 		}
 
 		if (mlo_si.links[i].center_frq1 > 0) {
-- 
2.34.1

