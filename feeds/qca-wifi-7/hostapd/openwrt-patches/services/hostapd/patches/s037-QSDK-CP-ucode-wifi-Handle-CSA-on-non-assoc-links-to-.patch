From 10fa2ddf50993488d2e5d26ff5ec22a5b6db4279 Mon Sep 17 00:00:00 2001
From: Nagarajan Maran <nmaran@qti.qualcomm.com>
Date: Fri, 21 Nov 2025 15:48:10 +0530
Subject: [PATCH] QSDK:CP:ucode:wifi: Handle CSA on non-assoc links to avoid
 STA disconnection

Scenario: Non-AP MLD repeater STA with more than one link + AP with
all the links in STA or more than that. Root MLD AP with all links.

In the above scenario, a channel change from the root on a non-assoc
link of the STA, triggers STA disconnection. On the repeater side,
wpa_supplicant sends the channel switch started event to hostapd via
ucode. This event is currently not sent for non-assoc links.

Add support to send the channel switch started event for non-assoc
links as well.

Patch-dependency:
	r50-03-QSDK-CP-hostapd-add-missing-WDS-repeater-6G-bring-up.patch

Signed-off-by: Nagarajan Maran <nmaran@qti.qualcomm.com>
---
 wpa_supplicant/events.c | 12 +++++++++---
 wpa_supplicant/ucode.c  | 25 ++++++++++---------------
 wpa_supplicant/ucode.h  |  4 ++--
 3 files changed, 21 insertions(+), 20 deletions(-)

diff --git a/wpa_supplicant/events.c b/wpa_supplicant/events.c
index 95e9a93b4bd6..6cf5eb362857 100644
--- a/wpa_supplicant/events.c
+++ b/wpa_supplicant/events.c
@@ -6312,7 +6312,6 @@ void supplicant_event(void *ctx, enum wpa_event_type event,
 		event_to_string(event), event);
 #endif /* CONFIG_NO_STDOUT_DEBUG */
 
-	wpas_ucode_event(wpa_s, event, data);
 	switch (event) {
 	case EVENT_AUTH:
 #ifdef CONFIG_FST
@@ -6626,8 +6625,12 @@ void supplicant_event(void *ctx, enum wpa_event_type event,
 			channel_width_to_string(data->ch_switch.ch_width),
 			data->ch_switch.cf1,
 			data->ch_switch.cf2);
-		if (event == EVENT_LINK_CH_SWITCH_STARTED)
+
+		if (event == EVENT_LINK_CH_SWITCH_STARTED) {
+			if (wpa_s->mlo_assoc_link_id != data->ch_switch.link_id)
+				wpas_ucode_event(wpa_s, data);
 			break;
+		}
 
 		wpa_s->links[data->ch_switch.link_id].freq =
 			data->ch_switch.freq;
@@ -6656,8 +6659,11 @@ void supplicant_event(void *ctx, enum wpa_event_type event,
 			channel_width_to_string(data->ch_switch.ch_width),
 			data->ch_switch.cf1,
 			data->ch_switch.cf2);
-		if (event == EVENT_CH_SWITCH_STARTED)
+
+		if (event == EVENT_CH_SWITCH_STARTED) {
+			wpas_ucode_event(wpa_s, data);
 			break;
+		}
 
 		wpa_s->assoc_freq = data->ch_switch.freq;
 		wpa_s->current_ssid->frequency = data->ch_switch.freq;
diff --git a/wpa_supplicant/ucode.c b/wpa_supplicant/ucode.c
index eca60ed8f611..3655be7155c3 100644
--- a/wpa_supplicant/ucode.c
+++ b/wpa_supplicant/ucode.c
@@ -123,14 +123,11 @@ void wpas_ucode_update_state(struct wpa_supplicant *wpa_s)
 	ucv_gc(vm);
 }
 
-void wpas_ucode_event(struct wpa_supplicant *wpa_s, int event, union wpa_event_data *data)
+void wpas_ucode_event(struct wpa_supplicant *wpa_s, union wpa_event_data *data)
 {
 	uc_value_t *val;
 	s8 hw_idx;
 
-	if (event != EVENT_CH_SWITCH_STARTED)
-		return;
-
 	val = wpa_ucode_registry_get(iface_registry, wpa_s->ucode.idx);
 	if (!val)
 		return;
@@ -148,20 +145,18 @@ void wpas_ucode_event(struct wpa_supplicant *wpa_s, int event, union wpa_event_d
 	uc_value_push(ucv_get(ucv_int64_new(hw_idx)));
 
 	uc_value_push(ucv_get(val));
-	uc_value_push(ucv_get(ucv_string_new(event_to_string(event))));
+	uc_value_push(ucv_get(ucv_string_new(event_to_string(EVENT_CH_SWITCH_STARTED))));
 	val = ucv_object_new(vm);
 	uc_value_push(ucv_get(val));
 
-	if (event == EVENT_CH_SWITCH_STARTED) {
-		ucv_object_add(val, "csa_count", ucv_int64_new(data->ch_switch.count));
-		ucv_object_add(val, "frequency", ucv_int64_new(data->ch_switch.freq));
-		ucv_object_add(val, "chan_width", ucv_int64_new(data->ch_switch.ch_width));
-		ucv_object_add(val, "sec_chan_offset", ucv_int64_new(data->ch_switch.ch_offset));
-		ucv_object_add(val, "center_freq1", ucv_int64_new(data->ch_switch.cf1));
-		ucv_object_add(val, "center_freq2", ucv_int64_new(data->ch_switch.cf2));
-		ucv_object_add(val, "link_id", ucv_int64_new(data->ch_switch.link_id));
-		ucv_object_add(val, "punct_bitmap", ucv_int64_new(data->ch_switch.punct_bitmap));
-	}
+	ucv_object_add(val, "csa_count", ucv_int64_new(data->ch_switch.count));
+	ucv_object_add(val, "frequency", ucv_int64_new(data->ch_switch.freq));
+	ucv_object_add(val, "chan_width", ucv_int64_new(data->ch_switch.ch_width));
+	ucv_object_add(val, "sec_chan_offset", ucv_int64_new(data->ch_switch.ch_offset));
+	ucv_object_add(val, "center_freq1", ucv_int64_new(data->ch_switch.cf1));
+	ucv_object_add(val, "center_freq2", ucv_int64_new(data->ch_switch.cf2));
+	ucv_object_add(val, "link_id", ucv_int64_new(data->ch_switch.link_id));
+	ucv_object_add(val, "punct_bitmap", ucv_int64_new(data->ch_switch.punct_bitmap));
 
 	ucv_put(wpa_ucode_call(5));
 	ucv_gc(vm);
diff --git a/wpa_supplicant/ucode.h b/wpa_supplicant/ucode.h
index 9986b12968cd..59e6a2d6e3d6 100644
--- a/wpa_supplicant/ucode.h
+++ b/wpa_supplicant/ucode.h
@@ -20,7 +20,7 @@ void wpas_ucode_free(void);
 void wpas_ucode_add_bss(struct wpa_supplicant *wpa_s);
 void wpas_ucode_free_bss(struct wpa_supplicant *wpa_s);
 void wpas_ucode_update_state(struct wpa_supplicant *wpa_s);
-void wpas_ucode_event(struct wpa_supplicant *wpa_s, int event, union wpa_event_data *data);
+void wpas_ucode_event(struct wpa_supplicant *wpa_s, union wpa_event_data *data);
 #else
 static inline int wpas_ucode_init(struct wpa_global *gl)
 {
@@ -41,7 +41,7 @@ static inline void wpas_ucode_update_state(struct wpa_supplicant *wpa_s)
 {
 }
 
-static inline void wpas_ucode_event(struct wpa_supplicant *wpa_s, int event, union wpa_event_data *data)
+static inline void wpas_ucode_event(struct wpa_supplicant *wpa_s, union wpa_event_data *data)
 {
 }
 
-- 
