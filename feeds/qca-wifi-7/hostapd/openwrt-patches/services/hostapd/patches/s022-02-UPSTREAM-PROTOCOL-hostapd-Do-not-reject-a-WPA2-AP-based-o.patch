From 13b75a7d5f23754cb95b64aa525220a8e334d5ee Mon Sep 17 00:00:00 2001
From: Sai Pratyusha Magam <smagam@qti.qualcomm.com>
Date: Thu, 9 Oct 2025 12:55:14 +0530
Subject: [PATCH 2/2] UPSTREAM:PROTOCOL:hostapd:Do not reject a WPA2 AP based on
 absence of SAE H2E bit

In the current implementation, the 6GHz related security
constraints check in wpa_scan_res_ok(), incorrectly causes
a supplicant network configuration supporting both WPA2-PSK
and WPA3 with Hash to element method(sae_pwe=1) to reject a
WPA2 AP based on the absence of H2E bit in the RSNXE in
beacons and probe response frames even in 2.4GHz/5GHz.

While in 6GHz, supplicant should continue to check for a
SAE H2E supporting AP, in other bands the SAE PWE method
match should be restricted to a WPA3 supporting AP only.
Split the existing check to validate 6GHz related security
constraint and SAE PWE method mismatch for non-6GHz bands
separately

Patch-work: None
Patch-dependency: None

Change-Id: I1e11cd97fedd8956acd8f5a6cec971245fca7659
Signed-off-by: Sai Pratyusha Magam <smagam@qti.qualcomm.com>
---
 wpa_supplicant/events.c | 20 ++++++++++++++++----
 1 file changed, 16 insertions(+), 4 deletions(-)

diff --git a/wpa_supplicant/events.c b/wpa_supplicant/events.c
index 95b4cb2..95e9a93 100644
--- a/wpa_supplicant/events.c
+++ b/wpa_supplicant/events.c
@@ -1257,7 +1257,8 @@ static bool wpa_scan_res_ok(struct wpa_supplicant *wpa_s, struct wpa_ssid *ssid,
 			    bool debug_print, bool link)
 {
 	int res;
-	bool wpa, check_ssid = false;
+	bool wpa, check_ssid = false, bss_key_mgmt_sae = false;
+	struct wpa_ie_data data;
 #ifdef CONFIG_MBO
 	const u8 *assoc_disallow;
 #endif /* CONFIG_MBO */
@@ -1271,7 +1272,9 @@ static bool wpa_scan_res_ok(struct wpa_supplicant *wpa_s, struct wpa_ssid *ssid,
 	wpa = ie && ie[1];
 	ie = wpa_bss_get_rsne(wpa_s, bss, ssid, false);
 	wpa |= ie && ie[1];
-
+	if (ie && wpa_parse_wpa_ie_rsn(ie, 2 + ie[1], &data) == 0 &&
+	    wpa_key_mgmt_sae(data.key_mgmt))
+		bss_key_mgmt_sae = true;
 #ifdef CONFIG_SAE
 	ie = wpa_bss_get_rsnxe(wpa_s, bss, ssid, false);
 	if (ie && ie[0] == WLAN_EID_VENDOR_SPECIFIC && ie[1] >= 4 + 1)
@@ -1429,10 +1432,19 @@ static bool wpa_scan_res_ok(struct wpa_supplicant *wpa_s, struct wpa_ssid *ssid,
 	/* When using SAE Password Identifier and when operationg on the 6 GHz
 	 * band, only H2E is allowed. */
 	sae_pwe = wpas_get_ssid_sae_pwe(wpa_s, ssid);
-	if ((sae_pwe == SAE_PWE_HASH_TO_ELEMENT ||
-	     is_6ghz_freq(bss->freq) || ssid->sae_password_id) &&
+	if (is_6ghz_freq(bss->freq) &&
 	    sae_pwe != SAE_PWE_FORCE_HUNT_AND_PECK &&
 	    wpa_key_mgmt_sae(ssid->key_mgmt) &&
+	    !(rsnxe_capa & BIT(WLAN_RSNX_CAPAB_SAE_H2E))) {
+		if (debug_print)
+			wpa_dbg(wpa_s, MSG_DEBUG,
+				"   skip - SAE H2E mandatory in 6GHz, but not supported by the AP");
+		return false;
+	}
+	if ((sae_pwe == SAE_PWE_HASH_TO_ELEMENT ||
+	     ssid->sae_password_id) &&
+	    sae_pwe != SAE_PWE_FORCE_HUNT_AND_PECK &&
+	    wpa_key_mgmt_sae(ssid->key_mgmt) && bss_key_mgmt_sae &&
 	    !(rsnxe_capa & BIT(WLAN_RSNX_CAPAB_SAE_H2E))) {
 		if (debug_print)
 			wpa_dbg(wpa_s, MSG_DEBUG,
-- 
