From ed51799b2da45eac47d21e69f29ba44c3f2fa558 Mon Sep 17 00:00:00 2001
From: Yuvarani V <quic_yuvarani@quicinc.com>
Date: Sat, 15 Feb 2025 02:05:16 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Fix adding ML Reconfig IE
 with no sta profile

Currently ML Reconfiguration IE with no sta profile is added
to Probe Response/Beacon when no link is undergoing ML Reconfig
Link removal.

As per IEEE P802.11be/D7.0 - 9.3.3.10, The AP MLD shall
announce the removal of any affiliated AP through
a Reconfiguration Multi-Link element in all
Beacon and Probe Response frames transmitted by its affiliated
APs until the affiliated AP is removed.

Fix this issue by adding a check to add the ML Reconfig IE
only if any sta profile is present(atleast 1 link has to undergo
ML Reconfig Link Removal).

Patch-dependency: None

Patch-work: None

Signed-off-by: Yuvarani V <quic_yuvarani@quicinc.com>
---
 src/ap/ieee802_11_eht.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 69b8df9..9d68b28 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -1612,6 +1612,7 @@ u8 *hostapd_eid_eht_reconf_ml(struct hostapd_data *hapd,
 	struct hostapd_data *link_bss;
 	u16 control;
 	u8 *pos = eid;
+	bool sta_profile_present = false;
 
 	*pos++ = WLAN_EID_EXTENSION;
 	*pos++ = 0;
@@ -1636,6 +1637,7 @@ u8 *hostapd_eid_eht_reconf_ml(struct hostapd_data *hapd,
 		    !link_bss->eht_mld_link_removal_inprogress)
 			continue;
 
+		sta_profile_present = true;
 		/* sub element ID is 0 */
 		*pos++ = 0;
 		*pos++ = 5;
@@ -1652,6 +1654,9 @@ u8 *hostapd_eid_eht_reconf_ml(struct hostapd_data *hapd,
 		pos += 2;
 	}
 
+	if (!sta_profile_present)
+		return eid;
+
 	eid[1] = pos - eid - 2;
 
 	wpa_hexdump_ascii(MSG_INFO, "MLD: reconfiguration MLE dump: ",
-- 
2.34.1

