From 7691af838291d80a66be893302a6c84b3bd2f61f Mon Sep 17 00:00:00 2001
From: Yuvarani V <yuvarani@qti.qualcomm.com>
Date: Tue, 23 Sep 2025 23:44:10 +0530
Subject: [PATCH] UPSTREAM:HOSTAPD: Cancel EAPOL timeout during ML link
 reconfig removal

During the LINK_REMOVAL_COMPLETED event, the current code
reconfigures WPA state machines for ML partner links when
the associated link ID matches. But it does not cancel any
pending EAPOL timeout, which can lead to a crash when a 4-way
handshake is in progress on the assoc link and a timeout is
scheduled. If the assoc link is removed and assoc_link_id is
updated, later when timeout cb handler tries to cancel the
timeout, it may access a freed authenticator object,
causing a use-after-free.
 
Fix this by explicitly cancelling the EAPOL timeout
before reconfiguring the state machine. This ensures
a cleaner handover, avoids race conditions and crashes.

Patch-depdendency: r32-007-hostapd-wpa_auth-reconfig-state-machine-for-assoc-li.patch

Patch-work: None

Signed-off-by: Yuvarani V <yuvarani@qti.qualcomm.com>
---
 src/ap/drv_callbacks.c | 2 ++
 src/ap/wpa_auth.c      | 4 ++--
 src/ap/wpa_auth.h      | 1 +
 3 files changed, 5 insertions(+), 2 deletions(-)

--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -2860,6 +2860,7 @@ static int hostapd_sm_link_reconfigure(s
 		return 0;
 
 	if (sta->mld_assoc_link_id == hapd->mld_link_id) {
+		eloop_cancel_timeout(wpa_send_eapol_timeout, hapd->wpa_auth, sta->wpa_sm);
 		set_for_each_partner_link_sta(hapd, sta, phapd->wpa_auth,
 					      wpa_auth_reconfig_wpa_auth_sm);
 
--- a/src/ap/wpa_auth.c
+++ b/src/ap/wpa_auth.c
@@ -41,7 +41,6 @@
 #define KDE_ALL_LINKS 0xffff
 
 
-static void wpa_send_eapol_timeout(void *eloop_ctx, void *timeout_ctx);
 static int wpa_sm_step(struct wpa_state_machine *sm);
 static int wpa_verify_key_mic(int akmp, size_t pmk_len, struct wpa_ptk *PTK,
 			      u8 *data, size_t data_len);
@@ -2019,7 +2018,7 @@ static int wpa_gmk_to_gtk(const u8 *gmk,
 }
 
 
-static void wpa_send_eapol_timeout(void *eloop_ctx, void *timeout_ctx)
+void wpa_send_eapol_timeout(void *eloop_ctx, void *timeout_ctx)
 {
 	struct wpa_authenticator *wpa_auth = eloop_ctx;
 	struct wpa_state_machine *sm = timeout_ctx;
--- a/src/ap/wpa_auth.h
+++ b/src/ap/wpa_auth.h
@@ -734,4 +734,5 @@ bool wpa_auth_sm_known_sta_identificatio
 					  const u8 *timestamp,
 					  const u8 *mic, size_t mic_len);
 
+void wpa_send_eapol_timeout(void *eloop_ctx, void *timeout_ctx);
 #endif /* WPA_AUTH_H */
