From d9d65cd3082904a01028bc043aaf740c48525e0d Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Mon, 29 Sep 2025 23:24:19 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:HOSTAPD: Weight based NFT rule
 configuration for SCS

Add support to configure the NF table rules as per weight
calculated based on TCLAS Classifier mask. A rule with more
weight (has more specific Tuple information) is programmed
last and takes higher precedence.

When SCS Add/Update request is received, the existing NF table
rules are cleared and rules sorted wrt ascending order of
weight are programmed. For SCS delete, the particular NFT rules
tied to the SCS request are cleared.

Tag: SCS

Patch-dependency:
r92-04-UPSTREAM-PROTOCOL-CP-HOSTAPD-Add-support-for-SCS-req-parsing.patch
r92-05-UPSTREAM-PROTOCOL-CP-HOSTAPD-Copy-and-send-SCS-data-over-QM.patch
r92-06-UPSTREAM-PROTOCOL-CP-HOSTAPD-Handle-SCS-response-from-driver.patch
r92-07-UPSTREAM-PROTOCOL-CP-HOSTAPD-Add-support-for-sending-SCS-response.patch

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 src/ap/robust_av.c | 146 ++++++++++++++++++++++++++++++++++++++++-----
 src/ap/robust_av.h |   4 ++
 2 files changed, 136 insertions(+), 14 deletions(-)

diff --git a/src/ap/robust_av.c b/src/ap/robust_av.c
index 7827bd8..6c9dcf1 100644
--- a/src/ap/robust_av.c
+++ b/src/ap/robust_av.c
@@ -1055,6 +1055,7 @@ static void hostapd_qm_prepare_nft_rule(struct hostapd_data *hapd,
 	if (te->classifier_type == QM_TCLAS_CLASSIFIER_TYPE4) {
 		if (type4_params->classifier_mask & BIT(0)) {
 			rule->ip_family = type4_params->ip_ver;
+			rule->weight++;
 		}
 
 		if (type4_params->classifier_mask & BIT(1)) {
@@ -1069,6 +1070,7 @@ static void hostapd_qm_prepare_nft_rule(struct hostapd_data *hapd,
 					  IPV6_LEN);
 			}
 			rule->valid_flags |= NFT_RULE_PARAM_SADDR;
+			rule->weight++;
 		}
 
 		if (type4_params->classifier_mask & BIT(2)) {
@@ -1083,16 +1085,19 @@ static void hostapd_qm_prepare_nft_rule(struct hostapd_data *hapd,
 					  IPV6_LEN);
 			}
 			rule->valid_flags |= NFT_RULE_PARAM_DADDR;
+			rule->weight++;
 		}
 
 		if (type4_params->classifier_mask & BIT(3)) {
 			rule->sport = type4_params->src_port;
 			rule->valid_flags |= NFT_RULE_PARAM_SPORT;
+			rule->weight++;
 		}
 
 		if (type4_params->classifier_mask & BIT(4)) {
 			rule->dport = type4_params->dst_port;
 			rule->valid_flags |= NFT_RULE_PARAM_DPORT;
+			rule->weight++;
 		}
 
 		if (type4_params->classifier_mask & BIT(6)) {
@@ -1102,15 +1107,19 @@ static void hostapd_qm_prepare_nft_rule(struct hostapd_data *hapd,
 				rule->proto = type4_params->next_header;
 			}
 			rule->valid_flags |= NFT_RULE_PARAM_PROTO;
+			rule->weight++;
 		}
 
 		if (te->tclas_elem.type4_params.classifier_mask & BIT(5)) {
 			rule->dscp = type4_params->dscp;
 			rule->valid_flags |= NFT_RULE_PARAM_DSCP;
+			rule->weight++;
 		}
 
-		wpa_printf(MSG_INFO, "qm_id : %d classifier_type : 0x%x classifier_mask : 0x%x\n",
-			   qm_id, te->classifier_type, type4_params->classifier_mask);
+		wpa_printf(MSG_INFO, "qm_id: %d, classifier_type: 0x%x, "
+			   "classifier_mask: 0x%x, weight: %u",
+			   qm_id, te->classifier_type,
+			   type4_params->classifier_mask, rule->weight);
 
 	} else if (te->classifier_type == QM_TCLAS_CLASSIFIER_TYPE10) {
 
@@ -1141,8 +1150,17 @@ static void hostapd_qm_prepare_nft_rule(struct hostapd_data *hapd,
 					  ((type10_params->filter_value[11] &
 					  type10_params->filter_mask[11]) << 0);
 		}
+
+		rule->weight++;
 	}
 
+	/* This check handles the case when 2 x TCLAS 4 elements have
+	 * overlapped parameters, which is an undesired case. So, the weight is
+	 * capped to NFT_RULE_MAX_WEIGHT which is the maximum value.
+	 */
+	if (rule->weight > NFT_RULE_MAX_WEIGHT)
+		rule->weight = NFT_RULE_MAX_WEIGHT;
+
 	memcpy(rule->dmac, sta->addr, ETH_ALEN);
 	rule->valid_flags |= NFT_RULE_PARAM_DMAC;
 	rule->mark = (qm_id << 8) | qm_tag;
@@ -1254,8 +1272,36 @@ int hostapd_mscs_delete_all_rules(struct hostapd_data *hapd,
 	return 0;
 }
 
+
+void hostapd_scs_add_nft_rule_list(struct hostapd_nft_rule_params *rule,
+				   struct hostapd_nft_rule_params *rules,
+				   int *rule_count)
+{
+	if (!rule || !rules || !rule_count) {
+		wpa_printf(MSG_ERROR, "Invalid rule input to add rule");
+		return;
+	}
+
+
+	if (*rule_count >= NFT_MAX_RULE_COUNT) {
+		wpa_printf(MSG_ERROR, "SCS: Rule count exceeded max limit %d",
+			   NFT_MAX_RULE_COUNT);
+		return;
+	}
+
+	rules[*rule_count] = *rule;
+
+	wpa_printf(MSG_INFO, "SCS: Rule added at index %u with weight %u",
+		   *rule_count, rule->weight);
+
+	(*rule_count)++;
+}
+
+
 static int hostapd_scs_add_nft_rule(struct hostapd_data *hapd,
-				    struct sta_info *sta, int scs_idx)
+				    struct sta_info *sta, int scs_idx,
+				    struct hostapd_nft_rule_params *rules,
+				    int *rule_count)
 {
 	struct hostapd_scs_req_desc_data *scs_req_desc = sta->scs_req_desc[scs_idx];
 	struct hostapd_tclas_elements te;
@@ -1279,16 +1325,17 @@ static int hostapd_scs_add_nft_rule(struct hostapd_data *hapd,
 				rule.valid_flags |= NFT_RULE_PARAM_PROTO;
 
 				rule.proto = IPPROTO_UDP;
-				hostapd_ucode_config_nft_rule(hapd, &rule, true);
-
+				hostapd_scs_add_nft_rule_list(&rule, rules,
+							      rule_count);
 				rule.proto = IPPROTO_TCP;
 			} else if (te.classifier_type == QM_TCLAS_CLASSIFIER_TYPE10) {
 				rule.ip_family = 4;
-				hostapd_ucode_config_nft_rule(hapd, &rule, true);
+				hostapd_scs_add_nft_rule_list(&rule, rules,
+							      rule_count);
 				rule.ip_family = 6;
 			}
 
-			hostapd_ucode_config_nft_rule(hapd, &rule, true);
+			hostapd_scs_add_nft_rule_list(&rule, rules, rule_count);
 
 			os_memset(&rule, 0, sizeof(rule));
 		}
@@ -1305,16 +1352,16 @@ static int hostapd_scs_add_nft_rule(struct hostapd_data *hapd,
 			rule.valid_flags |= NFT_RULE_PARAM_PROTO;
 
 			rule.proto = IPPROTO_UDP;
-			hostapd_ucode_config_nft_rule(hapd, &rule, true);
+			hostapd_scs_add_nft_rule_list(&rule, rules, rule_count);
 
 			rule.proto = IPPROTO_TCP;
 		} else if (!rule.ip_family) {
 			rule.ip_family = 4;
-			hostapd_ucode_config_nft_rule(hapd, &rule, true);
+			hostapd_scs_add_nft_rule_list(&rule, rules, rule_count);
 			rule.ip_family = 6;
 		}
 
-		hostapd_ucode_config_nft_rule(hapd, &rule, true);
+		hostapd_scs_add_nft_rule_list(&rule, rules, rule_count);
 
 		wpa_printf(MSG_INFO, "scs_id:%u rule valid flag : 0x%x ",
 			   scs_req_desc->scs_id, rule.valid_flags);
@@ -1384,8 +1431,6 @@ hostapd_process_scs_add(struct hostapd_data *hapd, struct sta_info *sta,
 	wpa_printf(MSG_DEBUG, "SCS add success - SCS ID: %u, Session count: %u",
 		   sta->scs_req_desc[idx]->scs_id, sta->scs_session_count);
 
-	hostapd_scs_add_nft_rule(hapd, sta, idx);
-
 	return 0;
 }
 
@@ -1462,8 +1507,6 @@ hostapd_process_scs_change(struct hostapd_data *hapd, struct sta_info *sta,
 	os_memcpy(sta->scs_req_desc[idx], scs_req_desc_tmp,
 		  sizeof(*scs_req_desc_tmp));
 
-	hostapd_scs_add_nft_rule(hapd, sta, idx);
-
 	wpa_printf(MSG_DEBUG, "STA MAC: " MACSTR, MAC2STR(sta->addr));
 	wpa_printf(MSG_DEBUG,
 		   "SCS change success - SCS ID: %u, Session count: %u",
@@ -1473,6 +1516,73 @@ hostapd_process_scs_change(struct hostapd_data *hapd, struct sta_info *sta,
 }
 
 
+static void
+hostapd_prepare_nft_rule_list(struct hostapd_data *hapd, struct sta_info *sta,
+			      struct hostapd_nft_rule_params *rules,
+			      int *rule_count)
+{
+	int idx;
+
+	for (idx = 0; idx < sta->scs_session_count; idx++)
+		hostapd_scs_add_nft_rule(hapd, sta, idx, rules, rule_count);
+}
+
+
+
+static int compare_rule_weight(const void *a, const void *b)
+{
+	const struct hostapd_nft_rule_params *rule_a =
+			(const struct hostapd_nft_rule_params *)a;
+	const struct hostapd_nft_rule_params *rule_b =
+			(const struct hostapd_nft_rule_params *)b;
+
+	return (rule_a->weight > rule_b->weight) - (rule_a->weight < rule_b->weight);
+}
+
+
+static void
+hostapd_sort_nft_rule_list(struct hostapd_nft_rule_params *rules,
+			   int rule_count)
+{
+	if (!rules || rule_count <= 0) {
+		wpa_printf(MSG_INFO, "SCS: No rules to sort");
+		return;
+	}
+
+	qsort(rules, rule_count, sizeof(struct hostapd_nft_rule_params),
+	      compare_rule_weight);
+
+	wpa_printf(MSG_DEBUG, "SCS: Sorted %u rules by weight", rule_count);
+}
+
+
+static void
+hostapd_configure_nft_rule_list(struct hostapd_data *hapd,
+				struct hostapd_nft_rule_params *rules,
+				int rule_count)
+{
+	int idx;
+
+	for (idx = 0; idx < rule_count; idx++)
+		hostapd_ucode_config_nft_rule(hapd, &rules[idx], false);
+
+	for (idx = 0; idx < rule_count; idx++)
+		hostapd_ucode_config_nft_rule(hapd, &rules[idx], true);
+}
+
+
+static void hostapd_process_nft_rules(struct hostapd_data *hapd,
+				      struct sta_info *sta)
+{
+	struct hostapd_nft_rule_params rules[NFT_MAX_RULE_COUNT];
+	int rule_count = 0;
+
+	hostapd_prepare_nft_rule_list(hapd, sta, rules, &rule_count);
+	hostapd_sort_nft_rule_list(rules, rule_count);
+	hostapd_configure_nft_rule_list(hapd, rules, rule_count);
+}
+
+
 static void hostapd_process_scs_req(struct hostapd_data *hapd,
 				    struct sta_info *sta,
 				    struct hostapd_scs_req_data *scs_req,
@@ -1482,6 +1592,7 @@ static void hostapd_process_scs_req(struct hostapd_data *hapd,
 	u8 scs_id_req, scs_id_resp, request_type, status;
 	struct hostapd_scs_req_desc_data *scs_req_desc;
 	int idx, idx1, scs_req_idx;
+	bool nft_update = false;
 	bool idx_found;
 	int ret;
 
@@ -1535,6 +1646,8 @@ static void hostapd_process_scs_req(struct hostapd_data *hapd,
 				scs_resp_desc->status =
 					WLAN_STATUS_REQUEST_DECLINED;
 
+			nft_update = true;
+
 			break;
 
 		case QM_REMOVE_REQ:
@@ -1558,6 +1671,8 @@ static void hostapd_process_scs_req(struct hostapd_data *hapd,
 				scs_resp_desc->status =
 					WLAN_STATUS_REQUEST_DECLINED;
 
+			nft_update = true;
+
 			break;
 
 		default:
@@ -1567,6 +1682,9 @@ static void hostapd_process_scs_req(struct hostapd_data *hapd,
 
 	}
 
+	if (nft_update)
+		hostapd_process_nft_rules(hapd, sta);
+
 	hostapd_drv_rule_config_notify(hapd, sta->addr);
 }
 
diff --git a/src/ap/robust_av.h b/src/ap/robust_av.h
index 4220e27..9baa2cc 100644
--- a/src/ap/robust_av.h
+++ b/src/ap/robust_av.h
@@ -94,6 +94,9 @@ struct sta_info;
 #define HOSTAPD_QOS_SCS_TAG	0xB9
 #define HOSTAPD_QOS_MSCS_TAG	0x58
 
+#define NFT_MAX_RULE_COUNT	(HOSTAPD_SCS_MAX_TCLAS_ELEMENTS_PER_DESCRIPTOR * \
+				 HOSTAPD_SCS_MAX_DESCRIPTORS_PER_PEER * 2)
+#define NFT_RULE_MAX_WEIGHT	8
 #define NFT_RULE_PARAM_SADDR    (1 << 0)
 #define NFT_RULE_PARAM_DADDR    (1 << 1)
 #define NFT_RULE_PARAM_SPORT    (1 << 2)
@@ -232,6 +235,7 @@ struct hostapd_nft_rule_params {
 	u8 dmac[ETH_ALEN];
 	u32 esp_spi;
 	u8 dscp;
+	u8 weight;
 };
 
 struct hostapd_mscs_resp {
-- 
