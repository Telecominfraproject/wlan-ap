From 3336998c81d6dad6d55305971200bcb102848cb7 Mon Sep 17 00:00:00 2001
From: Yuvarani V <yuvarani@qti.qualcomm.com>
Date: Mon, 6 Oct 2025 14:45:44 +0530
Subject: [PATCH] QSDK:PROTOCOL: Remove failure handling for radio mask update
 to support sigma_dut

When the interface is brought up via sigma_dut, the radio mask
update fails because the ucode is not involved during bring-up.
To fix this, failure handling logic for radio mask
updates in setup_mld and setup_interface2 has been removed.

This change ensures that hostapd initialization continues even
if ucode was not initialized (like manual hostapd bring up
scenarios)

Fixes: Ie767fce79 (QSDK:PROTOCOL: Fix HT scan failure during ML Reconfig Link
 addition by updating radio mask)

Signed-off-by: Yuvarani V <yuvarani@qti.qualcomm.com>
---
 src/ap/hostapd.c | 8 ++------
 1 file changed, 2 insertions(+), 6 deletions(-)

diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index 0866782..4626ddb 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -1911,12 +1911,10 @@ setup_mld:
 	}
 	if (!is_mesh && hapd->iface->current_hw_info &&
 	    !hostapd_ucode_update_radio_mask(hapd->conf->iface,
-					     hapd->iface->current_hw_info->hw_idx)) {
+					     hapd->iface->current_hw_info->hw_idx))
 		wpa_printf(MSG_ERROR,
 			   "Failed to update radio mask for %s",
 			   hapd->conf->iface);
-		return -1;
-	}
 #endif /* CONFIG_IEEE80211BE */
 
 	if (conf->wmm_enabled < 0)
@@ -2800,12 +2798,10 @@ static int setup_interface2(struct hostapd_iface *iface)
 
 			if (hw_info &&
 			    !hostapd_ucode_update_radio_mask(iface->conf->bss[0]->iface,
-							     hw_info->hw_idx)) {
+							     hw_info->hw_idx))
 				wpa_printf(MSG_ERROR,
 					   "Failed to update radio mask for %s",
 					   iface->conf->bss[0]->iface);
-				goto fail;
-			}
 		}
 
 		ret = hostapd_check_ht_capab(iface);
-- 
2.34.1

