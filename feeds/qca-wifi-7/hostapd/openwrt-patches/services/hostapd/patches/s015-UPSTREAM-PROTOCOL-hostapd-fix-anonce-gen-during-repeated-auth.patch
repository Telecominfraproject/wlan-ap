From 7bc818246854cf04a8fa84d7c7d27bbd36e1c265 Mon Sep 17 00:00:00 2001
From: Sowmiya Sree Elavalagan <ssreeela@qti.qualcomm.com>
Date: Wed, 24 Sep 2025 22:34:13 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd:Fix multiple ANonce generation
 during repeated FT auth

During roaming, if the AP delays its authentication response,
the station may retry the authentication request. The AP
responds to each retry, generating a new ANonce for every
authentication reply. However, the station uses the ANonce
from the first response to construct the FTIE in its
reassociation request. This mismatch causes the AP to reject
the reassociation due to an invalid FTIE.

This patch fixes the issue by ensuring that the AP generates
the ANonce only once per FT authentication attempt and
reuses the same ANonce for all authentication replies to the
same station. This ensures consistency in the FT handshake
and prevents reassociation failures.

Signed-off-by: Shiva Sankar Gajula <sgajula@qti.qualcomm.com>
Signed-off-by: Sowmiya Sree Elavalagan <ssreeela@qti.qualcomm.com>
---
 src/ap/wpa_auth_ft.c | 19 +++++++++++++++----
 src/ap/wpa_auth_i.h  |  7 +++++++
 2 files changed, 22 insertions(+), 4 deletions(-)

diff --git a/src/ap/wpa_auth_ft.c b/src/ap/wpa_auth_ft.c
index 63089eb..1e1555f 100644
--- a/src/ap/wpa_auth_ft.c
+++ b/src/ap/wpa_auth_ft.c
@@ -3710,10 +3710,18 @@ pmk_r1_derived:
 	os_memcpy(sm->pmk_r1, pmk_r1, pmk_r1_len);
 	sm->pmk_r1_len = pmk_r1_len;
 
-	if (random_get_bytes(sm->ANonce, WPA_NONCE_LEN)) {
-		wpa_printf(MSG_DEBUG, "FT: Failed to get random data for "
-			   "ANonce");
-		goto out;
+	if (!sm->ANonce_generated) {
+		/* Generate a new ANonce for the first FT authentication request */
+		if (random_get_bytes(sm->ANonce, WPA_NONCE_LEN)) {
+			wpa_printf(MSG_DEBUG, "FT: Failed to get random data for "
+				   "ANonce");
+			goto out;
+		}
+
+		sm->ANonce_generated = true;
+	} else  {
+		wpa_hexdump(MSG_DEBUG, "FT: Reusing existing ANonce",
+			    sm->ANonce, WPA_NONCE_LEN);
 	}
 
 	/* Now that we know the correct PMK-R1 length and as such, the length
@@ -3916,6 +3924,9 @@ int wpa_ft_validate_reassoc(struct wpa_state_machine *sm, const u8 *ies,
 
 	wpa_hexdump(MSG_DEBUG, "FT: Reassoc Req IEs", ies, ies_len);
 
+	/* Reset ANonce generation flag after receiving reassoc request */
+	sm->ANonce_generated = 0;
+
 	if (wpa_ft_parse_ies(ies, ies_len, &parse, sm->wpa_key_mgmt,
 			     false) < 0) {
 		wpa_printf(MSG_DEBUG, "FT: Failed to parse FT IEs");
diff --git a/src/ap/wpa_auth_i.h b/src/ap/wpa_auth_i.h
index 2a43aa6..986f0f1 100644
--- a/src/ap/wpa_auth_i.h
+++ b/src/ap/wpa_auth_i.h
@@ -61,6 +61,13 @@ struct wpa_state_machine {
 	unsigned int pmk_len;
 	u8 pmkid[PMKID_LEN]; /* valid if pmkid_set == 1 */
 	struct wpa_ptk PTK;
+	/*
+	* Flag indicating whether ANonce has already been generated for this STA
+	* during the current FT authentication exchange. This helps ensure that
+	* the same ANonce is reused across FT auth retries to avoid mismatch
+	* during reassociation.
+	*/
+	bool ANonce_generated;
 	u8 keyidx_active;
 	bool use_ext_key_id;
 	bool PTK_valid;
-- 
2.34.1

