@@ -4335,6 +4335,7 @@ void hostapd_interface_deinit_free(struc
 	hostapd_interface_deinit(iface);
 	wpa_printf(MSG_DEBUG, "%s: driver=%p drv_priv=%p -> hapd_deinit",
