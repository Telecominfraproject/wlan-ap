From 5283f0543ff9ef4d25837425fa235c64dd82b18f Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Sun, 5 Oct 2025 21:23:50 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:HOSTAPD: Remove NFT programming for SCS
 uplink desc

Block change to prepare NF table rules if the SCS
descriptor does not have any TCLAS elements i.e,
an Uplink descriptor.

Tag: SCS

Patch-dependency:
s020-UPSTREAM-PROTOCOL-HOSTAPD-Weight-based-NFT-rule-config.patch

Patch-work: NA

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 src/ap/robust_av.c | 10 ++++++++--
 1 file changed, 8 insertions(+), 2 deletions(-)

diff --git a/src/ap/robust_av.c b/src/ap/robust_av.c
index 61bbfba..91b52dd 100644
--- a/src/ap/robust_av.c
+++ b/src/ap/robust_av.c
@@ -1523,12 +1523,18 @@ hostapd_prepare_nft_rule_list(struct hostapd_data *hapd, struct sta_info *sta,
 {
 	int idx;
 
-	for (idx = 0; idx < sta->scs_session_count; idx++)
+	for (idx = 0; idx < sta->scs_session_count; idx++) {
+		/* SCS Uplink descriptors do not have TCLAS elements and do not
+		 * need rule prepare for NF table programming.
+		 */
+		if (!sta->scs_req_desc[idx]->num_tclas_elements)
+			continue;
+
 		hostapd_scs_add_nft_rule(hapd, sta, idx, rules, rule_count);
+	}
 }
 
 
-
 static int compare_rule_weight(const void *a, const void *b)
 {
 	const struct hostapd_nft_rule_params *rule_a =
