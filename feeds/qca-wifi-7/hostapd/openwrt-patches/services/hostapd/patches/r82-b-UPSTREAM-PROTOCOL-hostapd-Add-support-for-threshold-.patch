From f7e994edf363871efe7fbd86013897e1184b874e Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Fri, 18 Jul 2025 12:35:21 +0530
Subject: [PATCH 2/4] UPSTREAM: PROTOCOL: hostapd: Add support for threshold
 based puncturing

Currently, the dynamic puncturing support in hostapd for SP mode
punctures the unavailable or low power subchannels such that the
final power for the punctured channel is higher than the
    (1) the unpunctured channel EIRP for SP mode and
    (2) the unpunctured channel EIRP of LPI or VLP modes (if best power
        mode is enabled).

This patch adds support to further restrict the puncturing based
on a configurable EIRP threshold.

If the initial SP EIRP is greater than the configured threshold,
no puncturing is done. Subchannels will be punctured till we find
a valid pattern that meets the threshold.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
r82-a-UPSTREAM-PROTOCOL-hostapd-Add-support-for-6-GHz-dyna.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 hostapd/config_file.c  |  9 +++++++++
 hostapd/hostapd.conf   |  7 +++++++
 src/ap/ap_config.c     |  1 +
 src/ap/ap_config.h     |  7 +++++++
 src/ap/ctrl_iface_ap.c |  6 ++++--
 src/ap/hostapd.c       | 10 ++++++++++
 src/ap/hostapd.h       |  1 +
 7 files changed, 39 insertions(+), 2 deletions(-)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 6d357466cb30..10ad9ee52ada 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -3657,6 +3657,15 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 		}
 	} else if (os_strcmp(buf, "puncture_strict_6ghz") == 0) {
 		conf->puncture_strict_6ghz = atoi(pos);
+	} else if (os_strcmp(buf, "punc_eirp_thres_6ghz") == 0) {
+		conf->punc_eirp_thres_6ghz = atoi(pos);
+		if (conf->punc_eirp_thres_6ghz < CHAN_MIN_TX_POWER ||
+		    conf->punc_eirp_thres_6ghz > MAX_EIRP_THRESHOLD) {
+			wpa_printf(MSG_ERROR,
+				   "Line %d: invalid punc_eirp_thres value",
+				   line);
+			return 1;
+		}
 	} else if (os_strcmp(buf, "reg_def_cli_eirp_psd") == 0) {
 		conf->reg_def_cli_eirp_psd = atoi(pos);
 	} else if (os_strcmp(buf, "reg_sub_cli_eirp_psd") == 0) {
diff --git a/hostapd/hostapd.conf b/hostapd/hostapd.conf
index 000d4b1561de..cc063034ed2b 100644
--- a/hostapd/hostapd.conf
+++ b/hostapd/hostapd.conf
@@ -1145,6 +1145,13 @@ wmm_ac_vo_acm=0
 # channels.
 #puncture_strict_6ghz=0
 
+# punc_eirp_thres_6ghz: Puncture EIRP threshold for 6 GHz band.
+# This configures the EIRP threshold to be used for dynamic puncturing of 6 GHz
+# channels in standard power mode. If puncture_strict_6ghz is set to 0,
+# hostapd will try to dynamically puncture 6 GHz channels till the EIRP
+# threshold is reached.
+#punc_eirp_thres_6ghz=25
+
 ##### IEEE 802.1X-2004 related configuration ##################################
 
 # Require IEEE 802.1X authorization
diff --git a/src/ap/ap_config.c b/src/ap/ap_config.c
index 24e78ef73c3e..43a17bcc3a11 100644
--- a/src/ap/ap_config.c
+++ b/src/ap/ap_config.c
@@ -354,6 +354,7 @@ struct hostapd_config * hostapd_config_defaults(void)
 	conf->he_6ghz_reg_pwr_type = HE_REG_INFO_6GHZ_AP_TYPE_VLP;
 	conf->enable_best_power_mode = 1;
 	conf->puncture_strict_6ghz = 0;
+	conf->punc_eirp_thres_6ghz = CHAN_MIN_TX_POWER;
 	conf->reg_def_cli_eirp_psd = -1;
 	conf->reg_sub_cli_eirp_psd = -1;
 	conf->reg_def_cli_eirp = -1;
diff --git a/src/ap/ap_config.h b/src/ap/ap_config.h
index 7a4acbb67595..6b026c9c38dd 100644
--- a/src/ap/ap_config.h
+++ b/src/ap/ap_config.h
@@ -1247,6 +1247,13 @@ struct hostapd_config {
 	 * disable dynamic puncturing.
 	 */
 	bool puncture_strict_6ghz;
+	/*
+	 * This configures the EIRP threshold to be used for dynamic
+	 * puncturing of 6 GHz channels in Standard Power mode.
+	 * If puncture_strict_6ghz is set to false, we try to puncture
+	 * channels till the EIRP of the channel meets this threshold.
+	 */
+	s16 punc_eirp_thres_6ghz;
 	bool discard_6g_awgn_event;
 
 	int reg_def_cli_eirp_psd;
diff --git a/src/ap/ctrl_iface_ap.c b/src/ap/ctrl_iface_ap.c
index 88d6fe36ea48..06eb46a8adc6 100644
--- a/src/ap/ctrl_iface_ap.c
+++ b/src/ap/ctrl_iface_ap.c
@@ -1158,8 +1158,10 @@ int hostapd_ctrl_iface_status(struct hostapd_data *hapd, char *buf,
 
 		if (is_6ghz_op_class(iface->conf->op_class)) {
 			ret = os_snprintf(buf + len, buflen - len,
-					  "puncture_strict_6ghz=%d\n",
-					  iface->conf->puncture_strict_6ghz);
+					  "puncture_strict_6ghz=%d\n"
+					  "punc_eirp_thres_6ghz=%d\n",
+					  iface->conf->puncture_strict_6ghz,
+					  iface->conf->punc_eirp_thres_6ghz);
 			if (os_snprintf_error(buflen - len, ret))
 				return len;
 			len += ret;
diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index c797fab90bd3..38169f78fc37 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -7497,6 +7497,16 @@ s8 hostapd_get_6ghz_best_pp(struct hostapd_iface *iface, u16 freq,
 	if (initial_sp_eirp == CHAN_MIN_TX_POWER)
 		out_pp = PUNCTURE_INVALID;
 
+	if (iface->conf->punc_eirp_thres_6ghz != CHAN_MIN_TX_POWER) {
+		if (initial_sp_eirp > iface->conf->punc_eirp_thres_6ghz) {
+			wpa_printf(MSG_INFO,
+				   "AFC: Initial SP EIRP %d is greater than threshold %d",
+				   initial_sp_eirp, iface->conf->punc_eirp_thres_6ghz);
+			return 0;
+		}
+
+		initial_sp_eirp = iface->conf->punc_eirp_thres_6ghz;
+	}
 	hostapd_get_optimal_pp(iface, freq, center_freq, bw, *pp, pri_chan_pos,
 			       initial_sp_eirp, &ref_eirp, &out_pp);
 	if (out_pp == PUNCTURE_INVALID) {
diff --git a/src/ap/hostapd.h b/src/ap/hostapd.h
index 31d304c526a4..04c7b7e82e76 100644
--- a/src/ap/hostapd.h
+++ b/src/ap/hostapd.h
@@ -1077,6 +1077,7 @@ static inline bool hostapd_mld_is_first_bss(struct hostapd_data *hapd)
 #define CHAN_MIN_TWICE_TX_POWER              (CHAN_MIN_TX_POWER * 2)
 #define CHAN_MAX_TWICE_TX_POWER              ((CHAN_MAX_TX_POWER * 2) + 1)
 
+#define MAX_EIRP_THRESHOLD      33  /* A value above Max LPI and below Max SP */
 
 #define NUM_20PP_PUNC_80MHZ      4
 #define NUM_20PP_PUNC_160MHZ     8
