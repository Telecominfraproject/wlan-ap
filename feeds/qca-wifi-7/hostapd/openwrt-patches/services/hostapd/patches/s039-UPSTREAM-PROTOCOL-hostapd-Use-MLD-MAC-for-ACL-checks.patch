From e5a24f2effdba9374eeb50d2053ef81b5d13dfaf Mon Sep 17 00:00:00 2001
From: Sowmiya Sree Elavalagan <ssreeela@qti.qualcomm.com>
Date: Fri, 5 Dec 2025 00:43:46 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd: Use MLD MAC for ACL checks in
 auth/assoc

With 802.11be MLO, management frames arrive with the per‑link MAC in mgmt->sa,
while hostapd ACL entries are keyed by the station’s MLD MAC (optionally with
a VLAN ID). Comparing the link MAC against the MLD MAC fails, which prevents
dynamic VLAN creation and VLAN ID assignment for MLD stations.

Use the MLD MAC for ACL checks, in authentication and association calls,
pass MLD address for ieee802_11_allowed_address check. Align ACL
matching with the address stored in the ACL list and fix VLAN setup
for MLD stations.

Patch-dependency: s021-UPSTREAM-PROTOCOL-hostapd-Support-MLD-STA-reconnecti.patch

Signed-off-by: Sowmiya Sree Elavalagan <ssreeela@qti.qualcomm.com>
---
 src/ap/ieee802_11.c | 30 ++++++++++++++++++++++--------
 1 file changed, 22 insertions(+), 8 deletions(-)

--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -3477,7 +3477,7 @@ static void handle_auth(struct hostapd_d
 	 */
 	if (mld_sta) {
 
-		res = ieee802_11_allowed_address(hapd, mgmt->sa,
+		res = ieee802_11_allowed_address(hapd, sa,
 						 (const u8 *) mgmt, len,
 						 &rad_info);
 		if (res == HOSTAPD_ACL_REJECT && !skip_acl) {
@@ -3492,7 +3492,6 @@ static void handle_auth(struct hostapd_d
 	}
 #endif /* CONFIG_IEEE80211BE */
 
-
 #ifdef CONFIG_SAE
 	if (auth_alg == WLAN_AUTH_SAE && !from_queue &&
 	    (auth_transaction == 1 ||
@@ -6083,7 +6082,8 @@ void fils_hlp_timeout(void *eloop_ctx, v
 static struct sta_info * handle_mlo_translate(struct hostapd_data *hapd,
 					      const struct ieee80211_mgmt *mgmt,
 					      size_t len, bool reassoc,
-					      struct hostapd_data **assoc_hapd)
+					      struct hostapd_data **assoc_hapd,
+					      u8 *assoc_mld_addr)
 {
 	struct sta_info *sta;
 	struct ieee802_11_elems elems;
@@ -6109,6 +6109,8 @@ static struct sta_info * handle_mlo_tran
 					      mld_addr))
 		return NULL;
 
+	os_memcpy(assoc_mld_addr, mld_addr, ETH_ALEN);
+
 	sta = ap_get_sta(hapd, mld_addr);
 	if (!sta)
 		return NULL;
@@ -6252,6 +6254,7 @@ static void handle_assoc(struct hostapd_
 	int omit_rsnxe = 0;
 	bool set_beacon = false;
 	bool mld_addrs_not_translated = false;
+	u8 mld_addr[ETH_ALEN] = {0};
 
 	if (len < IEEE80211_HDRLEN + (reassoc ? sizeof(mgmt->u.reassoc_req) :
 				      sizeof(mgmt->u.assoc_req))) {
@@ -6325,7 +6328,7 @@ static void handle_assoc(struct hostapd_
 		struct hostapd_data *assoc_hapd;
 
 		sta = handle_mlo_translate(hapd, mgmt, len, reassoc,
-					   &assoc_hapd);
+					   &assoc_hapd, mld_addr);
 		if (sta) {
 			if (hapd != assoc_hapd) {
 				wpa_printf(MSG_DEBUG,
@@ -6381,9 +6384,20 @@ static void handle_assoc(struct hostapd_
 			int acl_res;
 			struct radius_sta info;
 
-			acl_res = ieee802_11_allowed_address(hapd, mgmt->sa,
-							     (const u8 *) mgmt,
-							     len, &info);
+			if (hapd->conf->mld_ap && sta && sta->mld_info.mld_sta) {
+				acl_res = ieee802_11_allowed_address(hapd, sta->addr,
+								     (const u8 *) mgmt,
+								     len, &info);
+			} else if (!is_zero_ether_addr(mld_addr)) {
+				acl_res = ieee802_11_allowed_address(hapd, mld_addr,
+								     (const u8 *) mgmt,
+								     len, &info);
+			} else {
+				acl_res = ieee802_11_allowed_address(hapd, mgmt->sa,
+								     (const u8 *) mgmt,
+								     len, &info);
+			}
+
 			if (acl_res == HOSTAPD_ACL_REJECT) {
 				wpa_msg(hapd->msg_ctx, MSG_DEBUG,
 					"Ignore Association Request frame from "
@@ -6524,7 +6538,6 @@ static void handle_assoc(struct hostapd_
 	     sta->sa_query_timed_out &&
 	     sta->mld_info.mld_sta) {
 		struct ieee802_11_elems elems;
-		u8 mld_addr[ETH_ALEN];
 
 		wpa_auth_sta_deinit(sta->wpa_sm);
 		sta->wpa_sm = NULL;
