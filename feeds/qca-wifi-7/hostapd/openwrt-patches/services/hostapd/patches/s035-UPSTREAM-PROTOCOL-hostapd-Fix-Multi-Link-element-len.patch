From 10a70534ccbd6b8c926403c619602b4c22723b04 Mon Sep 17 00:00:00 2001
From: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
Date: Sat, 22 Nov 2025 03:33:30 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Fix Multi-Link element length
 calculation for fragmentation

The hostapd_eid_eht_ml_len() function incorrectly calculated length
for fragmented MultiiLink elements, causing length mismatches in Link
Reconfiguration Response frames. hostapd_eid_eht_ml_len() incorrectly
added a fragment header when a Per-STA subelement was exactly 255 bytes,
leading to a mismatch between the computed mle_len and the bytes filled
by hostapd_eid_eht_basic_ml_common.

Add only the 2-byte base header when Per-STA data is 255 bytes and to
account for fragment headers only for data beyond 255. Similarly, add
ML element fragment headers only when ML data exceeds 254 bytes. This
aligns computed lengths.

Patch-dependency: None

Patch-work: None

Fixes: Ia63a866d66 ("UPSTREAM:PROTOCOL: Aggregate link_sta operations for ML reconfig")

Signed-off-by: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
---
 src/ap/ieee802_11_eht.c | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 048d1811aaf1..e8681433959c 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -759,7 +759,7 @@ static size_t hostapd_eid_eht_ml_len(struct mld_info *info,
 
 		/* Element data and (fragmentation) headers */
 		eht_ml_len += sta_len;
-		eht_ml_len += 2 + sta_len / 255 * 2;
+		eht_ml_len += 2 + (sta_len > 255 ? ((sta_len - 1) / 255) * 2 : 0);
 	}
 
 	/* Element data */
@@ -768,9 +768,8 @@ static size_t hostapd_eid_eht_ml_len(struct mld_info *info,
 	/* First header (254 bytes of data) */
 	len += 3;
 
-	/* Fragmentation headers; +1 for shorter first chunk */
 	if (eht_ml_len > 254)
-		len += (eht_ml_len + 1) / 255 * 2;
+		len += (eht_ml_len / 255) * 2;
 
 	return len;
 }
