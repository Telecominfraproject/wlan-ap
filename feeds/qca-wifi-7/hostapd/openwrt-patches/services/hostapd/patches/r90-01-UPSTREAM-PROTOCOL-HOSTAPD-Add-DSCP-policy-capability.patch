From 144eb0f59eea57d491edeb3a42c026443916ef12 Mon Sep 17 00:00:00 2001
From: Aishwarya R <aisr@qti.qualcomm.com>
Date: Mon, 14 Jul 2025 08:41:30 +0530
Subject: [PATCH 1/7] UPSTREAM:PROTOCOL:HOSTAPD: Add DSCP policy capability
 configuration

Introduce a new configuration parameter enable_dscp_policy_capa
to allow enabling or disabling DSCP policy capability per BSS.

The DSCP policy capability is disabled by default.
Add enable_dscp_policy_capa=1 option in the configuration file to
enable DSCP policy

Patch-dependency: None
Tag: DAP

Signed-off-by: Aishwarya R <aisr@qti.qualcomm.com>
---
 hostapd/config_file.c | 2 ++
 src/ap/ap_config.c    | 1 +
 src/ap/ap_config.h    | 1 +
 3 files changed, 4 insertions(+)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 561dbbc..7a50231 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -5127,6 +5127,8 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 	} else if (os_strcmp(buf, "ttlm_enable") == 0) {
 		bss->ttlm_enable = atoi(pos);
 #endif /* CONFIG_IEEE80211BE */
+	} else if (os_strcmp(buf, "enable_dscp_policy_capa") == 0) {
+		bss->enable_dscp_policy_capa = atoi(pos);
 	} else if (os_strcmp(buf, "twt_responder_caps") == 0) {
 		int val;
 		val = atoi(pos);
diff --git a/src/ap/ap_config.c b/src/ap/ap_config.c
index 4083a1f..e46f443 100644
--- a/src/ap/ap_config.c
+++ b/src/ap/ap_config.c
@@ -195,6 +195,7 @@ void hostapd_config_defaults_bss(struct hostapd_bss_config *bss)
 	bss->wmm_ac_params[1] = ac_bk;
 	bss->wmm_ac_params[2] = ac_vi;
 	bss->wmm_ac_params[3] = ac_vo;
+	bss->enable_dscp_policy_capa = false;
 	bss->twt_responder_caps = TWT_ITWT_ENABLED;
 }
 
diff --git a/src/ap/ap_config.h b/src/ap/ap_config.h
index d54cf7b..bc56fb3 100644
--- a/src/ap/ap_config.h
+++ b/src/ap/ap_config.h
@@ -1015,6 +1015,7 @@ struct hostapd_bss_config {
 	bool is_epcs_enabled;
 	bool ttlm_enable;
 #endif /* CONFIG_IEEE80211BE */
+	bool enable_dscp_policy_capa;
 	/*
 	 * twt_responder_caps: 0 - Disable TWT
 	 *                     1 - Enable TWT
-- 
2.34.1

