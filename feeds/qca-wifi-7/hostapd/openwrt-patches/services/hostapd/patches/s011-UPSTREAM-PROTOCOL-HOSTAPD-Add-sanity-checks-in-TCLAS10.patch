From 03f34c9c281c21540d92a73f5c61cff2e9ade563 Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Tue, 23 Sep 2025 10:57:26 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:HOSTAPD: Add sanity checks in TCLAS10
 NL80211 ops

Add additional sanity checks in nl80211 set_qos ops for TCLAS10
filter and nest handling.

Patch-dependency:
r92-05-UPSTREAM-PROTOCOL-CP-HOSTAPD-Copy-and-send-SCS-data-over-QM.patch

Tag: SCS

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 src/drivers/driver_nl80211.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 450dc6c..faacf8e 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -16017,6 +16017,9 @@ nl80211_set_qm_tclas10_elem(struct nl_msg *msg,
 	if (!tclas_type10)
 		return -ENOBUFS;
 
+	if (type10_params.filter_len > TCLAS10_FILTER_LEN)
+		return -EINVAL;
+
 	if (nla_put_u8(msg, NL80211_TCLAS_TYPE10_ATTR_PROT_INSTANCE,
 		       type10_params.protocol_instance) ||
 	    nla_put_u8(msg, NL80211_TCLAS_TYPE10_ATTR_PROT_NUMBER,
@@ -16086,6 +16089,8 @@ static int nl80211_set_qm_tclas(struct nl_msg *msg,
 	int tclas_idx;
 
 	qm_tclas = nla_nest_start(msg, NL80211_QM_DESC_ATTR_TCLAS_ELEMENTS);
+	if (!qm_tclas)
+		return -ENOBUFS;
 
 	for (tclas_idx = 0;
 	     tclas_idx < qm_req_desc.num_tclas_elements;
-- 
