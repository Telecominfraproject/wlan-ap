From d2490ba4ccdd8db4bb3a8c0be06697b081eb42c4 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Thu, 3 Apr 2025 14:14:05 +0530
Subject: [PATCH 01/20] UPSTREAM: PROTOCOL: hostapd: Add EPCS protocol
 definitions

Define EPCS request, response and teardown action frames
based on the format defined in the IEEE P802.11be/D7.0
spec from sections:

9.6.38.5 EPCS Priority Access Enable Request frame format
9.6.38.6 EPCS Priority Access Enable Response frame format
9.6.38.7 EPCS Priority Access Teardown frame details

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 src/common/ieee802_11_defs.h | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/src/common/ieee802_11_defs.h b/src/common/ieee802_11_defs.h
index 8c298a9..ea1a582 100644
--- a/src/common/ieee802_11_defs.h
+++ b/src/common/ieee802_11_defs.h
@@ -1104,6 +1104,23 @@ struct ieee80211_mgmt {
 					u8 trans_id[WLAN_SA_QUERY_TR_ID_LEN];
 					u8 variable[]; /* OCI element */
 				} STRUCT_PACKED sa_query_req;
+				struct {
+					u8 action;
+					u8 dialog_token;
+					/*Priority Access Multi-Link element*/
+					u8 variable[];
+				} STRUCT_PACKED epcs_req;
+				struct {
+					u8 action;
+					u8 dialog_token;
+					le16 status;
+					/*Priority Access Multi-Link element*/
+					u8 variable[];
+				} STRUCT_PACKED epcs_resp;
+				struct {
+					u8 action;
+					u8 variable[];
+				} STRUCT_PACKED epcs_teardown;
 				struct {
 					u8 action; /* */
 					u8 trans_id[WLAN_SA_QUERY_TR_ID_LEN];
-- 
2.34.1

