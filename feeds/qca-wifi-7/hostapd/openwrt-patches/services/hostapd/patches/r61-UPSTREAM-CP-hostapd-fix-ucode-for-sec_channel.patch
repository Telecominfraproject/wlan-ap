From bc77cde63d658aa732d587a4d7c0c8229251eb01 Mon Sep 17 00:00:00 2001
From: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
Date: Fri, 31 Jan 2025 11:10:49 -0800
Subject: [PATCH] UPSTREAM:CP:hostapd: fix ucode for sec_channel

WDS repeater AP fails to come up if configured bandwidth
is >= 40 MHz and WDS station associates with root AP in 20 MHz.
Failure happens because of three reasons:
(1) 'sec_channel' is not reset to 0 in uc_wpa_freq_info() when
'chanwidth' used for AP bring up is overwritten by new bandwidth
passed by wpa_supplicant upon association. Update 'sec_channel'
as per the new bandwidth.
(2) UPDATE_VAL() skips over processing when ucv_get_object()
returns zero because of the first condition checked in its
definition. Objects can have value '0' in valid cases and
should be processed accordingly. Fix the macro.
(3) uc_hostapd_iface_start() modifies seg0 and seg1 only if
new values are sent by uc_wpa_freq_info() via objects. In case
of this failure, original seg0 is non-zero which is rejected by
hostapd_set_freq_params() for new 20 MHz bandiwidth. Include '0'
for seg0 and seg1 in objects.

Patch-dependency:
r50-03-QSDK-CP-hostapd-add-missing-WDS-repeater-6G-bring-up.patch

Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 src/ap/ucode.c    | 10 ++++++----
 src/utils/ucode.c |  7 ++++++-
 2 files changed, 12 insertions(+), 5 deletions(-)

--- a/src/utils/ucode.c
+++ b/src/utils/ucode.c
@@ -173,6 +173,7 @@ uc_value_t *uc_wpa_freq_info(uc_vm_t *vm
                 break;
         case CHAN_WIDTH_20_NOHT:
         case CHAN_WIDTH_20:
+		sec_channel = 0;
         case CHAN_WIDTH_40:
         default:
                 chanwidth = CONF_OPER_CHWIDTH_USE_HT;
@@ -208,8 +209,12 @@ skip_chan_width:
 	ucv_object_add(ret, "frequency", ucv_int64_new(freq_val));
 	ucv_object_add(ret, "oper_chwidth", ucv_int64_new(chanwidth));
 
-	if (!sec_channel && freq_val < 5900 && !cf1)
+	if (!sec_channel && freq_val < 5900 && !cf1) {
+		ucv_object_add(ret, "center_seg0_idx", ucv_int64_new(seg0_idx));
+		ucv_object_add(ret, "center_seg1_idx", ucv_int64_new(seg1_idx));
+		ucv_object_add(ret, "punct_bitmap", ucv_int64_new(punct_bitmap));
 		return ret;
+	}
 
 	if (freq_val >= 5900)
 		center_ofs = 0;
