From 3624eeed53642150b83733dccd72071ab741fb3b Mon Sep 17 00:00:00 2001
From: Muna Sinada <muna.sinada@oss.qualcomm.com>
Date: Thu, 30 Oct 2025 19:00:28 -0700
Subject: [PATCH] UPSTREAM:CP hostapd: pass radio index in MU EDCA event

Currently we pass wiphy index to be utilized to identify the radio in
which the MU EDCA values should be updated for.

With the introduction of multi radio wiphy architecture, all radios
will be under one wiphy. As a result, MU EDCA values were being
updated only on the first link, many times being the wrong one.

Parse newly used NL80211_ATTR_WIPHY_RADIO_INDEX attribute and use it
to search for the BSS in which the targeted radio is assigned to.

Signed-off-by: Muna Sinada <muna.sinada@oss.qualcomm.com>
---
 src/ap/drv_callbacks.c             | 30 +++++++++++++++++++++++-------
 src/drivers/driver.h               |  1 +
 src/drivers/driver_nl80211_event.c |  5 +++++
 3 files changed, 29 insertions(+), 7 deletions(-)

--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -2497,8 +2497,33 @@ static void hostapd_event_wds_sta_interf
 static void hostapd_event_update_muedca_params(struct hostapd_data *hapd,
 					       struct update_muedca *params)
 {
+	struct hostapd_data *selected_hapd;
+	bool radio_matched = false;
 	int i;
 
+	if (hapd->conf->mld_ap) {
+		for_each_mld_link(selected_hapd, hapd) {
+			if (!selected_hapd->iface ||
+			    !selected_hapd->iface->current_hw_info)
+				continue;
+
+			if (selected_hapd->iface->current_hw_info->hw_idx ==
+							    params->radio_idx) {
+				radio_matched = true;
+				break;
+			}
+		}
+
+		if (!radio_matched) {
+			wpa_printf(MSG_DEBUG,
+				   "Radio index %u does not match HW index for any interface",
+				   params->radio_idx);
+			return;
+		}
+
+		hapd = selected_hapd;
+	}
+
 	/* Update current MU-EDCA parameters */
 	for (i = 0; i < 3; i++) {
 		hapd->iface->conf->he_mu_edca.he_mu_ac_be_param[i] =
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -7835,6 +7835,7 @@ union wpa_event_data {
 	 * struct update_muedca - Data for EVENT_UPDATE_MU_EDCA_PARAMS
 	 */
 	struct update_muedca {
+		u8 radio_idx;
 		u8 he_mu_ac_be_param[3];
 		u8 he_mu_ac_bk_param[3];
 		u8 he_mu_ac_vi_param[3];
--- a/src/drivers/driver_nl80211_event.c
+++ b/src/drivers/driver_nl80211_event.c
@@ -4821,6 +4821,15 @@ static void nl80211_update_muedca_params
 	union wpa_event_data ed;
 	int i;
 
+	os_memset(&ed, 0, sizeof(ed));
+
+	if (tb[NL80211_ATTR_WIPHY_RADIO_INDEX])
+		ed.update_muedca.radio_idx = nla_get_u8(tb[NL80211_ATTR_WIPHY_RADIO_INDEX]);
+	else {
+		/* Default to first radio */
+		ed.update_muedca.radio_idx = 0;
+	}
+
 	if (!tb[NL80211_ATTR_HE_MUEDCA_PARAMS])
 		return;
 
