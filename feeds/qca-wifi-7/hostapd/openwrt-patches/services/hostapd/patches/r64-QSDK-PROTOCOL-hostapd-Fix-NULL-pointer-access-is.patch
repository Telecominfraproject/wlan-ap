From d3787290638dac5e53ba6af6ee63abcb24396206 Mon Sep 17 00:00:00 2001
From: Roopni Devanathan <quic_rdevanat@quicinc.com>
Date: Thu, 6 Mar 2025 11:29:57 +0530
Subject: [PATCH] QSDK:PROTOCOL:hostapd: Fix NULL pointer access issues

Sometimes, mode and VHT capabilities of a hostapd interface might not be
allocated and might be empty. But functions - hostapd_eid_ht_operation()
and hostapd_eid_vht_operation() are trying to access these possibly NULL
pointers, namely, hapd->iface->current_mode and
hapd->iface->current_mode->vht_capab leading to hostapd crash.

Fix this by checking if these pointers are NULL before using them.

Depends-on: None
Fixes: None

Signed-off-by: Roopni Devanathan <quic_rdevanat@quicinc.com>
---
 src/ap/ieee802_11_ht.c  | 5 +++--
 src/ap/ieee802_11_vht.c | 5 +++--
 2 files changed, 6 insertions(+), 4 deletions(-)

diff --git a/src/ap/ieee802_11_ht.c b/src/ap/ieee802_11_ht.c
index 3b0af99..cdfe7e7 100644
--- a/src/ap/ieee802_11_ht.c
+++ b/src/ap/ieee802_11_ht.c
@@ -127,7 +127,7 @@ no_update:
 u8 * hostapd_eid_ht_operation(struct hostapd_data *hapd, u8 *eid)
 {
 	struct ieee80211_ht_operation *oper;
-	le32 vht_capabilities_info;
+	le32 vht_capabilities_info = 0;
 	u8 *pos = eid;
 	u8 chwidth;
 
@@ -145,7 +145,8 @@ u8 * hostapd_eid_ht_operation(struct hostapd_data *hapd, u8 *eid)
 	oper->operation_mode = host_to_le16(hapd->iface->ht_op_mode);
 	set_ht_param(hapd, oper);
 
-	vht_capabilities_info = host_to_le32(hapd->iface->current_mode->vht_capab);
+	if (hapd->iface->current_mode && hapd->iface->current_mode->vht_capab)
+		vht_capabilities_info = host_to_le32(hapd->iface->current_mode->vht_capab);
 	chwidth = hostapd_get_oper_chwidth(hapd->iconf);
 	if (vht_capabilities_info & VHT_CAP_EXTENDED_NSS_BW_SUPPORT
 		&& ((chwidth == CHANWIDTH_160MHZ) || (chwidth == CHANWIDTH_80P80MHZ))) {
diff --git a/src/ap/ieee802_11_vht.c b/src/ap/ieee802_11_vht.c
index dde63d1..198671b 100644
--- a/src/ap/ieee802_11_vht.c
+++ b/src/ap/ieee802_11_vht.c
@@ -92,7 +92,7 @@ u8 * hostapd_eid_vht_capabilities(struct hostapd_data *hapd, u8 *eid, u32 nsts)
 u8 * hostapd_eid_vht_operation(struct hostapd_data *hapd, u8 *eid)
 {
 	struct ieee80211_vht_operation *oper;
-	le32 vht_capabilities_info;
+	le32 vht_capabilities_info = 0;
 	u8 *pos = eid;
 	enum oper_chan_width oper_chwidth = hapd->iconf->vht_oper_chwidth;
 	u8 seg0 = hapd->iconf->vht_oper_centr_freq_seg0_idx;
@@ -127,7 +127,8 @@ u8 * hostapd_eid_vht_operation(struct hostapd_data *hapd, u8 *eid)
 	oper->vht_op_info_chan_center_freq_seg1_idx = seg1;
 
 	oper->vht_op_info_chwidth = oper_chwidth;
-	vht_capabilities_info = host_to_le32(hapd->iface->current_mode->vht_capab);
+	if (hapd->iface->current_mode && hapd->iface->current_mode->vht_capab)
+		vht_capabilities_info = host_to_le32(hapd->iface->current_mode->vht_capab);
 	if (oper_chwidth == CONF_OPER_CHWIDTH_160MHZ) {
 		/*
 		 * Convert 160 MHz channel width to new style as interop
-- 
