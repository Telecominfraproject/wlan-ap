From 588e54809c17f47dd2e6bdb44672ee18078a5576 Mon Sep 17 00:00:00 2001
From: Arunpandi Kannan <arunpand@qti.qualcomm.com>
Date: Tue, 4 Nov 2025 14:29:40 +0530
Subject: [PATCH] QSDK: PROTOCOL: HOSTAPD: [WAR]Send remain on channel before 
 doing chirping

Send remain on channel command to enable off-channel in driver.
Currently there is a limitation in driver that if we send off channel
packet directly, it will take some time to configure off channel and
that consumes most of duraion which configured from supplicant.
So enable off-channel first, and then send the off-channel packet.
so that given off-chan during in tranmission properly used in driver.

Also introduce new variable is_dpp_reconfig to prevent sending off
channel command before sending reconfig packets. There are some hw_sim
failure cases during reconfig if we send remain on channel before sending
DPP reconfig packets.

Tag: DPP
Patch-work: None
Patch-dependency: None

Signed-off-by: Arunpandi Kannan <arunpand@qti.qualcomm.com>
---
 wpa_supplicant/dpp_supplicant.c   | 28 +++++++++++++++++++++++++++-
 wpa_supplicant/wpa_supplicant_i.h |  2 ++
 2 files changed, 29 insertions(+), 1 deletion(-)

diff --git a/wpa_supplicant/dpp_supplicant.c b/wpa_supplicant/dpp_supplicant.c
index 526d507..cb2637a 100644
--- a/wpa_supplicant/dpp_supplicant.c
+++ b/wpa_supplicant/dpp_supplicant.c
@@ -5315,6 +5315,13 @@ static void wpas_dpp_chirp_next(void *eloop_ctx, void *timeout_ctx)
 		wpa_s->dpp_chirp_round++;
 		wpa_printf(MSG_DEBUG, "DPP: Start chirping round %d",
 			   wpa_s->dpp_chirp_round);
+		if (wpa_s->is_dpp_reconfig == false) {
+			wpa_drv_remain_on_channel(wpa_s, wpa_s->dpp_chirp_freq, 2000);
+			wpa_s->is_roc_started = true;
+			if (eloop_register_timeout(3, 0, wpas_dpp_chirp_timeout, wpa_s, NULL) < 0)
+				wpas_dpp_chirp_stop(wpa_s, 0);
+			return;
+		}
 	} else {
 		for (i = 0; wpa_s->dpp_chirp_freqs[i]; i++)
 			if (wpa_s->dpp_chirp_freqs[i] == wpa_s->dpp_chirp_freq)
@@ -5325,7 +5332,22 @@ static void wpas_dpp_chirp_next(void *eloop_ctx, void *timeout_ctx)
 				   wpa_s->dpp_chirp_freq);
 			return;
 		}
-		i++;
+		if (wpa_s->is_dpp_reconfig == false && wpa_s->is_roc_started == false) {
+			i++;
+			wpa_s->dpp_chirp_freq = wpa_s->dpp_chirp_freqs[i];
+			if (wpa_s->dpp_chirp_freq) {
+				wpa_drv_remain_on_channel(wpa_s, wpa_s->dpp_chirp_freq, 2000);
+				wpa_s->is_roc_started = true;
+				if (eloop_register_timeout(3, 0, wpas_dpp_chirp_timeout, wpa_s, NULL) < 0)
+					wpas_dpp_chirp_stop(wpa_s, 0);
+				return;
+			}
+		} else if (wpa_s->is_dpp_reconfig == true) {
+				i++;
+		}  else {
+			wpa_s->is_roc_started = false;
+		}
+
 		if (wpa_s->dpp_chirp_freqs[i]) {
 			wpa_s->dpp_chirp_freq = wpa_s->dpp_chirp_freqs[i];
 		} else {
@@ -5401,6 +5423,8 @@ int wpas_dpp_chirp(struct wpa_supplicant *wpa_s, const char *cmd)
 	if (!wpa_s->dpp_presence_announcement)
 		return -1;
 	wpa_s->dpp_chirp_iter = iter;
+	wpa_s->is_roc_started = false;
+	wpa_s->is_dpp_reconfig = false;
 	wpa_s->dpp_chirp_round = 0;
 	wpa_s->dpp_chirp_scan_done = 0;
 	wpa_s->dpp_chirp_listen = listen_freq;
@@ -5486,6 +5510,8 @@ int wpas_dpp_reconfig(struct wpa_supplicant *wpa_s, const char *cmd)
 	wpa_s->dpp_chirp_iter = iter;
 	wpa_s->dpp_chirp_round = 0;
 	wpa_s->dpp_chirp_scan_done = 0;
+	wpa_s->is_roc_started = false;
+	wpa_s->is_dpp_reconfig = true;
 	wpa_s->dpp_chirp_listen = 0;
 
 	return eloop_register_timeout(0, 0, wpas_dpp_chirp_next, wpa_s, NULL);
diff --git a/wpa_supplicant/wpa_supplicant_i.h b/wpa_supplicant/wpa_supplicant_i.h
index 13af4f8..70ead81 100644
--- a/wpa_supplicant/wpa_supplicant_i.h
+++ b/wpa_supplicant/wpa_supplicant_i.h
@@ -1518,6 +1518,8 @@ struct wpa_supplicant {
 	int dpp_chirp_freq;
 	int *dpp_chirp_freqs;
 	int dpp_chirp_iter;
+	bool is_roc_started;
+	bool is_dpp_reconfig;
 	int dpp_chirp_round;
 	int dpp_chirp_scan_done;
 	int dpp_chirp_listen;
-- 
2.34.1

