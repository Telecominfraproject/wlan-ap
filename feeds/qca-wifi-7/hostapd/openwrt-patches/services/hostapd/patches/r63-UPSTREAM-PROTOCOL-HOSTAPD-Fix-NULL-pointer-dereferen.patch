From 1387821e635bf6126af951262641d86e787dd56a Mon Sep 17 00:00:00 2001
From: Dhanavandhana Kannan <quic_dhanavan1@quicinc.com>
Date: Wed, 5 Feb 2025 20:24:51 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:HOSTAPD:KW: Fix NULL pointer dereference

Certain wpabuf pointers returned from hostapd_build_ap_extra_ies()
could be NULL as they are not checked after being passed into add_buf()
function in few places which could result in returning NULL pointer
to the caller functions.

Fix by checking whether the wpabuf pointers in
hostapd_build_ap_extra_ies() are not returned as NULL by handling the
failure cases.

Patch-dependency: None
Patch-work: None
Internal patch review title: "hostapd: Fix the instance of returning a
NULL pointer"

Signed-off-by: Dhanavandhana Kannan <quic_dhanavan1@quicinc.com>
---
 src/ap/ap_drv_ops.c | 17 +++++++++++------
 1 file changed, 11 insertions(+), 6 deletions(-)

--- a/src/ap/ap_drv_ops.c
+++ b/src/ap/ap_drv_ops.c
@@ -168,7 +168,10 @@ int hostapd_build_ap_extra_ies(struct ho
 #ifdef CONFIG_WPS
 	if (hapd->conf->wps_state) {
 		struct wpabuf *a = wps_build_assoc_resp_ie();
-		add_buf(&assocresp, a);
+		if (add_buf(&assocresp, a) < 0) {
+			wpabuf_free(a);
+			goto fail;
+		}
 		wpabuf_free(a);
 	}
 #endif /* CONFIG_WPS */
@@ -188,7 +191,10 @@ int hostapd_build_ap_extra_ies(struct ho
 	if (hapd->p2p_group) {
 		struct wpabuf *a;
 		a = p2p_group_assoc_resp_ie(hapd->p2p_group, P2P_SC_SUCCESS);
-		add_buf(&assocresp, a);
+		if (add_buf(&assocresp, a) < 0) {
+			wpabuf_free(a);
+			goto fail;
+		}
 		wpabuf_free(a);
 	}
 #endif /* CONFIG_WIFI_DISPLAY */
@@ -223,12 +229,15 @@ int hostapd_build_ap_extra_ies(struct ho
 		goto fail;
 #endif /* CONFIG_OWE */
 
-	add_buf(&beacon, hapd->conf->vendor_elements);
-	add_buf(&proberesp, hapd->conf->vendor_elements);
+	if (add_buf(&beacon, hapd->conf->vendor_elements) < 0 ||
+	    add_buf(&proberesp, hapd->conf->vendor_elements) < 0)
+		goto fail;
 #ifdef CONFIG_TESTING_OPTIONS
-	add_buf(&proberesp, hapd->conf->presp_elements);
+	if (add_buf(&proberesp, hapd->conf->presp_elements) < 0)
+		goto fail;
 #endif /* CONFIG_TESTING_OPTIONS */
-	add_buf(&assocresp, hapd->conf->assocresp_elements);
+	if (add_buf(&assocresp, hapd->conf->assocresp_elements) < 0)
+		goto fail;
 
 	*beacon_ret = beacon;
 	*proberesp_ret = proberesp;
