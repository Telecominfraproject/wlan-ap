From 331e14c6696b3b5b519e4d61c549a328c199589e Mon Sep 17 00:00:00 2001
From: Arunpandi Kannan <arunpand@qti.qualcomm.com>
Date: Wed, 30 Jul 2025 09:52:46 +0530
Subject: [PATCH] QSDK: PROTOCOL: AP MLD: Fix Link KDE validation in EAPOL-Key 
 msg 2/4

As per IEEE Std 802.11be-2024, for MLO, when more than one link is
requested and the message 2 is used for the initial 4-way handshake, an
MLO Link KDE for each affiliated STA link containing the affiliated STA
MAC address shall be included by the non-AP MLD for all the affiliated
links present in the Multi-Link element of (Re)Association Request
frame.

When a subset of links are rejected by AP MLD in association response,
its corresponding authenticator object and valid flag is reset in
wpa_state_machine(sm->mld_links[]). n_mld_affiliated_links also gets
decremented.

This causes EAPOL-Key msg 2/4 failure as the non-AP MLD will include
Link KDEs for all affiliated links that it requested in association
request, whereas the AP MLD is expecting it only for accepted links. Fix
this by not decrementing n_mld_affiliated_links when a subset of links
is rejected during association and skipping Link KDE validation for
rejected links.

Signed-off-by: Rameshkumar Sundaram <ramess@qti.qualcomm.com>
signed-off-by: Arunpandi Kannan <arunpand@qti.qualcomm.com>
---
 src/ap/drv_callbacks.c  |  2 +-
 src/ap/ieee802_11.c     | 13 ++++++++-----
 src/ap/ieee802_11_eht.c |  4 ++--
 src/ap/wpa_auth.c       | 24 +++++++++++++++++++++---
 src/ap/wpa_auth.h       |  2 +-
 src/ap/wpa_auth_i.h     |  1 +
 6 files changed, 34 insertions(+), 12 deletions(-)

diff --git a/src/ap/drv_callbacks.c b/src/ap/drv_callbacks.c
index 8c1cd8a..7734f4b 100644
--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -577,7 +577,7 @@ int hostapd_notif_assoc(struct hostapd_data *hapd, const u8 *addr,
 				   "MLD: Set ML info in RSN Authenticator");
 			wpa_auth_set_ml_info(sta->wpa_sm, hapd->mld_link_id,
 					     sta->mld_assoc_link_id,
-					     &sta->mld_info);
+					     &sta->mld_info, false);
 		}
 #endif /* CONFIG_IEEE80211BE */
 		res = wpa_validate_wpa_ie(hapd->wpa_auth, sta->wpa_sm,
diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index 081f316..874bf9b 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -3570,7 +3570,7 @@ static void handle_auth(struct hostapd_data *hapd,
 				wpa_auth_set_ml_info(sta->wpa_sm,
 						     hapd->mld_link_id,
 						     sta->mld_assoc_link_id,
-						     sta_mld_info);
+						     sta_mld_info, false);
 			}
 #endif /* CONFIG_IEEE80211BE */
 		}
@@ -4180,7 +4180,7 @@ u16 owe_process_rsn_ie(struct hostapd_data *hapd,
 #ifdef CONFIG_IEEE80211BE
 	if (ap_sta_is_mld(hapd, sta))
 		wpa_auth_set_ml_info(sta->wpa_sm, hapd->mld_link_id,
-				     sta->mld_assoc_link_id, &sta->mld_info);
+				     sta->mld_assoc_link_id, &sta->mld_info, false);
 #endif /* CONFIG_IEEE80211BE */
 	rsn_ie -= 2;
 	rsn_ie_len += 2;
@@ -4578,7 +4578,7 @@ static int __check_assoc_ies(struct hostapd_data *hapd, struct sta_info *sta,
 			wpa_auth_reset_ml_link_info(sta->wpa_sm, sta->mld_assoc_link_id);
 			wpa_auth_set_ml_info(sta->wpa_sm, hapd->mld_link_id,
 					     sta->mld_assoc_link_id,
-					     info);
+					     info, false);
 		}
 		if (sta->mld_info.mld_sta && link)
 			assoc_sta = hostapd_ml_get_assoc_sta(hapd, sta, &assoc_hapd);
@@ -4649,7 +4649,7 @@ static int __check_assoc_ies(struct hostapd_data *hapd, struct sta_info *sta,
 			wpa_auth_set_ml_info(sta->wpa_sm,
 					     hapd->mld_link_id,
 					     sta->mld_assoc_link_id,
-					     info);
+					     info, false);
 		}
 #endif /* CONFIG_IEEE80211BE */
 #ifdef CONFIG_SAE
@@ -5116,12 +5116,15 @@ out:
 	wpa_printf(MSG_DEBUG, "MLD: link: status=%u", status);
 	if (sta) {
 		if (status != WLAN_STATUS_SUCCESS) {
+			wpa_auth_set_ml_info(origin_sta->wpa_sm,
+					     hapd->mld_link_id, sta->mld_assoc_link_id,
+					     &sta->mld_info, true);
 			ap_free_sta(hapd, sta);
 		} else {
 			/* Maintain only accepted link STAs information in wpa_sm */
 			wpa_auth_set_ml_info(sta->wpa_sm,
 					     hapd->mld_link_id, sta->mld_assoc_link_id,
-					     &sta->mld_info);
+					     &sta->mld_info, false);
 		}
 	}
 
diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 41929d3..14283a1 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -1705,7 +1705,7 @@ void hostapd_link_reconf_resp_tx_status(struct hostapd_data *hapd,
 		wpa_auth_set_ml_info(assoc_sta->wpa_sm,
 				     lhapd->mld_link_id,
 				     assoc_sta->mld_assoc_link_id,
-				     &assoc_sta->mld_info);
+				     &assoc_sta->mld_info, false);
 	}
 
 exit:
@@ -1793,7 +1793,7 @@ hostapd_ml_process_reconf_link(struct hostapd_data *hapd,
 		os_memcpy(link->peer_addr, link_addr, ETH_ALEN);
 	}
 	wpa_auth_set_ml_info(lsta->wpa_sm, lhapd->mld_link_id,
-			     lsta->mld_assoc_link_id, &lsta->mld_info);
+			     lsta->mld_assoc_link_id, &lsta->mld_info, false);
 
 	return resp;
 }
diff --git a/src/ap/wpa_auth.c b/src/ap/wpa_auth.c
index c1a073d..b903550 100644
--- a/src/ap/wpa_auth.c
+++ b/src/ap/wpa_auth.c
@@ -3677,6 +3677,13 @@ static int wpa_auth_validate_ml_kdes_m2(struct wpa_state_machine *sm,
 			return -1;
 		}
 
+		/* Skip rejected links although the non-AP MLD will send them in
+		 * M2 of the initial 4-way handshake. */
+		if (sm->mld_links[i].rejected) {
+			n_links++;
+			continue;
+		}
+
 		if (!sm->mld_links[i].valid || i == sm->mld_assoc_link_id) {
 			wpa_printf(MSG_DEBUG,
 				   "RSN: MLD: Invalid link ID=%u", i);
@@ -7861,7 +7868,7 @@ void wpa_auth_sta_radius_psk_resp(struct wpa_state_machine *sm, bool success)
 
 
 void wpa_auth_set_ml_info(struct wpa_state_machine *sm, u8 link_id,
-			  u8 mld_assoc_link_id, struct mld_info *info)
+			  u8 mld_assoc_link_id, struct mld_info *info, bool rejected)
 {
 #ifdef CONFIG_IEEE80211BE
 	struct mld_link_info *link;
@@ -7870,7 +7877,7 @@ void wpa_auth_set_ml_info(struct wpa_state_machine *sm, u8 link_id,
 	const u8 *rsn_ies;
 	size_t rsn_ies_len;
 
-	if (!info || link_id >= MAX_NUM_MLD_LINKS)
+	if (!sm || !info || link_id >= MAX_NUM_MLD_LINKS)
 		return;
 
 	link = &info->links[link_id];
@@ -7883,9 +7890,16 @@ void wpa_auth_set_ml_info(struct wpa_state_machine *sm, u8 link_id,
 	os_memcpy(sm->peer_mld_addr, info->common_info.mld_addr, ETH_ALEN);
 
 	sm->mld_assoc_link_id = mld_assoc_link_id;
-	sm_link->valid = link->valid;
 	os_memcpy(sm_link->peer_addr, link->peer_addr, ETH_ALEN);
 	os_memcpy(sm_link->own_addr, link->local_addr, ETH_ALEN);
+	sm_link->rejected = rejected;
+	if (rejected) {
+		if (link_id != mld_assoc_link_id)
+			sm->n_mld_affiliated_links++;
+		wpa_printf(MSG_ERROR, "Link is Rejected. link_id:%u", link_id);
+		return;
+	}
+	sm_link->valid = link->valid;
 
 	wpa_printf(MSG_DEBUG,
 		   "WPA_AUTH: MLD: id=%u, addr=" MACSTR " peer=" MACSTR,
@@ -7995,6 +8009,10 @@ void wpa_auth_reset_ml_link_info(struct wpa_state_machine *sm, u8 mld_assoc_link
 	struct mld_link *link;
 	u8 link_id;
 
+	for (link_id = 0; link_id < MAX_NUM_MLD_LINKS; link_id++) {
+		link = &sm->mld_links[link_id];
+		link->rejected =  false;
+	}
 	for_each_sm_auth(sm, link_id) {
 		link = &sm->mld_links[link_id];
 		if (link_id != mld_assoc_link_id)
diff --git a/src/ap/wpa_auth.h b/src/ap/wpa_auth.h
index 2827fa5..33c027b 100644
--- a/src/ap/wpa_auth.h
+++ b/src/ap/wpa_auth.h
@@ -692,7 +692,7 @@ void wpa_auth_set_ocv_override_freq(struct wpa_authenticator *wpa_auth,
 void wpa_auth_sta_radius_psk_resp(struct wpa_state_machine *sm, bool success);
 
 void wpa_auth_set_ml_info(struct wpa_state_machine *sm, u8 link_id,
-			  u8 mld_assoc_link_id, struct mld_info *info);
+			  u8 mld_assoc_link_id, struct mld_info *info, bool rejected);
 void wpa_auth_reset_ml_link_info(struct wpa_state_machine *sm, u8 mld_assoc_link_id);
 void wpa_auth_ml_get_key_info(struct wpa_authenticator *a,
 			      struct wpa_auth_ml_link_key_info *info,
diff --git a/src/ap/wpa_auth_i.h b/src/ap/wpa_auth_i.h
index ddee141..2a43aa6 100644
--- a/src/ap/wpa_auth_i.h
+++ b/src/ap/wpa_auth_i.h
@@ -185,6 +185,7 @@ struct wpa_state_machine {
 
 	struct mld_link {
 		bool valid;
+		bool rejected;
 		u8 peer_addr[ETH_ALEN];
 		u8 own_addr[ETH_ALEN];
 
-- 
