From cae9ae251c9af87c15e099f8db9913d80aa031ff Mon Sep 17 00:00:00 2001
From: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
Date: Tue, 19 Aug 2025 11:15:44 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd: Fix accessing freed pointer during
iw del scenario

Currently when the iw del command is issued, the function
nl80211_stop_ap() is called for each link(say 2 GHz, 5 GHz,and 6 GHz
in a MLD). During this process, the active_links bitmap is updated,
and the flink  is reassigned to the next available active link after
each call.

For example:

nl80211_stop_ap() is called for 2 GHz → flink is updated to 5 GHz.
Then for 5 GHz → flink is updated to 6 GHz.
Finally for 6 GHz → all links are stopped, and active_links becomes zero.

After this, if a wifi down command is issued and links are removed in a
specific order (say 2 GHz first, then 6 GHz), the flink (which was pointing
to 6 GHz) gets removed. However, the driver context (drv->ctx) still points
to bss->ctx, which was associated with the now-deleted flink.

If an event arrives from the driver after this removal, it tries to
access drv->ctx, which now points to freed memory. This results in a
crash due to invalid memory access.

Fix by ensuring that flink is updated only during nl80211_remove_link()
and not during nl80211_stop_ap() the drv->ctx is properly updated with
flink->ctx during link removal and also ensure that scan_link is set to
NULL when the link being removed is same as the scan_link to prevent
accessing a freed pointer.

Patch-dependency:None

Patch-work: None

Fixes: I6f75d2f640fc(UPSTREAM:PROTOCOL: hostapd: use active_links to
notify start/stop state of links)
Fixes: I288f1c8ea061(UPSTREAM:PROTOCOL: hostapd: Fix accessing
removed bss during scan timeout)

Signed-off-by: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
---
 src/drivers/driver_nl80211.c | 36 +++++++++++++++++++-----------------
 1 file changed, 19 insertions(+), 17 deletions(-)

diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index e25b504..f99cca9 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -10121,10 +10121,6 @@ fail:
 
 void nl80211_update_active_links(struct i802_bss *bss, int link_id)
 {
-	struct wpa_driver_nl80211_data *drv = bss->drv;
-	struct i802_link *link = &bss->links[link_id];
-	size_t i;
-
 	wpa_printf(MSG_DEBUG, "nl80211: Update link (ifindex=%d link_id=%u)",
 		   bss->ifindex, link_id);
 
@@ -10136,17 +10132,7 @@ void nl80211_update_active_links(struct i802_bss *bss, int link_id)
 
 	wpa_driver_nl80211_del_beacon(bss, link_id);
 
-	eloop_cancel_timeout(wpa_driver_nl80211_scan_timeout, drv, bss->ctx);
-
 	bss->active_links &= ~BIT(link_id);
-	/* Choose new deflink if we are removing that link */
-	if (bss->flink == link) {
-		for_each_link(bss->active_links, i) {
-			bss->flink = &bss->links[i];
-			bss->scan_link = bss->flink;
-			break;
-		}
-	}
 }
 
 
@@ -10157,6 +10143,7 @@ int nl80211_remove_link(struct i802_bss *bss, int link_id)
 	struct nl_msg *msg;
 	int ret;
 	u8 link_addr[ETH_ALEN];
+	size_t i;
 
 	wpa_printf(MSG_DEBUG, "nl80211: Remove link (ifindex=%d link_id=%u)",
 		   bss->ifindex, link_id);
@@ -10177,6 +10164,19 @@ int nl80211_remove_link(struct i802_bss *bss, int link_id)
 	nl80211_update_active_links(bss, link_id);
 	bss->valid_links &= ~BIT(link_id);
 
+	eloop_cancel_timeout(wpa_driver_nl80211_scan_timeout, drv, bss->ctx);
+
+	/* Choose new deflink if we are removing that link */
+	if (bss->flink == link) {
+		for_each_link(bss->valid_links, i) {
+			bss->flink = &bss->links[i];
+			break;
+		}
+	}
+
+	if (bss->scan_link == link)
+		bss->scan_link = NULL;
+
 	/* If this was the last link, reset default link */
 	if (!bss->valid_links) {
 		/* TODO: Does keeping freq/bandwidth make sense? */
@@ -11739,10 +11739,12 @@ static int driver_nl80211_link_remove(void *priv, enum wpa_driver_if_type type,
 
 	nl80211_remove_link(bss, link_id);
 
-	bss->ctx = bss->flink->ctx;
-
-	if (drv->first_bss == bss && bss->valid_links)
+	if (drv->ctx == bss->ctx) {
+		eloop_cancel_timeout(wpa_driver_nl80211_send_rfkill, drv, drv->ctx);
+		bss->ctx = bss->flink->ctx;
 		drv->ctx = bss->ctx;
+	} else
+		bss->ctx = bss->flink->ctx;
 
 	if (!bss->valid_links) {
 		void *hapd = bss->ctx;
-- 
