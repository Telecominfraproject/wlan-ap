From ce9abfbc8fac2258b1ce18edd5278d926f5ec022 Mon Sep 17 00:00:00 2001
From: Rajat Soni <rajson@qti.qualcomm.com>
Date: Fri, 25 Jul 2025 13:51:27 +0530
Subject: [PATCH] QSDK: CP: hostapd: Validate chain mask inputs and improve
 nlmsg cleanup

Issue 1:
Currently, invalid character inputs (e.g., 'g') passed to the
`chain_mask` command via hostapd_cli were accepted silently,
resulting in default values being used for TX/RX chain masks.

Example:
    hostapd_cli -i wlan0 -l 2 chain_mask g g
    OK

This behavior is incorrect. Added input validation to reject
non-integer values and prevent unintended configuration.

Issue 2:
If `send_and_recv_cmd()` fails, it takes care to release the netlink
message memory (using nlmsg_free()). But it does not nullify the
pointer, which could lead to use-after-free issues and potential
crashes with current error handling condition.

Fix ensures that:
- Netlink message is only freed when NLA_PUT macros fail.
- Cleanup is handled consistently and safely to avoid memory leaks or
  crashes.

Fixes: Ifb2522ee9cd6 ("QSDK: CP: hostapd: Add support for dynamic chain mask")

Signed-off-by: Rajat Soni <rajson@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c         | 13 +++++++++++--
 src/drivers/driver_nl80211.c |  9 +++++----
 2 files changed, 16 insertions(+), 6 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 6e88bde..aeb9f1b 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -4903,7 +4903,7 @@ static int hotapd_ctrl_set_tx_rx_chain_mask(struct hostapd_data *hapd, char *cmd
 	int ret = -1, i;
 	uint32_t tx_ant, rx_ant;
 	uint8_t radio_idx = NL80211_WIPHY_RADIO_ID_MAX;
-	char *ptr;
+	char *ptr, *endptr;
 	u16 num_modes, flags;
 	u8 dfs_domain;
 	struct hostapd_hw_modes *modes;
@@ -4914,7 +4914,16 @@ static int hotapd_ctrl_set_tx_rx_chain_mask(struct hostapd_data *hapd, char *cmd
 	}
 
 	tx_ant = (uint32_t)strtol(cmd, &ptr, 10);
-	rx_ant = (uint32_t)strtol(ptr, NULL, 10);
+	if (ptr == cmd) {
+		wpa_printf(MSG_ERROR, "Invalid argument given.\n");
+		return ret;
+	}
+
+	rx_ant = (uint32_t)strtol(ptr, &endptr, 10);
+	if (ptr == endptr) {
+		wpa_printf(MSG_ERROR, "Invalid argument given.\n");
+		return ret;
+	}
 
 	if (hapd->iface->num_multi_hws)
 		radio_idx = hapd->iface->current_hw_info->hw_idx;
diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index cc20611..7f21f03 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -5336,14 +5336,15 @@ static int wpa_driver_set_chain_mask(void *priv, uint8_t radio_idx,
 	ret = send_and_recv_cmd(drv, msg);
 	if (!ret) {
 		return 0;
-	}
+	} else
+		goto fail;
+
 nla_put_failure:
+	nlmsg_free(msg);
+fail:
 	wpa_printf(MSG_ERROR, "nl80211: Chain_mask: Failed to set chain mask %d %d: "
 		   "%d (%s)", tx_ant, rx_ant, ret, strerror(-ret));
 
-	if (msg)
-		nlmsg_free(msg);
-
 	return ret;
 
 }
-- 
