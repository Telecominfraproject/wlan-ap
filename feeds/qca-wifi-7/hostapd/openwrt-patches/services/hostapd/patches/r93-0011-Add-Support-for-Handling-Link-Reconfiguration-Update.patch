+static void wpas_setup_link_reconfig(struct wpa_supplicant *wpa_s,
+				     struct reconfig_info *info)
+{
+	const u8 *key_data = info->resp_ie;
+	u8 key_data_len;
+
+	if (!info->added_links) {
+		wpa_printf(MSG_ERROR, "No links to be added");
+		return;
+	}
+
+	if (wpa_drv_get_mlo_info(wpa_s) < 0) {
+		wpa_printf(MSG_ERROR,
+			   "SETUP_LINK_RECONFIG: Failed to set reconfig info to wpa_s");
+		return;
+	}
+
+	if (wpa_sm_set_ml_info(wpa_s)) {
+		wpa_printf(MSG_ERROR,
+			   "SETUP_LINK_RECONFIG: Failed to set reconfig info to wpa_sm");
+		return;
+	}
+
+	wpa_hexdump(MSG_DEBUG, "Resp IE: ", info->resp_ie, info->resp_ie_len);
+
+	if (!key_data || info->resp_ie_len < (key_data[0] + 1)) {
+		wpa_printf(MSG_ERROR, "Invalid keys in the Resp IE");
+		return;
+	}
+
+	key_data_len = key_data[0];
+	key_data++;
+
+	if (wpa_sm_install_mlo_broadcast_keys(wpa_s->wpa, key_data, key_data_len,
+					      info->added_links)) {
+		wpa_printf(MSG_ERROR,
+			   "SETUP_LINK_RECONFIG: Failed to install broadcast keys for added links");
+		return;
+	}
+
+	wpa_msg(wpa_s, MSG_INFO, WPA_EVENT_LINK_RECONFIG "valid_links=0x%x",
+		wpa_s->valid_links);
+}
+
+
 static void wpas_link_reconfig(struct wpa_supplicant *wpa_s)
 {
 	u8 bssid[ETH_ALEN];
@@ -7199,6 +7244,10 @@ void supplicant_event(void *ctx, enum wp
 		if (data)
