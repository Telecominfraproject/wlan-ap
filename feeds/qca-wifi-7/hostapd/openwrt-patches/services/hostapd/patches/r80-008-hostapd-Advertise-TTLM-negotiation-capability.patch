From e85e7a00ee018b1828c3ce2c56163e1c1cc39ac0 Mon Sep 17 00:00:00 2001
From: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
Date: Mon, 2 Jun 2025 14:19:46 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Advertise TTLM
negotiation capability based on user config and target capability

An AP MLD that sets the TID-To-Link Mapping Negotiation Support
subfield of the MLD Capabilities and Operations field of the
Basic Multi-Link element to a nonzero value shall support TTLM
negotiation.

Add a user config "ttlm_enable" to allow user to control the
enablement of the feature.

When user enables "ttlm_enable" flag, advertise the TTLM negotiation
support as indicated by target in its capabilities.

Signed-off-by: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
---
 hostapd/config_file.c | 2 ++
 hostapd/hostapd.conf  | 6 ++++++
 2 files changed, 8 insertions(+)

--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -5112,6 +5112,8 @@ static int hostapd_config_fill(struct ho
 #ifdef CONFIG_IEEE80211BE
 	} else if (os_strcmp(buf, "enable_epcs") == 0) {
 		bss->is_epcs_enabled = atoi(pos);
+	} else if (os_strcmp(buf, "ttlm_enable") == 0) {
+		bss->ttlm_enable = atoi(pos);
 #endif /* CONFIG_IEEE80211BE */
 	} else {
 		wpa_printf(MSG_ERROR,
--- a/hostapd/hostapd.conf
+++ b/hostapd/hostapd.conf
@@ -3581,3 +3581,9 @@ own_ip_addr=127.0.0.1
 # epcs_wmm_ac_vo_cwmax=3
 # epcs_wmm_ac_vo_aifs=2
 # epcs_wmm_ac_vo_txop_limit=102
+#
+##### Tid-to-link Mapping ####################################################
+# Enable TTLM support
+# 0 = disabled (default)
+# 1 = enabled
+#ttlm_enable=1
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -642,8 +642,8 @@ static u8 * hostapd_eid_eht_basic_ml_com
 	mld_cap &= ~EHT_ML_MLD_CAPA_MAX_NUM_SIM_LINKS_MASK;
 	mld_cap |= active_links & EHT_ML_MLD_CAPA_MAX_NUM_SIM_LINKS_MASK;
 
-	/* TODO: Advertise T2LM based on driver support as well */
-	mld_cap &= ~EHT_ML_MLD_CAPA_TID_TO_LINK_MAP_NEG_SUPP_MSK;
+	if (!hapd->conf->ttlm_enable)
+		mld_cap &= ~EHT_ML_MLD_CAPA_TID_TO_LINK_MAP_NEG_SUPP_MSK;
 
 	wpa_printf(MSG_DEBUG, "MLD: MLD Capabilities and Operations=0x%x",
 		   mld_cap);
