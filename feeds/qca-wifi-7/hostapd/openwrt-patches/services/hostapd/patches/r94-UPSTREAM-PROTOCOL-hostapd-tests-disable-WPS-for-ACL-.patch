From fd07ebedc734579ebca22699ab2ca8ae7d9b1e3e Mon Sep 17 00:00:00 2001
From: Rameshkumar Sundaram <ramess@qti.qualcomm.com>
Date: Thu, 24 Jul 2025 19:11:30 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: tests: disable WPS for ACL test
 cases

When WPS is enabled, the patch
b00-029-hostapd-disable-MAC-ACL-if-WPS-enabled.patch
forces MAC-based ACL filtering to be disabled (i.e., it accepts any MAC
address), even if MAC ACL is configured in the BSS.

This behavior is in accordance with the Wi-Fi Protected Setup
Specification Version 2.0.9, Section 5 - Initial WLAN Setup:

  "If WSC is enabled, an AP shall not prevent enrollment or block
   communications based on other access control mechanisms
   (like MAC Address filtering)."

Hence, disable WPS for ACL test cases to ensure proper MAC filtering
behavior.

Patch-dependency: b00-029-hostapd-disable-MAC-ACL-if-WPS-enabled.patch
Patch-work: NA

Signed-off-by: Rameshkumar Sundaram <ramess@qti.qualcomm.com>
---
 tests/hwsim/test_wpas_ap.py | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/tests/hwsim/test_wpas_ap.py b/tests/hwsim/test_wpas_ap.py
index ae0225aac3ec..843c7826174d 100644
--- a/tests/hwsim/test_wpas_ap.py
+++ b/tests/hwsim/test_wpas_ap.py
@@ -1179,6 +1179,9 @@ def test_wpas_ap_acl_mgmt(dev):
     dev[0].set_network(id, "key_mgmt", "NONE")
     dev[0].set_network(id, "frequency", "2412")
     dev[0].set_network(id, "scan_freq", "2412")
+    # MAC based ACL is force disabled for a WPS enabled BSS
+    # disable it for this test.
+    dev[0].set_network(id, "wps_disabled", "1")
     dev[0].select_network(id)
     wait_ap_ready(dev[0])
 
-- 
