From 889f6f31a76fa3e56abfa54009cab5b6eb737e8a Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Fri, 9 May 2025 15:38:31 +0530
Subject: [PATCH 05/20] UPSTREAM:PROTOCOL: hostapd: Add support to extract bits
 from a value

Add an API to extract specific bits of a value based on the mask provided.
This API is used to extract the aci, aifsn, acm values from the ACI param and
ecw_min, ecw_max values from the ECW param of epcs_he_muedca params.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 src/utils/common.c | 5 +++++
 src/utils/common.h | 1 +
 2 files changed, 6 insertions(+)

diff --git a/src/utils/common.c b/src/utils/common.c
index c02725d..7ec25d5 100644
--- a/src/utils/common.c
+++ b/src/utils/common.c
@@ -1334,4 +1334,9 @@ u8 set_he_cap(int val, u8 mask)
 {
 	return (u8) (mask & (val << find_bit_offset(mask)));
 }
+
+u8 get_bits_using_bitmask(int val, u8 mask)
+{
+	return (u8) ((mask & val) >> find_bit_offset(mask));
+}
 #endif /*CONFIG_IEEE80211AX*/
diff --git a/src/utils/common.h b/src/utils/common.h
index 15af810..74c217f 100644
--- a/src/utils/common.h
+++ b/src/utils/common.h
@@ -645,6 +645,7 @@ void * __hide_aliasing_typecast(void *foo);
 #ifdef CONFIG_IEEE80211AX
 u8 find_bit_offset(u8 val);
 u8 set_he_cap(int val, u8 mask);
+u8 get_bits_using_bitmask(int val, u8 mask);
 #endif /*CONFIG_IEEE80211AX*/
 
 #define aliasing_hide_typecast(a,t) (t *) __hide_aliasing_typecast((a))
-- 
2.34.1

