From 841b5915f9c19db4d30c677ce5e3ed84367d5851 Mon Sep 17 00:00:00 2001
From: Banka Sai Krishna <banksaik@qti.qualcomm.com>
Date: Mon, 7 Jul 2025 10:13:42 +0530
Subject: [PATCH] wpa_supplicant: Fix missing update of 6G assoc freq

When the associated frequency is not set (i.e., 0) in the assoc_info structure,
`wpa_cli status` incorrectly reports a frequency of 0 for STA VAPs on 6GHz radios.
This occurs despite the BSSID being known and the frequency being available in
the BSS table.

This patch addresses the issue by checking if the frequency is zero and the BSSID
is known. If so, it retrieves the latest BSS entry for the BSSID and updates the
assoc_info.freq accordingly. This ensures that the correct frequency is reported
in the status output.

Signed-off-by: Banka Sai Krishna <banksaik@qti.qualcomm.com>
---
 wpa_supplicant/events.c | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

--- a/wpa_supplicant/events.c
+++ b/wpa_supplicant/events.c
@@ -3442,6 +3442,8 @@ static int wpa_supplicant_event_associnf
 		wpa_s->ssid_verified = true;
 #endif /* CONFIG_SME */
 #endif /* CONFIG_SAE */
+	if (!data->assoc_info.freq && wpa_s->current_bss)
+		data->assoc_info.freq = wpa_s->current_bss->freq;
 	bssid_known = wpa_drv_get_bssid(wpa_s, bssid) == 0;
 	if (data->assoc_info.req_ies)
 		wpa_hexdump(MSG_DEBUG, "req_ies", data->assoc_info.req_ies,
@@ -3795,7 +3797,6 @@ no_pfs:
 			wpa_supplicant_update_scan_results(wpa_s, bssid);
 		}
 	}
-
 	wpa_s->assoc_freq = data->assoc_info.freq;
 
 #ifndef CONFIG_NO_ROBUST_AV
