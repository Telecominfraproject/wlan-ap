index dabd12af2b2a..52c37659f989 100644
--- a/src/common/ieee802_11_defs.h
+++ b/src/common/ieee802_11_defs.h
@@ -3647,4 +3647,18 @@ struct ieee80211_ttlm_elem {
 } STRUCT_PACKED;
 
 #define IEEE80211_MSCS_DESC_MIN_LEN 8
+
+/**
+ * is_high_freq_mgmt_stype - Check if management subtype is high-frequency
+ * @stype: Management frame subtype (WLAN_FC_STYPE_*)
+ * Returns: true if subtype generates high-frequency logs, false otherwise
+ */
+static inline bool is_high_freq_mgmt_stype(u16 stype)
+{
+	return stype == WLAN_FC_STYPE_PROBE_REQ ||
+	       stype == WLAN_FC_STYPE_PROBE_RESP ||
+	       stype == WLAN_FC_STYPE_ACTION ||
+	       stype == WLAN_FC_STYPE_BEACON;
+}
+
 #endif /* IEEE802_11_DEFS_H */
