From c85a331cf882f2162408ca6d34a0436d26b30a9c Mon Sep 17 00:00:00 2001
From: Gunaal R <quic_gunar@quicinc.com>
Date: Wed, 8 Jan 2025 12:01:33 +0530
Subject: [PATCH] UPSTREAM:CP:HOSTAPD: Avoid adding duplicate link configuration in MLD.

Currently, when multi-link interface is configured with duplicate
links of same radio it gets added. Example, say MLD1 has two links of
radio 2 GHz and one 5 GHz link, then it gets added. This configuration
should not be allowed as it can cause duplicate bss in MLD.

Hence, add changes to avoid duplicate radio link in same MLD by comparing
the interface name the of all the other 802.11be capable bss configured and
ensure that it does not have same interface name

Fixes: f844241cffd52 ("hostapd: Rebase wlan-hostapd patches
on OpenWRT hostapd")

Patch-dependency: None
Patch-work: None

Signed-off-by: Gunaal R <quic_gunar@quicinc.com>
---
 src/ap/ap_config.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

--- a/src/ap/ap_config.c
+++ b/src/ap/ap_config.c
@@ -1308,6 +1308,8 @@ static int hostapd_config_check_bss(stru
 				    struct hostapd_config *conf,
 				    int full_config)
 {
+	size_t i;
+
 	if (full_config && is_6ghz_op_class(conf->op_class) &&
 	    !hostapd_config_check_bss_6g(bss))
 		return -1;
@@ -1361,8 +1363,6 @@ static int hostapd_config_check_bss(stru
 	}
 
 	if (full_config && !is_zero_ether_addr(bss->bssid)) {
-		size_t i;
-
 		for (i = 0; i < conf->num_bss; i++) {
 			if (conf->bss[i] != bss &&
 			    (hostapd_mac_comp(conf->bss[i]->bssid,
@@ -1541,6 +1541,22 @@ static int hostapd_config_check_bss(stru
 #endif /* CONFIG_FILS */
 
 #ifdef CONFIG_IEEE80211BE
+	/* Avoid duplicate radio link in same MLD by comparing the interface name
+	 * of all the other 11BE capable bss configured and ensure that it does
+	 * not have same interface name.
+	 */
+	for (i = 0; i < conf->num_bss; i++) {
+		if (conf->bss[i] != bss && (conf->ieee80211be && !bss->disable_11be)) {
+			if (os_strncmp(conf->bss[i]->iface, bss->iface,
+			               IFNAMSIZ) == 0) {
+				wpa_printf(MSG_ERROR, "Duplicate MLD %s on link"
+					   " BSSID " MACSTR,
+					   bss->iface, MAC2STR(bss->bssid));
+				return -1;
+			}
+		}
+	}
+
 	if (full_config && !conf->ieee80211be && bss->mld_ap) {
 		bss->mld_ap = 0;
 		wpa_printf(MSG_INFO,
