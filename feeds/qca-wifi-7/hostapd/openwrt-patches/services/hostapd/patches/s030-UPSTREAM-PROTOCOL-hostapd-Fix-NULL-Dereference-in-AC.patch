From 31f61aa7df7f61d83e50e0fdb5413381a0f41750 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Wed, 5 Nov 2025 12:54:53 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Fix NULL Dereference in ACS
 survey list

The following sequence leads to the hostapd crash.

1) ACS survey is started and the channel specific survey list is
   initialized.
2) Before we receive the survey results for the initiated survey
   NL80211_CMD_WIPHY_REG_CHANGE is received from the driver and thus the
   channel list for all interfaces are rebuilt. The survey list for all
   channels are now uninitialized (prev and next pointers are NULL) as
   they are rebuilt.
3) Survey results are received after scan completion.
4) When processing the survey results, we add the survey result entry
   for each channel to the per-channel specific survey list (which was
   initialized during acs survey start and became NULL when the channel
   lists are rebuilt)
5) Now, trying to access and add an entry to the NULL double linked list
   causes segmentation fault.

Unconditionally initialize the channel survey list whenever country
change event is received.

Free the previous survey list to prevent memory leak due to unfreed
survey results when the channels are freed during country change.

Fixes: Ib17b37be89e ("UPSTREAM:PROTOCOL:hostapd: Add retail AFC and best power mode support")
Tag: ACS
Patch-dependency:
r72-c-UPSTREAM-PROTOCOL-hostapd-Store-6-GHz-power-mode-cha.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 src/ap/acs.c         |  2 +-
 src/ap/acs.h         |  1 +
 src/ap/hw_features.c | 16 ++++++++++++++++
 3 files changed, 18 insertions(+), 1 deletion(-)

diff --git a/src/ap/acs.c b/src/ap/acs.c
index c642ce26778a..05c6551d1845 100644
--- a/src/ap/acs.c
+++ b/src/ap/acs.c
@@ -327,7 +327,7 @@ static void acs_clean_chan_surveys(struct hostapd_channel_data *chan)
 }
 
 
-static void acs_cleanup_mode(struct hostapd_hw_modes *mode)
+void acs_cleanup_mode(struct hostapd_hw_modes *mode)
 {
 	int i;
 	struct hostapd_channel_data *chan;
diff --git a/src/ap/acs.h b/src/ap/acs.h
index 8be3de5b5f78..0aa0b85bbb9b 100644
--- a/src/ap/acs.h
+++ b/src/ap/acs.h
@@ -14,6 +14,7 @@
 
 enum hostapd_chan_status acs_init(struct hostapd_iface *iface);
 void acs_cleanup(struct hostapd_iface *iface);
+void acs_cleanup_mode(struct hostapd_hw_modes *mode);
 
 #define ACS_SCAN_RETRY_MAX_COUNT	15
 #define ACS_SCAN_RETRY_INTERVAL		5
diff --git a/src/ap/hw_features.c b/src/ap/hw_features.c
index 312d19d18a49..e238531e0252 100644
--- a/src/ap/hw_features.c
+++ b/src/ap/hw_features.c
@@ -129,10 +129,26 @@ int hostapd_get_hw_features(struct hostapd_iface *iface)
 		is_6ghz = iface->current_mode->is_6ghz;
 		iface->current_mode = NULL;
 	}
+
+	/**
+	 * This function frees survey results, and initializes the chan
+	 * survey list. That is fine as the modes are freed anyway.
+	 */
+	for (i = 0; i < iface->num_hw_features; i++)
+		acs_cleanup_mode(&iface->hw_features[i]);
+	iface->chans_surveyed = 0;
+
 	hostapd_free_hw_features(iface->hw_features, iface->num_hw_features);
 	iface->hw_features = modes;
 	iface->num_hw_features = num_modes;
 
+	/**
+	 * This is done to (re)initialize the survey list for new channels as
+	 * the previous modes are freed.
+	 */
+	for (i = 0; i < iface->num_hw_features; i++)
+		acs_cleanup_mode(&iface->hw_features[i]);
+
 	for (i = 0; i < num_modes; i++) {
 		struct hostapd_hw_modes *feature = &modes[i];
 		int dfs_enabled = hapd->iconf->ieee80211h &&
-- 
