From 4fc65d111ead42ccfaa3a65d0ecdb407231ae246 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Fri, 6 Jun 2025 00:02:55 +0530
Subject: [PATCH 09/10] UPSTREAM:PROTOCOL:hostapd: Fix 6 GHz power mode configs

Fix a bug where after channel change, we change the power
mode only if the target power mode is different from the current
power mode. This is not correct as we need to update the power
values even if the target power mode is the same as the
current power mode.

Also, add 'NL80211_ATTR_6G_REG_POWER_MODE' attribute as part of
the 'NL80211_CMD_NEW_BEACON' command to ensure that the
kernel uses the correct power mode for the 6 GHz frequency
params.

Fixes: I0a0324ac226 ("hostapd: Add power mode to channel switch command")
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
n00-001-hostapd-add-support-for-6GHz-operation.patch
r32-001-hostapd-Add-support-to-receive-AFC-power-update-comp.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 src/ap/drv_callbacks.c | 9 ++-------
 1 file changed, 2 insertions(+), 7 deletions(-)

diff --git a/src/ap/drv_callbacks.c b/src/ap/drv_callbacks.c
index 3dd6ca8e6321..4b01feccbf21 100644
--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -1217,6 +1217,7 @@ int hostapd_switch_power_mode(struct hostapd_data *hapd)
 
 	hapd->iface->power_mode_6ghz_before_change = -1;
 
+	wpa_printf(MSG_ERROR, "Power mode change failed");
 	return ret;
 }
 
@@ -1419,13 +1420,7 @@ void hostapd_event_ch_switch(struct hostapd_data *hapd, int freq, int ht,
 	if (hapd->csa_in_progress &&
 	    freq == hapd->cs_freq_params.freq) {
 		if (hapd->iface->power_mode_6ghz_before_change > -1) {
-			if (hapd->iface->power_mode_6ghz_before_change !=
-			    hapd->iconf->he_6ghz_reg_pwr_type) {
-				if (hostapd_switch_power_mode(hapd))
-					wpa_printf(MSG_ERROR, "Power mode change failed");
-			} else {
-				hapd->iface->power_mode_6ghz_before_change = -1;
-			}
+			hostapd_switch_power_mode(hapd);
 		}
 
 		hostapd_cleanup_cs_params(hapd);
-- 
