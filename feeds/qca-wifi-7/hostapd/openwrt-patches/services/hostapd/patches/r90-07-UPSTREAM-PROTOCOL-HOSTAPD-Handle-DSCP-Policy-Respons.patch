--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -6731,6 +6731,9 @@ static void hostapd_dscp_action(struct h
 	case QM_DSCP_POLICY_QUERY:
 		hostapd_handle_dscp_policy_query(hapd, sta, pos, end - pos);
 		break;
+	case QM_DSCP_POLICY_RESP:
