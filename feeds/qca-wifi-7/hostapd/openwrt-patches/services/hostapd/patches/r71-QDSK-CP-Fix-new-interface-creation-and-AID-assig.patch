From fa2eb407595fb03e768f8bcbbbacafbf7be766ed Mon Sep 17 00:00:00 2001
From: Gunaal R <gunar@qti.qualcomm.com>
Date: Wed, 28 May 2025 18:56:52 +0530
Subject: [PATCH] QSDK:CP: Fix new interface creation and AID assignment in
 multi_ap mode

When using multi_ap in both AP and STA modes, an unintended AP/VLAN
interface was being created and the AID was incorrectly assigned.
This was due to an incorrect flag check and the handling of
multi_ap flags.

This patch corrects the logic by:
- Adding proper checks for multi_ap flags to prevent unintended
interface creation.
- Fixing AID assignment by including the multi_ap flag in the
condition used for AID selection.

Patch-work: None
Patch-dependency: None

Signed-off-by: Gunaal R <gunar@qti.qualcomm.com>
---
 src/ap/ieee802_11.c | 5 ++---
 src/ap/sta_info.c   | 4 ++--
 2 files changed, 4 insertions(+), 5 deletions(-)

--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -7327,16 +7327,15 @@ static void handle_assoc_cb(struct hosta
 	}
 
 	/* WPS not supported on backhaul BSS. Disable 4addr mode on fronthaul */
-	if ((sta->flags & WLAN_STA_WDS) ||
+	if (((sta->flags & WLAN_STA_WDS) && hapd->conf->wds_sta)||
 	    (sta->flags & WLAN_STA_MULTI_AP &&
 	     (hapd->conf->multi_ap & BACKHAUL_BSS) &&
-	     hapd->conf->wds_sta &&
 	     !(sta->flags & WLAN_STA_WPS))) {
 		int ret;
 		char ifname_wds[IFNAMSIZ + 1];
 		int aid;
 
-		if (hapd->conf->mld_ap && (sta->flags & WLAN_STA_WDS))
+		if (hapd->conf->mld_ap)
 			aid = sta->wds_mld_uid;
 		else
 			aid = sta->aid;
--- a/src/ap/sta_info.c
+++ b/src/ap/sta_info.c
@@ -361,11 +361,11 @@ void ap_free_sta(struct hostapd_data *ha
 
 	if ((sta->flags & WLAN_STA_WDS) ||
 	    (sta->flags & WLAN_STA_MULTI_AP &&
-	    (hapd->conf->multi_ap & FRONTHAUL_BSS) &&
+	    ((hapd->conf->multi_ap & FRONTHAUL_BSS)||(hapd->conf->multi_ap & BACKHAUL_BSS)) &&
 	    !(sta->flags & WLAN_STA_WPS))) {
 		int aid;
 
-		if (hapd->conf->mld_ap && (sta->flags & WLAN_STA_WDS))
+		if (hapd->conf->mld_ap)
 			aid = sta->wds_mld_uid;
 		else
 			aid = sta->aid;
