From 5978eea86463d4838d3ce7b8b483d9e3ec57db43 Mon Sep 17 00:00:00 2001
From: Harshitha Prem <hprem@qti.qualcomm.com>
Date: Sun, 27 Jul 2025 20:42:27 +0530
Subject: [PATCH 5/8] QSDK:CP: hostapd: ATF: add scheduling config

Add scheduling config for per inteface and per bss.

	1. atfstrictsched - this will be used for per interface/per radio.
	2. atfssidsched - this will be used for per bss.

ATF strict scheduling will take value either 0 or 1. When it is enabled,
strict scheduling is enabled across the radio, ssid and group.

ATF ssid scheduling config where it can take value 0 - 2.

0 indicates fair scheduling. SSID can contribute its
unused airtime with other SSIDs and can also borrow from them.

1 indicates strict scheduling airtime, SSID can contribute
its unused airtime with other SSID but cannot be borrowed.

2 indicates fair with upper bound, SSID can only contribute
its unused airtime, but cannot borrow airtime from other SSID.

Signed-off-by: Harshitha Prem <hprem@qti.qualcomm.com>
---
 hostapd/config_file.c | 21 +++++++++++++++++++++
 hostapd/hostapd.conf  | 12 ++++++++++++
 src/ap/ap_config.h    |  5 +++++
 src/atf/atf_offload.c |  1 +
 src/atf/atf_offload.h |  1 +
 5 files changed, 40 insertions(+)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 2c817a8..6028909 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -4767,7 +4767,28 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 			return 1;
 		}
 		conf->atf_ssid_grp = val;
+	} else if (os_strcmp(buf, "atfssidsched") == 0) {
+		int val = atoi(pos);
+
+		if (val < 0 || val > 2) {
+			wpa_printf(MSG_ERROR,
+				   "Line %d: Invalid atfssidsched", line);
+			wpa_printf(MSG_ERROR,
+				   "set 0 for 'Fair',1 for 'Strict' or '2' for 'fair with Upper bound");
+			return 1;
+		}
+
+		bss->atf_ssid_sched = val;
+	} else if (os_strcmp(buf, "atfstrictsched") == 0) {
+		int val = atoi(pos);
+		if (val < 0 || val > 1) {
+			wpa_printf(MSG_ERROR,
+				   "Line %d: Invalid atfstrictsched (must be 0 or 1)",
+				   line);
+			return 1;
+		}
 
+		conf->atf_strict_sched = val;
 #endif /* CONFIG_ATF_OFFLOAD */
 #ifdef CONFIG_MACSEC
 	} else if (os_strcmp(buf, "macsec_policy") == 0) {
diff --git a/hostapd/hostapd.conf b/hostapd/hostapd.conf
index 9f34da8..e4ee402 100644
--- a/hostapd/hostapd.conf
+++ b/hostapd/hostapd.conf
@@ -3439,6 +3439,18 @@ own_ip_addr=127.0.0.1
 #becomes ineffective.
 #atfssidgroup=0
 
+#ATF offload scheduling policy - ATF Strict Sched value only accept 1 (Enable) or 0 (Disable)
+#This will enable strict scheduling across the groups and ssids and discards the fair
+#scheduling.
+#
+#When this is enabled - Airtime can not be contributed to other SSID’s/Group or
+#can not be borrowed from other SSID’s/Group<200b>
+#atfstrictsched=0
+#
+#Per BSS configuration, ATF offload scheduling config. Set 0 for fair scheduling,
+#set 1 for strict scheduling and 3 for fair + upper bound.
+#atfssidsched=0
+
 ##### EDMG support ############################################################
 #
 # Enable EDMG capability for AP mode in the 60 GHz band. Default value is false.
diff --git a/src/ap/ap_config.h b/src/ap/ap_config.h
index 914ccfe..95d0ef7 100644
--- a/src/ap/ap_config.h
+++ b/src/ap/ap_config.h
@@ -816,6 +816,10 @@ struct hostapd_bss_config {
 	struct airtime_sta_weight *airtime_weight_list;
 #endif /* CONFIG_AIRTIME_POLICY */
 
+#ifdef CONFIG_ATF_OFFLOAD
+	u8 atf_ssid_sched;
+#endif /* CONFIG_ATF_OFFLOAD */
+
 #ifdef CONFIG_MACSEC
 	/**
 	 * macsec_policy - Determines the policy for MACsec secure session
@@ -1307,6 +1311,7 @@ struct hostapd_config {
 	bool commitatf;
 	char *atf_offload_config;
 	bool atf_ssid_grp;
+	bool atf_strict_sched;
 #endif /* CONFIG_ATF_OFFLOAD */
 
 	int ieee80211be;
diff --git a/src/atf/atf_offload.c b/src/atf/atf_offload.c
index 549ae32..39032f8 100644
--- a/src/atf/atf_offload.c
+++ b/src/atf/atf_offload.c
@@ -403,6 +403,7 @@ atf_init_algo(struct hostapd_iface *iface)
 	algo->iface = iface;
 	algo->atf_enabled = iface->conf->commitatf;
 	algo->ssid_group_enabled = iface->conf->atf_ssid_grp;
+	algo->atfstrictsched_enabled = iface->conf->atf_strict_sched;
 
 	if (iface->conf->atf_offload_config)
 		if (atf_read_config(algo, iface->conf->atf_offload_config))
diff --git a/src/atf/atf_offload.h b/src/atf/atf_offload.h
index 58b2fa5..b351b5a 100644
--- a/src/atf/atf_offload.h
+++ b/src/atf/atf_offload.h
@@ -92,6 +92,7 @@ struct atf_algo {
 
 	/* Feature flags */
 	bool ssid_group_enabled;
+	bool atfstrictsched_enabled;
 
 	/* used for ATF config parsing*/
 	struct atf_group *last_group;
-- 
