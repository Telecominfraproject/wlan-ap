+
+		if (hw_idx >= 0)
+			associated_hw_bmap |= BIT(hw_idx);
+	}
 
 	bss = wpa_bss_get_bssid(wpa_s, res->bssid);
 	if (!bss) {
@@ -3878,88 +3917,147 @@ static bool wpa_bss_update_scan_rnr_res(
