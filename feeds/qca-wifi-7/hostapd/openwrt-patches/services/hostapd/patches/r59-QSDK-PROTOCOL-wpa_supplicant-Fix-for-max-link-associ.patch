+	u16 non_assoc_links = 0;
+	int freqs[MAX_NUM_MLD_LINKS], j = 0;
+	s8 hw_idx;
+	u16 associated_hw_bmap = 0;
 	u32 changes;
-	u8 ret = true;
+
+	if (wpa_s->missing_link_scan)
+		return ret;
+
