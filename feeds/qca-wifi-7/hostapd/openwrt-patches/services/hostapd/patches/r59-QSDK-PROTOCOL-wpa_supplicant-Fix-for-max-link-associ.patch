 src/common/ieee802_11_common.h    |   1 +
 wpa_supplicant/events.c           |   9 ++
 wpa_supplicant/scan.c             | 237 +++++++++++++++++++++---------
 wpa_supplicant/wpa_supplicant_i.h |   1 +
 5 files changed, 186 insertions(+), 72 deletions(-)

