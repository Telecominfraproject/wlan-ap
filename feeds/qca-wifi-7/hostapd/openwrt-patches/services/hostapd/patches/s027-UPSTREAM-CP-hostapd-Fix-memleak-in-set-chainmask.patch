From 2fd23fbd48a6f1a45bbe9f3f920007b1e6e2af09 Mon Sep 17 00:00:00 2001
From: Sriram Sankar Sankarapandian Thangaraj <sriramsa@qti.qualcomm.com>
Date: Wed, 29 Oct 2025 16:44:28 +0530
Subject: [PATCH] UPSTREAM:CP:hostapd: Fix memleak in set chainmask

In hotapd_ctrl_set_tx_rx_chain_mask(), hostapd_hw_modes returned by
nl80211_get_hw_feature_data() is not freed properly resulting in memory leak.

Fix added to properly free hostapd hw modes.

Patch-dependency:
	patches/r72-a-UPSTREAM-PROTOCOL-hostapd-6-GHz-power-mode-channels-.patch
	patches/r82-QSDK-CP-Add-support-for-dynamic-chain-mask.patch

Signed-off-by: Sriram Sankar Sankarapandian Thangaraj <sriramsa@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 062979a..70f6e51 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -5053,6 +5053,8 @@ static int hostapd_ctrl_set_tx_rx_chain_mask(struct hostapd_data *hapd, char *cm
 				if (hapd->iface->current_mode->channels)
 					os_free(hapd->iface->current_mode->channels);
 
+				wpa_driver_free_6ghz_channels(hapd->iface->current_mode);
+
 				os_memcpy(hapd->iface->current_mode,
 					  mode, sizeof(struct hostapd_hw_modes));
 
@@ -5064,6 +5066,7 @@ static int hostapd_ctrl_set_tx_rx_chain_mask(struct hostapd_data *hapd, char *cm
 			}
 			os_free(mode->rates);
 			os_free(mode->channels);
+			wpa_driver_free_6ghz_channels(mode);
 		}
 		os_free(modes);
 		if (!found_matching_mode) {
-- 
