From 4999621eb1badb7b58648ff8c54bf9d6bf97e2fd Mon Sep 17 00:00:00 2001
From: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
Date: Mon, 25 Aug 2025 11:01:19 -0700
Subject: [PATCH 1/3] UPSTREAM:PROTOCOL: hostapd: reset beacon state after
 stop_ap

Each MLD link reload results in ieee802_11_set_beacon() sending
NL80211_CMD_START_AP to kernel for partner links as well. Kernel
may reject it based on which parameters changed. For example,
SSID changes between stop_ap() and reload_config result in an
error because kernel compares new link SSID with old configured
SSID for partner links even though links are stopped.

Set 'beacon_set_done' to 0 for each link when stop_ap() succeeds
to avoid setting beacon for stopped links. Remove the redundant
line from uc_hostapd_iface_stop().

Patch-dependency: none
Patch-work: none
Patch-title: "[PATCH v2] hostapd: reset beacon state after stop_ap"

Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 src/ap/ap_drv_ops.h | 10 ++++++++--
 src/ap/ucode.c      |  1 -
 2 files changed, 8 insertions(+), 3 deletions(-)

diff --git a/src/ap/ap_drv_ops.h b/src/ap/ap_drv_ops.h
index 21aef4910426..006f8282a233 100644
--- a/src/ap/ap_drv_ops.h
+++ b/src/ap/ap_drv_ops.h
@@ -422,7 +422,7 @@ static inline int hostapd_drv_vendor_cmd(struct hostapd_data *hapd,
 
 static inline int hostapd_drv_stop_ap(struct hostapd_data *hapd)
 {
-	int link_id = -1;
+	int link_id = -1, ret;
 
 	if (!hapd->driver || !hapd->driver->stop_ap || !hapd->drv_priv)
 		return 0;
@@ -430,7 +430,13 @@ static inline int hostapd_drv_stop_ap(struct hostapd_data *hapd)
 	if (hapd->conf->mld_ap)
 		link_id = hapd->mld_link_id;
 #endif /* CONFIG_IEEE80211BE */
-	return hapd->driver->stop_ap(hapd->drv_priv, link_id);
+
+	ret = hapd->driver->stop_ap(hapd->drv_priv, link_id);
+	if (ret)
+		return ret;
+
+	hapd->beacon_set_done = 0;
+	return 0;
 }
 
 static inline int hostapd_drv_if_rename(struct hostapd_data *hapd,
diff --git a/src/ap/ucode.c b/src/ap/ucode.c
index a4c98751460e..d70cd1d98242 100644
--- a/src/ap/ucode.c
+++ b/src/ap/ucode.c
@@ -577,7 +577,6 @@ uc_hostapd_iface_stop(uc_vm_t *vm, size_t nargs)
 		struct hostapd_data *hapd = iface->bss[i];
 
 		hostapd_drv_stop_ap(hapd);
-		hapd->beacon_set_done = 0;
 	}
 
 	return NULL;
-- 
