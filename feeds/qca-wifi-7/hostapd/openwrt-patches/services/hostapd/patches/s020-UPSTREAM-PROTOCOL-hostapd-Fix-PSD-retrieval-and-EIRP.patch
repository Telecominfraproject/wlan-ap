From 07955ebbaa62b246ab41f115a5e27edce4f836cd Mon Sep 17 00:00:00 2001
From: Priyadarshnee Srinivasan <priys@qti.qualcomm.com>
Date: Wed, 24 Sep 2025 11:02:24 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Fix PSD retrieval and EIRP
 computation issues in SP power mode with punctured channels

This commit addresses three issues:

1. Incorrect PSD retrieval for punctured non-SP channels
When AP is brought up in SP power mode and the first sub-channel
(e.g., channel 113 in 117 HT80) is punctured and non-SP,
hostapd_reg_get_psd_from_chan_list() incorrectly checks the PSD flag
on the start frequency (113). Since this channel is not valid in SP mode, PSD
retrieval fails. Fix by checking PSD capability
using the primary channel of the operating channel instead
of the start frequency.

2. Incorrect PSD values in TPE3 for composite AP mode
When AP is started on channel 117 HT80 with 113 punctured,
fill_psd_power_for_punctured_freq() assigns -1 dBm to 113 (LPI-only) and
5 dBm to 117, 121, and 125. This results in incorrect TPE values. Fix
by computing PSD as MAX(LPI PSD, SP PSD) for each channel. Since SP is
unsupported for subordinate clients, use MAX(-1, LPI PSD).

3. Incorrect EIRP computation in TPE5 for punctured channels
hostapd_get_sp_punc_eirp() limits AP’s OOBE PSD power using
the client’s regulatory PSD, which is incorrect. Fix by limiting it
using the AP’s regulatory PSD and using the corrected value for EIRP
computation in hostapd_reg_get_psd_from_chan_list().

Fixes: Ib17b37be89e8e5af0 ("hostapd: Support for SP and
Puncturing in EIRP API"), I07726d48d7facfe1940 (Handle TPE PSD for punctured and
non-punctured 6 GHz channels)
Patch-work: None
Feature: AFC
Tag: 6G_REGULATORY
Patch-dependency:
r85-00-UPSTREAM-PROTOCOL-hostapd-Handle-TPE-PSD-for-punctur.patch
r72-e-UPSTREAM-PROTOCOL-hostapd-Support-for-SP-and-Punctur.patch

Signed-off-by: Priyadarshnee Srinivasan <priys@qti.qualcomm.com>
---
 src/ap/hostapd.c    | 18 +++++++++++++-----
 src/ap/ieee802_11.c | 14 ++++++++------
 2 files changed, 21 insertions(+), 11 deletions(-)

Index: hostapd-2025.03.10~95ad7115/src/ap/hostapd.c
===================================================================
--- hostapd-2025.03.10~95ad7115.orig/src/ap/hostapd.c
+++ hostapd-2025.03.10~95ad7115/src/ap/hostapd.c
@@ -6719,7 +6719,7 @@ hostapd_reg_get_psd_from_chan_list(struc
 				   bool is_client_lookup, bool is_twice_pwr,
 				   s16 *psd_pwr)
 {
-	struct hostapd_channel_data *chan_6ghz = NULL;
+	struct hostapd_channel_data *chan_6ghz = NULL, *prim_chan;
 	u16 start_freq = (bw == 20) ? freq : center_freq - (bw / 2) + 10;
 	u8 pwr_type = (is_client_lookup) ? client_type : ap_pwr_type;
 	bool is_psd;
@@ -6736,6 +6736,14 @@ hostapd_reg_get_psd_from_chan_list(struc
 			   __func__, pwr_type, start_freq);
 		return -1;
 	}
+	prim_chan = hostapd_iface_get_6ghz_chan_list(iface, freq, pwr_type,
+						     NULL, NULL);
+	if (!prim_chan) {
+		wpa_printf(MSG_ERROR,
+			   "%s Error getting prim 6 GHz chan: power mode: %d freq: %d",
+			   __func__, pwr_type, freq);
+		return -1;
+	}
 
 	num_bw_chans = bw / 20;
 	if (chan_idx + num_bw_chans > num_channels_6ghz) {
@@ -6747,14 +6755,14 @@ hostapd_reg_get_psd_from_chan_list(struc
 
 	*psd_pwr = CHAN_MAX_TX_POWER;
 	effective_bw = hostapd_reg_find_non_punc_bw(bw, in_punc_pattern);
-	is_psd = chan_6ghz->flag & HOSTAPD_CHAN_PSD;
+	is_psd = prim_chan->flag & HOSTAPD_CHAN_PSD;
 	if (!is_psd) {
 		s16 reg_eirp_pwr;
 		int ret;
 
 		wpa_printf(MSG_INFO,
 			   "Channel %d does not support PSD, flag: 0x%x",
-			   chan_6ghz->freq, chan_6ghz->flag);
+			   prim_chan->freq, prim_chan->flag);
 		ret = hostapd_reg_get_eirp_from_chan_list(iface, freq,
 							  center_freq,
 							  bw,
@@ -6775,7 +6783,7 @@ hostapd_reg_get_psd_from_chan_list(struc
 		if (ret) {
 			wpa_printf(MSG_ERROR,
 				   "Failed to convert EIRP to PSD for freq %d",
-				   chan_6ghz->freq);
+				   prim_chan->freq);
 			return -1;
 		}
 
@@ -6880,9 +6888,12 @@ hostapd_get_sp_punc_eirp(struct hostapd_
 		return -1;
 	}
 
+	/* Set is_client_lookup to false to get AP PSD value and to avoid
+	 * subtracting 6dbm twice.
+	 */
 	ret = hostapd_reg_get_psd_from_chan_list(iface, freq, center_freq, bw,
 						 in_punc_pattern, NL80211_REG_AP_SP,
-						 client_type, is_client_lookup,
+						 client_type, false,
 						 false, &reg_psd_pwr);
 	if (ret)
 		return ret;
Index: hostapd-2025.03.10~95ad7115/src/ap/ieee802_11.c
===================================================================
--- hostapd-2025.03.10~95ad7115.orig/src/ap/ieee802_11.c
+++ hostapd-2025.03.10~95ad7115/src/ap/ieee802_11.c
@@ -9563,18 +9563,20 @@ fill_psd_power_for_punctured_freq(struct
 			psd_power = CHAN_MIN_TX_POWER;
 		wpa_printf(MSG_DEBUG, "LPI/VLP channel %d MHz, psd_power: %d",
 			   freq, psd_power);
+
 	} else {
 		/* For SP punctured channel, psd power is primary 20 MHZ PSD - 16 */
 		psd_power = (primary_20_mhz_psd - PUNCTURED_SP_CHAN_POWER_DIFF);
-		if (pwr_mode == HE_REG_INFO_6GHZ_AP_TYPE_INDOOR_SP &&
-		    !hostapd_is_additional_tpe(tx_pwr_intrpn)) {
-		    return get_max_psd_for_composite_ap(iface, freq,
-							pwr_type, client_mode,
-							psd_power);
-		}
 		wpa_printf(MSG_DEBUG, "SP channel %d MHz, psd_power: %d",
 			   freq, psd_power);
 	}
+
+	if (pwr_mode == HE_REG_INFO_6GHZ_AP_TYPE_INDOOR_SP &&
+	    !hostapd_is_additional_tpe(tx_pwr_intrpn)) {
+		return get_max_psd_for_composite_ap(iface, freq,
+						    pwr_type, client_mode,
+						    psd_power);
+	}
 	return psd_power;
 }
 
