+/**
+ * struct ieee80211_ttlm_elem - TID-To-Link Mapping element
+ *
+ * @control: the first part of control field
+ * @optional: the second part of control field
+ */
+struct ieee80211_ttlm_elem {
+	u8 control;
+	u8 optional[];
