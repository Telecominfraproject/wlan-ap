From b0c699862bcc626ea6f6c991cbcde84a4574e13d Mon Sep 17 00:00:00 2001
From: Karthik M <karm@qti.qualcomm.com>
Date: Tue, 15 Jul 2025 22:01:34 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Ignore BSS events from kernel when
no active links are present

During network restart, hostapd crashes when processing BSS events
from the kernel. This is because hostapd tries to access a freed 
BSS context.

While restarting the network, nl80211_stop_ap is received for last link, 
the active link count drops to zero and BSS freed. As a result, the flink 
is having a dangling pointer, and unexpected kernel event referencing that 
BSS can lead to a segmentation fault.

This patch avoids the crash by ignoring BSS events when there are no
active links associated with the BSS.

Patch-dependency: None

Patch-work: None

Signed-off-by: Karthik M <karm@qti.qualcomm.com>
---
 src/drivers/driver_nl80211_event.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/src/drivers/driver_nl80211_event.c b/src/drivers/driver_nl80211_event.c
index 0b813a2..b12c3d9 100644
--- a/src/drivers/driver_nl80211_event.c
+++ b/src/drivers/driver_nl80211_event.c
@@ -4955,6 +4955,13 @@ static void do_process_drv_event(struct i802_bss *bss, int cmd,
 	wpa_printf(MSG_DEBUG, "nl80211: Drv Event %d (%s) received for %s",
 		   cmd, nl80211_command_to_string(cmd), bss->ifname);
 
+	if (bss->valid_links && !bss->active_links) {
+		wpa_printf(MSG_ERROR, "nl80211: Ignoring BSS Event %d (%s) received for %s",
+			   cmd, nl80211_command_to_string(cmd),
+			   bss->ifname);
+		return;
+	}
+
 #ifdef CONFIG_DRIVER_NL80211_QCA
 	if (cmd == NL80211_CMD_ROAM &&
 	    (drv->capa.flags & WPA_DRIVER_FLAGS_KEY_MGMT_OFFLOAD)) {
@@ -5367,6 +5374,13 @@ int process_bss_event(struct nl_msg *msg, void *arg)
 		   gnlh->cmd, nl80211_command_to_string(gnlh->cmd),
 		   bss->ifname);
 
+	if (bss->valid_links && !bss->active_links) {
+		wpa_printf(MSG_ERROR, "nl80211: Ignoring BSS Event %d (%s) received for %s",
+			   gnlh->cmd, nl80211_command_to_string(gnlh->cmd),
+			   bss->ifname);
+		return NL_SKIP;
+	}
+
 	switch (gnlh->cmd) {
 	case NL80211_CMD_FRAME:
 	case NL80211_CMD_FRAME_TX_STATUS:
-- 
