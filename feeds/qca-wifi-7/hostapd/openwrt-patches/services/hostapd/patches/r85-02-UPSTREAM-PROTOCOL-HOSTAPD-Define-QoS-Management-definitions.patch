From 0c917682cae201c3d12acc1cb230ea4445028186 Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Wed, 2 Jul 2025 15:50:51 +0530
Subject: [PATCH 2/3] UPSTREAM:PROTOCOL:HOSTAPD Define QoS Management (QM)
 interface structures

Added foundational data structures and macros to support a
flexible and extensible QoS Management (QM) framework.

The design enables support for multiple QM command types,
starting with Stream Classification Service (SCS), and allows
future expansion for additional QoS protocols.

Key additions:
- Generic QM request and response structures
- TCLAS Type 4 and Type 10 classifier, QoS attribute structures
- Macros for QM attribute size, lengths, masks, and bit shifts
- Bitfield macros for control and delivery info parsing

These structures are designed to be reusable across various QM
protocol types, promoting modularity and consistency in QoS
feature implementation.

Patch-dependency: None
Patch-work: NA
Tag: SCS

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 src/drivers/driver.h | 159 +++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 159 insertions(+)

diff --git a/src/drivers/driver.h b/src/drivers/driver.h
index 3095f1c..a237029 100644
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -137,6 +137,165 @@ struct hostapd_wmm_rule {
 	int max_txop;
 };
 
+/**
+ * enum qos_mgmt_type - QoS Management feature types
+ * @HOSTAPD_QM_SCS: Stream Classification Service
+ */
+enum qos_mgmt_type {
+	HOSTAPD_QM_TYPE_SCS,
+	/* Future QM protocols to be added here */
+};
+
+#define IPV4_LEN	4
+#define IPV6_LEN	16
+
+#define TCLAS4_FLOW_LABEL_SIZE	3
+#define TCLAS10_FILTER_LEN	12
+
+#define QM_MAX_DESCRIPTORS_PER_PEER			10
+#define QM_MAX_DESCRIPTORS_PER_REQUEST			4
+#define QM_MAX_TCLAS_ELEMENTS_PER_QM_DESCRIPTOR	2
+
+#define QM_CTRL_INFO_DIRECTION_MASK	0x00000003
+#define QM_CTRL_INFO_DIRECTION_SHIFT	0
+#define QM_CTRL_INFO_TID_MASK		0x0000003C
+#define QM_CTRL_INFO_TID_SHIFT		2
+#define QM_CTRL_INFO_UP_MASK		0x000001C0
+#define QM_CTRL_INFO_UP_SHIFT		6
+#define QM_CTRL_INFO_BITMAP_MASK	0x01FFFE00
+#define QM_CTRL_INFO_BITMAP_SHIFT	9
+#define QM_CTRL_INFO_LINK_ID_MASK	0x1E000000
+#define QM_CTRL_INFO_LINK_ID_SHIFT	25
+#define QM_CTRL_INFO_RESERVED_MASK	0xE0000000
+#define QM_CTRL_INFO_RESERVED_SHIFT	29
+
+#define QM_MSDU_DELIVERY_INFO_RATIO_MASK		0x0F
+#define QM_MSDU_DELIVERY_INFO_RATIO_SHIFT		0
+#define QM_MSDU_DELIVERY_INFO_COUNT_EXPONENT_MASK	0xF0
+#define QM_MSDU_DELIVERY_INFO_COUNT_EXPONENT_SHIFT	4
+
+#define QM_QOS_ATTR_MAX_MSDU_SIZE_MASK			0x0001
+#define QM_QOS_ATTR_SVC_START_TIME_MASK		0x0002
+#define QM_QOS_ATTR_SVC_START_TIME_LINK_ID_MASK	0x0004
+#define QM_QOS_ATTR_MEAN_DATA_RATE_MASK		0x0008
+#define QM_QOS_ATTR_BURST_SIZE_MASK			0x0010
+#define QM_QOS_ATTR_MSDU_LIFETIME_MASK			0x0020
+#define QM_QOS_ATTR_MSDU_DELIVERY_INFO_MASK		0x0040
+#define QM_QOS_ATTR_MEDIUM_TIME_MASK			0x0080
+
+#define SET_QM_CTRL_INFO(control_info, field, value) \
+	(control_info |= ((value << QM_CTRL_INFO_##field##_SHIFT) & \
+			 QM_CTRL_INFO_##field##_MASK))
+
+#define QM_IS_QOS_ATTR_PRESENT(PARAM1, PARAM2) \
+	(PARAM1 & QM_QOS_ATTR_##PARAM2##_MASK)
+
+#define SET_QM_MSDU_DELIVERY_INFO(msdu_delivery_info, field, value) \
+	(msdu_delivery_info |= \
+		((value << QM_MSDU_DELIVERY_INFO_##field##_SHIFT) & \
+		 QM_MSDU_DELIVERY_INFO_##field##_MASK))
+
+enum qm_ip_ver {
+	IP_VERSION_4 = 4,
+	IP_VERSION_6 = 6,
+};
+
+enum qm_tclas_classifier {
+	QM_TCLAS_CLASSIFIER_TYPE4 = 4,
+	QM_TCLAS_CLASSIFIER_TYPE10 = 10,
+};
+
+struct qm_tclas_type4_params {
+	u8 classifier_mask;
+	enum qm_ip_ver ip_ver;
+	union {
+		u8 ipv4[IPV4_LEN];
+		u8 ipv6[IPV6_LEN];
+	} src_ip;
+	union {
+		u8 ipv4[IPV4_LEN];
+		u8 ipv6[IPV6_LEN];
+	} dst_ip;
+	u16 src_port;
+	u16 dst_port;
+	u8 dscp;
+	u8 protocol;
+	u8 next_header;
+	u8 flow_label[TCLAS4_FLOW_LABEL_SIZE];
+};
+
+struct qm_tclas_type10_params {
+	u8 protocol_instance;
+	u8 protocol_number;
+	u8 filter_value[TCLAS10_FILTER_LEN];
+	u8 filter_mask[TCLAS10_FILTER_LEN];
+	u8 filter_len;
+};
+
+struct qm_tclas_elements {
+	u8 up;
+	u8 classifier_type;
+	union qm_tclas_elem {
+	struct qm_tclas_type4_params type4_params;
+	struct qm_tclas_type10_params type10_params;
+	} tclas_elem;
+};
+
+struct qm_qos_attributes {
+	u32 direction:2,
+	    tid:4,
+	    up:3,
+	    bitmap:16,
+	    link_id:4,
+	    reserved:3;
+	u32 min_service_interval;
+	u32 max_service_interval;
+	u32 min_data_rate;
+	u32 delay_bound;
+	u16 max_msdu_size;
+	u32 service_start_time;
+	u8 service_start_time_link_id;
+	u32 mean_data_rate;
+	u32 burst_size;
+	u16 msdu_lifetime;
+	u8 msdu_delivery_ratio:4,
+	   msdu_count_exponent:4;
+	u16 medium_time;
+};
+
+struct qm_req_desc_data {
+	u8 qm_id;
+	u8 request_type;
+	u8 priority;
+	u8 num_tclas_elements;
+	struct qm_tclas_elements tclas[QM_MAX_TCLAS_ELEMENTS_PER_QM_DESCRIPTOR];
+	u8 tclas_processing;
+	bool is_qos_present;
+#ifdef CONFIG_IEEE80211BE
+	struct qm_qos_attributes qos_attr;
+#endif /* CONFIG_IEEE80211BE */
+};
+
+struct qm_req_data {
+	u8 peer_mac[ETH_ALEN];
+	u8 qm_type;
+	u8 dialog_token;
+	u8 num_qm_desc;
+	struct qm_req_desc_data qm_req_desc[QM_MAX_DESCRIPTORS_PER_REQUEST];
+};
+
+struct qm_resp_desc_data {
+	u8 qm_id;
+	u8 status;
+};
+
+struct qm_resp_data {
+	u8 qm_type;
+	u8 dialog_token;
+	u8 num_qm_desc;
+	struct qm_resp_desc_data qm_resp_desc[QM_MAX_DESCRIPTORS_PER_REQUEST];
+};
+
 /**
  * struct hostapd_channel_data - Channel information
  */
-- 
