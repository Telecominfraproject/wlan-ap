From 06918bd9d319d96333f1bf539ed1609f62db51cf Mon Sep 17 00:00:00 2001
From: Priyadarshnee Srinivasan <priys@qti.qualcomm.com>
Date: Mon, 26 May 2025 18:11:16 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL hostapd: Retrieve AFC support from wiphy
 feature flags

Currently, hostapd does not retrieve AFC and retail AFC support flags
from wiphy feature extensions.
This results in the inability to determine whether a channel change should
occur after receiving an AFC response, which may lead to non-compliant
behavior in regulatory scenarios.

To address this issue, retrieve AFC and retail AFC support flags from the
wiphy feature extensions and use them to control channel switching behavior
following an AFC response.

Feature: AFC
Patch-dependency: n00-001-hostapd-add-support-for-6GHz-operation.patch
Tag: 6G_REGULATORY

Change-Id: Ia531b51b4a152b5f5a1e95b713e0d88523ded56f
Signed-off-by: Priyadarshnee Srinivasan <priys@qti.qualcomm.com>
---
 src/drivers/driver_nl80211.h      | 2 ++
 src/drivers/driver_nl80211_capa.c | 6 ++++++
 src/drivers/nl80211_copy.h        | 2 ++
 3 files changed, 10 insertions(+)

diff --git a/src/drivers/driver_nl80211.h b/src/drivers/driver_nl80211.h
index 285ddf2..26613e9 100644
--- a/src/drivers/driver_nl80211.h
+++ b/src/drivers/driver_nl80211.h
@@ -205,6 +205,8 @@ struct wpa_driver_nl80211_data {
 	unsigned int qca_ap_allowed_freqs:1;
 	unsigned int connect_ext_vendor_cmd_avail:1;
 	unsigned int device_bw:1;
+	unsigned int afc_support:1;
+	unsigned int afc_retail_support:1;
 
 	u8 extra_bss_membership_selectors[8];
 
diff --git a/src/drivers/driver_nl80211_capa.c b/src/drivers/driver_nl80211_capa.c
index 6e7584f..6d819e2 100644
--- a/src/drivers/driver_nl80211_capa.c
+++ b/src/drivers/driver_nl80211_capa.c
@@ -670,6 +670,12 @@ static void wiphy_info_ext_feature_flags(struct wiphy_info_data *info,
 	if (ext_feature_isset(ext_features, len, NL80211_EXT_FEATURE_PUNCT))
 		info->drv->puncturing = 1;
 
+	if (ext_feature_isset(ext_features, len, NL80211_EXT_FEATURE_TARGET_AND_HOST_AFC_SUPPORT))
+		info->drv->afc_support = 1;
+
+	if (ext_feature_isset(ext_features, len, NL80211_EXT_FEATURE_RETAIL_AFC_SUPPORT))
+		info->drv->afc_retail_support = 1;
+
 	if (ext_feature_isset(ext_features, len,
 			      NL80211_EXT_FEATURE_BEACON_PROTECTION_CLIENT))
 		capa->flags2 |= WPA_DRIVER_FLAGS2_BEACON_PROTECTION_CLIENT;
diff --git a/src/drivers/nl80211_copy.h b/src/drivers/nl80211_copy.h
index d49c553..4ac730b 100644
--- a/src/drivers/nl80211_copy.h
+++ b/src/drivers/nl80211_copy.h
@@ -6896,6 +6896,8 @@ enum nl80211_ext_feature_index {
 	NL80211_EXT_FEATURE_DEVICE_BW,
 	NL80211_EXT_FEATURE_MLD_LINK_REMOVAL_OFFLOAD,
 	NL80211_EXT_FEATURE_ERP,
+	NL80211_EXT_FEATURE_TARGET_AND_HOST_AFC_SUPPORT,
+	NL80211_EXT_FEATURE_RETAIL_AFC_SUPPORT,
 
 	/* add new features before the definition below */
 	NUM_NL80211_EXT_FEATURES,
-- 
2.34.1

