From 77fedf3307306021cc5fae5fdf1e8f408dc01bc2 Mon Sep 17 00:00:00 2001
From: Aditya Kumar Singh <aditya.kumar.singh@oss.qualcomm.com>
Date: Wed, 30 Jul 2025 10:17:24 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostap: free wpa_auth sm from previous
 failed authentication

Currently, when the initial Multi-Link (ML) authentication fails, the
wpa_auth state machine is not properly freed, leading to a memory leak.
This typically occurs when an ML STA begins authentication on one link but
roams to a partner link before reaching the authorized state. During this
roaming process, the link ID is updated, but the original wpa_auth state
machine is left behind. Since the station is not authorized, retaining the
state machine is unnecessary and results in a memory leak.

Add logic to free the wpa_auth state machine from partner links when their
previous ML authentication attempt has failed.

Patch Dependency: r36-02-Update-partner-linkId-for-proper-partner-link-reset.patch
Link: None
Feature: MLO

Signed-off-by: Aditya Kumar Singh <aditya.kumar.singh@oss.qualcomm.com>
---
 src/ap/ieee802_11.c |  2 ++
 src/ap/sta_info.c   | 27 +++++++++++++++++++++++++++
 src/ap/sta_info.h   |  2 ++
 3 files changed, 31 insertions(+)

diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index 8586f56b5030..8747363844fc 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -3455,6 +3455,8 @@ static void handle_auth(struct hostapd_data *hapd,
 			set_link_id_for_each_partner_link_sta(hapd,
 							      sta,
 							      link_id);
+			remove_sm_for_each_partner_link_sta(hapd, sta, link_id);
+
 			/*
 			 * Set the MLD address as the station address and the
 			 * station addresses.
diff --git a/src/ap/sta_info.c b/src/ap/sta_info.c
index d2363c16777a..5fd1af2ec2f5 100644
--- a/src/ap/sta_info.c
+++ b/src/ap/sta_info.c
@@ -1060,6 +1060,33 @@ struct sta_info * ap_sta_add(struct hostapd_data *hapd, const u8 *addr)
 }
 
 
+void remove_sm_for_each_partner_link_sta(struct hostapd_data *hapd,
+					 struct sta_info *psta, int link_id)
+{
+	struct hostapd_data *lhapd;
+	struct sta_info *lsta;
+
+	if (!psta->mld_info.mld_sta)
+		return;
+
+	for_each_mld_link(lhapd, hapd) {
+		if (lhapd == hapd)
+			continue;
+
+		lsta = ap_get_sta(lhapd, psta->addr);
+		if (!lsta)
+			continue;
+
+		if ((!(lsta->flags & WLAN_STA_MFP) ||
+		     !ap_sta_is_authorized(lsta)) && lsta->wpa_sm) {
+			wpa_auth_sta_deinit(lsta->wpa_sm);
+			lsta->wpa_sm = NULL;
+			clear_wpa_sm_for_each_partner_link(lhapd, lsta);
+		}
+	}
+}
+
+
 void set_link_id_for_each_partner_link_sta(struct hostapd_data *hapd,
 					   struct sta_info *psta,
 					   int link_id)
diff --git a/src/ap/sta_info.h b/src/ap/sta_info.h
index 6a929ae27f0d..a1c07e84ea66 100644
--- a/src/ap/sta_info.h
+++ b/src/ap/sta_info.h
@@ -406,6 +406,8 @@ int set_for_each_partner_link_sta(struct hostapd_data *hapd,
 void set_link_id_for_each_partner_link_sta(struct hostapd_data *hapd,
 					   struct sta_info *psta,
 					   int link_id);
+void remove_sm_for_each_partner_link_sta(struct hostapd_data *hapd,
+					 struct sta_info *psta, int link_id);
 
 int ap_for_each_sta(struct hostapd_data *hapd,
 		    int (*cb)(struct hostapd_data *hapd, struct sta_info *sta,
-- 
