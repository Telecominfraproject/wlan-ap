From ca7e9b3e7c4b2cdd4e29da4748d1554a9597ce78 Mon Sep 17 00:00:00 2001
From: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
Date: Tue, 19 Aug 2025 19:35:24 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd: Fix use-after-free and update mac
 address in Link Reconfiguration Response.

Currently when handling station link removal in Link Reconfiguration
Request, ap_free_sta() is called before logging
WPA_EVENT_LINK_STA_REMOVED. This can lead to use-after-free or invalid
memory access when printing the STA address in the log message.

Move ap_free_sta() after the log message to ensure the STA address
remains valid during logging.

Also fix an issue in Link Reconfiguration Response where the STA address
in the per-STA profile was encoded as an invalid mac
address (00:00:00:00:00:00). Copy the hostapd link address into the per
STA profile to ensure the correct address is included.

Patch-dependency: patches/r93-b-004-UPSTREAM-PROTOCOL-HOSTAPD-Fix-ML-reconfig-response-f.patch

Patch-work: None

Fixes: Ia7bb63df9c38(6131166: PROTOCOL: MLD: Add support to handle ML Setup Link Reconfiguration)

Signed-off-by: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
---
 src/ap/ieee802_11_eht.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 742ddde3c052..715315e73de2 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -1613,10 +1613,10 @@ void hostapd_link_reconf_resp_tx_status(struct hostapd_data *hapd,
 		}
 
 		/* free as a link STA */
-		ap_free_sta(lhapd, lsta);
 		wpa_msg(hapd->msg_ctx, MSG_INFO,
 			WPA_EVENT_LINK_STA_REMOVED "sta=" MACSTR " link_id=%u",
 			MAC2STR(lsta->addr), link_id);
+		ap_free_sta(lhapd, lsta);
 
 		for_each_mld_link(other_hapd, lhapd) {
 			struct mld_link_info *link;
@@ -1846,6 +1846,8 @@ hostapd_send_link_reconf_resp(struct hostapd_data *hapd,
 				continue;
 
 			link->valid = true;
+
+			os_memcpy(link->local_addr, lhapd->own_addr, ETH_ALEN);
 			ieee80211_ml_build_assoc_resp(lhapd, NULL, assoc_sta, link);
 		}
 		mle_len = hostapd_eid_eht_ml_len(&mld, false, false, WLAN_FC_STYPE_ASSOC_RESP);
-- 
