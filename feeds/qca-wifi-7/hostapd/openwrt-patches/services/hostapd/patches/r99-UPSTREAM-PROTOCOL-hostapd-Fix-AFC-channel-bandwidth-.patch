From 613d179720b708bc2bf5680d61eb394715c8fe0d Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Fri, 22 Aug 2025 13:24:20 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Fix AFC channel, bandwidth
 validation

Currently, during channel change to an SP channel, hostapd validates if
the channel and bandwidth configured is valid for the SP power mode.
However, this validation incorrectly takes the channel, BW and
puncture pattern from the current channel, instead of the target channel.

This results in an incorrect validation, where we end up doing a
channel change to a channel in SP mode, even though the target
channel parameters may not be valid for SP mode.

Fix this by using the input frequency, bandwidth and puncture
pattern to validate if the channel params are allowed for a
given power mode.

Fixes: I1a47bc82031 ("UPSTREAM:PROTOCOL:hostapd: Validate channel and bandwidth  during power mode configuration")
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
n00-001-hostapd-add-support-for-6GHz-operation.patch
r28-hostapd-Add-hostapd-cli-support-to-switch-6GHZ-power.patch
r32-001-hostapd-Add-support-to-receive-AFC-power-update-comp.patch
r65-QSDK-HOSTAPD-Implement-Min-PSD-Calculation-and-Punct.patch
r72-a-UPSTREAM-PROTOCOL-hostapd-6-GHz-power-mode-channels-.patch
r72-d-UPSTREAM-PROTOCOL-hostapd-Clean-up-and-refactor-6-GH.patch
r72-e-UPSTREAM-PROTOCOL-hostapd-Support-for-SP-and-Punctur.patch
r96-00-UPSTREAM-PROTOCOL-hostapd-Validate-channel-and-bandw.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c           | 29 ++++++++++++++++++-----------
 src/ap/hostapd.c               | 27 ++-------------------------
 src/common/ieee802_11_common.c | 31 +++++++++++++++++++++++++++++++
 src/common/ieee802_11_common.h | 10 ++++++++++
 4 files changed, 61 insertions(+), 36 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 552ac97b0c08..269ffff917a8 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -2981,21 +2981,25 @@ is_afc_info_usable(struct afc_sp_reg_info *afc_info)
  * ieee80211_validate_chan_bw_in_afc_response() - Validate channel
  * bandwidth in AFC response
  * @iface: Pointer to hostapd interface data
+ * @freq: Frequency of the channel
+ * @cen_freq: Center frequency of the channel
+ * @bw: Bandwidth of the channel
+ * @pp: Puncturing bitmap
  * @he_6ghz_pwr_mode: HE 6 GHz power mode
+ *
  * Return: true if valid, false otherwise
  */
 static bool
 ieee80211_validate_chan_bw_in_afc_response(struct hostapd_iface *iface,
-					   u8 he_6ghz_pwr_mode)
+					   u16 freq, u16 cen_freq, u16 bw,
+					   u16 pp, u8 he_6ghz_pwr_mode)
 {
 	struct afc_sp_reg_info *afc_info;
 	bool valid;
 	u8 i;
-	u16 freq = iface->freq;
-	u16 cen_freq = hostapd_get_oper_centr_freq_seg0_idx(iface->conf);
-	u8 op_class = iface->conf->op_class;
+	u8 op_class;
 
-	if (he_6ghz_pwr_mode != HE_REG_INFO_6GHZ_AP_TYPE_SP || iface->conf->punct_bitmap)
+	if (he_6ghz_pwr_mode != HE_REG_INFO_6GHZ_AP_TYPE_SP || pp)
 		return true;
 
 	afc_info = iface->afc_rsp_info;
@@ -3004,6 +3008,10 @@ ieee80211_validate_chan_bw_in_afc_response(struct hostapd_iface *iface,
 		wpa_printf(MSG_WARNING, "AFC info is not usable");
 		return false;
 	}
+
+	if (get_6ghz_opclass_from_bw(bw, freq, &op_class))
+		return false;
+
 	valid = false;
 	for (i = 0; i < afc_info->num_chan_objs; i++) {
 		struct afc_chan_obj *chan_obj = &afc_info->afc_chan_info[i];
@@ -3052,8 +3060,7 @@ hostapd_validate_chan_bw_in_pwr_mode(struct hostapd_iface *iface, u16 freq,
 
 	wpa_printf(MSG_INFO,
 		   "Validating power mode: %d, Freq: %d, cf: %d, BW: %d, pp: 0x%x",
-		   pwr_type, iface->freq, center_freq, bw,
-		   iface->conf->punct_bitmap);
+		   pwr_type, iface->freq, center_freq, bw, pp);
 	chan_6ghz = hostapd_iface_get_6ghz_chan_list(iface,
 						     start_freq,
 						     pwr_type,
@@ -3092,15 +3099,15 @@ hostapd_validate_chan_bw_in_pwr_mode(struct hostapd_iface *iface, u16 freq,
 
 		chan_6ghz++;
 	}
-	if (!ieee80211_validate_chan_bw_in_afc_response(iface,
-							pwr_type)) {
+
+	if (!ieee80211_validate_chan_bw_in_afc_response(iface, freq, center_freq,
+							bw, pp, pwr_type)) {
 		wpa_printf(MSG_WARNING,
 			   "Channel %d, bw: %d is not supported in power mode %d",
-			   iface->freq, bw, pwr_type);
+			   freq, bw, pwr_type);
 		return false;
 	}
 
-
 	return true;
 }
 
diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index 8e4d3e632898..3d72190e7acf 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -6945,7 +6945,7 @@ hostapd_get_sp_eirp(struct hostapd_iface *iface, u16 freq, u16 cen_freq,
 		    bool is_client_lookup, bool is_twice_pwr, s16 *sp_eirp_pwr)
 {
 	s16 afc_eirp_pwr, reg_sp_eirp_pwr;
-	u8 i, op_class = 0;
+	u8 i, op_class;
 	struct afc_sp_reg_info *afc_info;
 	int ret = -1;
 	bool found = false;
@@ -6979,31 +6979,8 @@ hostapd_get_sp_eirp(struct hostapd_iface *iface, u16 freq, u16 cen_freq,
 						reg_sp_eirp_pwr, sp_eirp_pwr);
 	}
 
-	switch (bw) {
-	case 20:
-		if (freq == 5935)
-			op_class = 136;
-		else
-			op_class = 131;
-		break;
-	case 40:
-		op_class = 132;
-		break;
-	case 80:
-		op_class = 133;
-		break;
-	case 160:
-		op_class = 134;
-		break;
-#ifdef CONFIG_IEEE80211BE
-	case 320:
-		op_class = 137;
-		break;
-#endif
-	default:
-		wpa_printf(MSG_ERROR, "Invalid channel width");
+	if (get_6ghz_opclass_from_bw(bw, freq, &op_class))
 		return -1;
-	}
 
 	afc_eirp_pwr = CHAN_MIN_TX_POWER * EIRP_PWR_SCALE;
 	for (i = 0; i < afc_info->num_chan_objs; i++) {
diff --git a/src/common/ieee802_11_common.c b/src/common/ieee802_11_common.c
index 2db95ad0b8ce..a1a040429ff7 100644
--- a/src/common/ieee802_11_common.c
+++ b/src/common/ieee802_11_common.c
@@ -3069,6 +3069,37 @@ u8 get_subchannels_for_opclass(u8 cfi,
 	return nchans;
 }
 
+int get_6ghz_opclass_from_bw(int bw, int freq, u8 *op_class)
+{
+	switch (bw) {
+	case 20:
+		if (freq == 5935)
+			*op_class = 136;
+		else
+			*op_class = 131;
+		break;
+	case 40:
+		*op_class = 132;
+		break;
+	case 80:
+		*op_class = 133;
+		break;
+	case 160:
+		*op_class = 134;
+		break;
+#ifdef CONFIG_IEEE80211BE
+	case 320:
+		*op_class = 137;
+		break;
+#endif
+	default:
+		wpa_printf(MSG_ERROR, "Invalid channel width %d", bw);
+		return -1;
+	}
+
+	return 0;
+}
+
 bool is_320_opclass(u8 op_class)
 {
 #ifdef CONFIG_IEEE80211BE
diff --git a/src/common/ieee802_11_common.h b/src/common/ieee802_11_common.h
index 4094a399ee32..2d2daee31188 100644
--- a/src/common/ieee802_11_common.h
+++ b/src/common/ieee802_11_common.h
@@ -357,6 +357,16 @@ int get_6ghz_sec_channel(int channel);
 bool is_320_opclass(u8 op_class);
 u8 get_subchannels_for_opclass(u8 cfi, u8 opclass, u8 *subchannels);
 
+/**
+ * get_6ghz_opclass_from_bw - Get 6 GHz operating class for the given bandwidth
+ * @bw: Bandwidth in MHz (20, 40, 80, 160, 320)
+ * @freq: Primary frequency in MHz
+ * @op_class: Pointer to store the resulting operating class
+ *
+ * Returns: 0 on success, -1 on failure.
+ */
+int get_6ghz_opclass_from_bw(int bw, int freq, u8 *op_class);
+
 bool is_same_band(int freq1, int freq2);
 #define IS_2P4GHZ(n) (n >= 2412 && n <= 2484)
 #define IS_5GHZ(n) (n > 4000 && n < 5895)
