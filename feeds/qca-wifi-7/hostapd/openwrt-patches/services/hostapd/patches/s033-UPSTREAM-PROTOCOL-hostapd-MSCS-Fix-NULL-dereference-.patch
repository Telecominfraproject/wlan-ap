From 6dc8394c1776337e870613431dfc15ecfdb7a31d Mon Sep 17 00:00:00 2001
From: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
Date: Thu, 6 Nov 2025 12:45:04 -0800
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd:MSCS:Fix NULL dereference of MSCS
 context during rule create

Avoid dereferencing mscs_ctxt which maybe NULL, before setting up the
MSCS rule.
Check for mscs session existence as well before establishing an MSCS
rule.

Patch-dependency:
s011-UPSTREAM-PROTOCOL-hostapd-MSCS-Add-support-to-send-h.patch
Patch-work: NA
Tag: MSCS

Fixes: f4da3302416a ("Add MLME and NL80211 support for MSCS protocol")
Signed-off-by: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
---
 src/ap/robust_av.c | 22 +++++++++++-----------
 1 file changed, 11 insertions(+), 11 deletions(-)

diff --git a/src/ap/robust_av.c b/src/ap/robust_av.c
index 350264c21ee5..4136cc3d7808 100644
--- a/src/ap/robust_av.c
+++ b/src/ap/robust_av.c
@@ -1230,7 +1230,7 @@ static bool hostapd_mscs_flow_exists(struct hostapd_data *hapd,
 	struct hostapd_tclas_elements te = {0};
 	int idx;
 
-	if (!sta || !sta->mscs_ctxt)
+	if (!sta || !sta->mscs_ctxt || !sta->mscs_session_exists)
 		return false;
 
 	for (idx = 0; idx < sta->mscs_ctxt->available_idx; idx++) {
@@ -1250,7 +1250,7 @@ static int hostapd_mscs_add_flow_info(struct sta_info *sta,
 	if (!sta)
 		return -EINVAL;
 
-	if (!sta->mscs_ctxt)
+	if (!sta->mscs_ctxt || !sta->mscs_session_exists)
 		return -EINVAL;
 
 	available_idx = sta->mscs_ctxt->available_idx;
@@ -1272,7 +1272,7 @@ static int hostapd_mscs_add_nft_rule(struct hostapd_data *hapd,
 	struct hostapd_nft_rule_params rule = {0};
 	u8 tid = te->up;
 
-	if (!sta || !sta->mscs_ctxt) {
+	if (!sta || !sta->mscs_ctxt || !sta->mscs_session_exists) {
 		wpa_printf(MSG_ERROR, "MSCS: Missing context for STA");
 		return -EINVAL;
 	}
@@ -2415,15 +2415,14 @@ void hostapd_process_mscs_flow(struct hostapd_data *hapd,
 
 	sta = ap_get_sta(hapd, addr);
 
-	if (!sta) {
-		os_free(addr);
-		return;
-	}
+	if (!sta || !sta->mscs_ctxt || !sta->mscs_session_exists)
+		goto fail;
 
-	if (!hapd->conf->mscs) {
-		os_free(addr);
-		return;
-	}
+	if (!hapd->conf->mscs)
+		goto fail;
+
+	if (!te)
+		goto fail;
 
 	tid = hostapd_mscs_get_tid(hapd, sta, tid);
 	te->classifier_type = QM_TCLAS_CLASSIFIER_TYPE4;
@@ -2432,6 +2431,7 @@ void hostapd_process_mscs_flow(struct hostapd_data *hapd,
 
 	hostapd_mscs_add_nft_rule(hapd, sta, te);
 
+fail:
 	os_free(addr);
 	return;
 }
-- 
