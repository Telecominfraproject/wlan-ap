 	conf->hw_mode = ieee80211_freq_to_channel_ext(ssid->frequency, 0,
 						      CONF_OPER_CHWIDTH_USE_HT,
 						      &conf->op_class,
@@ -278,6 +280,8 @@ int wpa_supplicant_conf_ap_ht(struct wpa
 		return -1;
 	}
 
