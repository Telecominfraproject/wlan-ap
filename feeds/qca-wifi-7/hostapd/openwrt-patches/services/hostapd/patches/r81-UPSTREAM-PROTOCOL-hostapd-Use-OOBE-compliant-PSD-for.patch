From 4a1f8a3b20736cf4e4e91bfa978b02a1f2762d64 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Wed, 25 Jun 2025 12:06:26 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd: Use OOBE compliant PSD for
 calculating EIRP

Currently, calculation of EIRP for punctured bandwidth uses regulatory
PSD for standard power (SP) mode. This is not adjacent channel emission
compliant and violates the OOBE (Out of band emission) requirements.

To fix this, use the OOBE compliant PSD which is calculated with
puncture mask enforcement for calculating the EIRP for SP mode.

Fixes: ea3062368d32 ("UPSTREAM:PROTOCOL:hostapd: Add retail AFC and best power mode support")
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
n00-001-hostapd-add-support-for-6GHz-operation.patch
r32-001-hostapd-Add-support-to-receive-AFC-power-update-comp.patch
r72-e-UPSTREAM-PROTOCOL-hostapd-Support-for-SP-and-Punctur.patch
r80-d-UPSTREAM-PROTOCOL-hostapd-Add-minimum-PSD-calculatio.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 src/ap/hostapd.c | 14 +++++++++++---
 1 file changed, 11 insertions(+), 3 deletions(-)

diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index af5f55b21d0f..40ecc8aa2981 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -6605,17 +6605,25 @@ hostapd_get_sp_punc_eirp(struct hostapd_iface *iface, u16 freq, u16 center_freq,
 			 s16 reg_sp_eirp_pwr, s16 *sp_eirp_pwr)
 {
 	u16 effective_bw = hostapd_reg_find_non_punc_bw(bw, in_punc_pattern);
-	s16 oobe_psd_pwr, afc_eirp_pwr;
+	s16 oobe_psd_pwr, afc_eirp_pwr, reg_psd_pwr;
 	int ret;
 
+	get_min_psd_values(iface->afc_rsp_info, freq, center_freq,
+			   in_punc_pattern, bw, &oobe_psd_pwr);
+	if (oobe_psd_pwr == CHAN_MAX_TWICE_TX_POWER * PSD_SCALE) {
+		wpa_printf(MSG_ERROR, "Failed to calculate OOBE PSD");
+		return -1;
+	}
+
 	ret = hostapd_reg_get_psd_from_chan_list(iface, freq, center_freq, bw,
 						 in_punc_pattern, NL80211_REG_AP_SP,
 						 client_type, is_client_lookup,
-						 false, &oobe_psd_pwr);
+						 false, &reg_psd_pwr);
 	if (ret)
 		return ret;
 
-	oobe_psd_pwr *= PSD_SCALE;
+	reg_psd_pwr *= PSD_SCALE;
+	oobe_psd_pwr = MIN(oobe_psd_pwr, reg_psd_pwr);
 	if (hapd_psd_to_eirp(oobe_psd_pwr, PSD_SCALE, effective_bw, &afc_eirp_pwr)) {
 		wpa_printf(MSG_ERROR, "Unable to get EIRP from PSD");
 		return -1;
-- 
