From cdefa5ad8fd8695a0901d995232c0c404bea681c Mon Sep 17 00:00:00 2001
From: Karthik M <karm@qti.qualcomm.com>
Date: Tue, 19 Aug 2025 11:35:22 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: Hostapd: Fix memory leak in wpa_supplicant

Reset loop index when freeing channels_6ghz pointers during mesh
configuration to ensure all modes are properly cleaned up.

Fixes : ea3062368d3 ("UPSTREAM:PROTOCOL: hostapd: Add 6 GHz power mode channels support")

Patch-dependency: None

Patch-work: None

TAG: 6G_REGULATORY

Change-Id: I9226cd50a23c15ef31a4dc35e284ab7c9773791e
Signed-off-by: Karthik M <karm@qti.qualcomm.com>
---
 src/drivers/driver_nl80211.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 877da9d..15f5d27 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -9827,9 +9827,10 @@ static int wpa_driver_nl80211_send_action(struct i802_bss *bss,
 			offchanok = 0;
 		if (modes) {
 			struct hostapd_channel_data **chan_6ghz;
-			int j = 0;
+			int j;
 
 			for (i = 0; i < num_modes; i++) {
+				j = 0;
 				os_free(modes[i].channels);
 				os_free(modes[i].rates);
 				chan_6ghz =
-- 
2.34.1

