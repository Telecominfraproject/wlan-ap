From 942a6abee0bc98aa4d52d6a41acee14d74f7fb41 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Sat, 10 May 2025 02:52:51 +0530
Subject: [PATCH 14/20] UPSTREAM:PROTOCOL: hostapd: Add support to parse the
 EPCS Capability of a non-AP MLD.

EPCS is only initiated from the AP MLD when there are EPCS capable non-AP MLDs
present. When non-AP MLD associates with AP MLD, parse the EPCS Capability of
the non-AP MLD. If the non-AP MLD is EPCS capable, set its is_epcs_capable flag
to true.
If the non-AP MLD is not EPCS capable, set its is_epcs_capable flag to false.
The EPCS Action frames are not sent or processed if this flag is set to false.

The EPCS Capability advertisement is described in the Table- 9-417q Subfields
of the EHT MAC Capabilities Information field, of the IEEE P802.11be/D7.0 Spec.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 src/ap/hostapd.h        |  1 +
 src/ap/ieee802_11.c     |  1 +
 src/ap/ieee802_11_eht.c | 11 +++++++++++
 3 files changed, 13 insertions(+)

diff --git a/src/ap/hostapd.h b/src/ap/hostapd.h
index 947b489..a078d40 100644
--- a/src/ap/hostapd.h
+++ b/src/ap/hostapd.h
@@ -1062,5 +1062,6 @@ void hostapd_handle_epcs_action(struct hostapd_data *hapd,
 				const u8 *buf,
 				size_t len);
 
+void hostapd_get_epcs_capab(struct hostapd_data *hapd, struct sta_info *sta);
 #endif /* CONFIG_IEEE80211BE */
 #endif /* HOSTAPD_H */
diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index 7f45c31..6bd52a0 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -5324,6 +5324,7 @@ static int add_associated_sta(struct hostapd_data *hapd,
 						     WLAN_FC_STYPE_ASSOC_RESP);
 		p = hostapd_eid_eht_capab(hapd, p, IEEE80211_MODE_AP);
 		p = hostapd_eid_eht_operation(hapd, p);
+		hostapd_get_epcs_capab(hapd, sta);
 	}
 #endif /* CONFIG_IEEE80211BE */
 
diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 36e89d1..bc40f68 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -1931,3 +1931,14 @@ void hostapd_handle_epcs_action(struct hostapd_data *hapd,
 
 	hostapd_epcs_handle_and_send_action_frame(hapd, &epcs, sta, true);
 }
+
+
+void hostapd_get_epcs_capab(struct hostapd_data *hapd, struct sta_info *sta)
+{
+	if (sta->mld_info.mld_sta && sta->eht_capab &&
+	    (sta->eht_capab->mac_cap & EHT_MACCAP_EPCS_PRIO)) {
+		sta->mld_info.epcs.is_epcs_capable = true;
+		sta->mld_info.epcs.state = EPCS_STATE_DISABLED;
+	} else
+		sta->mld_info.epcs.is_epcs_capable = false;
+}
