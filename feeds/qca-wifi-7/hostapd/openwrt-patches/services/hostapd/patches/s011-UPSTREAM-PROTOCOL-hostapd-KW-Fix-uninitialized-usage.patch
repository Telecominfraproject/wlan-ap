From 912ca736adde8227d045d87b7d5447dc6ec6c2f5 Mon Sep 17 00:00:00 2001
From: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
Date: Tue, 16 Sep 2025 14:47:14 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd:KW: Fix uninitialized usage of
 sta_info

In hostapd_parse_link_reconf_req_sta_profile(), when
EHT_PER_STA_RECONF_CTRL_COMPLETE_PROFILE is not set in sta ctrl,
sta_info is used to process the add link request before it is
initialized. Fix this by initilizing sta_info before it is used.

Patch-dependency: r93-0003-AP-MLD-Process-Link-Reconfiguration-Request-frame-fo.patch

Fixes: Ia7bb63df9c3 ('PROTOCOL: MLD: Add support to handle ML Setup Link Reconfiguration')

Signed-off-by: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
---
 src/ap/ieee802_11_eht.c | 12 ++++++------
 1 file changed, 6 insertions(+), 6 deletions(-)

diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 69bbffd..a8f21bb 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -2060,6 +2060,12 @@ hostapd_parse_link_reconf_req_sta_profile(struct hostapd_data *hapd,
 	status = WLAN_STATUS_UNSPECIFIED_FAILURE;
 
 	per_sta_prof = (struct ieee80211_eht_per_sta_profile *) elem->data;
+	sta_info = per_sta_prof->variable;
+	if (end < sta_info + *sta_info) {
+		wpa_printf(MSG_DEBUG, "MLD: STA Info with excess length");
+		goto out;
+	}
+
 	sta_control = le_to_host16(per_sta_prof->sta_control);
 	sta_info_len = 1;
 
@@ -2125,12 +2131,6 @@ hostapd_parse_link_reconf_req_sta_profile(struct hostapd_data *hapd,
 	}
 	sta_info_len += nstr_bitmap_size;
 
-	sta_info = per_sta_prof->variable;
-	if (end < sta_info + *sta_info) {
-		wpa_printf(MSG_DEBUG, "MLD: STA Info with excess length");
-		goto out;
-	}
-
 	if (*sta_info < sta_info_len) {
 		wpa_printf(MSG_DEBUG, "MLD: Invalid Reconf STA Info len (%u); "
 			   "min expected=%zu", *sta_info, sta_info_len);
-- 
2.34.1

