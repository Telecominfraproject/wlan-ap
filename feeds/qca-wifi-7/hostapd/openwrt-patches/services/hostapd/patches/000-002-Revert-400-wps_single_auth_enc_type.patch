From fb02ac4016729af864469903357be3e68579fa96 Mon Sep 17 00:00:00 2001
From: Aaradhana Sahu <aaradhana.sahu@oss.qualcomm.com>
Date: Tue, 29 Jul 2025 16:49:30 +0530
Subject: [PATCH] QSDK:PROTOCOL:hostapd: Fix incorrect cipher configuration
 when both AES and TKIP are set in M1

Currently, when the M1 frame advertises both AES and TKIP in the encryption
type field, only AES is considered for setting wpa_pairwise. This leads to
incorrect cipher configuration, including group_cipher, rsn_pairwise_cipher,
and wpa_pairwise_cipher.

Fix this by checking all bits in the encryption type field and updating
wpa_pairwise accordingly.

Note: This is regression by 400-wps_single_auth_enc_type.patch

Patch-dependency: 400-wps_single_auth_enc_type.patch
Patch-work: None

Signed-off-by: Aaradhana Sahu <aaradhana.sahu@oss.qualcomm.com>
---
 src/ap/wps_hostapd.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/src/ap/wps_hostapd.c b/src/ap/wps_hostapd.c
index d2297ae..a81d324 100644
--- a/src/ap/wps_hostapd.c
+++ b/src/ap/wps_hostapd.c
@@ -394,8 +394,10 @@ static int hapd_wps_reconfig_in_memory(struct hostapd_data *hapd,
 				bss->wpa_pairwise |= WPA_CIPHER_GCMP;
 			else
 				bss->wpa_pairwise |= WPA_CIPHER_CCMP;
+		}
+
 #ifndef CONFIG_NO_TKIP
-		} else if (cred->encr_type & WPS_ENCR_TKIP)
+		if (cred->encr_type & WPS_ENCR_TKIP)
 			bss->wpa_pairwise |= WPA_CIPHER_TKIP;
 #endif /* CONFIG_NO_TKIP */
 		bss->rsn_pairwise = bss->wpa_pairwise;
@@ -1187,7 +1189,9 @@ int hostapd_init_wps(struct hostapd_data *hapd,
 					  WPA_CIPHER_GCMP_256)) {
 			wps->encr_types |= WPS_ENCR_AES;
 			wps->encr_types_rsn |= WPS_ENCR_AES;
-		} else if (conf->rsn_pairwise & WPA_CIPHER_TKIP) {
+		}
+
+		if (conf->rsn_pairwise & WPA_CIPHER_TKIP) {
 #ifdef CONFIG_NO_TKIP
 			wpa_printf(MSG_INFO, "WPS: TKIP not supported");
 			goto fail;
-- 
