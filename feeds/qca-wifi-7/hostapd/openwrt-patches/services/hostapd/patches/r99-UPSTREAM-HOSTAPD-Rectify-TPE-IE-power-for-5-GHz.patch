From f4601690e539c33eacc35537118764eb0ebdc680 Mon Sep 17 00:00:00 2001
From: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
Date: Wed, 17 Sep 2025 14:23:58 +0530
Subject: [PATCH] UPSTREAM:HOSTAPD: Rectify TPE IE power for 5 GHz

The EIRP is incorrect in the TPE IE of a 5 GHz AP.

In hostapd_eid_txpower_envelope, the eirp_tx_pwr_array is always
filled only for the 0th index.

To fix this issue, fill eirp_tx_pwr_array for all indices before
passing it to hostapd_add_tpe_info.

Also, add TPE support for 5 GHz AP operating in 320 MHz, by filling the
ext_tx_pwr_array.

Tag: REGULATORY
Fixes Ic72a220bd9c ('r21-001-hostapd-TPE-11AX-changes-and-support-for-11BE-TPE.patch')

Signed-off-by: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
---
 src/ap/ieee802_11.c | 16 +++++++++++-----
 1 file changed, 11 insertions(+), 5 deletions(-)

--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -9706,8 +9706,9 @@ static void hostapd_add_6g_tpe(struct ho
 
 u8 * hostapd_eid_txpower_envelope(struct hostapd_data *hapd, u8 *eid)
 {
+	u8 channel, tx_pwr_count, local_pwr_constraint, tx_pwr_ext_count = 0;
+	s8 tx_pwr_ext_array[TPE_NUM_EIRP_POWER_EXT_SUPPORTED] = {0};
 	s8 eirp_tx_pwr_array[MAX_TPE_EIRP_NUM_POWER_SUPPORTED];
-	u8 channel, tx_pwr_count, local_pwr_constraint;
 	struct hostapd_iface *iface = hapd->iface;
 	struct hostapd_hw_modes *mode = iface->current_mode;
 	struct hostapd_config *iconf = iface->conf;
@@ -9754,7 +9755,8 @@ u8 * hostapd_eid_txpower_envelope(struct
 		break;
 	case CONF_OPER_CHWIDTH_80P80MHZ:
 	case CONF_OPER_CHWIDTH_160MHZ:
-		/* Max Transmit Power count = 3 (20, 40, 80, 160/80+80 MHz) */
+	case CONF_OPER_CHWIDTH_320MHZ:
+		/* Max Transmit Power count = 3 (20, 40, 80, 160/80+80, 320 MHz) */
 		tx_pwr_count = 3;
 		break;
 	default:
@@ -9810,11 +9812,13 @@ u8 * hostapd_eid_txpower_envelope(struct
 	else
 		tx_pwr = max_tx_power;
 
-	for (i = 0; i < tx_pwr_count; i++)
-		eirp_tx_pwr_array[0] = tx_pwr;
-
+	memset(eirp_tx_pwr_array, tx_pwr, tx_pwr_count + 1);
+	hostapd_fill_eirp_for_ext_tpe(iconf, tx_pwr_ext_array,
+				      eirp_tx_pwr_array, &tx_pwr_ext_count,
+				      tx_pwr_count + 1);
 	eid = hostapd_add_tpe_info(eid, LOCAL_EIRP, tx_pwr_count, eirp_tx_pwr_array,
-			           0, NULL, REG_MAX_CLIENT_TYPE);
+				   tx_pwr_ext_count, tx_pwr_ext_array,
+				    REG_MAX_CLIENT_TYPE);
 	return eid;
 }
 
