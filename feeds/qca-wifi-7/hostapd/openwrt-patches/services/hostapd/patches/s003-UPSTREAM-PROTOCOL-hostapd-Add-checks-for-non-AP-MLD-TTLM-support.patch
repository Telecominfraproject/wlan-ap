From 1997e1b90cde4cdf3c03d0c900c28f2cdea9118b Mon Sep 17 00:00:00 2001
From: Nidhi Jain <nidhjain@qti.qualcomm.com>
Date: Wed, 20 Aug 2025 17:31:32 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Add checks for non AP MLD TTLM
 support

Add checks for TTLM support from non AP MLD requests, response
and teardown.
Add checks for TTLM non AP MLD support before sending request from AP MLD.

Patch-dependency:
r80-002-hostapd-Add-support-to-handle-TTLM-response.patch
r80-003-hostapd-Add-support-to-handle-TTLM-negotiation-via.patch
r80-004-hostapd-Add-support-to-handle-TTLM-request-action.patch
r80-006-hostapd-Add-support-to-handle-and-parse-TTLM.patch
r80-007-hostapd-Add-hostapd_cli-commands-to-support-TTLM.patch
r83-009-UPSTREAM-PROTOCOL-hostapd-Handle-advertised-ttlm-in-assoc-resp.patch

Patch-work : None

Signed-off-by: Nidhi Jain <nidhjain@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c |  5 +++++
 src/ap/ieee802_11.c  |  9 +++++----
 src/ap/ttlm.c        | 32 ++++++++++++++++++++++++++++++++
 src/ap/ttlm.h        |  2 +-
 4 files changed, 43 insertions(+), 5 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 552ac97b0c..d1aad54fbe 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -5148,6 +5148,11 @@ static int hostapd_ctrl_iface_negotiated_ttlm_request(struct hostapd_data *hapd,
 		return -1;
 	}
 
+	if (is_sta_ttlm_capable(sta) == false) {
+		os_free(input);
+		return -1;
+	}
+
 	ttlm_conf = os_zalloc(sizeof(*ttlm_conf));
 	ongoing_ttlm = os_zalloc(sizeof(*ongoing_ttlm));
 	if (!ttlm_conf || !ongoing_ttlm) {
diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index b955165536..6539d42912 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -6263,10 +6263,6 @@ static void handle_assoc(struct hostapd_data *hapd,
 			}
 		}
 	}
-
-	if (sta)
-		hostapd_handle_ttlm_assoc_req(hapd, mgmt, len, sta, pos, left);
-
 #endif /* CONFIG_IEEE80211BE */
 
 #ifdef CONFIG_IEEE80211R_AP
@@ -6586,6 +6582,11 @@ static void handle_assoc(struct hostapd_data *hapd,
 		hostapd_process_assoc_ml_info(hapd, sta, pos, left, reassoc,
 					      resp, false, &set_beacon);
 
+#ifdef CONFIG_IEEE80211BE
+	if (sta)
+		hostapd_handle_ttlm_assoc_req(hapd, mgmt, len, sta, pos, left);
+#endif /* CONFIG_IEEE80211BE */
+
 	if (resp == WLAN_STATUS_SUCCESS && sta &&
 	    add_associated_sta(hapd, sta, reassoc))
 		resp = WLAN_STATUS_AP_UNABLE_TO_HANDLE_NEW_STA;
diff --git a/src/ap/ttlm.c b/src/ap/ttlm.c
index ed7b47b537..54bc08f733 100644
--- a/src/ap/ttlm.c
+++ b/src/ap/ttlm.c
@@ -874,6 +874,25 @@ bool hostapd_is_mapping_homogeneous(struct ttlm_ongoing_negotiation_info *ongoin
 }
 
 
+bool is_sta_ttlm_capable(struct sta_info *sta)
+{
+	u16 mld_sta_capa;
+	int sta_ttlm_cap;
+
+	if (!sta || !sta->mld_info.mld_sta)
+		return false;
+
+	mld_sta_capa = sta->mld_info.common_info.mld_capa;
+	sta_ttlm_cap = (mld_sta_capa & EHT_ML_MLD_CAPA_TID_TO_LINK_MAP_NEG_SUPP_MSK) >> 5;
+	if (!sta_ttlm_cap) {
+		wpa_printf(MSG_ERROR, "STA is not TTLM capable");
+		return false;
+	}
+
+	return true;
+}
+
+
 int hostapd_handle_ttlm_resp(struct hostapd_data *hapd, struct sta_info *sta,
 			     const u8 *buf, size_t len)
 {
@@ -885,6 +904,10 @@ int hostapd_handle_ttlm_resp(struct hostapd_data *hapd, struct sta_info *sta,
 		wpa_printf(MSG_ERROR, "Station is not found");
 		return -1;
 	}
+
+	if (is_sta_ttlm_capable(sta) == false)
+		return -1;
+
 	ongoing_ttlm = &sta->mld_info.tid_map_info.ttlm_ongoing_negotiation_info;
 
 	if (ongoing_ttlm->dialog_token != mgmt->u.action.u.ttlm_resp.dialog_token) {
@@ -1048,6 +1071,9 @@ int hostapd_handle_ttlm_assoc_req(struct hostapd_data *hapd, const struct ieee80
 	enum ttlm_resp_type resp_type = TTLM_RESP_TYPE_SUCCESS;
 	u8 i;
 
+	if (is_sta_ttlm_capable(sta) == false)
+		return WLAN_STATUS_REQUEST_DECLINED;
+
 	/* initialize all partner stas */
 	os_memset(&sta->mld_info.tid_map_info.ttlm_ongoing_negotiation_info,
 		  0,
@@ -1240,6 +1266,9 @@ void hostapd_handle_ttlm_req(struct hostapd_data *hapd, struct sta_info *sta,
 		return;
 	}
 
+	if (is_sta_ttlm_capable(sta) == false)
+		return;
+
 	ongoing_ttlm->dialog_token = mgmt->u.action.u.ttlm_req.dialog_token;
 	pos = mgmt->u.action.u.ttlm_req.variable;
 	ie_len = buf + len - pos;
@@ -1403,6 +1432,9 @@ int hostapd_handle_ttlm_teardown(struct hostapd_data *hapd, struct sta_info *sta
 		return -1;
 	}
 
+	if (is_sta_ttlm_capable(sta) == false)
+		return -1;
+
 	negotiated_ttlm = &sta->mld_info.tid_map_info.ttlm_prev_negotiated_info;
 	negotiated_ttlm->dialog_token = 0;
 	hostapd_reset_ttlm_info(negotiated_ttlm->ttlm_info);
diff --git a/src/ap/ttlm.h b/src/ap/ttlm.h
index c2677ef21d..59ac84613a 100644
--- a/src/ap/ttlm.h
+++ b/src/ap/ttlm.h
@@ -244,5 +244,5 @@ void hostapd_ttlm_handle_expected_duration_expiry(struct ttlm_context *ttlm_ctx,
 int hostapd_send_advertised_ttlm(struct hostapd_data *hapd, struct mlo_ttlm_ie *ttlm_conf);
 bool is_valid_negotiated_ttlm(struct mlo_ttlm_ie *established_ttlm,
 			      struct ttlm_ongoing_negotiation_info *neg_info);
-
+bool is_sta_ttlm_capable(struct sta_info *sta);
 #endif /* TTLM_H */
-- 
2.34.1

