Patch-Dependency: r69-UPSTREAM-PROTOCOL-driver-Add-support-for-MLD-max-idle-period.patch
Link: None
Feature: MLO General

Since the GET_STATION command has multiple callers, and link-level
statistics are only needed in one specific path, introduce a boolean flag
parse_link_sta_data to indicate whether link-level parsing is required.
Use this flag to conditionally perform the parsing, avoiding unnecessary
memory allocation and potential leaks.

Additionally, refactor the memory freeing logic into a dedicated helper API
to improve maintainability and support future scalability.

Fixes: 099a5c3da4fd ("UPSTREAM:PROTOCOL:HOSTAPD: Add MLO support for MLD BSS Max Idle Period")
Signed-off-by: Sarika Sharma <sarishar@qti.qualcomm.com>
---
 src/drivers/driver.h         |  1 +
 src/drivers/driver_nl80211.c | 18 +++++++++++++++---
 src/drivers/driver_nl80211.h |  1 +
 3 files changed, 17 insertions(+), 3 deletions(-)

diff --git a/src/drivers/driver.h b/src/drivers/driver.h
index dd8b6f404a1a..921371ae73be 100644
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -2931,6 +2931,7 @@ struct hostap_sta_driver_data {
 	u8 rx_dcm, tx_dcm;
 	u16 valid_links;
 	struct hostap_sta_driver_data *link_sta_data[MAX_NUM_MLD_LINKS];
+	bool parse_link_sta_data;
 };
 
 struct hostapd_sta_add_params {
diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index e67cee6ee51d..7fae411dad08 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -8630,7 +8630,7 @@ static int get_sta_handler(struct nl_msg *msg, void *arg)
 		}
 	}
 
-	if (tb[NL80211_ATTR_MLO_LINKS])
+	if (tb[NL80211_ATTR_MLO_LINKS] && data->parse_link_sta_data)
 		if (get_link_sta_stats(data, tb, stats_policy))
 			wpa_printf(MSG_DEBUG,
 				   "nl80211: link=%d: failed to get link stats",
@@ -8643,6 +8643,18 @@ static int get_sta_handler(struct nl_msg *msg, void *arg)
 }
 
 
+void nl80211_free_sta_driver_link_data(struct hostap_sta_driver_data *data)
+{
+	int i;
+
+	if (!data)
+		return;
+
+	for_each_link(data->valid_links, i)
+		os_free(data->link_sta_data[i]);
+}
+
+
 int nl80211_get_link_signal(struct wpa_driver_nl80211_data *drv,
 			    const u8 *bssid,
 			    struct hostap_sta_driver_data *data)
@@ -8790,6 +8802,7 @@ static int i802_get_inact_sec(void *priv, const u8 *addr)
 
 	os_memset(&data, 0, sizeof(data));
 	data.inactive_msec = -1UL;
+	data.parse_link_sta_data = true;
 
 	ret = i802_read_sta_data(priv, &data, addr);
 	if (ret)
@@ -8804,8 +8817,7 @@ static int i802_get_inact_sec(void *priv, const u8 *addr)
 	}
 
 free_link_sta_data:
-	for_each_link(data.valid_links, i)
-		os_free(data.link_sta_data[i]);
+	nl80211_free_sta_driver_link_data(&data);
 
 	if (ret || (inactive_time == -1UL)) {
 		if (ret == -ENOENT)
diff --git a/src/drivers/driver_nl80211.h b/src/drivers/driver_nl80211.h
index ac53df8f4c6d..375b45a584be 100644
--- a/src/drivers/driver_nl80211.h
+++ b/src/drivers/driver_nl80211.h
@@ -451,5 +451,6 @@ nl80211_get_multi_hw_info(struct i802_bss *bss, unsigned int *num_multi_hws);
 u32 get_nl80211_protocol_features(struct wpa_driver_nl80211_data *drv);
 
 int get_sta_mlo_interface_info(struct wpa_driver_nl80211_data *drv);
+void nl80211_free_sta_driver_link_data(struct hostap_sta_driver_data *data);
 
 #endif /* DRIVER_NL80211_H */
