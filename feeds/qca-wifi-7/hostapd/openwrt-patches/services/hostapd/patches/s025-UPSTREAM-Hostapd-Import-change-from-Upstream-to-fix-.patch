From d812c66d447807078d31346babf304c8f6114ec7 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Tue, 14 Oct 2025 11:48:33 +0530
Subject: [PATCH] UPSTREAM:Hostapd: Import change from Upstream to fix color
 collision timeout issue

When color collisions occur, the logic for selecting a new BSS color
fails to evaluate all available options in the color list, leading to
failure or delays in selecting a suitable new color. Fix the color
generation logic by importing the implementation from the upstream source.

Co-developed-by: Lorenzo Bianconi <lorenzo@kernel.org>
Signed-off-by: Lorenzo Bianconi <lorenzo@kernel.org>
Signed-off-by: John Crispin <john@phrozen.org>
Signed-off-by: Ryder Lee <ryder.lee@mediatek.com>
Signed-off-by: Jouni Malinen <j@w1.fi>
Signed-off-by: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
---
 src/ap/hostapd.c | 11 +++++------
 1 file changed, 5 insertions(+), 6 deletions(-)

diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index eaf01ef..83b1c46 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -5984,13 +5984,12 @@ void hostapd_switch_color_timeout_handler(void *eloop_data,
 	if (!hapd->no_free_color)
 		 neighbor_color |= hapd->color_collision_bitmap;
 
-	 r = os_random() % HE_OPERATION_BSS_COLOR_MAX - 1;
-	 r++;
-	 for (i = 1; i < HE_OPERATION_BSS_COLOR_MAX; i++) {
-		 if ((neighbor_color & (1 << r)) == 0)
+	r = os_random() % HE_OPERATION_BSS_COLOR_MAX;
+	for (i = 0; i < HE_OPERATION_BSS_COLOR_MAX; i++) {
+		if (r && !(neighbor_color & (1ULL << r)))
 			break;
-		r = r % HE_OPERATION_BSS_COLOR_MAX - 1;
-		r++;
+
+		r = (r + 1) % HE_OPERATION_BSS_COLOR_MAX;
 	}
 
 	if (i == HE_OPERATION_BSS_COLOR_MAX) {
-- 
