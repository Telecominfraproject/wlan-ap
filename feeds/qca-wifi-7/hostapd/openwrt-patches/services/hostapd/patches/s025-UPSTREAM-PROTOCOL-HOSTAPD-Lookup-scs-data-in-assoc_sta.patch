From 914a10e2abcc57c865fb8eb271725e93ea370207 Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Wed, 15 Oct 2025 17:45:45 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:HOSTAPD: Lookup scs data in assoc_sta in
 case of MLD STA

Add logic to get assoc_hapd and corresponding assoc_sta in
case of MLD STA to access the SCS information stored in
assoc_sta to print in dump_scs scs_list and scs_info
commands.

Tag: SCS

Patch-dependency:
r92-04-UPSTREAM-PROTOCOL-CP-HOSTAPD-Add-support-for-SCS-req-parsing.patch
r92-05-UPSTREAM-PROTOCOL-CP-HOSTAPD-Copy-and-send-SCS-data-over-QM.patch
r92-06-UPSTREAM-PROTOCOL-CP-HOSTAPD-Handle-SCS-response-from-driver.patch
r92-07-UPSTREAM-PROTOCOL-CP-HOSTAPD-Add-support-for-sending-SCS-response.patch

Patch-work: NA

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c | 55 ++++++++++++++++++++++----------
 src/ap/robust_av.c   | 76 ++++++++++++++++++++++++++++++++++++++------
 2 files changed, 106 insertions(+), 25 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 7dd15fb..5cf5053 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -6010,8 +6010,9 @@ static int hostapd_ctrl_iface_dump_scs_list(struct hostapd_data *hapd,
 					    const char *cmd, char *buf,
 					    size_t buflen)
 {
+	struct hostapd_data *temp_hapd = hapd;
+	struct sta_info *sta = NULL;
 	u8 addr[ETH_ALEN];
-	struct sta_info *sta;
 
 	if (!hapd->conf->scs) {
 		wpa_printf(MSG_ERROR, "SCS feature is disabled");
@@ -6021,15 +6022,23 @@ static int hostapd_ctrl_iface_dump_scs_list(struct hostapd_data *hapd,
 	if (hwaddr_aton(cmd, addr))
 		return -1;
 
-	sta = ap_get_sta(hapd, addr);
+	if (hapd->conf->mld_ap) {
+		for_each_mld_link(temp_hapd, hapd) {
+			sta = ap_get_sta(temp_hapd, addr);
+			if (sta)
+				break;
+		}
+	} else
+		sta = ap_get_sta(temp_hapd, addr);
+
 	if (!sta) {
 		wpa_printf(MSG_ERROR,
-			   "Station " MACSTR " not found to dump SCS Info",
+			   "Station " MACSTR " not found to dump SCS List",
 			   MAC2STR(addr));
 		return -1;
 	}
 
-	return hostapd_dump_scs_list(hapd, sta, buf, buflen);
+	return hostapd_dump_scs_list(temp_hapd, sta, buf, buflen);
 }
 
 
@@ -6037,8 +6046,9 @@ static int hostapd_ctrl_iface_dump_scs_info(struct hostapd_data *hapd,
 					    const char *cmd, char *buf,
 					    size_t buflen)
 {
+	struct hostapd_data *temp_hapd = hapd;
 	char *token, *context = NULL;
-	struct sta_info *sta;
+	struct sta_info *sta = NULL;
 	u8 addr[ETH_ALEN];
 	int scs_id_temp;
 	u8 scs_id;
@@ -6063,7 +6073,15 @@ static int hostapd_ctrl_iface_dump_scs_info(struct hostapd_data *hapd,
 		return -1;
 	}
 
-	sta = ap_get_sta(hapd, addr);
+	if (hapd->conf->mld_ap) {
+		for_each_mld_link(temp_hapd, hapd) {
+			sta = ap_get_sta(temp_hapd, addr);
+			if (sta)
+				break;
+		}
+	} else
+		sta = ap_get_sta(temp_hapd, addr);
+
 	if (!sta) {
 		wpa_printf(MSG_ERROR,
 			   "Station " MACSTR " not found to dump SCS Info",
@@ -6073,16 +6091,17 @@ static int hostapd_ctrl_iface_dump_scs_info(struct hostapd_data *hapd,
 
 	scs_id = (u8) scs_id_temp;
 
-	return hostapd_dump_scs_info(hapd, sta, buf, buflen, scs_id);
+	return hostapd_dump_scs_info(temp_hapd, sta, buf, buflen, scs_id);
 }
 
 
 static int hostapd_ctrl_iface_send_scs_resp(struct hostapd_data *hapd,
 					    const char *cmd)
 {
+	struct hostapd_data *temp_hapd = hapd;
 	int scs_id_temp, req_type_temp;
 	char *token, *context = NULL;
-	struct sta_info *sta;
+	struct sta_info *sta = NULL;
 	u8 scs_id, req_type;
 	u8 addr[ETH_ALEN];
 
@@ -6111,21 +6130,25 @@ static int hostapd_ctrl_iface_send_scs_resp(struct hostapd_data *hapd,
 		return -1;
 	}
 
-	sta = ap_get_sta(hapd, addr);
-	if (!sta) {
-		wpa_printf(MSG_ERROR, "STA not found");
-		return -1;
-	}
+	if (hapd->conf->mld_ap) {
+		for_each_mld_link(temp_hapd, hapd) {
+			sta = ap_get_sta(temp_hapd, addr);
+			if (sta)
+				break;
+		}
+	} else
+		sta = ap_get_sta(temp_hapd, addr);
 
-	if (!sta->scs_session_count) {
-		wpa_printf(MSG_ERROR, "No SCS sessions configured");
+	if (!sta) {
+		wpa_printf(MSG_ERROR, "STA not found for Unsolicited response");
 		return -1;
 	}
 
 	scs_id = (u8) scs_id_temp;
 	req_type = (u8) req_type_temp;
 
-	if (hostapd_send_unsolicited_scs_resp(hapd, sta, scs_id, req_type) < 0) {
+	if (hostapd_send_unsolicited_scs_resp(temp_hapd, sta, scs_id,
+					      req_type) < 0) {
 		wpa_printf(MSG_ERROR, "Failed to send unsolicited SCS response");
 		return -1;
 	}
diff --git a/src/ap/robust_av.c b/src/ap/robust_av.c
index 54befc2..eecd46b 100644
--- a/src/ap/robust_av.c
+++ b/src/ap/robust_av.c
@@ -73,9 +73,30 @@ static bool hostapd_is_scs_present(struct sta_info *sta, u8 scs_id)
 int hostapd_dump_scs_list(struct hostapd_data *hapd, struct sta_info *sta,
 			  char *buf, size_t buflen)
 {
+	struct sta_info *assoc_sta = NULL;
+	struct hostapd_data *assoc_hapd;
 	int reply_len = 0, res;
 
-	if (sta->scs_session_count == 0) {
+#ifdef CONFIG_IEEE80211BE
+	if (!sta->mld_info.mld_sta) {
+		wpa_printf(MSG_DEBUG,
+			   "Assign sta to assoc_sta for Non-MLD STA");
+		assoc_sta = sta;
+	}
+#endif
+
+	assoc_hapd = hapd;
+
+	if (!assoc_sta) {
+		assoc_sta = hostapd_ml_get_assoc_sta(hapd, sta, &assoc_hapd);
+		if (!assoc_sta) {
+			wpa_printf(MSG_ERROR,
+				   "Assoc STA not found to dump scs list");
+			return -1;
+		}
+	}
+
+	if (!assoc_sta->scs_session_count) {
 		res = os_snprintf(buf + reply_len, buflen - reply_len,
 				  "No SCS sessions configured\n");
 		if (os_snprintf_error(buflen - reply_len, res))
@@ -87,14 +108,14 @@ int hostapd_dump_scs_list(struct hostapd_data *hapd, struct sta_info *sta,
 
 	res = os_snprintf(buf + reply_len, buflen - reply_len,
 			  "Configured SCS sessions for the client "
-			  MACSTR " are:\n", MAC2STR(sta->addr));
+			  MACSTR " are:\n", MAC2STR(assoc_sta->addr));
 
 	if (os_snprintf_error(buflen - reply_len, res))
 		return -1;
 	reply_len += res;
 
-	for (int i = 0; i < sta->scs_session_count; i++) {
-		struct hostapd_scs_req_desc_data *desc = sta->scs_req_desc[i];
+	for (int i = 0; i < assoc_sta->scs_session_count; i++) {
+		struct hostapd_scs_req_desc_data *desc = assoc_sta->scs_req_desc[i];
 
 		res = os_snprintf(buf + reply_len, buflen - reply_len,
 				  "  Index: %d, SCS ID: %u\n",
@@ -112,12 +133,43 @@ int hostapd_dump_scs_info(struct hostapd_data *hapd, struct sta_info *sta,
 			  char *buf, size_t buflen, u8 scs_id)
 {
 	struct hostapd_scs_req_desc_data *desc;
+	struct sta_info *assoc_sta = NULL;
 	const char *qos_type, *direction;
+	struct hostapd_data *assoc_hapd;
 	int reply_len = 0, res;
 	int index = -1;
 
-	for (int i = 0; i < sta->scs_session_count; i++) {
-		desc = sta->scs_req_desc[i];
+#ifdef CONFIG_IEEE80211BE
+	if (!sta->mld_info.mld_sta) {
+		wpa_printf(MSG_DEBUG,
+			   "Assign sta to assoc_sta for Non-MLD STA");
+		assoc_sta = sta;
+	}
+#endif
+
+	assoc_hapd = hapd;
+
+	if (!assoc_sta) {
+		assoc_sta = hostapd_ml_get_assoc_sta(hapd, sta, &assoc_hapd);
+		if (!assoc_sta) {
+			wpa_printf(MSG_ERROR,
+				   "Assoc STA not found to dump scs info");
+			return -1;
+		}
+	}
+
+	if (!assoc_sta->scs_session_count) {
+		res = os_snprintf(buf + reply_len, buflen - reply_len,
+				  "No SCS sessions configured\n");
+		if (os_snprintf_error(buflen - reply_len, res))
+			return -1;
+
+		reply_len += res;
+		return reply_len;
+	}
+
+	for (int i = 0; i < assoc_sta->scs_session_count; i++) {
+		desc = assoc_sta->scs_req_desc[i];
 		if (desc->scs_id == scs_id) {
 			index = i;
 			break;
@@ -126,7 +178,7 @@ int hostapd_dump_scs_info(struct hostapd_data *hapd, struct sta_info *sta,
 
 	if (index == -1) {
 		wpa_printf(MSG_ERROR, "SCS ID %u not found for STA " MACSTR,
-			   scs_id, MAC2STR(sta->addr));
+			   scs_id, MAC2STR(assoc_sta->addr));
 		return -1;
 	}
 
@@ -139,8 +191,9 @@ int hostapd_dump_scs_info(struct hostapd_data *hapd, struct sta_info *sta,
 		reply_len += res; \
 	} while (0)
 
-	APPEND("SCS Info for STA: " MACSTR "\n", MAC2STR(sta->addr));
-	APPEND("Number of SCS Descriptors: %u\n\n", sta->scs_session_count);
+	APPEND("SCS Info for STA: " MACSTR "\n", MAC2STR(assoc_sta->addr));
+	APPEND("Number of SCS Descriptors: %u\n\n",
+	       assoc_sta->scs_session_count);
 
 	qos_type = desc->is_qos_present ? "QoS R3" : "QoS R2";
 	direction = "Downlink"; /* Default value */
@@ -2285,6 +2338,11 @@ int hostapd_send_unsolicited_scs_resp(struct hostapd_data *hapd,
 		}
 	}
 
+	if (!assoc_sta->scs_session_count) {
+		wpa_printf(MSG_ERROR, "No SCS sessions configured");
+		return -1;
+	}
+
 	wpa_printf(MSG_DEBUG, "SCS Unsolicited: Active SCS session count:%u",
 		   assoc_sta->scs_session_count);
 
-- 
2.34.1

