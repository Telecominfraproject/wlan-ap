From 7bd524a6f75b149d68d80dea95da5403de063cbf Mon Sep 17 00:00:00 2001
From: Dhanavandhana Kannan <quic_dhanavan1@quicinc.com>
Date: Mon, 2 Dec 2024 21:42:27 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:HOSTAPD: Handle Probe request frame for
 Non-Transmitting BSS

When configured with multiple BSSIDs, probe request frame sent to
non-transmitting BSSs are currently dropped. This happens because only
the SSID of the transmitting BSS is checked against the probe request
frame SSID, ignoring other BSSID set members.

According to IEEE Std 802.11-2020 section 11.1.4.3.4, a probe response
frame can be sent if the SSID in the probe request frame matches any SSID
in the multiple BSSID set.

To fix this, ensure that SSIDs of non-transmitting BSSs are also checked
when receiving probe request frame in case of mbssid grouping and also in
cases of multiple BSSIDs and always use TX BSS to queue probe response
frame to driver for MBSSID.

Patch-dependency: For grouping related changes
		  r45-001-hostapd-Add-Multi-MBSSID-group-support.patch
                  r45-002-hostapd-AID-reservation-for-multi-BSSID.patch
                  r45-003-hostapd-Parse-NL80211-attributes-for-multi-MBSSID
-group.patch
                  r45-004-hostapd-Add-configuration-for-Multi-MBSSID.patch

Internal review cover title: hostapd: Handle ML Probe request for
Non-Transmitting BSS
			     Send probe response only from transmitting BSS
for MBSSID

Patch-work: None

Signed-off-by: Mohan Kumar G <quic_mkumarg@quicinc.com>
Signed-off-by: Dhanavandhana Kannan <quic_dhanavan1@quicinc.com>
---
 src/ap/beacon.c | 35 +++++++++++++++++++++++++++++++++--
 1 file changed, 33 insertions(+), 2 deletions(-)

--- a/src/ap/beacon.c
+++ b/src/ap/beacon.c
@@ -1624,6 +1624,41 @@ void handle_probe_req(struct hostapd_dat
 	res = ssid_match(hapd, elems.ssid, elems.ssid_len,
 			 elems.ssid_list, elems.ssid_list_len,
 			 elems.short_ssid_list, elems.short_ssid_list_len);
+	/* Check the SSID of Non Transmitting BSS if it is not
+	 * a broadcast probe request frame
+	 */
+	if (res == NO_SSID_MATCH && hapd->iconf->mbssid &&
+	    !(mgmt->da[0] & 0x01)) {
+		if (hapd->iconf->mbssid == MULTI_MBSSID_GROUP_ENABLED) {
+			struct hostapd_data *bss;
+			struct hostapd_multi_mbssid_group *group = hapd->mbssid_group;
+
+			dl_list_for_each(bss, &group->bss_list,
+					 struct hostapd_data, mbssid_bss) {
+				if (bss == hapd)
+					continue;
+				res = ssid_match(bss, elems.ssid,
+						 elems.ssid_len, elems.ssid_list,
+						 elems.ssid_list_len,
+						 elems.short_ssid_list,
+						 elems.short_ssid_list_len);
+				if (res != NO_SSID_MATCH)
+					break;
+			}
+		} else {
+			for (i = 0; i < hapd->iface->num_bss; i++) {
+				if (hapd->iface->bss[i] == hapd)
+					continue;
+				res = ssid_match(hapd->iface->bss[i], elems.ssid,
+						 elems.ssid_len, elems.ssid_list,
+						 elems.ssid_list_len,
+						 elems.short_ssid_list,
+						 elems.short_ssid_list_len);
+				if (res != NO_SSID_MATCH)
+					break;
+			}
+		}
+	}
 	if (res == NO_SSID_MATCH) {
 		if (!(mgmt->da[0] & 0x01)) {
 			wpa_printf(MSG_MSGDUMP, "Probe Request from " MACSTR
@@ -1776,7 +1811,8 @@ void handle_probe_req(struct hostapd_dat
 				params.ecsa_pos - (u8 *) params.resp;
 	}
 
-	ret = hostapd_drv_send_mlme(hapd, params.resp, params.resp_len, noack,
+	ret = hostapd_drv_send_mlme(hostapd_mbssid_get_tx_bss(hapd), params.resp,
+				    params.resp_len, noack,
 				    csa_offs_len ? csa_offs : NULL,
 				    csa_offs_len, 0);
 
