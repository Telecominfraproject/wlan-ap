From edfee5121f965fdd65803174442dcaa7e5869710 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Tue, 10 Jun 2025 20:11:35 +0530
Subject: [PATCH 03/10] UPSTREAM:PROTOCOL:hostapd: Store 6 GHz power mode
 channels in iface

Make a call to 'NL80211_CMD_GET_WIPHY' when we receive
'NL80211_CMD_WIPHY_REG_CHANGE' event from the kernel and process
the new channel list information and store it in the iface's
hostapd_hw_modes structure instead of using a local copy of the
hw modes.

Update the current mode for the based on the new channel
list information to avoid dangling pointers.

Fixes: None
Patch-work: None
Tag: 6G_REGULATORY
Patch-dependency:
r72-a-UPSTREAM-PROTOCOL-hostapd-6-GHz-power-mode-channels-.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 src/ap/hostapd.c                | 66 +++++++++++++++++----------------
 src/ap/hw_features.c            | 16 ++++++++
 src/ap/hw_features.h            | 10 +++++
 wpa_supplicant/wpa_supplicant.c |  1 +
 4 files changed, 62 insertions(+), 31 deletions(-)

diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index edd9d7bec3ac..f12f660e22c5 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -2227,30 +2227,15 @@ void hostapd_no_ir_cleanup(struct hostapd_data *bss)
 
 static int hostapd_no_ir_channel_list_updated(struct hostapd_iface *iface)
 {
-	struct hostapd_data *hapd = iface->bss[0];
 	bool all_no_ir, is_6ghz;
 	int i, j;
 	struct hostapd_hw_modes *mode = NULL;
-	struct hostapd_hw_modes *hw_features;
-	u16 num_hw_features, flags;
-	u8 dfs_domain;
-
-	if (hostapd_drv_none(hapd))
-		return -1;
-
-	hw_features = hostapd_get_hw_feature_data(hapd, &num_hw_features,
-						  &flags, &dfs_domain);
-	if (!hw_features) {
-		wpa_printf(MSG_DEBUG,
-			   "Could not fetching hardware channel list");
-		return -1;
-	}
 
 	all_no_ir = true;
 	is_6ghz = false;
 
-	for (i = 0; i < num_hw_features; i++) {
-		mode = &hw_features[i];
+	for (i = 0; i < iface->num_hw_features; i++) {
+		mode = &iface->hw_features[i];
 
 		if (mode->mode == iface->conf->hw_mode) {
 			if (iface->freq > 0 &&
@@ -2272,25 +2257,25 @@ static int hostapd_no_ir_channel_list_updated(struct hostapd_iface *iface)
 	}
 
 	if (!mode || !is_6ghz)
-		goto free_hw_features;
+		return 0;
 
 	if (iface->state == HAPD_IFACE_ENABLED) {
 		if (!all_no_ir) {
 			struct hostapd_channel_data *chan;
 
-			chan = hw_get_channel_freq(mode->mode,
+			chan = hw_get_channel_freq(iface->current_mode->mode,
 						   iface->freq, NULL,
-						   hw_features,
-						   num_hw_features);
+						   iface->hw_features,
+						   iface->num_hw_features);
 
 			if (!chan) {
 				wpa_printf(MSG_ERROR,
 					   "NO_IR: Could not derive chan from freq");
-				goto free_hw_features;
+				return 0;
 			}
 
 			if (!(chan->flag & HOSTAPD_CHAN_NO_IR))
-				goto free_hw_features;
+				return 0;
 			wpa_printf(MSG_DEBUG,
 				   "NO_IR: The current channel has NO_IR flag now, stop AP.");
 		} else {
@@ -2303,20 +2288,20 @@ static int hostapd_no_ir_channel_list_updated(struct hostapd_iface *iface)
 		if (all_no_ir) {
 			wpa_printf(MSG_DEBUG,
 				   "NO_IR: AP in NO_IR and all chan in the new chanlist are NO_IR. Ignore");
-			goto free_hw_features;
+			return 0;
 		}
 
 		if (!iface->conf->acs) {
 			struct hostapd_channel_data *chan;
 
-			chan = hw_get_channel_freq(mode->mode,
+			chan = hw_get_channel_freq(iface->current_mode->mode,
 						   iface->freq, NULL,
-						   hw_features,
-						   num_hw_features);
+						   iface->hw_features,
+						   iface->num_hw_features);
 			if (!chan) {
 				wpa_printf(MSG_ERROR,
 					   "NO_IR: Could not derive chan from freq");
-				goto free_hw_features;
+				return 0;
 			}
 
 			/* If the last operating channel is NO_IR, trigger ACS.
@@ -2327,15 +2312,13 @@ static int hostapd_no_ir_channel_list_updated(struct hostapd_iface *iface)
 				if (acs_init(iface) != HOSTAPD_CHAN_ACS)
 					wpa_printf(MSG_ERROR,
 						   "NO_IR: Could not start ACS");
-				goto free_hw_features;
+				return 0;
 			}
 		}
 
 		setup_interface2(iface);
 	}
 
-free_hw_features:
-	hostapd_free_hw_features(hw_features, num_hw_features);
 	return 0;
 }
 
@@ -2404,10 +2387,31 @@ int hostapd_handle_afc_channel_change(struct hostapd_iface *iface)
 static int hostapd_handle_regchannel_update(struct hostapd_iface *iface,
 					    void *ctx)
 {
+	int ret;
+
+	ret = hostapd_get_hw_features(iface);
+	if (ret) {
+		wpa_printf(MSG_ERROR, "Failed to get hardware features (%d)", ret);
+		return ret;
+	}
+
+	ret = hostapd_select_hw_mode(iface);
+	if (ret) {
+		wpa_printf(MSG_ERROR, "Failed to select hardware mode (%d)", ret);
+		return ret;
+	}
+
+	ret = hostapd_set_current_hw_info(iface, iface->freq);
+	if (ret) {
+		wpa_printf(MSG_ERROR, "Failed to set current hw info (%d)", ret);
+		return ret;
+	}
+
 	if (iface->is_afc_channel_change_pending) {
 		wpa_printf(MSG_DEBUG, "Handling AFC channel change");
 		return hostapd_handle_afc_channel_change(iface);
 	}
+
 	wpa_printf(MSG_DEBUG, "Handling AFC NOIR");
 	return hostapd_no_ir_channel_list_updated(iface);
 }
diff --git a/src/ap/hw_features.c b/src/ap/hw_features.c
index a5076c24f0ae..7a92623fe63d 100644
--- a/src/ap/hw_features.c
+++ b/src/ap/hw_features.c
@@ -24,6 +24,21 @@
 #include "beacon.h"
 #include "hw_features.h"
 
+void hostapd_free_6ghz_channels(struct hostapd_hw_modes *mode)
+{
+	struct hostapd_channel_data **chan_6ghz;
+	int i;
+
+	if (!mode)
+		return;
+
+	chan_6ghz = mode->channels_6ghz.chans_6ghz;
+	if (!chan_6ghz)
+		return;
+
+	for (i = 0; i < NL80211_REG_NUM_POWER_MODES; i++)
+		os_free(chan_6ghz[i]);
+}
 
 void hostapd_free_hw_features(struct hostapd_hw_modes *hw_features,
 			      size_t num_hw_features)
@@ -36,6 +51,7 @@ void hostapd_free_hw_features(struct hostapd_hw_modes *hw_features,
 	for (i = 0; i < num_hw_features; i++) {
 		os_free(hw_features[i].channels);
 		os_free(hw_features[i].rates);
+		hostapd_free_6ghz_channels(&hw_features[i]);
 	}
 
 	os_free(hw_features);
diff --git a/src/ap/hw_features.h b/src/ap/hw_features.h
index 73663d0af051..f66fb5d0621f 100644
--- a/src/ap/hw_features.h
+++ b/src/ap/hw_features.h
@@ -32,6 +32,16 @@ int hostapd_hw_skip_mode(struct hostapd_iface *iface,
 int hostapd_determine_mode(struct hostapd_iface *iface);
 void hostapd_free_multi_hw_info(struct hostapd_multi_hw_info *multi_hw_info);
 int hostapd_set_current_hw_info(struct hostapd_iface *iface, int oper_freq);
+
+/**
+ * hostapd_free_6ghz_channels() - Free 6 GHz channels for a given mode
+ * @mode: Pointer to the hostapd_hw_modes structure
+ *
+ * This function frees the 6 GHz channels for the given mode.
+ *
+ * Returns: None
+ */
+void hostapd_free_6ghz_channels(struct hostapd_hw_modes *mode);
 #else /* NEED_AP_MLME */
 static inline void
 hostapd_free_hw_features(struct hostapd_hw_modes *hw_features,
diff --git a/wpa_supplicant/wpa_supplicant.c b/wpa_supplicant/wpa_supplicant.c
index a5d28a66386e..27af736ece83 100644
--- a/wpa_supplicant/wpa_supplicant.c
+++ b/wpa_supplicant/wpa_supplicant.c
@@ -467,6 +467,7 @@ void free_hw_features(struct wpa_supplicant *wpa_s)
 	for (i = 0; i < wpa_s->hw.num_modes; i++) {
 		os_free(wpa_s->hw.modes[i].channels);
 		os_free(wpa_s->hw.modes[i].rates);
+		hostapd_free_6ghz_channels(&wpa_s->hw.modes[i]);
 	}
 
 	os_free(wpa_s->hw.modes);
-- 
