From 8e9e94f8ce28ac1d2d30c310f63a29f76302a5cd Mon Sep 17 00:00:00 2001
From: Aditya Kumar Singh <aditya.kumar.singh@oss.qualcomm.com>
Date: Wed, 30 Jul 2025 12:23:41 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostap: handle removal in progress flag or
 non-offloaded drivers

Driver offload multi-link removal introduced an in-progress flag to
determine whether a reconfiguration element should be added. However, this
flag is currently set only in the driver offload path and not in
non-offload drivers. As a result, the reconfiguration element is not added
in the non-offload case, leading to link removal failures

Add changes to handle the new flag in non-offload case as well.

Patches Dependency: r32-004-hostapd-Add-support-for-ML-reconfigure-offloaded-dri.patch
Link: None
Feature: Multi Link Removal

Fixes: a9b84d4802d5 ("hostapd: Add Multi-Link Reconfigure link removal support")
Signed-off-by: Aditya Kumar Singh <aditya.kumar.singh@oss.qualcomm.com>
---
 src/ap/hostapd.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index 2badcdf6ae12..b27a82a9a32d 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -571,6 +571,7 @@ static void hostapd_link_remove_timeout_handler(void *eloop_data,
 	ieee802_11_set_beacon(hapd);
 
 	if (!hapd->eht_mld_link_removal_count) {
+		hapd->eht_mld_link_removal_inprogress = false;
 		hostapd_free_link_stas(hapd);
 		hostapd_disable_iface(hapd->iface);
 		return;
@@ -838,6 +839,7 @@ int hostapd_link_remove(struct hostapd_data *hapd, u32 count)
 	    return hostapd_send_ml_reconfig_link_removal(hapd, count);
 	}
 
+	hapd->eht_mld_link_removal_inprogress = true;
 	eloop_register_timeout(0, TU_TO_USEC(hapd->iconf->beacon_int),
 			       hostapd_link_remove_timeout_handler,
 			       hapd, NULL);
-- 
2.34.1

