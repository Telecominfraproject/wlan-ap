From 264ed5ea599f4ac208ff67339145cd94b9915654 Mon Sep 17 00:00:00 2001
From: Karthik M <karm@qti.qualcomm.com>
Date: Fri, 14 Nov 2025 17:21:43 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Use beacon_set_done flag to
restrict OOB advertisement on lower bands when BSS is stopped

When repeater STA goes for scanning, ucode stops beaconing of all BSS
on that radio using NL_STOP_AP event, Once driver acknowledges this
with a NL_STOP_AP response, hostapd sets the 'disabled' flag of the BSS.
But this disabled flag is not reset anywhere unless there is an RTNL new
link event received from driver. (Note that in this particular case ucode
just stopped the beacon TX but didn't delete the netdev
hence there won't be an rtnl new link event).

When Repeater STA associates, ucode starts the BSS'es with START AP Command,
while doing so TX as well as non-TX bss are started but TX BSS beacon is not
included with any of the non-tx BSS profiles as they are
restricted by disabled flag. This causes failure in discovery
on non-TX profiles.

Setting disabled flag on NL_STOP_AP is introduced in
change - Ied4e44203c ("UPSTREAM:PROTOCOL: hostapd: Updated started flag when
the interface is stopped via some other userspace application").
This commit's intention was to avoid advertising the non-beaconing 6GHz BSS
RNR entry in lower Bands OOB advertisement.

Use beacon_set_done flag of BSS to achieve the same and remove the disabled
flag condition restricting the inclusion of non-TX profiles from TX BSS beacon.
The beacon_set_done flag is set when BSS (send NL_START_AP) is started
which means the interface is going to be enabled back.

Patch-dependency: None
Patch-work: Hostapd: Use beacon_set_done flag to manage RNR/MBSSID beacon
	    updates during interface stop (NL_STOP_AP)

Fixes: Ied4e44203c ("UPSTREAM:PROTOCOL: hostapd: Updated started flag when the
		    interface is stopped via some other userspace application")

Change-Id: If43d54ae061f58889c6024072f1fd0bb10841c4a
Signed-off-by: Karthik M <karm@qti.qualcomm.com>
---
 src/ap/drv_callbacks.c | 2 +-
 src/ap/ieee802_11.c    | 8 ++++----
 2 files changed, 5 insertions(+), 5 deletions(-)

--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -2322,9 +2322,9 @@ static void hostapd_event_iface_unavaila
 						&hapd->cs_freq_params);
 	}
 
-	/* Set disabled to false so the RNR and other beacon params are properly
+	/* Set beacon_set_done to false so the RNR and other beacon params are properly
 	 * updated */
-	hapd->disabled = 1;
+	hapd->beacon_set_done = 0;
 }
 
 
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -10536,7 +10536,7 @@ repeat_rnr_len:
 			bool ap_mld = false;
 			u8 match_idx = 255;
 
-			if (!bss || !bss->conf || !bss->started || bss->disabled)
+			if (!bss || !bss->conf || !bss->started || !bss->beacon_set_done)
 				continue;
 
 #ifdef CONFIG_IEEE80211BE
@@ -10808,7 +10808,7 @@ static bool hostapd_eid_rnr_bss(struct h
 #endif /* CONFIG_IEEE80211BE */
 
 	if (!bss || !bss->conf || !bss->started ||
-	    bss->disabled || bss == reporting_hapd)
+	    !bss->beacon_set_done || bss == reporting_hapd)
 		return false;
 
 	if (hostapd_skip_rnr(i, skip_profiles, ap_mld, tbtt_info_len,
@@ -11147,7 +11147,7 @@ static size_t hostapd_eid_mbssid_elem_le
 		else
 			bss = tx_bss->iface->bss[i];
 
-		if (!bss || !bss->conf || !bss->started || bss->disabled ||
+		if (!bss || !bss->conf || !bss->started ||
 		    mbssid_known_bss(i, known_bss, known_bss_len))
 			continue;
 
@@ -11379,7 +11379,7 @@ static u8 * hostapd_eid_mbssid_elem(stru
 		else
 			bss = tx_bss->iface->bss[i];
 
-		if (!bss || !bss->conf || !bss->started || bss->disabled ||
+		if (!bss || !bss->conf || !bss->started ||
 		    mbssid_known_bss(i, known_bss, known_bss_len))
 			continue;
 		conf = bss->conf;
