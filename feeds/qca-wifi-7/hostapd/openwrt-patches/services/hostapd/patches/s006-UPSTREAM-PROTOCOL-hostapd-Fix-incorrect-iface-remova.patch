From 7ecf9b14511e0d3a86aba0cb86c53a6c23d41927 Mon Sep 17 00:00:00 2001
From: Ramasamy Kaliappan <rkaliapp@qti.qualcomm.com>
Date: Wed, 30 Jul 2025 09:45:38 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Fix incorrect iface removal
 during reload_config for MLD AP

Currently, reload_config used iface name matching to remove interfaces,
In MLO AP setups where the same interface name is shared across links,
which leads to incorrect removal such as the 6GHz interface being
removed while reloading the configuration for the 2GHz link.

Example setup:
  iface[0]->bss[0] => wlan0.0 => 6GHz
  iface[1]->bss[0] => wlan0.0 => 5GHz
  iface[2]->bss[0] => wlan0.0 => 2GHz

The fix is to directly remove hapd->iface instead of searching iface by name.

Patch-dependency: none
Patch-work: none

Signed-off-by: Ramasamy Kaliappan <rkaliapp@qti.qualcomm.com>
---
 src/ap/hostapd.c | 38 +++++++++++++++++++++++++++++++++++++-
 src/ap/hostapd.h |  1 +
 2 files changed, 38 insertions(+), 1 deletion(-)

--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -439,7 +439,13 @@ int hostapd_reload_config(struct hostapd
 			hostapd_config_free(newconf);
 			return -1;
 		}
-		hostapd_remove_iface(interfaces, hapd->conf->iface);
+
+		if (hostapd_remove_hapd_iface(iface) != 0) {
+			os_free(fname);
+			hostapd_config_free(newconf);
+			return -1;
+		}
+
 		iface = hostapd_init(interfaces, fname);
 		os_free(fname);
 		hostapd_config_free(newconf);
@@ -4947,10 +4953,48 @@ int hostapd_remove_bss(struct hostapd_if
 }
 
 
+int hostapd_remove_hapd_iface(struct hostapd_iface *hapd_iface)
+{
+	struct hapd_interfaces *interfaces;
+	size_t i;
+
+	if (hapd_iface == NULL)
+		return -1;
+
+	hapd_iface->driver_ap_teardown =
+		!!(hapd_iface->drv_flags &
+				WPA_DRIVER_FLAGS_AP_TEARDOWN_SUPPORT);
+
+	interfaces = hapd_iface->interfaces;
+	for (i = 0; i < interfaces->count; i++) {
+
+		if (interfaces->iface[i] == hapd_iface)
+			break;
+	}
+
+	if (i >= interfaces->count)
+		return -1;
+
+	hostapd_interface_deinit_free(hapd_iface);
+
+	while (i < (interfaces->count - 1)) {
+		interfaces->iface[i] =
+			interfaces->iface[i + 1];
+		i++;
+	}
+	interfaces->count--;
+
+#ifdef CONFIG_IEEE80211BE
+	hostapd_cleanup_unused_mlds(interfaces);
+#endif /* CONFIG_IEEE80211BE */
+	return 0;
+}
+
+
 int hostapd_remove_iface(struct hapd_interfaces *interfaces, char *buf)
 {
 	struct hostapd_iface *hapd_iface;
-	size_t i, j, k = 0;
+	size_t i, j;
 
 	for (i = 0; i < interfaces->count; i++) {
 		hapd_iface = interfaces->iface[i];
@@ -4959,20 +5003,7 @@ int hostapd_remove_iface(struct hapd_int
 		if (!os_strcmp(hapd_iface->phy, buf) ||
 		    !os_strcmp(hapd_iface->conf->bss[0]->iface, buf)) {
 			wpa_printf(MSG_INFO, "Remove interface '%s'", buf);
-			hapd_iface->driver_ap_teardown =
-				!!(hapd_iface->drv_flags &
-				   WPA_DRIVER_FLAGS_AP_TEARDOWN_SUPPORT);
-
-			hostapd_interface_deinit_free(hapd_iface);
-			k = i;
-			while (k < (interfaces->count - 1)) {
-				interfaces->iface[k] =
-					interfaces->iface[k + 1];
-				k++;
-			}
-			interfaces->count--;
-			hostapd_cleanup_unused_mlds(interfaces);
-
+			hostapd_remove_hapd_iface(hapd_iface);
 			return 0;
 		}
 
--- a/src/ap/hostapd.h
+++ b/src/ap/hostapd.h
@@ -963,6 +963,7 @@ void hostapd_bss_deinit_no_free(struct h
 void hostapd_free_hapd_data(struct hostapd_data *hapd);
 void hostapd_cleanup_iface_partial(struct hostapd_iface *iface);
 int hostapd_add_iface(struct hapd_interfaces *ifaces, char *buf);
+int hostapd_remove_hapd_iface(struct hostapd_iface *hapd_iface);
 int hostapd_remove_iface(struct hapd_interfaces *ifaces, char *buf);
 void hostapd_channel_list_updated(struct hostapd_iface *iface, int initiator);
 void hostapd_set_state(struct hostapd_iface *iface, enum hostapd_iface_state s);
