From 6e68d0193eb5050bf7eb39e9e01d3fe28118b135 Mon Sep 17 00:00:00 2001
From: Santhosh Ramesh <santrame@qti.qualcomm.com>
Date: Mon, 23 Jun 2025 13:40:05 +0530
Subject: [PATCH] QSDK:PROTOCOL:hostapd: Fix crash in Access-Accept
 attribute handling

Fix a segmentation fault in the RADIUS server's EAP Access-Accept
path by correcting the handling of sess->accept_attr.

sess->accept_attr is a flat array of radius_accept_attr entries
returned by radius_server_copy_attr(), but the original implementation
incorrectly treats it as a linked list of hostapd_radius_attr. This
mismatch leads to invalid memory access when dereferencing attr->val.

Update the loop to correctly iterate over the radius_accept_attr array
using a null-terminated check on attr->data. This ensures safe access
and prevents crashes when processing malformed or incomplete attribute
lists introduced by OpenWrt-specific patches.

Patch-dependency: 770-radius_server.patch

Patch-work: None

Signed-off-by: Santhosh Ramesh <santrame@qti.qualcomm.com>
---
 src/radius/radius_server.c | 9 ++++-----
 1 file changed, 4 insertions(+), 5 deletions(-)

diff --git a/src/radius/radius_server.c b/src/radius/radius_server.c
index 59226a8..47ddd5e 100644
--- a/src/radius/radius_server.c
+++ b/src/radius/radius_server.c
@@ -960,11 +960,10 @@ radius_server_encapsulate_eap(struct radius_server_data *data,
 	}
 
 	if (code == RADIUS_CODE_ACCESS_ACCEPT) {
-		struct hostapd_radius_attr *attr;
-		for (attr = sess->accept_attr; attr; attr = attr->next) {
-			if (!radius_msg_add_attr(msg, attr->type,
-						 wpabuf_head(attr->val),
-						 wpabuf_len(attr->val))) {
+		struct radius_accept_attr *attr;
+		for (attr = sess->accept_attr; attr->data; attr++) {
+			if (!radius_msg_add_attr(msg, attr->type, attr->data,
+						 attr->len)) {
 				wpa_printf(MSG_ERROR, "Could not add RADIUS attribute");
 				radius_msg_free(msg);
 				return NULL;
-- 
