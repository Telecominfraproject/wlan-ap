 int hostapd_send_ttlm_teardown(struct hostapd_data *hapd, struct sta_info *sta);
 int hostapd_handle_ttlm_teardown(struct hostapd_data *hapd, struct sta_info *sta,
 				 const u8 *buf, size_t len);
-
