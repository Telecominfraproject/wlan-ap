From d5075a6834078cbd0a8f068a96582e59bbca00ba Mon Sep 17 00:00:00 2001
From: Shwetha G K <kshwetha@qti.qualcomm.com>
Date: Wed, 10 Sep 2025 10:37:25 +0530
Subject: [PATCH] UPSTREAM: PROTOCOL: hostapd: Fix NULL pointer dereferece in
 advertised TTLM

Fix the NULL pointer dereference issues in advertised TTLM.

Signed-off-by: Shwetha G K <kshwetha@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c | 13 +++++++++++--
 src/ap/ieee802_11.c  |  2 +-
 src/ap/ttlm.c        |  4 ++--
 3 files changed, 14 insertions(+), 5 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index c4205bd..1954d3e 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -5422,8 +5422,8 @@ static int hostapd_ctrl_iface_conf_ml_rec_links(struct hostapd_data *hapd,
 
 int hostapd_ctrl_iface_advertise_ttlm(struct hostapd_data *hapd, const char *cmd)
 {
-	struct mlo_ttlm_ie *ttlm_conf = os_zalloc(sizeof(struct mlo_ttlm_ie));
-	struct ttlm_info *ttlm = &ttlm_conf->ttlm;
+	struct mlo_ttlm_ie *ttlm_conf;
+	struct ttlm_info *ttlm;
 	struct hostapd_data *link_bss;
 	u16 removal_links = 0;
 	u16 ieee_link_map;
@@ -5431,6 +5431,7 @@ int hostapd_ctrl_iface_advertise_ttlm(struct hostapd_data *hapd, const char *cmd
 	int ret;
 	u8 i;
 
+
 	if (!hapd->conf->ttlm_enable) {
 		wpa_printf(MSG_ERROR, "TTLM support is not enabled");
 		return -1;
@@ -5446,6 +5447,14 @@ int hostapd_ctrl_iface_advertise_ttlm(struct hostapd_data *hapd, const char *cmd
 		return 0;
 	}
 
+	ttlm_conf = os_zalloc(sizeof(struct mlo_ttlm_ie));
+	if (!ttlm_conf) {
+		wpa_printf(MSG_ERROR, "TTLM failed to allocate ttlm_conf");
+		return -1;
+	}
+
+	ttlm = &ttlm_conf->ttlm;
+
 	pos = os_strstr(cmd, "ieee_link_map=");
 	if (!pos)
 		return -1;
diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index 24f15bf..4c74aff 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -5712,7 +5712,7 @@ rsnxe_done:
 		hostapd_get_epcs_capab(hapd, sta);
 	}
 
-	if (hapd->conf->ttlm_enable &&
+	if (hapd->conf->ttlm_enable && sta &&
 	    sta->mld_info.tid_map_info.ttlm_ongoing_negotiation_info.ttlm_resp_type ==
 	    WLAN_STATUS_SUCCESS)
 		hostapd_apply_ttlm_mapping_to_driver(hapd, sta);
diff --git a/src/ap/ttlm.c b/src/ap/ttlm.c
index 466ab59..82acc25 100644
--- a/src/ap/ttlm.c
+++ b/src/ap/ttlm.c
@@ -61,7 +61,7 @@ u8 *hostapd_add_ttlm_info_elem(u8 *pos, struct ttlm_info *ttlm, struct hostapd_d
 	u16 ttlm_control = 0;
 	u16 *ttlm_control_field;
 
-	if (ttlm->mapping_switch_time_present && !hapd->mapping_switch_time) {
+	if (ttlm->mapping_switch_time_present && hapd && !hapd->mapping_switch_time) {
 		wpa_printf(MSG_DEBUG, "TTLM MST TSF update not received. Skip adding TTLM IE");
 		return pos;
 	}
@@ -1274,7 +1274,7 @@ void hostapd_handle_ttlm_req(struct hostapd_data *hapd, struct sta_info *sta,
 	const struct ieee80211_mgmt *mgmt = (const struct ieee80211_mgmt *) buf;
 	struct ttlm_ongoing_negotiation_info *ongoing_ttlm, *configured_ttlm;
 	struct ieee802_11_elems elems;
-	struct ttlm_info ttlm_info;
+	struct ttlm_info ttlm_info = {};
 	bool homogeneous_map;
 	enum ttlm_dir dir;
 	const u8 *pos;
-- 
2.34.1

