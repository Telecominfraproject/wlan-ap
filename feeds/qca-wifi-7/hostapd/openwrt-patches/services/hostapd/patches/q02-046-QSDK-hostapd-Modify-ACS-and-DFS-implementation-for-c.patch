From 92fe5e25ad81ff0cf80295db931775956372c84f Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Thu, 24 Jul 2025 15:04:08 +0530
Subject: [PATCH] QSDK:hostapd: Modify ACS and DFS implementation for channel
 parameters

Modify the ACS and DFS Implementaion as below:

1. Add conf->ieee80211be support.
2. Add support to input both ACS_BW320_1 and ACS_BW320_2 bandwidth types and
   their center frequencies.
3. Modify the API acs_get_bw_start_chan take chan as function parameter instead
   of just frequency.
4. Add support in API acs_find_ideal_chan_mode to consider the puncture bitmap
   as part of the ideal channel parameters.

Signed-off-by: Karthik M <karm@qti.qualcomm.com>
Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Signed-off-by: Venkateswara Swamy Bandaru <vbandaru@qti.qualcomm.com>
---
 src/ap/acs.c | 32 ++++++++++++++++++++++----------
 src/ap/dfs.c |  6 ++++--
 2 files changed, 26 insertions(+), 12 deletions(-)

diff --git a/src/ap/acs.c b/src/ap/acs.c
index cdf0712..53fa21b 100644
--- a/src/ap/acs.c
+++ b/src/ap/acs.c
@@ -468,10 +468,11 @@ static int acs_get_bw_center_chan(int freq, enum bw_type bw)
 	return 0;
 }
 
-static int *acs_get_bw_start_chan(u32 bw, int freq, int *result_size)
+static int *acs_get_bw_start_chan(u32 bw, struct hostapd_channel_data *chan,
+				  int *result_size)
 {
 	int *freq_start_list = NULL;
-	enum bw_type bandwidth_type;
+	enum bw_type bandwidth_type = ACS_BW40;
 	*result_size = 0;
 
 	switch (bw) {
@@ -485,7 +486,10 @@ static int *acs_get_bw_start_chan(u32 bw, int freq, int *result_size)
 		bandwidth_type = ACS_BW160;
 		break;
 	case 320:
-		bandwidth_type = ACS_BW320_1;
+		if (acs_usable_bw_chan(chan, ACS_BW320_1))
+			bandwidth_type = ACS_BW320_1;
+		else if (acs_usable_bw_chan(chan, ACS_BW320_2))
+			bandwidth_type = ACS_BW320_2;
 		break;
 	default:
 		wpa_printf(MSG_INFO,
@@ -494,8 +498,8 @@ static int *acs_get_bw_start_chan(u32 bw, int freq, int *result_size)
 	}
 
 	for (int i = 0; bw_desc[bandwidth_type][i].first != -1; ++i) {
-		if (freq >= bw_desc[bandwidth_type][i].first &&
-		    freq <= bw_desc[bandwidth_type][i].last) {
+		if (chan->freq >= bw_desc[bandwidth_type][i].first &&
+		    chan->freq <= bw_desc[bandwidth_type][i].last) {
 			freq_start_list = os_realloc(freq_start_list,
 						     (*result_size + 1) * sizeof(int));
 			if (!freq_start_list) {
@@ -901,7 +905,7 @@ acs_find_6g_psc_chan_mode(struct hostapd_iface *iface,
 			continue;
 		}
 
-		start_freq_list =  acs_get_bw_start_chan(bw, chan->freq,
+		start_freq_list =  acs_get_bw_start_chan(bw, chan,
 							 &freq_match_size);
 		for (int i = 0; i < freq_match_size; i++) {
 			factor = 0;
@@ -1099,7 +1103,7 @@ acs_find_ideal_chan_mode(struct hostapd_iface *iface,
 				continue;
 		}
 
-		start_freq_list =  acs_get_bw_start_chan(bw, chan->freq,
+		start_freq_list =  acs_get_bw_start_chan(bw, chan,
 							 &freq_match_size);
 		for (int i = 0; i < freq_match_size; i++) {
 			factor = 0;
@@ -1233,6 +1237,7 @@ acs_find_ideal_chan_mode(struct hostapd_iface *iface,
 				*ideal_factor = factor;
 				*ideal_chan = chan;
 				ideal_bw320_offset = bw320_offset;
+				(*ideal_chan)->punct_bitmap = iface->conf->punct_bitmap;
 				index_primary = (chan->freq - start_freq_list[i]) / 20;
 
 #ifdef CONFIG_IEEE80211BE
@@ -1367,9 +1372,10 @@ static void acs_adjust_secondary(struct hostapd_iface *iface)
 }
 
 
-static void acs_adjust_center_freq(struct hostapd_iface *iface)
+static void acs_adjust_center_freq(struct hostapd_iface *iface,
+				   struct hostapd_channel_data *chan)
 {
-	int center;
+	int center = 0;
 
 	wpa_printf(MSG_DEBUG, "ACS: Adjusting center frequency");
 
@@ -1392,6 +1398,12 @@ static void acs_adjust_center_freq(struct hostapd_iface *iface)
 		break;
 	case CONF_OPER_CHWIDTH_320MHZ:
 		switch (hostapd_get_bw320_offset(iface->conf)) {
+		case 0:
+			if (acs_usable_bw_chan(chan, ACS_BW320_1))
+				center = acs_get_bw_center_chan(iface->freq, ACS_BW320_1);
+			else if (acs_usable_bw_chan(chan, ACS_BW320_2))
+				center = acs_get_bw_center_chan(iface->freq, ACS_BW320_2);
+			break;
 		case 1:
 			center = acs_get_bw_center_chan(iface->freq,
 							ACS_BW320_1);
@@ -1477,7 +1489,7 @@ static void acs_study(struct hostapd_iface *iface)
 	if (iface->conf->ieee80211ac || iface->conf->ieee80211ax ||
 	    iface->conf->ieee80211be) {
 		acs_adjust_secondary(iface);
-		acs_adjust_center_freq(iface);
+		acs_adjust_center_freq(iface, ideal_chan);
 	}
 
 	err = hostapd_select_hw_mode(iface);
diff --git a/src/ap/dfs.c b/src/ap/dfs.c
index ae1adf4..b93c305 100644
--- a/src/ap/dfs.c
+++ b/src/ap/dfs.c
@@ -51,7 +51,8 @@ static int dfs_get_used_n_chans(struct hostapd_iface *iface, int *seg1)
 	if (iface->conf->ieee80211n && iface->conf->secondary_channel)
 		n_chans = 2;
 
-	if (iface->conf->ieee80211ac || iface->conf->ieee80211ax) {
+	if (iface->conf->ieee80211ac || iface->conf->ieee80211ax ||
+	    iface->conf->ieee80211be) {
 		switch (hostapd_get_oper_chwidth(iface->conf)) {
 		case CONF_OPER_CHWIDTH_USE_HT:
 			break;
@@ -381,7 +382,8 @@ static void dfs_adjust_center_freq(struct hostapd_iface *iface,
 				   u8 *oper_centr_freq_seg0_idx,
 				   u8 *oper_centr_freq_seg1_idx)
 {
-	if (!iface->conf->ieee80211ac && !iface->conf->ieee80211ax)
+	if (!iface->conf->ieee80211ac && !iface->conf->ieee80211ax &&
+	    !iface->conf->ieee80211be)
 		return;
 
 	if (!chan)
-- 
2.34.1

