From 318e00f8c9a4e6627bd44afc289da2d683da3309 Mon Sep 17 00:00:00 2001
From: Karthik <quic_karm@quicinc.com>
Date: Tue, 26 Nov 2024 15:59:07 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: Hostapd: Fix auto channel hostapd crash

AP is configured with auto channel in 2 GHz and 5 GHz bandwidth
is more 20 MHz, Hostapd crashes due to the NULL pointer access in
hostapd_event_get_survey().

The ACS is activated for the 2.4 GHz band, initiating a scan with a 20-second
timeout. The 2.4 GHz band updates the scan context accordingly.
When the 5 GHz band is initialized, an HT40 scan is attempted due to the
bandwidth exceeding 20 MHz. However, the driver returns a "Resource busy"
message because of the ongoing ACS scan. An HT40 scan starts an eloop
timer for a retry. The HT40 scan retry timer is triggered, and in the meantime,
ACS scan results for the 2 GHz band are received. The HT40 scan is then
prioritized, and the driver initiates a scan, updating the scan context
for the 5 GHz band.

When the ACS event survey is processed, it uses the updated scan context.
During the survey event processing, the scan callback for the partner
link (2.4 GHz ACS) is handled, which leads to a crash.

Fix by intiating the HT scan after the ACS triggered scan is completed.

Patch-depdendency: None

Patch-work: None

Feature: SCAN

Signed-off-by: Karthik <quic_karm@quicinc.com>
---
 src/ap/hw_features.c | 30 ++++++++++++++++++++++++++++--
 1 file changed, 28 insertions(+), 2 deletions(-)

--- a/src/ap/ap_drv_ops.c
+++ b/src/ap/ap_drv_ops.c
@@ -25,6 +25,7 @@
 #ifdef CONFIG_IEEE80211BE
 #include "scs.h"
 #include "common/qca-vendor.h"
+#include "hw_features.h"
 #endif
 
 u32 hostapd_sta_flags_to_drv(u32 flags)
@@ -883,6 +884,29 @@ int hostapd_driver_scan(struct hostapd_d
 #ifdef CONFIG_IEEE80211BE
 	if (hapd->conf->mld_ap)
 		params->link_id = hapd->mld_link_id;
+
+	if (!hapd->iface->scan_cb && hapd->conf->mld_ap) {
+		/* Other links may be waiting for Scan result */
+		unsigned int i;
+
+		for (i = 0; i < hapd->iface->interfaces->count; i++) {
+			struct hostapd_iface *h =
+				hapd->iface->interfaces->iface[i];
+			struct hostapd_data *h_hapd = h->bss[0];
+
+			if (h == hapd->iface)
+				continue;
+
+			if (hostapd_is_ml_partner(hapd, h_hapd) &&
+			    (h_hapd->iface->state == HAPD_IFACE_ACS ||
+			     h_hapd->iface->state == HAPD_IFACE_HT_SCAN) &&
+			     h_hapd->iface->scan_cb) {
+				wpa_printf(MSG_ERROR,
+					   "Scan in Progress in Partner link - try to scan again");
+				return -EBUSY;
+			}
+		}
+	}
 #endif /* CONFIG_IEEE80211BE */
 
 	if (hapd->driver && hapd->driver->scan2)
--- a/src/ap/hw_features.c
+++ b/src/ap/hw_features.c
@@ -543,7 +543,7 @@ static void ap_ht40_scan_retry(void *elo
 		wpa_printf(MSG_ERROR,
 			   "Failed to request a scan of neighboring BSSes ret=%d (%s) - try to scan again (attempt %d)",
 			   ret, strerror(-ret), iface->num_ht40_scan_tries);
-		eloop_register_timeout(1, 0, ap_ht40_scan_retry, iface, NULL);
+		eloop_register_timeout(5, 0, ap_ht40_scan_retry, iface, NULL);
 		return;
 	}
 
@@ -555,6 +555,9 @@ static void ap_ht40_scan_retry(void *elo
 
 	wpa_printf(MSG_DEBUG,
 		   "Failed to request a scan in device, bringing up in HT20 mode");
+	hostapd_set_oper_centr_freq_seg0_idx(iface->conf, 0);
+	hostapd_set_oper_centr_freq_seg1_idx(iface->conf, 0);
+	hostapd_set_oper_chwidth(iface->conf, CONF_OPER_CHWIDTH_USE_HT);
 	iface->conf->secondary_channel = 0;
 	iface->conf->ht_capab &= ~HT_CAP_INFO_SUPP_CHANNEL_WIDTH_SET;
 	hostapd_setup_interface_complete(iface, 0);
