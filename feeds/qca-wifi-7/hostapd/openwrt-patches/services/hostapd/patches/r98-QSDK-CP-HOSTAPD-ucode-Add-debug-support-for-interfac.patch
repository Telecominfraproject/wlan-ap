From 6e19765ca05816a625a0fac213fa7c4dc94f9cb5 Mon Sep 17 00:00:00 2001
From: Vignesh C <vignc@qti.qualcomm.com>
Date: Sun, 6 Apr 2025 20:13:09 +0530
Subject: [PATCH] QSDK:CP:HOSTAPD:ucode Add debug support for interface start
 and stop operations

Add debug support for interface start and stop operations in hostapd.
Include return value handling for beacon deletion in stop_ap.

Patch-dependency:
	r50-01-wifi-hostapd-ucode-hostapd-pass-radio_id-ref.patch

Signed-off-by: Vignesh C <vignc@qti.qualcomm.com>
---
 src/ap/ucode.c               | 38 ++++++++++++++++++++----------------
 src/drivers/driver_nl80211.c |  6 +++++-
 2 files changed, 26 insertions(+), 18 deletions(-)

--- a/src/ap/ucode.c
+++ b/src/ap/ucode.c
@@ -591,7 +591,7 @@ uc_hostapd_iface_start(uc_vm_t *vm, size
 	struct hostapd_config *conf;
 	bool changed = false;
 	uint64_t intval;
-	int i;
+	int i, ret;
 
 	if (!iface)
 		return NULL;
@@ -699,22 +699,26 @@ out:
 
 		hapd->conf->start_disabled = 0;
 
-		hostapd_set_freq(hapd, conf->hw_mode, iface->freq,
-				 conf->channel,
-				 conf->enable_edmg,
-				 conf->edmg_channel,
-				 conf->ieee80211n,
-				 conf->ieee80211ac,
-				 conf->ieee80211ax,
-				 conf->ieee80211be,
-				 conf->secondary_channel,
-				 hostapd_get_oper_chwidth(conf),
-				 hostapd_get_oper_centr_freq_seg0_idx(conf),
-				 hostapd_get_oper_centr_freq_seg1_idx(conf),
-				 conf->bandwidth_device,
-				 conf->center_freq_device);
-
-		ieee802_11_set_beacon(hapd);
+		ret = hostapd_set_freq(hapd, conf->hw_mode, iface->freq,
+				       conf->channel,
+				       conf->enable_edmg,
+				       conf->edmg_channel,
+				       conf->ieee80211n,
+				       conf->ieee80211ac,
+				       conf->ieee80211ax,
+				       conf->ieee80211be,
+				       conf->secondary_channel,
+				       hostapd_get_oper_chwidth(conf),
+				       hostapd_get_oper_centr_freq_seg0_idx(conf),
+				       hostapd_get_oper_centr_freq_seg1_idx(conf),
+				       conf->bandwidth_device,
+				       conf->center_freq_device);
+
+		wpa_printf(MSG_INFO, "set_freq called for bssid " MACSTR " ret %d ifname %s\n",
+			   MAC2STR(hapd->own_addr), ret, hapd->conf->iface);
+		ret = ieee802_11_set_beacon(hapd);
+		wpa_printf(MSG_DEBUG, "set beacon called for bssid " MACSTR " ret %d \n",
+			   MAC2STR(hapd->own_addr), ret);
 	}
 
 	return ucv_boolean_new(true);
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -10384,6 +10384,7 @@ static int wpa_driver_nl80211_stop_ap(vo
 {
 	struct i802_bss *bss = priv;
 	struct wpa_driver_nl80211_data *drv = bss->drv;
+	int ret;
 
 	if (!is_ap_interface(drv->nlmode))
 		return -1;
@@ -10394,7 +10395,10 @@ static int wpa_driver_nl80211_stop_ap(vo
 	}
 
 	if (nl80211_link_valid(bss->valid_links, link_id)) {
-		wpa_driver_nl80211_del_beacon(bss, link_id);
+		ret = wpa_driver_nl80211_del_beacon(bss, link_id);
+		if (ret)
+			wpa_printf(MSG_ERROR, "nl80211: failed to del_beacon for (ifindex=%d) link_id %d\n",
+				   bss->ifindex, link_id);
 		return 0;
 	}
 
