From a8e457fbb8aee47ca6a0dcb9e9256a5ee7eca047 Mon Sep 17 00:00:00 2001
From: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
Date: Mon, 6 Oct 2025 12:41:20 -0700
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd:MSCS:Handle MSCS add failure during
 assoc

Ensure the AP correctly handles MSCS ADD request failures sent by the STA
during association.
If the ADD operation fails, the mscs_ctxt will be cleared and freed.
Therefore, do not update mscs_ctxt while sending the association response
to avoid referencing invalid memory.

Patch-dependency:
s011-UPSTREAM-PROTOCOL-hostapd-MSCS-Add-support-to-send-h.patch
Patch-work: NA
Tag: MSCS

Fixes: ccb76b371843 ("Add MSCS in assoc and add cli support for MSCS")

Signed-off-by: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
---
 src/ap/robust_av.c | 16 +++++++++++-----
 1 file changed, 11 insertions(+), 5 deletions(-)

diff --git a/src/ap/robust_av.c b/src/ap/robust_av.c
index 3eb8db9ee1d2..ea9c17a17f1c 100644
--- a/src/ap/robust_av.c
+++ b/src/ap/robust_av.c
@@ -1429,10 +1429,11 @@ int hostapd_process_mscs_req(struct hostapd_data *hapd,
 		if (ret == HOSTAPD_QM_STATUS_SUCCESS)
 			sta->mscs_session_exists = true;
 		else if (req_type == QM_ADD_REQ) {
-			if (!sta->mscs_ctxt)
-				goto decline;
-			os_free(sta->mscs_ctxt);
-			sta->mscs_ctxt = NULL;
+			if (sta->mscs_ctxt) {
+				os_free(sta->mscs_ctxt);
+				sta->mscs_ctxt = NULL;
+			}
+			goto decline;
 		}
 		break;
 	case QM_REMOVE_REQ:
@@ -1627,7 +1628,12 @@ int hostapd_handle_mscs_ie_assoc(struct hostapd_data *hapd,
 
 	ret = hostapd_process_mscs_req(hapd, sta, payload, &mscs, 0);
 
-	sta->mscs_ctxt->assoc_req_status = ret;
+	/**
+	 * Fill the MSCS descriptor in response, only when an
+	 * MSCS context is present
+	 */
+	if (sta->mscs_ctxt)
+		sta->mscs_ctxt->assoc_req_status = ret;
 	return 0;
 
 }
