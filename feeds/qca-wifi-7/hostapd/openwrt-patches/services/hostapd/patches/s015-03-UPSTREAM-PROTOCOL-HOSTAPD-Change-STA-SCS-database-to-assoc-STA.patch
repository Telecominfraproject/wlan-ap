From 3824f20328403d0d52d6d41219321e58b5e35fbd Mon Sep 17 00:00:00 2001
From: Arun Vikas T <vikast@qti.qualcomm.com>
Date: Fri, 26 Sep 2025 16:09:32 +0530
Subject: [PATCH 3/3] UPSTREAM:PROTOCOL:HOSTAPD: Change STA SCS database to
 assoc STA

- Update SCS request handler to resolve associated STA and hostapd
  context for both MLD and non-MLD STAs
- Refactor function signatures to remove redundant STA arguments
- Use assoc_sta for storing SCS database such that SCS request
  from any MLO link can add/delete/update the SCS ID info.

The change is required to handle SCS requests in multi-link
scenario correctly.

r92-04-UPSTREAM-PROTOCOL-CP-HOSTAPD-Add-support-for-SCS-req-parsing.patch
r92-05-UPSTREAM-PROTOCOL-CP-HOSTAPD-Copy-and-send-SCS-data-over-QM.patch
r92-06-UPSTREAM-PROTOCOL-CP-HOSTAPD-Handle-SCS-response-from-driver.patch

Tag: SCS

Signed-off-by: Arun Vikas T <vikast@qti.qualcomm.com>
---
 src/ap/robust_av.c | 42 +++++++++++++++++++++++++++++++-----------
 1 file changed, 31 insertions(+), 11 deletions(-)

diff --git a/src/ap/robust_av.c b/src/ap/robust_av.c
index d489f7b..51cbc76 100644
--- a/src/ap/robust_av.c
+++ b/src/ap/robust_av.c
@@ -8,6 +8,7 @@
 #include "common/ieee802_11_common.h"
 #include "hostapd.h"
 #include "robust_av.h"
+#include "ieee802_11.h"
 #include "sta_info.h"
 #include "ap_drv_ops.h"
 #include <linux/netfilter.h>
@@ -711,8 +712,7 @@ fail:
 
 
 static int hostapd_parse_scs_desc(
-		struct hostapd_data *hapd, const u8 *payload,
-		struct sta_info *sta,
+		const u8 *payload, struct sta_info *sta,
 		struct hostapd_scs_req_desc_data *scs_req_desc, u8 len)
 {
 	int ret = WLAN_STATUS_REQUEST_DECLINED;
@@ -1007,7 +1007,7 @@ static void hostapd_copy_scs_resp(struct hostapd_scs_resp_data *scs_resp,
 
 
 static int
-hostapd_copy_and_send_scs_data(struct hostapd_data *hapd, struct sta_info *sta,
+hostapd_copy_and_send_scs_data(struct hostapd_data *hapd,
 			       struct hostapd_scs_req_data *scs_req,
 			       struct hostapd_scs_resp_data *scs_resp)
 {
@@ -1589,8 +1589,7 @@ static void hostapd_update_scs_resp_err(struct hostapd_scs_req_data *scs_req,
 }
 
 
-static int hostapd_send_scs_response(struct hostapd_data *hapd,
-				     struct sta_info *sta, const u8 *da,
+static int hostapd_send_scs_response(struct hostapd_data *hapd, const u8 *da,
 				     struct hostapd_scs_resp_data *scs_resp)
 {
 	u8 scs_id, dialog_token, num_scs_desc, status;
@@ -1999,7 +1998,9 @@ static int hostapd_handle_scs_req(struct hostapd_data *hapd, const u8 *buf,
 	struct hostapd_scs_resp_data scs_resp = {0};
 	struct hostapd_scs_req_data scs_req = {0};
 	const u8 *payload, *payload_start;
-	struct sta_info *sta;
+	struct sta_info *assoc_sta = NULL;
+	struct hostapd_data *assoc_hapd;
+	struct sta_info *sta = NULL;
 	u8 elem_id, elem_len;
 	u8 index = 0;
 	int ret = 0;
@@ -2019,6 +2020,25 @@ static int hostapd_handle_scs_req(struct hostapd_data *hapd, const u8 *buf,
 		return -1;
 	}
 
+#ifdef CONFIG_IEEE80211BE
+	if (!sta->mld_info.mld_sta) {
+		wpa_printf(MSG_DEBUG,
+			   "Assign sta to assoc_sta for Non-MLD STA");
+		assoc_sta = sta;
+	}
+#endif
+
+	assoc_hapd = hapd;
+
+	if (!assoc_sta) {
+		assoc_sta = hostapd_ml_get_assoc_sta(hapd, sta, &assoc_hapd);
+		if (!assoc_sta) {
+			wpa_printf(MSG_DEBUG,
+				   "Assoc STA not found in scs_req handler");
+			return -1;
+		}
+	}
+
 	os_memcpy(scs_req.peer_mac, mgmt->sa, ETH_ALEN);
 
 	scs_req.dialog_token = mgmt->u.action.u.robust_av_req.dialog_token;
@@ -2028,7 +2048,7 @@ static int hostapd_handle_scs_req(struct hostapd_data *hapd, const u8 *buf,
 	wpa_printf(MSG_MSGDUMP, "Frame length:%zu, Dialog_token:%u",
 		   frame_length, scs_req.dialog_token);
 	wpa_printf(MSG_DEBUG, "Active SCS session count:%u",
-		   sta->scs_session_count);
+		   assoc_sta->scs_session_count);
 
 	while (frame_length > 0) {
 		payload = payload_start;
@@ -2046,7 +2066,7 @@ static int hostapd_handle_scs_req(struct hostapd_data *hapd, const u8 *buf,
 		elem_len = *payload++;
 		scs_id = *payload;
 
-		ret = hostapd_parse_scs_desc(hapd, payload, sta,
+		ret = hostapd_parse_scs_desc(payload, assoc_sta,
 					     &scs_req.scs_req_desc[index],
 					     elem_len);
 		if (ret != HOSTAPD_QM_STATUS_SUCCESS) {
@@ -2063,17 +2083,17 @@ static int hostapd_handle_scs_req(struct hostapd_data *hapd, const u8 *buf,
 
 	scs_req.num_scs_desc = index;
 
-	ret = hostapd_copy_and_send_scs_data(hapd, sta, &scs_req, &scs_resp);
+	ret = hostapd_copy_and_send_scs_data(assoc_hapd, &scs_req, &scs_resp);
 	if (ret) {
 		wpa_printf(MSG_ERROR, "Send SCS data failed, ret:%d", ret);
 		hostapd_update_scs_resp_err(&scs_req, &scs_resp);
 		goto send_error_resp;
 	}
 
-	hostapd_process_scs_req(hapd, sta, &scs_req, &scs_resp);
+	hostapd_process_scs_req(assoc_hapd, assoc_sta, &scs_req, &scs_resp);
 
 send_error_resp:
-	ret = hostapd_send_scs_response(hapd, sta, mgmt->sa, &scs_resp);
+	ret = hostapd_send_scs_response(hapd, mgmt->sa, &scs_resp);
 	if (ret)
 		wpa_printf(MSG_ERROR, "SCS response frame send failed, ret:%d",
 			   ret);
-- 
