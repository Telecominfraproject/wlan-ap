From 34775e4166ee0dd23df3c4a0008f44b59c62d008 Mon Sep 17 00:00:00 2001
From: Abhinav Raghunandan <abhiragh@qti.qualcomm.com>
Date: Tue, 9 Sep 2025 13:04:17 +0530
Subject: [PATCH] Advertise Channel Usage element in Beaconing and Association
 Response frames

Using the stored Channel Usage configuration in the hostapd data
structure, construct the Channel Usage element(s) and advertise it
in the Beaconing and Association Response frames.

Signed-off-by: Abhinav Raghunandan <abhiragh@qti.qualcomm.com>
---
 src/ap/beacon.c            |  5 +++
 src/ap/ieee802_11.c        |  5 +++
 src/ap/ieee802_11.h        |  3 ++
 src/ap/ieee802_11_shared.c | 68 ++++++++++++++++++++++++++++++++++++++
 4 files changed, 81 insertions(+)

diff --git a/src/ap/beacon.c b/src/ap/beacon.c
index e192ec2..3da8262 100644
--- a/src/ap/beacon.c
+++ b/src/ap/beacon.c
@@ -2466,6 +2466,10 @@ int ieee802_11_build_ap_params(struct hostapd_data *hapd,
 	if (hapd->iconf->ieee80211be && !hapd->conf->disable_11be) {
 		tail_len += hostapd_eid_eht_capab_len(hapd, IEEE80211_MODE_AP);
 		tail_len += 3 + sizeof(struct ieee80211_eht_operation);
+
+		/* Add space in beacon tail for Channel Usage element */
+		tail_len += hostapd_eid_channel_usage_len(hapd);
+
 		if (hapd->iconf->punct_bitmap)
 			tail_len += EHT_OPER_DISABLED_SUBCHAN_BITMAP_SIZE;
 
@@ -2732,6 +2736,7 @@ int ieee802_11_build_ap_params(struct hostapd_data *hapd,
 						IEEE80211_MODE_AP);
 		startpos = tailpos;
 		tailpos = hostapd_eid_eht_operation(hapd, tailpos);
+		tailpos = hostapd_eid_channel_usage(hapd, tailpos, tailend - tailpos);
 		if (hapd == tx_bss)
 			hostapd_eid_update_cu_info(hapd, &elemid_modified, startpos,
 						   tailpos-startpos, ELEMID_CU_PARAM_EXT_EHTOP);
