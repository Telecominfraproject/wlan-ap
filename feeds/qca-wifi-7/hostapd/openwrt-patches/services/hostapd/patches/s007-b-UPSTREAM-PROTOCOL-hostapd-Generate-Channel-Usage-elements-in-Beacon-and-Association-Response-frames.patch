+u8 * hostapd_eid_channel_usage(struct hostapd_data *hapd, u8 *eid,
+								size_t limit);
 u8 * hostapd_eid_time_zone(struct hostapd_data *hapd, u8 *eid);
 int hostapd_update_time_adv(struct hostapd_data *hapd);
