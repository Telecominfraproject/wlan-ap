From e654e46373240e686b786abf3b997b8fa1660a8f Mon Sep 17 00:00:00 2001
From: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
Date: Tue, 16 Sep 2025 11:24:35 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: Hostapd:KW: Fix NULL pointer dereference
 and memory leak

Add NULL checks for return from nla_nest_start, to prevent NULL
dereference.

When nla_nest_start fails, the function wpa_driver_nl80211_ml_reconf()
returns without freeing the msg buffer, resulting in a memory leak.
Fix the issue by performing proper cleanup before returning.

Patch-dependency: r93-b-003-UPSTREAM-PROTOCOL-hostap-Extend-NL80211_CMD_ASSOC_ML.patch

Fixes: Ia63a866d669 ('UPSTREAM:PROTOCOL: Aggregate link_sta operations for ML reconfig')

Signed-off-by: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
---
 src/drivers/driver_nl80211.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 9b1ba31..f104652 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -10394,12 +10394,15 @@ static int wpa_driver_nl80211_ml_reconf(void *priv,
 		goto fail;
 
 	links = nla_nest_start(msg, NL80211_ATTR_MLO_LINKS);
+	if (!links)
+		goto fail;
+
 	for_each_link(ml_reconf_req->add_links, link_id) {
 		added_links |= BIT(link_id);
 		struct hostapd_sta_add_params *params;
 		attr = nla_nest_start(msg, 0);
 		if (!attr)
-			return -1;
+			goto fail;
 		params = ml_reconf_req->sta_add_params[link_id];
 		ret = wpa_driver_nl80211_build_sta(drv, msg, params);
 		if (ret) {
-- 
