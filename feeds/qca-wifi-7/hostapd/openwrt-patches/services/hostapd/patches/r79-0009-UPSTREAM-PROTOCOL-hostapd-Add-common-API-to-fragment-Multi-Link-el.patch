From a3ae68aae24bdaa0fb64649deceab5c807221685 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Fri, 16 May 2025 15:43:10 +0530
Subject: [PATCH 09/20] UPSTREAM:PROTOCOL: hostapd: Add common API to fragment
 Multi-Link element

Add common helper API to fragment the Multi-Link elements. Replace the
fragmenting logic in hostapd_eid_eht_basic_ml_common with this new API.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 src/ap/ieee802_11.h     |  1 +
 src/ap/ieee802_11_eht.c | 73 +++++++++++++++++++++++------------------
 2 files changed, 42 insertions(+), 32 deletions(-)

diff --git a/src/ap/ieee802_11.h b/src/ap/ieee802_11.h
index ba3563a..6fc4dfb 100644
--- a/src/ap/ieee802_11.h
+++ b/src/ap/ieee802_11.h
@@ -309,4 +309,5 @@ int hostapd_process_assoc_ml_info(struct hostapd_data *hapd,
 #ifdef CONFIG_IEEE80211BE
 void hostapd_epcs_timeout_handler(void *eloop_ctx, void *timeout_ctx);
 #endif /* CONFIG_IEEE80211BE */
+u8 * hostapd_fragment_multi_link_element(struct wpabuf *buf, u8 *pos);
 #endif /* IEEE802_11_H */
diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index c5b8213..f3117ba 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -763,38 +763,7 @@ static u8 * hostapd_eid_eht_basic_ml_common(struct hostapd_data *hapd,
 
 out:
 	/* Fragment the Multi-Link element, if needed */
-	len = wpabuf_len(buf);
-	ptr = wpabuf_head(buf);
-
-	if (len <= 254)
-		slice_len = len;
-	else
-		slice_len = 254;
-
-	*pos++ = WLAN_EID_EXTENSION;
-	*pos++ = slice_len + 1;
-	*pos++ = WLAN_EID_EXT_MULTI_LINK;
-	os_memcpy(pos, ptr, slice_len);
-
-	ptr += slice_len;
-	pos += slice_len;
-	len -= slice_len;
-
-	while (len) {
-		if (len <= 255)
-			slice_len = len;
-		else
-			slice_len = 255;
-
-		*pos++ = WLAN_EID_FRAGMENT;
-		*pos++ = slice_len;
-		os_memcpy(pos, ptr, slice_len);
-
-		ptr += slice_len;
-		pos += slice_len;
-		len -= slice_len;
-	}
-
+	pos = hostapd_fragment_multi_link_element(buf, pos);
 	wpabuf_free(buf);
 	return pos;
 }
@@ -1688,6 +1657,46 @@ int hostapd_wnm_add_multi_link_sub_elem(struct hostapd_data *hapd,
 #endif /* CONFIG_IEEE80211BE */
 
 
+u8 * hostapd_fragment_multi_link_element(struct wpabuf *buf, u8 *pos)
+{
+	size_t len, slice_len;
+	const u8 *ptr;
+
+	len = wpabuf_len(buf);
+	ptr = wpabuf_head(buf);
+
+	if (len <= 254)
+		slice_len = len;
+	else
+		slice_len = 254;
+
+	*pos++ = WLAN_EID_EXTENSION;
+	*pos++ = slice_len + 1;
+	*pos++ = WLAN_EID_EXT_MULTI_LINK;
+	os_memcpy(pos, ptr, slice_len);
+
+	ptr += slice_len;
+	pos += slice_len;
+	len -= slice_len;
+
+	while (len) {
+		if (len <= 255)
+			slice_len = len;
+		else
+			slice_len = 255;
+
+		*pos++ = WLAN_EID_FRAGMENT;
+		*pos++ = slice_len;
+		os_memcpy(pos, ptr, slice_len);
+
+		ptr += slice_len;
+		pos += slice_len;
+		len -= slice_len;
+	}
+	return pos;
+}
+
+
 void hostapd_epcs_timeout_handler(void *eloop_ctx, void *timeout_ctx)
 {
 	struct wlan_epcs_info epcs_info = {0};
-- 
