From 6bc7c3d80fa02edcb8dd3265f7f695fb35e19948 Mon Sep 17 00:00:00 2001
From: Srinivas Pitla <spitla@qti.qualcomm.com>
Date: Fri, 4 Jul 2025 14:14:55 -0700
Subject: [PATCH 2/2] [PATCH 2/2] UPSTREAM: PROTOCOL: hostapd: Configure AAL
 Max ML  recommended links

This change invokes NL command to configure Max ML recommended
links to driver.

It also allows user to update max active links runtime.

This is defined as per IEEE P802.11be/D7.0 spec 9.4.2.322.2.3 Common
Info field of the Basic Multi-Link element.

Signed-off-by: Srinivas Pitla <spitla@qti.qualcomm.com>
---
 src/ap/beacon.c              | 14 ++++++++++++++
 src/drivers/driver.h         |  5 +++++
 src/drivers/driver_nl80211.c |  8 ++++++++
 src/drivers/nl80211_copy.h   |  1 +
 4 files changed, 28 insertions(+)

--- a/src/ap/beacon.c
+++ b/src/ap/beacon.c
@@ -3036,6 +3036,20 @@ static int __ieee802_11_set_beacon(struc
 		params.freq = &freq;
 	}
 
+#ifdef CONFIG_IEEE80211BE
+	if ((hapd->conf->mld_ap) && (hapd->conf->enable_aal)) {
+		if (hapd->mld->num_links >= hapd->conf->ml_max_rec_links)
+			params.ml_max_rec_links = hapd->conf->ml_max_rec_links;
+		else
+			params.ml_max_rec_links = hapd->mld->num_links;
+
+		if (params.ml_max_rec_links == ML_IE_RSVD_MAX_REC_LINKS)
+			params.ml_max_rec_links = ML_IE_NO_MAX_REC_LINKS;
+	} else {
+		params.ml_max_rec_links = ML_IE_MAX_REC_LINKS_INVAL;
+	}
+#endif /* CONFIG_IEEE80211BE */
+
 	params.allowed_freqs = NULL;
 #ifdef CONFIG_DRIVER_NL80211_QCA
 	for (i = 0; i < hapd->iface->num_hw_features; i++) {
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -2041,6 +2041,11 @@ struct wpa_driver_ap_params {
 	 * sae_password - SAE password for SAE offload
 	 */
 	const char *sae_password;
+
+	/**
+	 * ml_max_rec_links - Max recommended links for ML
+	 */
+	u8 ml_max_rec_links;
 };
 
 struct wpa_driver_mesh_bss_params {
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -5714,6 +5714,14 @@ static int wpa_driver_nl80211_set_ap(voi
 			goto fail;
 	}
 
+	if (params->ml_max_rec_links != ML_IE_MAX_REC_LINKS_INVAL) {
+		wpa_printf(MSG_DEBUG, "nl80211: ML Max rec links=%u",
+			   params->ml_max_rec_links);
+		if (nla_put_u8(msg, NL80211_ATTR_ML_MAX_REC_LINKS,
+			       params->ml_max_rec_links))
+			goto fail;
+	}
+
 #ifdef CONFIG_DRIVER_NL80211_QCA
 	if (cmd == NL80211_CMD_NEW_BEACON && params->allowed_freqs)
 		qca_set_allowed_ap_freqs(drv, params->allowed_freqs,
--- a/src/drivers/nl80211_copy.h
+++ b/src/drivers/nl80211_copy.h
@@ -3546,6 +3546,7 @@ enum nl80211_attrs {
 	NL80211_ATTR_AP_REMOVAL_COUNT,
 	NL80211_ATTR_TSF,
 	NL80211_ATTR_RXMGMT_LINK_REMOVAL_UPDATE,
+	NL80211_ATTR_ML_MAX_REC_LINKS,
 
 	NL80211_ATTR_ERP,
 
