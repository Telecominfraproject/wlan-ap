From 41e72bb26ac63287a7d5c8a43b79bff5c015aa90 Mon Sep 17 00:00:00 2001
From: Sai Maddali <saimadda@qti.qualcomm.com>
Date: Mon, 10 Nov 2025 04:02:27 -0800
Subject: [PATCH] QSDK:CP:HOSTAPD: Check obj->id validity before freeing in
 ubus_free_bss()

Ensure that obj->id is valid before attempting to free
resources in ubus_free_bss(). This prevents accidental
cleanup of stale or already-removed objects, avoiding
potential memory corruption or use-after-free issues.

Signed-off-by: Sai Maddali <saimadda@qti.qualcomm.com>
---
 src/ap/ubus.c | 9 +++++----
 1 file changed, 5 insertions(+), 4 deletions(-)

diff --git a/src/ap/ubus.c b/src/ap/ubus.c
index 4325a99..266622c 100644
--- a/src/ap/ubus.c
+++ b/src/ap/ubus.c
@@ -1676,10 +1676,11 @@ void hostapd_ubus_free_bss(struct hostapd_data *hapd)
 	if (!ctx)
 		return;
 
-	if (obj->id) {
-		ubus_remove_object(ctx, obj);
-		hostapd_ubus_ref_dec();
-	}
+	if (!obj->id)
+		return;
+
+	ubus_remove_object(ctx, obj);
+	hostapd_ubus_ref_dec();
 
 	free(name);
 }
-- 
