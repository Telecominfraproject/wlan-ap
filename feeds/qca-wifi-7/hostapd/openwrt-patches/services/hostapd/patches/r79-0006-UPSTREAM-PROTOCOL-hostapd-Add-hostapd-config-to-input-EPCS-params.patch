+#
+# This config represents EPCS he_mu_edca and wmm parameters for vo, vi, be
+# and bk traffic.
+# These parameters are sent as part of the EPCS Priority Access Multi-Link
+# element in the EPCS REQUEST and EPCS RESPONSE Action Frames from the AP MLD
+# to request an EPCS session with an EPCS authorized non-AP MLD. Set the default
+# values for these parameters based on WFA document -
+# Wi-Fi CERTIFIED 7 Test Plan v1.2, section 4.53 APUT EPCS tests.
+
+# epcs_he_mu_edca_ac_be_aifsn=8
+# epcs_he_mu_edca_ac_be_aci=0
+# epcs_he_mu_edca_ac_be_ecwmin=9
+# epcs_he_mu_edca_ac_be_ecwmax=10
+# epcs_he_mu_edca_ac_be_timer=255
+
+# epcs_he_mu_edca_ac_bk_aifsn=15
+# epcs_he_mu_edca_ac_bk_aci=1
+# epcs_he_mu_edca_ac_bk_ecwmin=9
+# epcs_he_mu_edca_ac_bk_ecwmax=10
+# epcs_he_mu_edca_ac_bk_timer=255
