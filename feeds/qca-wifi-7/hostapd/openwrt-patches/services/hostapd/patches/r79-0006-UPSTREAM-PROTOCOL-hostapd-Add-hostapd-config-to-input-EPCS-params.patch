+# epcs_he_mu_edca_ac_vi_aifsn=5
+# epcs_he_mu_edca_ac_vi_aci=2
+# epcs_he_mu_edca_ac_vi_ecwmin=5
+# epcs_he_mu_edca_ac_vi_ecwmax=7
+# epcs_he_mu_edca_ac_vi_timer=255
+
+# epcs_he_mu_edca_ac_vo_aifsn=5
+# epcs_he_mu_edca_ac_vo_aci=3
+# epcs_he_mu_edca_ac_vo_ecwmin=5
+# epcs_he_mu_edca_ac_vo_ecwmax=7
+# epcs_he_mu_edca_ac_vo_timer=255
+#
+# epcs_wmm_ac_be_cwmin=4
+# epcs_wmm_ac_be_cwmax=9
+# epcs_wmm_ac_be_aifs=3
+# epcs_wmm_ac_be_txop_limit=0
+#
+# epcs_wmm_ac_bk_cwmin=4
+# epcs_wmm_ac_bk_cwmax=9
+# epcs_wmm_ac_bk_aifs=7
+# epcs_wmm_ac_bk_txop_limit=0
+#
+# epcs_wmm_ac_vi_cwmin=3
+# epcs_wmm_ac_vi_cwmax=4
+# epcs_wmm_ac_vi_aifs=2
+# epcs_wmm_ac_vi_txop_limit=188
+#
+# epcs_wmm_ac_vo_cwmin=2
+# epcs_wmm_ac_vo_cwmax=3
+# epcs_wmm_ac_vo_aifs=2
+# epcs_wmm_ac_vo_txop_limit=102
