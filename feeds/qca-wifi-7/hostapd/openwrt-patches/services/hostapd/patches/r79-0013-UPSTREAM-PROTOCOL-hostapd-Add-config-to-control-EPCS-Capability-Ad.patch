From a33bc978006ca2208390248f71fa91a620a84df2 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Sat, 10 May 2025 02:48:04 +0530
Subject: [PATCH 13/20] UPSTREAM:PROTOCOL: hostapd: Add config to control EPCS
 Capability Advertisement

Add option enable_epcs in the hostapd config file to enable or disable
EPCS Capability Advertisement in the management frames of AP MLD - beacon,
probe response, assoc response. This helps users to enable or disable the EPCS
feature in AP MLD.
If enable_epcs=1, then advertise the EPCS capability in the above management
frames. If enable_epcs=0, then do not advertise the EPCS capability in the
above mentioned management frames.

The EPCS Capability advertisement is described in the Table-9-417q Subfields
of the EHT MAC Capabilities Information field, of the IEEE P802.11be/D7.0 Spec.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 hostapd/config_file.c   | 4 ++++
 hostapd/hostapd.conf    | 9 +++++++++
 src/ap/ap_config.h      | 1 +
 src/ap/ieee802_11_eht.c | 6 ++++++
 4 files changed, 20 insertions(+)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 9c1c034..8260ffa 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -5119,6 +5119,10 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 		conf->enable_6ghz_composite_ap = atoi(pos);
 	} else if (os_strcmp(buf, "enable_mcs15") == 0) {
 		conf->enable_mcs15 = atoi(pos);
+#ifdef CONFIG_IEEE80211BE
+	} else if (os_strcmp(buf, "enable_epcs") == 0) {
+		bss->is_epcs_enabled = atoi(pos);
+#endif /* CONFIG_IEEE80211BE */
 	} else {
 		wpa_printf(MSG_ERROR,
 			   "Line %d: unknown configuration item '%s'",
diff --git a/hostapd/hostapd.conf b/hostapd/hostapd.conf
index defe6ad..f9db6e3 100644
--- a/hostapd/hostapd.conf
+++ b/hostapd/hostapd.conf
@@ -3521,6 +3521,15 @@ own_ip_addr=127.0.0.1
 # 1 = enabled (default)
 #enable_6ghz_composite_ap=1
 #
+
+# This field is used to enable or disable EPCS Capability Advertisement in
+# the management frames of AP - beacon, probe response, assoc response.
+# This helps users to enable or disable the EPCS feature for the AP.
+# This field is enabled by default only if IEEE 802.11be (EHT) is enabled.
+# 0 = disabled
+# 1 = enabled (default for ieee80211be==1)
+# enable_epcs=1
+#
 # This config represents EPCS he_mu_edca and wmm parameters for vo, vi, be
 # and bk traffic.
 # These parameters are sent as part of the EPCS Priority Access Multi-Link
diff --git a/src/ap/ap_config.h b/src/ap/ap_config.h
index 67dafef..c1d9fff 100644
--- a/src/ap/ap_config.h
+++ b/src/ap/ap_config.h
@@ -1009,6 +1009,7 @@ struct hostapd_bss_config {
 	struct hostapd_wmm_ac_params prev_epcs_wmm_ac_params[4];
 	struct ieee80211_he_mu_edca_parameter_set epcs_he_mu_edca;
 	int epcs_parameter_set_count;
+	bool is_epcs_enabled;
 #endif /* CONFIG_IEEE80211BE */
 
 };
diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 7ceb84a..36e89d1 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -165,6 +165,12 @@ u8 * hostapd_eid_eht_capab(struct hostapd_data *hapd, u8 *eid,
 	cap = (struct ieee80211_eht_capabilities *) pos;
 	os_memset(cap, 0, sizeof(*cap));
 	cap->mac_cap = host_to_le16(eht_cap->mac_cap);
+
+	if (hapd->conf->is_epcs_enabled)
+		cap->mac_cap |= EHT_MACCAP_EPCS_PRIO;
+	else
+		cap->mac_cap &= ~EHT_MACCAP_EPCS_PRIO;
+
 	os_memcpy(cap->phy_cap, eht_cap->phy_cap, EHT_PHY_CAPAB_LEN);
 
 	if (!is_6ghz_op_class(hapd->iconf->op_class) ||
-- 
