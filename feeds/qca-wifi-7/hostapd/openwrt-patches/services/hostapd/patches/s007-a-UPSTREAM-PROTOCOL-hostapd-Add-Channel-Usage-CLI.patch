From 26aa2e3225db24b6cdb793507f8ec187d6f8379f Mon Sep 17 00:00:00 2001
From: Abhinav Raghunandan <abhiragh@qti.qualcomm.com>
Date: Tue, 9 Sep 2025 10:00:36 +0530
Subject: [PATCH] Add CLI option to configure Channel Usage element

Add a new CLI command that allows users to pass values to all the
fields in the Channel Usage element payload. After parsing and
validating the input data, store the configuration in the hostapd
data structure for future use.

Signed-off-by: Abhinav Raghunandan <abhiragh@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c   |  20 ++++++
 hostapd/hostapd_cli.c  | 137 +++++++++++++++++++++++++++++++++++++++++
 src/ap/ctrl_iface_ap.c | 126 +++++++++++++++++++++++++++++++++++++
 src/ap/ctrl_iface_ap.h |   2 +
 src/ap/hostapd.h       |  38 ++++++++++++
 5 files changed, 323 insertions(+)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 2ef42c5..fc33d7e 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -5482,6 +5482,23 @@ int hostapd_ctrl_iface_advertise_ttlm(struct hostapd_data *hapd, const char *cmd
 	return ret;
 }
 
+static int hostapd_ctrl_iface_set_channel_usage_element(struct hostapd_data *hapd,
+		                                         char *pos)
+{
+	struct channel_usage_config cfg;
+	if (hostapd_parse_channel_usage_settings(pos, &cfg) < 0) {
+		wpa_printf(MSG_ERROR, "Failure in parsing SET_CHANNEL_USAGE_ELEMENT");
+		return -1;
+	}
+	/* Save the config into hostapd_data structure and set beacon */
+	os_memcpy(&hapd->chan_usage_config, &cfg, sizeof(cfg));
+	wpa_printf(MSG_DEBUG, "Channel Usage element updated with %d elements",
+		   hapd->chan_usage_config.num_elems);
+	ieee802_11_set_beacon(hapd);
+	return 0;
+}
+
