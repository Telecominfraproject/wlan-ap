From 833ed5cf4925687a9b3ad3f606287d3701fa8a9c Mon Sep 17 00:00:00 2001
From: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
Date: Mon, 14 Jul 2025 14:11:18 -0700
Subject: [PATCH] UPSTREAM:hostapd:nl80211:Add MSCS specific params for nl80211

Add MSCS specific parameters like tclas_mask, user priority bitmap
and limit in NL80211, to notify the underlying driver about an
MSCS session

Signed-off-by: Ramanathan Choodamani <rchoodam@qti.qualcomm.com>
---
 src/drivers/driver_nl80211.c | 23 ++++++++++++++++++-----
 src/drivers/nl80211_copy.h   |  3 +++
 2 files changed, 21 insertions(+), 5 deletions(-)

--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -15935,6 +15935,21 @@ static int nl80211_set_qm_desc(struct nl
 			goto nla_fail;
 	}
 
+	if (qm_req_desc.user_priority_bitmap &&
+		nla_put_u8(msg, NL80211_QM_DESC_ATTR_USER_PRIORITY_BITMAP,
+			qm_req_desc.user_priority_bitmap))
+		goto nla_fail;
+
+	if (qm_req_desc.user_priority_limit &&
+		nla_put_u8(msg, NL80211_QM_DESC_ATTR_USER_PRIORITY_LIMIT,
+			qm_req_desc.user_priority_limit))
+		goto nla_fail;
+
+	if (qm_req_desc.tclas_mask &&
+		nla_put_u8(msg, NL80211_QM_DESC_ATTR_TCLAS_MASK,
+			qm_req_desc.tclas_mask))
+		goto nla_fail;
+
 #ifdef CONFIG_IEEE80211BE
 	if (qm_req_desc.is_qos_present) {
 		if (nl80211_set_qm_qos_attr(msg, qm_req_desc.qos_attr))
--- a/src/drivers/nl80211_copy.h
+++ b/src/drivers/nl80211_copy.h
@@ -8714,6 +8714,9 @@ enum nl80211_qm_desc_attrs {
 	NL80211_QM_DESC_ATTR_TCLAS_PROCESSING,
 	NL80211_QM_DESC_ATTR_QOS_ATTRIBUTES,
 	NL80211_QM_DESC_ATTR_STATUS,
+	NL80211_QM_DESC_ATTR_USER_PRIORITY_BITMAP,
+	NL80211_QM_DESC_ATTR_USER_PRIORITY_LIMIT,
+	NL80211_QM_DESC_ATTR_TCLAS_MASK,
 
 	/* keep last */
 	__NL80211_QM_DESC_ATTR_LAST,
