From 5105d439a8b11509ae563e22358db40677104eb7 Mon Sep 17 00:00:00 2001
From: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
Date: Wed, 17 Sep 2025 16:52:43 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd: Fix failure to disable FILS/UBPR

When dual-band is enabled, hostapd disables FILS/UBPR for 6GHz by
sending a value of 0 for FILS max interval or UBPR interval. But
the commands fails as 0 is incorrectly treated as an invalid
interval value.

Fix the issue by allowing 0 as a valid FILS/UBPR interval value.

Signed-off-by: Suraj P Kizhakkethil <suraj.kizhakkethil@oss.qualcomm.com>
---
 src/drivers/driver_nl80211.c | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 000deb7..a4a36f3 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -5843,8 +5843,7 @@ static int wpa_driver_nl80211_set_ap(void *priv,
 			goto fail;
 	}
 
-	if (params->ubpr.unsol_bcast_probe_resp_interval &&
-	    nl80211_unsol_bcast_probe_resp(bss, msg, &params->ubpr) < 0)
+	if (nl80211_unsol_bcast_probe_resp(bss, msg, &params->ubpr) < 0)
 		goto fail;
 
 	if (nl80211_mbssid(msg, &params->mbssid) < 0)
@@ -5869,7 +5868,7 @@ static int wpa_driver_nl80211_set_ap(void *priv,
 #endif /* CONFIG_SAE */
 
 #ifdef CONFIG_FILS
-	if (params->fd_max_int && nl80211_fils_discovery(bss, msg, params) < 0)
+	if (nl80211_fils_discovery(bss, msg, params) < 0)
 		goto fail;
 #endif /* CONFIG_FILS */
 
-- 
