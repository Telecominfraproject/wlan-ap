+		tailpos = hostapd_eid_he_mu_edca_parameter_set(hapd, tailpos, false);
 #ifdef CONFIG_IEEE80211BE
 		if (hapd == tx_bss)
 			hostapd_eid_update_cu_info(hapd, &elemid_modified, startpos,
@@ -2642,7 +2642,7 @@ int ieee802_11_build_ap_params(struct ho
 
