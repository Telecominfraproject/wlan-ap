-u8 * hostapd_eid_wmm(struct hostapd_data *hapd, u8 *eid);
+u8 * hostapd_eid_wmm(struct hostapd_data *hapd, u8 *eid, bool is_epcs);
 int hostapd_eid_wmm_valid(struct hostapd_data *hapd, const u8 *eid,
 			  size_t len);
