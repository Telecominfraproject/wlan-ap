From cad536e470896f85df41424bae89ea85c1d76b3e Mon Sep 17 00:00:00 2001
From: Mohan Kumar G <quic_mkumarg@quicinc.com>
Date: Wed, 27 Nov 2024 16:23:33 +0530
Subject: [PATCH] UPSTREAM:HOSTAPD: Add mcs15_disable subfield in EHT operation

As per IEEE P802.11be/D7.0 section 9.4.2.321, EHT operation element
contains disable_mcs15 as the 6th bit and is set to 1 when mcs15
support is not advertised.

Add disable_mcs15 to EHT operation parameters element and initialize
the bit to 1.

Patch-depdendency: None

Patch-work: None

Feature: MCS15

Signed-off-by: Mohan Kumar G <quic_mkumarg@quicinc.com>
Signed-off-by: Dhanavandhana Kannan <quic_dhanavan@quicinc.com>
---
 hostapd/config_file.c        | 2 ++
 src/ap/ap_config.h           | 1 +
 src/ap/ieee802_11_eht.c      | 2 ++
 src/common/ieee802_11_defs.h | 1 +
 4 files changed, 6 insertions(+)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 9dee882..41601f2 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -5228,6 +5228,8 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 		conf->use_ru_puncture_dfs = atoi(pos);
 	} else if (os_strcmp(buf, "enable_6ghz_composite_ap") == 0) {
 		conf->enable_6ghz_composite_ap = atoi(pos);
+	} else if (os_strcmp(buf, "enable_mcs15") == 0) {
+		conf->enable_mcs15 = atoi(pos);
 	} else {
 		wpa_printf(MSG_ERROR,
 			   "Line %d: unknown configuration item '%s'",
diff --git a/src/ap/ap_config.h b/src/ap/ap_config.h
index 8d29590..32ea7a4 100644
--- a/src/ap/ap_config.h
+++ b/src/ap/ap_config.h
@@ -1312,6 +1312,7 @@ struct hostapd_config {
 	 * hostpd config.
 	 */
 	bool enable_6ghz_composite_ap;
+	bool enable_mcs15;
 };
 
 
diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 7b2e0a4..8bd1099 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -265,6 +265,8 @@ u8 * hostapd_eid_eht_operation(struct hostapd_data *hapd, u8 *eid,
 	oper->oper_params = 0;
 	if (hapd->iconf->eht_default_pe_duration)
 		oper->oper_params |= EHT_OPER_DEFAULT_PE_DURATION;
+	if (!hapd->iconf->enable_mcs15)
+		oper->oper_params |= EHT_OPER_MCS15_DISABLE;
 
 	/* TODO: Fill in appropriate EHT-MCS max Nss information */
 	oper->basic_eht_mcs_nss_set[0] = 0x11;
diff --git a/src/common/ieee802_11_defs.h b/src/common/ieee802_11_defs.h
index 704adf9..82eb871 100644
--- a/src/common/ieee802_11_defs.h
+++ b/src/common/ieee802_11_defs.h
@@ -2731,6 +2731,7 @@ struct ieee80211_he_mu_edca_parameter_set {
 #define EHT_OPER_DEFAULT_PE_DURATION                   BIT(2)
 #define EHT_OPER_GROUP_ADDR_BU_INDICATION_LIMIT        BIT(3)
 #define EHT_OPER_GROUP_ADDR_BU_INDICATION_EXPONENT     (BIT(4) | BIT(5))
+#define EHT_OPER_MCS15_DISABLE                         BIT(6)
 #define EHT_OPER_DISABLED_SUBCHAN_BITMAP_SIZE          2
 
 /* Control subfield: Channel Width subfield; see Table 9-401b */
-- 
2.34.1

