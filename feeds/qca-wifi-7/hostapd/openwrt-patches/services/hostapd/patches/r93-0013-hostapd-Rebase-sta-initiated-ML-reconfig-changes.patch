From 9b7b86d5cb8e9b91850e8600f39112664ae0c549 Mon Sep 17 00:00:00 2001
From: Mohan Kumar G <mkumarg@qti.qualcomm.com>
Date: Tue, 15 Jul 2025 11:27:08 +0530
Subject: [PATCH 13/13] hostapd: Rebase sta initiated ML reconfig changes

Rebase changes for STA initiated ML reconfig feature and
update necessary functions / parameters on ToT.

Signed-off-by: Mohan Kumar G <mkumarg@qti.qualcomm.com>
---
 src/ap/ieee802_11.c     | 16 ++++++++--------
 src/ap/ieee802_11.h     |  6 +++++-
 src/ap/ieee802_11_eht.c | 23 +++++++++++++++--------
 3 files changed, 28 insertions(+), 17 deletions(-)

diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index 35b9a9a..dfbc0d9 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -4904,9 +4904,9 @@ static int check_assoc_ies(struct hostapd_data *hapd, struct sta_info *sta,
 #ifdef CONFIG_IEEE80211BE
 
 void ieee80211_ml_build_assoc_resp(struct hostapd_data *hapd,
-				    struct hostapd_data *phapd,
-				    struct sta_info *sta,
-				  struct mld_link_info *link)
+				   struct hostapd_data *phapd,
+				   struct sta_info *sta,
+				   struct mld_link_info *link)
 {
 	u8 buf[EHT_ML_MAX_STA_PROF_LEN];
 	u8 *p = buf;
@@ -4989,11 +4989,11 @@ out:
 
 int ieee80211_ml_process_link(struct hostapd_data *hapd,
 			      struct hostapd_data *phapd,
-			     struct sta_info *origin_sta,
-			     struct mld_link_info *link,
-			     const u8 *ies, size_t ies_len,
-			     enum link_parse_type type, bool offload,
-			     bool *set_beacon)
+			      struct sta_info *origin_sta,
+			      struct mld_link_info *link,
+			      const u8 *ies, size_t ies_len,
+			      enum link_parse_type type, bool offload,
+			      bool *set_beacon)
 {
 	struct ieee802_11_elems elems;
 	struct wpabuf *mlbuf = NULL;
diff --git a/src/ap/ieee802_11.h b/src/ap/ieee802_11.h
index 6d7d5f9..f21747e 100644
--- a/src/ap/ieee802_11.h
+++ b/src/ap/ieee802_11.h
@@ -430,11 +430,15 @@ int hostapd_process_assoc_ml_info(struct hostapd_data *hapd,
 #ifdef CONFIG_IEEE80211BE
 void ml_deinit_link_reconf_req(struct link_reconf_req_list **req_list_ptr);
 int ieee80211_ml_process_link(struct hostapd_data *hapd,
+			      struct hostapd_data *phapd,
 			      struct sta_info *origin_sta,
 			      struct mld_link_info *link,
 			      const u8 *ies, size_t ies_len,
-			      enum link_parse_type type, bool offload);
+			      enum link_parse_type type, bool offload,
+			      bool *set_beacon);
 void ieee80211_ml_build_assoc_resp(struct hostapd_data *hapd,
+				   struct hostapd_data *phapd,
+				   struct sta_info *sta,
 				   struct mld_link_info *link);
 
 void ieee802_11_rx_protected_eht_action(struct hostapd_data *hapd,
diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 0c98991..7cdfa9e 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -1695,6 +1695,7 @@ void hostapd_link_reconf_resp_tx_status(struct hostapd_data *hapd,
 			link->valid = false;
 		}
 		wpa_auth_set_ml_info(assoc_sta->wpa_sm,
+				     lhapd->mld_link_id,
 				     assoc_sta->mld_assoc_link_id,
 				     &assoc_sta->mld_info);
 	}
@@ -1747,6 +1748,7 @@ hostapd_ml_process_reconf_link(struct hostapd_data *hapd,
 	struct mld_link_info link;
 	struct sta_info *lsta, *other_sta;
 	u16 resp = WLAN_STATUS_UNSPECIFIED_FAILURE;
+	bool *set_beacon = false;
 
 	lhapd = hostapd_mld_get_link_bss(hapd, link_id);
 	if (!lhapd) /* this cannot be NULL */
@@ -1759,8 +1761,8 @@ hostapd_ml_process_reconf_link(struct hostapd_data *hapd,
 	os_memcpy(link.peer_addr, link_addr, ETH_ALEN);
 
 	/* Parse STA profile, check the IEs, and send ADD_LINK_STA */
-	ieee80211_ml_process_link(lhapd, assoc_sta, &link, ies, ies_len,
-				  LINK_PARSE_RECONF, false);
+	ieee80211_ml_process_link(lhapd, NULL, assoc_sta, &link, ies, ies_len,
+				  LINK_PARSE_RECONF, false, set_beacon);
 	resp = link.status;
 	if (resp != WLAN_STATUS_SUCCESS)
 		return resp;
@@ -1782,8 +1784,8 @@ hostapd_ml_process_reconf_link(struct hostapd_data *hapd,
 		os_memcpy(link->local_addr, other_hapd->own_addr, ETH_ALEN);
 		os_memcpy(link->peer_addr, link_addr, ETH_ALEN);
 	}
-	wpa_auth_set_ml_info(lsta->wpa_sm, lsta->mld_assoc_link_id,
-			     &lsta->mld_info);
+	wpa_auth_set_ml_info(lsta->wpa_sm, lhapd->mld_link_id,
+			     lsta->mld_assoc_link_id, &lsta->mld_info);
 
 	return resp;
 }
@@ -1886,8 +1888,10 @@ hostapd_send_link_reconf_resp(struct hostapd_data *hapd,
 				assoc_sta->wpa_sm, req_list->links_add_ok) + 1;
 		len += kde_len;
 
+#ifdef CONFIG_OCV
 		if (wpa_auth_uses_ocv(assoc_sta->wpa_sm))
 			len += OCV_OCI_EXTENDED_LEN;
+#endif /* CONFIG_OCV */
 
 		mld.mld_sta = true;
 		dl_list_for_each(info, &req_list->add_req,
@@ -1905,9 +1909,9 @@ hostapd_send_link_reconf_resp(struct hostapd_data *hapd,
 				continue;
 
 			link->valid = true;
-			ieee80211_ml_build_assoc_resp(lhapd, link);
+			ieee80211_ml_build_assoc_resp(lhapd, NULL, assoc_sta, link);
 		}
-		mle_len = hostapd_eid_eht_ml_len(&mld, false);
+		mle_len = hostapd_eid_eht_ml_len(&mld, false, true, WLAN_FC_STYPE_ACTION);
 		len += mle_len;
 	}
 
@@ -1977,6 +1981,7 @@ hostapd_send_link_reconf_resp(struct hostapd_data *hapd,
 		pos_len += kde_len;
 	}
 
+#ifdef CONFIG_OCV
 	/* OCI element for add links */
 	if (wpa_auth_uses_ocv(assoc_sta->wpa_sm)) {
 		struct wpa_channel_info ci;
@@ -1998,13 +2003,13 @@ hostapd_send_link_reconf_resp(struct hostapd_data *hapd,
 		pos += OCV_OCI_EXTENDED_LEN;
 		pos_len += OCV_OCI_EXTENDED_LEN;
 	}
-
+#endif
 	/* Basic Multi-Link element for add links */
 	if (mle_len) {
 		u8 *mle_pos = pos;
 
 		mle_pos = hostapd_eid_eht_basic_ml_common(hapd, mle_pos, &mld,
-							  false);
+							  true, 0, WLAN_FC_STYPE_ACTION);
 		if ((mle_pos - pos) != mle_len) {
 			reject_all = true;
 			goto reject_all_req;
@@ -2650,6 +2655,7 @@ hostapd_handle_link_reconf_req(struct hostapd_data *hapd, const u8 *buf,
 	if (!req_list->num_add_req)
 		goto skip_oci_validation;
 
+#ifdef CONFIG_OCV
 	if (!elems.oci || !elems.oci_len) {
 		if (wpa_auth_uses_ocv(assoc_sta->wpa_sm) == 1) {
 			wpa_printf(MSG_ERROR, "MLD: No OCI element present; "
@@ -2680,6 +2686,7 @@ hostapd_handle_link_reconf_req(struct hostapd_data *hapd, const u8 *buf,
 		}
 	}
 
+#endif
 skip_oci_validation:
 	/* Do STA profile validation */
 	if (!hostapd_validate_link_reconf_req(hapd, assoc_sta, req_list))
-- 
2.34.1

