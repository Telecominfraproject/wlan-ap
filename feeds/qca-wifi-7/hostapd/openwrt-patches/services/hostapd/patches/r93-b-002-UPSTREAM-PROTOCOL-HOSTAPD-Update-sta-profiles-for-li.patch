From 6b022e2fa68c501d8b7e804191dc4f07bf149ab4 Mon Sep 17 00:00:00 2001
From: Mohan Kumar G <mkumarg@qti.qualcomm.com>
Date: Thu, 24 Jul 2025 16:16:18 +0530
Subject: [PATCH 2/4] UPSTREAM:PROTOCOL:HOSTAPD: Update sta profiles for link 
 addition to ml_reconf_req

Update the STA profiles required for link addition request, parsed
from link_reconf_req_list, into ml_reconf_req structure. Also, add
bitmaps for all the updated links. Use this structure to hold
all reconfig request information and per sta profiles for
requested links.

Patch-work: None

Depends-on: None

Feature: ML_RECONFIG

Signed-off-by: Mohan Kumar G <mkumarg@qti.qualcomm.com>
---
 src/ap/ap_drv_ops.c     | 24 +++++++++++++++++++++++-
 src/ap/ap_drv_ops.h     |  2 +-
 src/ap/ieee802_11.c     | 14 ++++++++------
 src/ap/ieee802_11_eht.c | 10 ++++++++++
 src/ap/sta_info.c       |  2 +-
 5 files changed, 43 insertions(+), 9 deletions(-)

Index: hostapd-2025.03.10~95ad7115/src/ap/ap_drv_ops.c
===================================================================
--- hostapd-2025.03.10~95ad7115.orig/src/ap/ap_drv_ops.c
+++ hostapd-2025.03.10~95ad7115/src/ap/ap_drv_ops.c
@@ -531,9 +531,11 @@ int hostapd_sta_add(struct hostapd_data
 		    const struct ieee80211_he_6ghz_band_cap *he_6ghz_capab,
 		    u32 flags, u8 qosinfo, u8 vht_opmode, int supp_p2p_ps,
 		    int set, const u8 *link_addr, bool mld_link_sta,
-		    u16 eml_cap)
+		    u16 eml_cap, int type)
 {
 	struct hostapd_sta_add_params params;
+	struct hostapd_data *assoc_hapd;
+	struct sta_info *sta, *assoc_sta;
 
 	if (hapd->driver == NULL)
 		return 0;
@@ -575,6 +577,26 @@ int hostapd_sta_add(struct hostapd_data
 		if (link_addr)
 			params.eml_cap = eml_cap;
 	}
+
+	if (type == LINK_PARSE_RECONF) {
+		sta = ap_get_sta(hapd, addr);
+		if (!sta) {
+			wpa_printf(MSG_ERROR, "No link sta for addr = " MACSTR,
+				   MAC2STR(addr));
+			return -1;
+		}
+		assoc_sta = hostapd_ml_get_assoc_sta(hapd, sta, &assoc_hapd);
+		if (!assoc_sta) {
+			wpa_printf(MSG_ERROR, "No assoc sta found");
+			return -1;
+		}
+		assoc_sta->recfg_sta_add_params[hapd->mld_link_id] =
+			os_zalloc(sizeof(struct hostapd_sta_add_params));
+
+		os_memcpy(assoc_sta->recfg_sta_add_params[hapd->mld_link_id],
+			  &params, sizeof(params));
+		return 0;
+	}
 #endif /* CONFIG_IEEE80211BE */
 
 	return hapd->driver->sta_add(hapd->drv_priv, &params);
