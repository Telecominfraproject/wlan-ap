From c19bb61082b4fcd2b81fb5f914f7704bab6eec70 Mon Sep 17 00:00:00 2001
From: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
Date: Mon, 29 Sep 2025 22:33:15 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Fix use strtok_r instead of
 strtok

In hostapd_ctrl_iface_negotiated_ttlm_response(), use
strtok_r instead of strtok as this has been listed
under banned functions.

Patch-dependency: r80-007-hostapd-Add-hostapd_cli-commands-
to-support-TTLM.patch

Patch-work: None

Fixes: I7fe93c6d053b(UPSTREAM:PROTOCOL: hostapd: Negotiation
of TID-To-Link Mapping feature support)

Signed-off-by: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 8e6ce26..c603d70 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -5293,7 +5293,7 @@ static int hostapd_ctrl_iface_negotiated_ttlm_response(struct hostapd_data *hapd
 	struct hostapd_data *lhapd;
 	char *tid_str, *map_str;
 	bool homogeneous_map;
-	char *input, *token;
+	char *input, *token, *saveptr;
 	int assoc_frame = 0;
 	int resp_code = 0;
 	int i, dir = -1;
@@ -5311,7 +5311,7 @@ static int hostapd_ctrl_iface_negotiated_ttlm_response(struct hostapd_data *hapd
 	if (!input)
 		return -1;
 
-	token = strtok(input, " ");
+	token = strtok_r(input, " ", &saveptr);
 	if (!token || hwaddr_aton(token, addr)) {
 		wpa_printf(MSG_ERROR, "Invalid STA MAC address");
 		os_free(input);
@@ -5334,7 +5334,7 @@ static int hostapd_ctrl_iface_negotiated_ttlm_response(struct hostapd_data *hapd
 	for (i = 0; i < TTLM_DIRECTION_MAX; i++)
 		ttlm_conf->ttlm_direction[i].direction = TTLM_DIRECTION_INVALID;
 
-	while ((token = strtok(NULL, " "))) {
+	while ((token = strtok_r(NULL, " ", &saveptr))) {
 		if (strncmp(token, "assoc_frame=", 12) == 0) {
 			assoc_frame = atoi(token + 12);
 		} else if (strncmp(token, "resp_code=", 10) == 0) {
@@ -5370,8 +5370,8 @@ static int hostapd_ctrl_iface_negotiated_ttlm_response(struct hostapd_data *hapd
 			} else if (strncmp(token, "num_tids=", 9) == 0) {
 				ttlm_dir->num_tids = atoi(token + 9);
 				for (i = 0; i < ttlm_dir->num_tids; i++) {
-					tid_str = strtok(NULL, " ");
-					map_str = strtok(NULL, " ");
+					tid_str = strtok_r(NULL, " ", &saveptr);
+					map_str = strtok_r(NULL, " ", &saveptr);
 					if (!tid_str || !map_str) {
 						wpa_printf(MSG_DEBUG, "Missing TID or mapping");
 						goto fail;
-- 
