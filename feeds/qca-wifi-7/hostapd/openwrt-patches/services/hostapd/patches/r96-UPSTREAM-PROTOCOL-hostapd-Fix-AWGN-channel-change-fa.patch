 	csa_settings.freq_params.ht_enabled = conf->ieee80211n;
 	csa_settings.freq_params.bandwidth = conf->secondary_channel ? 40 : 20;
+	csa_settings.power_mode = conf->he_6ghz_reg_pwr_type;
 
 	if (conf->ieee80211ac) {
 		int freq1 = 0, freq2 = 0;
