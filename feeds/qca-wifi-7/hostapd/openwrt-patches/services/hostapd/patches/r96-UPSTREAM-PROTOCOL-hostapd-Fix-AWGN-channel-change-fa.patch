From 633a795db98e6f35eea8ce25a14fde19ff5a13e0 Mon Sep 17 00:00:00 2001
From: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
Date: Tue, 29 Jul 2025 13:27:33 +0530
Subject: [PATCH] UPSTREAM: PROTOCOL: hostapd: Fix AWGN channel change failure

As per the recent changes made in the cfg80211, any 6 GHz channel change
request also needs to include the 6 GHz power mode as a mandatory
attribute.

As part of the AWGN channel change request, the 6 GHz power mode
is not included in the request, which results in the kernel rejecting
the channel change request.

To fix this, include the 6 GHz power mode in the AWGN channel change
request. Select the 6 GHz power mode as the best power mode for the
target channel.
Also, update other channel change requests to include the 6 GHz power
mode as well.

Since the channel change request already includes the 6 GHz power mode,
there is no need to store and track the CSA power mode separately.
So, remove the code that tracks the CSA power mode.

Make sure to not allow power mode change when the CSA is in progress.

Fixes: Ia9ef1bdef51 ("UPSTREAM: PROTOCOL: hostapd: Support 6 GHz SP mode with MLO")
Patch-work: None
Tag: 6G_REGULATORY
Feature: AFC
Patch-dependency:
n00-001-hostapd-add-support-for-6GHz-operation.patch
r32-001-hostapd-Add-support-to-receive-AFC-power-update-comp.patch
r66-UPSTREAM-PROTOCOL-hostapd-Handle-AFC-Channel-Change.patch
r90-UPSTREAM-PROTOCOL-hostapd-Support-6-GHz-SP-mode-with.patch

Signed-off-by: Thirusenthil Kumaran J <thirusen@qti.qualcomm.com>
---
 hostapd/ctrl_iface.c            | 20 +++++---------------
 src/ap/drv_callbacks.c          | 16 +++-------------
 src/ap/interference.c           | 24 +++++++++++++++++++++++-
 src/ap/ubus.c                   |  1 +
 src/ap/ucode.c                  |  2 ++
 wpa_supplicant/p2p_supplicant.c |  1 +
 6 files changed, 35 insertions(+), 29 deletions(-)

diff --git a/hostapd/ctrl_iface.c b/hostapd/ctrl_iface.c
index 7c3162404f22..066fd3f83c1e 100644
--- a/hostapd/ctrl_iface.c
+++ b/hostapd/ctrl_iface.c
@@ -3027,6 +3027,11 @@ static int hostapd_ctrl_iface_set_pwr_mode(struct hostapd_iface *iface,
 		return -1;
 	}
 
+	if (hostapd_csa_in_progress(iface)) {
+		wpa_printf(MSG_ERROR, "Channel switch in progress");
+		return -1;
+	}
+
 	os_memset(&settings, 0, sizeof(settings));
 	he_6ghz_pwr_mode = strtol(pos, &end, 10);
 	if (pos == end || he_6ghz_pwr_mode < 0 || he_6ghz_pwr_mode > 2) {
@@ -3220,17 +3225,11 @@ static int hostapd_ctrl_iface_chan_switch(struct hostapd_iface *iface,
 		}
 	}
 
-	if (settings.power_mode > -1)
-		iface->power_mode_6ghz_before_change = settings.power_mode;
-
 	ret = hostapd_check_validity_device_params(&settings.freq_params);
 	if (ret) {
 		wpa_printf(MSG_ERROR, "chanswitch: invalid device parameters provided %d %d",
 			   settings.freq_params.bandwidth_device,
 			   settings.freq_params.center_freq_device);
-		if (iface->power_mode_6ghz_before_change != -1)
-			iface->power_mode_6ghz_before_change = -1;
-
 		return ret;
 	}
 
@@ -3277,9 +3276,6 @@ static int hostapd_ctrl_iface_chan_switch(struct hostapd_iface *iface,
 				   settings.freq_params.freq,
 				   settings.freq_params.sec_channel_offset,
 				   settings.freq_params.bandwidth);
-			if (iface->power_mode_6ghz_before_change != -1)
-				iface->power_mode_6ghz_before_change = -1;
-
 			return -1;
 		}
 
@@ -3302,9 +3298,6 @@ static int hostapd_ctrl_iface_chan_switch(struct hostapd_iface *iface,
 		/* Perform CAC and switch channel */
 		iface->is_ch_switch_dfs = true;
 		hostapd_switch_channel_fallback(iface, &settings.freq_params);
-		if (iface->power_mode_6ghz_before_change != -1)
-			iface->power_mode_6ghz_before_change = -1;
-
 		return 0;
 	}
 
@@ -3328,9 +3321,6 @@ static int hostapd_ctrl_iface_chan_switch(struct hostapd_iface *iface,
 
 		err = hostapd_switch_channel(iface->bss[i], &settings);
 		if (err) {
-			if (iface->power_mode_6ghz_before_change != -1)
-				iface->power_mode_6ghz_before_change = -1;
-
 			ret = err;
 			num_err++;
 		}
diff --git a/src/ap/drv_callbacks.c b/src/ap/drv_callbacks.c
index 72455c3caf9a..60de2745f3c1 100644
--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -1419,27 +1419,17 @@ void hostapd_event_ch_switch(struct hostapd_data *hapd, int freq, int ht,
 				  hapd->iface->num_hw_features);
 
 	wpa_msg(hapd->msg_ctx, MSG_INFO,
-		"%sfreq=%d ht_enabled=%d ch_offset=%d ch_width=%s cf1=%d cf2=%d is_dfs0=%d dfs=%d puncturing_bitmap=0x%04x width_device=%d, cf_device=%d",
+		"%sfreq=%d ht_enabled=%d ch_offset=%d ch_width=%s cf1=%d cf2=%d is_dfs0=%d dfs=%d puncturing_bitmap=0x%04x width_device=%d, cf_device=%d 6ghz power mode=%d",
 		finished ? WPA_EVENT_CHANNEL_SWITCH :
 		WPA_EVENT_CHANNEL_SWITCH_STARTED,
 		freq, ht, offset, channel_width_to_string(width),
-		cf1, cf2, is_dfs0, is_dfs, punct_bitmap, width_device, cf_device);
+		cf1, cf2, is_dfs0, is_dfs, punct_bitmap, width_device, cf_device, power_mode_6ghz);
 	if (!finished)
 		return;
 
 	if (hapd->csa_in_progress &&
 	    freq == hapd->cs_freq_params.freq) {
-		if (hapd->iface->power_mode_6ghz_before_change > -1) {
-			if (power_mode_6ghz == hapd->iface->power_mode_6ghz_before_change) {
-				hapd->iconf->he_6ghz_reg_pwr_type = power_mode_6ghz;
-				hapd->iface->power_mode_6ghz_before_change = -1;
-			} else {
-				wpa_printf(MSG_DEBUG,
-					   "CSA power mode: %d does not match requested power mode: %d",
-					   power_mode_6ghz, hapd->iface->power_mode_6ghz_before_change);
-				hostapd_switch_power_mode(hapd);
-			}
-		}
+		hapd->iconf->he_6ghz_reg_pwr_type = power_mode_6ghz;
 
 		hostapd_cleanup_cs_params(hapd);
 		hapd->disable_cu = 1;
diff --git a/src/ap/interference.c b/src/ap/interference.c
index f0af9871bc75..7c7f4028ebfd 100644
--- a/src/ap/interference.c
+++ b/src/ap/interference.c
@@ -744,6 +744,29 @@ int hostapd_intf_awgn_detected(struct hostapd_iface *iface, int freq, int chan_w
 	settings.freq_params.eht_enabled= iface->conf->ieee80211be;
 	settings.power_mode = -1;
 
+	if (is_6ghz_freq(settings.freq_params.freq) &&
+	    iface->conf->enable_best_power_mode) {
+		int best_power_mode;
+
+		best_power_mode =
+			hostapd_get_best_ap_6ghz_power_mode(iface,
+							    settings.freq_params.freq,
+							    settings.freq_params.center_freq1,
+							    settings.freq_params.bandwidth,
+							    settings.freq_params.punct_bitmap);
+		if (best_power_mode != NL80211_REG_NUM_POWER_MODES) {
+			settings.power_mode = best_power_mode;
+			wpa_printf(MSG_DEBUG, "%s: Best power mode for Freq %d is %d",
+				   __func__,
+				   settings.freq_params.freq,
+				   settings.power_mode);
+		} else {
+			wpa_printf(MSG_DEBUG, "%s: Failed to get BPM for Freq %d",
+				   __func__, settings.freq_params.freq);
+			goto exit;
+		}
+	}
+
 	for (i = 0; i < iface->num_bss; i++) {
 		/* Save CHAN_SWITCH VHT and HE config */
 		hostapd_chan_switch_config(iface->bss[i],
@@ -866,7 +889,6 @@ static void set_csa_param(struct csa_settings *settings,
 							    settings->freq_params.punct_bitmap);
 		if (best_power_mode != NL80211_REG_NUM_POWER_MODES) {
 			settings->power_mode = best_power_mode;
-			iface->power_mode_6ghz_before_change = best_power_mode;
 			wpa_printf(MSG_DEBUG, "%s: Best power mode for Freq %d is %d",
 				   __func__,
 				   settings->freq_params.freq,
diff --git a/src/ap/ubus.c b/src/ap/ubus.c
index 1323865d8554..4325a9985ef6 100644
--- a/src/ap/ubus.c
+++ b/src/ap/ubus.c
@@ -740,6 +740,7 @@ hostapd_switch_chan(struct ubus_context *ctx, struct ubus_object *obj,
 		break;
 	}
 
+	css.power_mode = hapd->iconf->he_6ghz_reg_pwr_type;
 	hostapd_set_freq_params(&css.freq_params, iconf->hw_mode,
 				css.freq_params.freq,
 				css.freq_params.channel, iconf->enable_edmg,
diff --git a/src/ap/ucode.c b/src/ap/ucode.c
index 3262ea290dd3..941d12bb0564 100644
--- a/src/ap/ucode.c
+++ b/src/ap/ucode.c
@@ -763,6 +763,8 @@ uc_hostapd_iface_switch_channel(uc_vm_t *vm, size_t nargs)
 		csa.freq_params.center_freq2 = intval;
 	if ((intval = ucv_int64_get(ucv_object_get(info, "punct_bitmap", NULL))) && !errno)
 		csa.freq_params.punct_bitmap = intval;
+	if ((intval = ucv_int64_get(ucv_object_get(info, "power_mode", NULL))) && !errno)
+		csa.power_mode = intval;
 
 	for (i = 0; i < iface->num_bss; i++)
 		ret = hostapd_switch_channel(iface->bss[i], &csa);
diff --git a/wpa_supplicant/p2p_supplicant.c b/wpa_supplicant/p2p_supplicant.c
