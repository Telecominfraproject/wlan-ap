+static bool recover_from_zero_links(u16 *links_del_ok, u8 *recovery_link)
+{
+	u8 pos = 0;
+	u16 del_links;
+
+	if (!links_del_ok || !recovery_link)
+		return false;
+
+	del_links = *links_del_ok;
+
+	while (del_links) {
+		if (del_links & 1)
+			break;
+		del_links >>= 1;
+		pos++;
+	}
+
+	/* No link found */
+	if (!del_links) {
+		wpa_printf(MSG_DEBUG, "MLD: Total valid links is 0 and "
+			   "no del-link found to reject for recovery");
+		return false;
+	}
+
+	*recovery_link = pos;
+	*links_del_ok &= ~BIT(*recovery_link);
+	wpa_printf(MSG_INFO, "MLD: Del-link request for link (%u) rejected to "
+		   "recover from zero-links", *recovery_link);
+	return true;
+}
