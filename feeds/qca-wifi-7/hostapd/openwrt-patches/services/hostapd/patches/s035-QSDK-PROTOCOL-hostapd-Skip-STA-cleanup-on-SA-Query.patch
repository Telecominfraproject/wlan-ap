From 016076c91b86d86d1fb5e5ccb51bdba6dba0b3c7 Mon Sep 17 00:00:00 2001
From: Sowmiya Sree Elavalagan <ssreeela@qti.qualcomm.com>
Date: Thu, 20 Nov 2025 18:15:50 +0530
Subject: [PATCH]QSDK:PROTOCOL:hostapd: Skip STA cleanup on SA Query timeout
in auth

When the STA is cleaned up in the authentication phase after an SA Query timeout,
only the assoc link is removed while partner links remain because the authorized
flag keeps them present. This leaves stale partner-link entries. If the STA later
associates using one of these stale partner links as the assoc link, hostapd
dereferences the already-cleaned STA and crashes.

Fix by removing STA cleanup from the auth path on SA Query timeout and simply
sending the Authentication response. The association phase performs the full
and safe cleanup, including all partner links.

Patch-dependency: none

Signed-off-by: Sowmiya Sree Elavalagan <ssreeela@qti.qualcomm.com>
---
 src/ap/ieee802_11.c | 20 ++++----------------
 1 file changed, 4 insertions(+), 16 deletions(-)

--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -3508,22 +3508,6 @@ static void handle_auth(struct hostapd_d
 
 	sta = ap_get_sta(hapd, sa);
 	if (sta) {
-#ifdef CONFIG_IEEE80211BE
-		if (mld_sta && sta->sa_query_timed_out) {
-			if (os_memcmp(mgmt->sa, sta->addr, ETH_ALEN)) {
-				u8 link_id = hapd->mld_link_id;
-
-				os_memcpy(sta->mld_info.links[link_id].peer_addr,
-					  mgmt->sa, ETH_ALEN);
-				if (ap_sta_re_add(hapd, sta, 1) < 0) {
-					resp = WLAN_STATUS_UNSPECIFIED_FAILURE;
-					goto fail;
-				}
-				/*reset sa query timed out flag - since it is readded and moved to unassoc state*/
-				sta->sa_query_timed_out = 0;
-			}
-		}
-#endif /* CONFIG_IEEE80211BE */
 		sta->flags &= ~WLAN_STA_PENDING_FILS_ERP;
 		sta->ft_over_ds = 0;
 		if ((fc & WLAN_FC_RETRY) &&
@@ -5309,6 +5293,10 @@ out:
 					     hapd->mld_link_id, sta->mld_assoc_link_id,
 					     &sta->mld_info, false);
 		}
+	} else {
+		wpa_auth_set_ml_info(origin_sta->wpa_sm,
+				     hapd->mld_link_id, origin_sta->mld_assoc_link_id,
+				     &origin_sta->mld_info, false);
 	}
 
 	return 0;
