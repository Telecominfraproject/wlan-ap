 	if (bw > 20 && !hostapd_get_bonded_chan_entry(freq, bw, center_freq)) {
 		wpa_printf(MSG_ERROR,
@@ -7086,14 +7424,9 @@ hostapd_get_best_ap_6ghz_power_mode(stru
