From 1379fb78d688c602d627d6b67a50e007ab0ce502 Mon Sep 17 00:00:00 2001
From: Vinay Adella <vadella@qti.qualcomm.com>
Date: Mon, 14 Jul 2025 12:41:31 +0530
Subject: [PATCH]  QSDK:CP:hostapd: add support to reload ifaces on events from
  Driver

Driver can indicate hostapd to reload interface by sending events.
These events can indicate if any specific link of the interface or
the complete interface needs to be reloaded.
This is a QCA vendor event with Attributes.

qca-vendor.h
        New sub-cmd QCA_NL80211_VENDOR_SUBCMD_IFACE_RELOAD
        Attribute QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_LINKID

driver_nl80211_event.c
        Process sub-cmd QCA_NL80211_VENDOR_SUBCMD_IFACE_RELOAD along
        with other QCA vendor events
        Parse link ID attribute and pass it up the wpad stack as a
        new wpa_event.

driver.h
driver_common.c
        Add new wpa_event EVENT_IFACE_RELOAD

drv_callbacks.c
        For non-mld bss, just reload the bss only.
        For mld bss, if link_id is invalid, reload all bss in the mld
        For mld bss, if link_id is valid, just reload the bss only.

Signed-off-by: Vinay Adella <vadella@qti.qualcomm.com>
---
 src/ap/drv_callbacks.c                        |  32 +++++++++++++-
 src/common/qca-vendor.h                       |  11 +++++
 src/drivers/driver.h                          |  14 +++++++
 src/drivers/driver_common.c                   |   1 +
 src/drivers/driver_nl80211_event.c            |  39 ++++++++++++++++++
 9 files changed, 96 insertions(+), 1 deletion(-)

--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -3063,9 +3063,10 @@ static void hostapd_event_update_expec_d
 void hostapd_wpa_event(void *ctx, enum wpa_event_type event,
 		       union wpa_event_data *data)
 {
-	struct hostapd_data *hapd = ctx;
+	struct hostapd_data *hapd = ctx, *phapd;
 	struct sta_info *sta;
 	struct hostapd_data *link_hapd;
+	bool found = false;
 
 #ifndef CONFIG_NO_STDOUT_DEBUG
 	int level = MSG_DEBUG;
@@ -3480,6 +3481,35 @@ void hostapd_wpa_event(void *ctx, enum w
 			hostapd_event_update_expec_dur(hapd, &data->ttlm_expec_dur_event);
 		break;
 #endif
+	case EVENT_IFACE_RELOAD:
+		if (!hapd->conf->mld_ap) {
+			if (hostapd_reload_bss_only(hapd) < 0)
+				wpa_printf(MSG_ERROR, "Reloading of BSS failed");
+			break;
+		}
+		if (data->iface_reload.link_id == 0xFF) {
+			/* If link id is invalid reload all bss of the mld interface */
+			for_each_mld_link(phapd, hapd) {
+				if (hostapd_reload_bss_only(phapd) < 0) {
+					wpa_printf(MSG_ERROR, "Reloading of BSS failed");
+					continue;
+				}
+			}
+		} else {
+			for_each_mld_link(phapd, hapd) {
+				if (phapd->mld_link_id == data->iface_reload.link_id) {
+					found = true;
+					break;
+				}
+			}
+			if (!found)
+				return;
+			if (hostapd_reload_bss_only(phapd) < 0) {
+				wpa_printf(MSG_ERROR, "Reloading of BSS failed");
+				return;
+			}
+		}
+		break;
 	default:
 		wpa_printf(MSG_DEBUG, "Unknown event %d", event);
 		break;
--- a/src/common/qca-vendor.h
+++ b/src/common/qca-vendor.h
@@ -1593,6 +1593,7 @@ enum qca_nl80211_vendor_subcmds {
 	QCA_NL80211_VENDOR_SUBCMD_PERIODIC_PROBE_RSP_CFG = 257,
 	QCA_NL80211_VENDOR_SUBCMD_SET_6GHZ_POWER_MODE = 258,
 	QCA_NL80211_VENDOR_SUBCMD_POWER_MODE_CHANGE_COMPLETED = 259,
+	QCA_NL80211_VENDOR_SUBCMD_IFACE_RELOAD = 267
 };
 
 /* Compatibility defines for previously used subcmd names.
@@ -19091,4 +19092,14 @@ enum qca_wlan_vendor_6ghz_power_mode {
 	QCA_WLAN_VENDOR_ATTR_6GHZ_REG_POWER_MODE_MAX =
 	QCA_WLAN_VENDOR_ATTR_6GHZ_REG_POWER_MODE_AFTER_LAST - 1,
 };
+
+enum qca_wlan_vendor_attr_iface_reload {
+	QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_INVALID = 0,
+	QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_LINKID = 1,
+
+	/* Keep last */
+	QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_AFTER_LAST,
+	QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_MAX =
+	QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_AFTER_LAST - 1,
+};
 #endif /* QCA_VENDOR_H */
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -6662,6 +6662,13 @@ enum wpa_event_type {
 	EVENT_AFC_RECEIVED,
 
 	/**
+	 * EVENT_IFACE_RELOAD - Reload BSS
+	 * This event is sent by the driver, if it expects hostapd to reload
+	 * the BSS, for a vendor configuration to complete
+	 */
+	EVENT_IFACE_RELOAD,
+
+	/**
 	 * EVENT_TTLM_UPDATE - Notification about TTLM info update event
 	 */
 	EVENT_TTLM_UPDATE,
@@ -7718,6 +7725,13 @@ union wpa_event_data {
 	} link_removal_event;
 
 	/**
+	 * Data for iface reload event
+	 */
+	struct iface_reload {
+		u8 link_id;
+	} iface_reload;
+
+	/**
 	 * struct ttlm_update_event - Data for EVENT_TTLM_UPDATE
 	 * @link_id: Link for which TTLM update was received
 	 * @status: Type of update received
--- a/src/drivers/driver_common.c
+++ b/src/drivers/driver_common.c
@@ -110,6 +110,7 @@ const char * event_to_string(enum wpa_ev
 	E2S(LINK_REMOVAL_STARTED);
 	E2S(LINK_REMOVAL_COMPLETED);
 	E2S(AFC_RECEIVED);
+	E2S(IFACE_RELOAD);
 	E2S(TTLM_UPDATE);
 	E2S(TTLM_EXPEC_DUR_UPDATE);
 	}
--- a/src/drivers/driver_nl80211_event.c
+++ b/src/drivers/driver_nl80211_event.c
@@ -3951,6 +3951,42 @@ static int copy_afc_chan_obj(struct nlat
 	return 0;
 }
 
+static int
+qca_nl80211_iface_reload(struct i802_bss *bss, u8 *data, size_t len)
+{
+	struct nlattr *tb[QCA_WLAN_VENDOR_ATTR_ACS_MAX + 1];
+	union wpa_event_data event;
+	struct iface_reload *iface_reload;
+	u8 link_id = -1;
+
+	if (!(data && len)) {
+		wpa_printf(MSG_ERROR, "Invalid data length data ptr: %pK ",
+			   data);
+		return -EINVAL;
+	}
+
+	os_memset(&event, 0, sizeof(event));
+	iface_reload = &event.iface_reload;
+
+	if (nla_parse(tb, QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_MAX,
+		      (struct nlattr *) data, len, NULL)) {
+		wpa_printf(MSG_ERROR,
+			   "invalid Iface Reload attribute\n");
+		return -EINVAL;
+	}
+
+	if (tb[QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_LINKID])
+		link_id = nla_get_u8(tb[QCA_WLAN_VENDOR_ATTR_IFACE_RELOAD_LINKID]);
+	else
+		link_id = -1;
+
+	iface_reload->link_id = link_id;
+
+	wpa_supplicant_event(bss->ctx, EVENT_IFACE_RELOAD, &event);
+
+	return 0;
+}
+
 #define NUM_6GHZ_OPCLASS 7
 static int
 qca_nl80211_afc_power_update_completed(struct i802_bss *bss,
@@ -4212,6 +4248,9 @@ static void nl80211_vendor_event_qca(str
 	case QCA_NL80211_VENDOR_SUBCMD_AFC_EVENT:
 		qca_nl80211_handle_afc_events(bss, data, len);
 		break;
+	case QCA_NL80211_VENDOR_SUBCMD_IFACE_RELOAD:
+		qca_nl80211_iface_reload(bss, data, len);
+		break;
 	default:
 		wpa_printf(MSG_DEBUG,
 			   "nl80211: Ignore unsupported QCA vendor event %u",
