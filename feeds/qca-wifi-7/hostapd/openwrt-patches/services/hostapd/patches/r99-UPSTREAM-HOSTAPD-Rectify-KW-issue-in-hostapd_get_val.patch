From 98983e300b437406b0a474e234ac59075f52f697 Mon Sep 17 00:00:00 2001
From: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
Date: Fri, 5 Sep 2025 11:56:28 +0530
Subject: [PATCH] UPSTREAM:HOSTAPD: Rectify KW issue in hostapd_get_valid_pp

In hostapd_get_valid_pp, add a sanity check for bw_pp_arr, to prevent
NULL pointer dereference.

Patch-dependency: r82-a-UPSTREAM-PROTOCOL-hostapd-Add-support-for-6-GHz-dyna.patch
Tag: 6G_REGULATORY
Fixes: Id4822cde776 ('UPSTREAM: PROTOCOL: hostapd: Add support for 6 GHz dynamic puncturing')

Signed-off-by: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
---
 src/ap/hostapd.c | 7 +++++++
 1 file changed, 7 insertions(+)

--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -7428,6 +7428,12 @@ hostapd_get_valid_pp(u16 *pp, u16 bw, u1
 	u16 i;
 
 	bw_pp_arr = hostapd_get_valid_puncture_pattern_arr(bw, &num_pp, &pp_mask);
+	if (!bw_pp_arr) {
+		wpa_printf(MSG_ERROR,
+			   "No valid puncture pattern array for bw %d", bw);
+		return -1;
+	}
+
 	for  (i = 0; i < num_pp; i++) {
 		if (hostapd_is_pp_subset_and_valid(*pp, bw_pp_arr[i],
 						   pp_mask, pri_chan_pos)) {
