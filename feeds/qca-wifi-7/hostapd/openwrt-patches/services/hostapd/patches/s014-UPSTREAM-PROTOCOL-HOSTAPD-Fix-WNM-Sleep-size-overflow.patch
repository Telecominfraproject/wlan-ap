From 448b1c1c7d1b2a826cac35f8b1d0d0e511728bbd Mon Sep 17 00:00:00 2001
From: Shreedhar Parande <sparande@qti.qualcomm.com>
Date: Fri, 19 Sep 2025 23:17:53 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:HOSTAPD: Fix WNM Sleep size overflow
 causing heap corruption in MLD

Use of `uint8_t` for `wnmsleep_subie_size` causes overflow
when the computed subelement size (348) exceeds the 255
limit. This wraps the value to 92, resulting in buffer
misallocation and memory corruption. Heap corruption occurs
during WNM Sleep frame construction in 3-link MLD
association scenarios.

Change the type of `wnmsleep_subie_size` to `uint16_t` to
handle larger values correctly and prevent overflow.

Patch-dependency: r69-001-UPSTREAM-PROTOCOL-hostapd-Add-MLO-support-for-WNM-Sleep.patch
Patch-work: None
Fixes: I1cd80690567 ('UPSTREAM:PROTOCOL:HOSTAPD: Add MLO support for WNM Sleep')

Signed-off-by: Shreedhar Parande <sparande@qti.qualcomm.com>
---
 src/ap/wnm_ap.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/ap/wnm_ap.c b/src/ap/wnm_ap.c
index da7c4fc..144d46a 100644
--- a/src/ap/wnm_ap.c
+++ b/src/ap/wnm_ap.c
@@ -173,7 +173,8 @@ static int ieee802_11_send_wnmsleep_resp(struct hostapd_data *hapd,
 	struct wnm_sleep_element wnmsleep_ie;
 	u8 *wnmtfs_ie, *oci_ie;
 	u8 wnmsleep_ie_len, oci_ie_len;
-	u8 wnmsleep_subie_size, n_mld_affiliated_links;
+	u16 wnmsleep_subie_size;
+	u8 n_mld_affiliated_links;
 	u16 wnmtfs_ie_len;
 	u8 *pos;
 	struct sta_info *sta;
-- 
