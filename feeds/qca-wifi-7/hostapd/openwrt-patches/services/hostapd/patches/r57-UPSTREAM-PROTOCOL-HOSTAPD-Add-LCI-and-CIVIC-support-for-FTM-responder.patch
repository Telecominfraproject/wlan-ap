From 24f310d644813721e373354f1460da62c61b0210 Mon Sep 17 00:00:00 2001
From: Shreedhar Parande <quic_sparande@quicinc.com>
Date: Tue, 21 Jan 2025 23:39:01 +0530
Subject: [PATCH] QSDK:PROTOCOL:HOSTAPD: Add LCI and CIVIC support for FTM
 responder

Add LCI and CIVIC configuration support for FTM
responder mode as per 9.4.2.27 of IEEE Std 802.11-2016.
LCI and LCR values are sent via
ATTR to wireless driver.

Signed-off-by: Shreedhar Parande <quic_sparande@quicinc.com>
---
 hostapd/config_file.c        |  8 ++++++++
 src/ap/beacon.c              |  8 ++++++--
 src/ap/ieee802_11_shared.c   | 10 ++++++++++
 src/common/ieee802_11_defs.h |  2 +-
 src/drivers/driver_nl80211.c | 20 +++++++++++---------
 5 files changed, 36 insertions(+), 12 deletions(-)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 5104a79..078efdf 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -4789,6 +4789,14 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 		if (atoi(pos))
 			bss->radio_measurements[0] |=
 				WLAN_RRM_CAPS_LINK_MEASUREMENT;
+	} else if (os_strcmp(buf, "rrm_lci_measurement") == 0) {
+		if (atoi(pos))
+			bss->radio_measurements[1] |=
+				WLAN_RRM_CAPS_LCI_MEASUREMENT;
+	} else if (os_strcmp(buf, "rrm_civic_measurement") == 0) {
+		if (atoi(pos))
+			bss->radio_measurements[4] |=
+				WLAN_RRM_CAPS_CIVIC_LOCATION_MEASUREMENT;
 	} else if (os_strcmp(buf, "gas_address3") == 0) {
 		bss->gas_address3 = atoi(pos);
 	} else if (os_strcmp(buf, "stationary_ap") == 0) {
diff --git a/src/ap/beacon.c b/src/ap/beacon.c
index 8e8f2c0..5e15b16 100644
--- a/src/ap/beacon.c
+++ b/src/ap/beacon.c
@@ -2898,8 +2898,12 @@ int ieee802_11_build_ap_params(struct hostapd_data *hapd,
 	if (hapd->conf->ftm_responder) {
 		if (hapd->iface->drv_flags & WPA_DRIVER_FLAGS_FTM_RESPONDER) {
 			params->ftm_responder = 1;
-			params->lci = hapd->iface->conf->lci;
-			params->civic = hapd->iface->conf->civic;
+			if (hapd->conf->radio_measurements[1] &
+			    WLAN_RRM_CAPS_LCI_MEASUREMENT)
+				params->lci = hapd->iface->conf->lci;
+			if (hapd->conf->radio_measurements[4] &
+			    WLAN_RRM_CAPS_CIVIC_LOCATION_MEASUREMENT)
+				params->civic = hapd->iface->conf->civic;
 		} else {
 			wpa_printf(MSG_WARNING,
 				   "Not configuring FTM responder as the driver doesn't advertise support for it");
diff --git a/src/ap/ieee802_11_shared.c b/src/ap/ieee802_11_shared.c
index d097060..33e6843 100644
--- a/src/ap/ieee802_11_shared.c
+++ b/src/ap/ieee802_11_shared.c
@@ -383,6 +383,16 @@ static void hostapd_ext_capab_byte(struct hostapd_data *hapd, u8 *pos, int idx,
 			/* Bit 13 - Collocated Interference Reporting */
 			*pos |= 0x20;
 		}
+		if ((hapd->conf->radio_measurements[1] &
+		     WLAN_RRM_CAPS_LCI_MEASUREMENT) &&
+		    hapd->iface->conf->lci) {
+			*pos |= 0x40; /* Bit 14 - Civic Location */
+		}
+		if ((hapd->conf->radio_measurements[4] &
+		     WLAN_RRM_CAPS_CIVIC_LOCATION_MEASUREMENT) &&
+		    hapd->iface->conf->civic) {
+			*pos |= 0x80; /* Bit 15 - Geospatial Location*/
+		}
 		break;
 	case 2: /* Bits 16-23 */
 		if (hapd->conf->wnm_sleep_mode)
diff --git a/src/common/ieee802_11_defs.h b/src/common/ieee802_11_defs.h
index 0ecd7f1..87b4a67 100644
--- a/src/common/ieee802_11_defs.h
+++ b/src/common/ieee802_11_defs.h
@@ -789,7 +789,7 @@
 #define WLAN_RRM_CAPS_LCI_MEASUREMENT BIT(4)
 /* byte 5 (out of 5) */
 #define WLAN_RRM_CAPS_FTM_RANGE_REPORT BIT(2)
-
+#define WLAN_RRM_CAPS_CIVIC_LOCATION_MEASUREMENT BIT(3)
 /*
  * IEEE Std 802.11-2020, 9.4.2.20.19 (Fine Timing Measurement Range
  * request) - Minimum AP Count
diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 01a9f39..e10f269 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -5489,15 +5489,17 @@ static int wpa_driver_nl80211_set_ap(void *priv,
 
 		ftm = nla_nest_start(msg, NL80211_ATTR_FTM_RESPONDER);
 		if (!ftm ||
-		    nla_put_flag(msg, NL80211_FTM_RESP_ATTR_ENABLED) ||
-		    (params->lci &&
-		     nla_put(msg, NL80211_FTM_RESP_ATTR_LCI,
-			     wpabuf_len(params->lci),
-			     wpabuf_head(params->lci))) ||
-		    (params->civic &&
-		     nla_put(msg, NL80211_FTM_RESP_ATTR_CIVICLOC,
-			     wpabuf_len(params->civic),
-			     wpabuf_head(params->civic))))
+		    nla_put_flag(msg, NL80211_FTM_RESP_ATTR_ENABLED))
+			goto fail;
+		if (params->lci &&
+		    nla_put(msg, NL80211_FTM_RESP_ATTR_LCI,
+			    wpabuf_len(params->lci),
+			    wpabuf_head(params->lci)))
+			goto fail;
+		if (params->civic &&
+		    nla_put(msg, NL80211_FTM_RESP_ATTR_CIVICLOC,
+			    wpabuf_len(params->civic),
+			    wpabuf_head(params->civic)))
 			goto fail;
 		nla_nest_end(msg, ftm);
 	}
-- 
2.34.1

