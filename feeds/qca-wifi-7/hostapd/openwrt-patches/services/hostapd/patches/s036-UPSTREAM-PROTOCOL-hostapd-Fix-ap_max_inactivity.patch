From 748d8b35a7e51a43470513bd7f1b535872d4dde7 Mon Sep 17 00:00:00 2001
From: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
Date: Mon, 1 Dec 2025 09:53:41 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL:hostapd: Fix ap_max_inactivity timer
 handling during TTLM

Currently the inactivity timer is incorrectly scheduled on links
that become disabled after TTLM negotiation, causing deauthentication.
To address this, an `enabled_links_bitmap` is  introduced to track
active links, and the timer is now configured only for links that are
enabled. Disabled links will no longer have the ap_max_inactivity timer,
preventing disconnections.

Patch-dependency: s024-UPSTREAM-PROTOCOL-hostapd-Fix-client-
		  disconnection-d.patch
Patch-work: None

Fixes: I349d3ae55db0(UPSTREAM:PROTOCOL:hostapd: Fix the client
disconnection during load balancing)

Signed-off-by: Dhanavandhana Kannan <dhanavan@qti.qualcomm.com>
---
 src/ap/ttlm.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

--- a/src/ap/ttlm.c
+++ b/src/ap/ttlm.c
@@ -1305,6 +1305,7 @@ void hostapd_handle_ttlm_req(struct host
 	const u8 *pos;
 	size_t ie_len;
 	int retval, i;
+	u16 enabled_links_bitmap = 0;
 
 	if (!hapd->conf->ttlm_enable) {
 		wpa_printf(MSG_ERROR, "TTLM negotiation support is disabled");
@@ -1342,6 +1343,8 @@ void hostapd_handle_ttlm_req(struct host
 			ongoing_ttlm->ttlm_resp_type = TTLM_RESP_TYPE_SUCCESS;
 			os_memcpy(&ongoing_ttlm->ttlm_info[ttlm_info.direction],
 				  &ttlm_info, sizeof(struct ttlm_info));
+			/* consider TID0 for now as we support only homogeneous mapping */
+			enabled_links_bitmap |= ttlm_info.ieee_link_map_tid[0];
 		} else {
 			wpa_printf(MSG_ERROR, "Failed to parse TTLM IE");
 			os_free(ongoing_ttlm);
@@ -1362,8 +1365,11 @@ void hostapd_handle_ttlm_req(struct host
 		if (lsta && lsta->mld_info.mld_sta &&
 		    lsta->timeout_next == STA_DISASSOC_FROM_CLI) {
 			eloop_cancel_timeout(ap_handle_timer, lhapd, lsta);
-			eloop_register_timeout(lhapd->conf->ap_max_inactivity, 0,
-					       ap_handle_timer, lhapd, lsta);
+			if (BIT(lhapd->mld_link_id) & enabled_links_bitmap) {
+				lsta->timeout_next = STA_NULLFUNC;
+				eloop_register_timeout(lhapd->conf->ap_max_inactivity, 0,
+						       ap_handle_timer, lhapd, lsta);
+			}
 			wpa_printf(MSG_DEBUG, "BTM timer cancelled for the client");
 		}
 	}
