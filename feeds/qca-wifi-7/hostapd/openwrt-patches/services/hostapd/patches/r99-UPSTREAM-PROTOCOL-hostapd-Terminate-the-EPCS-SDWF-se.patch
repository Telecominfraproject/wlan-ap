From d3c935647b237fe130a911ba4655c0cdb1e971df Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Thu, 14 Aug 2025 14:37:53 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Terminate the EPCS SDWF session
 only if it is enabled

Terminate the EPCS SDWF Session, only if the current EPCS state of the
MLD STA is EPCS_STATE_ENABLED. Reset the EPCS state of MLD STA to
EPCS_STATE_DISABLED after the SDWF session is successfully terminated.

Tag: EPCS

Fixes: Ib510869b17353f1176e47927ab5414549170c2cd (UPSTREAM:PROTOCOL: hostapd: Configure nftables for EPCS)

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 src/ap/sta_info.c | 9 ++++++---
 1 file changed, 6 insertions(+), 3 deletions(-)

diff --git a/src/ap/sta_info.c b/src/ap/sta_info.c
index e9b03ab..f15bda2 100644
--- a/src/ap/sta_info.c
+++ b/src/ap/sta_info.c
@@ -659,9 +659,12 @@ void ap_free_sta(struct hostapd_data *hapd, struct sta_info *sta)
 	os_free(sta->ifname_wds);
 
 #ifdef CONFIG_IEEE80211BE
-
-	wpa_printf(MSG_INFO, "EPCS Tear Down from AP free STA");
-	hostapd_configure_epcs(hapd, sta, QM_REMOVE_REQ);
+	if (sta->mld_info.mld_sta &&
+	    sta->mld_info.epcs.state == EPCS_STATE_ENABLED) {
+		wpa_printf(MSG_INFO, "EPCS Tear Down from AP free STA");
+		if (!hostapd_configure_epcs(hapd, sta, QM_REMOVE_REQ))
+			sta->mld_info.epcs.state = EPCS_STATE_DISABLED;
+	}
 	eloop_cancel_timeout(hostapd_epcs_timeout_handler, hapd, sta);
 	ap_sta_free_sta_profile(&sta->mld_info);
 	ml_deinit_link_reconf_req(&sta->reconf_req);
-- 
