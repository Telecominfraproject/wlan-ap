From fcf1ff2fdac3f09c460c1f0a8ed2e2b8aee8d05a Mon Sep 17 00:00:00 2001
From: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
Date: Sat, 20 Sep 2025 14:48:23 +0530
Subject: [PATCH] UPSTREAM: PROTOCOL: hostapd: keep assoc flag for links added
 during ML reconfig

During ML reconfiguration, adding a new link for an already associated
station can cause the station to be removed by the association timeout
handler in ap_sta_assoc_timeout(), because the new link is not marked
as associated. This makes a valid ML reconfig look like an incomplete
association and leads to deauthentication.

Fix this by preserving the WLAN_STA_ASSOC flag from the origin station
when processing a Link Reconfiguration Request, so that the station
remains marked as associated during ML reconfig link addition.

Signed-off-by: Hari Naraayana Desikan Kannan <hnaraaya@qti.qualcomm.com>
---
 src/ap/ieee802_11.c | 5 +++++
 1 file changed, 5 insertions(+)

--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -5135,10 +5135,14 @@ int ieee80211_ml_process_link(struct hos
 			goto out;
 		}
 	}
 
 	sta->flags = (origin_sta->flags & WLAN_STA_AUTH);
+
+	if (type == LINK_PARSE_RECONF)
+		sta->flags |= (origin_sta->flags & WLAN_STA_ASSOC);
+
 	sta->mld_assoc_link_id = origin_sta->mld_assoc_link_id;
 	sta->sa_query_timed_out = origin_sta->sa_query_timed_out;
 	sta->wpa_sm = origin_sta->wpa_sm;
 	ap_sta_set_mld(sta, true);
 
