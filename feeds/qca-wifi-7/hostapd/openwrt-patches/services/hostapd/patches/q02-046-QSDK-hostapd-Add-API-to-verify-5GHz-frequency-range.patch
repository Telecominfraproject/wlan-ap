From d451698798c2767d380aa723294f232b535d9f84 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Thu, 24 Jul 2025 14:59:17 +0530
Subject: [PATCH] QSDK:hostapd: Add API to verify 5GHz frequency range

Add API to verify if a given frequency is in the 5GHz frequency range. This
helps to identify if a particular channel's frequency is supported by 5G.

Signed-off-by: Karthik M <karm@qti.qualcomm.com>
Signed-off-by: Ramya Gnanasekar <rgnanase@qti.qualcomm.com>
Signed-off-by: Hari Chandrakanthan <haric@qti.qualcomm.com>
Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Signed-off-by: Venkateswara Swamy Bandaru <vbandaru@qti.qualcomm.com>
---
 src/common/ieee802_11_common.c | 7 +++++++
 src/common/ieee802_11_common.h | 1 +
 2 files changed, 8 insertions(+)

diff --git a/src/common/ieee802_11_common.c b/src/common/ieee802_11_common.c
index 1e72c4b..692d9e4 100644
--- a/src/common/ieee802_11_common.c
+++ b/src/common/ieee802_11_common.c
@@ -2940,6 +2940,13 @@ int center_idx_to_bw_6ghz(u8 idx)
 	return -1;
 }
 
+bool is_5ghz_freq(int freq)
+{
+	if ((freq >= 5180 && freq < 5600) ||
+	    (freq >= 5660 && freq < 5825))
+		return true;
+	return false;
+}
 
 bool is_6ghz_freq(int freq)
 {
diff --git a/src/common/ieee802_11_common.h b/src/common/ieee802_11_common.h
index 5a49692..0b05c6f 100644
--- a/src/common/ieee802_11_common.h
+++ b/src/common/ieee802_11_common.h
@@ -300,6 +300,7 @@ u8 country_to_global_op_class(const char *country, u8 op_class);
 
 const struct oper_class_map * get_oper_class(const char *country, u8 op_class);
 int oper_class_bw_to_int(const struct oper_class_map *map);
+bool is_5ghz_freq(int freq);
 int center_idx_to_bw_6ghz(u8 idx);
 bool is_6ghz_freq(int freq);
 bool is_6ghz_op_class(u8 op_class);
-- 
