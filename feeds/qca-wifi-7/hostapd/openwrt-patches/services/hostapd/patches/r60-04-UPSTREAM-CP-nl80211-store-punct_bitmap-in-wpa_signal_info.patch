From 806668f8950700d807788a5ab0e9bb868b18a125 Mon Sep 17 00:00:00 2001
From: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
Date: Mon, 13 Jan 2025 13:14:24 -0800
Subject: [PATCH 4/4] UPSTREAM:CP:nl80211: store punct_bitmap in wpa_signal_info

Add support in get_channel_width() and get_links_channel_width()
to parse and store puncturing bitmap sent by kernel in
structure wpa_signal_info. Userspace can retrieve this information
by calling signal_poll/mlo_signal_poll commands.

Patch-dependency:
r60-01-CP-wpa_supplicant-add-punct_bitmap-to-signal-poll-co.patch

Signed-off-by: Aloka Dixit <aloka.dixit@oss.qualcomm.com>
---
 src/drivers/driver_nl80211.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 01a9f3984d5c..91fb991f1d00 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -10145,6 +10145,9 @@ static int get_channel_width(struct nl_msg *msg, void *arg)
 		if (tb[NL80211_ATTR_CENTER_FREQ2])
 			sig_change->center_frq2 =
 				nla_get_u32(tb[NL80211_ATTR_CENTER_FREQ2]);
+		if (tb[NL80211_ATTR_PUNCT_BITMAP])
+			sig_change->punct_bitmap =
+				nla_get_u32(tb[NL80211_ATTR_PUNCT_BITMAP]);
 	}
 
 	return NL_SKIP;
@@ -10280,6 +10283,10 @@ static int get_links_channel_width(struct nl_msg *msg, void *arg)
 		if (tb2[NL80211_ATTR_CENTER_FREQ2])
 			mlo_sig->links[link_id].center_frq2 =
 				nla_get_u32(tb2[NL80211_ATTR_CENTER_FREQ2]);
+
+		if (tb2[NL80211_ATTR_PUNCT_BITMAP])
+			mlo_sig->links[link_id].punct_bitmap =
+				nla_get_u32(tb2[NL80211_ATTR_PUNCT_BITMAP]);
 	}
 
 	return NL_SKIP;
-- 
