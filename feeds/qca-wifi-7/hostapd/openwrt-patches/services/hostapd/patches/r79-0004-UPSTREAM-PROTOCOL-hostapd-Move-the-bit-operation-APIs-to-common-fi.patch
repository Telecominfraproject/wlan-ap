From d9af73d75d9b6b3f615414f596e4ec382405d256 Mon Sep 17 00:00:00 2001
From: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
Date: Tue, 1 Apr 2025 12:40:38 +0530
Subject: [PATCH 04/20] UPSTREAM:PROTOCOL: hostapd: Move the bit operation APIs
 to common files

Move the APIs which extract and set specific bits of a value from config file
to the common file for ease of use.
These APIs are used to set the config params - aci, aifsn, acm values into the
ACI param value and ecw_min, ecw_max values into the ECW param value of
epcs_he_muedca params.

Signed-off-by: Sri Vidya Gunturi <sgunturi@qti.qualcomm.com>
---
 hostapd/config_file.c | 20 --------------------
 src/utils/common.c    | 20 ++++++++++++++++++++
 src/utils/common.h    |  6 ++++++
 3 files changed, 26 insertions(+), 20 deletions(-)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 8de366a..0aa54a0 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -1161,26 +1161,6 @@ static int hostapd_config_vht_capab(struct hostapd_config *conf,
 
 #ifdef CONFIG_IEEE80211AX
 
-static u8 find_bit_offset(u8 val)
-{
-	u8 res = 0;
-
-	for (; val; val >>= 1) {
-		if (val & 1)
-			break;
-		res++;
-	}
-
-	return res;
-}
-
-
-static u8 set_he_cap(int val, u8 mask)
-{
-	return (u8) (mask & (val << find_bit_offset(mask)));
-}
-
-
 static int hostapd_parse_he_srg_bitmap(u8 *bitmap, char *val)
 {
 	int bitpos;
diff --git a/src/utils/common.c b/src/utils/common.c
index d62dec7..c02725d 100644
--- a/src/utils/common.c
+++ b/src/utils/common.c
@@ -1315,3 +1315,23 @@ void forced_memzero(void *ptr, size_t len)
 	if (len)
 		forced_memzero_val = ((u8 *) ptr)[0];
 }
+
+#ifdef CONFIG_IEEE80211AX
+u8 find_bit_offset(u8 val)
+{
+	u8 res = 0;
+
+	for (; val; val >>= 1) {
+		if (val & 1)
+			break;
+		res++;
+	}
+
+	return res;
+}
+
+u8 set_he_cap(int val, u8 mask)
+{
+	return (u8) (mask & (val << find_bit_offset(mask)));
+}
+#endif /*CONFIG_IEEE80211AX*/
diff --git a/src/utils/common.h b/src/utils/common.h
index 1dc2ea5..15af810 100644
--- a/src/utils/common.h
+++ b/src/utils/common.h
@@ -641,6 +641,12 @@ void forced_memzero(void *ptr, size_t len);
  * in the future to handle these cases.
  */
 void * __hide_aliasing_typecast(void *foo);
+
+#ifdef CONFIG_IEEE80211AX
+u8 find_bit_offset(u8 val);
+u8 set_he_cap(int val, u8 mask);
+#endif /*CONFIG_IEEE80211AX*/
+
 #define aliasing_hide_typecast(a,t) (t *) __hide_aliasing_typecast((a))
 
 #ifdef CONFIG_VALGRIND
-- 
2.34.1

