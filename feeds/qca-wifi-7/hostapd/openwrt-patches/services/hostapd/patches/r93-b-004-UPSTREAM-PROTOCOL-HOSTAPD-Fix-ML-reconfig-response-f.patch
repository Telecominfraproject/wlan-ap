From b2eefc973d6068c2e37dff33f7e571c60902a584 Mon Sep 17 00:00:00 2001
From: Mohan Kumar G <mkumarg@qti.qualcomm.com>
Date: Wed, 23 Jul 2025 15:27:54 +0530
Subject: [PATCH 4/4] UPSTREAM:PROTOCOL:HOSTAPD: Fix ML reconfig response frame
 length

Currently, when including Multi-link element for the reconfig response
frame length the functions hostapd_eid_eht_ml_len() and
hostapd_eid_eht_ml_common() have different values for parameters
mld_id, ext_cap and bpcc.

Fix this mismatch by only including BPCC and not including mld id and
ext_cap similar to assoc response. Also, fix the calculation of
mle length while fragmentation occurs.

Patch-work: None

Depends-on: None

Feature: ML_RECONFIG

Signed-off-by: Mohan Kumar G <mkumarg@qti.qualcomm.com>
---
 src/ap/ieee802_11_eht.c | 9 ++++++---
 1 file changed, 6 insertions(+), 3 deletions(-)

diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index d130907..115dfab 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -861,7 +861,8 @@ static size_t hostapd_eid_eht_ml_len(struct mld_info *info,
 	len += 3;
 
 	/* Fragmentation headers; +1 for shorter first chunk */
-	len += (eht_ml_len + 1) / 255 * 2;
+	if (eht_ml_len > 254)
+		len += (eht_ml_len + 1) / 255 * 2;
 
 	return len;
 }
@@ -1919,7 +1920,7 @@ hostapd_send_link_reconf_resp(struct hostapd_data *hapd,
 			link->valid = true;
 			ieee80211_ml_build_assoc_resp(lhapd, NULL, assoc_sta, link);
 		}
-		mle_len = hostapd_eid_eht_ml_len(&mld, false, true, WLAN_FC_STYPE_ACTION);
+		mle_len = hostapd_eid_eht_ml_len(&mld, false, false, WLAN_FC_STYPE_ASSOC_RESP);
 		len += mle_len;
 	}
 
@@ -2017,8 +2018,10 @@ hostapd_send_link_reconf_resp(struct hostapd_data *hapd,
 		u8 *mle_pos = pos;
 
 		mle_pos = hostapd_eid_eht_basic_ml_common(hapd, mle_pos, &mld,
-							  true, 0, WLAN_FC_STYPE_ACTION);
+							  false, false, WLAN_FC_STYPE_ASSOC_RESP);
 		if ((mle_pos - pos) != mle_len) {
+			wpa_printf(MSG_DEBUG, "MLD: ML reconfig: BMLE length mismatch mle_len=%zu (mle_pos - pos)=%td",
+				   mle_len, (mle_pos - pos));
 			reject_all = true;
 			goto reject_all_req;
 		}
-- 
