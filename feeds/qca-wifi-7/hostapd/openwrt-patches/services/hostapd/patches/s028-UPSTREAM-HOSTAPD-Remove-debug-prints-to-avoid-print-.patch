From 40107ef6894f0e7449c60d75726e6fc74993e1b9 Mon Sep 17 00:00:00 2001
From: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
Date: Mon, 17 Nov 2025 15:01:30 +0530
Subject: [PATCH] UPSTREAM: HOSTAPD: Remove debug prints to avoid print flood

The 6 GHz channel information related to TPE IE, keeps getting saved in the
syslog and fills up the syslog quickly. This causes the useful Hostapd
debug information between AP and STA to get missed out in the syslog,
for example, the peer level error classification is absent.

Fix this issue by removing the channel related debug prints in
set_ieee_order_chan_list() and get_psd_for_chan_idx()

Tag: 6G_REGULATORY
Patch-dependency: r85-00-UPSTREAM-PROTOCOL-hostapd-Handle-TPE-PSD-for-punctur.patch
Fixes: I07726d48d7f ('UPSTREAM:PROTOCOL:hostapd:Handle TPE PSD for punctured and non-punctured 6 GHz channels')

Signed-off-by: Hariharan Basuthkar <hbasuthk@qti.qualcomm.com>
---
 src/ap/ieee802_11.c | 7 -------
 1 file changed, 7 deletions(-)

diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index 1a7ae19..94577c5 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -8566,11 +8566,6 @@ static int set_ieee_order_chan_list(struct hostapd_hw_modes *mode,
 
 	wpa_printf(MSG_DEBUG, "Set IEEE 6GHz channel list with %d channels",
 		   chan_data->num_channels);
-	for (i = 0; i < chan_data->num_channels; i++) {
-		wpa_printf(MSG_DEBUG, "Channel %d: freq %d MHz, flags 0x%x",
-			   channels[i].chan, channels[i].freq,
-			   channels[i].flag);
-	}
 
 	return 0;
 }
@@ -9092,8 +9087,6 @@ static s8 get_psd_for_chan_idx(struct hostapd_data *hapd,
 			reg_psd = reg_eirp_pwr - CONV_20MHZ_EIRP_TO_PSD_IN_DBM;
 		}
 
-		wpa_printf(MSG_DEBUG, "Using reg_psd:%d for channel %d",
-			   reg_psd, chan_data.channels[non_11be_start_idx].chan);
 		return reg_psd;
 	}
 
