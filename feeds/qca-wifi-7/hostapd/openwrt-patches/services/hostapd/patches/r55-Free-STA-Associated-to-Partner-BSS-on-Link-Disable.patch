From ff24e129dc30a7c90dbb9da578a7327205fdb2dc Mon Sep 17 00:00:00 2001
From: Hari Naraayana Desikan Kannan <quic_hnaraaya@quicinc.com>
Date: Mon, 9 Dec 2024 16:17:05 +0530
Subject: [PATCH] Free STA Associated to Partner BSS on Link Disable

Currently, when a link is disabled and a STA is associated
as a partner link to the current link, a broadcast deauth is sent,
and the STA gets disconnected. However, since the STA is connected
only as a partner link (non-assoc link), the STA reference is not
deleted and is only removed after the maximum inactivity time.

This causes an issue where the STA tries to associate after deauth
but fails because the STA reference remains.

To address this issue, when a link is disabled, check if the STA
is a partner link of the currently disabled BSS and remove the STA
reference, allowing the STA to retry association.

Signed-off-by: Hari Naraayana Desikan Kannan <quic_hnaraaya@quicinc.com>
---
 src/ap/hostapd.c  |  2 ++
 src/ap/sta_info.c | 30 ++++++++++++++++++++++++++++++
 2 files changed, 32 insertions(+)

--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -1075,6 +1075,9 @@ static int hostapd_flush_old_stations(st
 
 void hostapd_bss_deinit_no_free(struct hostapd_data *hapd)
 {
+#ifdef CONFIG_IEEE80211BE
+	ap_for_each_sta(hapd, hostapd_free_partner_link_stas, NULL);
+#endif /* CONFIG_IEEE80211BE */
 	hostapd_free_stas(hapd);
 	hostapd_flush_old_stations(hapd, WLAN_REASON_DEAUTH_LEAVING);
 #ifdef CONFIG_WEP
--- a/src/ap/sta_info.c
+++ b/src/ap/sta_info.c
@@ -597,6 +597,34 @@ void set_valid_for_each_partner_link_sta
 			lsta->mld_info.links[hapd->mld_link_id].valid = valid;
 	}
 }
+
+
+int hostapd_free_partner_link_stas(struct hostapd_data *hapd,
+				   struct sta_info *sta,
+				   void *ctx)
+{
+	struct sta_info *lsta;
+	struct hostapd_data *lhapd;
+
+	if (!hostapd_is_mld_ap(hapd))
+		return -1;
+
+	for_each_mld_link(lhapd, hapd) {
+		if (hapd == lhapd)
+			continue;
+
+		lsta = ap_get_sta(lhapd, sta->addr);
+		if (lsta && ap_sta_is_mld(lhapd, lsta) &&
+		    lsta->mld_info.links[hapd->mld_link_id].valid) {
+			wpa_printf(MSG_DEBUG, "Removing link station " MACSTR,
+				   MAC2STR(lsta->addr));
+			mlme_deletekeys_request(lhapd, lsta);
+			ap_free_sta(lhapd, lsta);
+		}
+	}
+
+	return 0;
+}
 #endif /* CONFIG_IEEE80211BE */
 
 
--- a/src/ap/sta_info.h
+++ b/src/ap/sta_info.h
@@ -481,4 +481,8 @@ void hostapd_free_link_stas(struct hosta
 void set_valid_for_each_partner_link_sta(struct hostapd_data *hapd,
                                            struct sta_info *psta,
                                            int valid);
+
+int hostapd_free_partner_link_stas(struct hostapd_data *hapd,
+				   struct sta_info *sta,
+				   void *ctx);
 #endif /* STA_INFO_H */
