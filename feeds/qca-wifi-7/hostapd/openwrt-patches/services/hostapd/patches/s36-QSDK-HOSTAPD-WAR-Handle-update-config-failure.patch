From 69b32811c3300aac794daca84ad46673c91c21f5 Mon Sep 17 00:00:00 2001
From: Arunpandi Kannan <arunpand@qti.qualcomm.com>
Date: Mon, 8 Dec 2025 14:36:52 +0530
Subject: [PATCH] QSDK:HOSTAPD: [WAR]: Handle update config failure

In STA /var/run folder runs in root permission whereas supplicant
process runs in network user permission. Due to that supplicant process
cannot update any file from /var/run folder. so update_config fails
as it tries to update .conf file in /var/run folder.

As a fix create temporary .conf file in /tmp folder and update the latest
config. This retrived by DPP action scripts and updated in wireless config
file to retain the config across restarts.

Patch-dependency: None
Patch-work: None

Signed-off-by: Arunpandi Kannan <arunpand@qti.qualcomm.com>
---
 wpa_supplicant/config_file.c | 34 ++++++++++++++++++++++++++++++++--
 1 file changed, 32 insertions(+), 2 deletions(-)

diff --git a/wpa_supplicant/config_file.c b/wpa_supplicant/config_file.c
index 7000bf2..27209ce 100644
--- a/wpa_supplicant/config_file.c
+++ b/wpa_supplicant/config_file.c
@@ -1804,6 +1804,7 @@ int wpa_config_write(const char *name, struct wpa_config *config)
 	const char *orig_name = name;
 	int tmp_len;
 	char *tmp_name;
+	char *conf_file;
 
 	if (!name) {
 		wpa_printf(MSG_ERROR, "No configuration file for writing");
@@ -1815,17 +1816,46 @@ int wpa_config_write(const char *name, struct wpa_config *config)
 	if (tmp_name) {
 		os_snprintf(tmp_name, tmp_len, "%s.tmp", name);
 		name = tmp_name;
+	} else {
+		wpa_printf(MSG_ERROR,"Failed to allocate memory for conf path");
+		return -1;
 	}
-
 	wpa_printf(MSG_DEBUG, "Writing configuration file '%s'", name);
 
 	f = fopen(name, "w");
 	if (f == NULL) {
 		wpa_printf(MSG_DEBUG, "Failed to open '%s' for writing", name);
 		os_free(tmp_name);
-		return -1;
+		/*if writinging to /var/run/supplicant.conf write fails write it to
+		 * tmp/supplicant.conf
+		 */
+		name = orig_name;
+		conf_file = strrchr(name, '/');
+		if (conf_file == NULL) {
+			wpa_printf(MSG_ERROR, "Invalid config file path");
+			return -1;
+		}
+		conf_file++;
+		tmp_len = os_strlen(conf_file) + 6; /* allow space for /tmp/ prefix */
+		tmp_name = os_malloc(tmp_len);
+		if (tmp_name) {
+			os_snprintf(tmp_name, tmp_len, "%s%s", "/tmp/", conf_file);
+			name = tmp_name;
+		} else {
+			wpa_printf(MSG_ERROR,"Failed to allocate memory for conf path");
+			return -1;
+		}
+		wpa_printf(MSG_DEBUG, "Writing configuration file '%s'", name);
+
+		f = fopen(name, "w");
+		if (f == NULL) {
+			wpa_printf(MSG_DEBUG, "Failed to open '%s' for writing", name);
+			os_free(tmp_name);
+			return -1;
+		}
 	}
 
+
 	wpa_config_write_global(f, config);
 
 	for (cred = config->cred; cred; cred = cred->next) {
-- 
