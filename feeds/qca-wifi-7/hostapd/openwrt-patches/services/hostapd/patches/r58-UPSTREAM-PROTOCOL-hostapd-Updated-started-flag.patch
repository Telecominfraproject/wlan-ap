From 34bb3a93c27b57126acb6061782d3c16dfb97136 Mon Sep 17 00:00:00 2001
From: Manish Dharanenthiran <quic_mdharane@quicinc.com>
Date: Tue, 21 Jan 2025 14:43:02 +0530
Subject: [PATCH] UPSTREAM:PROTOCOL: hostapd: Updated started flag when the
 interface is stopped via some other userspace application

When any MLD/legacy interface is deleted through other userspace
network application like iw/ifconfig, kernel will intimate that through
STOP_AP event to hostapd. Currently, for this STOP_AP event, we will
set the interface to be stopped and incase of MLD, additionally we will
remove the link from the bss list. Incase of MBSSID case, if the deleted
interface is TX BSS, then the corressponding non-TX BSS will also get
deleted and recieve STOP_AP event similar to the orginally deleted
interface.

In current scenario, we will not updating the beacon of the partner
links/interface in this case, which leads to the deleted/stopped BSS RNR
information still present in the beacon as neighbor entry.

Avoid this by setting the disable flag to true for the stopped BSS,
refresh all the interface beacon and check whether the bss is disabled
or not before adding to the RNR/MBSSID element(s).

Signed-off-by: Manish Dharanenthiran <quic_mdharane@quicinc.com>
---
 src/ap/drv_callbacks.c | 9 +++++++++
 src/ap/hostapd.c       | 3 ++-
 src/ap/hostapd.h       | 4 ++++
 3 files changed, 15 insertions(+), 1 deletion(-)

--- a/src/ap/drv_callbacks.c
+++ b/src/ap/drv_callbacks.c
@@ -2286,6 +2286,10 @@ static void hostapd_event_iface_unavaila
 		hostapd_switch_channel_fallback(hapd->iface,
 						&hapd->cs_freq_params);
 	}
+
+	/* Set disabled to false so the RNR and other beacon params are properly
+	 * updated */
+	hapd->disabled = 1;
 }
 
 
@@ -3123,6 +3127,10 @@ void hostapd_wpa_event(void *ctx, enum w
 #ifdef NEED_AP_MLME
 	case EVENT_INTERFACE_UNAVAILABLE:
 		hostapd_event_iface_unavailable(hapd);
+		/* Update beacon to all the interfaces about the
+		 * removal/disable of one of the BSS.
+		 */
+		hostapd_refresh_all_iface_beacons(hapd->iface);
 		break;
 	case EVENT_DFS_RADAR_DETECTED:
 		if (!data)
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -9445,7 +9445,7 @@ repeat_rnr_len:
 			bool ap_mld = false;
 			u8 match_idx = 255;
 
-			if (!bss || !bss->conf || !bss->started)
+			if (!bss || !bss->conf || !bss->started || bss->disabled)
 				continue;
 
 #ifdef CONFIG_IEEE80211BE
@@ -9717,7 +9717,7 @@ static bool hostapd_eid_rnr_bss(struct h
 #endif /* CONFIG_IEEE80211BE */
 
 	if (!bss || !bss->conf || !bss->started ||
-	    bss == reporting_hapd)
+	    bss->disabled || bss == reporting_hapd)
 		return false;
 
 	if (hostapd_skip_rnr(i, skip_profiles, ap_mld, tbtt_info_len,
@@ -10056,7 +10056,7 @@ static size_t hostapd_eid_mbssid_elem_le
 		 else
 			 bss = tx_bss->iface->bss[i];
 
-		if (!bss || !bss->conf || !bss->started ||
+		if (!bss || !bss->conf || !bss->started || bss->disabled ||
 		    mbssid_known_bss(i, known_bss, known_bss_len))
 			continue;
 
@@ -10254,7 +10254,7 @@ static u8 * hostapd_eid_mbssid_elem(stru
 		else
 			bss = tx_bss->iface->bss[i];
 
-		if (!bss || !bss->conf || !bss->started ||
+		if (!bss || !bss->conf || !bss->started || bss->disabled ||
 		    mbssid_known_bss(i, known_bss, known_bss_len))
 			continue;
 		conf = bss->conf;
