From 7e98afa600c118cfa770df2465a019d71deb1f2e Mon Sep 17 00:00:00 2001
From: Karthik M <karm@qti.qualcomm.com>
Date: Mon, 8 Sep 2025 12:29:49 +0530
Subject: [PATCH] TREAM:PROTOCOL:KW: hostapd: Fix the following KW issues

Ensure 'bss' is non-NULL before passing it to
wpa_supplicant_need_to_roam_within_ess() to prevent unsafe
dereference. This guards against crashes when no valid BSS
is available during WNM-based roaming.

Ensure 'sta' is non-NULL before dereferencing in
hostapd_get_epcs_capab(). This prevents potential crashes
when the function is called with a NULL sta pointer.

Initialize max_rec_links to avoid use of uninitialized value

Change-Id: Ibae056ffa0db47e735b48020440c2c5174a58d46
Signed-off-by: Karthik M <karm@qti.qualcomm.com>
---
 src/ap/ieee802_11_eht.c  | 6 ++++++
 wpa_supplicant/wnm_sta.c | 2 +-
 2 files changed, 7 insertions(+), 1 deletion(-)

--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -624,10 +624,10 @@ static u8 * hostapd_eid_eht_basic_ml_com
 			ext_mld_cap |= ((max_rec_links <<
 					EHT_ML_MLD_EXT_CAPA_MAX_NUM_REC_LINKS_OFFSET) &
 					EHT_ML_MLD_EXT_CAPA_MAX_NUM_REC_LINKS_MASK);
+			wpa_printf(MSG_DEBUG, "MLD: rec_links %u", max_rec_links);
 		}
 		wpa_printf(MSG_DEBUG,
-			   "MLD: Ext MLD Capabilities and Operations=0x%x rec_links %u",
-			   ext_mld_cap, max_rec_links);
+			   "MLD: Ext MLD Capabilities and Operations=0x%x", ext_mld_cap);
 		wpabuf_put_le16(buf, ext_mld_cap);
 	}
 
@@ -3342,6 +3342,11 @@ void hostapd_handle_epcs_action(struct h
 
 void hostapd_get_epcs_capab(struct hostapd_data *hapd, struct sta_info *sta)
 {
+	if (!sta) {
+		wpa_printf(MSG_DEBUG, "sta is NULL, not able to get EPCS CAPABILITY");
+		return;
+	}
+
 	if (sta->mld_info.mld_sta && sta->eht_capab &&
 	    (sta->eht_capab->mac_cap & EHT_MACCAP_EPCS_PRIO)) {
 		sta->mld_info.epcs.is_epcs_capable = true;
--- a/wpa_supplicant/wnm_sta.c
+++ b/wpa_supplicant/wnm_sta.c
@@ -1090,7 +1090,7 @@ int wnm_scan_process(struct wpa_supplica
 			return 0;
 
 #ifndef CONFIG_NO_ROAMING
-		if (current_bss && bss != current_bss &&
+		if (bss && current_bss && bss != current_bss &&
 		    wpa_supplicant_need_to_roam_within_ess(wpa_s, bss,
 							   current_bss, false))
 			return 0;
