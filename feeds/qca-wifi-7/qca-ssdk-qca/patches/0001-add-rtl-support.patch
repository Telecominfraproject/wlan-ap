From 3e004e8d0bd48d139c515cd1ec84695c01f2393d Mon Sep 17 00:00:00 2001
From: "Justin.Guo" <guoxijun@actiontec.com>
Date: Thu, 5 Mar 2026 16:23:53 +0800
Subject: [PATCH] add rtl support

Signed-off-by: Justin.Guo <guoxijun@actiontec.com>
---
 include/hsl/phy/hsl_phy.h | 2 ++
 src/hsl/phy/hsl_phy.c     | 3 +++
 2 files changed, 5 insertions(+)

diff --git a/include/hsl/phy/hsl_phy.h b/include/hsl/phy/hsl_phy.h
index e987495..97c3add 100644
--- a/include/hsl/phy/hsl_phy.h
+++ b/include/hsl/phy/hsl_phy.h
@@ -31,6 +31,7 @@ typedef enum
 	QCA803X_PHY_CHIP,
 	SFP_PHY_CHIP,
 	MPGE_PHY_CHIP,
+	RTL_PHY_CHIP,
 /*qca808x_start*/
 	QCA808X_PHY_CHIP,
 	MAX_PHY_CHIP,
@@ -63,6 +64,7 @@ typedef struct {
 #define MVL_PHY_X3410           0x31c31DD3
 #define SFP_PHY                 0xaaaabbbb
 #define MP_GEPHY                0x004DD0C0
+#define RTL_PHY                 0X001CCAF3
 #define SFP_PHY_MASK            0xffffffff
 
 #define CABLE_PAIR_A            0
diff --git a/src/hsl/phy/hsl_phy.c b/src/hsl/phy/hsl_phy.c
index 250784a..e20a626 100644
--- a/src/hsl/phy/hsl_phy.c
+++ b/src/hsl/phy/hsl_phy.c
@@ -123,6 +123,9 @@ phy_type_t hsl_phytype_get_by_phyid(a_uint32_t dev_id, a_uint32_t phy_id)
 		case QCA8081_PHY:
 			phytype = QCA808X_PHY_CHIP;
 			break;
+		case RTL_PHY:
+			phytype = RTL_PHY_CHIP;
+			break;
 		default:
 			phytype = MAX_PHY_CHIP;
 	}
-- 
