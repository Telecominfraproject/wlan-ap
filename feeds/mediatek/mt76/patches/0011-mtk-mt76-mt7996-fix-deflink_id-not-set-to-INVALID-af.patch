From 8df1af32385a6c89c90da6625a515956ce388cf0 Mon Sep 17 00:00:00 2001
From: Shayne Chen <shayne.chen@mediatek.com>
Date: Tue, 3 Feb 2026 21:42:36 +0800
Subject: [PATCH 11/89] mtk: mt76: mt7996: fix deflink_id not set to INVALID
 after link remove

This fixes mtxq->wcid of extender, will be sent to upstream.

Signed-off-by: Shayne Chen <shayne.chen@mediatek.com>
---
 mt7996/main.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/mt7996/main.c b/mt7996/main.c
index b14636099..140f62591 100644
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -405,7 +405,7 @@ void mt7996_vif_link_remove(struct mt76_phy *mphy, struct ieee80211_vif *vif,
 	    mvif->mt76.deflink_id == link_conf->link_id) {
 		struct ieee80211_bss_conf *iter;
 		struct mt76_txq *mtxq;
-		unsigned int link_id;
+		unsigned int link_id, deflink_id = mvif->mt76.deflink_id;
 
 		mvif->mt76.deflink_id = IEEE80211_LINK_UNSPECIFIED;
 		mtxq = (struct mt76_txq *)vif->txq->drv_priv;
@@ -413,7 +413,7 @@ void mt7996_vif_link_remove(struct mt76_phy *mphy, struct ieee80211_vif *vif,
 		for_each_vif_active_link(vif, iter, link_id) {
 			struct mt7996_vif_link *link;
 
-			if (link_id == link_conf->link_id)
+			if (link_id == deflink_id)
 				continue;
 
 			link = mt7996_vif_link(dev, vif, link_id);
-- 
