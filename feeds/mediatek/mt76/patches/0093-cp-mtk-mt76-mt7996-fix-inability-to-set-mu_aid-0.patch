From 8c2dfa7ad776175055bc6248126a10dba4bb4d50 Mon Sep 17 00:00:00 2001
From: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
Date: Tue, 31 Mar 2026 15:52:21 +0800
Subject: [PATCH] mtk: mt76: mt7996: fix inability to set mu_aid=0

Setting mu_aid = 0 should be allowed

issue severity: Normal
Signed-off-by: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
---
 mt7996/testmode.c | 5 +++--
 testmode.c        | 1 +
 2 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/mt7996/testmode.c b/mt7996/testmode.c
index 7005f9de5..73b65bea9 100644
--- a/mt7996/testmode.c
+++ b/mt7996/testmode.c
@@ -497,8 +497,9 @@ mt7996_tm_set_rx_frames(struct mt7996_phy *phy, bool en)
 		return;
 	}
 
-	if (td->tx_rate_mode >= MT76_TM_TX_MODE_HE_MU)
-		mt7996_tm_set(dev, SET_ID(RX_MU_AID), td->mu_aid ?: MT76_TM_MAX_MU_AID);
+	if (td->tx_rate_mode >= MT76_TM_TX_MODE_HE_MU &&
+	    td->tx_rate_mode != MT76_TM_TX_MODE_EHT_TRIG)
+		mt7996_tm_set(dev, SET_ID(RX_MU_AID), td->mu_aid);
 
 	mt7996_tm_set(dev, SET_ID(TX_MODE),
 		      mt7996_tm_rate_mapping(td->tx_rate_mode, RATE_MODE_TO_PHY));
diff --git a/testmode.c b/testmode.c
index 1dff28493..728b5466d 100644
--- a/testmode.c
+++ b/testmode.c
@@ -1625,6 +1625,7 @@ int mt76_testmode_dump(struct ieee80211_hw *hw, struct sk_buff *msg,
 	    nla_put_u8(msg, MT76_TM_ATTR_PAYLOAD_RULE, td->payload_rule) ||
 	    nla_put_u8(msg, MT76_TM_ATTR_PAYLOAD, td->payload) ||
 	    nla_put_u8(msg, MT76_TM_ATTR_MAX_PKT_EXT, td->max_pkt_ext) ||
+	    nla_put_u16(msg, MT76_TM_ATTR_MU_AID, td->mu_aid) ||
 	    nla_put_u8(msg, MT76_TM_ATTR_TX_LEN_MODE, td->tx_len_mode) ||
 	    (mt76_testmode_param_present(td, MT76_TM_ATTR_TX_LTF) &&
 	     nla_put_u8(msg, MT76_TM_ATTR_TX_LTF, td->tx_ltf)) ||
-- 
2.45.2

