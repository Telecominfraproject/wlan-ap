From 704b6b27c109f19db03428d2f43e4305f2f87a73 Mon Sep 17 00:00:00 2001
From: Rex Lu <rex.lu@mediatek.com>
Date: Mon, 2 Feb 2026 11:04:31 +0800
Subject: [PATCH] wifi: mt76: mt7996: wed :Refactor wed init for build pass

Depend on wed kernel patch:
https://git01.mediatek.com/plugins/gitiles/openwrt/feeds/mtk-openwrt-feeds/+/refs/heads/master/25.12/files/target/linux/mediatek/patches-6.12/999-wed-18-Refactor-wed-msdu-page-ring-init-flow.patch

CR-Id: WCNCR00259516
Signed-off-by: Rex Lu <rex.lu@mediatek.com>
Change-Id: I28dfe4bd74498619ba2488920ab664337d2a6485
---
 mt7996/mmio.c | 8 +++++---
 1 file changed, 5 insertions(+), 3 deletions(-)

diff --git a/mt7996/mmio.c b/mt7996/mmio.c
index bb774342..0560d8f9 100644
--- a/mt7996/mmio.c
+++ b/mt7996/mmio.c
@@ -578,7 +578,7 @@ int mt7996_mmio_wed_init(struct mt7996_dev *dev, void *pdev_ptr,
 						MT_RXQ_RING_BASE(MT7996_RXQ_BAND2) +
 						MT7996_RXQ_BAND2 * MT_RING_SIZE;
 
-		wed->wlan.id = MT7996_DEVICE_ID_2;
+		wed->wlan.fc_disable = true;
 		wed->wlan.tx_tbit[0] = ffs(MT_INT_TX_DONE_BAND2) - 1;
 	} else {
 		wed->wlan.hw_rro = (enum mtk_wed_hwrro_mode)dev->mt76.hwrro_mode; /* default on */
@@ -649,8 +649,10 @@ int mt7996_mmio_wed_init(struct mt7996_dev *dev, void *pdev_ptr,
 			wed->wlan.rx_pg_tbit[0] = ffs(MT_INT_RX_DONE_MSDU_PG_BAND0) - 1;
 			wed->wlan.rx_pg_tbit[1] = ffs(MT_INT_RX_DONE_MSDU_PG_BAND1) - 1;
 			wed->wlan.rx_pg_tbit[2] = ffs(MT_INT_RX_DONE_MSDU_PG_BAND2) - 1;
+			wed->wlan.pg_ring_num = is_mt7996(&dev->mt76) ? 3 : 1;
 		} else {
 			wed->wlan.rro_3_1_rx_tbit = ffs(MT_INT_RX_DONE_RRO_RXDMAD_C) - 1;
+			wed->wlan.pg_ring_num = 0;
 		}
 
 		wed->wlan.tx_tbit[0] = ffs(MT_INT_TX_DONE_BAND0) - 1;
@@ -672,13 +674,13 @@ int mt7996_mmio_wed_init(struct mt7996_dev *dev, void *pdev_ptr,
 			wed->wlan.wpdma_txfree = wed->wlan.phy_base + MT_RXQ_RING_BASE(0) +
 						 MT7996_RXQ_MCU_WA_MAIN * MT_RING_SIZE;
 			if (dev->hif2)
-				wed->wlan.id = MT7992_DEVICE_ID;
+				wed->wlan.fc_disable = true;
 		} else {
 			wed->wlan.txfree_tbit = ffs(MT_INT_RX_TXFREE_BAND0_MT7990) - 1;
 			wed->wlan.wpdma_txfree = wed->wlan.phy_base + MT_RXQ_RING_BASE(0) +
 						 MT7990_RXQ_TXFREE0 * MT_RING_SIZE;
 			if (dev->hif2)
-				wed->wlan.id = MT7990_DEVICE_ID;
+				wed->wlan.fc_disable = true;
 		}
 
 		dev->mt76.rx_token_size = tx_token_size + rx_token_size;
-- 
2.45.2

