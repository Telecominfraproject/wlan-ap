From 3f1db66a326b200b5ab26a788c50e12f1c49ceb7 Mon Sep 17 00:00:00 2001
From: Peter Chiu <chui-hao.chiu@mediatek.com>
Date: Wed, 22 Apr 2026 09:31:12 +0800
Subject: [PATCH] mtk: mt76: mt7996: Remove firmware log initialization

Do not modify firmware log method by driver. It is controlled
by firmware.

Feature:
Log

Signed-off-by: Peter Chiu <chui-hao.chiu@mediatek.com>
---
 mt7996/mcu.c | 7 -------
 1 file changed, 7 deletions(-)

diff --git a/mt7996/mcu.c b/mt7996/mcu.c
index 9a107d74c..fdf381863 100644
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -5577,15 +5577,8 @@ int mt7996_mcu_init_firmware(struct mt7996_dev *dev)
 		return ret;
 
 	set_bit(MT76_STATE_MCU_RUNNING, &dev->mphy.state);
-	ret = mt7996_mcu_fw_log_2_host(dev, MCU_FW_LOG_WM, 1);
-	if (ret)
-		return ret;
 
 	if (mt7996_has_wa(dev)) {
-		ret = mt7996_mcu_fw_log_2_host(dev, MCU_FW_LOG_WA, 1);
-		if (ret)
-			return ret;
-
 		ret = mt7996_mcu_set_mwds(dev, 1);
 		if (ret)
 			return ret;
-- 
2.45.2

