From 4b5c4e24be43ee3e8f7468720b0d04b56bf60ca8 Mon Sep 17 00:00:00 2001
From: Felix Fietkau <nbd@nbd.name>
Date: Mon, 9 Mar 2026 05:11:31 +0000
Subject: [PATCH 01/89] wifi: mt76: fix scan work requeue race with spinlock

Prevent mt76_scan_rx_beacon() in softirq from requeuing scan_work
after cancel_delayed_work_sync() returns in mt76_abort_scan(). Without
synchronization, the beacon handler can observe beacon_wait as true
and requeue scan_work between the cancel and the memset in
mt76_scan_complete(), leading to a NULL pointer dereference when
scan_work runs against zeroed scan state.

Introduce scan_lock (placed outside the scan struct to survive the
memset) to make the beacon handler's check-and-queue atomic with
respect to abort_scan's clear of beacon_wait. This eliminates the
race with a single cancel_delayed_work_sync() call.

Signed-off-by: Felix Fietkau <nbd@nbd.name>
---
 mac80211.c |  1 +
 mt76.h     |  1 +
 scan.c     | 17 +++++++++++++++--
 3 files changed, 17 insertions(+), 2 deletions(-)

diff --git a/mac80211.c b/mac80211.c
index beb5a0c67..9933830b7 100644
--- a/mac80211.c
+++ b/mac80211.c
@@ -728,6 +728,7 @@ mt76_alloc_device(struct device *pdev, unsigned int size,
 	INIT_LIST_HEAD(&dev->rxwi_cache);
 	dev->token_size = dev->drv->token_size;
 	INIT_DELAYED_WORK(&dev->scan_work, mt76_scan_work);
+	spin_lock_init(&dev->scan_lock);
 
 	for (i = 0; i < ARRAY_SIZE(dev->q_rx); i++)
 		skb_queue_head_init(&dev->rx_skb[i]);
diff --git a/mt76.h b/mt76.h
index df66b70bc..52ca1eb99 100644
--- a/mt76.h
+++ b/mt76.h
@@ -1015,6 +1015,7 @@ struct mt76_dev {
 	u32 rxfilter;
 
 	struct delayed_work scan_work;
+	spinlock_t scan_lock;
 	struct {
 		struct cfg80211_scan_request *req;
 		struct ieee80211_channel *chan;
diff --git a/scan.c b/scan.c
index ed50bd6c6..2b5f30cef 100644
--- a/scan.c
+++ b/scan.c
@@ -27,6 +27,10 @@ static void mt76_scan_complete(struct mt76_dev *dev, bool abort)
 
 void mt76_abort_scan(struct mt76_dev *dev)
 {
+	spin_lock_bh(&dev->scan_lock);
+	dev->scan.beacon_wait = false;
+	spin_unlock_bh(&dev->scan_lock);
+
 	cancel_delayed_work_sync(&dev->scan_work);
 	mt76_scan_complete(dev, true);
 }
@@ -83,16 +87,21 @@ void mt76_scan_rx_beacon(struct mt76_dev *dev, struct ieee80211_channel *chan)
 {
 	struct mt76_phy *phy;
 
+	spin_lock(&dev->scan_lock);
+
 	if (!dev->scan.beacon_wait || dev->scan.beacon_received ||
 	    dev->scan.chan != chan)
-		return;
+		goto out;
 
 	phy = dev->scan.phy;
 	if (!phy)
-		return;
+		goto out;
 
 	dev->scan.beacon_received = true;
 	ieee80211_queue_delayed_work(phy->hw, &dev->scan_work, 0);
+
+out:
+	spin_unlock(&dev->scan_lock);
 }
 EXPORT_SYMBOL_GPL(mt76_scan_rx_beacon);
 
@@ -110,8 +119,10 @@ void mt76_scan_work(struct work_struct *work)
 	if (!phy || !req)
 		return;
 
+	spin_lock_bh(&dev->scan_lock);
 	beacon_rx = dev->scan.beacon_wait && dev->scan.beacon_received;
 	dev->scan.beacon_wait = false;
+	spin_unlock_bh(&dev->scan_lock);
 
 	if (beacon_rx)
 		goto probe;
@@ -140,8 +151,10 @@ void mt76_scan_work(struct work_struct *work)
 		goto out;
 
 	if (chandef.chan->flags & (IEEE80211_CHAN_NO_IR | IEEE80211_CHAN_RADAR)) {
+		spin_lock_bh(&dev->scan_lock);
 		dev->scan.beacon_received = false;
 		dev->scan.beacon_wait = true;
+		spin_unlock_bh(&dev->scan_lock);
 		goto out;
 	}
 
