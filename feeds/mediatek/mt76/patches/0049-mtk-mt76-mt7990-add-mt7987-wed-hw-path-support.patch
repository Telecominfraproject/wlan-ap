 #define MT7996_CFEND_RATE_DEFAULT	0x49	/* OFDM 24M */
@@ -204,6 +204,7 @@ enum mt7996_coredump_state {
 };
 
 enum mt7996_txq_id {
+	MT7996_TXQ_WED_RX = 0,
