From ba05806b7f5f922f8e7cfa07a8f8eb7d368e2fc8 Mon Sep 17 00:00:00 2001
From: Rex Lu <rex.lu@mediatek.com>
Date: Thu, 13 Nov 2025 11:41:39 +0800
Subject: [PATCH 49/89] mtk: mt76: mt7990: add mt7987 wed hw path support

1. mt7996_mmio_wed_init support to check wed hw version for init setup
2. add rro3.1 hw init function
3. add wed rx data ring for wed3.1 to host
4. change has_rro to hwrro_mode for support rro3.1 and rro 3.0. and move from mt7996_dev to mt76.

1. Align logan setting to adjust HW Tx/Rx token size

Signed-off-by: Rex Lu <rex.lu@mediatek.com>
---
 dma.c           |   3 +-
 mt76.h          |   1 +
 mt7996/dma.c    |  47 ++++++++++++++++++---
 mt7996/mac.c    |   3 +-
 mt7996/mmio.c   | 108 +++++++++++++++++++++++++++++++++++-------------
 mt7996/mt7996.h |   4 +-
 mt7996/pci.c    |  16 +++++++
 mt7996/regs.h   |   2 +
 wed.c           |   5 +++
 9 files changed, 153 insertions(+), 36 deletions(-)

diff --git a/dma.c b/dma.c
index c47d883e1..30c95bc5b 100644
--- a/dma.c
+++ b/dma.c
@@ -534,7 +534,8 @@ mt76_dma_get_buf(struct mt76_dev *dev, struct mt76_queue *q, int idx,
 		t->ptr = NULL;
 
 		mt76_put_rxwi(dev, t);
-		if (drop)
+		/* only wed v2 rx path handle by wo */
+		if (drop && dev->mmio.wed.version == MTK_WED_HW_V2)
 			*drop |= !!(buf1 & MT_DMA_CTL_WO_DROP);
 	} else {
 		dma_sync_single_for_cpu(dev->dma_dev, e->dma_addr[0],
diff --git a/mt76.h b/mt76.h
index 54cc9e1fa..88ad3c394 100644
--- a/mt76.h
+++ b/mt76.h
@@ -163,6 +163,7 @@ enum mt76_rxq_id {
 	MT_RXQ_RRO_RXDMAD_C,
 	MT_RXQ_NPU0,
 	MT_RXQ_NPU1,
+	MT_RXQ_WED_RX_DATA,
 	__MT_RXQ_MAX
 };
 
diff --git a/mt7996/dma.c b/mt7996/dma.c
