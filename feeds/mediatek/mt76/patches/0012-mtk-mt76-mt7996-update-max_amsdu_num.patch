From c6fd5767d61b601dbc4d7a91f12c7a39c2726ec0 Mon Sep 17 00:00:00 2001
From: Shayne Chen <shayne.chen@mediatek.com>
Date: Thu, 22 Jan 2026 23:10:52 +0800
Subject: [PATCH 12/89] mtk: mt76: mt7996: update max_amsdu_num

Sync the HW setting with Logan's chip_cap->hw_max_amsdu_nums.

Signed-off-by: Shayne Chen <shayne.chen@mediatek.com>
---
 mt7996/mcu.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mt7996/mcu.c b/mt7996/mcu.c
index d949b0378..dc8015b32 100644
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -1624,7 +1624,7 @@ mt7996_mcu_sta_amsdu_tlv(struct mt7996_dev *dev, struct sk_buff *skb,
 
 	tlv = mt76_connac_mcu_add_tlv(skb, STA_REC_HW_AMSDU, sizeof(*amsdu));
 	amsdu = (struct sta_rec_amsdu *)tlv;
-	amsdu->max_amsdu_num = 8;
+	amsdu->max_amsdu_num = 31;
 	amsdu->amsdu_en = true;
 	msta_link->wcid.amsdu = true;
 
