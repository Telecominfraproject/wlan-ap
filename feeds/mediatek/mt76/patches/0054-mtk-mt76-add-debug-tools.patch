+	if (en != MRU_PROBE_ENABLE)
+		return 0;
+
+	ret = mt7996_mcu_set_mru_probe_en(phy);
+	if (ret)
+		return ret;
+
+	phy->mru_probe_enable = en;
+	/* When enabling MRU probe, PP would also enter FW mode */
+	phy->pp_mode = PP_FW_MODE;
+
+	return 0;
+}
