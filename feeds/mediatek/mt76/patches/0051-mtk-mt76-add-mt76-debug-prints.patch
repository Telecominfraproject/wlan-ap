From: Shayne Chen <shayne.chen@mediatek.com>
Date: Mon, 2 Mar 2026 14:52:59 +0800
Subject: [PATCH 51/89] mtk: mt76: add mt76 debug prints

---
 Makefile |  2 +-
 debug.c  | 78 ++++++++++++++++++++++++++++++++++++++++++++++++++++++++
 debug.h  | 53 ++++++++++++++++++++++++++++++++++++++
 mt76.h   |  1 +
 4 files changed, 133 insertions(+), 1 deletion(-)
 create mode 100644 debug.c
 create mode 100644 debug.h

diff --git a/Makefile b/Makefile
index ae9c201b4..14c071a84 100644
--- a/Makefile
+++ b/Makefile
@@ -11,7 +11,7 @@ obj-$(CONFIG_MT792x_USB) += mt792x-usb.o
 
 mt76-y := \
 	mmio.o util.o trace.o dma.o mac80211.o debugfs.o eeprom.o \
-	tx.o agg-rx.o mcu.o wed.o scan.o channel.o
+	tx.o agg-rx.o mcu.o wed.o scan.o channel.o debug.o
 
 mt76-$(CONFIG_MT76_NPU) += npu.o
 mt76-$(CONFIG_PCI) += pci.o
diff --git a/debug.c b/debug.c
new file mode 100644
index 000000000..3d693303f
--- /dev/null
+++ b/debug.c
@@ -0,0 +1,78 @@
+// SPDX-License-Identifier: ISC
+/*
+ * Copyright (C) 2024 MediaTek Inc.
+ */
+
+#include <linux/vmalloc.h>
+#include "mt76.h"
+
+unsigned int mt76_debug_mask = 0x3f;
+module_param(mt76_debug_mask, uint, 0644);
+MODULE_PARM_DESC(mt76_debug_mask, "Debugging mask");
+
+void mt76_info(struct mt76_dev *dev, const char *fmt, ...)
+{
+	struct va_format vaf = {
+		.fmt = fmt,
+	};
+	va_list args;
+
+	va_start(args, fmt);
+	vaf.va = &args;
+	dev_info(dev->dev, "%pV", &vaf);
+
+	va_end(args);
+}
+EXPORT_SYMBOL_GPL(mt76_info);
+
+void mt76_err(struct mt76_dev *dev, const char *fmt, ...)
+{
+	struct va_format vaf = {
+		.fmt = fmt,
+	};
+	va_list args;
+
+	va_start(args, fmt);
+	vaf.va = &args;
+	dev_err(dev->dev, "%pV", &vaf);
+
+	va_end(args);
+}
+EXPORT_SYMBOL_GPL(mt76_err);
+
+void mt76_warn(struct mt76_dev *dev, const char *fmt, ...)
+{
+	struct va_format vaf = {
+		.fmt = fmt,
+	};
+	va_list args;
+
+	va_start(args, fmt);
+	vaf.va = &args;
+	dev_warn_ratelimited(dev->dev, "%pV", &vaf);
+
+	va_end(args);
+}
+EXPORT_SYMBOL_GPL(mt76_warn);
+
+void __mt76_dbg(enum mt76_debug_mask mask, struct mt76_dev *dev, const char *fmt, ...)
+{
+	struct va_format vaf = {
+		.fmt = fmt,
+	};
+	va_list args;
+
+	if (!(mask & mt76_debug_mask))
+		return;
+
+	va_start(args, fmt);
+	vaf.va = &args;
+
+	if (dev)
+		dev_printk(KERN_DEBUG, dev->dev, "%pV", &vaf);
+	else
+		pr_info("%pV", &vaf);
+
+	va_end(args);
+}
+EXPORT_SYMBOL_GPL(__mt76_dbg);
diff --git a/debug.h b/debug.h
new file mode 100644
index 000000000..d13bb1953
--- /dev/null
+++ b/debug.h
@@ -0,0 +1,53 @@
+/* SPDX-License-Identifier: ISC */
+/*
+ * Copyright (C) 2024 MediaTek Inc.
+ */
+#ifndef __MT76_DEBUG_H_
+#define __MT76_DEBUG_H_
+
+struct mt76_dev;
+
+enum mt76_debug_mask {
+	MT76_DBG_DEV = BIT(0),
+	MT76_DBG_PHY = BIT(1),
+	MT76_DBG_BSS = BIT(2),
+	MT76_DBG_STA = BIT(3),
+	MT76_DBG_MLO = BIT(4),
+	MT76_DBG_TM = BIT(5),
+
+	MT76_DBG_ALL = 0xffffffff,
+};
+
+__printf(2, 3) void mt76_info(struct mt76_dev *dev, const char *fmt, ...);
+__printf(2, 3) void mt76_err(struct mt76_dev *dev, const char *fmt, ...);
+__printf(2, 3) void mt76_warn(struct mt76_dev *dev, const char *fmt, ...);
+__printf(3, 4) void __mt76_dbg(enum mt76_debug_mask mask, struct mt76_dev *dev,
+			       const char *fmt, ...);
+
+#define vif_name(_vif)	netdev_name(ieee80211_vif_to_wdev(_vif)->netdev)
+
+#define mt76_dev_dbg(dev, fmt, ...)					\
+	__mt76_dbg(MT76_DBG_DEV, dev, "%s: " fmt,			\
+		   __func__, ##__VA_ARGS__)				\
+
+#define mt76_phy_dbg(phy, fmt, ...)					\
+	__mt76_dbg(MT76_DBG_PHY, phy->dev, "band %u: %s: " fmt,	\
+		   phy->band_idx, __func__, ##__VA_ARGS__)		\
+
+#define mt76_bss_dbg(vif, fmt, ...)					\
+	__mt76_dbg(MT76_DBG_BSS, NULL, "%s: %s: " fmt,			\
+		   vif_name(vif), __func__, ##__VA_ARGS__)		\
+
+#define mt76_sta_dbg(vif, fmt, ...)					\
+	__mt76_dbg(MT76_DBG_STA, NULL, "%s: %s: " fmt,			\
+		   vif_name(vif), __func__, ##__VA_ARGS__)		\
+
+#define mt76_mlo_dbg(vif, fmt, ...)					\
+	__mt76_dbg(MT76_DBG_MLO, NULL, "%s: %s: " fmt,			\
+		   vif_name(vif), __func__, ##__VA_ARGS__)		\
+
+#define mt76_tm_dbg(dev, fmt, ...)					\
+	__mt76_dbg(MT76_DBG_TM, dev, "%s: " fmt,			\
+		   __func__, ##__VA_ARGS__)				\
+
+#endif /* __MT76_DEBUG_H_ */
