+static int
+mt7915_sr_enable_set(void *data, u64 val)
+{
+	struct mt7915_phy *phy = data;
+	int ret;
+
+	if (!!val == phy->sr_enable)
+		return 0;
+
+	ret = mt7915_mcu_enable_obss_spr(phy, SPR_ENABLE, !!val);
+	if (ret)
+		return ret;
+
+	return mt7915_mcu_enable_obss_spr(phy, SPR_GET_ENABLE, 0);
+}
