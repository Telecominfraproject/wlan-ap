+static int
+mt7915_tx_drop_show(struct seq_file *s, void *data)
+{
+	struct mt7915_phy *phy = s->private;
+	struct mt76_tx_debug *stats = &phy->mt76->tx_dbg_stats;
+
+	seq_printf(s, "Receive from mac80211: %d\n", stats->data[MT_TX_FROM_MAC80211]);
+	seq_printf(s, "Send to hw: %d\n", stats->data[MT_TX_TO_HW]);
+
+#define __pr(t) seq_printf(s, "Drop due to %s: %d\n", \
+			   #t, stats->data[MT_TX_DROP_##t])
+	__pr(IN_TESTMODE);
+	__pr(WCID_NOT_INIT);
+	__pr(STOPPED_QUEUE);
+	__pr(RESET_STATE);
+	__pr(GET_TXWI_FAIL);
+	__pr(DMA_FAIL);
+	__pr(AGG_EXCEEDED);
+	__pr(RING_FULL);
+	__pr(INVALID_SKB);
+	__pr(GET_TOKEN_FAIL);
+
+#undef __pr
+
+	return 0;
+}
+
+DEFINE_SHOW_ATTRIBUTE(mt7915_tx_drop);
