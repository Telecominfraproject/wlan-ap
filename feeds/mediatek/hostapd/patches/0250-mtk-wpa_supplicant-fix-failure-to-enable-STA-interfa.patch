From 0ca1b092fa49b6b71cac6183529c94edf81d293d Mon Sep 17 00:00:00 2001
From: Benjamin Lin <benjamin-jw.lin@mediatek.com>
Date: Fri, 9 Jan 2026 15:42:47 +0800
Subject: [PATCH 250/260] mtk: wpa_supplicant: fix failure to enable STA
 interface

Fix failure to enable STA interface for Wi-Fi 6 kernel 6.12 codebase.
Specifically, in Wi-Fi 6 multi-wiphy architecture, multi_hw_info and vif_radio_mask are not used, so do not check their values.
Otherwise, failure will be returned because multi_hw_info will be NULL and vif_radio_mask will be 0.

Signed-off-by: Benjamin Lin <benjamin-jw.lin@mediatek.com>
---
 wpa_supplicant/wpa_supplicant.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/wpa_supplicant/wpa_supplicant.c b/wpa_supplicant/wpa_supplicant.c
index 6986c2eb1..864d7b742 100644
--- a/wpa_supplicant/wpa_supplicant.c
+++ b/wpa_supplicant/wpa_supplicant.c
@@ -7902,11 +7902,13 @@ static int wpa_supplicant_init_iface(struct wpa_supplicant *wpa_s,
 	}
 
 	wpa_s->multi_hw_info = wpas_drv_get_multi_hw_info(wpa_s, &wpa_s->num_multi_hws);
-	if (!wpa_s->multi_hw_info)
+	if ((wpa_s->drv_flags2 & WPA_DRIVER_FLAGS2_MLO) &&
+	    !wpa_s->multi_hw_info)
 		return -1;
 
 	ret = wpas_drv_get_vif_radio_mask(wpa_s, &wpa_s->vif_radio_mask);
-	if (ret || !wpa_s->vif_radio_mask)
+	if ((wpa_s->drv_flags2 & WPA_DRIVER_FLAGS2_MLO) &&
+	    (ret || !wpa_s->vif_radio_mask))
 		return -1;
 
 	capa_res = wpa_drv_get_capa(wpa_s, &capa);
-- 
