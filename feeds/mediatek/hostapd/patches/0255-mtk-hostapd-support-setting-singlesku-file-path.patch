From 762e95b62121b50ebe594b7e74b1147e656750b2 Mon Sep 17 00:00:00 2001
From: Ryder Lee <ryder.lee@mediatek.com>
Date: Thu, 5 Feb 2026 22:41:48 -0800
Subject: [PATCH 255/260] mtk: hostapd: support setting singlesku file path

Add support for configuring the singlesku file path via the hostapd.conf

Signed-off-by: Ryder Lee <ryder.lee@mediatek.com>
---
 hostapd/config_file.c        |  2 ++
 src/ap/ap_config.c           |  1 +
 src/ap/ap_config.h           |  2 ++
 src/ap/ap_drv_ops.c          |  3 ++-
 src/common/mtk_vendor.h      |  1 +
 src/drivers/driver.h         |  4 +++-
 src/drivers/driver_nl80211.c | 11 ++++++++---
 7 files changed, 19 insertions(+), 5 deletions(-)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index 7620d0c01..50bdf51ee 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -5377,6 +5377,8 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 	} else if (os_strcmp(buf, "lpi_bcn_enhance") == 0) {
 		u8 en = strtol(pos, NULL, 10);
 		conf->lpi_bcn_enhance = !!en;
+	} else if (os_strcmp(buf, "sku_filename") == 0) {
+		os_strlcpy(conf->sku_filename, pos, sizeof(conf->sku_filename));
 	} else {
 		wpa_printf(MSG_ERROR,
 			   "Line %d: unknown configuration item '%s'",
diff --git a/src/ap/ap_config.c b/src/ap/ap_config.c
index beb047675..f4decb33f 100644
--- a/src/ap/ap_config.c
+++ b/src/ap/ap_config.c
@@ -336,6 +336,7 @@ struct hostapd_config * hostapd_config_defaults(void)
 	conf->sku_idx = -1;
 	conf->lpi_sku_idx = -1;
 	conf->lpi_bcn_enhance = 0;
+	conf->sku_filename[0] = '\0';
 
 	hostapd_set_and_check_bw320_offset(conf, 0);
 
diff --git a/src/ap/ap_config.h b/src/ap/ap_config.h
index ea84ce586..71b21baa2 100644
--- a/src/ap/ap_config.h
+++ b/src/ap/ap_config.h
@@ -1373,6 +1373,8 @@ struct hostapd_config {
 	s8 sku_idx;
 	s8 lpi_sku_idx;
 	u8 lpi_bcn_enhance;
+#define SKU_FILENAME_MAX		64
+	char sku_filename[SKU_FILENAME_MAX];
 };
 
 #define THREE_WIRE_EXT_SEL_UNSET	0xff
diff --git a/src/ap/ap_drv_ops.c b/src/ap/ap_drv_ops.c
index e16627ad7..d79480d79 100644
--- a/src/ap/ap_drv_ops.c
+++ b/src/ap/ap_drv_ops.c
@@ -1699,7 +1699,8 @@ int hostapd_drv_txpower_ctrl(struct hostapd_data *hapd)
 					 hapd->iconf->lpi_bcn_enhance,
 					 link_id,
 					 afc_power_table,
-					 lpi_mode);
+					 lpi_mode,
+					 hapd->iconf->sku_filename);
 out:
 #ifdef CONFIG_AFC
 	os_free(afc_power_table);
diff --git a/src/common/mtk_vendor.h b/src/common/mtk_vendor.h
index d32671b4d..37d9c5923 100644
--- a/src/common/mtk_vendor.h
+++ b/src/common/mtk_vendor.h
@@ -331,6 +331,7 @@ enum mtk_vendor_attr_txpower_ctrl {
 	MTK_VENDOR_ATTR_TXPOWER_CTRL_LINK_ID,
 	MTK_VENDOR_ATTR_TXPOWER_CTRL_AFC_TABLE,
 	MTK_VENDOR_ATTR_TXPOWER_CTRL_AFC_LPI,
+	MTK_VENDOR_ATTR_TXPOWER_CTRL_SKU_FILENAME,
 
 	/* keep last */
 	NUM_MTK_VENDOR_ATTRS_TXPOWER_CTRL,
diff --git a/src/drivers/driver.h b/src/drivers/driver.h
index d522d80e4..61e8facb3 100644
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -5923,9 +5923,11 @@ struct wpa_driver_ops {
 	* @link_id: MLD link id. -1 if this is an non-MLD AP
 	* @power_table: power table generated from AFC response
 	* @lpi_mode: specify the current mode is whether lpi
+	* @sku_filename: used to indicate which sku path should be used
 	*/
 	int (*txpower_ctrl)(void *priv, u8 lpi_psd, s8 sku_idx, u8 lpi_bcn_enhance,
-			    s8 link_id, s8 *power_table, u8 lpi_mode);
+			    s8 link_id, s8 *power_table, u8 lpi_mode,
+			    const char *sku_filename);
 	/**
 	* get_vif_radio_mask - get the radio mask of the interface
 	* @priv: Private driver interface data
diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 6d77f6e92..acacc1bb6 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -212,6 +212,7 @@ txpower_ctrl_policy[NUM_MTK_VENDOR_ATTRS_TXPOWER_CTRL] = {
 	[MTK_VENDOR_ATTR_TXPOWER_CTRL_LINK_ID] = { .type = NLA_U8 },
 	[MTK_VENDOR_ATTR_TXPOWER_CTRL_AFC_TABLE] = { .type = NLA_BINARY },
 	[MTK_VENDOR_ATTR_TXPOWER_CTRL_AFC_LPI] = { .type = NLA_U8 },
+	[MTK_VENDOR_ATTR_TXPOWER_CTRL_SKU_FILENAME] = { .type = NLA_STRING },
 };
 
 static struct nl_sock * nl_create_handle(struct nl_cb *cb, const char *dbg)
@@ -17487,8 +17488,9 @@ fail:
 	return -ENOBUFS;
 }
 
-static int nl80211_txpower_ctrl(void *priv, u8 lpi_psd, s8 sku_idx, u8 lpi_bcn_enhance,
-				s8 link_id, s8 *power_table, u8 lpi_mode)
+static int
+nl80211_txpower_ctrl(void *priv, u8 lpi_psd, s8 sku_idx, u8 lpi_bcn_enhance, s8 link_id,
+		     s8 *power_table, u8 lpi_mode, const char *sku_filename)
 {
 	struct i802_bss *bss = priv;
 	struct wpa_driver_nl80211_data *drv = bss->drv;
@@ -17517,7 +17519,10 @@ static int nl80211_txpower_ctrl(void *priv, u8 lpi_psd, s8 sku_idx, u8 lpi_bcn_e
 		goto fail;
 
 	nla_put_u8(msg, MTK_VENDOR_ATTR_TXPOWER_CTRL_LPI_PSD, lpi_psd);
-	if (sku_idx > -1)
+	if (sku_filename[0])
+		nla_put_string(msg, MTK_VENDOR_ATTR_TXPOWER_CTRL_SKU_FILENAME,
+			       sku_filename);
+	else if (sku_idx > -1)
 		nla_put_u8(msg, MTK_VENDOR_ATTR_TXPOWER_CTRL_SKU_IDX, sku_idx);
 	nla_put_u8(msg, MTK_VENDOR_ATTR_TXPOWER_CTRL_LPI_BCN_ENHANCE, lpi_bcn_enhance);
 
-- 
2.45.2

