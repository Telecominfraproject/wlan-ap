From: Shayne Chen <shayne.chen@mediatek.com>
Date: Thu, 26 Feb 2026 14:43:19 +0800
Subject: [PATCH 001/260] Revert "MLD: Pass SSID when doing multi-link probe
 check"

This reverts commit 3bba8e22233f3868304ebcc7fb3517fc79acd8a4.
---
 wpa_supplicant/events.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/wpa_supplicant/events.c b/wpa_supplicant/events.c
index 6111cebea..b6424ea34 100644
--- a/wpa_supplicant/events.c
+++ b/wpa_supplicant/events.c
@@ -1899,7 +1899,7 @@ static int wpa_supplicant_connect_ml_missing(struct wpa_supplicant *wpa_s,
 	      (wpa_s->drv_flags & WPA_DRIVER_FLAGS_SME)))
 		return 0;
 
-	usable_links = wpa_bss_get_usable_links(wpa_s, selected, ssid,
+	usable_links = wpa_bss_get_usable_links(wpa_s, selected, NULL,
 						&missing_links);
 	if (!usable_links || !missing_links)
 		return 0;
