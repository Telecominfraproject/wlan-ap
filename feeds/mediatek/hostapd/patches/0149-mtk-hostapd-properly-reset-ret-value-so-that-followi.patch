From ff28a7959db52b669271aabe0c3de6b8f7dd3109 Mon Sep 17 00:00:00 2001
From: Michael-CY Lee <michael-cy.lee@mediatek.com>
Date: Tue, 11 Mar 2025 16:55:52 +0800
Subject: [PATCH 149/260] mtk: hostapd: properly reset ret value so that
 following errors can be reported

Signed-off-by: Michael-CY Lee <michael-cy.lee@mediatek.com>
---
 src/drivers/driver_nl80211.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 62cbc4024..2b3f47078 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -5771,6 +5771,9 @@ static int wpa_driver_nl80211_set_ap(void *priv,
 				   "nl80211: Frequency set failed: %d (%s)",
 				   ret, strerror(-ret));
 		}
+
+		/* reset ret to the original error value */
+		ret = -ENOBUFS;
 	}
 
 	if (!(msg = nl80211_bss_msg(bss, 0, cmd)) ||
-- 
2.45.2

