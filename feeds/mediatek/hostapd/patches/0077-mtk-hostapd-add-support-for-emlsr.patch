+
 	payload = ((const u8 *) mgmt) + IEEE80211_HDRLEN + 1;
 	action = *payload++;
+	plen = len - IEEE80211_HDRLEN - 2;
 
 	switch (action) {
 	case WLAN_PROT_EHT_LINK_RECONFIG_REQUEST:
