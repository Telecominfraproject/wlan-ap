From 2bd11b3a01f74d84e4a75c5e1369a95ee5bdeceb Mon Sep 17 00:00:00 2001
From: Michael-CY Lee <michael-cy.lee@mediatek.com>
Date: Thu, 24 Jul 2025 11:06:52 +0800
Subject: [PATCH 195/260] mtk: hostapd: fix debug log parameters order in
 ap_sta_disconnect_common()

Signed-off-by: Michael-CY Lee <michael-cy.lee@mediatek.com>
---
 src/ap/sta_info.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/ap/sta_info.c b/src/ap/sta_info.c
index aa5992723..b4febc3db 100644
--- a/src/ap/sta_info.c
+++ b/src/ap/sta_info.c
@@ -1082,7 +1082,7 @@ static void ap_sta_disconnect_common(struct hostapd_data *hapd,
 
 	wpa_printf(MSG_DEBUG,
 		   "reschedule ap_handle_timer timeout (%u sec) for " MACSTR,
-		   MAC2STR(sta->addr), timeout);
+		   timeout, MAC2STR(sta->addr));
 
 	eloop_cancel_timeout(ap_handle_timer, hapd, sta);
 	eloop_register_timeout(timeout, 0, ap_handle_timer, hapd, sta);
-- 
