From 6715365eaa5d5205520b3ec1095a50693c352294 Mon Sep 17 00:00:00 2001
From: Howard Hsu <howard-yh.hsu@mediatek.com>
Date: Wed, 4 Mar 2026 15:08:22 +0800
Subject: [PATCH 251/260] mtk: hostapd: add hostapd config
 he_bcast_twt_disabled and eht_restricted_twt_disabled

Add support for disabling HE Broadcast TWT and EHT Restricted TWT
capabilities in hostapd configuration to enhance control over TWT
features. This update allows configuration of these capabilities based
on hardware support.

Signed-off-by: Howard Hsu <howard-yh.hsu@mediatek.com>

Fix compile error if the config CONFIG_IEEE80211BE is not set.

Signed-off-by: Howard Hsu <howard-yh.hsu@mediatek.com>
---
 hostapd/config_file.c        |  4 ++++
 hostapd/hostapd.conf         | 10 ++++++++++
 src/ap/ap_config.h           |  4 ++++
 src/ap/hostapd.c             |  6 ++++++
 src/ap/hostapd.h             |  2 ++
 src/ap/ieee802_11.h          |  4 ++++
 src/ap/ieee802_11_eht.c      |  3 +++
 src/ap/ieee802_11_he.c       |  5 +++++
 src/ap/ieee802_11_shared.c   | 22 +++++++++++++++++++++-
 src/common/ieee802_11_defs.h |  2 ++
 10 files changed, 61 insertions(+), 1 deletion(-)

diff --git a/hostapd/config_file.c b/hostapd/config_file.c
index fcdb5984d..7620d0c01 100644
--- a/hostapd/config_file.c
+++ b/hostapd/config_file.c
@@ -4045,6 +4045,8 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 			return 1;
 		}
 		conf->mu_onoff = val;
+	} else if (os_strcmp(buf, "he_btwt_disabled") == 0) {
+		bss->he_btwt_disabled = !!atoi(pos);
 #endif /* CONFIG_IEEE80211AX */
 	} else if (os_strcmp(buf, "max_listen_interval") == 0) {
 		bss->max_listen_interval = atoi(pos);
@@ -5274,6 +5276,8 @@ static int hostapd_config_fill(struct hostapd_config *conf,
 		conf->neg_ttlm_support_mode = atoi(pos);
 	} else if (os_strcmp(buf, "robust_av_scs_disabled") == 0) {
 		bss->robust_av_scs_disabled = !!atoi(pos);
+	} else if (os_strcmp(buf, "eht_rtwt_disabled") == 0) {
+		bss->eht_rtwt_disabled = !!atoi(pos);
 #ifdef CONFIG_TESTING_OPTIONS
 	} else if (os_strcmp(buf, "eht_oper_puncturing_override") == 0) {
 		if (get_u16(pos, line, &bss->eht_oper_puncturing_override))
diff --git a/hostapd/hostapd.conf b/hostapd/hostapd.conf
index 3e63f8328..fc9af900f 100644
--- a/hostapd/hostapd.conf
+++ b/hostapd/hostapd.conf
@@ -1188,6 +1188,16 @@ wmm_ac_vo_acm=0
 # 1 = AP does not handle any SCS requests
 #robust_av_scs_disabled=0
 
+# Broadcast TWT disable configuration
+# 0 = enabled if supported by the hardware (default)
+# 1 = disabled
+#he_btwt_disabled=0
+
+# Restricted TWT disable configuration
+# 0 = enabled if supported by the hardware (default)
+# 1 = disabled
+#eht_rtwt_disabled=0
+
 ##### IEEE 802.1X-2004 related configuration ##################################
 
 # Require IEEE 802.1X authorization
diff --git a/src/ap/ap_config.h b/src/ap/ap_config.h
index 7246d4cf1..ea84ce586 100644
--- a/src/ap/ap_config.h
+++ b/src/ap/ap_config.h
@@ -995,6 +995,7 @@ struct hostapd_bss_config {
 
 	bool epcs_disabled;
 	bool robust_av_scs_disabled;
+	bool eht_rtwt_disabled;
 #ifdef CONFIG_TESTING_OPTIONS
 	/*
 	 * If set indicate the AP as disabled in the RNR element included in the
@@ -1003,6 +1004,9 @@ struct hostapd_bss_config {
 	bool mld_indicate_disabled;
 #endif /* CONFIG_TESTING_OPTIONS */
 #endif /* CONFIG_IEEE80211BE */
+#ifdef CONFIG_IEEE80211AX
+	bool he_btwt_disabled;
+#endif
 	int mbssid_index;
 
 	bool spp_amsdu;
diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index 057055bb8..ab8e5b449 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -2799,6 +2799,12 @@ static void hostapd_mld_started(struct hostapd_iface *iface)
 
 		if (hapd->conf->robust_av_scs_disabled)
 			hapd->mld->robust_av_scs_disabled = hapd->conf->robust_av_scs_disabled;
+
+		if (hapd->conf->he_btwt_disabled)
+			hapd->mld->he_btwt_disabled = hapd->conf->he_btwt_disabled;
+
+		if (hapd->conf->eht_rtwt_disabled)
+			hapd->mld->eht_rtwt_disabled = hapd->conf->eht_rtwt_disabled;
 	}
 #endif /* CONFIG_IEEE80211BE */
 }
diff --git a/src/ap/hostapd.h b/src/ap/hostapd.h
index bef1f62ce..e9d483d6e 100644
--- a/src/ap/hostapd.h
+++ b/src/ap/hostapd.h
@@ -631,6 +631,8 @@ struct hostapd_mld {
 
 	bool epcs_disabled;
 	bool robust_av_scs_disabled;
+	bool he_btwt_disabled;
+	bool eht_rtwt_disabled;
 };
 
 #define HOSTAPD_MLD_MAX_REF_COUNT      0xFF
diff --git a/src/ap/ieee802_11.h b/src/ap/ieee802_11.h
index 843fc9cab..9abe99cc4 100644
--- a/src/ap/ieee802_11.h
+++ b/src/ap/ieee802_11.h
@@ -355,6 +355,10 @@ int ieee802_11_send_epcs_req(struct hostapd_data *hapd, struct mld_info *mld,
 int ieee802_11_send_epcs_resp(struct hostapd_data *hapd, struct mld_info *mld,
 			      u8 dialog_token, u16 status, u16 *wmm_idx_tbl);
 int ieee802_11_send_epcs_teardown(struct hostapd_data *hapd, struct mld_info *mld);
+bool hostapd_is_eht_rtwt_disabled(struct hostapd_data *hapd);
 #endif /* CONFIG_IEEE80211BE */
+#ifdef CONFIG_IEEE80211AX
+bool hostapd_is_he_btwt_disabled(struct hostapd_data *hapd);
+#endif /* CONFIG_IEEE80211AX */
 bool hostapd_is_robust_av_scs_disabled(struct hostapd_data *hapd);
 #endif /* IEEE802_11_H */
diff --git a/src/ap/ieee802_11_eht.c b/src/ap/ieee802_11_eht.c
index 1cf5aa28f..c7d8eb287 100644
--- a/src/ap/ieee802_11_eht.c
+++ b/src/ap/ieee802_11_eht.c
@@ -147,6 +147,9 @@ u8 * hostapd_eid_eht_capab(struct hostapd_data *hapd, u8 *eid,
 	if (hostapd_is_robust_av_scs_disabled(hapd))
 		cap->mac_cap &= ~host_to_le16(EHT_MACCAP_SCS_TRAFFIC_DESC);
 
+	if (hostapd_is_eht_rtwt_disabled(hapd))
+		cap->mac_cap &= ~host_to_le16(EHT_MACCAP_RESTRICTED_TWT);
+
 	os_memcpy(cap->phy_cap, eht_cap->phy_cap, EHT_PHY_CAPAB_LEN);
 
 	if (!is_6ghz_op_class(hapd->iconf->op_class))
diff --git a/src/ap/ieee802_11_he.c b/src/ap/ieee802_11_he.c
index 56935ce83..54af382fb 100644
--- a/src/ap/ieee802_11_he.c
+++ b/src/ap/ieee802_11_he.c
@@ -118,6 +118,11 @@ u8 * hostapd_eid_he_capab(struct hostapd_data *hapd, u8 *eid,
 
 	os_memcpy(cap->he_mac_capab_info, he_capab->mac_cap,
 		  HE_MAX_MAC_CAPAB_SIZE);
+
+	if (hostapd_is_he_btwt_disabled(hapd))
+		cap->he_mac_capab_info[HE_MACCAP_BROADCAST_TWT_SUPPORT_IDX] &=
+			~HE_MACCAP_BROADCAST_TWT_SUPPORT;
+
 	os_memcpy(cap->he_phy_capab_info, he_capab->phy_cap,
 		  HE_MAX_PHY_CAPAB_SIZE);
 	epos = (u8 *) &cap->he_basic_supported_mcs_set;
diff --git a/src/ap/ieee802_11_shared.c b/src/ap/ieee802_11_shared.c
index 9ebacbc7d..528f9fd76 100644
--- a/src/ap/ieee802_11_shared.c
+++ b/src/ap/ieee802_11_shared.c
@@ -1324,6 +1324,18 @@ void hostapd_wfa_capab(struct hostapd_data *hapd, struct sta_info *sta,
 		hostapd_wfa_gen_capab(hapd, sta, gen_capa + 2, gen_capa[1]);
 }
 
+#ifdef CONFIG_IEEE80211AX
+bool hostapd_is_he_btwt_disabled(struct hostapd_data *hapd)
+{
+#ifdef CONFIG_IEEE80211BE
+	if (hostapd_is_mld_ap(hapd))
+		return hapd->mld && hapd->mld->he_btwt_disabled;
+#endif
+
+	return hapd->conf->he_btwt_disabled;
+}
+#endif /* CONFIG_IEEE80211AX */
+
 #ifdef CONFIG_IEEE80211BE
 bool hostapd_is_robust_av_scs_disabled(struct hostapd_data *hapd)
 {
@@ -1332,4 +1344,12 @@ bool hostapd_is_robust_av_scs_disabled(struct hostapd_data *hapd)
 
 	return hapd->conf->robust_av_scs_disabled;
 }
-#endif
+
+bool hostapd_is_eht_rtwt_disabled(struct hostapd_data *hapd)
+{
+	if (hostapd_is_mld_ap(hapd))
+		return hapd->mld && hapd->mld->eht_rtwt_disabled;
+
+	return hapd->conf->eht_rtwt_disabled;
+}
+#endif /* CONFIG_IEEE80211BE */
diff --git a/src/common/ieee802_11_defs.h b/src/common/ieee802_11_defs.h
index 5d411376b..c9727bf64 100644
--- a/src/common/ieee802_11_defs.h
+++ b/src/common/ieee802_11_defs.h
@@ -2629,6 +2629,8 @@ struct ieee80211_spatial_reuse {
 /* HE Capabilities Information defines */
 
 #define HE_MACCAP_TWT_RESPONDER			((u8) BIT(2))
+#define HE_MACCAP_BROADCAST_TWT_SUPPORT_IDX	2
+#define HE_MACCAP_BROADCAST_TWT_SUPPORT		((u8) BIT(4))
 
 #define HE_PHYCAP_CHANNEL_WIDTH_SET_IDX		0
 #define HE_PHYCAP_CHANNEL_WIDTH_MASK		((u8) (BIT(1) | BIT(2) | \
-- 
2.45.2

