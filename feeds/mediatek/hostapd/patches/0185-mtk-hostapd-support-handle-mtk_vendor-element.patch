 }
 
+static void check_mtk_vendor_elem(struct hostapd_data *hapd, struct sta_info *sta,
+				  struct ieee802_11_elems *elems)
+{
+	if (!sta || !elems->vendor_mtk)
+		return;
+
+	sta->mtk_sta = 1;
+}
+
