diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index f02fbf892..a78302619 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -4091,6 +4091,15 @@ static void check_mscs_desc_elem(struct hostapd_data *hapd, struct sta_info *sta
