From 9714db03bedc4b0b1e2a2ebe0ab6d4762c61d988 Mon Sep 17 00:00:00 2001
From: Howard Hsu <howard-yh.hsu@mediatek.com>
Date: Thu, 5 Feb 2026 11:14:32 +0800
Subject: [PATCH 253/260] mtk: hostapd: fix the potential memory leak for
 muru_config

Without this commit, the muru_config might be not freed if user does not
type the update command. This commit frees the allocated memory to fix
it.

Signed-off-by: Howard Hsu <howard-yh.hsu@mediatek.com>
---
 src/ap/ap_config.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/ap/ap_config.c b/src/ap/ap_config.c
index 5f79168e7..beb047675 100644
--- a/src/ap/ap_config.c
+++ b/src/ap/ap_config.c
@@ -1068,6 +1068,7 @@ void hostapd_config_free(struct hostapd_config *conf)
 	os_free(conf->acs_chan_bias);
 #endif /* CONFIG_ACS */
 	os_free(conf->edcca_threshold);
+	os_free(conf->muru_config);
 	wpabuf_free(conf->lci);
 	wpabuf_free(conf->civic);
 #ifdef CONFIG_AFC
-- 
2.45.2

