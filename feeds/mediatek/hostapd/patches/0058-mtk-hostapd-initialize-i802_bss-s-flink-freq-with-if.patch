From 9b0e99c77dfa78aceccfc7004ec9c3049e205bdb Mon Sep 17 00:00:00 2001
From: Bo Jiao <Bo.Jiao@mediatek.com>
Date: Thu, 19 Oct 2023 13:38:11 +0800
Subject: [PATCH 058/260] mtk: hostapd: initialize i802_bss's flink->freq with
 iface freq.

Signed-off-by: Bo Jiao <Bo.Jiao@mediatek.com>
---
 hostapd/main.c               | 2 +-
 src/ap/ap_drv_ops.c          | 6 +++---
 src/ap/ap_drv_ops.h          | 2 +-
 src/ap/hostapd.c             | 2 +-
 src/drivers/driver.h         | 2 +-
 src/drivers/driver_nl80211.c | 2 +-
 wpa_supplicant/driver_i.h    | 2 +-
 7 files changed, 9 insertions(+), 9 deletions(-)

diff --git a/hostapd/main.c b/hostapd/main.c
index 236e5a8da..15466a55b 100644
--- a/hostapd/main.c
+++ b/hostapd/main.c
@@ -280,7 +280,7 @@ static int hostapd_driver_init(struct hostapd_iface *iface)
 				   &hapd->drv_priv, force_ifname, if_addr,
 				   params.num_bridge && params.bridge[0] ?
 				   params.bridge[0] : NULL,
-				   1)) {
+				   1, hapd->iface->freq)) {
 			wpa_printf(MSG_ERROR, "Failed to add BSS (BSSID="
 				   MACSTR ")", MAC2STR(hapd->own_addr));
 			os_free(params.bridge);
diff --git a/src/ap/ap_drv_ops.c b/src/ap/ap_drv_ops.c
index 9bc14180a..c54453f1d 100644
--- a/src/ap/ap_drv_ops.c
+++ b/src/ap/ap_drv_ops.c
@@ -378,7 +378,7 @@ int hostapd_vlan_if_add(struct hostapd_data *hapd, const char *ifname)
 #endif /* CONFIG_IEEE80211BE */
 
 	return hostapd_if_add(hapd, WPA_IF_AP_VLAN, ifname, addr,
-			      NULL, NULL, force_ifname, if_addr, NULL, 0);
+			      NULL, NULL, force_ifname, if_addr, NULL, 0, hapd->iface->freq);
 }
 
 
@@ -593,13 +593,13 @@ int hostapd_set_ssid(struct hostapd_data *hapd, const u8 *buf, size_t len)
 int hostapd_if_add(struct hostapd_data *hapd, enum wpa_driver_if_type type,
 		   const char *ifname, const u8 *addr, void *bss_ctx,
 		   void **drv_priv, char *force_ifname, u8 *if_addr,
-		   const char *bridge, int use_existing)
+		   const char *bridge, int use_existing, int freq)
 {
 	if (hapd->driver == NULL || hapd->driver->if_add == NULL)
 		return -1;
 	return hapd->driver->if_add(hapd->drv_priv, type, ifname, addr,
 				    bss_ctx, drv_priv, force_ifname, if_addr,
-				    bridge, use_existing, 1);
+				    bridge, use_existing, 1, freq);
 }
 
 
diff --git a/src/ap/ap_drv_ops.h b/src/ap/ap_drv_ops.h
index 495278a4b..8b4c1df30 100644
--- a/src/ap/ap_drv_ops.h
+++ b/src/ap/ap_drv_ops.h
@@ -62,7 +62,7 @@ int hostapd_set_ssid(struct hostapd_data *hapd, const u8 *buf, size_t len);
 int hostapd_if_add(struct hostapd_data *hapd, enum wpa_driver_if_type type,
 		   const char *ifname, const u8 *addr, void *bss_ctx,
 		   void **drv_priv, char *force_ifname, u8 *if_addr,
-		   const char *bridge, int use_existing);
+		   const char *bridge, int use_existing, int freq);
 int hostapd_if_remove(struct hostapd_data *hapd, enum wpa_driver_if_type type,
 		      const char *ifname);
 int hostapd_if_link_remove(struct hostapd_data *hapd,
diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index 3ae5c5a3c..3523515e7 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -1547,7 +1547,7 @@ int hostapd_setup_bss(struct hostapd_data *hapd, int first, bool start_beacon)
 				   conf->iface, addr, hapd,
 				   &hapd->drv_priv, force_ifname, if_addr,
 				   conf->bridge[0] ? conf->bridge : NULL,
-				   use_existing)) {
+				   use_existing, hapd->iface->freq)) {
 			wpa_printf(MSG_ERROR, "Failed to add BSS (BSSID="
 				   MACSTR ")", MAC2STR(hapd->own_addr));
 			hapd->interface_added = 0;
diff --git a/src/drivers/driver.h b/src/drivers/driver.h
index bc7c8fa19..0740b307e 100644
--- a/src/drivers/driver.h
+++ b/src/drivers/driver.h
@@ -4170,7 +4170,7 @@ struct wpa_driver_ops {
 	int (*if_add)(void *priv, enum wpa_driver_if_type type,
 		      const char *ifname, const u8 *addr, void *bss_ctx,
 		      void **drv_priv, char *force_ifname, u8 *if_addr,
-		      const char *bridge, int use_existing, int setup_ap);
+		      const char *bridge, int use_existing, int setup_ap, int freq);
 
 	/**
 	 * if_remove - Remove a virtual interface
diff --git a/src/drivers/driver_nl80211.c b/src/drivers/driver_nl80211.c
index 0959130bc..ee8630daa 100644
--- a/src/drivers/driver_nl80211.c
+++ b/src/drivers/driver_nl80211.c
@@ -9477,7 +9477,7 @@ static int wpa_driver_nl80211_if_add(void *priv, enum wpa_driver_if_type type,
 				     void *bss_ctx, void **drv_priv,
 				     char *force_ifname, u8 *if_addr,
 				     const char *bridge, int use_existing,
-				     int setup_ap)
+				     int setup_ap, int freq)
 {
 	enum nl80211_iftype nlmode;
 	struct i802_bss *bss = priv;
diff --git a/wpa_supplicant/driver_i.h b/wpa_supplicant/driver_i.h
index fc51784a7..255e2c49b 100644
--- a/wpa_supplicant/driver_i.h
+++ b/wpa_supplicant/driver_i.h
@@ -457,7 +457,7 @@ static inline int wpa_drv_if_add(struct wpa_supplicant *wpa_s,
 	if (wpa_s->driver->if_add)
 		return wpa_s->driver->if_add(wpa_s->drv_priv, type, ifname,
 					     addr, bss_ctx, NULL, force_ifname,
-					     if_addr, bridge, 0, 0);
+					     if_addr, bridge, 0, 0, -1);
 	return -1;
 }
 
-- 
2.45.2

