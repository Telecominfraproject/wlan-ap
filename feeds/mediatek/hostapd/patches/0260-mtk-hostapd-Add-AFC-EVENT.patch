From 1a5e81eab9806327200c6f26b02e3115945ca20b Mon Sep 17 00:00:00 2001
From: Allen Ye <allen.ye@mediatek.com>
Date: Wed, 3 Dec 2025 18:11:21 +0800
Subject: [PATCH 260/260] mtk: hostapd: Add AFC EVENT

Add AFC event
AFC_EVENT_RECEIVED for EasyMesh spec 8.2.5.
AFC_EVENT_COMPLETE for AFC procedure is completed and ap is host on a
available channel.

Signed-off-by: Allen Ye <allen.ye@mediatek.com>
---
 src/ap/afc.c          | 7 ++++++-
 src/ap/hostapd.c      | 5 +++++
 src/common/wpa_ctrl.h | 3 +++
 3 files changed, 14 insertions(+), 1 deletion(-)

diff --git a/src/ap/afc.c b/src/ap/afc.c
index 4d0ff47c2..35bd8d360 100644
--- a/src/ap/afc.c
+++ b/src/ap/afc.c
@@ -14,6 +14,7 @@
 #include "utils/eloop.h"
 #include "utils/json.h"
 #include "common/hw_features_common.h"
+#include "common/wpa_ctrl.h"
 #include "hostapd.h"
 #include "acs.h"
 #include "hw_features.h"
@@ -811,8 +812,11 @@ static int hostapd_afc_send_receive(struct hostapd_iface *iface)
 		goto close_sock;
 
 	ret = hostapd_afc_parse_reply(iface, buf, ret);
-	if (ret)
+	if (ret) {
 		wpa_printf(MSG_ERROR, "Failed parsing AFC reply: %d", ret);
+		goto close_sock;
+	}
+	wpa_msg(iface->bss[0]->msg_ctx, MSG_INFO, AFC_EVENT_RECEIVED);
 close_sock:
 	os_free(buf);
 	iface->afc_request = request_obj;
@@ -1035,6 +1039,7 @@ resched:
 		iface->afc.lpi_mode = true;
 		fallthrough;
 	case AFC_CONTINUE:
+		wpa_msg(iface->bss[0]->msg_ctx, MSG_INFO, AFC_EVENT_COMPLETE);
 		hostapd_drv_txpower_ctrl(iface->bss[0]);
 		break;
 	default:
diff --git a/src/ap/hostapd.c b/src/ap/hostapd.c
index ab8e5b449..1f949cbc5 100644
--- a/src/ap/hostapd.c
+++ b/src/ap/hostapd.c
@@ -3035,6 +3035,11 @@ dfs_offload:
 	}
 #endif /* CONFIG_FST */
 
+#ifdef CONFIG_AFC
+	if (iface->afc.data_valid)
+		wpa_msg(iface->bss[0]->msg_ctx, MSG_INFO, AFC_EVENT_COMPLETE);
+#endif /* CONFIG_AFC */
+
 	hostapd_set_state(iface, HAPD_IFACE_ENABLED);
 	hostapd_owe_update_trans(iface);
 	airtime_policy_update_init(iface);
diff --git a/src/common/wpa_ctrl.h b/src/common/wpa_ctrl.h
index 36312439f..9a5cbd97d 100644
--- a/src/common/wpa_ctrl.h
+++ b/src/common/wpa_ctrl.h
@@ -466,6 +466,9 @@ extern "C" {
  * Parameters: <STA addr> <Generational Capabilities Indication body> */
 #define WFA_GEN_CAPAB_RX "WFA-GEN-CAPAB "
 
+#define AFC_EVENT_RECEIVED "AFC-EVENT-RECEIVED "
+#define AFC_EVENT_COMPLETE "AFC-EVENT-COMPLETE "
+
 #ifndef BIT
 #define BIT(x) (1U << (x))
 #endif
-- 
2.45.2

