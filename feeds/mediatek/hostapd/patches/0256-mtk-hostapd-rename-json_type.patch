From f27e49977c111857926f635861ca7295fe24c642 Mon Sep 17 00:00:00 2001
From: Allen Ye <allen.ye@mediatek.com>
Date: Mon, 3 Nov 2025 16:21:24 +0800
Subject: [PATCH 256/260] mtk: hostapd: rename json_type

FIx redeclaration of json_type on OpenWrt, which is used by json-c and
hostapd self. As for the json-c is included by ucode.

Signed-off-by: Allen Ye <allen.ye@mediatek.com>
---
 src/utils/json.c | 2 +-
 src/utils/json.h | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/utils/json.c b/src/utils/json.c
index 5523f284d..d8df5e695 100644
--- a/src/utils/json.c
+++ b/src/utils/json.c
@@ -551,7 +551,7 @@ struct wpabuf * json_get_member_base64(struct json_token *json,
 }
 
 
-static const char * json_type_str(enum json_type type)
+static const char * json_type_str(enum hostapd_json_type type)
 {
 	switch (type) {
 	case JSON_VALUE:
diff --git a/src/utils/json.h b/src/utils/json.h
index 8448bb0c5..a5f8b3517 100644
--- a/src/utils/json.h
+++ b/src/utils/json.h
@@ -10,7 +10,7 @@
 #define JSON_H
 
 struct json_token {
-	enum json_type {
+	enum hostapd_json_type {
 		JSON_VALUE,
 		JSON_OBJECT,
 		JSON_ARRAY,
-- 
2.45.2

