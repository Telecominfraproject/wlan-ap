From b3780b4ce1b809ee4d608e3b4cc1f10229d89f25 Mon Sep 17 00:00:00 2001
From: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
Date: Tue, 27 Jan 2026 22:29:14 +0800
Subject: [PATCH 131/137] mtk: mac80211: remove identical channel check in
 set_monitor_channel for testmode

Remove identical channel check in set_monitor_channel for testmode

Signed-off-by: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
---
 net/mac80211/cfg.c | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/net/mac80211/cfg.c b/net/mac80211/cfg.c
index 065be4ca..9c6e877d 100644
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -1079,11 +1079,6 @@ static int ieee80211_set_monitor_channel(struct wiphy *wiphy,
 			goto done;
 	}
 
-	if (rcu_access_pointer(sdata->deflink.conf->chanctx_conf) &&
-	    cfg80211_chandef_identical(&sdata->vif.bss_conf.chanreq.oper,
-				       &chanreq.oper))
-		return 0;
-
 	ieee80211_link_release_channel(&sdata->deflink);
 	ret = ieee80211_link_use_channel(&sdata->deflink, &chanreq,
 					 IEEE80211_CHANCTX_SHARED);
-- 
