From 180dc6d4d07a423dcfb209492df47a613e1a2f54 Mon Sep 17 00:00:00 2001
From: MeiChia Chiu <MeiChia.Chiu@mediatek.com>
Date: Mon, 2 Mar 2026 08:50:50 +0800
Subject: [PATCH 134/137] mtk: mac80211: Add debugfs control for AP EML Action
 Frame

Add debugfs entry 'eml_resp' for AP EML Action Frame Response control.
This change is needed due to the integration of the upstream EMLSR patch.
Users can now enable or disable EML Action frame responses via debugfs,
without modifying hostapd config.

Signed-off-by: MeiChia Chiu <MeiChia.Chiu@mediatek.com>
---
 include/net/mac80211.h        |  1 +
 net/mac80211/debugfs_netdev.c | 20 ++++++++++++++++++++
 net/mac80211/eht.c            |  3 +++
 3 files changed, 24 insertions(+)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index 914151da..2d263f24 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -2000,6 +2000,7 @@ struct ieee80211_vif_cfg {
 	bool s1g;
 	bool idle;
 	u8 ap_addr[ETH_ALEN] __aligned(2);
+	u8 eml_resp;
 };
 
 /**
diff --git a/net/mac80211/debugfs_netdev.c b/net/mac80211/debugfs_netdev.c
index b353db7b..16c5ae7a 100644
--- a/net/mac80211/debugfs_netdev.c
+++ b/net/mac80211/debugfs_netdev.c
@@ -751,6 +751,25 @@ static ssize_t ieee80211_if_parse_active_links(struct ieee80211_sub_if_data *sda
 }
 IEEE80211_IF_FILE_RW(active_links);
 
+static ssize_t ieee80211_if_fmt_eml_resp(const struct ieee80211_sub_if_data *sdata,
+					 char *buf, int buflen)
+{
+	return snprintf(buf, buflen, "%u\n", sdata->vif.cfg.eml_resp);
+}
+
+static ssize_t ieee80211_if_parse_eml_resp(struct ieee80211_sub_if_data *sdata,
+					   const char *buf, int buflen)
+{
+	u8 val;
+
+	if (kstrtou8(buf, 0, &val))
+		return -EINVAL;
+	sdata->vif.cfg.eml_resp = val;
+
+	return buflen;
+}
+IEEE80211_IF_FILE_RW(eml_resp);
+
 IEEE80211_IF_LINK_FILE(addr, conf->addr, MAC);
 
 #ifdef CPTCFG_MAC80211_MESH
@@ -874,6 +893,7 @@ static void add_ap_files(struct ieee80211_sub_if_data *sdata)
 	DEBUGFS_ADD(dtim_count);
 	DEBUGFS_ADD(ttlm);
 	DEBUGFS_ADD(num_buffered_multicast);
+	DEBUGFS_ADD(eml_resp);
 	DEBUGFS_ADD_MODE(tkip_mic_test, 0200);
 	DEBUGFS_ADD_MODE(multicast_to_unicast, 0600);
 }
diff --git a/net/mac80211/eht.c b/net/mac80211/eht.c
index cfc0f96a..a885e477 100644
--- a/net/mac80211/eht.c
+++ b/net/mac80211/eht.c
@@ -113,6 +113,9 @@ ieee80211_send_eml_op_mode_notif(struct ieee80211_sub_if_data *sdata,
 	struct ieee80211_mgmt *mgmt;
 	struct sk_buff *skb;
 
+	if (!sdata->vif.cfg.eml_resp)
+		return;
+
 	len += opt_len; /* optional len */
 	skb = dev_alloc_skb(local->tx_headroom + len);
 	if (!skb)
-- 
