From 20b25487ad90650bf60829ba5d708df14feb304f Mon Sep 17 00:00:00 2001
From: Shayne Chen <shayne.chen@mediatek.com>
Date: Thu, 19 Oct 2023 00:27:15 +0800
Subject: [PATCH 038/137] mtk: mac80211: allow multiple links for STA vif

Signed-off-by: Shayne Chen <shayne.chen@mediatek.com>
---
 net/mac80211/link.c | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/net/mac80211/link.c b/net/mac80211/link.c
index e8601db0..c4a2a127 100644
--- a/net/mac80211/link.c
+++ b/net/mac80211/link.c
@@ -182,10 +182,7 @@ static void ieee80211_set_vif_links_bitmaps(struct ieee80211_sub_if_data *sdata,
 		WARN_ON(dormant_links);
 		break;
 	case NL80211_IFTYPE_STATION:
-		if (sdata->vif.active_links)
-			break;
 		sdata->vif.active_links = valid_links & ~dormant_links;
-		WARN_ON(hweight16(sdata->vif.active_links) > 1);
 		break;
 	default:
 		WARN_ON(1);
-- 
