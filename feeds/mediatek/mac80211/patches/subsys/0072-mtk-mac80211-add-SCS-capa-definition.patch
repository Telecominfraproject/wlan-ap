From 42502858a2d3fbc36e5707739c9b4fa8bdfce98c Mon Sep 17 00:00:00 2001
From: Howard Hsu <howard-yh.hsu@mediatek.com>
Date: Fri, 5 Jul 2024 09:42:46 +0800
Subject: [PATCH 072/137] mtk: mac80211: add SCS capa definition

Add scs capabilities definition in extended capabilities ie.

Signed-off-by: Howard Hsu <howard-yh.hsu@mediatek.com>

---
 include/linux/ieee80211.h | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/include/linux/ieee80211.h b/include/linux/ieee80211.h
index 0aa2fb8f..ecdda6c9 100644
--- a/include/linux/ieee80211.h
+++ b/include/linux/ieee80211.h
@@ -2016,6 +2016,8 @@ enum ieee80211_tdls_actioncode {
 #define WLAN_EXT_CAPA5_TDLS_PROHIBITED	BIT(6)
 #define WLAN_EXT_CAPA5_TDLS_CH_SW_PROHIBITED	BIT(7)
 
+#define WLAN_EXT_CAPA7_SCS_SUPPORT 	BIT(6)
+
 #define WLAN_EXT_CAPA8_TDLS_WIDE_BW_ENABLED	BIT(5)
 #define WLAN_EXT_CAPA8_OPMODE_NOTIF	BIT(6)
 
