From 81a69a992235207ef0e2ffd411dda50b6087195a Mon Sep 17 00:00:00 2001
From: Howard Hsu <howard-yh.hsu@mediatek.com>
Date: Mon, 8 Dec 2025 19:22:36 +0800
Subject: [PATCH 130/137] mtk: mac80211: check twt capa before handling twt
 action frame

Check whether cpaability IEEE80211_HE_MAC_CAP2_BCAST_TWT or
IEEE80211_EHT_MAC_CAP0_RESTRICTED_TWT is set before handling Broadcast
TWT or Restricted TWT action frame.

Signed-off-by: Howard Hsu <howard-yh.hsu@mediatek.com>
---
 include/linux/ieee80211-he.h |  5 +++++
 include/net/mac80211.h       |  5 +++++
 net/mac80211/cfg.c           |  6 ++++++
 net/mac80211/s1g.c           | 35 +++++++++++++++++++++++++++++++++++
 4 files changed, 51 insertions(+)

diff --git a/include/linux/ieee80211-he.h b/include/linux/ieee80211-he.h
index ee89f8a2..95aedf1a 100644
--- a/include/linux/ieee80211-he.h
+++ b/include/linux/ieee80211-he.h
@@ -103,6 +103,11 @@ struct ieee80211_twt_teardown {
 	u8 all:1;
 } __packed;
 
+enum ieee80211_btwt_recommendation {
+	IEEE80211_BTWT_RECOMM_NO_CONSTRAINT = 0,
+	IEEE80211_BTWT_RECOMM_RTWT_SP = 4,
+};
+
 /**
  * struct ieee80211_he_cap_elem - HE capabilities element
  * @mac_cap_info: HE MAC Capabilities Information
diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index c8e4de5b..645e578b 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -763,6 +763,8 @@ struct ieee80211_parsed_tpe {
  *	(as opposed to hearing its value from another link's beacon).
  * @s1g_long_beacon_period: number of beacon intervals between each long
  *	beacon transmission.
+ * @he_btwt_supported: does this BSS support HE broadcast TWT
+ * @eht_rtwt_supported: does this BSS support EHT restricted TWT
  */
 struct ieee80211_bss_conf {
 	struct ieee80211_vif *vif;
@@ -867,6 +869,9 @@ struct ieee80211_bss_conf {
 	u8 bss_param_ch_cnt_link_id;
 
 	u8 s1g_long_beacon_period;
+
+	bool he_btwt_supported;
+	bool eht_rtwt_supported;
 };
 
 /**
diff --git a/net/mac80211/cfg.c b/net/mac80211/cfg.c
index 8174f45b..065be4ca 100644
--- a/net/mac80211/cfg.c
+++ b/net/mac80211/cfg.c
@@ -1577,6 +1577,9 @@ static int ieee80211_start_ap(struct wiphy *wiphy, struct net_device *dev,
 		link_conf->he_full_ul_mumimo =
 			params->he_cap->phy_cap_info[2] &
 				IEEE80211_HE_PHY_CAP2_UL_MU_FULL_MU_MIMO;
+		link_conf->he_btwt_supported =
+			params->he_cap->mac_cap_info[2] &
+				IEEE80211_HE_MAC_CAP2_BCAST_TWT;
 	}
 
 	if (params->eht_cap) {
@@ -1604,6 +1607,9 @@ static int ieee80211_start_ap(struct wiphy *wiphy, struct net_device *dev,
 		link_conf->eht_disable_mcs15 =
 			u8_get_bits(params->eht_oper->params,
 				    IEEE80211_EHT_OPER_MCS15_DISABLE);
+		link_conf->eht_rtwt_supported =
+			params->eht_cap->fixed.mac_cap_info[0] &
+				IEEE80211_EHT_MAC_CAP0_RESTRICTED_TWT;
 	} else {
 		link_conf->eht_su_beamformer = false;
 		link_conf->eht_su_beamformee = false;
diff --git a/net/mac80211/s1g.c b/net/mac80211/s1g.c
index 6b52fa8f..d54fac5e 100644
--- a/net/mac80211/s1g.c
+++ b/net/mac80211/s1g.c
@@ -166,8 +166,29 @@ ieee80211_s1g_rx_twt_setup(struct ieee80211_sub_if_data *sdata,
 	struct ieee80211_mgmt *mgmt = (void *)skb->data;
 	struct ieee80211_twt_setup *twt = (void *)mgmt->u.action.u.s1g.variable;
 	struct ieee80211_twt_params *twt_agrt = (void *)twt->params;
+	struct ieee80211_bss_conf *bss_conf;
+	bool he_btwt, eht_rtwt;
 	int ret;
 
+	rcu_read_lock();
+	bss_conf = rcu_dereference(sdata->vif.link_conf[link_id]);
+	if (!bss_conf) {
+		rcu_read_unlock();
+		return;
+	}
+	he_btwt = bss_conf->he_btwt_supported;
+	eht_rtwt = bss_conf->eht_rtwt_supported;
+	rcu_read_unlock();
+
+	if (twt->control & IEEE80211_TWT_CONTROL_NEG_TYPE_BROADCAST) {
+		if (!he_btwt)
+			return;
+
+		if ((le16_get_bits(twt_agrt->req_type, IEEE80211_TWT_REQTYPE_BTWT_RECM) ==
+		    IEEE80211_BTWT_RECOMM_RTWT_SP) && !eht_rtwt)
+			return;
+	}
+
 	if (twt->control & IEEE80211_TWT_CONTROL_NEG_TYPE_BROADCAST &&
 	    (le16_get_bits(twt_agrt->req_type, IEEE80211_TWT_REQTYPE_SETUP_CMD) ==
 	     TWT_SETUP_CMD_DEMAND)) {
@@ -199,6 +220,20 @@ ieee80211_s1g_rx_twt_teardown(struct ieee80211_sub_if_data *sdata,
 {
 	struct ieee80211_mgmt *mgmt = (struct ieee80211_mgmt *)skb->data;
 	struct ieee80211_twt_teardown *td = (void *)mgmt->u.action.u.s1g.variable;
+	struct ieee80211_bss_conf *bss_conf;
+	bool he_btwt;
+
+	rcu_read_lock();
+	bss_conf = rcu_dereference(sdata->vif.link_conf[link_id]);
+	if (!bss_conf) {
+		rcu_read_unlock();
+		return;
+	}
+	he_btwt = bss_conf->he_btwt_supported;
+	rcu_read_unlock();
+
+	if (td->neg_type == IEEE80211_TWT_NEGO_TYPE_BTWT_MBR_MGMT && !he_btwt)
+		return;
 
 	if (td->all)
 		return; /* Not supported yet */
-- 
2.45.2

