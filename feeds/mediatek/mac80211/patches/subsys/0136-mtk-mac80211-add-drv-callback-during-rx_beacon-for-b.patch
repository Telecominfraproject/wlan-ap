From 4bc9f945e894c111e1e8d09ca1cda2912ae7edb3 Mon Sep 17 00:00:00 2001
From: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
Date: Thu, 5 Mar 2026 15:55:44 +0800
Subject: [PATCH 136/137] mtk: mac80211: add drv callback during rx_beacon for
 bcn mon 11v rework

When the STA is connected to an 11v non-TX BSS, the beacon monitor cannot
work in mt76 driver, as no actual is sent from the AP.
Additionally, it is hard for driver to recognize the beacon of the TX BSS of its
connected AP in the rx path.
Therefore, the beacon receiving mechanism is moved from the driver to mac80211.

Signed-off-by: StanleyYP Wang <StanleyYP.Wang@mediatek.com>
Signed-off-by: Shayne Chen <shayne.chen@mediatek.com>
---
 include/net/mac80211.h | 12 ++++++++++++
 net/mac80211/mlme.c    | 10 ++++++++++
 2 files changed, 22 insertions(+)

diff --git a/include/net/mac80211.h b/include/net/mac80211.h
index 2d263f24..edbd0e34 100644
--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -423,12 +423,14 @@ enum ieee80211_bss_change {
  * @BA_FRAME_TIMEOUT: Frames were released from the reordering buffer because
  *	they timed out. This won't be called for each frame released, but only
  *	once each time the timeout triggers.
+ * @BCN_RX_EVENT: a beacon was received
  */
 enum ieee80211_event_type {
 	RSSI_EVENT,
 	MLME_EVENT,
 	BAR_RX_EVENT,
 	BA_FRAME_TIMEOUT,
+	BCN_RX_EVENT,
 };
 
 /**
@@ -499,12 +501,21 @@ struct ieee80211_ba_event {
 	u16 ssn;
 };
 
+/**
+ * struct ieee80211_bcn_event - data attached to %BCN_RX_EVENT
+ * @link_id: the link that receives beacon
+ */
+struct ieee80211_bcn_event {
+	unsigned int link_id;
+};
+
 /**
  * struct ieee80211_event - event to be sent to the driver
  * @type: The event itself. See &enum ieee80211_event_type.
  * @u.rssi: relevant if &type is %RSSI_EVENT
  * @u.mlme: relevant if &type is %AUTH_EVENT
  * @u.ba: relevant if &type is %BAR_RX_EVENT or %BA_FRAME_TIMEOUT
+ * @u.bcn: relevant if &type is %BCN_RX_EVENT
  * @u:union holding the fields above
  */
 struct ieee80211_event {
@@ -513,6 +524,7 @@ struct ieee80211_event {
 		struct ieee80211_rssi_event rssi;
 		struct ieee80211_mlme_event mlme;
 		struct ieee80211_ba_event ba;
+		struct ieee80211_bcn_event bcn;
 	} u;
 };
 
diff --git a/net/mac80211/mlme.c b/net/mac80211/mlme.c
index dd17d531..d7bdf96f 100644
--- a/net/mac80211/mlme.c
+++ b/net/mac80211/mlme.c
@@ -2544,6 +2544,10 @@ static void ieee80211_csa_switch_work(struct wiphy *wiphy,
 	struct ieee80211_sub_if_data *sdata = link->sdata;
 	struct ieee80211_local *local = sdata->local;
 	struct ieee80211_if_managed *ifmgd = &sdata->u.mgd;
+	struct ieee80211_event event = {
+		.type = BCN_RX_EVENT,
+		.u.bcn.link_id = link->link_id,
+	};
 	int ret;
 
 	if (!ieee80211_sdata_running(sdata))
@@ -2658,6 +2662,7 @@ static void ieee80211_csa_switch_work(struct wiphy *wiphy,
 			return;
 	}
 
+	drv_event_callback(local, sdata, &event);
 	/*
 	 * Reset the beacon monitor and connection monitor timers when CSA
 	 * is active for all links in MLO when channel switch occurs in all
@@ -7640,6 +7645,9 @@ static void ieee80211_rx_mgmt_beacon(struct ieee80211_link_data *link,
 		.from_ap = true,
 		.type = le16_to_cpu(mgmt->frame_control) & IEEE80211_FCTL_TYPE,
 	};
+	struct ieee80211_event event = {
+		.type = BCN_RX_EVENT,
+	};
 
 	lockdep_assert_wiphy(local->hw.wiphy);
 
@@ -7731,6 +7739,8 @@ static void ieee80211_rx_mgmt_beacon(struct ieee80211_link_data *link,
 		ieee80211_reset_ap_probe(sdata);
 	}
 
+	event.u.bcn.link_id = link->link_id;
+	drv_event_callback(local, sdata, &event);
 	/*
 	 * Push the beacon loss detection into the future since
 	 * we are processing a beacon from the AP just now.
-- 
2.45.2

