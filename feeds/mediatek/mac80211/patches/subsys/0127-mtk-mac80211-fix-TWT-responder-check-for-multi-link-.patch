From 3735613260748642dac4242ac95311868e1fc373 Mon Sep 17 00:00:00 2001
From: Howard Hsu <howard-yh.hsu@mediatek.com>
Date: Wed, 24 Sep 2025 14:37:01 +0800
Subject: [PATCH 127/137] mtk: mac80211: fix TWT responder check for multi-link
 operation

Fix issue in TWT action processing by correctly referencing bss_conf
for multi-link devices, ensuring proper TWT responder checks and
enhancing compatibility with AP mode.

Signed-off-by: Howard Hsu <howard-yh.hsu@mediatek.com>
---
 net/mac80211/rx.c | 6 ++----
 1 file changed, 2 insertions(+), 4 deletions(-)

diff --git a/net/mac80211/rx.c b/net/mac80211/rx.c
index 72b06370..2e68f526 100644
--- a/net/mac80211/rx.c
+++ b/net/mac80211/rx.c
@@ -3580,18 +3580,16 @@ ieee80211_process_rx_twt_action(struct ieee80211_rx_data *rx)
 {
 	struct ieee80211_mgmt *mgmt = (struct ieee80211_mgmt *)rx->skb->data;
 	struct ieee80211_sub_if_data *sdata = rx->sdata;
+	struct ieee80211_bss_conf *bss_conf = rx->link->conf;
 
 	/* TWT actions are only supported in AP for the moment */
 	if (sdata->vif.type != NL80211_IFTYPE_AP)
 		return false;
 
-	if (!sdata->vif.bss_conf.twt_responder)
-		return false;
-
 	if (!rx->local->ops->add_twt_setup)
 		return false;
 
-	if (!sdata->vif.bss_conf.twt_responder)
+	if (!bss_conf->twt_responder)
 		return false;
 
 	if (!rx->sta)
-- 
