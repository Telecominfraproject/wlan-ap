
dev_tty="$1"
baudrate="$2"
gpio_backdoor="$3"
gpio_reset="$4"
nordic_fw="$5"

##ble backdoor
echo $gpio_backdoor > /sys/class/gpio/export
echo "out" > /sys/class/gpio/gpio$gpio_backdoor/direction
echo 0 > /sys/class/gpio/gpio$gpio_backdoor/value

##ble reset
echo $gpio_reset > /sys/class/gpio/export
echo "out" > /sys/class/gpio/gpio$gpio_reset/direction
echo 0 > /sys/class/gpio/gpio$gpio_reset/value
sleep 1
echo 1 > /sys/class/gpio/gpio$gpio_reset/value

/usr/sbin/mcumgr --conntype serial --connstring=$dev_tty,baud=$baudrate,mtu=1024 image upload $nordic_fw

##ble backdoor
echo 1 > /sys/class/gpio/gpio$gpio_backdoor/value

##ble reset
echo 0 > /sys/class/gpio/gpio$gpio_reset/value
echo 1 > /sys/class/gpio/gpio$gpio_reset/value
