From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:01 2001
From: Sujeet Kumar <sujeet.kumar@inventum.net>
Date: Tue, 24 Jun 2026 09:30:00 +0530
Subject: [PATCH] ipq40xx: add MAC address support for udaya a5-id2

Signed-off-by: Sujeet Kumar <sujeet.kumar@inventum.net>
---
 target/linux/ipq40xx/base-files/etc/board.d/02_network | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/target/linux/ipq40xx/base-files/etc/board.d/02_network b/target/linux/ipq40xx/base-files/etc/board.d/02_network
--- a/target/linux/ipq40xx/base-files/etc/board.d/02_network
+++ b/target/linux/ipq40xx/base-files/etc/board.d/02_network
@@ -195,6 +195,11 @@ ipq40xx_setup_macs()
 		lan_mac=$(cat /sys/firmware/mikrotik/hard_config/mac_base)
 		label_mac="$lan_mac"
 		;;
+	udaya,a5-id2)
+		wan_mac=$(cat /sys/class/net/eth0/address)
+		lan_mac=$(cat /sys/class/net/eth1/address)
+		label_mac=$wan_mac
+		;;
 	esac

 	[ -n "$lan_mac" ] && ucidef_set_interface_macaddr "lan" $lan_mac
