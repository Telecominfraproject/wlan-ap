From 7a6440b62d9dac259fb7f1920dd02afa63dba71c Mon Sep 17 00:00:00 2001
From: "niko.lei" <niko.lei@cybertan.com.tw>
Date: Tue, 31 Mar 2026 10:15:06 +0800
Subject: [PATCH] base files boot img select

---
 package/base-files/files/lib/upgrade/stage2 | 36 ++++++++++++++++++++-
 1 file changed, 35 insertions(+), 1 deletion(-)

diff --git a/package/base-files/files/lib/upgrade/stage2 b/package/base-files/files/lib/upgrade/stage2
index 5ce0b3549c..1ec150ed01 100755
--- a/package/base-files/files/lib/upgrade/stage2
+++ b/package/base-files/files/lib/upgrade/stage2
@@ -15,6 +15,32 @@ RAMFS_COPY_DATA=	# extra data files
 
 include /lib/upgrade
 
+set_boot_img_vars() {
+    BOOT_IMG_DIR="/usr/share/boot_img"
+    board="$(cat /tmp/sysinfo/board_name)"
+    case $board in
+    sonicfi,rap650c)
+        BOOT_IMG_TGZ="${BOOT_IMG_DIR}/openwrt-ipq807x-u-boot.tar.gz"
+        BOOT_IMG_FILE="openwrt-ipq807x-u-boot.mbn"
+        ;;
+    sonicfi,rap630c-311g|\
+    sonicfi,rap630w-311g|\
+    sonicfi,rap630w-312g)
+        BOOT_IMG_TGZ="${BOOT_IMG_DIR}/openwrt-ipq5018-u-boot.tar.gz"
+        BOOT_IMG_FILE="openwrt-ipq5018-u-boot.mbn"
+        ;;
+    sonicfi,rap7110c-341x|\
+    sonicfi,rap750w-311a|\
+    sonicfi,rap750e-s|\
+    sonicfi,rap750e-h)
+        BOOT_IMG_TGZ="${BOOT_IMG_DIR}/openwrt-ipq5332-u-boot.tar.gz"
+        BOOT_IMG_FILE="openwrt-ipq5332-u-boot.mbn"
+        ;;
+    *)
+        v "error: unknown board '$board'"
+        ;;
+    esac
+}
 
 supivot() { # <new_root> <old_root>
 	/bin/mount | grep "on $1 type" 2>&- 1>&- || /bin/mount -o bind $1 $1
@@ -56,7 +82,8 @@ switch_to_ramfs() {
 	install_file /etc/resolv.conf /lib/*.sh /lib/functions/*.sh	\
 		/lib/upgrade/*.sh /lib/upgrade/do_stage2 		\
 		/usr/share/libubox/jshn.sh /usr/sbin/fw_setenv		\
-		/etc/fw_env.config $RAMFS_COPY_DATA
+		/etc/fw_env.config $RAMFS_COPY_DATA			\
+		${BOOT_IMG_DIR}/${BOOT_IMG_FILE}
 
 	mkdir -p $RAM_ROOT/var/lock
 
@@ -168,6 +195,13 @@ fi
 
 if [ -n "$(rootfs_type)" ]; then
 	v "Switching to ramdisk..."
+
+	set_boot_img_vars
+	if [ -f "$BOOT_IMG_TGZ" ]; then
+		tar -xzf $BOOT_IMG_TGZ -C $BOOT_IMG_DIR
+	else
+		v "boot img file does not exist..."
+	fi	
 	switch_to_ramfs
 fi
 
-- 
2.34.1

