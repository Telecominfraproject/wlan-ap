From 6c077aec05d9e59aa2b40c0920199bb8d7f915f6 Mon Sep 17 00:00:00 2001
From: John Crispin <john@phrozen.org>
Date: Tue, 21 Apr 2026 08:29:08 +0200
Subject: [PATCH] hostapd: emit inline r0kh/r1kh instead of rxkh_file

The qca-wifi-6 build uses a hostap snapshot (2021-02-20) predating the
rxkh_file config option, so hostapd rejects the line with
"unknown configuration item 'rxkh_file'" and config_set fails. Emit
r0kh= / r1kh= entries directly in bss_conf; this format is accepted
by both the old snapshot and current hostap, so a single wifi-scripts
code path works across all variants.

Also fix an operator-precedence bug in normalize_rxkhs() in hostapd.uc
so the helper is correct whenever it is still exercised via an
explicit rxkh_file path: 'if(!k[2] = ...)' parses as '(!k[2]) = ...'
which is an invalid lvalue; wrap the assignment in parentheses so the
intended assign-then-negate semantics survive.

Fixes: WIFI-15449
Signed-off-by: John Crispin <john@phrozen.org>
---
 .../wifi-scripts/files/lib/netifd/hostapd.sh  | 24 +++++++------------
 .../network/services/hostapd/files/hostapd.uc |  2 +-
 2 files changed, 9 insertions(+), 17 deletions(-)

diff --git a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
index b56397dbb1..5df4a58578 100644
--- a/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
+++ b/package/network/config/wifi-scripts/files/lib/netifd/hostapd.sh
@@ -407,7 +407,7 @@ hostapd_common_add_bss_config() {
 
 	config_add_boolean ieee80211r pmk_r1_push ft_psk_generate_local ft_over_ds
 	config_add_int r0_key_lifetime reassociation_deadline ft_l2_refresh
-	config_add_string mobility_domain r1_key_holder rxkh_file ft_iface ft_key
+	config_add_string mobility_domain r1_key_holder ft_iface ft_key
 	config_add_array r0kh r1kh
 
 	config_add_int ieee80211w_max_timeout ieee80211w_retry_timeout
@@ -1046,7 +1046,7 @@ hostapd_set_bss_options() {
 			[ -n "$ft_l2_refresh" ] && append bss_conf "ft_l2_refresh=$ft_l2_refresh" "$N"
 
 			if [ "$ft_psk_generate_local" -eq "0" ]; then
-				json_get_vars r0_key_lifetime r1_key_holder pmk_r1_push rxkh_file ft_key
+				json_get_vars r0_key_lifetime r1_key_holder pmk_r1_push ft_key
 				json_get_values r0kh r0kh
 				json_get_values r1kh r1kh
 
@@ -1071,20 +1071,12 @@ hostapd_set_bss_options() {
 				append bss_conf "r0_key_lifetime=$r0_key_lifetime" "$N"
 				append bss_conf "pmk_r1_push=$pmk_r1_push" "$N"
 
-				if [ -z "$rxkh_file" ]; then
-					set_default rxkh_file /var/run/hostapd-$ifname.rxkh
-					[ -e "$rxkh_file" ] && rm -f "$rxkh_file"
-					touch "$rxkh_file"
-
-					for kh in $r0kh; do
-						append rxkhs "r0kh=${kh//,/ }" "$N"
-					done
-					for kh in $r1kh; do
-						append rxkhs "r1kh=${kh//,/ }" "$N"
-					done
-					echo "$rxkhs" > "$rxkh_file"
-				fi
-				append bss_conf "rxkh_file=$rxkh_file" "$N"
+				for kh in $r0kh; do
+					append bss_conf "r0kh=${kh//,/ }" "$N"
+				done
+				for kh in $r1kh; do
+					append bss_conf "r1kh=${kh//,/ }" "$N"
+				done
 			fi
 		fi
 
diff --git a/package/network/services/hostapd/files/hostapd.uc b/package/network/services/hostapd/files/hostapd.uc
index 059ea6c7f3..92cebf0e85 100644
--- a/package/network/services/hostapd/files/hostapd.uc
+++ b/package/network/services/hostapd/files/hostapd.uc
@@ -402,7 +402,7 @@ function normalize_rxkhs(txt)
 		if(match(k[0], /^r1kh/)) {
 			k[1] = lc(k[1]);
 		}
-		if(!k[2] = hostapd.rkh_derive_key(k[2])) {
+		if (!(k[2] = hostapd.rkh_derive_key(k[2]))) {
 			return;
 		}
 		return join(" ", k);
-- 
2.34.1

