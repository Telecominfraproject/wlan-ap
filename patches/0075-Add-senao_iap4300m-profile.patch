 		CI_ROOT_UBIPART=ubi
 		nand_do_upgrade "$1"
 		;;
+	senao,iap4300m)
+		CI_UBIPART="ubi_1"
+		nand_do_upgrade "$1"
+		;;
 	*)
 		nand_do_upgrade "$1"
 		;;
@@ -158,3 +174,14 @@ platform_pre_upgrade() {
 		;;
 	esac
 }
+
+platform_post_upgrade_success() {
+	local board=$(board_name)
+
+	case "$board" in
+	senao,iap4300m)
+		senao_swap_active_fw
+		;;
+	esac
+}
